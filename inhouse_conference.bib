  author = {Barresi, R. Baxter &J.},
  booktitle = {Fourth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1978},
  abstract = {Cooperative responding in the prisoner's dilennna game has been increased from a free play 30% to 80% when a preprogrammed tit- for-tat strategy is used by the "partner". This strategy involves responding on each trial with the real subject's previous response. Thus, the subject is rewarded for a cooperative response (i.e., with cooperation) and punished for a competitive response (i.e., with competition). The effectiveness of this and two other preprogrammed strategies were compared in a three-choice mixed-motive game. The results of the experiment suggest that the reward and punish strategy of tit-for-tat is more effective in producing cooperation than other more "altruistic" strategies. Furthermore, in the three-choice game this strategy elicited 95% cooperation in the last 30 of the 120 trials.},
}

