  year = {1995},
  abstract = {Previous research suggests that semantic processing using imagery reduces priming on implicit retrieval tasks of memory while increasing performance on explicit tasks. Eighty undergraduates were randomly assigned to study conditions involving the reading of words, imagery of the words, imagery of different words, and reading of words followed by reading different words. The implicit and explicit retrieval tests were word stem completion and cued recall, respectively. Preliminary results will be discussed.},
