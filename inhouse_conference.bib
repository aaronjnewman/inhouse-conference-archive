@inproceedings{matheson1995initial,
  title = {Initial Steps Toward A Model Of Numerosity Discrimination In The Pigeon},
  author = {Matheson, W.R. and Gadbois, Simon and Honig, W. K.},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {A series of studies has shown that pigeons can estimate the relative and absolute numerosities of arrays of small elements, and can discriminate related properties such as uniformity. These abilities have been demonstrated with both successive and simultaneous discrimination procedures, and with elements which differed on dimensions including color, shape, and size. We have begun to develop an information processing model to provide a framework to explain these results, and, more specifically, to analyze relative numerosity discriminations as secondary to concurrent processes of absolute discrimination. Our model is based on the work of J. Gibbon, R. Church, and C.R. Gallistel, particularly on Gibbon's scalar timing theory. We are also using Monte Carlo simulations to derive predicted relative numerosity gradients from data obtained during absolute numerosity tasks. In future research, the collection of trial by trial data will assist in narrowing the range of possible models.},
  note = {Poster; booktitle inferred},
}

