@inproceedings{klein2013neo,
  title = {A neo-Hebbian blueprint for the integration of neuro-psychological science and the mission of our Department},
  author = {Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {With Hebb's ideas providing a backdrop, the recent history of our discipline will be related to a (somewhat) personalized history of the department. Divisions based on workplace (laboratory versus clinic), type of work (studies of brain versus behavior; animals versus humans), sub-discipline (development, perception, personality, learning, etc.) and favorite causal mechanism (nature vs nurture) characterize these histories. Importantly, conceptual, methodological and technological innovations have made it possible for us to implement Hebb's neuropsychological vision of the discipline through an integrated effort to understand how nature and nurture shape the neural networks that underlie the organization of our overt and covert behaviors.},
  note = {QA: needs-split-review; Split from T50 at: 'A neo-Hebbian blueprint for the integrat'},
}

@inproceedings{krigolson2013future,
  title = {The future of psychology and neuroscience},
  author = {Krigolson, Olav},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Our increasing ability to see into the mind has helped scientists adapt theory to match the computations that are actually performed within the brain. For example, rational choice theory would posit that when faced with a decision, one should always choose the response option with the highest utility, or value. However, that is not always the case. When humans play the “ultimatum game” frequently people make irrational decisions - they reject proffered money in the name of “fairness”. Functional imaging has given us insight into why this occurs, and has forced a reconciliation of rational choice theory with psychological theory. As we head into the future, technological advances in human neuroimaging will only allow us to see further into the processes of the mind and explain other phenomenon. For instance, recent advances in neuroimaging have taken us into the realm of mind reading - a technology that knows what we are thinking as we are thinking it. Not only does research like this give us better insight into why we do and say the things we do, but it also puts us right in front of Pandora's Box - forcing to us to an understanding that we might not want to have.},
  note = {QA: needs-split-review; Split from T50 at: 'The future of psychology and neuroscienc'},
}

@inproceedings{gralnick2013perfectionisa,
  title = {Is Perfectionism a Vulnerability Factor for Depression After Controlling for Neuroticism?},
  author = {Gralnick, Tara M and Sherry, Simon},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Extensive evidence suggests neuroticism (i.e., a dispositional tendency to experience negative emotional states) is a higher order personality trait that shares substantial variance with perfectionism dimensions and depressive symptoms (Graham et al., 2010; Sherry et al., 2012). Such evidence raises an important question: are perfectionism dimensions vulnerability factors for depressive symptoms after controlling for neuroticism? The present meta-analysis examined the existing evidence testing if perfectionism dimensions (i.e., self-oriented perfectionism, socially prescribed perfectionism, concern over mistakes, doubts about actions, and perfectionistic attitudes) predict changes in depressive symptoms after controlling for neuroticism. A comprehensive meta-analysis of 10 longitudinal studies involving 1858 participants from undergraduate, community, and psychiatric samples indicated all five perfectionism dimensions significantly predicted changes in depressive symptoms after neuroticism was taken into account. Perfectionism dimensions consistently predicted changes in depressive symptoms across a wide range of samples, methods, and measures. Observed effect sizes were small to moderate in magnitude. Results lend credence to and bring coherence to theoretical accounts, case histories, and empirical studies suggesting perfectionism dimensions are part of the premorbid personality of people vulnerable to depressive symptoms. Results also suggest perfectionism dimensions are unique lower order personality traits that add incrementally to understanding of depressive symptoms above and beyond neuroticism. Perfectionism dimensions appear neither redundant with nor captured by neuroticism. Findings from the present meta-analysis are incongruent with a view of self-oriented perfectionism as an adaptive personality trait associated with positive outcomes. In contrast, results indicate self-oriented perfectionism may represent a form of counterproductive overstriving that confers vulnerability to depressive symptoms. Although self-oriented perfectionism is often labeled as adaptive, such assertions appear premature.},
  note = {QA: needs-split-review; Split from T50-split5 at: 'Is Perfectionism'},
}

@inproceedings{glowacka2013genito,
  title = {Genito-pelvic pain during pregnancy and postpartum: The prospective impact of pain-related anxiety and hypervigilance to pain},
  author = {Glowacka, Maria},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Background. Genital and pelvic (genito-pelvic) pain is common at three months postpartum (Barrett et al., 1999). However, there is limited knowledge regarding the course and specific symptom profile (e.g., onset, location) of this pain in pregnancy and after childbirth. Further, pain-related anxiety and hypervigilance to pain have been associated with increased genital pain intensity in women, unrelated to childbirth (Desrochers et al., 2009). These relationships have not been examined in postpartum populations, or prospectively. Research Questions. The following research questions were examined: (1) What is the prevalence and symptom profile of genito-pelvic pain during pregnancy and at three months postpartum? (2) What is the impact of pain-related anxiety and hypervigilance to pain in pregnancy on genito-pelvic pain quality and intensity at three months postpartum? Method. One hundred forty-three first-time expectant mothers completed measures of pain-related anxiety and hypervigilance to pain. Those reporting genito-pelvic pain in pregnancy and/or at three months postpartum completed measures of the quality and average intensity of their genito-pelvic pain. Results. Of 143 women, 70 (49%) reported genito-pelvic pain in pregnancy (88% reported developing the pain during pregnancy). Genital pain was reported in 21% of women, pelvic pain in 24%, and both genital and pelvic pain in 47%. At three months postpartum, 29 (27%) women reported genito-pelvic pain. The pain resolved for 30/70 (43%) women, persisted for 21/70 (30%), and 8/29 (28%) women reported a new onset of genito-pelvic pain after childbirth. At postpartum, 52% of women reported genital pain, 22% pelvic pain, and 26% both genital and pelvic pain. Controlling for breastfeeding, higher pain-related anxiety and hypervigilance to pain during pregnancy accounted for 40% and 33% of the variance in the quality and average genito-pelvic pain intensity at three months postpartum, respectively. Only pain-related anxiety was an independent predictor for both the quality, β = .43, p = .06 (trend) and intensity, β = .47, p = .04, of the pain. Conclusions. Results suggest that about half of women may develop genito-pelvic pain during pregnancy, but that this pain will resolve for a majority, persist for about a third, and a significant subset of women will newly develop pain after childbirth. Pain-related anxiety in pregnancy may increase the risk for greater postpartum genito-pelvic pain. An improved understanding of the course and predictors of genito-pelvic pain could help health care providers identify and offer early intervention to women that are at risk for experiencing this pain postpartum.},
}

@inproceedings{wilson2013don,
  title = {We don't lose it all as we age: Filtering visual distraction across the lifespan},
  author = {Wilson, Ryan and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Background: Working Memory (WM) is used to hold and manipulate information in an active, short-term store while performing a range of daily tasks such as reading, mental arithmetic and problem solving. These tasks must be completed in the face of distractors, which appear to become increasing difficult to ignore as we age (e.g. Gazzaley et al., 2005). The purpose of this study was to investigate the effect of distractors on both the maintenance and manipulation components of WM performance. Method: 20 healthy younger and 20 healthy older adults completed a series of n-back WM tasks designed to assess the effects of task-irrelevant distractors on WM performance. Analysis of reaction time (RT) data and error rates (ER) was conducted using mixed effects modeling using Age Group (young vs older), Load (1 vs 2 targets), Task Type (maintenance vs manipulation) and Distraction (present vs not present) treated as fixed effects. Hypotheses: We predicted that WM performance (ER and RT) would be most disrupted by distractors when the task required continuous manipulation of 2 targets in the active short-term store at and that older adults would be more adversely affected by the presence of distractors than would younger adults. Results: ER and RT were adversely affected in both young and older adults as Load increased and as the Task Type switched from a maintenance to a manipulation task and this effect was more pronounced in older adults. Older adults were no more affected by the presence of distractors than were younger adults and the addition of a second target during the manipulation task resulted in reduced distractor effects. Conclusion: It may be the case that, as a way of coping with distraction, particularly when the primary task is difficult, individuals apply a more stringent attentional control setting, thereby limiting the amount of information that can enter WM. Contrary to our predictions these data also suggest that this ability is maintained in healthy aging. Differences between current results and the existing literature will be discussed.},
}

@inproceedings{tremblay2013more,
  title = {More Than Just Words: A Crowded Mental Dictionary},
  author = {Tremblay, Antoine and Johnson, Anne and Asp, Elissa and Bardouille, Tim and Zarzycka, Malgorzata and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {We attempt to gain better insight into the question of what is stored in our mental dictionary and what is put together from smaller parts. Many linguistic theories posit a separation between a system that stores individual words and their meanings (a lexicon) and a system of rules for combining lexical items into phrases and sentences (a grammar). However, we have previously found behavioural evidence that multi-word sequences that frequently occur together (e.g., in the middle of) may in fact be stored as chunks" in the lexicon rather than being computed on-line from grammatical rules every time they are produced. Using the magneto-encephalography (MEG), independent components analysis (ICA), hierarchical clustering, and generalized additive mixed-effects modeling (GAMM), we characterized the effects of the frequency of use of single words (this; man; looks; like), bigrams (this man; man looks; looks like), trigrams (this man looks; man looks like), and quadgrams (this man looks like) on brain activity in specific brain regions during the pre-production stage of unconstrained overt picture description, in adults over a range of ages and educational backgrounds. Our findings suggest that (1) very low to low frequency bigrams, trigrams, and quadgrams may be computed, more or less quickly, from smaller parts, and (2) very high frequency bigrams, trigrams, and quadgrams may coalesce into single units, similarly to words such as dog, strawberry, and bicycle (i.e., they may be stored as wholes rather than computed from smaller units).},
}

@inproceedings{korgan2013effects,
  title = {Effects of environmental enrichment on the HPA-axis in a convulsive rat model},
  author = {Korgan, Austin C. and Green, Amanda D. and Esser, Michael J. and Perrot, Tara S.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Environmental enrichment (EE) has been associated with decreased vulnerability to neurological and psychological disorders in several species. Following prenatal stress, EE can reduce anxiolytic behavior and restore normal hypothalamus-pituitary-adrenal (HPA)-axis functioning. One approach to restoring this functioning is through the regulation of corticotropin releasing hormone (CRH). CRH has been shown to be a powerful convulsant in animal models and is up regulated following febrile seizures in humans. In this study, we subjected pregnant dams to daily predator exposure stress from gestational day 13-20. Following birth, subsets of these dams and their pups were housed in a larger, 'enriched' environment. On postnatal day 14, rat pups were given an injection of lipopolysaccharide, followed by a subthreshold dose of kainic acid. Behavior recordings of the ensuing seizures allowed us to classify them based on severity (mild, moderate, or severe). Perfusions and blood collections the following day allowed us to observe CRH-immunoreactivity (-ir) in the hypothalamic paraventricular nucleus, as well as measure plasma corticosterone (cort) levels. Overall, EE decreased CRH levels in all pups, independent of seizure status. Post hoc analysis revealed a trend between plasma cort levels and pre- and post-natal conditions in pups experiencing moderate seizure. Correlations among plasma cort levels, CRH-ir, birth weight, and total seizure score for each group suggests differential HPA-axis function dependent on early life exposure.},
}

@inproceedings{coupland2014fern,
  title = {fERN differences within Subclinical Psychopaths},
  author = {Coupland, Mitchell and Krigolson, Olav},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Psychopathy is a personality disorder distinguished by a characteristic lack of affect, superficiality, spontaneous and impulsive behavior, and a parasitic lifestyle. Clinical and subclinical psychopathy differ only in the severity of dysfunction within the individual. One may wonder if psychopathy may impact reward processing within the medial-frontal cortex? The feedback error-related negativity (fERN) is a component of the human event-related brain potential (ERP) that is sensitive to reward processing. In the present study we sought to investigate the relationship between fERN amplitude and subclinical psychopathy; using the Self-Report Psychopathy Scale Revised III to measure levels of subclinical psychopathy within an undergraduate population. Given that, by nature, Psychopaths do not typically learn from their mistakes, we expect to find a deficit in reward processing as reflected in an overall decrease in fERN amplitude for people who score high on psychopathy. Our data supports this contention.},
  note = {Poster},
}

@inproceedings{ababou2014drosophila,
  title = {Drosophila Melanogaster},
  author = {Ababou, Nedjma and Wiederman, Meagan},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Mitochondria produce energy, in the form of ATP, to carry out cellular work. Our experiment hypothesized that larger mitochondrial volumes are present where greater energy demands exist in visual neurons of fruit flies (Drosophila melanogaster). We predicted that L1 neurons, the more energetically intensive neurons, would have greater mitochondrial volume and surface area densities than L2 neurons. We predicted that mitochondrial volume would be greatest in the presynaptic area, where neurotransmitter cycling occurs. Using Fiji Image J we traced mitochondria in electron micrograph stacks of four L1 and six L2 neurons to reconstruct the three-dimensional mitochondrial distributions for comparison between neuron types and boutons. Z-tests demonstrated L2 neurons have significantly greater mitochondrial volume and surface area densities; therefore, greater energy requirements. Greater mitochondrial volumes in the postsynaptic terminals of both neurons indicated greater local energy demand. Further research is required to extend this hypothesis to neuron classes in other strata.},
  note = {Poster},
}

@inproceedings{howse2014impact,
  title = {The Impact of Socioeconomic Status on Reward Learning in the Medial-Frontal Cortex},
  author = {Howse, Ashley and Peloquin, Marcel and Doherty, S. and Hassall, Cam and Krigolson, Olav},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {While there is strong evidence that a system involved in reward processing exists within the human medial-frontal cortex, there is still a lot to learn about the factors that impact the sensitivity and functional efficacy of this system. Behavioural studies have indicated that children from low socioeconomic (SES) backgrounds may be more sensitive to rewards than those from privileged backgrounds. While children of higher SES outperform their disadvantaged counterparts on cognitive tasks, children of lower SES show greater improvement when rewards are offered for task performance compared to those of higher SES (Sweet & Ringness, 1971; Johnson, 1974). In the present study, we sought to examine the effect of childhood SES on the reward processing system within the human medial frontal cortex. Participants completed a learnable gambling task while electroencephalographic data were recorded. In line with previous work, we found that reward and loss feedback elicited a feedback error-related negativity (fERN; Miltner et al., 1997). Further, and importantly, we found that that the amplitude of the fERN is reduced for participants from low SES compared to high SES backgrounds--a result that suggests individuals from low SES backgrounds are more sensitive to rewards than their privileged counterparts. Additionally, a moderate correlation was observed between SES and fERN amplitude suggesting the reward sensitivity decreases as SES increases.},
  note = {Poster},
}

@inproceedings{simmons2014personality,
  title = {Personality Differences Among Smokers and Non-Smokers},
  author = {Simmons, Chad and Ivany, Meredith},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Past Research has shown there is a clear link between some personality traits and substance use. Our research will tackle the question of whether there is a measureable difference between the personalities of students that smoke cigarettes and those who do not. We accomplished this by comparing personality dimensions in 432 high school smoking and non-smoking students with the Substance Use Risk Profile Scale (SURPS) and the Connor-Davidson Resilience Scale 10 (CD-RISC). The SURPS measured hopelessness (HI), anxiousness (AS), impulsivity (IMP) and sensation seeking (SS). The CD-RISC measured resiliency. Smokers were found to have higher hopelessness and sensation seeking as well as lower resiliency scores than non-smokers, and within the smokers, those with high resiliency started smoking later in life than those with low resiliency. Smokers with high HI attended fewer smoking cessation sessions, and those who completed the program were found to have lower HI and SS scores. This suggests that individuals with different personality traits would benefit from different treatment types, for example, smokers with high HI may benefit from a focus on self-worth in their treatment. Furthermore, high resiliency appears to delay or prevent the onset of smoking, so increasing resiliency in our children is a step that can be taken in the future.},
  note = {Poster},
}

@inproceedings{lowe2014contrast,
  title = {Contrast adaptation in mouse V1 depends on spatial frequency but not firing rate},
  author = {Lowe, Matthew P. and King, Jillian L. and Crowder, Nathan A.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {It is well known that the visual system adjusts it function based on prevailing viewing conditions. For example, prolonged viewing of high contrast gratings produces contrast adaptation in which both the perceived contrast of test stimuli and the responsivity of visual neurons can be altered. Contrast adaptation has been well documented in cats and primates, however its underlying neural mechanisms are not well known. Therefore, we examined this phenomenon in V1 in mice, a genetically manipulable animal model. Previous research in mice has shown that contrast adaptation depends on the spatial frequency (SF) of the adaptor, and that the strength of adaptation can diminish when non-preferred stimuli are used. The purpose of the current study was to determine whether the selectivity of the adaptation effect is due to the SF of the stimuli or merely the sub-maximal spike rates elicited by non-preferred SFs. To do this, we used a top up contrast adaptation protocol where two different adaptors flanked the preferred SF and elicited similar spike rates. The test stimulus either matched the adaptor or was different than the adaptor. Similar to previous studies, we found that contrast adaptation was strongest when the test SF matched the adaptor. It appears that contrast adaption is mediated by similar underlying neural mechanisms in different animals, which suggests that genetic tools available in mice could be leveraged to investigate these mechanisms.},
  note = {Poster},
}

@inproceedings{abouleish2014retinorecipi,
  title = {Retinorecipient areas in the diurnal rodent Octodon Degu},
  author = {Abouleish, Malik and Frank, Kevin J. and King, Jillian L. and Crowder, Nathan A.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The degu (Octodon Degu) is a diurnal rodent that has been used in neuroscience research to study circadian rhythms. However, degus may also be worth considering as a model in visual neuroscience because they have a far greater density of cone photoreceptors than traditional lab rodents (rats and mice). We used biotinylated dextran amine anteriograde labeling to explore the retinofugal projections in the degu for the first time. We documented anteriograde labeling in twenty-eight subcortical visual nuclei, but focused the majority of our analysis on the dorsal lateral geniculate nucleus and the superior colliculus as two regions that may have adapted to diurnal activity. We found that the degu's dorsal lateral geniculate nucleus lacked distinct stratification, and was morphologically similar to the rat. The greatest density of labeling we observed occurred in the superior colliculus, with far greater contralateral bias than observed in rats. These differences may reflect the cone-rich retinofugal signal in degus, but overall the morphology of visual projections in this member of the family Octodontidae resembles that in members of the family Muridae.},
  note = {Poster},
}

@inproceedings{bowdridge2014investigatin,
  title = {Investigating a Role for Matrix Metalloproteinases in the Cortex of Visually Deprived Cats.},
  author = {Bowdridge, Josh and Duffy, Dr. Kevin},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Occlusion of one eye in early life can produce an intractable impairment of visual acuity in the deprived eye that persists through life. Monocular deprivation (MD) in kittens has been studied as a model of human amblyopia, an analogous condition that arises due to abnormal development of the visual system during early postnatal life. Recently, it has been demonstrated that a short period of 10 days of complete darkness is sufficient to reverse the anatomical and functional changes that result from MD. In the present study we chose to examine levels of matrix metalloproteinase (MMP) activity in the visual cortex of animals reared with various forms of abnormal visual experience in an attempt to elucidate the molecular mechanisms that underlie deprivation-induced neural changes, and also those that underlie recovery from MD. Our examination of MMP activity revealed an increase in MMP-2 activity in V1 of kittens after 7 days of monocular deprivation that was coincident with a loss of the MMP substrate, aggrecan.},
  note = {Poster},
}

@inproceedings{smithen2014recovery,
  title = {Recovery from monocular deprivation in kittens induced by ten days of darkness depends upon the acuity in the non-deprived eye and requires a period of binocular vision},
  author = {Smithen, Matthew J. and Holman, Kaitlyn and Mitchell, Donald and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Amblyopia is a condition that results in a deficit in vision and is modelled primarily in kittens by depriving one eye of patterned input for a defined period. Recently, it was discovered that ten days of darkness could promote the recovery of vision in kittens with experimentally induced amblyopia. Experiments were designed, first, to test whether ten days of darkness could promote recovery when the monocular deprivation was extended to eight weeks of age. Second, whether the recovery of vision in the deprived eye was boot-strapped by the neural connections established with the non-deprived eye. Third, if a period of binocular vision was necessary for the recovery seen following ten days of dark rearing.},
  note = {Poster},
}

@inproceedings{maclean2014erp,
  title = {ERP Components Underlying Prism Adaptation (PA)},
  author = {Maclean, Stephane and Ishigami-Doyle, Yoko and Hassall, Cameron and Krigolson, Olave and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Prism adaptation (PA) is an experimental technique used to treat spatial neglect after stroke, but the effects are inconsistent over studies, suggesting a need to understand better the underlying mechanisms. Redding and Wallace suggested that the adaptation process involves two components: An immediate strategic recalibration of visuomotor aiming (top-down) and a slower visuo-motor spatial realignment process (bottom-up). The purpose of our study was to examine whether we could detect these components by measuring event-related potentials (ERPs) that are generated during the visuomotor adaptation process induced by exposure to visual field-displacing goggles while reaching. The findings identified two ERPs associated with movement completion that dissociate over the time-course of adaptation: an invariant ERN response sensitive to error commission that could reflect realignment and a P300 response that decreases over time that could reflect conscious visuomotor re-calibration. Implications of these findings for understanding prism adaptation and treatment of neglect will be discussed. Friday's Posters},
  note = {Poster},
}

@inproceedings{ishigami2014relationship,
  title = {Relationship of the components of the Attention Network Test-Interaction (ANT-I) to standardized measures of attention and executive function},
  author = {Ishigami, Yoko and Longman, Stewart and Tyndall, Amanda and Burek, Grazyna and Denheyer, Melanie and Poulin, Marc and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The Attention Network Test is a useful computer-based tool for measuring the three attention networks (alerting, orienting, and executive) within a single 20-miniute session. We examined relationships between the attention networks and the global performance measured with the Attention Network - Interaction (ANT-I) and standardized neuropsychological tests clinically used to measure different domains of cognitive functioning: attention, processing speed, memory, executive function with healthy older adults (N=181). We found that better executive network scores and better global performance from the ANT-I were associated with processing speed, memory, and executive function as measured by the standardized neuropsychological tests. The results provide insights into the psychometrics of the ANT-I and its potential utility in clinical research settings.},
  note = {Poster},
}

@inproceedings{burke2014neuroeconomi,
  title = {Neuroeconomics: Changes in neural activity during learning},
  author = {Burke, Luke and Alsip, Laura and Hodder, Nicole and Vokey, Sarah and Hassall, Cameron and Krigolson, Olav},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The purpose of our research was to investigate the brain basis of what it means to be an expert. We recorded EEG while participants completed a perceptual discrimination task and examined two particular components of the event-related potential: the N250 and the reward positivity. Participants showed an enhancement of the N250, thought to index familiarity, for familiar stimuli (previously-learned, computer-generated "blobs") compared to unfamiliar stimuli (novel blobs). We also observed a decrease in the reward positivity, a positive deflection in response to unexpected rewards, for familiar stimuli compared to unfamiliar stimuli. Thus, in addition to perceptual familiarity, one of the hallmarks of expertise may be that feedback type (correct/incorrect) is more expected, evoking a diminished reward response.},
  note = {Poster},
}

@inproceedings{salmon2014step,
  title = {A step towards building better video "games" for rehabilitation: A survey investigating entertainment preferences in adults},
  author = {Salmon, Joshua P. and Wilson, Graham C. and Klein, Raymond M. and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {As the healthcare system becomes increasingly burdened with demands for rehabilitation services, the need for accessible therapies is growing. Video game approaches offer a promising supplement to existing therapy programs. Research has shown that video games can improve such cognitive functions as memory, processing speed, executive function and attention in both young and older adults. The current challenge however, is finding (or designing) video game approaches that simultaneously match the therapeutic needs of the patient population while remaining fun and engaging. As part of a larger research program, to develop better rehabilitation software or "games" for patients recovering from Stroke or Parkinson's disease, the current study conducted a nation-wide survey of adult entertainment preferences. Measures of favorite television, book, film and movie genres were also collected, as well as information about frequency of use of various technologies, devices and video games. The results from this research offer a window into how adults spend their time with technology, and what approaches in designing new software for older adults might be most effective. The ultimate goal of this research is to apply this information to design more engaging game-like therapies that will encourage and motivate patient rehabilitation.},
  note = {Poster},
}

@inproceedings{perrot2014introduction,
  title = {Introduction},
  author = {Perrot, Tara},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {A historical overview of the people and events in our department from at least 1970. This year I will focus on the contributions of Jeannette McGlone and Heather Schellinck, who will retire this year.},
}

@inproceedings{howse2014hangover,
  title = {Is my hangover affecting my ability to learn? Neurological evidence from electroencephalography},
  author = {Howse, Ashley and Peloquin, Marcel and Hassall, Cameron and Krigolson, Olav},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {While there is strong evidence for a reward processing system involved with learning within the human medial-frontal cortex, a lot remains unclear about the factors that influence the functional efficacy of this system. Behavioural evidence suggests that alcohol hangover impacts motor control and cognitive functioning (Cherpitel et al., 1998; Verster, 2007). In the present study, we aimed to provide the first neurological evidence of an impairment of the reward processing system of the human medial fontal cortex during alcohol hangover. Participants completed a learnable gambling task while EEG data were recorded. In line with previous work, we found that the feedback error-related negativity (fERN; Miltner et al., 1997) was elicited by wins and losses during this paradigm. Further, and importantly, a reduction in fERN amplitude was observed between hangover and control participants. Additionally, a moderate correlation was observed between fERN magnitude and hangover severity. These data indicate the magnitude of the impairment increases with hangover severity. The results of the present study are important for public education and safety, as an impairment of the reward processing system may implicate individuals' ability to execute corrective behaviours--processes necessary for successfully executing potentially dangerous tasks such as driving a motor vehicle.},
}

@inproceedings{ramasubbu2014catastrophiz,
  title = {Do Catastrophizing of Bodily Sensations and Health-Related Reassurance-Seeking Maintain Health-Related Anxiety?},
  author = {Ramasubbu, Cynthia and Sherry, Simon and Gautreau, Chantal and Sherry, Dayna and Nealis, Logan and Hadjistavropoulos, Heather and Stewart, Sherry},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The impact of catastrophizing of bodily sensations (i.e., rumination about, overconcern with, and intolerance of bodily sensations) and health-related reassurance-seeking (i.e., seeking care from others regarding one's perceived health problems) on health-related anxiety (i.e., anxiety about perceived health problems) is unknown. We hypothesized catastrophizing of bodily sensations and health-related reassurance-seeking maintain health-related anxiety, and catastrophizing of bodily sensations predicts health-related reassurance-seeking. A sample of 155 young adults was studied using a 28-day daily diary study with longitudinal follow-up. We found results consistent with two hypotheses: Catastrophizing of bodily sensations maintained health-related anxiety, and catastrophizing of bodily sensations predicted health-related reassurance-seeking. A cyclical, self-perpetuating pattern was observed wherein catastrophizing of bodily sensations and health- related anxiety contribute to one another over time.},
}

@inproceedings{chinneck2014investigatin,
  title = {Investigating Possible Reciprocal Relationships between Symptoms of Depression and Pathological Gambling in Emerging Adults},
  author = {Chinneck, Annie and McKinnon, Sean and Stewart, Sherry},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Based on literature linking emotional disorders and problem gambling, the present study tested bidirectional relationships between depression and pathological gambling in emerging adults. It was hypothesized that depressive and pathological gambling symptomology would be positively related at baseline, and that depression would confer risk for increased gambling over time, and vice versa. A sample of 517 Manitobans aged 18 to 20 years completed a series of questionnaires over four waves and five years (2007 to 2011) as part of the Manitoba Longitudinal Study of Young Adults. Data were analysed using inflated zero univariate growth curves. Depression and pathological gambling were positively related at Wave 1. Furthermore, having symptoms of depression at Wave 1 was related to a significant increase in pathological gambling symptoms over time. The reverse was not supported, however, and engaging in pathological gambling at Wave 1 was not related to changes in depression symptomology over time. Depression may lead to escalations in gambling problems over time via self-medication. This has treatment implications in that, while depression affects changes in problem gambling, the reverse is not true. Young adults who are depressed may therefore be a subgroup who should be targeted for problem gambling prevention.},
}

@inproceedings{williams2014longitudinal,
  title = {A longitudinal exploration of advantageous and disadvantageous inequity aversion in children},
  author = {Williams, Amanda and Moore, Chris},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {How children make decisions in situations of disadvantageous inequity, (DI) where one can split resources equally or allow one's partner to receive more, has received little attention. Though research has explored decisions made in situations of advantageous inequity, (AI) -such as sharing- more thoroughly, little is known regarding how the developmental trajectories of these two forms of inequity aversion compare, and whether they are related to one another. In this longitudinal study, two forms of AI, and two forms of DI (cost and no cost) were explored in children at three time points; 4.5 years, 5 years, and 5.5 years of age. Using a forced choice resource allocation task, relationships between the two forms of each type of inequity aversion were investigated, and relationships across the three time points for AI, and DI were examined independently. Finally, the relationship between AI and DI was explored. For both AI and DI, cost and no cost variables were correlated at each time point. Correlations across all time points were observed in AI trials, and grew stronger with age, while only one relationship was observed over time in DI trials (between times one and two). A positive relationship (indicating a preference for equity) was observed between AI and DI at time one, whereas no relationships were observed later in development. These results suggest that AI and DI do indeed have distinct developmental trajectories, and that the relationship between them changes with age},
}

@inproceedings{richards2014give,
  title = {"Give It Away, Give It Away, Give It Away Now": Children's Sharing Generosity & Receiving Preferences in Contexts of Anonymity},
  author = {Richards, Jennifer E. and Moore, Chris},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {People engage in prosocial behaviours, such as sharing, from a very young age. Numerous factors, including anonymity, can influence sharing. While anonymity has been shown to decrease adults' generosity, it remains unknown whether anonymity influences children's generosity. Two experiments examined the impact of anonymity on children's sharing behaviour. Experiment 1 investigated if children understood anonymity, and whether their generosity was influenced when they shared as anonymous or identified donors. Experiment 2 examined whether children preferred to receive from donors who wished to be anonymous, or from donors who wished to be identified to the child. Findings from these experiments suggest that children understood the concept of anonymous sharing, and preferred to receive from identified donors. However, unlike adults, children's generosity did not decrease when sharing anonymously.},
}

@inproceedings{hebert2014assessing,
  title = {Assessing the Relation Between Subjective Cognitive Impairment, Neurological Functioning, and Psychosocial Symptoms in Multiple Sclerosis Patients},
  author = {Hebert, Max and Fisk, John},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Multiple Sclerosis (MS) is a degenerative neurological disorder that impacts quality of life. Among the symptoms, 65% of patients experience cognitive impairments (e.g., working memory, processing speed) throughout the course of their illness. Complicating this, many MS patients experience subjective mood symptoms of depression and anxiety that can distort accurate knowledge of cognitive impairments, resulting in patients concluding that their cognitive impairments are more severe than has been objectively measured. The current study will investigate subjective and objective cognitive impairments and how subjective mood can moderate this relationship. Participants of the study will be 354 adults with clinically definite MS from the Dalhousie MS Research Unit database. Moderation analysis will determine if anxiety or depression ratings act as a moderator between subjective and objective cognitive performance. Further analysis will employ structural equation modeling to determine whether subjective mood or other assessment measures of disability will be effective in accounting for the variability between subjective and objective cognitive impairment ratings.},
}

@inproceedings{sobey2014face,
  title = {Face Processing and Gender Recognition: An Eye-Tracking Study},
  author = {Sobey, Stephanie and McMullen, Dr. Patricia and Matheson, Dr. Heath},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Purpose: During social interactions, the eyes provide information that can be used to facilitate effective communication, and even play a role in identifying gender. While some research has demonstrated that mutual eye contact facilitates gender processing, others report conflicting results. It is also widely accepted that inverted faces are harder to identify, and this Face Inversion Effect is caused by a lack of expertise. This lack of expertise causes a shift to featural- based processing as opposed to the holistic processing applied to upright faces. The current study incorporates eye-tracking technology to further investigate orientation and gaze direction effects on gender processing. Methods: Participants completed a gender categorization task in which face orientation (upright/inverted) and gaze direction (direct/averted) were manipulated. An eye-tracking device recorded saccades and fixations within specified interest areas as well as reaction time and decision accuracy. It is well established that humans are highly efficient at identifying gender; therefore, faces were morphed into varying degrees of masculinity/femininity to make the task more difficult and ensure rich eye-tracking data. Preliminary Results: Upright faces were indeed processed faster and more accurately than inverted faces and eye-tracking showed a strong preference for the upper portion of the face. Gaze direction influenced reaction times such that averted gaze was processed faster than direct gaze - an effect that was modulated by the degree of masculinity/femininity of the face. These results suggest that mutual eye contact may interfere with gender processing and this interference is most pronounced in highly masculine faces.},
}

@inproceedings{mcinnes2014comprehensiv,
  title = {A Comprehensive Review of the Neural Correlates, the Mechanisms, and the Involvement of the Primary Motor Cortex (M1) in Motor Imagery},
  author = {McInnes, Kerry and Boe, Shaun},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Motor Imagery (MI) is the mental rehearsal of a movement without the actual overt execution. MI and motor execution (ME) activate overlapping brain regions. Therapeutic interventions targeting lost motor function from neural damage capitalize on ME. In other words, ME drives activation of central motor pathways, which rewires the damaged networks and rehabilitates lost motor function. Given the overlapping neural activation during ME and MI, it follows that MI also has the potential to rehabilitate compromised motor function. The following review explores the similarities and differences between MI and ME. It focuses on the theories for understanding MI --specifically, its neural correlates and mechanisms. Our understanding of MI, however, is greatly hindered by the debated findings regarding the involvement of the primary motor cortex (M1) during MI. This review therefore explores MI theories with an emphasis on the contribution of M1 during MI.},
}

@inproceedings{kraeutner2014motor,
  title = {Motor imagery as a modality of skill acquisition: Assessing the neural correlates of motor imagery},
  author = {Kraeutner, Sarah and Gionfriddo, A. and Bardouille, T. and Boe, Shaun},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Motor imagery (MI) is a form of practice in which an individual mentally rehearses a motor task, driving plastic changes in the brain and facilitating skill acquisition in the absence of physical practice. Previous research suggests that MI recruits similar brain regions as motor execution (ME), however, this data remains controversial due to methodological limitations. The current research seeks to further establish MI as a secondary modality of skill acquisition by providing electrophysiological evidence, using MEG, of an overlap between brain areas recruited for ME and MI. Participants performed both execution and imagery of a button press task. We demonstrate that regions recruited during ME were also recruited during MI. In contrast with ME, however, spatial extent of activation was greater and additional areas were recruited during MI, suggesting that MI may be a learned skill in itself. These findings further establishes MI as a secondary form of skill acquisition.},
}

@inproceedings{ishigami2014effects,
  title = {Effects of alerting tones on prism adaptation in healthy older adults},
  author = {Ishigami, Yoko and Kintzel, Franziska and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {One therapeutic approach for patients with spatial neglect is prism adaptation (PA), which targets the orienting deficit in spatial neglect. In the current study, we examined whether combining the PA technique with alerting tones (to enhance vigilance) increases the PA effects in older adults. Forty healthy older participants were randomly assigned to one of four conditions that varied in the presence of PA and frequency of alerting tones during the adaptation period. During the adaptation period, participants pointed towards targets while wearing clear or prismatic goggles shifting the visual field rightwards with alerting tones occurring on 0 - 50% of trials. Outcome measures included subjective-midline tasks (SMTs) and visual search. The greatest after-effects were observed with the highest frequency of the tones (50%) in an SMT involving both visual and proprioceptive guidance. We conclude that alerting tones may improve some aspects of PA treatment in patients with spatial neglect.},
}

@inproceedings{mackinnon2014mate,
  title = {Mate preferences in speed-dating: Do women really prefer men with higher earning prospects?},
  author = {Mackinnon, Sean and Selterman, D.F. and Chagnon, E. and Furda, M.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {As part of a large-scale, collaborative research project to test the reproducibility of scientific results in psychology, we sought to replicate key findings from Eastwick and Finkel (2008). Specifically, we hypothesized - contrary to evolutionary theory - that women would not display a preference for mates with higher perceived earning prospects in a live-attraction (speed-dating) paradigm, compared to men. Participants (N=307) went on brief, 4-minute "dates" with potential romantic partners. Participants rated dates on attraction and relationship initiation variables after speed-dating. We also followed participants for 30 days following the speed-dating to explore actual dating experiences. Results showed the perception of greater earning prospects was associated with greater romantic interest in potential partners, r=.17 [.05, .29], but this effect was not moderated by gender χ2(1)=0.89, p=.46. We successfully replicated the findings from Eastwick and Finkel (2008), suggesting both men women and men prefer partners with higher earning prospects, contrary to evolutionary theory.},
}

@inproceedings{jones2014beyond,
  title = {Beyond the Physical: Can We Improve Thinking and Memory in Parkinson's?},
  author = {Jones, Stephanie A. H. and Green, Janet and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Individuals with Parkinson's Disease (PD) experience problems with working memory (WM), even in the early stages of the disease. However, no standard treatment for WM deficit is available. We sought to investigate the feasibility and preliminary effectiveness of an intensive and focused computerized WM training program for individuals in the early stages of PD. A controlled single blind randomized crossover design was used. One group receives a 'dual n- back' working memory training task first, and the second group receives a control visuospatial computer task first. Training includes at home 25 minute sessions, 5 days/week for 5 weeks. After 5 weeks, the training conditions are crossed over for phase 2. Outcome measures include WM, fluid intelligence and self-report functional outcomes immediately after each phase, and after 3 months. Preliminary pre and post training results on selected outcome measures obtained from 3 participants (2 additional participants are currently enrolled) will be presented.},
}

@inproceedings{wilson2014compromised,
  title = {Compromised Attention After Stroke? Maybe Not!},
  author = {Wilson, Ryan and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Deficits in attention control, an aspect of working memory (WM), are considered one of the most prominent impairments caused by stroke, but few studies have examined which specific aspects of attention control are affected. This study tested the ability of 15 stroke survivors and 20 healthy control subjects to ignore distracting information while completing the n-back WM task under increasing levels of load. We hypothesized increased distractor processing, i.e., longer reaction times (RT) and higher error rates (ER), for stroke survivors and healthy controls as WM load increased, and that stroke survivors would be more adversely affected by increased WM load than the healthy controls. Contrary to our hypotheses stroke survivors and healthy controls evidenced equivalent distractor processing, suggesting perseveration of some aspects of attention control after stroke. Furthermore, both groups showed reduced distractor processing during the most difficult task compared to all other tasks. Implications will be discussed.},
}

@inproceedings{gadbois2014applications,
  title = {Applications of scent processing with canines and other animals 1: Implementation and deployment challenges.},
  author = {Gadbois, Simon and dogs, Catherine Reeve Training and detection, other animals for scent and discrimination},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {identification, trailing, and tracking is an emerging field of research with its own challenges. Our lab has explored this field of research for eight years and worked with private and public institutions on specific problems (mostly environmental and medical). We will present the implementation challenges of this research, and the conflicts between the academic and R&D approach. We will then discuss future opportunities and applications and explain why we are expanding our research program to other scenting species.},
}

@inproceedings{reeve2014applications,
  title = {Applications of scent processing with canines and other animals 2: Methodological challenges of canine olfactory psychophysics},
  author = {Reeve, Catherine and Gadbois, Simon},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {After eight years of trial and error, fine-tuning of procedures and training protocols, our lab has recently focused on a few techniques. We are challenging some common approaches based on psychophysical (stimulus saliency), cognitive (working memory), and neuroscience (olfactomotor activation) principles. Data will be presented to support our new approaches especially in relation to the detection of hypoglycaemia in breath samples from individuals with Type 1 diabetes.},
}

@inproceedings{fisk2014song,
  title = {Song Learning Under Stress: Does single parenting affect song development in zebra finches?},
  author = {Fisk, Jordan and Aitken, Sean and Perrot, Tara and Phillmore, Leslie},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Young male songbirds such as zebra finches learn their song from listening to and memorizing their father's song and then practicing until they produce a "good copy". Memorization begins at about 25 days post-hatch, before the birds can produce song, active practice begins at about 35 days, and song crystallizes at adulthood - about 90 days. We were interested in whether having a single father throughout development, when typically both the mother and the father contribute to offspring care, would affect a son's ability to produce a good copy of adult song. To do this we removed the father or mother four days after eggs hatched, allowed birds to mature, and then compared recordings of adult offspring to their father. We found that birds reared without a model (single mother) had poor copies of fathers song as expected, but birds reared with a single father were not as good at copying father's song on several measures compared to birds reared with both parents.},
}

@inproceedings{ovens2014human,
  title = {Human Sensitivity to Single Temporal Irregularities},
  author = {Ovens, Laura and Phillips, Dennis P.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {There is remarkably little evidence on human sensitivity to auditory temporal irregularities. This is important because deficits in neural timing are implicated in poor perception in auditory pathologies. Building on previous work using the jitter paradigm, experiments will measure human sensitivity to single temporal irregularities within 25-click trains having inter-click intervals (ICI) between 5 and 160 ms. Thresholds will be measured as a function of ICI in four different conditions which vary across two dimensions; direction of click shift (backward or forward in time), and position of subsequent clicks (block shifted or not). Block shifting of subsequent clicks results in a stimulus with only one aberrant ICI. Stimuli will be presented in two forms; as wide-band clicks, as well as high-pass clicks in the presence of a low frequency noise masker. It is expected that performance will vary as a function of ICI, as has been seen in previous work. It is further expected that thresholds will vary between conditions, with higher thresholds on conditions containing only one aberrant ICI.},
}

@inproceedings{holman2014contrast,
  title = {In contrast to the effects observed in kittens, 10 days of darkness does not restore neural or visual plasticity in adult cats.},
  author = {Holman, Kaitlyn and Duffy, Kevin and Mitchell, Donald},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Recent investigations show that 10days of darkness imposed on kittens can rejuvenate cortical plasticity and promote fast recovery of vision in kittens with stable, experimentally induced amblyopia. Here, we report effects of darkness on neural and visual plasticity in adult cats. First, we report the effect of darkness on the vision of adult cats with stable, experimentally induced amblyopia. Second, we report the effect of darkness on the vision of a normal adult cat when imposed before a period of monocular deprivation (MD). Third, we report effects of darkness on recovery of soma size and neurofilament immunolabeling in the lateral geniculate nucleus (LGN) of adult cats that had experienced long-term MD. Finally, we report effects of darkness on LGN soma size and neurofilament immunolabeling in normal adult cats when imposed before MD. In all cases, 10days of darkness did not promote restoration of neural or visual plasticity in adult cats.},
}

@inproceedings{king2014orientation,
  title = {Orientation Plasticity in Mouse Primary Visual Cortex},
  author = {King, Jill},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Information processing in the visual system is shaped by recent stimulus history, such that prolonged viewing of an adaptor can alter the perception of subsequently presented stimuli and modify the visual response properties of neurons in multiple brain areas. In the tilt-aftereffect, the perceived orientation of a grating is often repelled away from the orientation of a previously viewed adaptor grating. A potential neural correlate for this tilt-aftereffect has been described in cat and macaque primary visual cortex (V1), where adaptation produces repulsive shifts in the orientation tuning curves of V1 neurons. In these animals, columns of V1 neurons are clustered into iso-orientation domains and pinwheel centers, and there is evidence that orientation adaptation is more prevalent near pinwheel centers. We investigated orientation adaptation in mouse V1 with the aim of establishing a genetically tractable model to study this form of plasticity. We were also curious about how orientation adaptation might differ in a species known to lack pinwheel columnar organization and have a lower proportion of orientation tuned neurons. We used stimulus protocols that were readily comparable with previous studies, and found that orientation adaptation caused repulsive shifts in the majority of orientation tuned neurons, and a general decrease in firing in neurons that were not selective for orientation.},
}

@inproceedings{shinomiya2014candidate,
  title = {Candidate neural substrate of a motion detection circuit in the visual system of Drosophila},
  author = {Shinomiya, Kazunori and Meinertzhagen, Ian A.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {In the fruit fly's visual motion pathways, two cell types - T4 and T5 - are the first known relay neurons to signal small-field direction-selective motion responses. I report that multiple types of transmedulla (Tm) neurons provide inputs to T5 at their terminals in the third neuropil, or lobula. From L2 cells, the OFF-channel neuron in the lamina, motion information comes from three types of Tm cells, including Tm1, 2 and 4. Additional input to T5 comes from Tm9, the medulla target of a lamina interneuron L3. Input synapses from Tm2 and Tm9 are spatially segregated on T5's dendritic arbor, providing candidate anatomical substrates for the two arms of a T5 EMD circuit. Transcript profiling indicates that T5 expresses both nicotinic and muscarinic cholinoceptors, qualifying T5 to receive cholinergic inputs from Tm9 and Tm2, which both express ChAT. I hypothesize that T5 computes small-field motion signals by integrating multiple cholinergic Tm inputs using nicotinic and muscarinic cholinoceptors.},
}

@inproceedings{korgan2014prenatal,
  title = {Prenatal paternal stress and postnatal enhanced home cage affect maternal care and anxiety like behaviour in juvenile rats},
  author = {Korgan, Austin and Perrot, Tara and Weaver, Ian},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Paternal effects have recently drawn interest from neuroscientists, within the context of epigenetic transmission, largely following evidence from behavioural ecology and epidemiology. Recent studies have demonstrated offspring effects of paternal age, obesity, enrichment, and psychological stress. These outcomes may be partially manifested through differences in maternal care. For the current study, we used predator odour exposure to stress male Long-Evans rats for 7 days, immediately preceding a partner preference test, followed by breeding. On the day of parturition, dams were transferred to enhanced home cages (EHC), which are approximately twice the size of a standard cage (SC) and contain a burrow, or SC. Maternal care was observed for 10 days in both conditions. At P25,two male and two female offspring were observed for social play behaviour for 5 days. Anxiety-like behaviour was examined using the elevated plus maze and open-field test on P32-35. Then, between P35-40 offspring were exposed to a predator odour for 30-minutes and sacrificed for immunohistochemical detection of GH and NPY.},
}

@inproceedings{adamo2014squeeze,
  title = {The squeeze is on: Increased competition for faculty positions has ramifications for the recruitment of women into academia.},
  author = {Adamo, Shelley A.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The number of women faculty in the sciences has increased steadily over the last 40 years. However, relatively fewer women than men make the transition from doctoral student to faculty member. The reason for the loss of these highly skilled individuals from academic science remains unclear. Both motherhood and a bias against women in science have been hypothesized to be the main culprits. I present evidence that excessive competition for faculty positions disproportionately affects women with children. The ratio of academic positions available, given the number of doctoral students trained, has been falling over the last decade in Canada. Studies in the US have shown that women doctoral students and post docs with children are less likely to obtain a faculty position than single women or men. A comparison with medicine demonstrates how motherhood need not be a barrier to womens' participation in academic science.},
}

@inproceedings{bergey2014how,
  title = {How do student-generated questions relate to comprehension, self-efficacy and achievement in an undergraduate chemistry course?},
  author = {Bergey, Bradley},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Since questions can both indicate knowledge deficits and facilitate knowledge construction, it is unclear how student-generated questions relate to comprehension and ability beliefs during classroom learning. This study examines the relations among characteristics of students' questions, perceived comprehension of lectures, self-efficacy beliefs, and exam scores in an undergraduate chemistry course. Participants (N =103) recorded questions (n = 980) in written logs across 8 consecutive lectures. Questions were coded for various qualities. Results from path analyses indicate that different question characteristics have different relations with perceived comprehension and achievement. The percentage of unanswered questions was associated with lower perceived comprehension. Questions that clarified or indicated narrow knowledge deficits were positively associated with perceived comprehension and exam scores. Perceived comprehension predicted situated efficacy beliefs more strongly than did general self-efficacy beliefs for the course. Findings are discussed in light of implications and on-going research.},
}

@inproceedings{lambe2014dyadic,
  title = {Dyadic conflict, drinking to cope, and alcohol-related problems: A 4-week longitudinal study},
  author = {Lambe, Laura and MacKinnon, Sean and Cartwright, L. and Korecky, M. and Orr, M. and Park, S.J. and Song, D. and Stewart, Sherry Stewart},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The motivational model of alcohol use posits that individuals may consume alcohol to cope with negative affect. Conflict is a strong predictor of coping motives, which consistently predict alcohol-related problems. The current study tested the link between dyadic conflict, coping motives, and alcohol-related problems in romantic couples. It was hypothesized that (a) the association between dyadic conflict and alcohol-related problems would be mediated by coping- depression and coping-anxiety motives, (b) that this would be true for actor and partner effects, and (c) when controlling for enhancement motives. Participants (N=70 couples) completed weekly questionnaires for four weeks. Data was analyzed using a longitudinal Actor Partner Interdependence Model. Only coping-depression motives independently mediated the conflict- alcohol problems relationship. This held for actor effects, but not for partner effects. Results remained significant when controlling for enhancement motives. Overall, results suggested certain individuals may be coping maladaptively by turning to alcohol following relationship},
}

@inproceedings{gendron2014alzheimer,
  title = {Alzheimer's Disease and 5XFAD Mice: A Study of Hormonal Abnormalities and Metabolism},
  author = {Gendron, William and Brown, Dr. Richard E. and Anini, Dr. Younes},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The 5XFAD mouse is a double transgenic model of Alzheimer's disease (AD), which carries an amyloid precursor protein (APP) transgene with three mutations, and a presenilin-1 transgene with two mutations. These mutant transgenes act additively to produce massive increases in beta amyloid (AB)-peptides, and the development of AB-plaques by two months of age. Therefore, the 5XFAD mouse is useful for investigating AB-pathology in AD and for assessing the efficacy of novel therapeutics in reducing AB-plaque load. In our lab, we have previously observed age- related weight-loss in the 5xFAD mouse. Weight-loss is also a common problem in human AD patients. Our objective is to investigate feeding behaviour and feeding-related hormone levels in 5xFAD mice and their WT controls. Several hormones may be involved with this characteristic weight loss, including ghrelin leptin, insulin, thyroid hormones, testosterone, and estrogen. In this study we will collect blood and measure the concentration of the hormones previously stated. Muscle tissue will be collected to evaluate whether mice suffer from sarcopenia (muscle loss), and fat tissue to identify whether weight loss may be attributed with fat loss. We hypothesize that there will be feeding and weight differences, hormonal abnormalities, sarcopenia, all of which indicate an abnormal metabolic state. This project will clarify the mechanisms underlying the feeding abnormalities and weight loss in the 5xFAD mouse model, which parallel human AD symptoms.},
}

@inproceedings{barresi2014moral,
  title = {The moral bases of John Woolman's opposition to slavery: A comparison of qualitative and quantitative analyses.},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {How John Woolman came to play a seminal role in the movement to abolish slavery that began in the mid-18th century has recently become an issue of philosophical discussion. My interest is in a psychological account of the moral bases of Woolman's role in this movement. Thus far I have focused on a qualitative analysis of Woolman's moral development using Sylvan Tomkins' Script Theory to interpret entries in his Journal, an autobiographical document that traces his moral life history and includes discussion of his activities in opposition to slavery. For this talk, I will compare this analysis to findings from a statistical analysis of words used in the Journal that correspond to Jonathan Haidt's Moral Foundations Theory. The comparison of the two theoretical approaches and empirical methods can provide independent light on the value of each theory as well as a deeper understanding of the origins for Woolman's moral opposition to slavery.},
}

@inproceedings{christie2014you,
  title = {You Can Take a Peek Under the Covers Without Taking a p.},
  author = {Christie, John},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Several recent papers have discussed various problems with the way statistics are commonly done including data peeking. It can result in inflation of the Type I error rate to unknown, and sometimes large, amounts. It is strongly discouraged. I discuss how data peeking can be done safely and without any of the typical issues that argue for its abolishment. On the contrary, I argue that proper and disciplined data peeking should be encouraged.},
}

@inproceedings{oneil2014second,
  title = {Second-language vocabulary training strategies and their impact on learning outcomes and brain function},
  author = {O'Neil, Kiera and Hauser, Max and Eng, Vivian and Frenck-Mestre, Cheryl and Newman, Aaron J},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The goal of the proposed study is to assess the efficacy of two second-language (L2) vocabulary training strategies on learning outcomes and brain activation. Words in a language novel to participants (Spanish) will be taught using LANGA (Copernicus Studios, Halifax, NS), a set of computer games using automated speech recognition. A vocabulary of 84 words (none of which were English cognates) will be taught over 9, half hour sessions. Half the words will be taught via paired association (i.e. visual representation paired with individual written Spanish word) and half will be taught contextually (i.e. visual representation paired with written Spanish sentences), with word assignment balanced across participants. Participants are to be assessed on Spanish vocabulary knowledge before and after training using both a picture naming task and a picture- word match/mismatch task. ERPs (event-related potentials) will be recorded during the latter task, with the expectation of a larger N400 ERP component post-training, as the N400 is an index of lexical access. After training, subjects should able to name significantly more items than before training. Mismatched picture-word pairs should elicit an N400 effect after, but not before training. The N400 will greater for words taught contextually than for those taught by paired association. This research will demonstrate the efficacy of automated speech recognition in teaching vocabulary in a new language, and suggest that contextual teaching strategies appear to foster better second language retention.},
}

@inproceedings{macdonald2014investigatin,
  title = {Investigating the factors that influence lexical stress processing in English disyllabic words.},
  author = {MacDonald, Rebecca and Sparks, Erin},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The current study examined adults' processing of letter strings as cues to lexical stress. In English orthography, lexical stress is often associated with patterns of letter strings, typically found in word endings. Adult participants completed a lexical decision task. We selected items that varied in their number of stress friends, i.e. words sharing the same word ending and the same lexical stress. For example, label and novel are stress friends because they end in -el and take first-syllable stress. Using by-items linear regression, we analyzed the impact of the proportion of stress friends, the absolute number of stress friends, and the frequency of stress friends on reaction time. We determined that only the proportion of stress friends predicted reaction time. These findings suggest that adult readers are sensitive to spelling regularities that predict lexical stress and make use of these regularities in their lexical stress processing. We interpret these results within the context of statistical learning theory.},
}

@inproceedings{chevalier2014understandin,
  title = {Understanding Cortical Activation Associated with Second Language Acquisition},
  author = {Chevalier, Thérèse M. and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Although transcranial magnetic stimulation (TMS) has been proposed as treatment for individuals with aphasia following a stroke, the function of the brain regions that are the proposed targets of TMS are not well understood. The present study aims to understand cortical activation associated with effortful phonetic processing of a second language in order to add to our understanding of language learning circuitry and provide a basis for further research on treatment of language disorders such as aphasia. Thirty-four healthy adults underwent three computer-based Spanish language-learning sessions, an fMRI scan, and a session of inhibitory TMS, which targeted regions of the left or right hemisphere that were active during fMRI naming tasks. Consistent with our hypothesis, similar patterns of activation were found at the group level during picture naming tasks in English and Spanish. However, no clear patterns emerged following TMS based on stimulation site. Implications for further research will be discussed.},
}

@inproceedings{muisehennessey2014relationship,
  title = {The relationship between implicit sequence learning, speech in noise perception, and working memory.},
  author = {Muise-Hennessey, Alexandria and McWhinney, Sean and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Language processing involves manipulation and encoding of sequential patterns, and some work has indicated that sequential memory plays an important role in spoken language processing. Indeed, the ability to implicitly learn sequences is correlated with sentence perception in degraded listening conditions (Conway, C. M., Bauernschmidt, A., Huang, S. S., & Pisoni, D. B. (2010). Cognition, 114, 356-71). We investigated whether the relationship between implicit sequential pattern (a Markovian finite-state artificial grammar) learning and speech-in-noise perception (AzBio) is mediated by cognitive functions such as memory, attention, and executive function. Replicating previous work, we found that implicit sequence learning performance was correlated with speech perception in noise. As well, operation span (a working memory measure) was strongly correlated with speech-in-noise perception but not with implicit sequence learning. suggesting that the relationship between sequence learning and speech-in-noise perception is not mediated by working memory. Additional studies are underway to characterize the relationship between speech-in-noise perception and implicit sequence learning as a function of the signal-to- noise ratio of the speech.},
}

@inproceedings{deacon2014morphologica,
  title = {Morphological and Syntactic Awareness: Understanding the Deficits in Children with Poor reading Comprehension},
  author = {Deacon, S. Helene and Tong, Shelley and Cain, Kate},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Poor comprehenders have intact word reading skills but struggle specifically with understanding what they read. We investigated whether two metalinguistic skills, morphological and syntactic awareness, are specifically related to poor reading comprehension. We compared two groups of children in grade 4 matched on multiple skills: poor comprehenders (n = 15) and average comprehenders (n = 15). The two groups performed comparably on a morphological awareness task that involved both morphological and syntactic cues. However, poor comprehenders performed less well than average comprehenders on a morphological task in which there was no additional syntactic information, and also less well on a syntactic awareness task, in which there were no morphological manipulations. Clearly, poor comprehenders struggle, in comparision to average comprehenders, on tasks targeting each of morphological and syntactic skills separately, but not when the two are combined. Future research needs to identify precisely in what ways these specific metalinguistic difficulties connect to challenges with reading comprehension.},
}

@inproceedings{tucker2014breastfeedin,
  title = {Breastfeeding in the NICU: An exploratory study of barriers and facilitators from the perspectives of mothers and health-care professionals.},
  author = {Tucker, Rebecca and McGrath, Patrick and Huguet, Anna and Inglis, Darlene and Campbell-Yeo, Marsha and LeDrew, Michelle},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Breastfeeding is known to have health benefits for both infants and their mothers. Based on the evidence of these benefits, the World Health Organization's recommendation is to exclusively breastfeed infants for their first six months. Despite this, we continue to see low numbers of Canadian mothers that are still exclusively breastfeeding their infants at six months of age. For infants who have been admitted to the Neonatal Intensive Care Unit (NICU), the number of mothers who are still exclusively breastfeeding at six months appears to be even lower. In this study, we will be talking to both mothers and health-care professionals in an attempt to understand their experiences and get their perceptions of the challenges to, and facilitators of, breastfeeding infants who have been admitted to the NICU. We are also interested in what they suggest as possible solutions and supports that would have helped them (or their patients, in the case of health-care professionals). Ideally, this research will provide important information that can then be used to develop an interactive web-based instructional program aimed at supporting sustained breastfeeding for mothers who have had infants admitted},
}

@inproceedings{redden2014champ,
  title = {Champ vs. Chump: Knowledge of Opponent Ability Modulates Reward Processing in Medial-Frontal Cortex},
  author = {Redden, Ralph S. and Hassall, Cameron D. and Krigolson, Olave E.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {A series of recent studies (Krigolson & Holroyd, 2006, 2007a, 2007; Krigolson et al., 2008) suggest that a reinforcement learning system within medial-frontal cortex may underlie motor learning. Here, we sought to further that work by examining how expertise modulated reward evaluation by the medial-frontal system. More specifically, we were interested in whether learned knowledge of an opponent's skill level would impact reward processing (i.e. amplitude of the neural response to the presentation of the opponent). In the present study we had participants play rock, paper, scissors against virtual "opponents" while electroencephalographic (EEG) data was recorded. In the key manipulation, participants played three opponents - one who was skilled highly (won 60% of games), skilled poorly (won 20% of games), and skilled moderately (won 33% of games). A post experiment analysis of the EEG data revealed that a reward positivity was elicited when participant wins were contrasted with losses (Holroyd et al., 2008). Furthermore, and importantly, after participants had learned their opponents' ability, viewing "good" opponents faces relative to "bad" opponents faces also yielded a reward positivity. This supports our theory that individuals process opponents differently based on their history of wins and losses against them. These outcomes also support the theory that reward positivity is not only evoked by outcomes, but also modulated by stimuli that predict outcomes, as indicated by a differentiation in medial-frontal activity at the earliest indication of potential reward.},
}

@inproceedings{hassall2014learning,
  title = {Learning what matters most},
  author = {Hassall, Cameron and Krigolson, Olav},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Decision making in a complex world is made possible by heuristics, or "mental shortcuts". One such heuristic, sparsity, guides our choices by focusing learning on only a small subset of available features (such as choosing a graduate program based on how much free food is available). Here, we replicated work suggesting that humans use sparsity when making complex choices, and found electroencephalographic (EEG) evidence implicating selective attention in this process. In particular, we observed an increase in the N2pc (a marker of attention) in response to high-valued relevant features compared to low-valued irrelevant features. Thus, selective attention may be one of the mechanisms behind the use of sparsity in decision making.},
}

@inproceedings{mohamed2014effect,
  title = {The Effect of Visual Noise on the Magnitude of the Directed Forgetting Effect},
  author = {Mohamed, Noha},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The present study determined whether the amount of attention paid during initial item processing influenced the strength of the intentional forgetting effect. Using an item-method directed forgetting paradigm, study items in high or low background visual noise appeared one at a time in the centre of a computer screen, each followed by an instruction to remember or forget the previous item. After all study items were presented, participants completed a recognition task in which they indicated whether they recognized the items, regardless of their memory instruction. Results revealed a higher accuracy for to-be-remembered items than to-be-forgotten items. There was no significant difference in the magnitude of the directed forgetting effect between high and low noise conditions. This suggests that the amount of attention paid during encoding is not a significant indicator of the magnitude of the directed forgetting effect. Future research should address both attention withdrawal and cognitive load in the context of directed forgetting effect.},
}

@inproceedings{salmon2014how,
  title = {How good is your reaction time data? Lessons learned from the Dalhousie Computerized Attention Battery (DalCAB)},
  author = {Salmon, Joshua P. and Jones, Stephanie A. H. and Wright, Chris and Lawrence, Michael and Butler, Beverly and Klein, Ray and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The speed at which a task is performed can be a valuable research instrument in research and clinical assessments. However, standard computer hardware employed for measuring reaction and response times (e.g. a standard computer monitor or mouse) can add noise to the data collection of reaction times, potentially compromising the precision of measurements and subsequent conclusions drawn from the data. Therefore, an assessment of the precision of measurement should be included in the development of computerized tasks and assessments. This talk will outline different methods for assessing the precision of collected reaction time data (with and without independent chronometry). In particular, using example data collected from the Dalhousie Computerized Attention Battery (DalCAB), this talk will discuss the detection, measurement, and correction of non-representative noise in reaction time measurement. This talk should act as a cautionary tale to any researchers who have built their own software, use reaction time as a dependent measure, but have not yet employed methods for verifying the chronometry of their software.},
}

@inproceedings{lawrence2014covert,
  title = {Covert measurement of covert orienting: An electroencephalographic and pupilometric investigation},
  author = {Lawrence, Mike},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Covert orienting of spatial attention is typically measured by overt motor responses (keypress, eye movement, etc) made by participants to a peripheral stimulus. This presentation will discuss attempts to simultaneously deploy two measures of covert orienting that do not require such a response, one based on steady-state visual evoked potentials elicited by flickering peripheral stimuli, and another based on a relatively recently discovered effect of covert attention on pupil size when participants view differentially luminous scenes.},
}

@inproceedings{dolan2014prosodic,
  title = {Prosodic Factors in Directed Forgetting of Speech Errors},
  author = {Dolan, Sarah and Taylor, Tracy and Fawcett, Jonathan},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Past research has shown that when a speech error is followed by a forget instruction (e.g., " No, sorry, I meant…") and then by a correction to the error, participants are able to intentionally forget the error, while performance for the correction to the error is improved as compared to baseline. However, previous research has not controlled for prosodic emphasis of corrections, which is commonly used in natural speech and has been shown to improve memory. We manipulated prosodic emphasis of corrections within auditory narratives containing speech errors. After listening to these narratives, participants were tested for recognition memory. Results showed that recognition performance for errors and control statements was not significantly different, however, performance for corrections was significantly higher than performance for both errors and control statements. We found no impact of prosodic emphasis of corrections on recognition performance. It appears that performance for corrected information benefits from listeners' increased attention after an error occurs, but that prosodic emphasis does not facilitate this process.},
}

@inproceedings{thompson2014directed,
  title = {The directed forgetting effect: The processes associated with intentionally forgetting and remembering.},
  author = {Thompson, Kate and Taylor-Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The processes involved in successfully remembering target information have long been a focus of research in cognitive psychology. Equally important, however, is our ability to intentionally forget irrelevant or misleading information. Investigation of intentional forgetting has progressed through the use of directed forgetting paradigms. In particular, research in the Taylor-Helmick lab has focused on the item-method directed forgetting paradigm. Participants are presented with study items one at a time, each followed by an instruction to Remember or Forget. When tested for memory of ALL items, participants reveal a directed forgetting effect: better memory for items they were told to Remember (R-items) compared to those they were told to Forget (F- items). This difference is the result of a number of cognitive processes -- some that lead to increased memory for R-items, and some that minimize memory for F-items. These processes will be summarized, and the empirical findings that support them will be discussed to provide a complete account of how we remember and forget in item-method directed forgetting.},
}

@inproceedings{rubinfeld2014dalhousie,
  title = {The Dalhousie Computerized Attention Battery: Validation against traditional neuropsychological testing instruments},
  author = {Rubinfeld, Lindsay},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The Dalhousie Computerized Attention Battery is a new battery of experimentally validated tests of attention, developed to measure the vigilance, orienting, and executive control networks of attention as described in a model by Posner and colleagues. The proposed study aims to evaluate the convergent and discriminant validity of the DalCAB with fifty healthy older adult participants (55 years and older) by comparing their performance on the DalCAB to their performance on "gold standard" neuropsychological tests of attention and other cognitive functions using regression analyses. The purpose is to evaluate how well findings from experimentally derived attention measures (i.e., DalCAB tasks) converge with results from clinical measures of attention. Results of this study will further the development of the DalCAB as a tool for the assessment and treatment of attention disorders by clinicians.},
}

@inproceedings{williams2014effects,
  title = {Effects of child temperament and parenting on toddlers' executive functioning},
  author = {Williams, Loriann and Smith, Isabel and Garon, Nancy},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The objective of the current study is to investigate how child temperament and parenting discipline style independently and jointly influence early executive functioning in typically developing preschoolers, observed at two years of age and again, a year later, at three years of age. Specifically, the study addresses: Does a positive parental disciplinary style promote the development of executive function skills in toddlers rated high in temperamental positive affect? It is hypothesized that a) toddlers who are temperamentally positive will display larger gains in executive function abilities at three years of age than toddlers with other temperament profiles and b) that toddlers whose parents engage in positive discipline will exhibit larger executive function gains at three years of age, compared to at two years of age. We also hypothesize that c) parental discipline will mediate the relationship between temperament and executive functioning such that positive discipline during toddlerhood will be related to greater executive functioning for temperamentally positive children at age 3 years. Identifying factors in toddlerhood that may promote subsequent executive function abilities has important implications for social, emotional, and behavioral development. Identification of these factors is also important in the context of community and family-level prevention or early intervention programs aimed at preschoolers. Special Adjunct Talks},
}

@inproceedings{bardouille2014laterality,
  title = {Laterality of Motor Imagery-Related Brain Activity is Modulated by Real-Time},
  author = {Bardouille, Neurofeedback Tim},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Motor imagery (MI) is the mental performance of a movement in the absence of actual movement. As in physical practice, the repetitive activation of neural pathways during MI can drive short- and long-term brain changes that underlie skill acquisition. However, the effectiveness of MI may be limited by the lack of feedback from this endogenous process. Real- time feedback about MI-related brain activity (i.e., neurofeedback) has the potential to overcome this limitation. I will present a two-group longitudinal study, wherein participants performed MI across repeated sessions with (group 1) or without (group 2) neurofeedback. Participants who received neurofeedback were able to generate a more contralateral pattern of MI-related brain activity in primary sensorimotor cortex. This indicates that the provision of real-time neurofeedback during MI allows healthy individuals to modulate regional brain activity. This finding has the potential to improve the effectiveness of MI to support skill acquisition and neurorehabilitation.},
}

@inproceedings{leroux2014impact,
  title = {Impact of Menstrual Cycle Phase on Endocrine Effects of Partial Sleep Restriction in Healthy Women},
  author = {LeRoux, Amanda and Wright, Lisa and Perrot, Tara and Rusak, Benjamin},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {There is extensive evidence that sleep restriction alters endocrine function in healthy young men, increasing afternoon cortisol levels and modifying levels of other hormones that regulate metabolism. Recent studies have confirmed these effects in young women, but have not investigated whether menstrual cycle phase influences these responses. The effects on cortisol levels of limiting sleep to 3 h for one night were assessed in two groups of women at different points in their menstrual cycles: mid-follicular and mid-luteal. Eighteen healthy, young women, not taking oral contraceptives (age: 21.8 ± 0.54; BMI: 22.6 ± 0.63 [mean ± SEM]), were studied. Baseline sleep durations, eating habits and menstrual cycles were monitored. Salivary samples were collected at six times of day (08:00, 08:30, 11:00, 14:00, 17:00, 20:00) during two consecutive days: first after a 10 h overnight sleep opportunity (Baseline) and then after a night with a 3 h sleep opportunity (Sleep Restricted). All were awakened at the same time of day. Women in the follicular phase showed a significant decrease (p =0.004) in their cortisol awakening responses (CAR) after sleep restriction and a sustained elevation in afternoon/evening cortisol levels (p =0.005), as has been reported for men. Women in the luteal phase showed neither a depressed CAR, nor an increase in afternoon/evening cortisol levels. Menstrual cycle phase dramatically altered the responses of healthy, young women to a single night of sleep restriction, implicating effects of spontaneous changes in endocrine status on metabolic responses to sleep loss.},
}

@inproceedings{satel2014integrating,
  title = {Integrating methods from neuroscience, experimental psychology, and computer science in the study of cognitive science},
  author = {Satel, Jason},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Cognitive science is widely considered to be the last frontier of scientific inquiry. In order to adequately investigate difficult questions in cognitive science, we must begin integrating techniques from multiple disciplines. Although my work so far has focused primarily on the study of visual attention, I am interested in using multiple interdisciplinary methods to investigate questions in cognitive science pertaining to many different topics, including, for example, attention, learning, memory, language, and disorders associated with such functions. In this talk, I will demonstrate how I have integrated methods from neuroscience, psychology, and computer science to investigate a cognitive phenomenon, termed inhibition of return, as an example of how such techniques can be combined to provide insight on difficult topics. I believe this work can be used as a model for the integration of multiple techniques throughout cognitive science and revolutionize the field.},
}

@inproceedings{conrad2014spelling,
  title = {Spelling Matters Too! How spelling practice can benefit reading skill in children},
  author = {Conrad, Nicole},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Many theoretical models of reading propose that fluent and skilled reading results from the rapid recognition of letter sequences as a single unit within a word. This rapid recognition depends on previously established memory representations of letter patterns that occur frequently within a language (i.e., orthographic representations). Much research has been devoted to how this orthographic information is acquired incidentally during reading. However, as spelling requires the production rather than recognition of words, spelling may establish higher quality orthographic representation due to the increased thoroughness of processing. During this presentation, I will present studies, in varying stages of completeness, that illustrate gains in spelling can transfer to gains in reading, and that begin to shed light on the mechanisms that enable the acquisition of orthographic knowledge. POSTERS Thursday's Posters},
}

@inproceedings{markovich2014validating,
  title = {Validating the Children's Sleep Habits Questionnaire Against Polysomnography in School-Aged Children},
  author = {Markovich, Adria and Gendron, Melissa and Corkum, Penny V.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Sleep is a vital physiological behaviour in children's development, and as such it is important to be able to efficiently and accurately assess whether children display difficulties with sleep quality and quantity. The Children's Sleep Habits Questionnaire (CSHQ; Owens, Spirito, & McGuinn, 2000) is one of the most commonly used diagnostic tools for pediatric sleep problems. However, this instrument has never been validated directly against the gold standard of sleep measurement (i.e., polysomnography; PSG), and studies comparing it to actigraphy are limited. The current study assessed the validity of the CSHQ via direct comparison with PSG for 30 typically developing school-aged children (ages 6 to 12). Significant correlations were expected between the four CSHQ subscale scores that were analyzed (i.e., Sleep Onset Delay, Sleep Duration, Night Wakings, and Sleep Disordered Breathing) and related sleep parameters as measured via PSG. Furthermore, these CSHQ subscales were predicted to accurately identify 80% of children meeting related PSG criteria for a sleep disorder. Surprisingly, Pearson's correlation analyses revealed no significant correlations between CSHQ subscales and PSG variables. In addition, sensitivity and specificity analyses of the CSHQ subscales revealed consistently low sensitivity and high specificity. Combined, the CSHQ Sleep Onset Delay, Sleep Duration, Night Wakings, and Sleep Disordered Breathing subscales showed low construct validity and diagnostic validity. These results demonstrate weak support for the overall clinical utility of the CSHQ as a comprehensive screening tool for sleep difficulties in school-aged children.},
}

@inproceedings{sterniczuk2014sleep,
  title = {Sleep disturbance and daytime sleepiness increase dementia risk in healthy individuals independent of overall health status},
  author = {Sterniczuk, Roxanne and Rusak, Benjamin and Rockwood, Kenneth},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {This study examined the relationship between sleep disturbance and overall health status, in the development of incident dementia. Secondary analyses were conducted on cognitively healthy older males who participated in the Honolulu-Asia Aging Study (N = 3,852). A 9-item 'sleep disturbance index' consisting of factors related to nighttime insomnia and daytime sleepiness, was compared to a 60-item 'frailty index' (FI) consisting of various health-related factors. Controlling for age, education, body mass index, and FI, the 'sleep disturbance index' was significantly predictive of incident dementia after an average of 2.9 years. Individual items 'waking up several times at night' and 'sleepy most of the day', were strong predictors in risk models that included the FI; however the FI was not a significant predictor in our models. Sleep disturbance appears to be an important risk factor in the preclinical stage of incident dementia (i.e., prior to the manifestation of cognitive decline).},
}

@inproceedings{stewart2014why,
  title = {Why my Friends Drink is Why I Drink},
  author = {Stewart, Sherry and Castellanos-Ryan, N. and Vitaro, F. and Conrod, P.J.},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {Peers may influence one another's drinking behavior through social influences on drinking motives. A sample of 2,659 adolescents (median age = 14.5 at baseline) in 20 schools across 11 boroughs of London, UK participated. At each of 4 waves, spaced at 6 month intervals, participants completed measures of their own risky internal drinking motives and their own binge drinking frequency. At each wave, students also nominated up to five students who were their closest friends. We created two scores for each individual representing coping motives and enhancement motives in the peer group by averaging the coping motives and enhancement motives scores of his/her nominated friends. Using cross-lagged analyses we showed that, over time, the internal drinking motives of the peer group influenced individual binge drinking by way of influencing individual internal drinking motives. Moreover, peer influences on drinking motives occurred later in adolescence for coping motives than for enhancement motives.},
}

@inproceedings{perrot2014early,
  title = {Early Life Models of Anxiety: The Role of Age, Sex and the Environment},
  author = {Perrot, Tara and Green, Amanda},
  booktitle = {Psychology and Neuroscience 40th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2014},
  abstract = {The early environment (prenatal and postnatal) shapes stress response systems, ultimately affecting adult brain and behaviour. We have developed a novel model of prenatal stress coupled with postnatal enrichment to investigate the expression of anxiety-like behaviours in adult rats. Moms were exposed to a live cat 3 times a day for each day (prenatal stress; or a control condition) during the last week of gestation and then either housed in standard cages or enhanced home cages. Offspring behaviour was examined in the juvenile period as well as in adulthood. Anxiety was reduced by prenatal stress in juvenile males, but not females, but effects were gone by adulthood. Prenatal stress also reduced play behaviour in the juvenile period. The combination of prenatal stress and postnatal enrichment produced complex results.},
}

@inproceedings{dentremont2015looking,
  title = {Looking at endogenous prior entry effects in baseball judgements at first base},
  author = {d'Entremont, Ghislain and Redden, RJ and Lawrence, Mike and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {To examine whether Tichener's law of prior entry holds in a baseball context, participants were presented with close plays at first base. After each play, participants made a "Safe" or "Out" judgement, or reported the perceived colour of a disk flashed briefly over either the base or the glove. The biased presentation of coloured disks at one location or the other within a block was intended to endogenously orient attention towards that location. A novel colour wheel analysis was implemented and compared with the conventional analysis. The attentional manipulation was successful, but there was no visual prior entry effect. Poster 2 moved to Friday},
  note = {Poster},
}

@inproceedings{sterniczuk2015exploring,
  title = {Exploring sleep and circadian rhythm disturbance in an animal model of early stage Alzheimer's disease},
  author = {Sterniczuk, Roxanne and Lahasee, Setareh and Rusak, Ben},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Sleep disturbance and impairment to the sleep-wake cycle, are commonly reported by individuals in the early stages of Alzheimer's disease (AD). Using a triple transgenic mouse model of AD (i.e., 3xTg-AD), this study examined whether there are alterations to the circadian pacemaker, the suprachiasmatic nucleus (SCN), prior to the development of the hallmark neuropathological changes that are characteristic of the disease (i.e., plaques and tangles). Previous work of ours found that 3xTg-AD mice show changes in neuropeptide profiles in the SCN when the brain exhibits AD neuropathology. Prior to the development of AD neuropathology however, there are already alterations in the activity/rest cycles of these mice. It is not known at what stage of disease progression changes within the SCN occur. Preliminary results indicate decreased clock gene protein product Period1 in the SCN prior to neuropathology. Findings from this study may help to identify novel biomarkers that could lead to the earlier and more accurate diagnosis of AD},
  note = {Poster},
}

@inproceedings{kindellan2015investigatio,
  title = {Investigation of glial fibrillary acidic protein (GFAP) in the primary visual cortex during normal development and in the absence of visually-driven activity.},
  author = {Kindellan, NESC: R. and Morrow, J. and Shahisavandi, A. and Thorpe, H. and Trotman, K. and Hidaya, A. and Barbaro, M. and Blacklaws, J. and Brown, A. and Greenan, J. and Kwiatkowski, S. and Meisner, L. and Pieterse, A. and Shehzaad, S. and Taylor, M. and Horne, JA and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Neurons within the mammalian primary visual pathway exhibit a high capacity for neural plasticity early in postnatal development. This critical period of neural development eventually closes so that little plasticity remains in adolescence and adulthood. The natural reduction of plasticity that occurs with age appears to be partly rooted in the accumulation of proteins - called molecular brakes - that stabilize neural circuits refined by early visual experience. Astrocytes are among the most plentiful cells within the central nervous system and they have been implicated as facilitators of neural plasticity. In this study we examined a prinicpal constituent of the astrocyte cytoskeleton, glial fibrillary acidic protein (GFAP), to determine if it is developmentally regulated within the visual cortex in a manner consistent with a molecular brake. In the second part of our study we examined whether dark-rearing, a condition known to enhance neural plasticity, alters GFAP labeling in visual cortex. While GFAP levels appeared not to be developmentally regulated within the developing visual cortex, labeling for GFAP was altered when visually-driven activity was removed through dark-rearing.},
  note = {Poster},
}

@inproceedings{fertan2015age,
  title = {Age related changes in anxiety, motor performance and spatial learning in the 5xFAD mouse model of Alzheimer's Disease.},
  author = {Fertan, Emre and Brown, Dr. Richard E.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {We used the Triple Test of Anxiety (TTA), Rotarod and the Hebb-Williams (HWM) maze to assess anxiety, motor performance and spatial learning and memory in 5xFAD mice at 6 and 12 months of age. We observed less time spent in the closed arms of the elevated plus maze for the 5xFAD mice, yet they spent more time in the dark box. We found motor deficits in the 12 month old 5xFAD mice on the Rotarod which affected both their latencies and motor learning. While there were no significant differences between the WT and 5xFAD mice in the acquisition phase of the HWM, all the mice had longer latencies and higher number of errors in the hard mazes of the test phase and there was a trend of 5xFAD mice making more errors compared to the WT controls in all three levels of difficulty.},
  note = {Poster},
}

@inproceedings{gardner2015using,
  title = {Using the SpyTrain videogame as a means to improve visual search in the older adults},
  author = {Gardner, Michael and Daly, Ella},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {The capacity for our brains to perceive information and generate knowledge is known as cognition. With age and the onset of health problems associated with age, this ability gradually begins to decline. Videogames have shown some promising effects on cognition in past studies, so the "SpyTrain" game was created to train visual search skills. We used SpyTrain to measure the effect of age, videogame and computer experience on reaction time and accuracy. Fifteen older and fifteen younger adults participated, and were asked about their weekly videogame and computer use. These participants then individually played "SpyTrain" while their reaction time and accuracy was being monitored. We found strong correlations between age and reaction time in the old group and computer use and error in the young group, suggesting that visual search declines with age and that frequent computer use can improve accuracy. Trends were also found between age and error and computer use and reaction time in the young group, implying the older participants might be putting in more effort and those who often use computers are sacrificing time to reduce error. We were unable to find any correlations with videogame use due to a lack of gamer participants and we found no correlation between computer use in the old group, suggesting seniors do not often use computers in an engaging way.},
  note = {Poster},
}

@inproceedings{hodgin2015examining,
  title = {Examining mood, drinking motives, and alcohol use over the menstrual cycle},
  author = {Hodgin, Megan and Hudson, Amanda and O'Connor, Roisin M. and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Alcohol use tends to vary over women's menstrual cycles, with increased intake occurring (pre)menstrually - a phase also characterized by enhanced negative mood. Together, these findings suggest that women may drink for particular emotion-focused reasons at specific points in their cycles. In the current study, normally-cycling women (Mage = 22.58 years, SDage = 3.43) completed daily dairy measures (via Smartphone surveys), with questions on mood, drinking motives, and drinks consumed each day for the course of a full cycle. Results thus far (n = 26) indicate that women felt less positive during menstruation and drank most heavily in the ovulatory phase, followed by menstrual and premenstrual phases, and lastly by follicular and luteal phases. Motives also varied by cycle phase, with women endorsing enhancement motives most in the ovulatory phase, and coping motives most (pre)menstrually. Social motives were commonly reported in both premenstrual and ovulatory phases.},
  note = {Poster},
}

@inproceedings{hamodat2015anatomy,
  title = {Anatomy and Pathology of the Human Olfactory Bulb in Alzheimer's Disease},
  author = {Hamodat, H. and Cash, M.K. and Darvesh, S.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Background: Clinically, there is evidence for olfactory dysfunction in neurodegenerative disorders, like Alzheimer's disease (AD), preceding typical cognitive and behavioural symptoms. In AD, olfactory impairment may result from neuronal loss, neuroinflammation and pathological deposition of β-amyloid (Aβ) plaques and tau neurofibrillary tangles (NFTs) in the olfactory bulb (OB). However, the laminar organization of the human OB is poorly understood and observations of AD pathology have been inconsistent. Purpose: the goal of this study was to discern the laminar organization of the human OB and determine structural and pathological changes in the AD OB. Methods: AD and normal control OB tissues were obtained from the Maritime Brain Tissue Bank in Halifax, Canada. Adjacent OB tissues were stained with Nissl to examine laminar distribution and immunohistochemical techniques to examine neuronal, AD pathological and neuroinflammatory markers. Results: Herein, we provide a detailed map of the anatomical distribution of the human OB. Aβ plaques and tau NFTs were observed in specific layers of the AD OB, predominately in the anterior olfactory nucleus. A lack of pathology was noted in the olfactory tract. A neuroinflammatory response was observed through the presence of activated microglia, particularly in regions with noted AD pathology. Conclusions: The specific pattern of AD pathological changes observed in the AD OB, provides support that impaired olfactory functions may be related to the peripheral olfactory system. Further investigation of the AD OB is warranted for the potential use of olfactory dysfunction as an early, definitive biomarker and diagnostic target for AD diagnosis.},
  note = {Poster},
}

@inproceedings{duncan2015amyloid,
  title = {Amyloid-beta plaque load, cell density, and soma size in the 3xTg-AD mouse model of Alzheimer's disease},
  author = {Duncan, Kylie and Frison, Miranda and Lehman, Michelle and Wood, Hannah},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Alzheimer's disease (AD) leads to the deterioration of thinking, memory, and motor function. The triple transgenic mouse model of AD (3xTg-AD) mimics the spatial and temporal progression of AD's neuropathological hallmarks - amyloid-beta (Aβ) plaques and neurofibrillary tangles. Previous studies found that 3xTg-AD mice showed superior motor coordination relative to controls (B6129SF2/J) on the rotarod apparatus. Given that motor deficits in human AD arise from Aβ plaque-induced neurotoxicity in the primary motor cortex (M1), the current study was conducted to determine if a relationship exists between Aβ plaque load, soma size, and cell density in layer V of M1 of 3xTg-AD mice. We used ImageJ to quantify Aβ plaque load, soma size, and cell density in two- and 15-month-old male and female 3xTg-AD and control mice. We found that 3xTg-AD females expressed significantly higher plaque loads than genotype- and age-matched males at both ages. Although a main effect of genotype on cell density or soma size was not observed, a main effect of sex on soma size was found, with females showing larger cells than males, and a main effect of age on cell density was found, with two-month-old mice having higher cell density than 15-month-old mice. Plaque load was significantly correlated with soma size and cell density. These results suggest that further examination of the motor system of 3xTg-AD mice may uncover a neuroanatomical or neurophysiological mechanism that preserves their motor functioning, which could have implications for the treatment of motor disturbances in human AD.},
  note = {Poster},
}

@inproceedings{beattie2015directed,
  title = {Directed Forgetting: Consequences of a Forget Instruction},
  author = {Beattie, Andrew and Thompson, Kate and Taylor-Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {This study aimed at replicating the Directed Forgetting Effect through the use of videos of people saying a word. Typically, research has used written words to test this Effect, although more recently faces have been used in conjunction with written words to make the Directed Forgetting Effect more generalizable and ecologically valid. With reference to the Mere Exposure research, familiarity of stimuli, even when presented unconsciously, has led to an increase in liking for those stimuli. The aim of the current study was to combine these two areas to determine if the Directed Forgetting Effect can be replicated with more complex and ecologically valid stimuli, namely videos, while determining whether the instruction to Remember or Forget the word presented in the video will affect the likeability ratings of the faces shown in the videos. The hypothesis was that there would greater likeability of the faces associated with a Remember instruction compared to a Forget instruction, since Remember words would be more familiar, as verified through the Directed Forgetting Effect. Results of the study showed a very strong Directed Forgetting Effect of the videos, with higher recognition accuracy of Remember than Forget words. However, strong evidence was found against the difference between ratings for faces associated with Remember and Forget instructions.},
}

@inproceedings{chisholm2015from,
  title = {From gestures to gaming: Visible embodiment of one's cognitive state},
  author = {Chisholm, Joseph},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {The field of embodied cognition is based on the idea that cognition does not occur in isolation but operates within, and interacts with, a body. Consistent with this notion, research has demonstrated how bodily states can influence affective and perceptual processes. However, it is also clear that internal cognitive states can influence bodily states (e.g., to generate goal-directed actions); therefore, the observation of overt behaviour can be used to gain insight into one's cognitive state. Interestingly, we often engage in overt behaviour that does not appear deliberate or even appear to serve any clear purpose (e.g., gestures, leaning behaviour). A series of recent investigations have employed a natural observation approach to study these spontaneous behaviours in contexts ranging from a letter reading task to video game playing (teleoperation). I will present the results of this work and discuss how spontaneous behaviours can represent the visible embodiment of one's cognitive state.},
}

@inproceedings{stewart2015mediating,
  title = {The Mediating Role of Gambling Motives in Explaining the Prospective Relations of Personality to Gambling Outcomes in Emerging Adults},
  author = {Stewart and H, S. and Mackinnon and P, S. and Lambe and L and Pearson, R},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {We tested relations between the five-factor model traits of Neuroticism and Conscientiousness with gambling outcomes, as mediated through coping and enhancement gambling motives. Four-hundred-and-eighty-seven emerging adult gamblers (52.6% female; mean age = 22.2) participated as a part of the last two waves of the Manitoba Longitudinal Study of Young Adults (Manitoba Gaming Control Commission, 2011). Participants completed the NEO Five Factor Inventory (Costa & McCrae, 1992), the Gambling Motives Questionnaire (Stewart & Zack, 2008), and the Canadian Problem Gambling Index (CPGI; Ferris & Wynne, 2001). Multiple mediator analyses, using bootstrapping, revealed the hypothesized significant indirect effects of low Conscientiousness on money spent, gambling frequency, and gambling problems mediated through enhancement motives, and significant indirect effects of high Neuroticism (expected) and low Conscientiousness (unexpected) on money spent gambling that were mediated through coping motives. Findings suggest two relatively distinct pathways to excessive/problematic gambling among emerging adults. Prevention implications will be discussed.},
}

@inproceedings{howlett2015don,
  title = {Don't Stumble Tumble: A Videogame to Reduce the Use of General Anesthesia in Pediatric Magnetic Resonance Imaging},
  author = {Howlett, Melissa and Chorney, Jill},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Magnetic resonance imaging (MRI) is distressing for many children, as they must remain immobile and endure loud noises, while lying in a narrow, enclosed tube. Some children even require general anesthesia (GA) in order to complete the scan successfully. Currently, there is no effective and accessible preparation tool available for MRI; as such, this research aims to test the efficacy of a MRI-preparatory videogame for children. This videogame is designed to prepare children for the sensory experience of MRI, while also shaping skills to enhance their capability of completing the scan without GA. Beta testing will test the game with children, in order to identify functional issues and incorporate feedback into remodelling. Implementation testing will provide the opportunity for children referred for MRI with GA, to use the videogame and attempt MRI without GA, thereby determining the proportion of families willing to use the videogame and whether the videogame is successful in reducing the necessity of GA. This tool has the potential to increase healthcare efficiency by reducing the time and resources necessary to acquire quality scans, as well as provide children with an enhanced MRI experience.},
}

@inproceedings{friesen2015real,
  title = {Real Time Neurofeedback During Imagined Imitation of Arm Movements: A Pilot Study},
  author = {Friesen, Christopher and Boe, Shaun},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {While various forms of mental exercises to promote motor recovery--specifically Action Observation (AO) and Motor Imagery (MI)--can be performed at home and have been proven efficacious, at the moment they are rarely used. This pilot project will combine AO and MI, where an individual watches movements whilst imagining they are executing those same movements, while providing real-time neurofeedback via electroencephalography (EEG). This protocol of Imagined Imitation (II) has previously been shown to engage the motor network to a greater degree than either AO or MI alone. Furthermore, while MI with neurofeedback has been shown to more effectively engage the sensorimotor areas required to induce motor recovery from stroke than MI alone, this has not yet been attempted using II. In this pilot project healthy subjects will perform II of a unilateral upper-limb movement, while receiving information about the symmetry of their sensorimotor activity. This project will provide valuable information for those interested in designing an optimal at-home adjunct to physiotherapy to promote motor recovery following stroke.},
}

@inproceedings{couture2015exposure,
  title = {Exposure to tobacco-related cues does not enhance cravings in patients with psychotic disorders relative to control smokers},
  author = {Couture, Marie-Eve and Barrett, Sean P. and Schlagintweit, Hera and Tibbo, Phil and Stewart, Sherry H. and Milliken, Heather and Good, Kimberley P.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Rates of tobacco smoking in patients with psychosis are remarkably high, and are accompanied by low rates of successful smoking cessation. Exposure to smoking-related cues is shown to reliably enhance cigarette cravings in dependent smokers recruited from the general population. In contrast, it remains unclear whether or smoking-related cues affect smokers diagnosed with psychotic disorders to the same degree as they do non-psychiatric populations. In addition, it is unknown whether the smoking motives of patients with psychosis differ from those of non- psychiatric smokers. A greater understanding of cue reactivity and reasons for smoking in smokers with psychosis may lead to enhanced interventions and increased rates of successful smoking cessation in this population. The present study compared the smoking motives, and the cigarette cravings of patients with psychotic disorders to those of healthy control participants after completion of a cue reactivity paradigm. Results revealed patients with psychotic disorders tended to be less sensitive to the cue-reactivity paradigm and suggests that patients may not be affected by tobacco cues to the same degree, if at all, as their healthy control counterparts. Further, comparison of smoking motives suggests no differences between the reasons for smoking reported by patients and those reported by healthy controls. Findings have implications for future studies aimed at identifying the source of the wide discrepancy in rates of tobacco smoking and smoking cessation across these two populations, and for the development of effective smoking cessation interventions for smokers with psychosis.},
}

@inproceedings{jones2015pilot,
  title = {A pilot study to examine the effects of computerized working memory training on working memory and attention in people with Parkinson's disease},
  author = {Jones, Stephanie A. H. and Skene, Elaine and Green, Janet and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Working memory (WM) is the ability to actively hold and manipulate information in one's mind and is needed for many everyday tasks such as reading and following a conversation. More than half of people with Parkinson's disease (PD) exhibit cognitive impairment, including WM deficits (Kehagia et al. 2010). We examined whether using a WM computer activity benefits WM and attention in people with PD compared to a control group. PD participants were randomly assigned to one of two computer activity groups: WM or control (CT). Each activity was used five days per week (30 minutes/day) for five weeks. Age-matched healthy adults were randomly assigned to use one of the computerized activities. WM activity: an adaptive dual n- back activity in which participants had to monitor a series of visual and auditory stimuli and press computer mouse buttons when the current stimulus matched a previous stimulus 'n' items ago. The 'n' was adaptive in that it adjusted according to the performance of the individual. CT activity: participants moved and rotated blocks to form horizontal lines (non-adaptive). All participants completed a computerized battery of attention tasks before and after the five weeks of activity use. We examined baseline differences in reaction time and accuracy for each independent variable within each of the attention tasks. Hedges' g was used to quantify the change in reaction time and accuracy before and after computerized activity use in the WM and CT groups. Preliminary results indicate that at baseline, PD participants show attention and WM deficits similar to previous reports (problems with initiation, inhibition, response interference, monitoring and WM). After training, the WM training group shows particular improvement on tasks requiring initiation, response interference and verbal WM compared to the control group.},
}

@inproceedings{oneil2015building,
  title = {Building a cortical network of semantic concepts in a second language: ERP evidence of fast learning via computerized games},
  author = {O'Neil, Kiera and Lagarrigue, Aurélie and Newman, Aaron J. and Frenck-Mestre, Cheryl},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {What does it take to acquire a semantic network in a second language? The present ERP study shows extremely rapid instantiation of both learned words and related concepts, via computerized games ("LANGA"). Participants served as their own control. Electrical activity of the brain, recorded at the scalp, was examined prior to exposure to the second language and 8 days later, following a 6 day training session (preceded and followed by orientation and consolidation, respectively). Participants learned 12 words per day (nouns and verbs), for a total of 72 words over 6 consecutive days. Results show rapid changes in cortical activity, associated with learning. Prior to exposure, no modulation of the N400 component was found as a function of the correct match vs. mismatch of audio presentation of words and their associated images. Post training, a large N400 effect was found for mismatch trials compared to correctly matched audio-visual trials. More importantly, images that were semantically related to learned words (eg. for the learned word "horse" the image of a saddle was presented), produced a reduction of the N400 compared to mismatched pairs (eg. the same learned word "horse" paired with the image of a building). This semantic priming effect suggests that the words in the new language were rapidly integrated with existing semantic networks, rather than existing as an isolated second language lexicon. Our results attest to the plasticity of adult learners' brains and provide evidence for rapid onset of a semantic network in a late learned language.},
}

@inproceedings{usai2015virtual,
  title = {Virtual reality environments for aphasia rehabilitation},
  author = {Usai, Francesco and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Current online applications for aphasia rehabilitation show high rates of attrition in the early stages of the training process, limiting the potential for optimal recovery. The main limit of these applications is a design overlooking important factors for a successful therapy, such as the level of immersion and motivation the users experience while doing the exercises. In this regard, this project aims at creating a cost-effective, easily accessible framework for aphasia rehabilitation that overcomes the limits of current online therapies. To achieve this goal, we will use principles of serious gaming and virtual reality to design evidence-based therapies that can engage and motivate the user to attain constant and intensive training required for a successful rehabilitation. Product design will be driven by evidence from relevant literature and basic research done in our lab, together with feedback from subjects with aphasia taking part to the process of validation.},
}

@inproceedings{hastings2015diffusion,
  title = {Diffusion Tensor Magnetic Resonance Imaging and Assessment of Olfactory Function as Early Indicators of Parkinson's Disease and Alzheimer's Disease},
  author = {Hastings, Rebecca and Good, Dr. Kim},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Alzheimer's Disease (AD) and Parkinson's Disease (PD) are the two most common neurodegenerative disorders amongst Canada's geriatric population. It has long been understood that olfactory impairments are manifested in both AD and PD and that these deficits are often present before the cardinal symptoms appear. A robust literature has shown that those afflicted with AD and PD perform poorly on the University of Pennsylvania Smell Identification Test (UPSIT) when compared to age-matched controls. The olfactory bulbs and tracts are shown to be abnormal when assessed using diffusion tensor magnetic imaging (DT-MRI), but only in PD patients. No study has yet combined objective olfactory ability with brain imaging techniques to compare those diagnosed with AD with those diagnosed with PD. The current study aimed to assess olfactory function in AD patients and PD patients along with a group of age-matched healthy controls. Olfactory function was assessed with the UPSIT, while DT-MRI techniques were used to examine the integrity of white matter in olfactory tracts and in the parahippocampal gyri. Results from the present study indicated that patients with AD and patients with PD suffer significant olfactory impairments relative to healthy controls. No significant differences were found in integrity of white matter tracts in either the olfactory bulbs or the parahippocampal gyri.},
}

@inproceedings{tagarelli2015understandin,
  title = {Understanding second language in the brain with a mini-language model},
  author = {Tagarelli, Kaitlyn M. and Newman, Aaron J. and Ullman, Michael T.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {How does an adult brain learn a second language (L2)? The complex nature of L2 learning - such as the amount of time it takes to learn a language, the variety of conditions in which people learn languages, and the vast individual differences between learners - has made it difficult to completely answer this question. In order to address some of these issues, research in psychology and applied linguistics has turned toward artificial linguistic systems, like word lists, artificial grammars, and artificial languages, which can be learned quickly in highly controlled settings. However, the extent to which results from this research can be generalizable to natural languages is often called into question. This presentation evaluates the utility of a more natural language model, a mini-language, and presents a study in which learners were exposed to a mini-language while continuous behavioral and fMRI measures were acquired. The results from this study support dual-mechanism models of language learning and processing, in which the neural bases of language change as a function of exposure and proficiency, with different patterns for lexical/semantics and grammar.},
}

@inproceedings{ingram2015inducing,
  title = {Inducing Spike Timing Dependent Plasticity in the Human Brain Through Paired Associative Stimulation.},
  author = {Ingram, Tony and Boe, Shaun},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {In the mid 20th century Hebb famously proposed that the timing of neuronal discharge underlies synaptic plasticity. This phenomenon is now referred to as spike-timing-dependent plasticity (STDP). Two forms of plasticity, long-term potentiation and depression, occurs when a postsynaptic neuron discharges within ~20 ms after the presynaptic neuron (potentiation) or when it discharges ~20-100 ms before (depression). Recent studies indicate that STDP-like changes can be induced similarly on a larger scale -- between brain areas -- in humans using a paradigm known as paired associative stimulation (PAS). PAS involves stimulating two areas of the brain in close succession, allowing for facilitation of either long-term potentiation or depression between the targeted brain areas. Thus PAS may prove to be a powerful tool in research and clinical practice by aiding in functions like learning and memory. This talk will outline the existing literature on this approach, and propose applications for facilitating motor learning using PAS.},
}

@inproceedings{leblanc2015sequential,
  title = {Sequential actions: why do upcoming perceptual - but not motor - tasks affect grasping?},
  author = {LeBlanc, Kevin and Westwood, David},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Past research has shown strong evidence supporting the notion that the visual control of action and the visual perception of objects are mediated by two functionally and anatomically distinct visual systems. Little is known about how each visual system interferes with the other when performing a sequential task. However, it is known that the kinematics of an action can be affected by a subsidiary attention task. In the current study participants were presented with two rectangular objects placed one in front of the other. Participants were instructed to grasp the first object and place it on a specified target area and then either grasp, make a perceptual judgment about, or ignore the second object. The results revealed that preparing an action to the second object does not produce interference to the first action, but attending to its size for verbal judgment does. Specifically, as the size of the second object increased, the amplitude of peak grip aperture towards the first object also increased when performing the perception condition.},
}

@inproceedings{mitchell2015there,
  title = {Is there a pharmacological intervention to replace darkness? Preliminary results from a collaborative study (M.I.T) of the use of intraocular injection of tetrodotoxin (TTX) to recover vision in animal models of amblyopia},
  author = {Mitchell, Donald and Duffy, Kevin and Northrup, Paige and Fong, Ming-fai and Bear, Mark},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {We previously demonstrated in kittens that the profound deficit in vision following an early period of monocular deprivation (MD) can be blocked or eliminated by 10 days of complete darkness (Duffy & Mitchell Curr Biol. 2013). The loss of visually driven neural activity associated with darkness may reset the levels of certain plasticity braking molecules in the visual cortex to low levels typical of an earlier stage of development. The increased plasticity conferred by reduced levels of braking molecules following immersion in darkness may promote the fast recovery from the anatomical and behavioural effects of a prior period of MD. We have investigated the possible benefits of the use of intraocular injections of TTX, a potent marine neurotoxin that selectively binds sodium channels and temporarily blocks action potentials. We examined whether blockage of all retinal activity (not just visually driven activity) with intraocular TTX recapitulates the beneficial effects of darkness.},
}

@inproceedings{maclean2015feedback,
  title = {Feedback content can alter ERPs and perceptual realignment during a prism adaptation task},
  author = {MacLean, Stephane and Ishigami, Yoko and Hassall, Cameron and Krigolson, Olav and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Prism adaptation (PA) is a demonstration of perceptual-motor plasticity, but is also a promising rehabilitation tool for visuo-spatial neglect (VSN). During PA, participants perform a visuomotor accuracy task while their visual field is shifted laterally by prism goggles. The visual shift initially causes large accuracy errors, but adaptation takes place after repeated trials. Upon returning to normal vision, participants show an aftereffect - a visuomotor bias in the opposite direction of the preceding prism shift. For VSN patients, it is important to develop PA paradigms that create robust aftereffects because these are what ameliorate their symptoms. Not all forms of "adaptation", however, result in strong aftereffects. The present study investigated the effect of presenting different forms of accuracy feedback to healthy young participants while they performed a PA task. We compared magnitude of aftereffects and event-related brain potentials evoked by onset of different feedback events. Results suggest that visual feedback of upper limb position at the end of each trial leads to stronger aftereffects compared to feedback that only indicates size of error on each trial. Visual feedback of upper limb also evokes a parietal ERP that may serve as a marker of perceptual "realignment" processes that are critical to producing strong aftereffects.},
}

@inproceedings{king2015optogenetic,
  title = {Optogenetic silencing of mouse primary visual cortex affects contrast adaptation in V1 but not the LGN.},
  author = {King, Jillian L. and Stover, Kurt R. and Lowe, Matthew P. and Crowder, Nathan A.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Contrast adaptation is induced by prolonged viewing of a high contrast gratings, and perceptually manifests as a decrease in perceived stimulus contrast. Neurons in the primary visual cortex (V1) show characteristic changes in their contrast response functions during contrast adaptation, but the cellular mechanisms behind this phenomenon are largely unknown. Our lab has previously measured contrast adaptation in mouse V1 and found close similarities to higher order mammals; therefore we have taken advantage of the genetic tools available in mice to probe the mechanisms of contrast adaptation. We performed extracellular recordings in both V1 and the lateral geniculate nucleus (LGN) in transgenic mice that express channelrhodopsin-2 (ChR2) in GABAergic neurons while optogenetically silencing V1 to investigate the role of spike rate on adaptation. We found that silencing the cortex while the adapting grating was present reduced the magnitude of adaptation in V1 cells, and also caused an increase in sensitivity to low contrasts. This latter effect had never before been observed in non-perturbed circuits. Adaptation changed the responses of LGN neurons very little except for an increase in sensitivity to low contrasts. These results have allowed us to estimate what proportion of contrast adaptation observed in V1 can be attributed to inheritance from LGN and intrinsic processes from the spiking of V1 neurons themselves. We hypothesize residual adaptation not accounted for by these two factors arises from synaptic depression at genicluo-cortical synapses.},
}

@inproceedings{jung2015horizontal,
  title = {Horizontal cell inhibition of cones via ATP hydrolysis},
  author = {Jung, Sunghan and Baldridge, William H.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Retinal horizontal cells (HCs) modulate the output from photoreceptors via inhibitory feedback. It has been suggested that feedback is due to changing pH in the synaptic cleft between photoreceptors and HCs. One model proposes that phosphate, produced by extracellular degradation of ATP released through pannexin-1 channels of HC dendrites, acidifies the synaptic space. To test this model we studied the effect of drugs that interfere with the proposed pathway on an indicator of feedback, the rollback of the HC response to light. The effect of the pannexin- 1 blocker, probenecid, and the ecto-ATPase inhibitors, ARL 67156 and BGO-136, were tested. ARL 67156 reduced HC rollback but neither BGO-136 nor probenecid had a significant effect. The action of ARL 67156 on HC rollback is consistent with the ATPase/proton model of feedback. The lack of an effect of probenecid and BGO-136 on HC rollback is not consistent with the model suggesting that additional work is necessary to characterize feedback.},
}

@inproceedings{fisk2015zebra,
  title = {Do zebra finches speak Russian? An operant task to test discriminability of mothers' song and speech to their infants.},
  author = {Fisk, Jordan and Tsang, Christine and Falk, Simone and Phillmore, Leslie},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Discrimination between human song and speech can be difficult when mothers are communicating with their infants because "motherese" is song-like in delivery. In previous studies, Tsang et al. used a preference test to demonstrate infants aged 6-9 months were able to discriminate between audio clips of mothers singing and mothers speaking to their babies in Russian. However, in a different study by the same authors, adults had difficulty discriminating some ambiguous English stimuli; they could not accurately categorize them as song or speech. In this project we used an operant task to test whether zebra finches could discriminate between audio clips of human mothers singing to their babies in Russian and English from clips of mothers speaking to their babies in Russian and English. We also presented birds with the ambiguous English stimuli to see how they categorized them. Finches were able to accurately discriminate song from speech in both languages.},
}

@inproceedings{redden2015dynamics,
  title = {The dynamics of inhibition in the aftermath of a cue is contingent on reflexive oculomotor activation.},
  author = {Redden, Ralph S. and Hilchey, Matthew D. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Inhibition of return (IOR) is considered an inhibitory aftermath of visuospatial orienting, expressed in the form of slower responding toward the locations of prior orienting responses. As shown by Taylor and Klein (2000), the form of IOR depends on the saccadic response demands imposed by the task and, hypothetically, whether the oculomotor response system for reflexively generated saccades is in an active state. To test this hypothesis, we evaluate IOR by requiring a manual discrimination response preceded by reflexive and non-reflexive eye movements in separate conditions. The findings suggest that the state of the oculomotor system determines the form of IOR.},
}

@inproceedings{shaw2015three,
  title = {Three optical mechanisms in wing spots of a large dolichopodid fly, Liancalus genualis},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Most flies have plain or darkly mottled wings, but Liancalus males have wing spots that redirect and diffuse sunlight using ~1515 tiny upright hairs, forming a bright signal for conspecifics. When the sun is obscured, a second signal is still possible because the spots fluoresce bluish- white in UV light, an important component of skylight. There is much blue in skylight though, raising the question of whether the fluorescence could even be seen over reflection from the rest of the wing. Reflection, measured with collimated blue light was surprisingly low. Quantification of fluorescence required several steps, and indicated impressive efficiency: only 12 UV photons are required to displace one fluorescent photon from the wing spot. The wavelength distribution in 5000K skylight then dictates that the natural fluorescence-to- reflection ratio will be high, ~19:1. Fluorescent spots should be easy to see. Accordingly, photographs made under natural skylight revealed a spot visual contrast of ~15:1. However, when sky UV was selectively filtered out, spot brightness dropped by only 14-18%. This exposes a third signaling mechanism: the spot’s refractile hairs act as waveguides and pick up skylight but reflect about 17% back. Fluorescence scores at only ~1/6 of this.},
}

@inproceedings{changeskensullivansickanimalstypicallychangetheirbehaviour2015comparative,
  title = {A Comparative Approach to Understanding Sickness Mediated Behavioural},
  author = {Changes Ken Sullivan Sick animals typically change their behaviour, becoming lethargic, disinterested in food, water},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {and social activities and run a fever. This change in behaviour, termed sickness behaviour, is considered an adaptive response and is thought to enhance immune function. Sickness behaviour is observed not just in mammals, but in animals across all phyla, suggesting this change in behaviour is a highly conserved evolutionary adaptation. If this is true, then understanding how sickness behaviours have been adapted over time in different species is crucial in understanding and controlling its positive (and negative) influence. A great deal of previous work has focused on studying sickness behaviour in mammals. We have used the Texas field cricket Gryllus texensis to study sickness mediated behavioural changes in order to fill in the gaps in our understanding of the adaptive nature of sickness behaviour.},
}

@inproceedings{patrick2015brain,
  title = {Brain Activation Associated with American Sign Language Learning},
  author = {Patrick, Emily and McGuire, Emily and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Studying sign languages gives the opportunity to explore a language that is unique in terms of the form of communication. Neuroimaging studies have shown that signed and spoken languages engage similar neural networks in native learners of each. Experience in visual-manual language affects how people process not only linguistic signs, but non-linguistic gesture as well. It is not known, however, how much sign language knowledge is necessary for these changes in brain activation patterns to occur. In the proposed research, we will use functional MRI to investigate the changes in brain activation patterns in response to signs and gestural stimuli, as hearing English speakers learn American Sign Language (ASL). We hypothesize that when responding to ASL stimuli (and potentially gestures) patterns will shift from bilateral activation of areas responsible for biological motion and human action perception, towards left lateralized activation of networks associated with linguistic processing. This research will add to the current understanding of how ASL knowledge affects processing of not only signs but also non- linguistic gestures. In addition, by examining novice ASL learners, we will gain a better understanding of how people learn a second language in a new modality, something that has yet to be determined.},
}

@inproceedings{turnbull2015coping,
  title = {Coping with constraints: nutritional stress elicits changes in immune function in the caterpillar, Manduca sexta},
  author = {Turnbull, Kurtis and Kovalko, Ilya F. and Davies, Gillian and Easy, Russell H. and Adamo, Shelley A.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {It is thought that nutrition may reconfigure the immune system to optimize immune function when resources are constrained. However, few studies provide empirical evidence that immune resources are redistributed during nutritional limitation. We examined the effect of short-term nutritional stress on the immune function and energy availability of fifth instar Manduca sexta larvae. Insects reared on a low-nutrition diet (25% nutrient) for two days exhibited pathogen- specific declines in resistance, but did not show changes in energy availability, immune measures or immune-related gene expression. In contrast, the nutrition-absent diet (0% nutrient) caused declines in overall pathogen resistance, infection tolerance measures and energy availability. Surprisingly, the M. sexta larvae reared on the nutrition-absent diet upregulated both resistance mechanisms and immune-related gene expression. We hypothesize that the cost of inducible immune responses (i.e. immune resources synthesized in response to a pathogen) may increase during nutritional stress and therefore, constitutive immunity (i.e. immune resources present even when there is no infection) is upregulated. Together, these results suggest that assumptions about the costs and benefits of different immune components may not hold under nutritional constraints.},
}

@inproceedings{perrot2015coping,
  title = {Coping with stress early in life to build resilience for later: Further evidence for the negative effects of helicopter parenting.},
  author = {Perrot, Tara},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Environmental enrichment (EE) produces a host of effects in mammals that are associated with a shift toward the resilient end of the vulnerable-resilient continuum that defines individual differences in the development of psychiatric conditions. The mechanism by which environmental enrichment, a non-drug and non-surgical manipulation, is associated with such robust effects remains speculative. One recent hypothesis states that EE is a form of inoculation stress - successfully coping with the chronic mild stress associated with EE produces protective phenotypes. Our unique model of EE in which mother rats are housed in enhanced home cages (EHC) with their young produces long-lasting changes in emotional and social development of the young. More recently, we have been investigating how the EHC alters maternal behaviour as one means for altering offspring phenotype. I will summarize our recent findings using the EHC and discuss them within the context of the inoculation stress hypothesis.},
}

@inproceedings{tougas2015scoping,
  title = {A scoping review of information about child health shared over social media},
  author = {Tougas, Michelle E and Chambers, Christine T and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Social media facilitates information exchange and is increasingly being used by professionals and general public. Little is known about child health and social media interaction. Aim: 1) Adapt systematic review methodology to explore social media interaction about pediatric pain and pediatric sleep; 2) identify and categorize main themes, 3) assess user interactions across social media platforms, and 4) assess consistency of posts with research evidence. Methods: Twitter and YouTube will be searched for posts about pediatric pain and pediatric sleep. Themes will be categorized and extracted. Category frequencies and user metrics will be analyzed. Netlytic will be used to summarize and discover social networks. Post content will be compared to research to identify the quality of information shared on social media. Results: This presentation will outline the novel methodology and planned stages of research that will be undertaken. Conclusions: This work will evaluate an approach for describing health-related social media, will examine how this information is being shared, what questions are being asked, and what information is being disseminated.},
}

@inproceedings{kehayes2015gender,
  title = {Gender Differences in the Mutual Influences of Drinking Motives in Couples},
  author = {Kehayes, Ivy-Lee and Mackinnon, Sean P. and Leonard, Ken and Fraser, Ron and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Drinking is related to various negative consequences (e.g., memory loss, injury). Drinking motives in the five-factor model (enhancement, conformity, social, coping-with-anxiety, and coping-with-depression) have been linked to different drinking patterns. Interpersonal factors are also important predictors of drinking, as couples enter into a "drinking partnership," where one partner's drinking influences the other's. Additionally, gender influence models suggest men hold power over women and influence women more than vice versa. This project sought to integrate drinking motives, drinking partnerships, and gender influence models to explain how romantic relationships influence drinking motivations over time. One hundred heterosexual couples were assessed once a week for four weeks. It was hypothesized that motives would be influenced by both the individual and the partner, and that men would influence women more than the reverse. Such results would demonstrate the importance of gender influence in romantic relationships and their effects on drinking motives. Preliminary results will be shared.},
}

@inproceedings{mackinnon2015relationship,
  title = {Relationship conflict and drinking to cope: An actor-partner interdependence model},
  author = {Mackinnon and P, S. and Pieterse and A and Keyhayes and I and Leonard and K and Fraser and R and Stewart, S. H},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Past research on couples has demonstrated that relationship conflict is a risk factor for alcohol- related problems through drinking to cope (Lambe et al., submitted). It was theorized that conflict increases negative emotions (i.e., anxiety and depression) which in turn leads people to drink as a means of coping with those emotions. However, our past work did not incorporate symptoms of anxiety and depression. The present study tests whether anxious/depressed affect mediates the conflict-coping relationship using a 4-wave, 4-week longitudinal study of romantic dyads. A sample of 103 romantic dyads participated, all of whom were pre-screened to have consumed 12+ alcoholic drinks in the past year. Significant indirect effects were found, with anxious/depressed affect mediating the relationship between conflict and coping motives. Significant actor effects (i.e., own affect predicting own motives) but non-significant partner effects (i.e., own affect predicting partner's motives) were found. Implications and future directions will be discussed.},
}

@inproceedings{begum2015periodic,
  title = {Periodic limb movements during sleep in children with Attention- Deficit/Hyperactivity Disorder: Baseline frequency and impact of psycho-stimulant medication.},
  author = {Begum, Esmot A and Goodday, Amy and Spurr, Kathy F. and Rajda, Malgorzata and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {To determine the prevalence of periodic limb movements during sleep (PLMS) in children with attention-deficit/hyperactivity disorder (ADHD) and the impact of stimulant medication on PLMS, 25 medication naïve children with ADHD and 25 typically developing (TD) children, 6- 12 years of age, were evaluated using overnight polysomnography (PSG) in three phases: baseline, stimulant treatment and placebo treatment. Compared to the TD children, children with ADHD had significantly higher rates of PLMS (ADHD=24%, TD=4.0%, p<0.05) with longer sleep latency (p<0.05). Children in the ADHD/PLMS group shifted their sleep stages more frequently than children in the ADHD/Non-PLMS group (p<0.001). Stimulant medication was not associated with PLMS; however, children in the ADHD/PLMS group showed significantly longer sleep latency and decreased sleep efficiency during stimulant treatment compared to the placebo. The result of this study reveals that PLMS in children with ADHD is associated with more severe sleep problems and more side- effects on medication.},
}

@inproceedings{hudson2015attentional,
  title = {Attentional biases in problem and non-problem gamblers},
  author = {Hudson, Amanda and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Although attentional biases have been widely studied in substance use disorders, relatively few studies have looked at attentional biases in gamblers. The current study examined attentional biases for gambling stimuli, relative to emotional and neutral stimuli, in problem and non- problem gamblers (n = 57). To do so, we used a Rapid Serial Visual Presentation (RSVP) paradigm, which decomposed different components of attention, namely attentional capture and maintenance/ disengagement, by employing different time lags between distractors and targets. Problem gamblers showed attentional biases for gambling stimuli, relative to all other distractors, and these biases were observed only at the level of attentional maintenance/ disengagement. Non-problem gamblers showed some evidence of non-specific attentional biases (to both negative and gambling pictures). These findings highlight important differences in attentional processes between problem and non-problem gamblers, and suggest that sustained attentional biases among problem gamblers might be worthy targets for clinical interventions.},
}

@inproceedings{mackenzie2015emotional,
  title = {Emotional Decision-Making and Psychotic-Like Experiences},
  author = {MacKenzie, Lynn and Uher, Rudolf and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Background: Emotional executive functioning has previously been labelled hot executive function as this process involves an emotional component. Performance on emotional executive functioning has been linked to the ventromedial prefrontal cortex of the brain (Bechara et al, 2000). Hot or emotional executive function has yet to be explored in individuals at high risk for SMI and may yield valuable results to the field of research. Recent research has shown promising results for improving executive functioning abilities through early intervention (Diamond & Lee, 2011). Identifying an association between executive functioning deficits and psychotic-like experiences could provide useful information for clinicians selecting assessments and possible early intervention in high-risk populations. Exploratory analysis of emotional decision-making and psychotic-like experiences could also be meaningful to support further inquiry into testing feasibility and effectiveness of executive function interventions specific to this population. Methods: Children and young people aged 8 to 21 will be selected from the existing Families Overcoming Risks Building Opportunities for Wellbeing cohort. The FORBOW is an accelerated cohort study enriched in risk of severe mental illness, which started recruiting participants in January 2013. FORBOW recruits the sons and daughters of people suffering from SMI and matched comparison controls. Overall, 75% of FORBOW participants have a family history of SMI in one or both parents, putting them at a 1-in-3 risk for developing a SMI themselves by early adulthood (Rasic et al., 2013). The remaining 25% are offspring of parents without SMI of similar age and form the same neighbourhood, referred to as comparison offspring (CO). FORBOW recruits participants at a young age (5 to 21) and follows them up in yearly intervals. The annual follow-ups include a comprehensive assessment of psychopathology and antecedents to SMI: cognitive impairment or delay,(Reichenberg et al., 2010) affective instability,(Egeland et al., 2012) anxiety, (Duffy et al., 2010; Kim-Cohen et al., 2003; Kovacs et al., 1989; Copeland et al., 2009) basic symptoms (Schimmelmann et al., 2013) and psychotic-like experiences.(Downs et al., 2013; Kelleher and Cannon, 2011; Polanczyk et al., 2010) Implications and Directions: Since FORBOW is a prospective study, the scores on the emotional decision making test will further be used to predict emergence and persistence of PLE on follow-up assessments. The results from these investigations will inform the planning and design of early interventions. If impaired emotional decision making is associated with PLE, a training in emotional decision making may be included as part of interventions for young people with PLE.},
}

@inproceedings{brown2015why,
  title = {Why study the history of neuroscience?},
  author = {Brown, Richard},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {This presentation has 3 parts. First, what is history? Second, why study the history of neuroscience? In the third part, I will show some of the work we are doing at Oxford on our "Saving the history of neuroscience" project using examples from our history of neuroscience website [https://history.medsci.ox.ac.uk/]. The general purpose of the presentation is to show how history is embedded in each phase of scientific research and teaching.},
}

@inproceedings{bird2015representing,
  title = {Representing the Brain: Modeling neuroanatomy from the Early Modern to the},
  author = {Bird, Contemporary period Brianna},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {This presentation will survey the history of anatomy modeling in reference to the brain and nervous system. Important developments include whole-body wax modeling in the 18th century, "moulages" as teaching models in the 19th century, and contemporary computer modeling. Given their visual nature, models engage non-experts and exert a strong influence on the popular imagination. Neuroanatomical models therefore reveal the tenor of broader ideas about the brain and the mind.},
}

@inproceedings{g2015visualize,
  title = {Visualize your imagination},
  author = {G, Sreejith P and Flick, Graham and Tremblay, Antoine and Newman, Aaron J},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Communication is one the most important skills that is required to be successful in life. There are so many creative people around the world who do not have the ability to speak and are unable to showcase their talents to the full extent. Through my research I am developing a technique to project what we imagine onto a computer screen. Using this technique, people who do not have the ability to speak may eventually be able to convert what they want to convey into visuals, making communication easier for them. My research focuses on harnessing the power of machine learning to build a system that can decode visual imagery from neural activation, with the goal of predicting what people are imagining based on their patterns of brain activity. To do this, Naïve Bayes and C-forest classification models were trained on magnetoencephalography (MEG) recordings acquired while subjects viewed a series of images, thus establishing profiles of neural activation associated with visual components of the imagination. These models were then used to predict what images the subjects saw based on their observed neural activation. Ensemble techniques in machine learning were used to make the model more general and less prone to over-fitting. Initial results indicated good success in predicting stimulus features including shape, orientation, and colour based on brain activation alone. Different brain regions contributed most to correct classification of different features, and classification accuracy was improved by using data exclusively from the temporal and occipital lobes, compared to using data form the whole brain. If these models are successful, they will constitute an initial step towards reconstructing authentic human visual experiences.},
}

@inproceedings{fertan2015golgi,
  title = {Golgi versus Cajal and the Neuron Doctrine},
  author = {Fertan, Emre},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {With Robert Hooke's (1665) discovery of cells using his new microscope, biologists were able to study cells as the building blocks of living organisms. This led to the development of the cell theory by Matthias Schleiden and Theodor Schwann (1838). Due to the difficulties of studying neurons, they were excluded from the cell theory. The invention of the microtome (1770) and the discovery of the tissue fixing properties of formaldehyde (1859) enabled neuroanatomists to prepare brain tissue slices to study under the microscope. The turning point for cytoarchitecture was the discovery and usage of different dyes to stain the slides. Golgi developed his famous staining technique using silver and made neuronal bodies and extensions visible, but he could not identify the small gaps between the neurons. Santiago Ramon y Cajal, modified Golgi's method to stain different nerve tissues and defined the neuronal doctrine, which states that neurons do not form continuous webs, but are separated from each other by small gaps. This led to the famous arguments between Golgi and Cajal when they were jointly awarded the Nobel Prize in},
}

@inproceedings{wheeler2015wilder,
  title = {Wilder Penfield's lasting contributions to neuroscience},
  author = {Wheeler, Ryan},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Dr. Wilder Penfield is perhaps the most well known Canadian neuroscientist. Penfield's surgical work on epilepsy was ground-breaking. However, it is his work on cerebral localisation which put his name into introductory psychology textbooks across the globe. What is often forgotten, is his incredible educational experience as a Rhode's scholar, working with greats like Sir William Osler and Sir Charles Sherrington, to name a few. As founder of the Montreal Neurological Institute, Penfield played a pivotal role in creating a world famous destination for neuroscience research in Canada. Penfield's brilliant work, and the creation of the MNI, has influenced many other famous Canadian neuroscientists such as Donald Hebb and Brenda Milner. His influence not only lives on in the famous homunculus drawing but also in the long lasting impression he has made on neuroscience research in Canada and the world.},
}

@inproceedings{christie2015significant,
  title = {I'm significant and you're not},
  author = {Christie, John},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {The title may not sound meaningful to you because, alone, it's not. But worse, if I relied on it alone to argue about meaningful differences I would be making a serious error. This talk was inspired by watching our honours conference and how our students are trained to interpret statistical tests. Special Adjunct Talks},
}

@inproceedings{robertson2015children,
  title = {Do children with dyslexia have deficits in spoken sentence comprehension?},
  author = {Robertson, Erin},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  note = {QA: abstract-too-short},
}

@inproceedings{cutmore2015effect,
  title = {The Effect of Cueing on the Directed Forgetting Effect},
  author = {Cutmore, Laura and Taylor-Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {This study explored the possible effects of cueing on the Directed Forgetting Effect (DFE). Thirty-six participants were shown words followed by a 'remember' or 'forget' instruction and then given a yes/no recognition memory test. In order to test whether cueing would decrease the DFE, the memory test was blocked into Remember Cued, Forget Cued, and Uncued sections. The proportion of corrected yes responses were calculated to find the results. The results showed a DFE as there was a main effect for memory instruction [F(1,35)=89.780, MSe=.030, p<.001] with Remember greater than Forget (Mr=.5293, Mf=.2566, SEr=.04006, SEf=.02209), but there memory instruction and cueing. From this study, it was found that cueing has no effect on the DFE.},
}

@inproceedings{barresi2015evolution,
  title = {The evolution of persons},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {In contrast to other animals, human beings are aware of themselves as selves and persons. How and why did this level of self-consciousness come about? I argue that it came about to meet the challenge for hominins to work together cooperatively in the complex physical and social environment of the Pleistocene. Through cooperation that involved both foraging and breeding, our ancestors became cognitively and emotionally bound to each other in order to engage in temporally extended joint activities that provided a fitness advantage for all members of the collective. Individuals became aware of themselves and others equally as persons involved in a variety of roles that were potentially reversible. The agent-neutral concept of person made possible uniform calculations of costs and benefits to self and other that could be used to maintain equity across cooperative activities and provide roughly equal fitness gains for all members in the collective.},
}

@inproceedings{chisholm2015individual,
  title = {Individual differences in attentional control: The case of action video game players},
  author = {Chisholm, Joseph},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {The past couple of decades have seen a marked increase in the popularity of video game playing, especially games within the action genre. Given how cognitively complex action video games are, coupled with the time people spend playing these games, interest has grown in how extensive experience with action video games may affect those who play them. To date, studies comparing action video game player (AVGPs) and non-player performance on a variety of cognitive tasks, many which engage aspects of selective attention, have revealed that AVGPs commonly outperform non-players. To date, the collective evidence has suggested that action video game playing provides players with greater or more flexible control over the spatial allocation of attentional resources. I will present recent work that compared AVGPs and non- player performance in attention and oculomotor capture tasks to assess whether AVGPs are able to engage such superior attentional control to better resist visual distraction.},
}

@inproceedings{cunningham2015effects,
  title = {Effects of Sleep Restriction on Components of Attention: Interim Results},
  author = {Cunningham, Jasmyn E. A. and Jones, Stephanie A. H. and Salmon, Joshua P. and Kintzel, Franziska and Eskes, Gail A. and Rusak, Benjamin},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {Many patients with psychiatric illnesses have both cognitive problems and disturbed sleep. These may be causally related since sleep loss is known to disrupt many aspects of cognition. Attention is a complex function that includes several separate, but interacting neural systems guiding vigilance (readiness to respond), orienting (searching for and the selection of stimuli for further processing) and executive control (attention resource allocation) abilities. However, it is not clear which of these underlying component processes of attention are most affected by sleep loss. The Dalhousie Computerized Attention Battery (DalCAB, 8 computerized reaction time tasks purported to measure aspects of vigilance, orienting and executive control) was administered on two occasions (within subjects design) to healthy participants (women aged 19-25 years), once after a nine hour overnight sleep opportunity and a second time after a three hour overnight sleep opportunity (sleep deprivation condition). Self-ratings of sleepiness and mood states were also obtained following each sleep condition. Interim results evaluating which attentional systems are affected by acute sleep loss will be reported.},
}

@inproceedings{ishigami2015finding,
  title = {Finding physiological indices of alertness in healthy adults using electroencephalography (EEG)},
  author = {Ishigami, Yoko and Satel, Jason and Boe, Shaun and Klein, Raymond M. and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 41st Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2015},
  abstract = {The alerting network plays a special role in the systems of attention. In our previous work, we determined that the alerting network interacts both with the orienting and executive networks of attention. However, these interactions depends on the modality of alerting (visual and auditory) and age. The goal of the current study is to examine the physiological indices of the alerting effects previously identified in an identification task as a function of alerting cue modality. The task for the participants (n=15/ modality condition, mean age = 20.8 yrs) is to indicate the direction of an arrow in the middle of the screen following a visual or auditory alerting cue in half of the trials while electroencephalography was recorded. Cue-elicited event-related potentials (ERPs), including the P1 and P300 ERP components, will be examined for each modality. Details of the relationship between alerting effects in ERPs and behaviour will be discussed.},
}

@inproceedings{horne2016fib,
  title = {FIB-SEM connectome reconstructions of an antennal lobe glomerulus from the Drosophila brain},
  author = {Horne, J. A and Langille, C and McLin, S and Wiederman, M and Borycz and Tarnogorska, J.A.1and and D and Team, FlyEM Project and Plaza, S and Xu, S and Hess, H and Meinertzhagen, I.A},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {The antennal lobe of the fruit fly is similar to the olfactory bulb in the mammalian brain in that it is divided into individual glomeruli each of which has it own set of receptor neuron inputs that encode a particular olfactant. We have undertaken dense reconstruction on glomerulus VA1v in the Drosophila antennal lobe and sparse tracing beyond, from an isotropic 8nm stack of segmented FIB-SEM images. The image stack encompasses the entire right antennal lobe of a 6-day female fly viewed in a frontal plane. This fruitless-positive, sexually dimorphic glomerulus is responsive to fly odour (Sakurai et al. Nat. Commun., 4:1825, 2013) and was chosen because it is large, enclosing a region much larger than any densely annotated antennal lobe volume to date. Three main classes of neurons populate the glomerulus. We have reconstructed and blindly annotated the synapses of the following: olfactory receptor neurons (ORNs), projection neurons (PNs), and local interneurons (LINs). In aggregate the 183 cells we have identified represent ~70% of the glomerular synaptic connections with more work yet to be done.},
  note = {Poster},
}

@inproceedings{jesso2016drinking,
  title = {Drinking Motives and Sex Motives Vary Differently Across Women's Menstrual Cycle},
  author = {Jesso, Shaunda-Lynn and Hudson, Amanda and O'Connor, Roisin and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Drinking behaviors differ depending on a person's drinking motives (Grant et al., 2009). Similarly, sexual behaviors differ depending on a person's reasons for engaging in sexual activity (Ball et al., 2014). Preliminary work suggests that sex and drinking motives may vary across the menstrual cycle (Hudson et al., 2015; Sheldon et al., 2006), but no study to date has studied how cyclical patterns in these variables overlap or diverge. This study examined cyclical changes in enhancement, coping and social motives across behaviors (sex; drinking). We predicted that reasons for sex and for drinking would vary similarly depending on phase of the menstrual cycle, consistent with perspective on motives as "traits". Participants were 48 normally-cycling women (M = 22.7 years, SD = 5.2) of reproductive age who were regular drinkers. Daily diary surveys were completed for a full cycle and motives for sex and for drinking were assessed in signal contingent surveys sent each afternoon to participant's smartphones. Phase means were calculated for the menstrual, follicular, ovulatory, luteal, and premenstrual phases of each woman's cycle for each category of sex and drinking motive. ANOVAs were conducted to test whether enhancement, coping, and social motives for sex and drinking changed in a parallel manner over women's menstrual cycles. Results revealed that drinking and sex motives each showed significant changes, but divergent patterns of change, across the menstrual cycle. Findings suggest that motives for these particular behaviors change in a domain-specific way across the menstrual cycle. Clinical and nonclinical implications will be presented.},
  note = {Poster},
}

@inproceedings{cochingyan2016investigatin,
  title = {Investigating the Effect of Lexical Frequency on the N400m in Unconstrained Conversation},
  author = {Cochingyan, Estelle and Macgillivray, Caitlyn and Mahmoud-Ahmed, Hayam and Schwartz, Sarah and Sher, Caleb and Newman, Aaron J. and Tremblay, Antoine},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {The magnetic N400 (henceforth N400m) is a magnetic field occurring roughly 400 ms post stimulus onset with a negative and a positive field at left anterior and left posterior scalp regions, respectively. The amplitude of the N400m is known to be modulated, among other things, by the frequency with which a word is used. More specifically, low frequency words exhibit greater N400m amplitudes than high frequency words. The N400m has been studied in the context of well controlled experimental paradigms, which have little to do with how we actually use language in everyday settings. Here we investigate whether the N400m effect generalizes to such settings. We gathered four recordings of free, completely unconstrained conversation between a participant and an experimenter while the participant was sitting in an MEG scanner. The event-related fields data for each participant was analyzed individually using generalized mixed-effects modeling (GAMM). The results show that low frequency words exhibited greater amplitudes than high frequency ones roughly 400 ms after being heard in a manner consistent with previous, less ecologically valid studies. This suggests that the lexical frequency effect on the N400m generalizes to more ecologically valid settings. In addition, these results illustrate that research can be carried out using experimental paradigms that are completely uncontrolled and more in line with actual language use.},
  note = {Poster},
}

@inproceedings{vallis2016comparison,
  title = {A Comparison of Engagement within the Attention Trip and the Attention Network Test},
  author = {Vallis, Emily Howes and Klein, Dr. Ray},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {The Attention Network Test (ANT) is a frequently used stimuli task that measures the networks of attention (Fan et al, 2002). However, prior research has cautioned against using this test with specific populations due to possible boredom effects (Ishigami & Klein, 2014). The Attention-Trip (A-Trip) is a video game inspired task designed by the Klein lab to measure the networks of attention (Klein et al., 2011). No previous literature has compared the ANT and the A-Trip in the context of participant engagement. The primary objective of this study involved utilizing two subtests of the User Engagement Scale (O'Brien, 2010) to compare the ANT and the A-Trip tasks. The objective was achieved by administering both the ANT and the A-Trip to the same sample of 28 participants recruited through Dalhousie University. After each task was performed participants completed a version of the User Engagement Scale in response to the task that was just completed. Results show that participants reported the A-Trip to be more engaging in comparison to the ANT. Both the ANT and the A-Trip generated typical attention network scores in all three attentional networks (alerting, orienting, and executive function).},
  note = {Poster},
}

@inproceedings{mccormick2016exogenous,
  title = {Exogenous Eye Movements and Inhibition of Return: Is Environmental Context Essential for the Maintenance of IOR?},
  author = {McCormick, Colin R. and Redden, Ralph S. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Inhibition of return (IOR) functions by inhibiting orienting back to previously attended and disengaged-from locations and through this process we are more likely to attend to new areas. The mechanisms and properties of IOR are explored in this study, specifically looking at whether background maintenance is essential for viewing IOR generated by exogenous eye movements. A modification of Klein and MacInnes (1999) "Where's Waldo?" search experiment is used to do this. But instead of allowing self-generated eye movements (in the service of searching for Waldo) we guided the participant's oculomotor behaviour with a sequence of salient fixation stimuli. The reaction times to orient to the final saccade were recorded using an eye tracker. There were six different and equiprobable locations of the target on the screen at varying degrees away from the previous fixation, or the fixation two before. There were 3 background conditions: 1) a Waldo picture that remained present for the whole trial; 2) a Waldo picture that was removed at the time of the appearance of the final target; 3) the series of eye movements was made on a blank background. Results reflect those of Klein and MacInnes (1999) in that participants were slower to respond to targets at locations that were previously disengaged from compared to targets at previously unviewed locations, but only in trials where the background remained consistent (conditions 1 and 3). Implications of this study for understanding IOR are discussed.},
  note = {Poster},
}

@inproceedings{wheeler2016effects,
  title = {The Effects of Exercise on Memory and Learning in 3xTg Mice and Their Wild Type Controls},
  author = {Wheeler, Alexis and Brown, Dr. Richard},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Exercise has shown to improve neurogenesis and reduce the onset of dementia in Alzheimer's affected patients. Female triple transgenic Alzheimer's disease model mice and female B6129SF2 wild type mice were given access to either a functioning running wheel or a stationary running wheel for a period of three weeks. After three weeks of voluntary running the mice were tested for spatial learning and memory in the Morris Water Maze. Mice given access to a running wheel had a significantly shorter swim distance to reach the hidden platform, more percent time spent in the correct quadrant during the probe trials and more annulus crossings during the probe trials than their stationary counterparts. Transgenic mice given a running wheel also performed comparably to wild type mice with access to a running wheel. These results indicate that short-term exercise has a significant effect on spatial learning and memory in Alzheimer's model mice and can help to reduce the onset of dementia and other Alzheimer's symptoms. Testing other age groups, shorter or longer running periods, as well as testing male mice would give further insight into the prevention of Alzheimer's symptoms and the effects of short-term exercise on learning and memory.},
  note = {Poster},
}

@inproceedings{zhang2016does,
  title = {Does the discrepancy between self and other ratings of affect predict sharing in children?},
  author = {Zhang, Ying and Longard, Julie and Moore, Chris},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {We examined if the discrepancy between children's mood and their empathic concern for another child in distress would predict more sharing. Eighteen boys and 12 girls (M = 58 months, SD = 10 months) were asked to rate their self-mood using a Facial Affect Scale (FAS) before watching an empathy-inducing video, then they were asked to rate their empathic concern toward the protagonist using the FAS. For each participant, a discrepancy score between their self-mood and empathic concern rating was calculated. Participants' sharing behaviours were then measured using a resource allocation task, in which they were given opportunities to share stickers with the protagonist. Spearman's correlational analysis between children's discrepancy scores and sharing was not significant. Limitations of the study, including the ubiquitously high ratings of self-mood using the FAS, are addressed. Retesting the correlation in future research may help to improve our understanding of the mechanisms underlying children's generosity.},
  note = {Poster},
}

@inproceedings{cutmore2016let,
  title = {Let Me Give You a Hint: Recognition Cues Don't Alter Directed Forgetting in an Item- Method Task},
  author = {Cutmore, Laura and Pries, Lotta and Taylor, Tracy},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {In an item-method directed forgetting paradigm, words are presented one at a time, each followed by an instruction to Remember or Forget; on subsequent tests of explicit memory, performance is better for Remember words than Forget words - a directed forgetting effect. The dominant view is that the directed forgetting effect arises during encoding due to selective rehearsal of Remember over Forget items. We attempted to falsify a strong view that the directed forgetting effect is due only to encoding mechanisms. Following a typical item-method study phase, we presented yes-no recognition test items in one of three colors: 1) green to indicate that the test item might have received a Remember instruction at study; 2) red to indicate that the test item might have received a Forget instruction at study; and, 3) black, which provided no cue to study instruction. In Experiment 1, recognition color cues were mixed within-blocks; in Experiment 2, they were manipulated between-blocks. We found no evidence that the directed forgetting effect is influenced by recognition cueing},
  note = {Poster},
}

@inproceedings{tutelman2016parental,
  title = {Parental Management of Pediatric Cancer Pain at Home},
  author = {Tutelman, Perri and Chambers, Christine},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Pain is one of the most problematic aspects of a pediatric cancer diagnosis and persists throughout the course of the disease. Improvements in pediatric cancer prognoses and shifts towards models of outpatient cancer care mean that parents have become increasingly responsible for assessing and treating their children's cancer pain at home. However, literature on what parents do to manage their children's cancer pain outside of a medical setting is sparse. The current study will investigate how parents assess and treat their children's cancer pain at home and seeks to identify how parental beliefs, misconceptions, and characteristics may impact their ability to optimally manage their child's cancer-related pain. 200 parents of children with cancer across North America will be recruited to complete an online survey through a partnership with the Cancer Knowledge Network (www.cancerkn.com), an online forum for those living with cancer and their caregivers. Data collection will begin in April 2016. The study's background, design, goals, outcome measures, and implications will be presented.},
}

@inproceedings{tremblay2016optimizing,
  title = {Optimizing Conditional Inference Random Forest Parameter Settings for the Analysis of Complex Brain Imaging Data},
  author = {Tremblay, Antoine and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Conditional inference Random Forest modelling (CForest) is a non-parametric modelling approach where a great number of conditional inference regression trees (CTree) are grown, typically between 500 to 2,500. Each CTree recursively partitions data into nodes and branches by way of hypothesis testing. The CForest modelling approach has numerous advantages including (i) the ability to attenuate the effects of random vaiables (e.g., repeated measurements and testing sites) and outlier data points, (ii) can model high-order interactions, (iii) doesn't over-fit the data, (iv) allows predictor variables that would otherwise be suppressed by stronger competitors to be expressed in the results, and (v) are reliable, generalizable, and easily interpretable. Five parameters are associated with CForest namely, the number of CTrees to grow, the number of independent variables to pre-select before performing an omnibus test at each tree node, the proportion of the data that is randomly selected for each CTree, whether the random sampling is done with or without replacement, and the alpha value for significance. Aiming to use the CForest approach to model complex brain imaging data, we sought to determine the optimal combination of parameter settings. A simulated whole-brain MEG data set in source space comprising 278 virtual electrode time courses was created, which was used to investigate 864 possible combinations of parameter settings. Results suggest that a random sampling of 92% of the data with replacement, without variable pre-selection yields the best results, at an alpha level of 0.05, irrespective of the number of CTrees grown.},
}

@inproceedings{bailey2016exploring,
  title = {Exploring potential new approaches to rehabilitation in aphasia},
  author = {Bailey, Lyam and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Aphasia is a devastating communication disorder in which an individual's ability to comprehend and/or produce language is severely impaired or altogether lost, and this can have widespread negative impact on an individual's overall quality of life. Current treatments for aphasia, most notably intensive speech-language therapy (SLT), are extremely effective in terms of improving patients' language functionality. However, many individuals with aphasia face barriers to obtaining the necessary level of treatment required to gain functional improvements. These barriers are primarily related to accessibility and financial cost of SLT. As such we aim to develop an inexpensive, accessible and scientifically validated computer-based treatment for aphasia, in the form of a serious online gaming platform. Our program will feature gamification of validated SLT drills that are known to be highly effective in traditional standard-of-care treatment. Initial prototypes of our program will be piloted on patients who have previously received/are currently receiving standard SLT, with a view to make a finalised version of the program commercially available. Predicted outcomes of this treatment approach and future directions will be discussed.},
}

@inproceedings{beydoun2016studying,
  title = {Studying Morpho-semantic and Morpho-syntactic Anomalies in Modern Standard Arabic through ERPs},
  author = {Beydoun, Yasmin and Tagarelli, Kaitlyn and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Modern Standard Arabic (MSA) is the literary standard used by Arabic speakers. Its words are composed of two overlapping morphemes: a semantic morpheme that is a 3-consonant root containing the meaning of the word, and a syntactic morpheme that is the sets of letters inserted into the roots to form new words. The objective of the study was to understand better how overlapping morphology is processed using semantic and syntactic neurocognitive distinctions. We tested native Arabic speakers using EEG as they read sentences that contained either a correct final target word, a morpho-semantic anomaly or one of two morpho-syntactic violations (semantically related and unrelated). Two (ERPs) were examined: The N400 associated with semantic violations and the P600 associated with syntactic anomalies. We hypothesized that when reading a morpho-syntactic anomaly an N400 will be elicited and that both types of morpho- syntactic anomalies will elicit a P600 in addition to small N400 responses (larger in the unrelated condition). The majority of the results were as predicted: the morpo-semantic anomaly elicited a prominent N400 effect in the centroparietal regions while the semantically related morpho-syntactic anomaly elicited a significant P600 peak in the posterior regions in addition to a smaller, but significant, N400 effect. The unrelated morpho-syntactic condition elicited a smaller, but significant P600 as well as an N400 response. Results point to a distinction in processing for each morpheme in MSA, with a plausible interaction between them when considering the general semantics. Results have implications for better understanding sentence processing in under-studied languages.},
}

@inproceedings{klein2016how,
  title = {How "inhibition of return" biases orienting depends on the state of the reflexive oculomotor system},
  author = {Klein, Raymond M. and Redden, Ralph S. and Hilchey, Matthew D.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Since 1988, when we discovered itʼs function as a foraging facilitator, the Klein lab has been preoccupied by efforts to understand inhibition of return (IOR). In her 1997 dissertation, and while varying the response modality (manual versus eye movements), Taylor compared the effect of IOR on localization response times when targets were stimuli presented in the periphery at the cued or uncued location or were centrally presented arrows. Taylor discovered two forms of IOR: When only manual responses were made, IOR affected inputs or their ability to capture attention; when eye movements were made, IOR affected outputs or the decision to respond in a certain direction. In his 2003 dissertation, Ivanoff explored the effects of IOR in speed-accuracy space. He obtained evidence for two different kinds of effect: a genuine effect upon the accumulation of information about the target and a speed-accuracy tradeoff with little or no change in information processing dynamics. Only in the last few years, have we put these two distinctions together demonstrating that when the reflexive oculomotor system is suppressed, IOR affects information processing dynamics, while when this system is not suppressed IOR operates as a response bias.},
}

@inproceedings{petley2016networks,
  title = {Networks of Visual Attention as Revealed Using Magnetoencephalography},
  author = {Petley, Lauren D. and Bardouille, Timothy and Omisade, Antonina and Beyea, Steven D. and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Attention is a complex construct that encompasses many of the neurological capacities that support purposeful, directed behaviour. Posner and Peterson delineated three functionally and neuroanatomically distinct networks of attention, including an alerting network, an orienting network, and an executive network. The Attention Network Task (ANT) is a popular test that measures the efficiency of these networks. This task has been noninvasively studied in time (EEG) and space (functional MRI) in healthy individuals, but these techniques have different physiological correlates. By contrast, magnetoencephalography (MEG) measures neural events with high resolution in both time and space. We studied the ANT using MEG with a distributed source model in 12 healthy young adults. The alerting network was associated with activation in visual areas and the parietal lobe, with a right hemisphere bias. The orienting network consisted of regions classically associated with both voluntary and involuntary spatial attention-switching. Activation related to the executive network differed from the results observed in previous studies and may reflect sequence effects on cognitive control.},
}

@inproceedings{gaughan2016effect,
  title = {The Effect of Directed Forgetting on Embodied Cognition in an Item-Method Paradigm},
  author = {Gaughan, Theresa and Taylor-Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {People form associations between objects and where they are typically found in space: When a word with a spatial association such as "bird" is presented, the detection of a target is faster when it appears subsequently in a congruent ("up") location rather than an incongruent ("down") location. We determined whether an instruction to forget a word with a spatial association reduces or eliminates this spatial congruency effect. We presented participants with words one at a time, each of which had an association to upper space, lower space, or no spatial association. Each word was followed by an instruction to remember or forget and then by a target that appeared above or below the word location; participants made a speeded keypress to localize the target. Participants were tested for their recognition of all words presented. In addition to finding a directed forgetting effect, with worse recognition of to-be-forgotten words than to-be-remembered words, we observed a smaller spatial congruency effect for trials with a forget instruction rather than a remember instruction. Forget instructions thus impact encoding as well as spatial associations, likely due to changes in attention.},
}

@inproceedings{northrup2016effectivenes,
  title = {Effectiveness of Tetrodotoxin in promoting anatomical recovery from monocular deprivation in kittens},
  author = {Northrup, Paige and Duffy, Dr. Kevin},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Monocular deprivation (MD) by closure of one eyelid during the critical period of visual development precipitates neuronal alterations in the dLGN of kittens that include a significant decrease in neuron somata size within its deprived layers. Brief periods of complete darkness during the critical period have been shown to be effective in restoring a high capacity for neural plasticity and promoting recovery from the anatomical effects of monocular deprivation. The cytoskeleton of neurons consists of a multitude of filamentous proteins, of which neurofilament acts to enhance stability of neural circuitry during maturation. The consequence of this increased stability is a proportional reduction in the capacity for neural plasticity. In this study examined the effectiveness of binocular retinal inactivation to promote recovery from the effects of MD. Following binocular retinal inactivation with intravitreal injections of TTX, we observed significant anatomical recovery from the effects of 7 days of MD that was complete by ten days. These results indicate that binocular retinal inactivation recapitulates the plasticity-enhancing effects of dark exposure.},
}

@inproceedings{king2016contrast,
  title = {Contrast adaptation in mouse primary visual cortex is not generated by parvalbumin interneurons},
  author = {King, Jillian L. and Korgan, Austin C. and Papsin, Emily and Crowder, Nathan A.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Contrast adaptation can be produced by prolonged viewing of a high contrast stimulus, and induces a perceived fading of the adapting stimulus. Neural correlates of contrast adaptation have been described throughout the visual system, including the primary visual cortex (V1). We recently found that optogenetically silencing V1 during contrast adaptation changed the cortical pattern of adaptation to resemble that observed in the dorsal lateral geniculate nucleus (dLGN). Thus, adaptation in V1 is firing rate dependent and adds onto inherited thalamic adaptation. How does this activity-dependent V1 adaptation come about? To test a previous proposal suggesting parvalbumin expressing (Pvalb+) interneurons produce adaptation by inhibiting neighboring cells, we optogenetically activated Pvalb+ cells during adaptation. Our preliminary findings indicate that activating Pvalb+ cells reduces adaptation rather than enhancing it, which suggests Pvalb+ cells are not themselves driving contrast adaptation in V1, but instead regulate cortical response gain.},
}

@inproceedings{bobbieansah2016crucial,
  title = {A crucial role for the fellow eye in the darkness-induced recovery of visual acuity in the amblyopic eye of kittens.},
  author = {Bobbie-Ansah, Philip and Duffy, Kevin and Mitchell, Donald},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Following a short period of monocular deprivation (MD), there is a profound reduction of the vision of the deprived eye. Although the vision of this eye improves somewhat afterwards, a substantial deficit in visual acuity remains with characteristics similar to those observed in human amblyopia. However, we have shown that a ten day period of total darkness can induce recovery of the visual acuity of the amblyopic eye to normal levels in just 5-7 days. The speed and magnitude of this recovery suggest that neural connections with the fellow eye, that support normal vision and are retained following the period of darkness, may play a crucial role in recovery of the amblyopic eye. We investigated the possibility that activation of the connections from the fellow eye may serve to guide darkness-induced recovery. This was assessed by occluding the fellow (stronger) eye for 10-14 days immediately after the period of darkness. This simple manipulation blocked any improvement of the acuity of the amblyopic eye.},
}

@inproceedings{sinno2016extended,
  title = {Extended Periods of Darkness Facilitate Anatomical Recovery in the Dorsal Lateral Geniculate Nucleus of Juvenile Felines},
  author = {Sinno, Jad and Duffy, Kevin and Bowdridge, Josh},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Amblyopia is a condition characterized by a permanent reduction of visual acuity in one eye that cannot be attributed to abnormalities within the eye itself. It becomes irreversible after the closure of the critical period (CP) of the central visual pathway, when the brain's plasticity has decreased, and current treatments are ineffective at restoring complete binocular vision in many clinical cases (Sun and Zhang, 2011). A period of complete darkness has been observed to reintroduce heightened levels of neural plasticity in rats (He et al., 2007) and kittens (Duffy and Mitchell, 2013) by removing molecular brakes on plasticity, such as neurofilament (NF), in the lateral geniculate nucleus (LGN; O'Leary et al., 2012). The following study explored the anatomical profile of darkness-facilitated recovery, concerning neuron structure and NF density. The remedial effects of 10 days of darkness were found to diminish with increasing duration of monocular deprivation (MD) and was not sufficient to promote complete neural recovery in juvenile cats that received 21 days of MD at postnatal day 30 (P30). Alternatively, 15 days of darkness was enough to promote neural growth in deprived layers to normal levels, suggesting that increasing periods of darkness treatment can be effective in animals that have aged beyond the peak of the CP. However, only partial recovery of NF density was observed with and was attributed to an insufficient duration of treatment. These findings were the same for equal durations of binocular vision, which has a similar anatomical recovery profile as DR. Overall, these findings suggest that complete anatomical recovery is possible for animals that have matured beyond the peak of the CP, but may not be necessary given the literature on behavioural recovery.},
}

@inproceedings{ali2016modifying,
  title = {Modifying an Online Intervention to Treat Sleep Problems in Children with Neurodevelopmental Disorders},
  author = {Ali, Nicole and Team, BNBD-NDD Investigative},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {The goal of this study, which is currently underway, is to transform an online sleep intervention, Better Nights, Better Days, which was designed for typically developing children so that it is appropriate and effective for use with children who have Neurodevelopmental Disorders (NDDs). A Delphi study will be used to survey experts in the area of sleep and NDDs for suggestions for developing an online intervention for sleep problems in children with NDDs. Their answers will be compiled, combined with suggestions drawn from the literature, and fed back to the experts who will rate, on a 7-point Likert scale, how important they believe each modification to be. Delphi rounds will continue until consensus is reached. The information gathered from this Delphi study, in combination with results from the literature, will ensure the modifications that are made to the Better Nights, Better Days intervention are based both in research and in expert opinion.},
}

@inproceedings{duffy2016susceptibili,
  title = {Susceptibility to monocular deprivation following immersion in darkness either late into or beyond the critical period.},
  author = {Duffy, Kevin and Lingley, Alexander and Holman, Kaitlyn and Mitchell, Donald},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {An extended duration of darkness starting near the time of birth preserves immature neuronal characteristics and prolongs the accentuated plasticity observed in young animals. Brief periods of complete darkness have emerged as an effective means of restoring a high capacity for neural plasticity and of promoting recovery from the effects of monocular deprivation (MD). We examined whether 10 days of darkness imposed in adulthood or beyond the peak of the critical period could rejuvenate the ability of MD to reduce the size of neuron somata within deprived layers of the cat dorsal lateral geniculate nucleus (dLGN). In adult cats subjected to 10 days of darkness before 7 days of MD, we observed no alteration in neuron size or neurofilament labeling within the dLGN. At 12 weeks of age, MD that followed immediately after 10 days of darkness produced an enhanced reduction of neuron soma size within deprived dLGN layers. At this age we observed that 10 days of darkness also enhanced the loss of neurofilament protein within deprived dLGN layers. These results indicate that while 10 days of darkness in adulthood does not enhance the susceptibility to 7 days of MD, darkness imposed near the trailing edge of the critical period can restore a heightened susceptibility to MD more typical of an earlier developmental stage. The loss of neurofilament in juveniles exposed to darkness prior to MD suggests the enhanced capacity for structural plasticity is partly rooted in the ability of darkness to modulate molecules that inhibit plasticity.},
}

@inproceedings{kraeutner2016imagine,
  title = {Imagine that! Motor imagery for skill acquisition},
  author = {Kraeutner, Sarah and Boe, Shaun},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Motor imagery (MI), the mental rehearsal of movement, is a useful adjunct to physical practice (PP) in numerous domains. However, to use MI when one is unable to engage in PP, such as post- stroke, we must establish whether MI alone can produce learning. Further, brain damage resulting from stroke may impact the effectiveness of MI. Thus, we must identify brain regions critical to MI. The objective of this work was to characterise MI-based learning independent of PP and investigate the role of parietal regions, commonly affected post-stroke, in MI. Findings demonstrate that MI alone facilitated learning. However, inhibition of parietal regions impaired MI-based learning. Therefore, while MI can facilitate learning in the absence of PP, the integrity of parietal regions are likely critical for MI performance and thus MI-based learning. Ultimately, these findings support the use of MI as a form of practice and inform applications of MI for neurorehabilitation.},
}

@inproceedings{mcwhinney2016age,
  title = {Age-related decline in white matter integrity differs in male and female healthy adults},
  author = {McWhinney, Sean R. and Tremblay, Antoine and Chevalier, Thérèse M. and Lim, Vanessa K. and Maessen, Heather D. and Bance, Manohar and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Gaining a better understanding of how white matter integrity changes over time will be beneficial in contributing to mitigation of health care challenges associated with an aging population. Healthy aging has been associated with a global reduction in white matter integrity, which is thought to reflect cognitive decline. The present study aimed to investigate this reduction over a broad range of the life span, using diffusion tensor imaging (DTI) alongside conditional inference random forest modeling (CForest). This approach is sensitive to subtle and potentially non-linear effects over the age continuum, and was used to characterize the progression of decline in greater detail than has been possible in the past. DTI data were collected from 45 healthy individuals ranging in age from 19 to 67 years. Fractional anisotropy (FA), a quantification of water diffusion and indicator of tract integrity, was estimated using probabilistic tractography for sixteen major tracts across the brain to provide widespread coverage. CForest was used to recursively partition data into subsets at the point of division yielding the most significant difference along a random selection of variables (including age, sex, handedness, and tract). This process was completed 10,000 times to create a distribution of FA estimates for each unique combination of variables, and subsequently estimate their impact on changes in FA. Age coincided with a general non-linear decrease in FA, with onset beginning at approximately 30 years of age and the steepest declines occurring later in life. However, several tracts showed a transient increase prior to this decline, notable until 36-38 years of age. The age of onset and progression of decline varied by tract, with steeper but later decline occurring in more anterior than posterior tracts. In general, males showed higher FA than females, though this was only evident for certain age-ranges that were tract-dependent, and while significant, sex differences were small. Lastly, strongly right-handed individuals demonstrated relatively preserved FA until more than a decade following the onset of decline of others. These results demonstrate known reductions in FA in healthy aging while providing new insight into the onset and progression of decline, while new evidence suggests increases in integrity continuing into adulthood.},
}

@inproceedings{joshi2016detecting,
  title = {Detecting an olfactory-based biomarker for early stage Parkinson's disease using Diffusion Tensor Imaging},
  author = {Joshi and N and Rolheiser and T and Fisk and JD and Good and KP and Khan and MN and Phillips and G and McKelvey and JR and Robertson, HR},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Diagnosis of Parkinson's disease (PD) requires the presence of motor symptoms although changes such as olfactory loss precede the emergence of motor symptoms. We sought to find diffusion tensor imaging (DTI) based biomarkers related to the loss of olfactory ability and substantia nigra dopaminergic neurons that might differentiate early-stage PD from healthy controls (HC). We used a Region-of-Interest approach to determine if anterior olfactory structures (AOS: olfactory bulb & tract) as well as the substantia nigra exhibit microstructural changes among PD and HC subjects. Twenty-three early-stage (Hoehn and Yahr stage I or II) PD and thirty-three age-matched HC were compared. Olfaction was tested using the University of Pennsylvania Smell Identification Test (UPSIT). Magnetic resonance imaging employed a 1.5T GE scanner and sequences such as a coronal T2 FRFSE sequence as well as an axial DTI sequence. Both regions were independently traced (manually) on each side of the brain of every subject using the T2 images, and the tracings registered to the DTI images. Measures generated included: Volume of the tracing on the T2 image, Fractional Anisotropy (FA), Mean Diffusivity (MD), Axial Diffusivity (AD) and Radial Diffusivity (RD) which were compared between the two groups using a two-way ANOVA with side and disease state as independent variables. Expectedly, UPSIT scores revealed poorer olfaction in PD subjects and DTI-variables also revealed group differences. These findings indicate that DTI measures of AOS and substantia nigra could differentiate early-stage PD patients from HC and support their use in the development of multimodal biomarkers to identify premotor stages of PD.},
}

@inproceedings{habibnezhad2016evidence,
  title = {Evidence-based attention rehabilitation after stroke: A review},
  author = {Habibnezhad, Mohammad and Cutmore, Laura and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {It is estimated that one Canadian has a stroke every 10 minutes, and mini-strokes happen every minute. Attention deficits are among the most commonly reported cognitive problems after stroke. Although attentional problems can improve over time, 20-50% of persons experiencing a stroke will have long-lasting impairments. Negative outcomes are common with attentional problems (e. g. longer hospital stays, limited independence, etc.); thus identification and/or development of effective interventions is crucial. We aimed to summarize the evidence for the effectiveness of cognitive rehabilitation in treating attention problems after stroke. We surveyed articles from Web of Science, Cochrane Register of Controlled Trials, PubMed (and PubMed Central, PMC), OT seeker, CINAHL (included databases: Academic Search Premier, Alternative Press Index, PsycARTICLES, PsycINFO, SPORTDiscus). Articles were included if they provided results from randomised controlled trials (RCTs) of cognitive rehabilitation (i.e. attention, working memory, executive function training) for people after stroke. Articles were excluded if they did not have at least one control condition, stroke patients did not comprise at least half of the study population, or the methods did not provide an adequate description of training procedures. Preliminary results of the quality of the evidence and overall results will be provided.},
}

@inproceedings{whitehouse2016effectivenes,
  title = {Effectiveness of Implementing Spatial Neglect after Right Hemisphere Stroke: A Clinical Trial},
  author = {Whitehouse, Christiane E. and Eskes, Gail A. and Braha, Richard E. and Boyce, Joy and Champod, Anne Sophie and King, Myrna},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Spatial neglect is a common attention disorder following right hemisphere stroke, and is associated with decreased independence and quality of life. Despite its high prevalence, there is currently no standard of care for the treatment of neglect. Prism adaptation (PA) is a promising rehabilitation technique, however incorporation into clinical care has been limited. We have developed a computerized PA procedure designed to better engage patients and assist clinicians. We aim to evaluate the effectiveness of the PA procedure in a typical health care setting. Twenty-six stroke inpatients will complete 10 sessions of either the PA procedure or an active control over two weeks. We hypothesize that those patients who complete the PA procedure will show a greater decrease in neglect severity and better functional outcomes compared to those in the control condition. An effective rehabilitation procedure for neglect patients would allow for faster recovery and increased independence in daily living.},
}

@inproceedings{leblanc2016does,
  title = {Does size really matter? Exploring the interference effects of size and orientation within a sequential grasping task.},
  author = {LeBlanc, Kevin and Westwood, David},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Previous research has suggested that the orientation of an object might be more influential in sequential tasks than size information. However, recent evidence from our lab has shown that preparing an action to the second object does not produce interference to the first action, but attending to its size for verbal judgment does. Specifically, as the size of the second object increased, the amplitude of peak grip aperture towards the first object also increased when performing the perception condition. The current study was designed in order to incorporate both size and orientation within a sequential task. Participants were required to grasp a cylinder (5cm in diameter) place it on an identified target area and than either grasp or make a perceptual judgment to the second object. The second object was either 3cm or 7cm in length and was either presented on a 45degree angle towards the left or the right. The results revealed that orientation information affected grip posture more so than size information in both conditions.},
}

@inproceedings{deacon2016children,
  title = {Children's awareness of sentence structure and their reading comprehension.},
  author = {Deacon, S.H and Kieffer, M},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {We test theoretical predictions as to how syntactic awareness, or awareness of word order within sentences, contributes to reading comprehension. We conducted a longitudinal study of 100 children followed from Grade 3 to 4. Children completed measures of syntactic awareness, word reading, and reading comprehension, and reading-related control variables. Path analyses at each of Grades 3 and 4 show a unique contribution of syntactic awareness to reading comprehension, with no mediation through word reading skills. Longitudinal analyses reveal that syntactic awareness at Grade 3 predicts gains in reading comprehension between Grades 3 and 4. Children's syntactic awareness has a direct and potentially causal influence on their reading comprehension.},
}

@inproceedings{korgan2016male,
  title = {Male Experience, Female Investment and Offspring Anxiety Behaviour: Where Father's Nature Meets Mother's Nurture…},
  author = {Korgan, Austin and O'Leary, Elizabeth and Bauer, Jessica and Weaver, Ian C.G. and Perrot, Tara},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Programming of reproductive strategies and defensive (stress) responses in the adult rat is programmed early in life by maternal care. The detection of a potential mate's past experience with predators could inform the dam about the stress level of a potential mate, the likelihood of paternal effects in offspring, and potential ecological threats. We examined whether a male's previous exposure to predator (cat) odor influences a female's attraction toward these males, subsequent mother-infant interactions and the development of long-term emotional (defensive) responses in the offspring. Our results show for the first time that variation among males in their predator encounters may contribute to stable behavioural variation among females in courtship and maternal care, even when the females themselves are not directly exposed to a predator. Furthermore, paternal predator experience is associated with long-term effects on chromatin plasticity and anxiety-like behaviour of the young adult offspring. These results, together with our previous findings, suggest that paternal predator exposure can influence offspring development both directly and indirectly, through altering maternal behaviour.},
}

@inproceedings{peverill2016impact,
  title = {The Impact of Wealth and Social Comparison on Sharing in Children},
  author = {Peverill, Sarah and Moore, Chris},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Prosocial behaviours (e.g., sharing, helping) are known to be influenced by the process of social comparison. Wealth is one variable that can lead to social comparison; people will describe themselves as rich or poor in comparison to another individual. The purpose of the proposed project is to investigate the influence of wealth and social comparison on prosocial behaviour in children aged four to eight years old. Children will spin a wheel and win more (wealthy condition), the same (control condition), or fewer (poor condition) stickers than a partner. Children will then be asked if and how many stickers they would like to share with their partner. It is hypothesized that children in the wealthy and poor conditions will share more and less, respectively, than children in the control condition. Understanding the factors that influence prosociality in children is necessary for encouraging and supporting the development of this important behaviour.},
}

@inproceedings{mahu2016personality,
  title = {Personality traits and methadone dose and compliance independently predict concurrent substance use in clients undergoing methadone maintenance treatment for opiate addiction},
  author = {Mahu, Ioan T. and Barrett, Sean P. and Peters, Lacey R. and Fulton, Heather G. and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {This study aimed to examine the relationship of personality and methadone dose/compliance to concurrent substance use in a sample of methadone maintenance therapy (MMT) clients. Sixty- eight clients (63.2% male; mean age = 38.5 years, SD = 9.8) were recruited from a low-threshold MMT clinic in Halifax, Canada (mean methadone dose = 105.4 mg, SD = 41.1). Substance use was assessed using an adapted version of the Drug List Questionnaire (Barrett, Gross, Garand, & Pihl, 2005). Demographic variables and methadone dose/compliance were collected via self-report. Personality dimensions were measured using the Substance Use Risk Profile Scale. Prescription opioid misuse was predicted by lower methadone compliance (B = -.606, OR= .545, 95% CI [.342- .869], p= .01), higher hopelessness (B= .259, OR= 1.30, 95% CI [1-1.67], p= .048) and anxiety sensitivity (B= .568, OR= 1.77, 95% CI [1.13-2.75], p= .012). Injection drug use (n=51) was predicted by lower methadone dose (B= -.043, OR= .96, 95% CI [.93-.98], p=.003), higher impulsivity (B=.398, OR= 1.49, 95% CI [1.04-2.14], p= .031) and hopelessness (B=.426, OR= 1.53, 95% CI [1.04-2.25], p= .03). In contrast, neither personality nor methadone variables predicted alcohol, cannabis, cocaine or benzodiazepine use. In sum, methadone variables and personality independently predicted opiate use and injection drug use patterns within a clinical sample of clients at a later stage of addiction. Results caution that personality may be targeted in treatment as a supplement to MMT.},
}

@inproceedings{macgowan2016social,
  title = {Social behaviour and aggression in the 5xFAD mouse model of Alzheimer's disease},
  author = {MacGowan, Taigan},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Background: Social dysfunctions in Alzheimer's disease (AD) are reported in a significant number of the patient population, and greatly contribute to the overall societal burden of the disease. While social withdrawal and aggression have been clearly documented in the AD patient population, they have not been well assessed in transgenic mouse models of AD. Methods: 5xFAD and control mice were housed in same-sex same-genotype pairs and were tested in behavioural tests aimed at quantifying measures of sociability and aggressive behaviours. Tests included a homecage interaction test, a newly-developed odour plus maze, and the three- chamber sociability test. Results: 5xFAD mice spent similar time interacting in their homecage, tended to spend less time in an area containing an unfamiliar social odour (U=13, p=0.07), but spent more time in an area containing a social stimulus (U=10, p=0.03) compared to control mice. Conclusions: These results suggest a complex interplay between social avoidance and approach behaviours that are dependent on the quality of the social stimuli. Although 5xFAD mice avoid a social odour, they approach a social stimulus. It is expected that this phenomenon may be due to apathy exhibited by these mice. These findings suggest that 5xFAD mice share key aspects of social dysfunctions observed in AD patients.},
}

@inproceedings{fertan2016determining,
  title = {Determining the age-related changes in spatial learning and memory in the 3xTG mouse model of Alzheimer's disease using the Hebb-Williams maze},
  author = {Fertan, Emre and Woodland, Nicole and Brown, Dr. Richard E.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {SUMMARY: The 3xTG mouse model of Alzheimer's disease develops intracellular plaques at 3 months, extracellular plaques at 6 months, and tau tangles by 12 months of age. We used the Hebb-Williams maze with food reward to assess learning and memory in 3xTG mice and their B6129SF2 wild type controls at 4 and 7 months of age. In the acquisition (Long-Term Memory) phase, 3xTG mice reached the learning criterion significantly faster than the WT mice and males reached criterion faster than the females. In the test phase (Working memory), 3xTG mice had significantly longer latencies in the hard mazes than the easy and medium mazes, but there was no such difficulty effects for the WT mice. The 4 month old male WT mice had significantly shorter latencies then female WT mice but there was no sex difference for the 3xTG mice. At 7 months of age male and female mice of both genotypes had longer latencies in the hard mazes. Our results show that (1) 3xTG and male mice have better long term memory compared to the WT and female mice. (2) Working memory deficits in the 3xTG mice start as early as 4 months but they can be detected only in difficult tasks. (3) Anxiety and motivation may be affecting the cognitive performance of 3xTG mice and WT controls.},
}

@inproceedings{perrot2016importance,
  title = {The importance of the seemingly unimportant.},
  author = {Perrot, Tara and Joshi, Namrata},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Laboratory studies involving rodents are designed to control for as many extraneous variables as possible. This generally results in the inclusion of at least one 'control' group, the goal for whom is exposure to all of the non-manipulated variables of the experiment, in a fashion identical to that of the experimental group, except for the manipulated variable. A number of reports over the years that shown that seemingly less important variables such as sex of the experimenter, exposure to routine lab procedures, and prior testing experience, can have experimental effects. We demonstrate that repeated exposure to a series of events that included experimenter handling, transport to and exposure to a novel room and arena had strong effects on anxiety-related behaviour in pair-housed rats. Interestingly, repeated exposure did not have the same effects in animals raised in isolation. These results will be discused within a stress inoculation framework.},
}

@inproceedings{horne2016how,
  title = {How to find the sexy secrets of the fruit fly's Va1v glomerulus.},
  author = {Horne, Jane Anne},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {For the last 6 years in collaboration with the Janelia Research Campus of HHMI we have been undertaking dense reconstruction of major parts of the Drosphila brain to produce wiring diagrams of synaptic networks. In the last two years we densely reconstructed the Va1v glomerulus in the antennal lobe. Dense reconstruction is an evolving technique that depends on advances in imaging hardware, imaging automation and processing, tissue preparation, manual tracing, computer vision and machine learning. In this presentation I will present the evolution of some of the techniques that lead to dense reconstruction and where we hope to go from here.},
}

@inproceedings{meinertzhagen2016connectomic,
  title = {Connectomic approaches to a simple brain},
  author = {Meinertzhagen, Ian},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {The brain of the fruit fly Drosophila melanogaster is unique in the range of genetic methods that can target transgenes to the identified neurons of its nervous system, and remarkable for the numerical and morphological determinacy of those neurons. Defining the complete synaptic networks, or connectomes, of behaviourally significant regions of the fly's brain requires us to reconstruct neurons at EM level, which is now routinely possible, albeit a highly labour intensive process. The product is a connectome, one that is complete, accurate and permanent (CAP: Brenner). Our work on this approach, now continued at the Janelia Research Campus of HHMI, has already identified neuron candidates for the Reichardt elementary motion detector circuit for directional selectivity, a longstanding mathematical model that for 50 years lacked biological implementation. Of course, an anatomical network is only a map, incomplete insofar as it lacks temporal information, necessary but not sufficient to analyse function. It is required for that analysis because it identifies neurons that then must be tested functionally. An early example identified a neuron required for fly UV phototaxis. This approach identifies a causal basis for behaviour, in a way that behavioural analyses alone cannot, nor can electro/optophysiological correlates of behaviour. In addition to enabling the interpretation of behaviour, a connectome is also predictive, identifying surprise pathways for which no behaviour has yet been reported, but which can then be tested.},
}

@inproceedings{hall2016not,
  title = {The not very hungry caterpillar: Illness-induced anorexia may allow the caterpillar Manduca sexta to shift molecular resources to immunity},
  author = {Hall, Laura and Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Like other animals, larval M. sexta lose their appetite after an immune challenge, yet the biological function of this illness-induced anorexia is poorly understood. This research examines the hypothesis that illness-induced anorexia allows the caterpillar M. sexta to shift molecular resources from food detoxification to immune function. Appetite loss occurred after injection of either sephadex beads, which induce encapsulation, heat-killed Gram negative bacteria (Serratia marcescens) or Gram positive bacteria (Bacillus cereus), which induce nodulation. Therefore, illness-induced anorexia appears to be a general response to immune activation in M. sexta, as it is in vertebrates. Caterpillars that received an immune challenge were more likely to die after ingesting permethrin than that those did not. Conversely, a sublethal dose of permethrin reduced resistance to the Gram negative bacterium S. marcescens. These results suggest that there is a negative interaction between detoxification and immune defense. During an immune challenge, caterpillars were less likely to consume food containing traces of quinine. We are in the preliminary stages of using qPCR to test for a potential conflict between detoxification and immune defense.},
}

@inproceedings{reeve2016changes,
  title = {Changes in food consumption, immune response, and immune gene regulation due to predator stress in the Tobacco Hornworm, Manduca sexta.},
  author = {Reeve, Catherine and MacDonald, Jenna and Turnbull, Kurtis and Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {When faced with the threat of predation, animals alter their behaviour and physiology in ways that are believed to maximize short-term survival and growth. Furthermore, adaptive changes in immune response are likely, as predation risk increases the chance of wounding. The current study examined the effects of simulated predator stress on food consumption, weight gain, immune response, and immune gene regulation in the Tobacco Hornworm, Manduca sexta. A predator rich environment was simulated by subjecting newly molted fifth instar hornworms to a series of leg pinches for three consecutive days. Subsequently, hemolymph was collected and a sample of fat body tissue was extracted. The hemolymph was used to test the effect of simulated predator stress on melanzation, number of hemocytes, total protein, PO activity, glutathione concentration, lysozyme activity, and clotting time. RNA was extracted from the fat body tissue and, after cDNA was generated, the relative expression of four immune genes (PAP3, Serpin3, Attacin, and Lysozyme) were measured using qPCR. Results revealed that caterpillars in the simulated predator stress group did not eat less than caterpillars in the control group, but gained significantly less weight. The concentration of glutathione in the hemolymph was decreased in caterpillars in the simulated predator stress group compared to the control group, and the hemolymph of caterpillars in the simulated predator stress group clotted faster than the hemolymph of the caterpillars in the control group. The simulated predator stress did not effect the regulation of the immune genes examined.},
}

@inproceedings{borycz2016searching,
  title = {Searching the function of the gene inebriated in the Drosophila eye.},
  author = {Borycz, Janusz and Borycz, Jolanta and Meinertzhagen, Ian A.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Histamine (HA) is a neurotransmitter released at photoreceptor terminals in Drosophila. We have previously found that as for vertebrate photoreceptor glutamate, most HA in the fly's eye is recycled via a glial shuttle pathway. In the process two enzymes are involved. The enzyme Ebony, which is expressed in epithelial glia that surround the photoreceptor terminals, conjugates b- alanine (b-Ala) to HA, to synthesise b-alanyl histamine (carcinine, CA). Then the enzyme Tan, which is expressed in the photoreceptors, hydrolyses CA to release HA and b-Ala. Transporters are essential to maintain the process, but these are largely unknown. Recently, we have found that carcinine is transported into photoreceptors by a transporter called CarT. We have also found a layered pattern of expression of a second transporter called Inebriated in the Drosophila eye. The inebriated (ine) gene encodes a Na+/Cl--dependent SLC6 family transporter and is translated as two protein isoforms, long (P1) and short (P2). Photoreceptors specifically express the P2 isoform whereas P1 is expressed in non-neuronal cells. Using Drosophila brain synaptosome preparations we have found that Inebriated may be involved in transporting b-Ala out of photoreceptors and at the same time may mediate photoreceptor uptake of CA. This function would overlap that of CarT but Ine expression is distributed differently in the fly's eye and also from vertebrate research on fast neurotransmitters, we know that glutamate and GABA are often transported by multiple transporters to provide rapid elimination from the synaptic cleft.},
}

@inproceedings{shaw2016impulses,
  title = {Impulses buried in the electroretinogram (ERG) of Drosophila come from amacrine neurons.},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Amacrine neurons (Am) in Drosophila's first visual synaptic zone receive many inputs directly from photoreceptors R1-6 at ~50 'tetrad' synapslets per axon terminal. Each tetrad also involves output neurons L1-3, as a quartet in which R1-6 L1, L2, Am, L3. Each postsynaptic participant except Am possesses ort histamine receptors, so can respond to histamine released from R1-6 during illumination, but Am is obviously excluded. Frequent neurites from amacrines feed back directly upon the photoreceptor axons, probably responsible for transiently cutting off R1-6's output, with a delay observed of only ≤ 2 milliseconds. Histamine is recycled or made with three enzymes that are individually defective in Drosophila mutants tan, ebony and hdc. As expected, the ON- and OFF-transients in the ERG associated with L1-L3's histaminergic responses are missing in all three mutants, but Hotta & Benzer (1969) nonetheless detected enigmatic wobbles on the initial phase of the residual light response. Improved techniques using white mutants like w, hdc910 now reveal these as bursts of extracellular impulses, the short initial latency of which confirms a monosynaptic connection from R1-6. These therefore must be impulses from amacrines, the only tetrad neurons not histamine-blocked. While L1-3 hyperpolarize, amacrines depolarize and spike, responding to a neurotransmitter that is not histamine.},
}

@inproceedings{brown2016alzheimer,
  title = {Is Alzheimer's a disease of the spleen?},
  author = {Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {There are at least 10 theories about the causes of Alzheimer's Disease (AD), but those involving amyloid beta and tau receive the most attention. Some time ago a professor of medicine told me how kidney disease can cause neural damage. We have found that our 3x-Tg- AD mice have enlarged spleens. As a joke I said that maybe AD is a disease of the spleen, BUT more and more evidence points to abnormalities of the spleen in AD. This talk examines the spleen, the enteric nervous system (ENS) and the brain-gut connections in AD. The role of the spleen, ENS and brain- gut system in AD may be a red herring OR it may be the missing link in understanding the development of AD and possibly other neurodegenerative disorders.},
}

@inproceedings{merwin2016need,
  title = {We need to talk: The influence of disclosure of female sexual problems on sexual and relationship well-being},
  author = {Merwin, Kathleen and BScH and Rosen, Natalie O.},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Disclosure (sharing personal thoughts, feelings, and information) is an essential part of relationships. General disclosures in romantic relationships and sexual disclosures (e.g., disclosing personal sexual likes and dislikes) in particular are related to higher sexual and relationship satisfaction. Sexual problems are common in romantic relationships, with research showing that 43% of women have experienced one or more sexual concerns in the previous 18 months. Despite the high prevalence of sexual problems, the relational and sexual consequences of disclosing sexual problems to a romantic partner remain unknown. The present study examines the rate of disclosure of sexual problems and whether disclosure is related to sexual and relationship well- being. Women (N = 280) completed online questionnaires about their sexual problem(s), and their sexual and relationship well-being. Women that disclosed sexual problem(s) to their romantic partners (n = 194, 69%) reported greater sexual functioning and relationship satisfaction and lower depression than those that did not disclose sexual problem(s) to their partners (n = 86, 31%). Findings may identify factors that could be targeted in sex and couples' therapy, such as increasing intimate disclosure, for the many intimate relationships that encounter sexual problems.},
}

@inproceedings{cowie2016automatic,
  title = {Automatic Approach Biases toward Gambling Stimuli in Canadian and Dutch Gamblers.},
  author = {Cowie and M, E. and Salmon and J, P. and Jong, de and D and Boffo and M and Salemink and E and Wiers and R, W. and Stewart, H. S},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Implicit association research has provided considerable insight into the cognitive mechanisms underlying addictive behavior (Reingold & Ray, 2005). The "automatic approach bias" (automatic tendency to approach stimuli; Wiers et al., 2009), has increased our understanding of the cognitive influences on addiction. A gambler's automatic approach bias toward gambling stimuli, however, has yet to be studied. The present study adapted Wiers' Alcohol Approach Avoidance Task to the gambling context, testing its validity among problem and non-problem gamblers in Canada and the Netherlands. The Gambling Approach Avoidance Task was developed with Dutch images and adapted for Canadians. As hypothesized, Dutch problem gamblers displayed a stronger approach bias toward gambling stimuli than non-problem gamblers, which was related to greater gambling severity. Canadians displayed no approach bias toward either stimulus. Moreover, gambling approach bias scores were negatively correlated with gambling severity suggesting an unexpected aversion to gambling stimuli. Reasons for these discrepancies are discussed.},
}

@inproceedings{farmer2016perfectionis,
  title = {Perfectionism and life narratives: A qualitative study},
  author = {Farmer and R, J. and Cowie and M and Mackinnon, S. P},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Perfectionism has been conceptualized as a multidimensional personality trait involving striving for flawlessness, placing exorbitantly high standards for performance, and the tendency to be excessively critical regarding self-evaluations of behaviour. However, there is almost no research examining the life narratives of perfectionistic people. The present study sought to examine how perfectionistic people conceptualize perfectionism, and how they narrate their significant life events. We tested a sample of 22 university students who qualify as highly perfectionistic (N = 8 adaptive and N = 14 maladaptive perfectionists). Using thematic analysis, we identified 11 themes within participant responses to questions about their conceptualization of perfectionism. These themes supported previous conceptualizations of perfectionism, but also revealed novel facets. Within the life narratives interview, we identified 5 major themes (relationship success, relationship problems, agentic redemption, agentic contamination, and academic success), which provided an intriguing perspective as to how perfectionistic students comprehend their lives through narratives.},
}

@inproceedings{mackinnon2016gender,
  title = {Gender and homophily in naturalistic seating patterns: A teaching activity},
  author = {Mackinnon, S. P and Class, PSYO},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {A new field research activity was tested as a teaching tool for PSYO 3082. Students observed seating patterns in naturalistic environments such as busses, cafeterias, and computer labs. Specifically, they looked for gendered seating patterns: That is, do men tend to sit by men, and women by women more often than chance? Students first conducted statistical power analysis for their study, striving to reach 80% power. Then, students collected data in pairs, generating a total of 13 datasets (234 observations in total; range 7-40). Students analyzed data using Hernandez's (2014) index of adjacency calculator, and one-sample t-tests. Overall, only 5 of 13 students supported the hypothesis within the individual datasets. However, when data were combined together into a mega-analysis, hypotheses were clearly supported, t(233) = -6.28, p < .001. Presenting data as a forest plot served as a useful teaching moment on the importance of replication and cumulative science.},
}

@inproceedings{jarvis2016first,
  title = {First Language Effects on the Learning of Grammatical Gender in a Second Language},
  author = {Jarvis and M, E. and Newman and J, A. and Frenck-Mestre, C},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Some languages contain categorization systems for nouns called grammatical gender, while others do not. Learning a second language with grammatical gender can pose different obstacles for individuals from different linguistic backgrounds. This study aims to address two questions: 1. Does having grammatical gender in one's native language make it easier or harder to learn gender in a new language, compared to not having grammatical gender in one's native language? 2. Do explicit and implicit training methods differ in their efficacy for teaching grammatical gender in a new language, and does this differ depending on whether or not one's native language has grammatical gender? To achieve these aims we will use a between-groups design, training English and French native speakers on a small artificial language that has a gender system wherein half of the nouns have the same lexical gender as in French, and the other half have gender that conflicts with French. Half the participants in each native language group will receive explicit training; the other half implicit training. Using a match/mismatch paradigm paired with EEG, we will compare participants in each language group and training group on their ability to learn grammatical gender in the artificial language.},
}

@inproceedings{oneil2016cortical,
  title = {Cortical Changes Linked to Semantic Integration},
  author = {O'Neil and K and Newman and A and Frenck-Mestre, C},
  booktitle = {Psychology and Neuroscience 42nd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2016},
  abstract = {Previous work has shown that adult second language learners can rapidly acquire second language vocabulary, and newly acquired vocabulary words are integrated into existing semantic networks in the brain. However, prior research has focused on vocabulary learning, while the current study will be expanded to focus on sentence processing and will provide information on a higher level of integration. Of particular interest is how well adult second language learners can integrate and process newly learned linguistic materials at the sentence level. Participants will complete a 5-day video-game-based second language training program, and their brain activity (measured with electroencephalography, or EEG) will be measured pre and post-training. Eye- tracking will also be used to assess how participants naturally read sentences containing newly acquired second language vocabulary. Crucially, we will examine cortical changes across sessions to novel sentences (i.e. those not learned during training), which will allow us to determine if participants are able to generalize their vocabulary knowledge gained through training to new sentences.},
}

@inproceedings{k2017investigatio,
  title = {Investigation of neuron structural modifications within the visually deprived superior colliculus.},
  author = {K, NESC: Zajdlik and S, Lausch and C, Crouse and T, Elia and E, Aronitz and S, Ellis and J, Fish and P, Lagman and J, MacDonald and E, McGroarty and D, Mustafa and M, Piercey and S, Bassil and L, Connell and S, Lee and K, MacLellan and J, Pappin and G, Ribeiro and S, Kraeutner and KR, Duffy},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Neurons within the mammalian primary visual pathway exhibit a high capacity for neural plasticity early in postnatal development. Even a short duration of monocular deprivation (MD) can led to structural and functional neural modifications that result in a profound visual impairment called amblyopia. Although modification of neurons with the superior colliculus (SC) has been suggested to underlie ocular motor deficits associated with amblyogenic rearing, identification of structural abnormalities within the SC has been elusive. In this study we imposed a complete form of MD by inactivating one eye for 10 days. We reasoned that this extreme form of amblyogenic deprivation would be more likely to precipitate measureable structural abnormalities within the SC. Following 10 days of MD we observed a reduction in the size of neuron somata within the contralateral SC that receives most input from the inactivated eye. We also showed that this form of MD is sufficient to cause a loss of neurofilament protein within the SC contralateral to the inactivated eye. These results demonstrate that a profound monocular deprivation is sufficient to catalize neuron structural modification within the superior colliculus, and this alteration may be enabled by a reduction of neurofilament protein that destabilizes the cytoskeleton and raises the capacity for plasticity.},
  note = {Poster},
}

@inproceedings{horne2017major,
  title = {Major connections in glomerulus VA1v in the Drosophila antennal lobe},
  author = {Horne and JA and S, McLin and M, Wiederman and JA, Borycz and D, Tarnogorska and Team, FlyEM Project and S, Plaza and S, Xu and H, Hess and IA, Meinertzhagen},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
