  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {In the initial study of an ongoing project investigating quality of life and psychosocial functioning in MS patients, 89 subjects from the Dalhousie MS Research Clinic were assessed. Scores on the Mental Health Inventory were used as the dependent measure in a multiple regression analysis that included measures of social support, fatigue, responsiveness to stress, physical handicap, neurological disability, duration of disease and disease activity. Results indicate that social support and fatigue are important issues for MS patients. These two factors alone accounted for 44.8% of variance in Mental Health scores of the total sample. Furthermore, standard status meaures of neurological disability and physical handicap were not significant predictors of Mental Health status in MS patients.},
