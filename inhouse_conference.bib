}

@inproceedings{whalen1978power,
  title = {The Power of Learning Theories.},
  author = {Whalen, T.},
  booktitle = {Fourth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1978},
  abstract = {The nature of a theory of learning may be determined using theoretical machines called finite automata. There is some finite automaton which will behave in the same way as any organism. As an organism learns, however, it changes its behaviour. Therefore, there will be a way to change a finite automaton so that it also behaves in this new way: A description of these changes will be equivalent to a theory of learning. If it can be shown that a particular process is required to alter a finite automaton so that it learns appropriate behaviour, a theory of learning must also incorporate this process. For example, if it can be shown that something more than stimulus- response associations are required for a "naive" finite automaton to learn some behaviour, then S-R theories will not be sufficient to account for this learning.},
  note = {QA: needs-split-review; Split from 25-split1 at: 'T. Whalen'},
}

