  year = {1977},
  abstract = {At the perforant path-dentate granule cell synapse, the increased synaptic efficacy following brief episodes of high frequency activation can be resolved into a long lasting component and one or more short last- ing components. The long lasting component requires about 50 seconds to develop, following the stimulation, and may last, under some circumstances, for weeks. The short lasting effects are present immediately following activation, and decay completely within minutes. Different rules govern the development of the two effects. They interact in a fashion con- sistent with the hypothesis that a post-synaptic mechanism under]ies the long lasting effect.},
}

@inproceedings{klein1977hemispheric,
