  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {eye photoreceptor terminals (Rl-R6) and intemeurons are reciprocally connected. At each afferent synaptic sites a presynaptic ribbon in R-R6 abuts a postsynaptic tetrad containing processes of two monopolar cells, Ll & L2. L2 in tum provides feedback input to Rl- R6 at a synaptic dyad. We have examined both afferent and feedback synapses, in each case following the loss of their main target cells. When R 1-R6 degenerated by photoablation, presynaptic ribbons of feedback synapses separated from teh presynaptic membrane and soon appeared free floating in L2's cytoplasm. Despite the presence of floating ribbons the number of L2 synapses increased twofold during an overlapping period of reactive synaptogenesis. When L1 and U degenerated by lesioning, presynaptic ribbons of afferent synapses were only mod~tely affected with slight decreases in their frequency. Thus many presynaptic ribbons in Rl-R6 outlive their postsynaptic partners. This difference in the reaction of photoreceptor and monopolar cells following the loss of postsynaptic partners, reflects a greater dependence of monopolar cells upon their targets, Rl-R6, than of Rl-R6 upon their targets, L2 and Ll.},
}

@inproceedings{mcnulty1991psychologicaa,
  title = {Psychological sequelae of carbon monoxide poisoning and their},
  author = {McNulty, John},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {treatment with hyperbaric oxygen One of the most frequently observed symptoms of carbon monoxide (CO) poisoning is "mental" or "cognitive" impairment. These symptoms often persist even when other medical and neurological symptoms have disappeared. The standard treatment for coexposure is hyperbaric oxygen. If symptoms are minor, or exposure time is short, patients are sometimes treated only with oxygen at normal atmospheric pressure or are not treated at all. There are, however, "hints" that failure to treat even mild cases may result in relatively permanent neuropsychological deficits. Some preliminary data and suggestions for research on the problem will be presented.},
}

@inproceedings{losier1991cholinergica,
  title = {Cholinergic and aminergic inputs from the mesopontine area to the basal forebrain and thalamus: A hypothesis for brainstem involvement in cortical arousal},
  author = {Losier, BrunoJ. and KazueSemba},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {Researchers of behavioral states have investigated the role of specific direct and indirect cholinergic inputs of the basal forebrain and mesopontine tegmental cholinergic areas in the regulation of waking and sleep. This study examines the contribution of tegmental cholinergic, serotonergic and dopaminergic cell groups in modulating the activity of both thalamic and basal forebrain neurons in cortical arousal. Following multiple injections of both FITC beads into the basal forebrain, and Fluorogold into the thalamus, alternate sections from the forebrain and brainstem were processed for immunohistochemistry with antibodies to visualire cholinergic and aminergic neurons. Injection sites were plotted and alternate brainstem sections were surveyed for the presence of triple labeled neurons.},
  note = {QA: abstract-too-short},
}

@inproceedings{frankland1991non,
  title = {Non-temporal and temporal effects on the perception of pattern in sequential stimuli},
  author = {Frankland, B.W.},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {The analysis of the perception and/or cognition of pattern in sequentially presented stimuli is constrained by non-temporal and temporal factors that limit the number and type of possible temporal patterns. This work will discuss the effects of such constraints on the perception of pattern in the contour (the pattern of up and down) in sequentially presented tones. In particular, a brief review of the role of tonality (essentially, a non- temporal constraint) and the role of short term memory (essentially a temporal constraint) on the perception of pattern in contour will be presented. --------},
}

@inproceedings{ozier1991mood,
  title = {Mood and memory: Open your Ears and close your eyes Usually we remember better if given a category cue to the meaning of the word we are},
  author = {Ozier, Marcia and Blumenthal, Andrea},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {seeking in memory than if we are given an alphabetic one. That finding reverses if we are induced into depression before trying to remember. Induced depression results in a dramatic decrease in the potency of category cues to meaningful words. Previous reports have been based upon an experimental design in which words were presented visually and test cues presented visually. The current experiment asked whether the decrease in potency of category cues under induced depression would occur if presentation and test were auditory rather than visual. The loss of meaning as a function of induced depression seems to be specific to the visual modality. The moral is: If you feel down, open your ears and close your eyes. This remedy is not recommended if you feel down while you are driving a car.},
}

@inproceedings{localiiation1991hiroshi,
  title = {Hiroshi Abe, Benjamin Rusak and Harry Robertson Photic induction of Fos protein in the suprachiasmatic nucleus is},
  author = {localii.ation, are so poor at sound},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {inhibited by NMDA receptor antagonists Exposure of hamsters to light can induce c-fos immunoreactivity in cells of the suprachiasmatic nucleus (SCN), which is a dominant pacemaker in the mammalian circadian system. Excitatory amino acids (EAAs) have been implicated in both the entrainment pathway by which light synchronizes circadian rhythms and in the induction of c-fos in other parts of the nervous system. We examined the effects of pre-treatment with MK-801 and ketamine which are non-competitive N-methyl-D-aspartate (NMDA) receptor antagonists on the induction of Fos-like immunoreactivity (Fos-lir) in cells in the hamster SCN. Pretreatment with these drugs blocked photic induction of Fos-lir in a dose-dependent manner in the rostral SCN and ventral portions of the caudal SCN, but not in a discrete region of the dorsolateral SCN. These results suggest that the NMDA-type of EAA receptor may be involved in the photic induction of Fos-lir in most of the SCN but not in one portion of the SCN.},
}

@inproceedings{croll1991injury,
  title = {Injury-induced neuroplasticity in the snail Following a crush to a central pathway in the snail, the nervous system responds by},
  author = {Croll, Roger P.},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {regenerating lesioned axons, by rerouting some fibres to contralateral pathwyas and by sprouting new projections from uninjured neurons. Together these responses lead to supernumerary neurites throughout the nervous system. These abberrent projections are gradually lost, and normal projection patterns return by 5 weeks after the lesion. When regeneration is prevented by cutting rather than crushing the nerve, supernumerary elements continue to increase with no return to normal numbers evident after 15 weeks. Together these results suggest that the cessation of sprouting and the retraction of supernumerary fibres are dependent upon successfulregeneration of the injured neurons.},
}

@inproceedings{lamoureux1991studies,
  title = {Studies of ambiguous pitch: Direction and reaction time measures},
  author = {Lamoureux, Michael},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {In line with our interest in the representation of sequential patterns, listeners judged the pitch direction of pairs of randomly selected Shepard tones (synthesized from 10 consecutive octave components with amplitude envelope peaking over central components) from the set of 12 semitones in the octave. Direction judgments were consistent for short absolute distances between tones and were bivalent for distances of 5- 6 semitones. Reaction time data and the pattern of directions preceding ambiguous intervals reveals whether ambiguous pitch is disambiguated by preceding redundant directional patterns.},
  note = {QA: abstract-too-short},
}

@inproceedings{fentress1991marvels,
  title = {The marvels of mutant mice in motion},
  author = {Fentress, John and Bolivar, Valerie and Coscia, Elizabeth and Danilchuk, Wanda},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {The marvels of mouse movements provide the inspiration for this projecL The small but sophisticated brains of these little beasts enable them to articulate beautifully coordinated actions. These, as other animal (and human) actions, challenge us to think carefully about how mammalian brains achieve their essential balance between isolable operations and the rules of combination in space and time among these operations. We shall treat the troops with our first attempts to employ benign developmental analyses of neurological mutant strains to examine fundamental problems of pattern formation in behavioral organization. The data are preliminary, but you'll love our mice!},
  note = {QA: abstract-too-short},
}

@inproceedings{rodger1991betcha,
  title = {Betcha Bob's E~ is better than the bruited ~ by a bundle The traditional anova procedures is badly flawed so far as type-I error-rate is concerned, leading to a dramatic loss of power ~ as the numerator degrees of freedom of the variance- ratio increases, given a fixed NL( µj - µ_)2 162 . There are also serious ambiguities involved in setting ~ for a pre-chosen .r(µj - µ_)2. These problems are resolved if Rodger's (1967-) method is used. That sets rejection rates for null contrasts at Ea when they are true and at E~ when they are false by the pre-chosen amount g 6..['f;;2j·The amount of treatment effect claimed after analysis can be justified by maximum likelihood if E~ has been chosen wisely.},
  author = {Rodger, R.S.},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  note = {QA: abstract-too-short},
}

@inproceedings{corkum1991development,
  title = {Development of early interlimb coordination},
  author = {Corkum, Valerie},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {Recently, increasing attention has been devoted to the application of dynamical theories of motor coordination to infant motor developmenL A number of studies indicate little synchrony in early movement patterns but a significant increase over the first 6 months. A recent study by Thelen and colleagues found the legs to be coupled in the form of compensatory limb movements at 6 weeks of age. However, as yet, the developmental trend of compensatory limb movements has neither been documented for the legs nor has its existence even been explored in the anns. The present study looks developmentally at these two types of motor coordination (i.e., synchronous and compensatory movements) in both arms and legs in order to understand better the nature and ontogeny of early interlimb coordination.},
}

@inproceedings{smith1991sodium,
  title = {Sodium Amytal memory testing: Use in prediction of post-surgical},
  author = {Smith, Isabel and McGlone, Jeannette},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {amnesia The intracarotid sodium amytal procedure is used worldwide to determine lateralization of speech (Wada, 1949) and memory (Milner et al., 1962) prior to temporal lobe resection for epileptic seizure control. Jack et al. (1988) have advocatedinjection of sodium amytal directly into the posterior cerebral artery (PCA), rather than the internal carotid artery (!CA), for the selective examination of memory functions. They argue that more direct inactivation of the posterior hippocampus would improve prediction of post-surgical amnesia; the increased risk associated with catheterizing the PCA makes this a controversial suggestion. In addition, Milner (1972) and Rausch et al. (1989) claim that using the standard ICA injection, filling of the PCA is not necessary to produce amnesia. We examine the relationship between filling of the PCA (blind angiographic ratings) and recognition memory in 83 epileptic patients undergoing the traditional ICA procedure. We also discuss other factors related to the reliability and validity of the intracarotid sodium amytal memory tesL},
}

@inproceedings{mcgrath1992parental,
  title = {PARENTAL MANAGEMENT OF POST-OPERATIVE PAIN},
  author = {McGrath, Patrick and Finley, G.Allen and McNeill, Gillian and Forward, Paula and Fitzgerald, Peter},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Although most children's post-operative pain is managed by parents at home, no studies have examined parental management of the adequacy of their practices. We will present data on 200 subjects from a survey of parents who have children aged 2-12 years who have undergone surgery and been discharged within a day. Data will be presented on levels of pain and treatment used for different groups.},
}

@inproceedings{beaver1992pattern,
  title = {PATTERN OF C-FOS EXPRESSION IN AREA 17 OF VISUALLY DEPRIVED KITTENS FOLLOWING INTRODUCTION OF NORMAL VISUAL INPUT},
  author = {Beaver, Chris and Mitchell, Donald E.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Last year we reported on the rapid expression of cf os in various visual cortical areas of dark-reared kittens following their initial exposure to light. Here we focus on the pattern and time course of this expression visualized in both coronal secretions and in unfolded and flattened sections of the visual cortex. Data relevant to two issues will be discussed, namely, the possible involvement of cfos in the signal pathway that mediates experience-dependent change in the visual cortex during development, and possible modular organizational principles of the cat visual cortex.},
}

@inproceedings{phillips1992ode,
  title = {ODE TO A HAIRDRESSER. WHY SHE SMILES AND NODS AT PARTIES, OR, WHEN "YES" MEANS "I DIDN'T UNDERSTAND A DAMNED WORD YOU JUST SAID".},
  author = {Phillips, Dennis P. and Rappaport, Jamie M. and Gulliver, J. Mark},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {One of the most common complaints of listeners with noise-induced cochlear hearing loss is that they have difficulty discriminating speech in noisy environments. Historically, this problem has been attributed to a loss of frequency resolving power in the cochlea. This is because the impaired frequency resolution is independently demonstrable, and because it is, in the principle, the kind of deficit that might prevent the ear from encoding the distributions of spectral energy that identify the phonemes of speech-a problem that is presumably only exacerbated by the presence of masking noise. In this talk, we present evidence which (a), knocked our socks off, and (b) suggests that a defect in temporal, rather than frequency, resolution accounts for the perceptual difficulty reported by these patients.},
}

@inproceedings{honig1992discriminati,
  title = {DISCRIMINATION BY PIGEONS OF UNIFORMITY AND MIXTURE IN ARRAYS OF STIMULUS EFFECTS},
  author = {Honig, Werner K.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Pigeons pecked at a video "touch screen" on which randomized arrays of 36 small squares of two different colors were presented in various proportions. With uniform arrays of red or blue elements, responding to the right side of the screen was rewarded. With all mixed arrays, containing both red and blue elements, responding to the left side was rewarded. The pigeons provided orderly proportions of choices in the form of gradients which reflect the degree of stimulus mixture in the arrays. This discrimination transferred readily to arrays of green and blue elements, and to arrays consisting of fewer (25) and more (64) elements than the training arrays.},
}

@inproceedings{nakajima1992location,
  title = {LOCATION OF DOPAMINERGIC SITES CRITICAL FOR BRAIN-STIMULATION REW ARD},
  author = {Nakajima, Shinshu},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {The locus of dopamine receptors critically involved in the generation of reinforcing effect of brain stimulation was examined. Rats were trained to press a bar for the lateral hypothalamic stimulation, and D 1 or D2 antagonists was injected through the cannula during the operant responding. D1 antagonists suppressed responding when injected into a part of the nucleus accumbens, ventral tegmentum, or their vicinities. D2 antagonist suppressed responding only when injected into the nucleus accumbens, and not into any other loci.},
}

@inproceedings{eskes1992picture,
  title = {A PICTURE IS NOT ALWAYS WORTH A THOUSAND WORDS: DISSOCIATIONS BETWEEN EXPLICIT AND IMPLICIT MEMORY TESTS.},
  author = {Eskes, Gail and Moscovitch, Morris and McCauley, Mary},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Performance on explicit (e.g., free recall) and implicit (e.g., word stem completion) memory tests can be dissociated experimentally; implicit tests are said to involve automatic or unconscious memory processes, while explicit tests require strategic or consciously-controlled processes. Thus, it has been traditionally asswned that explicit tasks would benefit from elaborative processing during study (e.g.,imagery), while this kind of processing would have no effect on implicit memory tasks. The current study suggests that while imagery does benefit explicit test performance as expected, using imagery during study can actually reduce implicit task performance in young adults. In contrast, older adults show reduced benefits of imagery on explicit tasks, and fewer costs of imagery on implicit tasks. Performance on some implicit memory tasks may not be so automatic, after all.},
}

@inproceedings{cole1992pigeon,
  title = {PIGEON UMWEL T II: IS A PICTURE AS GOOD AS A PLACE TO A PIGEON?},
  author = {Cole, Patricia and Honig, Werner K.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Pigeons were trained on a simultaneous slide discrimination between colored slides of various views of the ends of a rectangular room. A control group was trained on an irrelevant slide discrimination between outdoor scenes. After reaching criterion on this "2D" task, the birds were released into the actual room previously represented in slide photographs and allowed to forage. Their behaviour in this "3D" task suggested the photographic medium may capture real world cures that are salient to pigeons as well as humans.},
}

@inproceedings{barresi1992meditations,
  title = {MEDITATIONS ON MALCOLM X: A SOCIO-PSYCHOLOGICAL ANALYSIS},
  author = {Barresi, John and Juckes, Tim},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {The relationship between individual and social forces in the historical transformation of society is not well understood. On the one hand, it appears that it is the action of individuals in pursuit of personal (subjective) goals that produces social change. On the other hand, it appears that (objective) social forces produce change. We (Juckes and Barresi, in preparation) have developed a model that articulates how these two types of forces can be understood jointly to produce social change. In the present paper the life-history of Malcolm X and his role in the development of black consciousness in America will be used to illustrate the usefulness of this model.},
}

@inproceedings{li1992vitro,
  title = {IN VITRO STUDY OF DROSOPHILA VISUAL SYSTEM},
  author = {Li, Chinglu and Meinenzhagen, Ian A.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {With its much simpler structural and functional organization compared to that of the vertebrates, the visual system of fruit fly, Drosophila,provides an ideal preparation forthe studies of synaptogeneseis. Success of in vitro culture of this system can funher simplify this system, permitting experimental control over spatial and temporal aspects of its development. By screening different culture conditions, we • have established primary cultures of eye imaginal discs and its target neuron, the optic neurons.},
}

@inproceedings{corkum1992cues,
  title = {CUES FOR JOINT VISUAL ATTENTION IN INFANTS},
  author = {Corkum, Valerie and Moore, Chris},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Joint visual attention refers to the ability to follow another's direction of gaz.e.This project examined the relative importance of eye and head orientation in the establishment of joint attention in infants ranging from 6 to 19 months. In a face to face interaction with the experimenter, infants were exposed to four types of trials in which head and/or eye position varied: H (head only), E (eyes only), H+E (head & eyes match), and H-E (head & eyes mismatch). Results indicate that 6 to 10 month olds do not reliably engage in joint attention based on information from any of the cues while 12-13 month-olds establish joint attention based on head position alone. In contrast, 15 to 19 month olds rely on congruent head and eye position for determining direction of gaze and joining attention. At no age did infants establish joint attention based on eye position alone whether presented in isolation or in the context of the H-E cue. Based on these findings it appears that while head orientation is initially the most salient cue, by 15 months, head and eye orientation play equal roles in the establishment of joint attention.},
}

@inproceedings{piggins1992electrophysi,
  title = {ELECTROPHYSIOLOGICAL INVESTIGATIONS ON THE SUPRACHIASMATIC NUCLEUS IN VITRO},
  author = {Piggins, Hugh and Rusak, Ben},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {The suprachiasmatic nuclei (SCN) of the hypothalamus house a dominant circadian pacemaker. Our research involves monitoring the effects of exogenously administered neurochemicals on the extracellularly recorded spontaneous firing activity of SCN cells maintained in a brain slice preparation in vitro. In particular, we examine how substances which are thought to be released from the visual projections to the SCN and substances which are intrinsic to the SCN affect SCN cells. Through this research, we aim to characterize the neuropharmacology of the circadian clock.},
}

@inproceedings{jensen1992development,
  title = {•THE DEVELOPMENT OF TRIADIC INTERACTIONS IN WOLVES (CANIS LUPUS) AND RED FOXES (VULPES VULPES)},
  author = {Jensen, Keith and Fentress, John},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Triadic interactions are social interactions that involve three individuals. They likely require greater social sophistication than dyadic interactions, and may be important for animals that live in complex social groups and engage in activities requiring coordination of behaviour. If triadic interactions are adaptive, then they should be exhibited more often and display a more coordinated form in social canids (wolves) than relatively asocial canids (foxes). Preliminary analyses indicate that during ontogeny, wolf pups do become more triadic in their social interactions than fox kits do. Further analysis will show whether the triadic interactions take on a more cooperative form in wolves.},
}

@inproceedings{davidson1992user,
  title = {USER FRIENDLY STATISTICS FOR EVALUATING RISK FACTORS FOR CHD MORTALITY},
  author = {Davidson, Karina and Chaplin, William and Prkachin, Kenneth},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Large scale studies have relied on tests of statistical significance to index and evaluate risk factors to coronary heart disease (CHD). Because such statistics are influenced by sample size and measurement error, they do not provide a clear indication of the practical implications of risk factors for mortality from coronary heart disease. In this paper, we describe an alternative to traditional tests of statistical significance, Rosenthal's binomial effect size display (BESD), that effectively and unambiguously communicates the pragmatic importance of risk factors for coronary heart disease (CHD) mortality. Moreover, the BESD facilitates both the evaluation of the relative importance of risk factors within one study, and the stability of the same risk factor in different studies.},
}

@inproceedings{mcmullen1992naming,
  title = {NAMING FAMILIAR FACES ROTATED IN TWO AND THREE DIMENSIONS},
  author = {McMullen, Patricia A.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Naming latencies have supported mental representations of objects in 3/4 view. Yet, cells in the monkey temporal gyrus respond preferentially to frontal and profile views of faces. Are objects and faces represented in fundamentally different ways? Frontal, 3/4 and profile views of familiar faces were named. Like objects, upright faces in 3/4 view were named the fastest However, rotations in the picture-plane· had equivalent effects on latencies for 3/4 and frontal views and much greater effects for profile views.},
}

@inproceedings{mcalpine1992young,
  title = {A YOUNG CHILD'S DEVELOPING UNDERSTANDING OF PAIN},
  author = {McAlpine, Linda M. and McGrath, Patrick J.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Further advancement in assessment and treatment of pain in children has been hampered by our limited knowledge of emerging concepts of pain in preschool children and by their immature expressive language. Methodologies used to research a child's developing "theory of mind" proved useful in revealing how young children conceptualize pain. It was hypothesized that preschool children would progress from recognizing pain in others to imputing to others the emotions which pain evokes and subsequently to predicting behaviour resulting from pain experience. This hypothesis was investigated through collection of a two week language sampling from subjects (30 children, aged 18-76 months) augmented by data collected during structures play sessions in which the children assume the characters in pictures and of toy figures who experience pain. Comparisons were made to the children's developing concepts of internal states in themselves and others.},
}

@inproceedings{connolly1992event,
  title = {EVENT-RELATED POTENTIALS TO PHONOLOGICAL AND SEMANTIC PROCESSING IN SPOKEN SENTENCES},
  author = {Connolly, John F. and Phillips, Natalie A.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {In previous studies (Connolly et al., 1990; 1992) a negative-going component peaking at about 200-250 msec after the onset of the terminal word of a low contextually constrained (spoken) sentence was observed in conditions which also elicited a N400 response. The N200 and N400 were found to be differentially sensitive to phonologically correct masking-N400 peak latency was delayed while N200 was unaffected. The N200 was hypothesized to be sensitive to the initial phoneme of the terminal work and a reflection of the acoustic-phonetic process in the phonological stage of word processing. The present experiment was designed to explore further the N200 and the N400 elicited by the terminal words of spoken sentences. Four conditions were employed which elicited the N200 and N400 together, separately and not at all. Results are interpreted as supporting the idea of the N200 as reflecting an acoustic-phonetic process and the N400 as a process dependent upon the "outcome" of the process(es) manifested by the N200. Results for the N200 are also interpreted in relation to the cohort model of spoken word recognition with particular reference to the concept of recognition-point},
}

@inproceedings{eskes1992memory,
  title = {MEMORY AND AGEING: HOW DOES SEMANTIC PROCESSING HELP?},
  author = {Eskes, Gail and Craik, Gus},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {While there is general agreement that semantic processing during item study enhances later recall, little attention has been directed at investigating whether different types of semantic processing (e.g., cueing superordinate vs subordinate properties) are differentially effective in increasing memory performance. The results of this study suggest that some types of semantic processing can have differential effects on memory performance. In general, however, processing of superordinate or subordinate features had similar effects on memory, while words associated with more elaborative processing were better recalled by both young and older adults.},
}

@inproceedings{braha1992visual,
  title = {VISUAL WORD RECOGNITION AND VISUAL ATTENTIONAL PROCESSES IN DEVELOPMENTAL DYSLEXIA: A FAMILIAL CASE STUDY*},
  author = {Braha, Richard and Klein, Raymond},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Reading and visual attentional processes were studied in a family with two known developmentally dyslexic children. The family underwent neuropsychological assessment and a series of cognitive experiments. Control group S's provided normative data. The sets included: Coltheart's reading battery; a test of memory for visual spatial and temporal information; Olson's component reading skills task; visual attentional distractor tasks, and 4 separate tests of exogenous and endogenous control over overt and coven orienting of visual attention. Both parents and 4 of the 5 children displayed reading disabilities and several similar problems with visual attentional processes. * Previously presented at the Rotman Research Institute's conference on attention (Toronto, March, 1992).},
}

@inproceedings{bolivar1992development,
  title = {DEVELOPMENT OF MOVEMENT SEQUENCES IN JIMPY (CNS MYELIN DEFICIENT) MICE},
  author = {Bolivar, Valerie and Manley, Kevin and Danilchuk, Wanda and Fentress, John},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {We examined the ontogeny of grooming and swimming behaviors in mutantjimpy male pups and their littennate controls. The animals were videotaped at 2 day intervals from the 3rd to the 21st day postpartum. Developmental measures included the percent time spent grooming, the number of grooming bouts and interlimb coordination during swimming. Results indicate that the mutants displayed a developmental lag in swimming ability, however, they did spend more time grooming and groomed earlier than littermate controls. Our data confirms the importance of detailed behavioural documentation if we are to understand how gene expression affects motor development},
}

@inproceedings{phillips1992cognitive,
  title = {COGNITIVE IMPAIRMENT IN PATIENTS WITH LOWER EXTREMITY AMPUTATIONS SECONDARY TO PERIPHERAL VASCULAR DISEASE},
  author = {Phillips, Natalie A. and Mate-Kole, C. Charles and Kirby, R. Lee},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Peripheral vascular disease (PVD) refers to disease of any of the blood vessels outside the heart and accounts for approximately 75-80% of lower-extremity amputations performed today. Although patients with PVD are considered neurologically normal, PVD might lead to cerebral ischemia or cerebrovascular disease. We hypothesized that patients with PVD would show cognitive deficits on neuropsychological assessment Memory, language function, visuopatial ability, and problem solving were evaluated in 14 patients with lower-extremity amputations secondary to PVD and 16 healthy elderly age-matched controls. Patients with PVD performed more poorly than controls on tests of visuopatial ability, problem solving and abstract reasoning. It is suggested that the cognitive status of amputee patients with PVD should be considered in prosthetic rehabilitation programs.},
}

@inproceedings{mitchell1992development,
  title = {DEVELOPMENT IN KITTENS BASED ON OBSERVATIONS OF CAT-301 IMMUNOREACTIVITY IN THE dLGN OF VISUALLY DEPRIVED ANIMALS},
  author = {Mitchell, Donald E. and Beaver, Chris},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {The monoclonal antibody, Cat-301, recognizes a surface associated antigen (a chondroitin pulphate proteoglycan) on a specific class of neurons (Y-cells) in the central visual pathways of cats. Cat-301 is first expressed in the dLFN of kittens at 4 weeks of age and adult levels are not reached until 6 months of age, a time course that is mirror symmetric to the declining ability of the central visual pathways for experience-dependent change. During the course of experiments that explored further the experience-dependent nature of Cat-301 expression, we observed that short periods of monocular deprivation resulted in low overall immunoreactivity in both the deprived and nondeprived laminae of the dLDN's. This and other findings from this investigation hold implications for the timing sensitive periods in visual development.},
}

@inproceedings{phillips1992selective,
  title = {SELECTIVE ADAPTATION STUDIES OF CAT CORTICAL AUDITORY NEURONS},
  author = {Phillips, Dennis P. and Hall, Susan E.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Studied with tone pulses of any given amplitude, neurons of the cat's primary auditory cortex are excited by a narrow range of tone frequencies. Curves plotting response rate as a function of frequency have an inverted- V shape, and are very narrow in relation to the animal's audible range. On the basis of persuasive, if somewhat thin evidence, we once argued that in some neurons, such a curve actually represents the envelope of the response ranges of a number of independent inputs tuned to similar, but not necessarily identical, frequencies. We have now directly tested this notion by obtaining response-vs-frequency functions for tone impulses in the absence and presence of a continuous tonal masker whose frequency was set at the edge of a neuron's effective frequency range. Our data support the hypothesis that the response-vs-frequency function is indeed, for some neurons, the envelope of those for a number of independent, closely-tuned points.},
}

@inproceedings{hamm1992orientation,
  title = {ORIENTATION EFFECTS DURING OBJECT NAMING},
  author = {Hamm, Jeff},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Are the effects of orientation on object naming due to finding the top of rotated objects or in identifying the object? Experiment 1 cued the location of the top prior to an object naming task. Experiment 2 cued object identity prior to a top-bottom discrimination task. Experiment 1 showed no influence of cuing, and Experiment 2 showed a benefit of cuing identity. Neither experiment showed a reduction in the effects of orientation due to cuing. The effects of orientation found in top-bottom discriminations may be explained as response competition.},
}

@inproceedings{yoon1992action,
  title = {ACTION DEVELOPS EARLIER THAN ATTRIBUTION OF THINKING OR RETROACTIVE JUSTIFICATION},
  author = {Yoon, Myong G. and Yoon, Myonghae},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {We studied the development of children's understanding of false beliefs in cross- sectional (3ylm - 5y0m; N=88) and longitudinal (2y8m - 4y6m; N=l 1) experiments. During 3ylm- 3y6m, 52% of 22 children were able to make correct predictions such that the protagonist's action would be consistent with the , protagonist's false belief. Most (95%) of them, however, were unable to explain their own correct predictions, and rarely made an explicit attribution of the false belief to the protagonist. They also showed difficulties in justifying the protagonist's futile action retroactively, in spite of their preceding successful predictions of the protagonist's action. During 3y7m - 4y0m, 38% of 22 children acquired new abilities to explicitly attribute the false belief to the protagonist, whereas they made only a minor improvement in making correct predictions (61%). In general, children's ability for a correct prediction of action developed 4-7 months earlier than those for explanation of prediction, attribution of thinking, or retroactive justification of the protagonist's futile action.},
}

@inproceedings{pyza1992day,
  title = {DAY/NIGHT AND CIRCADIAN RHYTHMS IN THE FIRST VISUAL NEUROPILE IN THE OPTIC LOBE OF THE FLY MUSCA DOMESTICA},
  author = {Pyza, Elzbieta and Meinertzhagen, Ian A.},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {In the fly's visual neuropile, or lamina of the optic lobe, the frequency of synaptic profiles changes during the 24 hours period. Under light/dark conditions (LD 12: 12), the number of afferent tetrad synapses formed upon two interneurons Ll and L2 is higher during the day but numer their reciprocal counterparts from L2 formed back upon receptor terminals is higher during the night. Examination of the presynaptic ribbon profiles under constant darkness conditions (DD) revealed a strong circadian rhythm in frequency of feedback synapses and less pronounced rhythm in frequency of tetrad synapses. In the present study, the seize of presynaptic ribbon profiles in single EM sections has been measured at LD 12:12 conditions. Moreover, we have measured area, perimeter, length, formfactor and diameter of two intemeurons Ll and L2 under LD and DD conditions. The results obtained from this study have shown no statistically significant differences in the seize of presynaptic ribbon of tetrad and feedback as well as synapses. In parameters of Ll and L2 intemeurons, however, there were remarkable differences at all levels oflamina depth between day and night at LD and between subjective day and subjective night at DD conditions. Ll and specially L2 intemeurons were bigger during the day and subjective day than during the night and subjective night.},
}

@inproceedings{semba1992cholinergic,
  title = {CHOLINERGIC AND SEROTONERGIC MECHANISMS OF RAPID EYE MOVEMENT (REM) SLEEP},
  author = {Semba, Kazue},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Cholinergic neurons in the mesopontine tegmentum have implicated in the regulation of REM sleep. Serotonergic suppression of these cholinergic neurons has long been postulated on the basis of behavioural studies, but no direct proof was available. We have investigated serotonergic input to cholinergic neurons using both physiological (intracellular recordings using brain slices in vitro) and anatomical (tract tracing, irnmunohistochemistry, and electron microscopy) techniques. The results were consistent with the suggested role of serotonin in modulating rapid eye movement sleep phenomenology through its inhibitory action on cholinergic neurons in the mesopontine tegmentum.},
}

@inproceedings{ryon1992wolves,
  title = {WOLVES' RESPONSES TO CONSPECIFIC URINE-MARKS},
  author = {Ryon, Jenny and Paquet, Paul and Brown, Richard},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {We studied urine-marking and responses to marks in a pack of gray wolves (Cm ~ housed at the Dalhousie Animal Behaviour Field Station for five years. Dominant wolves of both sexes urinated at higher frequencies than subdominant wolves. Responses included sniffing, over-marking, and licking. The type of response varied with the sex, age, reproductive status, and/or age of both the marking and the investigating individual. In adults, marks of female wolves were investigated more than those of males. The frequency of all types of response for the marks of adult females followed the same circannual rhythm of urine-marking frequency, with a peak during the winter mating season. Urine-marks may aid in reproductive synchrony in some wolves, while suppressing reproductive readiness in others.},
}

@inproceedings{schellinck1992expression,
  title = {EXPRESSION OF C-FOS IN THE ACCESSORY OLFACTORY SYSTEM OF JUVENILE FEMALE MICE AFTER EXPOSURE TO MALE-SOILED BEDDING},
  author = {Schellinck, Heather and Smyth, Cathy and Brown, Richard and Wilkinson, Michael},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Exposure to the urine or soiled bedding odours of novel adult males is known to accelerate puberty in juvenile female mice. To determine what part of the olfactory system is activated by these odours, the expression of cf os in the main olfactory bulb (MOB) and the accessory olfactory bulb (AOB) of juvenile female mice was examined after their exposure to male-soiled bedding, peppermint extract or their own bedding. Well defined immunoreactivity was found throughout the AOB of the juvenile female mice exposed to the bedding odours of adult males for 3 and 12 hours. In contrast, dense fos staining was found in the granular cell layer of the MOB of mice exposed to peppermint odours for 3 or 12 hours. Of the mice exposed to their own bedding for 3 or 12 hours, none showed immunostaining for fos in the AOB; slight or no staining was observed in the MOB. These data indicate that social odours activate fos in the AOB while non-social odours activate the MOB.},
}

@inproceedings{daloisio1992dysphoria,
  title = {DYSPHORIA AND CERTAINTY FOR SOCIAL JUDGEMENTS},
  author = {D'Aloisio, April and Sullivan, Mick and Murphy, Fionnula},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Nineteen dysphoric and 20 nondysphoric subjects read brief person descriptions that were either high or low in information value, and were asked to make trait ratings for each person described. Subjects were then asked to indicate their level of certainty in the ratings they made. Results showed that dysphoric subjects were less certain than nondysphoric subjects in the trait ratings they made for low information descriptions. It is argued that, in the absence of detailed stimulus information, dysphoric individuals may be impaired in their ability to generate heuristic mental representations of social stimuli. The findings are discussed in relation to current positions on biased and realistic information processing in dysphoria.},
}

@inproceedings{francis1992dysphoria,
  title = {DYSPHORIA AND APPLICATION OF GENDER STEREOTYPES},
  author = {Francis, Judith and Sullivan, Mick},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {This present study investigated the relationship between mood and application of gender stereotypes. Dysphoric and non-dysphoric subjects read statements describing a male or a female target behaving in a manner consistent or inconsistent with stereotypes for the target's gender. A three-way interaction was found between mood (dysphoric, non-dysphoric), target sex and stereotype consistency of behaviour (consistent, inconsistent). Dysphoric subjects rated female targets as more likely to engage in stereotype consistent behaviour than non-dysphoric subjects. As a function of limited cognitive resources, dysphoric subjects may have used stereotypes as a heuristic to reduce the cognitive processing demands of the prediction task.},
}

@inproceedings{tihova1992freeze,
  title = {FREEZE-FRACTURE ELECTRON MICROSCOPY OF RECONSTITUTED CYTOCHROME OXIDASE},
  author = {Tihova, Mariana and Tattrie, B. and Nicholls, Peter},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {Eukaryotic cytochrome oxidase (CO) is a multisubunit enzyme spanning the inner mitochondrial membrane. The size, shape and other gross features of the 3- dimensional structure of this protein have been obtained only for its isolated crystal form. The enzyme can be incorporated into liposomes of a defined lipid composition. Freeze-fracture electron microscopy of cytochrome oxidase vesicles (COV) was used to study the structure of the reconstituted enzyme. The enzyem incorporation was characterized by size distribution of the protein "bumps" of Pt/C replicas of convex and concave surfaces determined using a MCID program (Imaging Res. Inc.). Ta/W shadowing was used to obtain images with higher resolution, which allow us to find out some details on the surfaces of the protein.},
}

@inproceedings{bolivar1992ontogeny,
  title = {THE ONTOGENY OF ULTRASONIC VOCALIZATIONS IN CNS MYELIN DEFICIENT (JIMPY) MICE},
  author = {Bolivar, Valerie and Brown, Richard},
  booktitle = {Eighteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1992},
  abstract = {We recorded both the ultrasonic vocalizations (UVs), at 65, 70, 75 and 80 kHz, and motor behaviours of jimpy mouse pups at 2 day intervals from days 2 to 20 postpartum. Jp/Y males vocalized less frequently than their normal male littennates from 2 to 8 days of age. For both jp/Y and normal mice, the rate of UVs was highest at day 2 and decreased with age up to day 8, after which UVs ceased almost completely. Our results indicate that UVs may be useful as an early predictor of future neuromuscular anomalies.},
}

@inproceedings{frame1993negative,
  title = {NEGATIVE PRIMING IN A LOCALIZATION TASK: A METHODOLOGICAL CRITIQUE AND AN EMPIRICAL PUZZLE},
  author = {Frame, Kelly and Christie, John and Klein, Raymond},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {When a subject is presented with pairs of trials (prime followed by probe) in which a target (0) must be localized, sometimes in the presence of a distracting non-target (+, distractor), response time is slower if a probe trial's target appears in the location occupied by the previous (prime) trial's distractor than when it appears in a new location. This finding (negative priming) suppons the proposal that selective attention is accomplished by active inhibition of irrelevant information. The literature, however, is characterized by an insensitivity to design features necessary to ensure the purity of the observed effects. When all necessary conditions are included, our results reveal interference, negative priming, and both inhibition and facilitation at the previous target's location. Yet these mechanisms, alone, are insufficient to explain the data. Will there still be a role for negative priming when the full puzzle is solved?},
  note = {Poster},
}

@inproceedings{hall1993gender,
  title = {GENDER DIFFERENCES IN THE CONSTRUCT VALIDITY OF TWO HOSTILITY MEASURES},
  author = {Hall, Peter and Davidson, Karina},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Objective: To detennine the construct validity of the Ho subscale of the MMPI and the structured interview method (SI) of hostility measurement while examining gender differences. Design: Correlational Setting: University Participants: From an introductory psychology class. Mean age of nineteen. 54 male and 87 female volunteers were used. Interventions: Subjects were given a standard structured interview and asked to fill out the Ho scale and the PANAS negative affect (NA) scale. Measures: Two tailed t-tests were used to compare means of males with females. Simple correlations and intercorrelations between Ho and SI measures were used. Results: For females 9% of the variance (r=.30) in scores on the Ho scale were accounted for by variability of scores on the NA scale. No significant variability in PH scores was accounted for by NA scores in females. In males, 11% of the variance (r=.34) in scores on the Ho scale were accounted for by variability in NA scores. Scores of PH accounted for an additional 33% of variability in Ho scores in males. Conclusions: It appears that Ho and SI methods of hostility assessment are not measuring the same construct for females, but have high construct validity for males. Rater-reliability and other possible confounding factors for the female hostility data will be presented. There are significant gender differences in expression of hostility.},
  note = {Poster},
}

@inproceedings{hamm1993response,
  title = {RESPONSE COMPETITION CONTRIBUTES TO THE EFFECTS OF ORIENTATION WHEN LOCATING THE TOP OR BOTTOM OF ROTATED OBJECTS},
  author = {Hamm, Jeff P. and McMullen, Patricia A.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {The time to determine if a dot is located near the top or bottom pole of rotated objects increases linearly for rotations up to 120 deg. This effect has been linked to a similar effect of orientation found for rotated object naming. However, different causes for these effects may be inferred if it was shown that they were panly due to response compatibility in the top-bottom discrimination task. Results from this task showed that responses to dots at the top were faster than those to dots at the bottom of the screen. This effect was additive with the effects of object orientation. However, compatibility between location of the dot on the screen and response was confounded with object orientation. Objects near upright orientations were confounded with compatible responses and objects at more extreme orientations were confounded with incompatible responses. To determine if response compatibility accounted for some of the effects of orientation during top-bottom discriminations, "top" and "bottom" keys were positioned horizontally or vertically. Vertical key placement, which was thought to improve response mapping, resulted in a greater effect of orientation than horizontal placement The effects of orientation during top-bottom discriminations may partially reflect response competition, suggesting these orientation effects are not reflective of those found during rotated object naming.},
  note = {Poster; QA: abstract-too-short},
}

@inproceedings{dywan1993electrophysi,
  title = {ELECTROPHYSIOLOGICAL CORRELATES OF SINGLE-WORD RECEPTIVE VOCABULARY IN CHILDREN},
  author = {Dywan, Christopher and Byrnes, Joseph and Connolly, John},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {A computerized version of the Peabody Picture Vocabulary Test, Revised, was developed to examine potential electrophysiological correlates of single-word receptive vocabulary in normal IO-year-old children. Of primary interest will be ERP components that may differentiate between picture-word pairs that match or mismatch at 3 levels of difficulty (below age, at age and above age level). This paradigm may potentially facilitate objective assessment of single word receptive vocabulary in patients whose conditions, such as Cerebral Palsy, may preclude traditional assessments based on verbal or motor responses. If available, preliminary data will be presented and discussed.},
  note = {Poster},
}

@inproceedings{schellinck1993why,
  title = {WHY DOES ORIENTATION-SENSITIVITY DIMINISH DURING REPEATED NAMING OF ROTATED OBJECTS: FEATURES OR OBJECT-CENTRED REPRESENT ATIO NS?},
  author = {Schellinck, Heather A. and McMullen, Patricia A.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Effects of orientation on rotated object naming diminish over presentation blocks. Is this effect due to emergent naming based on orientation-invariant features (Jolicoeur & Milliken, 1989) or on object-centred representations (see Marr, 1982)? If the former, then repeated naming of objects whose features are spatially scrambled should diminish effects of orientation on a final block of intact, rotated object naming in the same way that repeated blocks of intact, rotated object naming does. In contrast, if naming over blocks is based on emergent reliance on object-centred representations, then repeated naming of feature-scrambled objects should not result in diminished effects of orientation on a final block of intact, rotated object naming. To test which hypothesis is better supported, one group of subjects repeatedly named feature-scrambled objects followed by a final block of intact, rotated object naming. A second group named intact rotated objects in all blocks. A final group repeatedly named intact, upright objects followed by a block of intact, rotated objects. Effects of orientation on the final block, were diminished after repeated naming of intact, rotated and feature-scrambled objects but not after repeated naming of upright objects. These results support the hypothesis that feature-based naming underlies the diminished effects of orientation over repeated blocks of rotated object naming.},
  note = {Poster},
}

@inproceedings{kind1993effects,
  title = {THE EFFECTS OF MONOCULAR DEPRIVATION AND REVERSE OCCLUSION ON THE EXPRESSION OF CAT-301 IN AREA 17 OF KITTENS},
  author = {Kind, Peter C. and Beaver, Chris J. and Mitchell, Donald E.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Although considerable recovery can occur from the effects of an early period of monocular deprivation (MD) following prompt imposition of a period of reverse occlusion (RO), recent behavioural work has revealed that this procedure can result in a wide variety of other outcomes, including severe bilateral amblyopia. In an attempt to understand the mechanisms that underlie the behavioral findings, we have examined the expression of the Cat-301 antigen in area 17 of kittens monocularly deprived to 4, 5, 6 or 8 weeks of age that subsequently received either a period of RO (that lasted from 9 days to 12 weeks) followed by binocular visual exposure, or else the latter alone. We have reported previously that certain of these regimens that employ short periods of RO result in very low levels of Cat-301 expression in the dLGN, equivalent to levels reported in dark-reared animals. We now report that these same rearing regimens also result in a substantial reduction of Cat-301 expression in area 17. The largest decrease (as much as 75%) occurred in the supragranular layers with a smaller decrement (about 30%) evident in the upper portion of layer 4.},
  note = {Poster},
}

@inproceedings{francis1993mood,
  title = {IN THE MOOD: INFLUENCE OF MOODS ON SELF-DISCREPANCIES},
  author = {Francis, Judith and Davidson, Karina},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {The purpose of the present study was to examine the causal relation between self- discrepancies and mood. According to Self-discrepancy theory (e.g. Higgins, 1987), various self-concept discrepancies represent enduring cognitive structures, which when activated produce specific changes in mood. The purpose of the present study was to test the hypothesis that transient mood states can influence the type of self-discrepancies reported. Subjects were assigned to one of two mood induction conditions: sad, or anxious. After mood was induced, subjects completed the Selves Questionnaire which measures self-concept discrepancies. Results of analyses support Higgins' proposed causal relation between mood and self-discrepancies. When subjects were classified as dysphoric or non-dysphoric based on BDI scores, dysphoric subjects were found to have higher ideal discrepancy scores as well as greater ought discrepancy scores, regardless of mood induction condition. Results support a uni- directional relationship between self-discrepancies and mood and argue against a reverse causality hypothesis.},
  note = {Poster},
}

@inproceedings{frame1993effects,
  title = {EFFECTS OF SEX HORMONES ON COGNITIVE ABILITIES: A CRITICAL REVIEW},
  author = {Frame, Kelly A.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Effects of sex hormones on cognitive abilities in humans has been investigated 1) prenatally, by acting to organize neural pathways and 2) by activating previously organized functions in adulthood. Because it is difficult to manipulate hormones in humans, research on activational effects has relied upon naturally occurring bio- rhythms, and medical conditions. The menstrual cycle is a convenient way to study how hormonal fluctuations might influence cognitive abilities in women. For example, high levels of estrogen (follicular phase) have been associated with poorer performance on spatial tasks compared to performance during menses when hormones are low (Hampson, 1990). Other studies have focused on a cycling of cognitive performance in relation to brain laterality effects. Heister et al. (1989) reported right hemisphere superiority on a visual perception task during menses which decreased linearly through follicular and luteal phases to a small left hemisphere superiority effect during the premenstrual phase. To date, theoretical explanations are unconfirmed and methodology is problematic. A summary of relevant results as well as theoretical implications and methodological suggestions will be proposed.},
  note = {Poster},
}

@inproceedings{macgregor1993sex,
  title = {SEX DIFFERENCES IN TARGET HOSTILITY RATINGS},
  author = {MacGregor, Michael and Davidson, Karina},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {This study examined: 1) Sex differences in the ability to detect hostility during an audio recording, and; 2) the extent to which such differences affect subject- and friend- agreement about the subject's hostility level. Data was collected from 112 undergraduates who each provided the name of a close friend To determine their ability to detect hostility the friends completed the MacGregor Hostility Recognition Scale (MACH-0 after listening to either a high or low hostile audio recording. Results indicated that in both the high and low hostile recordings males (M=3.4 and M=2.7 respectively) reported significantly less hostility to be present than females (M=4.0, 1(52)=-2.9,12.-.005and M=3.1, 1(51)=-1.8, 12-.056 respectively). When male and female ratings of hostility were subtracted from the actual levels of hostility in the recordings (as determined by expert raters) females (Mdiff=.27) were significantly more accurate than males (Mdiff=.86, 1(52)=2.9, l2,_.005)on the high hostile recordings. No difference in accuracy was found between males (Mdiff=-.72) and females (Mdiff=-1.13, t=l.80, 12>.05)on the low hostile recordings. Second, the subject's hostility level, measured by the Cook-Medley Hostility Scale, was rated by both the subject and the subject's friend and subject- friend agreement was determined Male friends had less agreement with male subjects about hostility (M=19.43. SD=l0.14) compared to female friends with male subjects (M.=25.47, SD=8.30, 1(34)=-2.00, 12-.053). Thus it appears that males are less accurate in detecting hostility.},
  note = {Poster},
}

@inproceedings{ingenmey1993gender,
  title = {GENDER DIFFERENCES IN SOCIAL REFERENCING DURING A STRANGER INTERACTION},
  author = {Ingenmey, Rita and Dunham, Philip J.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {We asked 1) whether 9-month-old males and females differ in their tendency to visually reference their mother during the infants' interaction with a stranger and 2) if gender differences are observed in infant's emotional reactions. Maternal employment conditions were also included as a moderator variable. Thirty-four infants played "peek-a-boo" with a female experimenter while the mother's profile was in the infant's view. Looks at mother were used as an index of social referencing and Izaard's (1983) AFFEX was used to assess the infant's emotional expression. Females referenced their mothers more .f(l, 29) = 6.05, 12<.02, than males but no gender differences were observed in the infants' emotional reactions. Infants with mothers employed outside the home smiled more frequently at the stranger, E,(1,29) = 7.58, 12<.01, than infants with mothers working inside the home. The results suggest that gender differences in social referencing behaviour are observed as early as 9 months and that these gender differences in referencing are not emotionally mediated.},
  note = {Poster},
}

@inproceedings{klein1993why,
  title = {WHY DO FIXATION OFFSETS FACILITATE SACCADIC LATENCIES?},
  author = {Klein, Raymond and Taylor, Tracy and Kingstone, Alan},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {When the fixation point is removed 200 ms prior to the appearance of a visual target (gap condition), subjects can initiate saccades within 100 ms. This is so much faster than the typical (when the fixation remains present, overlap condition) saccadic reaction time (RT) that the label "express saccade" has become popular. We will describe some problems with this label and suggest that investigators focus their attention on those factors which act to reduce RT in the gap condition. Our research suggests a 2- component model of the gap effect: 1) motor preparation which can operate in any response modality and is dependent on the foreperiod between any warning signal and a subsequent target, and 2) saccadic disengagement which (normally) depends on removal of the fixation stimulus, operates specifically to reduce saccadic latencies, and may be mediated by the rostral pole of the superior colliculus.},
}

@inproceedings{shaw1993evaluation,
  title = {RE-EVALUATION OF THE MOST SENSITIVE KNOWN "VIBRATION" DETECTOR},
  author = {Shaw, Stephen R.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {In vertebrate auditory systems, basilar membrane vibration has been measured directly: absolute threshold is reached at displacement amplitudes of -4 x 10-9 meter, i.e. at dimensions that are small on an atomic scale. It has been claimed that the supersensitive knees of some insects do even better by the large factor of-200 (0.002 nm threshold), raising the question of whether these magnificent animals have discovered some superior biophysical principle that has been missed in vertebrate evolution. The lab cockroach is the best of all, but previous students of its knees have failed to agree on just how sensitive these really are. Further, none of them calibrated their vibrators directly at the tiny amplitudes with which they worked, but trusted the perilous procedure of unsupported linear extrapolation downwards from much larger calibrated movements. Finally, some investigators delivered stimuli that may have unwittingly included an acoustic component. We have subsequently shown that the cockroach leg's "vibration" detector is a sensitive auditory organ, and that this may even be its primary response mode. In light of this, a new device has been developed that allows the leg's vibration threshold to be measured directly without acoustic complications. Overlapping calibrations eliminate the potential problems issuing from non-linear extrapolation. Some preliminary results will be described.},
}

@inproceedings{stuart1993temporal,
  title = {TEMPORAL RESOLUTION IN DIFFERENT FREQUENCY CHANNELS OF HUMAN COCHLEAR OUTPUT},
  author = {Stuart, Andrew and Phillips, Dennis},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Last year, Phillips and colleagues reported that patients with selective high- frequency cochlear hearing losses evidenced a temporal resolution defect in their auditory perception. This defect expressed itself as a compromised ability to discriminate spoken words against a background of noise that fluctuated in amplitude, a task that requires the auditory system to resolve the speech fragments that occur in the troughs of the noise envelope. We argued that these listeners were performing the task using their (normal) low-frequency hearing, and that the low frequency channels of cochlear output have inherently poor temporal resolution. To test this hypothesis we have studied normal listeners with the same general paradigm, and under two listening conditions: (a), normal, and (b), one which prevented them from using their high-frequency hearing, namely low-pass filtering of the stimuli. The pattern of responses obtained under the "filtered-stimulus" condition precisely mimicked those obtained in patients with high-frequency, sensorineural hearing loss. This made us very happy troopers. It.· i'f! rii • r},
}

@inproceedings{rusak1993circuitous,
  title = {CIRCUITOUS CIRCADIAN CIRCUITS},
  author = {Rusak, Benjamin and Abe, Hiroshi},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {The suprachiasmatic nucleus (SCN) of the hypothalamus is the major pacemaker of the mammalian circadian timing system. It is synchronizedby environmental light cues conveyed from the eyes to the SCN directly via the retinohypothalamic tract and indirectly through a portion of the lateral geniculate nuclei called the intergeniculate leaflet (IGL). We have used light-induced expression of the immediate-early gene cfos as a marker for retinal input to the SCN, in order to study which neurotransmitter receptors must be activated in order to convey light information to this nucleus. Evidence from many sources indicates that the NMDA receptor is critical to the photic entrainment process. Nevertheless, neurons in one restricted portion of the SCN continue stubbornly to express cfos under photic control, despite blockade of either NMDA or non-NMDA amino acid receptors. We found evidence that suggested that these cells were continuing to get input indirectly from the IGL, but further tests have refuted this model. Our newer results now suggest that there are two pharmacologically and anatomically distinct direct retinal projections to the SCN. This revised model may also require reinterpretation of the results of several earlier studies.},
}

@inproceedings{eskes1993role,
  title = {THE ROLE OF THE PREFRONTAL CORTEX IN CONDITIONAL},
  author = {Eskes, Gail},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {DISCRIMINATION LEARNING Rats with prefrontal lesions are impaired on conditional discrimination learning (CDL), a task that requires them to associate one response to a particular stimulus and a differentresponse to another stimulus. The role of the prefrontal lobe in this task is unclear. Deficits on CDL could be due to either an inability to learn the necessary associations between the different stimuli and responses, and/or to a difficulty in selecting the correct response, given a particular stimulus. The present study was designed to attempt to distinguish between these two alternatives. Rats with prefrontal lesions (PFC, n=I0) and sham-operated controls (SC, n=ll) were first compared using the standard CDL paradigm, in which they were required to learn to respond to one of two bars, depending on the location of the light stimulus. We confirmed the impairment of PFC lesioned animals on this paradigm as previously reported (Winocur, 1991). In the next phase, we attempted to eliminate the necessity of selecting between the two equally probable response alternatives by providing only one bar during any one light stimulus. Correct responding (either pressing the correct bar, or not pressing the incorrect bar) was rewarded. Thus, in this new procedure, rats were tested for their knowledge of the association between the light and bar, in the absence of the need to make a choice between the two available bar press responses. Under these conditions, PFC animals were not impaired on CDL when compared to controls. Performance averaged over the last 2 days of testing were: 67.4%± 4.39 correct vs 66.49% ± 4.53, PFC vs controls, respectively). These data suggest that deficits seen in conditional discrimination learning due to prefrontal lesions are due to a difficulty in selecting between response alternatives, rather than in forming associations between stimuli and responses. (In collaboration with Gordon Winocur)},
}

@inproceedings{fidler1993effects,
  title = {EFFECTS OF PREEXPOSURE ON FEAR CONDITIONING TO A CONTEXT},
  author = {Fidler, Tara and LoLordo, Vincent M.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Nonreinforced exposure to a stimulus typically makes it harder to condition that stimulus when it is reinforced. This phenomenon is called latent inhibition. In the present experiment, which used a 3 X 2 factorial design, groups of rats were repeatedly, but briefly, preexposed to: (1) the context in which they would subsequently be conditioned, or (2) a tone in that context, or (3) a different context Then rats from each of these groups were randomly assigned to two subgroups. One set of subgroups received several sessions in which the tone occurred and was followed by a brief footshock. The others received the shock but not the tone. Conditioned freezing was assessed. Rats that were preexposed to the tone in the conditioning context and then given tone-shock pairings in that context learned to freeze in that context sooner than any of the other groups, and maintained a higher level of freezing there over a number of extinction sessions. This result is noteworthy because it is the opposite of the latent inhibition usually obtained. We will speculate about its basis.},
}

@inproceedings{honig1993numerosity,
  title = {NUMEROSITY DISCRIMINATIONS BY PIGEONS OBTAINED WITH A TOUCH-SCREEN PROCEDURE},
  author = {Honig, Werner K.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {The "touch screen" provides a sensitive method for assessing the discrimination of complex arrays of elements. Pigeons were trained to peck at one side of a randomized array when there were more blue than red elements, and at the other side with the opposite proportions. This yielded orderly maintained discriminations of response location based on relative numerosity. Corresponding results were obtained when pigeons had to respond to the left side when uniform arrays were presented, and to the right side when other, mixed proportions were shown. This general method has the advantage that the different elements are equally associated with reinforcement during training.},
}

@inproceedings{christie1993chronometric,
  title = {CHRONOMETRIC ANALYSIS OF THE EFFECTS OF FAMILIARITY UPON VISUAL ORIENTING: DOES WHAT WE KNOW AFFECT WHAT WE NOTICE, AND IF SO HOW AND WHEN?},
  author = {Christie, John and Klein, Raymond},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {It is often assumed (c<f> Farah) that the system responsible for perception of the visual array is richly interconnected with both a spatial attention system and a system of stored representations. Contemplating this arrangement one of us (Christie) proposed that familiar items should exert a stronger pull on attention than novel ones, because the region in the visual array occupied by a familiar item will be more highly activated due to greater feedback from its stored representation. The relevant empirical literature, which appears to be full of contradictions, will be critically reviewed. The method we have developed to explore our proposal will be described, and the timecourse of visual orienting to familiar vs unfamiliar objects, as seen using our method, will be revealed.},
}

@inproceedings{forbes1993memory,
  title = {MEMORY PERFORMANCE, ERPS AND PHONOLOGICAL},
  author = {Forbes, Kelly A.K. and Connolly, John F.},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {ENCODING DURING SILENT READING The dual-route theory (e.g. Coltheart, 1978) proposes that the initial interpretation of written text is phonologically mediated. Phonological mediation is later superseded by orthography as reading becomes more proficient Research indicates that the interpretation of written text may continue to be influenced by the phonological representation of the words (e.g. Doctor & Coltheart, 1980). The present study investigates the effects of prior exposure on the later interpretation of written text containing homophones using explicit and implicit memory measures. Subjects were right-handed, English speaking undergraduates (N=40). Event related potentials (ERPs) were recorded to highly contextually constrained sentences completed with homophones. The manner in which the sentences were completed was manipulated in the study phase. Sentence endings were completed with homophones that were semantically and phonologically appropriate (S+P+), semantically incongruous but phonologically appropriate (S-p+) or semantically and phonologically incongruous (S-P-) to the sentence context During the test phase, subjects completed a recognition task or an oral spelling task requiring them to identify homophones previously seen or to spell homophones the first way they came to mind, respectively. ERP findings indicate that s+p+ and s-p+ are processed similarly and both are processed differently than s-p-. In contrast, behavioural measures indicate that comprehension is influenced by spelling frequency and the degree to which the infonnation agrees with the sentence context. Findings support phonological mediation in reading and are discussed in light of current theories.},
}

@inproceedings{corkum1993development,
  title = {DEVELOPMENT AL EMERGENCE OF JOINT VISUAL ATTENTION},
  author = {Corkum, Valerie and Moore, Chris},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {The present study examined joint visual attention in a conditioned head tum paradigm in 63 infants from 6 to 11 months of age. Results suggested three distinct patterns of response, which were developmentally ordered. Older infants tended to show spontaneous NA, without the need for conditioning. Infants at an intermediate age showed no spontaneous NA but did learn to match an adult's head tum given contingent feedback. Finally, a perseverative pattern was demonstrated by the youngest inf ants who tended to show either a majority of head turns in one direction or several series of turns in the same direction. These results suggest that the onset of joint attention, in line with general sensorimotor development, may be tied to infant's ability to respond flexibly to two separate spatial locations on the basis of different cues.},
}

@inproceedings{yoon1993development,
  title = {THE DEVELOPMENT OF CHILDREN'S UNDERSTANDING OF FALSE BELIEFS},
  author = {Yoon, Myong G. and Yoon, Myonghae},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {We studied the developmental sequence in the following aspects of children's understanding of false beliefs: Predictions of a protagonist's action, explanations of their own predictions, explicit attributions of the protagonist's thinking, explanations of their own attributions, and retroactive justifications for the protagonist's futile past action. The results show that a child's ability to make a correct prediction of a protagonist's action develops earlier than his/her abilities to explain the correct prediction, to impute the protagonist's mental states, and/or to justify the protagonist's futile past action: During 3y lm - 3y 6m, 52 % of younger 3-year-olds made correct predictions of the protagonist's action. Most (95 %) of them, however, were unable to make an explicit attribution of false belief to the protagonist. They also showed difficulties in justifying the protagonist's futile action retroactively, in spite of their preceding successful predictions of the protagonist's action. During 3y 7m - 4y Om, 38 % of older 3-year-olds acquired new abilities to explicitly attribute false belief to the protagonist, whereas their correct predictions (61 %) changed insignificantly. Longitudinal studies show that children's correct predictions of action developed 4 - 7 months earlier than their explicit attributions of false beliefs to protagonists. This developmental trend suggests that a normal child's understanding of false beliefs develops gradually from (a) the 'ego-centric (Level 0) conceptual perspective taking' stage (characterized by 'incorrect prediction of action and inability to attribute false belief) to (b) the transitory intermediate stage of 'Level 1 conceptual perspective taking' ('correct prediction of action without being able to attribute false belief), and then to (c) the stage of 'Level 2 conceptual perspective taking' ('attribution of false belief as well as correct prediction of action') during the formative period between 3 and 4 years of age.},
}

@inproceedings{moore1993development,
  title = {DEVELOPMENT AL RELATIONSHIPS BETWEEN PRODUCTION AND COMPREHENSION OF MENTAL TERMS},
  author = {Moore, Chris},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Production of mental terms, including belief and desire terms, was studied in a sample of 14 mother-child pairs longitudinally when the children were 2;0, 3;0, and 4;0. In addition, children at 4;0 were tested for comprehension of the distinctions between the belief terms 'know', 'think', and 'guess' using a task designed to assess the understanding of the expression of relative certainty. Children's comprehension of belief terms at 4;0 was significantly correlated with mothers' use of belief terms at 2;0, children's use of desire terms at 2;0 and children's use of belief terms at 3;0. These results reflect individual developmental differences in the development of belief-desire reasoning and are consistent with a picture of maternal linguistic influence on their children's developing theory of mind.},
}

@inproceedings{barresi1993view,
  title = {THE VIEW FROM ELSEWHERE: OR, EVERYTHING THAT YOU WANTED TO KNOW ABOUT YOUR SELF BUT WERE AFRAID TO ASK},
  author = {Barresi, John and Martin, Raymond},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {Instead of engaging in experimental research, philosophers like to explore theoretical questions by imagining various sorts of possible worlds interestingly different from our own. Such imaginative worlds can sometimes be used to answer questions inaccessible to empirical study. One such question that we hope to explore using this method in a future paper is: How would our self-knowledge change if we had access to perceiving ourselves from both a first and third person perspective? The way to approach this question is to imagine that a person could fission into two identical individuals, as do some other biological species on our planet, and that this is a typical happening in the adult lives of individuals on this imagined world What would self-knowledge amount to under circumstances when you had recently divided in two? In this talk our intuitions into this matter will be explored.},
}

@inproceedings{gidron1993psychosocial,
  title = {THE PSYCHOSOCIAL AND PHYSICAL PREDICTORS OF ADOLESCENTS' RECOVERY FROM ORAL SURGERY},
  author = {Gidron, Yori},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {This study expanded medical models of prediction and outcome related to surgery in adolescents. Fifty two adolescents undergoing 3rd molar surgery participated. Adolescents' negative affectivity, expectancies, coping styles and illness behavior encouragement were assessed before surgery. Extent of surgery was assessed by the oral surgeon. Outcome measures included resumption of initial mouth opening, disability and pain. After controlling for extent of surgery, the psychosocial parameters accounted for 16% of the variance in mouth opening and 24% of the variance in disability. Extent of surgery did not predict recovery. Expectancies had an independent and significant association with recovery. Gender effects masked associations between some predictors and recovery. Adding pain as a predictor more than doubled the variance explained in disability. Expectancies about recovery should be included in models of adolescents' recovery from surgery. Interventions which modify pessimistic expectancies and improve pain treatment may enhance recovery.},
  note = {QA: abstract-too-short},
}

@inproceedings{phillips1993few,
  title = {FEW COGNITIVE ABILITIES CHANGE FOLLOWING TEMPORAL LOBECTOMY},
  author = {Phillips, Natalie A. and McGlone, Jeannette},
  booktitle = {Nineteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1993},
  abstract = {The frequency of clinically significant change greater than one standard deviation on 14 cognitive neuropsychological tests was examined in 47 patients undergoing temporal lobectomy for medically intractable epilepsy. The majority of scores (68%) did not change more than one standard deviation, and 17% actually improved following surgery. Clinically significant decline in neuropsychological functioning was relatively infrequent (15%). Data were also grouped into material-specific domains (verbal versus non-verbal memory, and language versus visuospatial abilities) to determine how often decline was related to side of surgery in 35 right-handed patients (13 left-temporal; 22 right-temporal). Material- specific change occurred only after left temporal lobectomy where relatively more verbal memory scores declined (17%) than improved (8%) and more non-verbal memory scores improved (22%) than declined (3%). Taken together, these data indicate that most patients with longstanding temporal lobe seizures experience relatively little cognitive change following a temporal lobectomy.},
}

@inproceedings{schellinck1994selective,
  title = {SELECTIVE DEPLETION OF GUT BACTERIA ALTERS THE ODOURS OF INDIVIDUALITY IN RATS},
  author = {Schellinck, Heather and Brown, Richard},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Urinary odours of individuality in rats may be produced by the action of specific gut bacteria. To test this hypothesis, we used three types of discrimination tasks to assess the abilty of male rats to discriminate between the urine odours of outbred Long-Evans male rats before and after their gram negative or gram positive bacteria were depleted by drug treatment. Results were similar whether gram positive or gram negative bacteria were removed. When tested in an operant-olfactometer, rats previously trained to discriminate between the urine odours of two rats did not generalize to the urine odours of the same rats collected after their bacteria were removed, indicating that removal of the bacteria altered their individual odours. However, these same subjects made fewer errors in learning to discriminate between urine samples from rats after their bacteria were selectively removed than in learning to discriminate between samples from previously unknown rats indicating that they recognized some components of these odours (savings effect). In a habituation-dishabituation task, rats detected discriminable differences between the urine odours of the same rat before and after its bacteria were selectively depleted further indicating that bacterial depletion altered the rat's odour. The fact that the odours of two individual rats could still be discriminated after removal of bacteria indicates that, while their individual odours were altered by removal of bacteria, they were not eliminated.},
  note = {Poster},
}

@inproceedings{francis1994dysphoria,
  title = {DYSPHORIA AND UTILIZATION OF STEREOTYPES},
  author = {Francis, Judith},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The present study investigated the relationship between dysphoria and utilization of stereotypes. Dysphoric and non-dysphoric subjects were asked to view photographs of male and female target people and asked to guess the height of each target to the nearest half inch. In the no-instruction condition, subjects were simply asked to guess the height of each target. In the instruction condition, subjects were told that male and female targets were actually matched for height so that the stereotype that men are taller than women would not be a useful heuristic to aid them in making their judgements. Stereotype utilization was measured by subtracting the average height estimate of female targets from the average height estimate of male targets. It was hypothesized that dysphoric subjects would rely more heavily on the stereotype that men are taller than women to make their height estimates. However, it was found that dysphoric subjects were actually less likely to rely on the stereotype to make their judgements than non-dysphoric subjects. Results are consistent with research suggesting that dypshoric people are more effortful information processors than non-dysphoric people.},
  note = {Poster},
}

@inproceedings{macgregor1994gender,
  title = {GENDER DIFFERENCES IN THE RATING OF HOSTILITY},
  author = {MacGregor, Michael and Davidson, Karina},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The effect of coder gender on hostility ratings of structured interviews (Sis) was examined. Two male and two female actors were trained to exhibit high levels of both emotional and behavioural hostility during an SI. The actors were interviewed by either a male or female interviewer, resulting in four SI videotapes representing all possible interviewer/interviewee gender combinations. Trained male and female coders independently rated the resulting SI videotapes to ensure that there was an equal intensity of behavioural and emotional hostility displayed in each videotape. All four videotapes were then rated for hostility level in a counterbalanced order by 105 male and 116 female undergraduates. There was no main effect for gender of the undergraduate coder or gender of the interviewer in either emotional or behavioural hostility ratings. However, there was a main effect for gender of the interviewee. Female interviewees were rated as being more behaviourally hostile (E (1,242) = 6.31, 12< .01) and less emotionally hostile (E (1,242) =8.42, 12.< .01) than male interviewees. Results are discussed in terms of the possible impact gender may have for future research using SI scored hostility.},
  note = {Poster},
}

@inproceedings{dsweet1994pain,
  title = {PAIN INDUCED CENTRAL PLASTICITY: A REVIEW},
  author = {D.Sweet, Susan and Rioux, George R. and McGrath, Patrick J.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {This study reviews the literature examining changes pain causes in the central nervous system, which we may call pain induced plasticity. Such studies show that pain may sensitize the body to further pain, or, conversely, that it may inhibit the sensation of further pain. Studies examining pain induced plasticity through self- reports of pain sensitivity or pain threshold by means of the cutaneous flexor reflex were considered for inclusion. Studies were rated by two independent observers on criteria examining their methodology and the type of pain produced. Nineteen studies met the initial criteria and were further examined to determine consistencies which would be useful to create a model of the differential effects pain may have on the central nervous system. Future directions of this work are discussed in terms of its implications for pain assessment and management, especially for children too young to report their level of pain.},
  note = {Poster},
}

@inproceedings{dywan1994unawareness,
  title = {UNAWARENESS OF HEMIPLEGIA MAY BE LINKED TO POOR RECOGNITION MEMORY FOLLOWING INTRACAROTID SODIUM AMOBARBIT AL INJECTIONS CONTRALATERAL TO THE TEMPORAL LOBE SEIZURE FOCUS},
  author = {Dywan, C. A. and McGlone, J. and Fox, A.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Unawareness of hemispheric deficits experienced following intracarotid barbiturate injections (i.e., Wada testing) has been assessed upon the recovery of function as a model of anosognosia. Unawareness of drug-induced hemiplegia was examined upon clearing of the deficit in 83 patients who were counterbalanced for side of temporal-lobe seizure focus and who underwent left and right sodium amobarbital injections. Unawareness was common (66%) and occurred with equal frequency following left- and right- injections. These findings were not moderated by sex, handedness or speech dominance. Unawareness was demonstrated more frequently after injections contra- than ipsi-lateral to the major seizure focus. Objective memory performance and unawareness were related after contra- but not after ipsi-lateral injections. Thus when assessed following the recovery of function, unawareness of hemiplegia was found to be related to the functional status of the temporal lobe independently of hemispheric laterality. Department of Psychology (If you keep programs for posterity attach this sheet to the full program before storage!) Program Changes: T8 (D. E. Mitchell, G. Bateman, C.J. Beaver & P. Ritchie) is a poster (Thursday) Tl 1 (F. Dastur) is a poster (Thursday) P4 (McMullen & Trappenberg) is a talk, replacing T8 in the program P6 (L.A. Chambers & K. Kavidson) and P12 (S. D. Sweet, G. Rioux & P. J. McGrath) have switched days, so P6 is on Friday and Pl 2 is on Thursday Program Additions: One abstract (P7 A. Trillo, C. Daniels & R. Klein) was submitted too late to be in the original program, and one presentation (T. Smith-Crosby) which was inadvertently left off the program has been added as Pl 4. The abstracts for these presentation appear overleaf.},
  note = {Poster},
}

@inproceedings{smithcrosby1994possible,
  title = {POSSIBLE CONSTRAINTS ON THE CUES INVOLVED IN JOINT VISUAL ATTENTION},
  author = {Smith-Crosby, Tracy},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Joint visual attention (NA) which can be defined as simply looking where someone else is looking, has been found to develop in infants in response to the head tum of an experimenter around 10 to 12 months of age. Recent work, however, has shown that infants of only 8 months of age are able to be conditioned to make a NA-like head tum response if rewarded by an interesting sight located in the experiment's direction of gaze. These findings suggest learning as a possible mechanism through which JV A may develop. However, subsequent research indicates that infants are unable to be conditioned to make a NA-like head tum response in a direction opposite to the experimenter's head tum cue. Although this finding cannot rule out learning as a mechanism for the development of NA it certainly does suggest that the cues which elicit JV A in infants may be constrained. The proposed research intends to determine if the cues involved in NA may be constrained to those containing movement and if NA is able to be conditioned to as non- social stimuli. Possible implications for mechanisms of NA are discussed.},
  note = {Poster},
}

@inproceedings{ingles1994dissociation,
  title = {DISSOCIATION OF VISUAL AND AUDITORY COMPREHENSION IN A CASE OF FLUENT APHASIA},
  author = {Ingles, Janet L. and Mate-Kole, C. Charles and Connolly, John F.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {A 24-year old woman developed fluent aphasia and anomia following bi temporal brain damage due to herpes simplex encephalitis. Her language disturbance showed exceptional features: reading was neologistic and yet reading comprehension was superior to auditory comprehension. Event-related brain potential responses (N400) recorded in response to semantically-incongruous sentence endings in the visual but not auditory modality further support this dissociation. These findings suggest that despite a breakdown of phonological output some preservation of visual and semantic routes for reading may occur. These features are discussed with reference to other acquired language disorders.},
  note = {Poster},
}

@inproceedings{morehouse1994attention,
  title = {ATTENTION: HOW DOES IT MOVE US? A KINEMATIC ANALYSIS OF THE EFFECTS OF ATTENTION ON MANUAL AIMING MOVEMENTS},
  author = {Morehouse, Susan and Fisk, John},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {How does the way we attend to objects influence aspects of our movement to these objects? The effect of attention on the kinematic parameters of motor function has largely been ignored. Since attention and motor function are intertwined in everyday life, it makes sense from an ecological perspective to empirically investigate their interaction. The proposed experiments have been designed to investigate the effects of visually directed attention on the kinematic parameters of manual aiming movements. The paradigm incorporates basic aspects of Posner's (1980) cost/benefit cuing paradigm with those of Rosenbaum's (1980) precuing paradigm for motor function. Possible outcomes of these experiments will be discussed as will potential contributions of this research to the areas of attention and motor function.},
  note = {Poster},
}

@inproceedings{mcmullen1994i,
  title = {i},
  author = {McMullen, P.A.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {REPRESENTING FACES IN A NEURAL NETWORK A simple perceptron neural network was implemented to represent three distinct faces based on Tanaka's (1991) caricature recognition model. Modifications to his original model were compared including passing the output through a linear transfer function, adding a hidden layer with back propagation, back propagation with momentum and back propagation, with momentum and an entropic error surface and a winner-takes-all network. As was found with the original model, all modified models correctly "recognized" each face input vector and produced higher output activation levels to caricatures than veridical faces. However, only the original model produced equal activation levels in all three output nodes to an average prototypical face. Output nodes of all modified models failed to show any activation to prototypical input. These findings suggest that the system which represents a generic or superordinate face may be independent of the system which represents specific face exemplars.},
  note = {Poster},
}

@inproceedings{rioux1994application,
  title = {THE APPLICATION OF EVENT-RELATED BRAIN POTENTIAL MEASURES TO NEUROPSYCHOLOGICAL ASSESSMENT},
  author = {Rioux, G.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {In general, this research is aimed at the development of electro-physiologically- based assessment tools for use with patients who are unable to be tested in the conventional manner on standard neuropsychological tests (e.g., expressive aphasics, coma patients). The present study represents an intial validation of an event-related brain potential (ERP) adaptation of the vocabulary sub-tests of the Wechsler Intelligence Scale for Children, and the Wechsler Adult Intelligence Scale. Preliminary findings with normal subjects are presented, and suggest that a late positive component (i.e., P300) in the ERP waveform may be an accurate index of individual test performance, independent of overt behavioural response.},
  note = {Poster},
}

@inproceedings{chambers1994reducing,
  title = {REDUCING PSYCHOLOGICALRISK FACTORS: A HEALTH PROFESSIONAL INTERVENTION},
  author = {Chambers, Laura A. and Davidson, Karina},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The Nova Scotia Heart Health Project was undertaken in the summer of 1989 to enable Nova Scotians to take action to improve cardiovascular health by controlling or reducing their risks for disease. As part of this multifaceted community wide effort, materials aimed at increasing the effectiveness of a psychological intervention will be provided to health professionals. Included in such materials will be a treatment manual providing practical information on how to identify and manage psychological risk factors for CHD such as hostility and social support. For example, information will be provided on how to quickly assess social network and then give practical advice on social network enhancement. Once psychological risk factors have been managed, adherence to interventions for other established risk factors such as obesity and smoking is expected to increase. This practical guide for health professionals will be presented. It will then be used, in addition to other materials, in Nova Scotia to assess the efficacy of reducing community level risk factors.},
  note = {Poster},
}

@inproceedings{trillo1994phantom,
  title = {THE PHANTOM CHEST: A STUDY IN RADIOLOGY},
  author = {Trillo, Alex and Daniels, Cupido and Klein, Raymond M.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Previous research has shown there to be a roughly thirty percent error rate across all specialties in radiology. Research related to reducing this error rate has looked at everything from screening radiology applicants based on their cognitive or perceptual skills to employing the help of computer classifier programs. In our experiment we endeavored to see if there might be a correlation between a radiologist's visual search skills and their performance on a series of chest x-rays. We developed a set of visual search tasks and used fifty chest films, half of which contained abnormalities and half of which were phantoms, in order to assess whether there was a relationship between these two tasks. We found that there was an approximate 30 percent error rate on the films across level of experience and radiological specialty. Additionally, there were some correlations between the film scores the visual scores, but these are not easily interpretable.},
  note = {Poster},
}

@inproceedings{dastur1994effects,
  title = {THE EFFECTS OF HYPOTHYROIDISM ON THE ULTRASONIC VOCALIZATIONS OF INF ANT LONG-EV ANS RATS (RA TTUS NORVEGICUS)},
  author = {Dastur, Farhad N. and Brown, Richard E.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Eighty Long-Evans rat pups were made hypothyroid by administration of methimazole (MMI) in the drinking water of their dams (el 7 - pndlO). Dams were randomly assigned to one of four conditions: (1) control (no drug in water); (2) 0.05 mg/ml (MMI dissolved in water); (3) 0.1 mg/ml, or (4) 0.2 mg/ml. The dependent measure was the number of ultrasonic vocalizations (UV s) emitted during an 8-minute test on postnatal days 8, 10, 12, 14, and 21. Hypothyroidism had a significant effect on UVs, F(3,76) = 33.40, p < .001, and was significant at all ages tested (p < .001). The hypothyroid pups vocalized more than the control pups at all ages except day 8, suggesting a developmental shift towards later ages in the pattern of UV production. There was no effect of sex; however, the age effect was significant, F(4,304) = 1159.59, p < .001. A significant age x drug interaction was also found, F(12,304) = 15.61, p < .001. Since the internal body temperature of hypothyroid pups was lower than that of controls, F(3, 72) = 81.90, p < .001, it was concluded that the hypothyroid pups experienced greater thermal stress than controls and this accounted for their increased number of UV s.},
  note = {Poster},
}

@inproceedings{fidler1994stress,
  title = {STRESS AND ALCOHOL PREFERENCE},
  author = {Fidler, Tara L. and LoLordo, Vincent M.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Volpicelli, Ulm, and Hopson (1990) found that rats given a choice between 5% ethanol and water in the home cage showed enhanced ethanol preference following four daily 1-hr sessions of inescapable shock in another environment, relative to a no-treatment control. We attempted to replicate this effect including a shocked group, a no-treatment control, and a group taken to the distinctive environment each day but not shocked. Our baseline ethanol preferences were much higher than theirs, 0.55 versus 0.35. Additionally, whereas their ethanol preferences increased from baseline to shock to post-shock phases, our ethanol preferences decreased over phases, especially in the no-treatment group. In the second replication, the pattern of results was the same, although baseline preferences were like those of Volpicelli et al. Thus we did not replicate the stress effect on alcohol consumption observed by Volpicelli et al. Additional research aimed at resolving this discrepancy is in progress.},
  note = {Poster; QA: abstract-too-short},
}

@inproceedings{hoffman1994lab,
  title = {LAB, LIBRARY, LAN, AND (L')INTERNET},
  author = {Hoffman, Ron},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {This past year has seen the arrival of some exciting new technologies for information access. At Dalhousie, the University Library has been purchasing multi-user network versions of several computer-readable databases, including those most widely used by students in Psychology. It is now possible for our students to access CD-ROM databases located in the Killam Library from any terminal in the Psychology Computer Laboratory. At the same time (and from the same computer), students can check Novanet for availability of journals at the libraries, and even order a fax copy of an article over the Internet. For the benefit of those who have not yet utilized these new tools, we will quickly demonstrate use of PsycLIT, Med.Line and Science Citation Index, and then introduce some new tools for finding information on the Internet. .  ', ~- 'i ,},
}

@inproceedings{ourednik1994embryonic,
  title = {EMBRYONIC NEURAL GRAFTS INDUCE REPAIR BY THE JUVENILE NEOCORTEX IN MICE - AN IMMUNOHISTOCHEMICALAND AUTORADIOGRAPHIC STUDY},
  author = {Ourednik, Jitka},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The postnatal central nervous system (CNS) of mammals has a diminished restorative capacity. Recent research proposes that embryonic neural grafts transferred into a damaged region of the CNS may lead to a certain degree of anatomical and functional recovery. Until now, it was generally believed that it is the graft which is the source of the reconstituted tissue. Our observations (J.Ourednik et al. 1993, W. Ourednik et al. 1994) indicate that in the CNS the regenerative capacity is not lost irreversibly and that embryonic grafts from the presumptive murine cerebral cortex may induce restorative processes and cell proliferation within the severely injured cerebral cortex of young mice. Our investigation is based on immunohistochemical distinction of donor and host tissues of two congenic mouse strains which express two different allelic forms of the Thy-1 antigen, and on detection of newly formed cells by their incorporation of 3H-thymidine administered to the recipients shonly after transplantation. Neurons are revealed by antibodies against neuron-specific marker proteins (MAP2, PY or NF-h). Radioactively labelled cells are detected in the immunohistochemically stained sections by autoradiography. We demonstrate that in animals that had received a tiny graft, a serious mechanical insult of the neocortex was repaired mainly by proliferation of host cells of both neuronal and non-neuronal origin. During the 2-month survival period, the graft was either completely resorbed, or participated in a minor way in the reconstruction. Ourednik, J., Ourednik, W., Van der Loos, H., Do fetal neural grafts induce repair by the injured juvenile neocortex? NeuroReport 5: 133-136 (1993) Ourednik, W., Ourednik, J., the late Van der Loos, H., Newly formed host cells in grafted juvenile neocortex expressing neuron-specific marker proteins. NeuReport 5: (1994, in press)},
}

