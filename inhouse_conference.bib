@inproceedings{phillips1991physics,
  title = {Physics and brain design, or what rats tell us about where god went},
  author = {Phillips, Dennis P. and Kelly, Jack B.},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {wrong By comparison with cats and monkeys, rats and other small mammals are very poor at localizing sounds in space. The most recent accounts of this disparity are couched in terms of the ethological demands on the species, or in terms of the correlation between localization acuity and the horizontal width of the species' visual streaks or areae centrali (since this width determines the auditory localization acuity required to bring the target into the part of the visual field with greatest acuity). These accounts in no way explain why small rodents are so poor at localizing sounds: they simply point to correlates of that performance. Jack and I measured the ability of rat cortical auditory neurons to encode interaural time differences, which are a major cue for sound location. We found that the dynamic range of this code was the same as that seen in cats and primates; this despite the fact that rats have much smaller heads, and therefore will only ever encounter very small interaural time disparities. We suggest, then, that for rats, there exists a mismatch between the behaviorally-relevantrange of interaural time differences and the range of time differences that the animal's brain encodes. This may be one reason why small mammals},
}

