@inproceedings{mazerolle2006determining,
  title = {Determining neuro-cognitive connectivity: An event-related fMRI study at 4T. OR Beyond phrenology: Functional connectivity of the human brain},
  author = {Mazerolle, Erin L. and D'Arcy, Ryan C.N.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {There is a growing trend in neuroscience to study the nature of the connections between brain regions, as these connections are vitally important to understanding brain function. The well-studied visual and motor systems provide an excellent foundation for investigations of functional connectivity. Interhemispheric connections between the visual and motor systems have been previously studied using unimanual reaction times (RTs) to lateralized light flashes. When the light is flashed in the hemifield contralateral to the responding hand, the visual information must cross to the hemisphere that controls the hand. While behavioural studies have yielded differences between crossed and uncrossed RTs, it is likely that light flashes can be processed by relatively low-level systems. We propose to use lateralized cognitive processes (face and word processing) to elicit interhemispheric transfer between distributed cortical systems. Furthermore, we plan to vary the extent of the network recruited by the task by manipulating the number of interhemispheric transfers. This model will allow for testing of basic hypotheses about 'neuro-cognitive' connectivity using non-invasive functional imaging.},
}

@inproceedings{gawryluk2006emotional,
  title = {Is emotional intelligence affected by right more than left temporal lobe resections?},
  author = {Gawryluk, Jodie and McGlone, Jeannette and Sadler, Mark and D'Arcy, Ryan},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The right amygdala may have a distinct role in emotional intelligence. This research will examine emotional intelligence after left and right temporal lobe resections that include the amygdala. There are several approaches to evaluate emotional intelligence. Critically, this study will use Bar-On's Emotional Quotient inventory. It is hypothesized that individuals with right temporal lobe resections will score lower on the EQ-i, than those with left temporal lobe resections. Conversely, individuals who have had left temporal lobe resections are expected to have lower verbal memory and naming scores than those with right-sided resections. These groups are not expected to differ on descriptive information or neuropsychological measures such as intelligence, speed of reading, or visuospatial skills.},
}

@inproceedings{carmichael2006ear,
  title = {Ear asymmetries in auditory temporal gap detection},
  author = {Carmichael, Martha E. and Phillips, Dennis P.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {There is a long history of interest in the functional specializations of the two cerebral hemispheres in man. In particular, there is interest in the reasons why language processing is often lateralized to the left hemisphere. One hypothesis is that the left hemisphere, and perhaps especially the auditory part of it, is in some way a "faster temporal processor" than is the right. The intended connotations of that expression are not always clear, but they typically include auditory temporal acuity, i.e., the temporal "grain" with which the stream of sound is perceptually resolved. In this regard, high temporal acuity is advantageous for resolving the sounds of speech. The present study employs temporal gap detection paradigms, with and without two kinds of contralateral masking, to measure temporal acuity through the left and right ears in normal adult listeners. Differences in acuity through the two ears may be informative about the temporal resolution supported by the two cerebral hemispheres.},
}

@inproceedings{butler2006orienting,
  title = {Orienting attention in visuospatial neglect: How limb movements affect the disengage deficit Or "Limbs…Cueing…Attention" (read as "Lights…Camera…Action")},
  author = {Butler, Beverly},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Visuo-spatial neglect from right hemisphere damage is associated a difficulty disengaging attention from the right side to move it to the left side (disengage deficit). Neglect has been shown to be reduced with both active and passive left limb movements, but the mechanisms of this positive effect is unknown. In the current study a cuing paradigm was used to assess the effect of active (AM) and passive (PM) left and right limb movements, compared to a no movement condition (NM), on the disengage function in right hemisphere stroke patients with and without neglect and in older healthy controls. Results showed that the disengage deficit was related in size to neglect severity in stroke participants and orienting was affected by limb movements in the older control group and in two neglect subjects with a severe disengage deficit. These data suggest that left limb movements can directly affect the orienting of attention, although the direction and consistency of the effect remains yet to be resolved.},
}

@inproceedings{lawrence2006patterns,
  title = {Patterns of attention in visual search after stroke},
  author = {Lawrence, Mike and Butler, Beverly and Eskes, Gail},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Visual search performance was measured in healthy subjects and right hemisphere stroke survivors, including patients with and without neglect. These groups were compared on traditional measures of global and spatial attention, as well as new measures that quantified how attention moved through space during the search task. It was discovered that neglectful stroke survivors fared worse than their non-neglectful and healthy counterparts not only in where they allotted their attention, but how they moved it as well. These results reveal a novel pattern of performance that may shed light on the mechanism of the neglect dysfunction.},
}

@inproceedings{macpherson2006individual,
  title = {Individual Differences in the Development of Face Recognition},
  author = {MacPherson, Amy C. and McMullen, Patricia A. and Dunham, Phillip J.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Children at seven (n = 32) and eleven (n = 30) years of age participated in a project examining individual differences in face recognition and the processing strategies children use to recognize faces. Children took part in two tasks including choosing the familiar face from a series of upright or inverted photographs of human faces and determining which of two abstract images (i.e., Mooney face stimuli and scrambled counterparts) contained a face. The goal of this project was to provide further evidence of a switch during childhood from feature-based to configural processing in the recognition of upright faces. Results are combined with those from adults (n = 62) tested under similar conditions to tell a complete developmental story.},
}

@inproceedings{prusky2007role,
  title = {The Role of Superordinate Labels on Categorical Flexibility in 3- and 4-year-olds},
  author = {Prusky, Carly and Jacques, Sophie},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The purpose of the current study was to investigate the effect of superordinate labels on categorical flexibility in 3- and 4-year-olds using two match-to-sample tasks that assess categorization and cognitive flexibility. It was expected that both 3- and 4-year-olds would perform better on the categorization task than on the cognitive flexibility task. In addition, 4-year-olds were expected to improve in a label condition on both the categorization task and the cognitive flexibility task, but 3-year-olds were not. As predicted, 4-year-olds performed better than 3-year-olds on both versions of both tasks and performance was better on the categorization task than on the cognitive flexibility task for both age groups. Surprisingly, however, 4-year-olds did not benefit from labels on either task but 3-year-olds did. Results are discussed in terms of the role that different labels might have on categorical flexibility.},
  note = {Poster},
}

@inproceedings{laur2007improvements,
  title = {Improvements in Quality of Life in Patients with Obstructive Sleep Apnea using Continuous Positive Airway Pressure (CPAP) Treatment is Related to Decreased Sleepiness and Improved Mood.},
  author = {Laur, E.L. and Lau, E.Y.Y. and Eskes, G.A. and Morrison, D. and Rajda, M.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Obstructive Sleep Apnea (OSA) is a disorder characterized by brief breathing disruptions during sleep. Symptoms include excessive daytime sleepiness, depression, and decreased memory, attention and quality of life (QoL). Continuous Positive Airway Pressure (CPAP) is the standard treatment for OSA. CPAP keeps the airway open to eliminate disrupted breathing and is effective in restoring sleep and improving daytime symptoms. The current study aimed to investigate the role of sleepiness and mood on QoL in patients with OSA. We hypothesized that both mood and residual sleepiness are associated with QoL after using CPAP. Thirty patients with moderate to severe OSA were asked to complete questionnaires to measure sleepiness, mood, and QoL. CPAP was found to significantly improve QoL (t(24)=-8.977, p=0.00) and decrease sleepiness (t(28)=6.323, p=0.00). QoL was negatively correlated with sleepiness r(29)=-0.605, p=0.00) and depressed mood r(29)=-0.629, p=0.00). Our findings suggest that the effects of CPAP treatment on sleepiness and depression are associated with improvement in QoL.},
  note = {Poster},
}

@inproceedings{mullane2007sleep,
  title = {Sleep Problems and Performance on a New Test of Attention in Children with and without ADHD},
  author = {Mullane, Jennifer C. and MA and Bower, Jenna L. and BSc and Corkum, Penny V.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Few studies have examined the relationship between sleep disturbances and attention in children and even fewer have investigated this association in children with ADHD. This pilot study examined differences in sleep problems between children with and without ADHD and explored the effects of sleep disturbances on three networks of attention as measured by the Attention Network Test (ANT). Participants were 24 children with ADHD-Combined Type (Mage = 110.58 mths), 17 children with ADHD-Inattentive Type (Mage = 116.12 mths), and 45 typically developing children (Mage = 115.32 mths). Children with both subtypes of ADHD had significantly more sleep problems than controls, as measured by the Children‚s Sleep Habits Questionnaire. Partial correlation analyses found that sleep disturbances were related to less efficient performance on the ANT‚s measure of executive attention, but only in the ADHD-Combined Type group.},
  note = {Poster},
}

@inproceedings{brown2007children,
  title = {Children's Attributions for Ambiguous Intentions: Hostile or Outcome Driven?},
  author = {Brown, Ashley and Jacques, Sophie},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The current study examined three possible reasons for why aggressive children make hostile attributions of intent in ambiguous situations: social learning deficits, theory of mind deficits, or innate predispositions. Thirty-five typically developing children between the ages of 44 and 87 months were assessed on their tendency to make hostile attributions using an extended version of the hostile attribution bias interview. This extended interview included vignettes with both positive and negative outcomes as well as hostile, ambiguous, and benign intentions. Results indicated a main effect of intent and a trend toward a significant age group effect, but no effect of story outcome and no significant interactions. Results are discussed in terms of existing theories and limitations of the current study.},
  note = {Poster},
}

@inproceedings{duncan2007how,
  title = {How Does the Reader Read -er: Using the Missing Letter Task to Investigate Lexical Access of Morphologically Complex Words},
  author = {Duncan, Hilary D. and Deacon, S. H. and Saint-Aubin, Jean},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Dual-route models of complex word processing posit two access routes to the lexicon: a direct-access route, wherein the word's full-form representation is accessed via the whole word; and a decompositional route, wherein the component morphemes are accessed separately. Evidence for a dual-route model comes from lexical decision tasks and eye-movement monitoring during fluent reading. These studies have shown that the time needed to identify morphologically complex words is influenced by whole-word and component frequencies. The aim of the current study is to investigate the ability of the Missing Letter Effect task to replicate these results. Sixty-three university students were asked to search for the target letter -r while reading a prose passage containing high and low frequency one-morpheme and derived words. More omissions were made on one-morpheme than derived words when they were low-frequency, but there was no difference when they were high-frequency. Results support recent eye-movement studies that posit a dual-route model of lexical access.},
  note = {Poster},
}

@inproceedings{green2007does,
  title = {Does the risk of memory loss influence decision making by physicians and patients who contemplate temporal lobe resection for control of seizures?},
  author = {Green, Jaime Williams Jordan and Authority, Jeannette McGlone Capitol District Health},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Temporal lobe resection (TLR) is a successful, although underutilized treatment for complex partial seizures. One reason for this underutilized may be the perceived risk of severe and permanent memory loss. However, patients' and physicians' perceptions of the risk of memory loss following TLR have not been empirically investigated. In this presentation, we propose a series of studies using a triangulation of methodologies examining whether fear of memory loss contributes to decision-making about elective brain surgery. First, we propose conducting focus groups with non-surgical, pre and post TLR patients to uncover their thoughts and attitudes towards TLR surgery and the risk of memory loss. Second, we will survey epilepsy specialists querying their thoughts regarding memory loss including how they communicate the risk to patients and what role the risk has in recommending and proceeding with TLR. Finally, we will explore information available on the Internet regarding TLR and the risk of memory loss, including the accuracy and consistency of the information. Implications of the research will be discussed including the importance of effective epilepsy-related knowledge transfer and critical comments will be invited.},
  note = {Poster},
}

@inproceedings{hoffman2007selective,
  title = {Selective cholinergic basal forebrain lesions using anti-murine-p75-saporin (mu p75-saporin): a mouse model of Alzheimer's disease?},
  author = {Hoffman, Nicola and Semba, Kazue and Stamp, Jennifer and Brown, Richard},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Degeneration of cholinergic neurons in the basal forebrain (BF) is a prominent characteristic of Alzheimer's disease (AD). One current animal model developed to mimic BF cholinergic neuron atrophy observed in human AD is via injecting neurotoxins into the mouse brain. Our long-term research aims are to selectively lesion mouse BF cholinergic neurons and then examine the cognitive and other functional deficits associated with this cell loss. Mu p75-saporin is an immunotoxin that has been shown to selectively destroy cholinergic neurons in the medial septum (MS), but demonstrates concurrent cell loss in cerebellar Purkinje cells. In the present study we examined the efficacy of the recently developed, presumably improved mu p75-saporin in selectively lesioning BF cholinergic neurons in the mouse brain. One of three doses (1.0, 1.5, or 2.0 μg/μl) of the immunotoxin or vehicle was infused bilaterally into the lateral ventricles of male C57BL/6J mice. Two weeks following injections, mice were intra-cardially perfused, the brains removed and sectioned for immunohisto-chemistry to visualize cholinergic and a subtype of GABAergic BF neurons, as well as acetylcholinesterase (AChE) histochemistry. Quantitative analysis revealed a reduction of cholinergic neurons in the MS/VDB following intracerebroventricular injections of mu p75-saporin, but only a trend for a decrease of cholinergic neurons in the nBM. The density of AChE-postive fibers in the hippocampus and somatosensory cortex was not significantly altered following neurotoxin injection, although there was a trend for a decrease in the hippocampus. No loss of noncholinergic neurons in the MS or nBM was apparent, nor was there a loss of noncholinergic cerebellar Purkinje cells. The results indicate that the most recently developed mu p75-saporin has an increased selectivity to cholinergic MS neurons, compared with the previous formula, and may be useful as a selective cholinergic immunotoxin for mice. Mu 75-saporin may be a useful tool to create an animal model of AD and expand research concerning the progression and neuropathology of the disease.},
  note = {Poster},
}

@inproceedings{bolivar2007don,
  title = {"Don't Look at a White Bear!" Action Suppression in Adults},
  author = {Bolivar, Teri and Jacques, Sophie},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The purpose of this study was to develop an objective measure of action suppression. In this task, participants were required to inhibit looking at the content of a picture cue, while still using its location to inform them about the location of target words to which they had to respond. Although reaction time data showed few effects, accuracy data showed that participants were unable to ignore the content of cues at SOA of 300 ms. Results are discussed in relation to prior thought suppression research and findings in the attention literature (Wegner et al., 1987; Wegner & Zanakos, 1994; Jonides, 1981; Danziger & Kingstone, 2005).},
  note = {Poster},
}

@inproceedings{eyy2007effects,
  title = {Effects of Continuous Positive Airway Pressure (CPAP) Treatment of Obstructive Sleep Apnea on Daily Functions, Mood and Quality of},
  author = {E.Y.Y, Lau and G.A, Eskes and D.L, Morrison and Rajda and M and K.F, Spurr},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Introduction: Obstructive sleep apnea (OSA) is characterized by disrupted breathing during sleep, leading to hypoxemia and fragmented sleep at night, daytime sleepiness, and changes in cognition and mood. Here, we report preliminary analyses of an ongoing study of the effects of CPAP treatment on sleepiness, sleep quality, daily functions, mood, and quality of life (QoL). Methods: Thirty CPAP-treated patients with moderate to severe OSA were studied with an overnight polysomnographic sleep study, measures of sleepiness and sleep quality, mood, functional outcomes, cognition, and QoL. Pre-treatment respiratory disturbance index (RDI), mean oxygen saturation (SpO2), sleep quality, and sleepiness, and retrospective ratings on functional outcomes and QoL were also available. Results: CPAP improved breathing disruptions, sleep quality, daytime sleepiness, functional outocmes, and QoL. Post-treatment mood, functional outcomes, and quality of life are predicted by sleepiness and sleep quality. Conclusion: CPAP is an effective treatment for OSA in ameliorating breathing disruption and oxygen desaturation during sleep. However, there are residual dfficulties in daytime outcomes associated with sleepiness and sleep quality.},
}

@inproceedings{deurveilher2007sleep,
  title = {Sleep is the Best Remedy for Sleep Loss, But How are our Hormones Affecting our Ability to Recover Sleep? --A Case for Females},
  author = {Deurveilher, Samüel and Wilkinson, Michael},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {We investigated the effects of ovariectomy with or without estrogen and/or progesterone replacement on spontaneous sleep and recovery sleep after 6 h of sleep deprivation in female rats. Male rats were also included for comparison. Females were ovariectomized and implanted subcutaneously with capsules containing oil, estrogen, progesterone or both hormones. Males received oil-filled capsules. All were implanted with EEG and EMG electrodes. During the baseline recording, ovariectomized rats without hormone replacement tended to spend more time in both non-rapid eye movement (NREM) and REM sleep than those with estrogen and/or progesterone replacement and males. Following 6-hour sleep deprivation, ovariectomized rats without hormone replacement were much slower in recovering REM sleep (but not NREM sleep) than the other groups, whereas ovariectomized rats with the highest dose of estrogen showed the lowest NREM EEG delta power (a measure of sleep intensity). These results indicate that ovarian hormones can significantly affect REM sleep and NREM delta power recovery in female rats.},
}

@inproceedings{dreumontboudreau2007role,
  title = {The Role of Caffeine Exposure and Dependence in a Conditioned Flavor Avoidance Paradigm},
  author = {Dreumont-Boudreau, Sarah E. and LoLordo, Vincent M.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Two experiments assessed the value of a flavor that signaled 24 hrs of caffeine exposure (Signal CS) in male Sprague-Dawley rats. In Experiment 1, naïve rats were given a Kool-Aid flavor followed by 24 hr access to caffeine. Several days later, they were given a different flavor followed by water (Neutral CS). When given a choice between the two flavors, rats avoided the Signal CS and consumed more of the Neutral CS. Avoidance of the Signal CS was maintained even after the rats were made dependent on caffeine. In Experiment 2, Group 1 was maintained on 21 days chronic caffeine, while Group 2 was maintained on water. Both groups were then given a Signal CS followed by 24 hrs of caffeine, and several days later, a Neutral CS followed by water. Group 2 avoided the Signal CS, and consumed more of the Neutral CS. However, Group 1 consumed equivalent amounts of both the Signal and Neutral CSs.},
}

@inproceedings{dingle2007caffeine,
  title = {Caffeine dependence in rats: Effects of dose and exposure on conditioned flavour avoidance.},
  author = {Dingle, Rachel and LoLordo, Vincent M.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {In order to examine the parameters of oral caffeine dependence, groups of rats were chronically exposed to caffeine-tainted water (1.0 g/L) for 5, 10, 15 and 20 days. Upon removal of the caffeine, rats were exposed to one of two novel Kool-Aid flavours (CS Withdrawal). Twelve days later, rats were exposed to the second Kool-Aid flavour (CS Neutral). A 24-hour 2-bottle test showed that rats that had been exposed to caffeine for 20 days, but not 5, 10 or 15 days, strongly preferred the CS Neutral. In a second experiment, groups of rats were given caffeine-tainted water for 21 days at one of four concentrations (1.0 g/L, 0.5 g/L, 0.25 g/L, and 0.125 g/L), after which withdrawal and neutral CSs were established. Only rats that drank the 1.0 g/L caffeine solution strongly preferred the CS Neutral. This suggests that long exposure to a strong caffeine solution is required in order to induce dependence in rats such that a CS associated with the withdrawal of caffeine becomes avoided.},
}

@inproceedings{bisong2007effect,
  title = {The Effect of Consumption of Kola Nut (Cola Nitida) Diet on Locomotor Behaviour and Anxiety in Mice},
  author = {Bisong, Sunday A. and Oyibo, Gideon},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Kola nuts are eaten in Nigeria (mostly in the Northern part) during ceremonies and as stimulants. The long term effect on behaviour is yet known. Following chronic consumption (4 weeks feeding) of kola nut (cola nitida) diet (50%w/w), patterns of locomotor behaviour and anxiety were studied in 16 male Swiss white mice (18-32g body weight), using the open field, elevated plus maze and the light/dark transition box. Mice in the control group (n = 8) were fed normal rodent chow while those in the kola group (n = 8) were fed kola diet (50% kola, 50% rodent chow) for 4 weeks. All animals were allowed free access to clean drinking water. The frequency of line crossing in the open did not differ between the kola and control groups. The frequency of rearing against the wall did not differ, but the frequency of rearing in the open field was lower in the kola group (p< 0.05). Grooming and genital licking were also lower in the kola group compared to control (p< 0.001, 0.05 respectively). In the elevated plus maze the duration in the open arm in the kola group was higher than the control group (p< 0.01). The frequency and duration of head dips did not differ. The frequency and duration in the closed arm were lower in the kola group compared to control (p< 0.05). The duration of grooming, genital licking in the kola group was higher in the closed arm compared with control (p< 0.01). The kola fed animals spent more time in the light region of the light/dark transition box (p< 0.01), showed more rearing (p< 0.05), and spent less time in the dark region when compared with controls. These results indicate that consumption of kola nut diet decreases anxiety-related behaviour in mice in the elevated plus maze and the light/dark transition box but does not affect locomotor activity in the open field.},
}

@inproceedings{stamp2007anxiety,
  title = {Anxiety and Risk-Taking in a Mouse Model of Sensation Seeking},
  author = {Stamp, Jennifer and Mendelsohn, Danny and Wong, Michael and Cyr, David and Schellinck, Heather},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Sensation-seeking is a personality trait characterized by the desire to experience novelty. Sensation seeking is typically associated with low anxiety, high risk-taking and vulnerability to drug abuse. One potential animal model of human sensation-seeking is high response to novelty in rats. High responders (HRs) choose novel environment over a familiar one and show an increase in locomotor activity in the new environment. These rats also display lower levels of anxiety and an enhanced propensity to self-administer drugs of abuse. This project had two main aims: 1) to determine whether the low anxiety in HR rats is also demonstrable in C57 mice and 2) to use two tests of anxiety (open field and elevated plus maze) as well as a test to specifically assess the dimension of risk taking (predator exposure). HR mice were distinguished from their LR counterparts based upon the amount of activity in an open field. In the open field, HRs spent more time in the "risky" center and less time in the "safe" corners compared to LRs. There were no significant differences between HRs and LRs in any of the measures in the elevated-plus maze but HR mice spent significantly more time than LRs in an area of a predator arena which was in proximity to a food-deprived rat. These data suggest that attributes of humans sensation-seeking are demonstrable in mice.},
}

@inproceedings{shaw2007what,
  title = {What route do visual currents take in generating the fly's electroretinogram (ERG)?},
  author = {Shaw, Steve},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The ERG is an easily recorded, generic visual response, neglected since the 1960s but recently resurrected as an assay tool for investigating the molecular biology of synaptic transmission in Drosophila. Using the blowfly Calliphora, I'm attempting to determine the real origin of the ERG, mistakenly believed to have been solved long ago. Transient ERG currents generated in the first synaptic zone add arithmetically to those generated by the retina, but the direction of current flow uncovered here is unconventional. Currents move out from the synapse into the retina, surprisingly so as the retina appears to be a cul-de-sac surrounded by impervious cuticle. That the cornea is actually a good conductor has been confirmed by tracking responses over it with a new fangled surface electrode, after current has been injected alternately on the cornea then just inside it. ERG currents behaved similarly: the cornea has low internal resistance, though a barrier exists at its intersection with head cuticle. By tracking the angular response of ERG components over ~250°, ERG currents have been found to enter the cornea only where the light source illuminates active neurons underneath. Some of this current leaves again from 'inactive', unilluminated zones, while the rest loops out around the eye, giving rise to the recorded ERG.},
}

@inproceedings{groh2007plasticity,
  title = {Plasticity of microcircuits in the insect central nervous system},
  author = {Groh, Claudia and Meinertzhagen, Ian},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The goal of our project is to study cellular components of neuronal plasticity and their outcomes in the behavioural plasticity of two model insect species (the honeybee Apis mellifera and the fruit fly Drosophila melanogaster). In these species, synaptic complexes within the first optic neuropil and within the synaptic input region of the mushroom body (a higher sensory integration centre required for olfactory learning and memory) facilitate the investigation of fundamental principles of neuronal structural plasticity. My previous work revealed specific, environmentally induced and age-dependent structural plasticity within the brain of female honeybees, but there is still little information about the underlying cellular, subcellular and molecular events underlying such changes. Using electron microscopy and immunofluorescence labelling of filamentous (f-) actin, which is enriched in dendrites, my proposed project seeks to narrow the gap between two hypotheses that: a) developmental and adult plasticity of these synaptic circuits in the insect brain may underlie behavioural plasticity; and b) the source of dendritic structural plasticity is based on the dynamics of motile f-actin.},
}

@inproceedings{takemura2007synaptic,
  title = {Synaptic circuits formed by input neurons to the fly's optic medulla},
  author = {Takemura, Shini-ya and Lu, Zhiyuan and Meinertzhagen, Ian},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The visual system of a fly is intricate, precise, and supports rapid vision. Photoreceptor inputs are received at the two outermost neuropiles of the optic lobe. Many classes of optic lobe neuron, each with a unique morphological signature, are reported from Golgi impregnation. Their synaptic circuits are known completely in the first neuropile, or lamina, but remain a formidable challenge in the second, the medulla. The shape of a neuron is only a guide to how it may connect with other neurons, which must ultimately be investigated by electron microscopy (EM). Most synaptic sites are divergent dyads, and much of the neuropile comprises interneurons and their local microcircuits. Using: a) unlabelled EM series of the distal medulla; and b) the Gal4/UAS system to label specific neurons at EM level, we are analysing synaptic connections of lamina input terminals. Spectral sensitivity is encoded by photoreceptors R7 and R8, and motion sensitivity by lamina cells L1 and L2. Remarkably, R8 provides input to R7 and also to L1, structural evidence for a pathway between colour and motion-sensitive channels.},
}

@inproceedings{hamanaka2007immunocytoch,
  title = {Immunocytochemical localization of synaptic and other proteins in the photoreceptor terminals of the fruit fly, Drosophila melanogaster.},
  author = {Hamanaka, Yoshitaka and Meinertzhagen, Ian},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The fruit fly, Drosophila melanogaster, is a useful model organism to study the localization of the proteins that contribute to synaptic function because it is genetically manipulable and because its neurons have a distinctive synaptic ultrastructure that includes a specialized pre-synaptic organelle at the release site, T-bar ribbon. The latter comprises a platform surmounting a pedestal. I examined the protein composition of the presynaptic T-bar ribbon and its associated synaptic organelles, at photoreceptor terminals of D. melanogaster. After validating candidate antibodies by confocal microscopy, pre-embedding immuno-EM methods showed that four monoclonal antibodies all clearly label distinct synaptic structures: nc82 (Bruchpilot) and SUK4 (which labels a kinesin epitope) label the T-bar ribbon, nc82 at the edge of the platform, and SUK4 close to its pedestal; anti-discs large recognizes the photoreceptor head of capitate projections that invaginate from surrounding glia; while aa2/2 (raised against a homogenate of D. melanogaster brains) localizes to the synaptic vesicle pool.},
}

@inproceedings{stewart2007how,
  title = {How does interoceptive exposure work in the treatment of anxiety sensitivity?},
  author = {Stewart, Sherry H and Sabourin, Brigitte and Watt, Margo C and Wald, Jaye},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Anxiety sensitivity (AS) is implicated in the development/maintenance of anxiety disorders. A brief cognitive behavioural (CB) intervention is effective in decreasing fear of anxiety in high AS women (Watt et al., 2006). This process-based study explored the specific role of the interoceptive exposure component (i.e., running) in explaining intervention efficacy. Female undergraduates, selected as either high or low in AS, participated in three 1-hour CB group sessions that included the running component on the third day. Participants also completed ten 10-minute running sessions between the third day of therapy and the 10-week follow-up. Running was effective in increasing heart rate. Compared to low AS participants, high AS participants displayed greater somatic, affective, and cognitive reactions to running, and showed a greater decrease in affective and cognitive reactions over sessions. These preliminary results suggest that interoceptive exposure may exert its effects in decreasing AS by reducing catastrophic thinking about arousal-related sensations. Note: This talk will be jointly presented by Sherry Stewart and Brigitte Sabourin.},
}

@inproceedings{edwards2007ectopic,
  title = {Ectopic synapses in the visual system of the fruit fly Drosophila melanogaster},
  author = {Edwards, Tara and Meinertzhagen, Ian},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The visual system of the fruit fly is remarkable for its numerical and spatial determinacy, especially at its identified photoreceptor synapses. In Drosophila we can examine ectopic synaptogenesis by genetic means, by targeting photoreceptor axons to an incorrect neuropile in the brain. Photoreceptors are of two types, R1-R6 that innervate the first optic neuropile, the lamina, and R7-R8 that innervate the second, the medulla. Target cells within the lamina persist and maintain expression of cell-specific markers, even when their normal R1-R6 photoreceptor inputs terminate in the medulla. Analysis of lamina ultrastructure reveals that the axons of these mis-targeted photoreceptors, even though they penetrate the lamina, nevertheless form reciprocal synaptic inputs with their normal lamina targets. In addition, these mis-targeted R1-R6 photoreceptors also form ectopic synapses within the medulla, thus providing input to two neuropiles. A subset of these ectopic synapses are characteristic of photoreceptor synapses in the lamina, tetrads with four postsynaptic partners, which are otherwise not found in the R7-R8 photoreceptors that normally terminate within the medulla.},
}

@inproceedings{borowska2007influence,
  title = {The influence of heavy metals on the morphology and plasticity of neurons in the fly's visual system},
  author = {Borowska, Joanna and Meinertzhagen, Ian},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The insect's brain provides an excellent, expendible model to study basic processes occurring in neurons. Using the housefly's brain, I have previously examined the toxic effects of heavy metals (lead, cadmium, zinc and copper) on neuronal morphology and plasticity. My analysis of neurotoxicity concentrated on the influence of these metals on the plasticity of two classes of monopolar cell, L1 and L2, in the lamina of the optic lobe. Changes in the volume of these interneurons depended on the type of metal and its concentration, and revealed that heavy metals penetrate the haemolymph-brain barrier. Rare genetic errors in metal metabolism, or accumulation of metals through environmental or occupational over-exposure can also elevate brain metals to cause neurodegeneration. When they degenerate, neurons take up heavy metals, probably because fail to pump them. With workers at the Canadian Light Source, we will use X-Ray absorption spectroscopy to image the metal profile of fly brains undergoing neural degeneration. For this, we are examining a fly model of Alzheimer's Disease, mutant for the human gene for human Aβ42 amyloid peptides, a major component of senile plaques, and are developing methods to image the brains of these flies non-invasively, as a model for the progression of neurodegenerative disease in humans.},
}

@inproceedings{borycz2007drosophila,
  title = {Drosophila mutants white, scarlet and brown differ not only in their eye colour but also in the distribution and head content of biogenic amines},
  author = {Borycz, Janusz and Borycz, Jola and Kostyleva, Rita and Meinertzhagen, Ian},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The white, scarlet and brown genes in Drosophila melanogaster are named because their mutants have these abnormal eye colours. white mutant flies also have a behavioural phenotype that indicates a neural action. The genes encode ABC transporters involved with the uptake and storage of precursors of pigment granules. We find additional effects on head biogenic amines: all three have about half the normal head histamine (HA), a neurotransmitter at photoreceptor terminals, as well as reduced 5-HT; and white also has reduced dopamine (DA). The mutants also have abnormal cellular distributions of HA, 5-HT and DA. In centrifugates of wild-type brain homogenates, a vesicle-enriched pellet fraction contains ~75% of head HA with 25% in the supernatant. In white, brown and scarlet these proportions are reversed. Similar determinations reveal a reversed ratio between supernatant and pellet fractions for 5-HT and DA as well, and mutant photoreceptor terminals have reduced numbers of synaptic vesicles. We suggest that these three genes may influence the intravesicular contents of the neurotransmitters histamine, serotonin and dopamine in neurons, so as to affect transmission by these neurons.},
}

@inproceedings{greiner2007drosophila,
  title = {Drosophila synapses: protein complexes viewed using EM tomography},
  author = {Greiner, Birgit and Delaney, Nicole and Butcher, Nancy and Marshall, Rorbert M. and Meinertzhagen, Ian A.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Genes programme the physiology of synapses by coding for the synaptic proteins that regulate synaptic function. However, conventional electron microscopy of thin sections is unable to visualise the organisation of such protein complexes because these overlap each other within the depth (~50nm) of an ultrathin section. Recent developments in EM tomography solve the problem of overlap, deriving depth information from wide-angle image tilt series, and revealing structure at the sub-nanometre resolution inherent in an electron beam. Using EM tomography methods we have reconstructed the T-bar ribbons and other synaptic organelles at the release sites of two types of Drosophila wild-type synapse, the neuromuscular junction and photoreceptor tetrad synapses of the fly's lamina. These reconstructions provide a basis against which we will compare structural perturbations in synapses of flies mutant for the genes, such as endophilin or bruchpilot, coding for synaptic proteins.},
}

@inproceedings{porter2007that,
  title = {That's what Friends are For: A Comparison of the Qualities of Single- and Dual-Perpetrator Murders},
  author = {Porter, Stephen and Woodworth, Michael T. and Juodis, Marcus},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {To date, there has been no investigation of possible qualitative differences between homicides committed by perpetrators acting alone versus those who acted with an accomplice. In this presentation, the findings from the first empirical study of single- versus dual-perpetrator homicides will be described. This study involves a thorough examination of the official crime descriptions of 124 Canadian homicides, 84 involving a single perpetrator and 40 involving two perpetrators. The crimes are being compared in terms of perpetrator motive, instrumental/ reactive violence, sadistic violence, gratuitous violence, sexual elements, and victim characteristics. Preliminary findings suggest that dual-perpetrator homicides are associated with a higher level of instrumental aggression (i.e., premeditation, external gain) than single-perpetrator homicides. Further, murders by single perpetrators were significantly more likely to display sadistic and sexual violence than murders by dual-perpetrators. Single perpetrators were more likely to target female victims, whereas dual perpetrators targeted both males and females.},
}

@inproceedings{thompson2007conflict,
  title = {Conflict in Dating Relationships},
  author = {Thompson, Kate},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The present study assessed the relationship between dating abuse and irrational thinking and the hostile attributional bias. This was done using the Conflict in Adolescent Dating Relationships Inventory (CADRI) as the measure of past abusive behavior, the Survey of Personal Beliefs (SPB) as the measure of irrationality, and the rating of a video depicting an ambiguous interaction between two triangles as a measure of the hostile attributional bias. It was hypothesized that greater levels of abuse would be significantly related to higher levels of irrational thinking, and greater incidence of the hostile attributional bias. Hierarchical regression analysis indicated a small, but significant, relationship between abuse and irrational thinking (particularly, the inability to tolerate frustration). Limitations and future directions are discussed.},
}

@inproceedings{zahradnik2007collaborativ,
  title = {A collaborative, community based exploration of how post-traumatic chronic arousal acts as a mediator between exposure to violence and subsequent alcohol use in a sample of school attending Mi'kmaq adolescents},
  author = {Zahradnik, Marc and Stewart, Sherry H. and Stevens, Doreen and Wekerle, Christine and Musquash, Christopher},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {This study is part of a larger ongoing collaborative mental health initiative between our lab and a Nova Scotian Mi'kmaq community. Given the strong relationship that post-traumatic stress (PTS) symptoms have with both childhood exposure to violence (EV) and substance misuse, particularly alcohol, we hypothesized that--based on the "self-medication" hypothesis--in a sample of school attending Mi'kmaq adolescents, PTS symptoms will mediate the relationship between EV and subsequent alcohol use (AU). From a total sample of 166 (52% female, 42% male, & 6% unknown) adolescents (minimum age 14), individual regression analyses (Baron & Kenny, 1986) yielded empirical support for chronic arousal PTS symptoms, total PTS symptoms, and depressive symptoms as "partial mediating" variables that help explain the relationship of EV with later AU. However, a regression analysis that included all relevant predictors--EV, each of the 3 PTS symptoms, total PTS symptoms, and depressive symptoms--resulted in a final model that accounts for 28% of the variance in predicting AU, and in which only the chronic arousal symptom cluster of PTS and EV remained significant.},
}

@inproceedings{fawcett2007incidental,
  title = {Incidental forgetting as a by-product of intentional forgetting},
  author = {Fawcett, Jonathan and Taylor, Tracy L.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The present study explored the consequences of item-method directed forgetting on incidental learning of probe words. During the study phase, study words were presented individually followed by an instruction to remember (R) or forget (F). Pink and blue probe words were presented at stimulus onset asynchronies (SOAs) of 1400, 1800 or 2600 ms in relation to each memory instruction; participants were required to make a speeded colour discrimination of each probe word. After the study trials, a yes-no recognition task measured retention of R and F study words and incidental learning of probe words. Recognition data indicated a significant directed forgetting effect, with greater recognition of R than F study words. Importantly, F instructions increased discrimination RTs and impeded later recognition of probe words presented at the earliest SOA. These findings demonstrate that intentional forgetting interferes with the formation of incidental memories. These results are inconsistent with the dominant hypothesis in the literature, which suggests that forgetting is accomplished by allowing F items to passively decay from working memory.},
}

@inproceedings{smith2007temporal,
  title = {Temporal Order Judgement in Regards to First Base Plays in Baseball},
  author = {Smith, Kristin G.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Sports fans, players and coaches can get very heated about important games, often disagreeing with the umpire's calls. Basic research on the effect of attention on temporal order judgments suggest that these disagreements may occur because the spectators and umpires are attending different regions of space. We sought to determine if attending to different regions in space would cause a difference in the decision of an individual to call a play "safe" or "out". In E1 participants were instructed to attend to the ball or the foot. The results showed that attention mattered: when attending the foot there were more "safe" calls than when attending the ball. In E2, when participants were instructed to attend to the glove or the base, no significant effect of attention was found. It was hypothesized that the participants may have been able to attend both the base and the glove due to their proximity. In E3 participants were instructed to attend both stationary objects, or both moving objects. It was found that the data was similar to that of E2 and there was no significant difference between the attend stationary and the attend moving conditions. Across all trials there was a bias to call "safe" more often than "out".},
}

@inproceedings{matheson2007psychophysic,
  title = {Psychophysical Quantification of Configural Face Processing Using Just Noticeable Differences},
  author = {Matheson, Heath and McMullen, Paddy},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {To quantify the degree to which upright faces are processed with a 'configural processor' relative to inverted faces and objects, psychophysical, just-noticeable differences (jnds) were determined for displacement of critical features (e.g. eyes, windows) within upright and inverted faces and houses and other objects. Stimuli were closely matched on low-level visual features of size, luminance, and shape. Observers were most sensitive to displacement of critical features in upright faces. Sensitivity was equivalent for inverted faces, upright houses and inverted houses. This technique provides quantified differences in the degree to which configural processing is used.},
}

@inproceedings{hoffman2007preserving,
  title = {Preserving Our History with Digital Video: The Snapshot Project},
  author = {Hoffman, Ron and Schellinck, Heather},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Video records documenting the history of the Dalhousie Psychology Department are few in number, and in too many cases rapidly deteriorating. The old analog recordings on magnetic tape will be a difficult challenge to recover. On the other hand, modern digital video recording technology holds promise for increased longevity of archival records, and offers relative ease in recording. In the winter term this year, students in the Psychology/Neuroscience 3010 class began a project to record on digital media a video "snapshot" of the department as it exists today, by interviewing faculty members on camera and then producing a short edited version of each interview. In this presentation, we will describe the project and the training given the students, and show some examples of the resulting material that will go into the departmental archives.},
}

@inproceedings{dukewich2007low,
  title = {Low-Level Processes Contribute to the Production of the Inhibition of Return Effect},
  author = {Dukewich, Kristie and Boehnke, Susan},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The ability to detect and orient to unexpected novel changes in our environment is one of the primary functions of attention. Inhibition of return (IOR) is thought to be a functional after-effect of visuo-spatial orienting, defined as an increase in response times to a target when it is presented at a previously stimulated location compared to when it appears at a new location. Recently it was shown that IOR is correlated with the decrement in the visual response of superior colliculus neurons to a target after responding to a cue at the same location (Dorris et al, 2002). Furthermore, for a sequence of visual stimuli, a smaller visual response occurs with each subsequent stimulus presentation, likely through a process of adaptation and/or habituation (Boehnke et al, 2006). This suggests that the IOR effect should grow as a function of the number of times a cue is presented prior to the target. To investigate this, we used multiple cue presentations (blocked by number of cues) and multiple cue identities in a Posner cueing task requiring a manual response to a target. The results of the experiments demonstrate that habituation and/or adaptation can occur based on a stimulus' location and affects the timing of subsequent behavior, providing further evidence that low-level sensory processes play a role in producing the IOR effect.},
}

@inproceedings{barresi2007black,
  title = {Black and White Like Me},
  author = {Barresi, John},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {John Griffin's classic on racism, Black Like Me, provides an interesting text in which to investigate the development of a dialogical self. Griffin becomes a black man for only a short period of time, but during that time he develops a black social identity that contrasts radically with his former white identity. He develops a schizoid sense of self. He is white and he is black. When he looks into a mirror on several occasions he engages in a dialogue with himself, as both a black and a white person. At first these two identities are so different that there is no "sympathy" between them. But through his experience, he eventually overcomes the dichotomy of two opposing selves, and acquires a personal identity, neither white nor black, but just human. In this talk, I will trace the development of these dialogical selves and the emergence of this new human identity.},
}

@inproceedings{moore2007development,
  title = {The development of 'third-party' gaze following},
  author = {Moore, Chris and Collicott, Cherie},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {By 9 months of age, infants will typically follow the gaze of an interactive partner to a target outside of the immediate visual field. We know from recent research (e.g. Floor & Akhtar, 2006) that infants are only able to learn words and actions in purely observational (or 'third party') contexts from about 18 months. In this study we examined when infants would follow the gaze of someone with whom they are not interacting. Infants of 12 and 18 months observed an interaction between their mothers and an experimenter during which the two adults periodically turned to look at an interesting sight. Coding of infants' tendency to follow the adults' gaze showed that whereas 12-month-olds did not follow gaze, 18-month-olds did. This difference was not due to age-related differences in the tendency to look at the adults. These results are consistent with the idea that young infants learn best in interactive joint attentional settings but by the end of infancy can start to learn purely through observation.},
}

@inproceedings{dummer2007rubber,
  title = {THE RUBBER HAND ILLUSION: Intermodal Perception and Self-Ownership in Adults},
  author = {Dummer, Timothy},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Mental representation of the body arises from the intricate relationship between intermodal sensory input and a continually changing conceptual diagram. Any interference to this process, such as when a person views a rubber hand being stimulated in synchrony with the occluded real hand, will lead to a misperception as tactile sensations are falsely referred to the non-body part. Our research is focused on further analyzing the nature of the rubber hand illusion using conditions of intentional (goal directed) and random movement. We predict that intentional movement will generate a stronger rubber hand illusion based on previous research that links volition with body perception. Results failed to produce a robust rubber hand illusion but revealed a possible attentional component to the process of body identification. In the present study we plan to replicate the previous experiment with the inclusion of a goal-directed movement condition and measure of attention.},
}

@inproceedings{hamonhill2007feel,
  title = {I feel the same way: Recognizing facial emotion as appropriate to context.},
  author = {Hamon-Hill, Cindy and Barresi, John},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Almost all research in emotion recognition to date focuses on categorizing exaggerated facial displays of primary emotions. Little research has focused on how we recognize more complex emotional expressions in their natural contexts - in particular in contexts in which we share emotions with others but do not explicitly label them. The main purpose of our current project is to develop a paradigm in which natural emotional expression to given contexts are used in research on emotion recognition. We focus on the ability to recognize when someone is sharing an emotional reaction similar to self with respect to a stimulus context, rather than on the more cognitive/linguistic task of labelling that emotion. We expect that the development of such a paradigm will open up new ground for investigating the basic processes involved in understanding shared emotional states, where articulation through use of emotion category labels is not involved.},
}

@inproceedings{brinke2007reading,
  title = {Reading between the Lies: An examination of cues to deception in emotional facial expressions},
  author = {Brinke, Leanne ten and Porter, Dr. Steve},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Since the 1960s, Ekman and colleagues have argued that certain aspects of facial communication are not controllable and that inconsistent emotional expressions, including "micro-expressions", can betray a deceiver's true emotion. Despite the widespread popularity of this idea, it has received little empirical attention. This study compared genuine and deceptive (simulated, neutralized, masked) facial expressions. Each 1/30th second frame of the videotaped clips then was coded for the presence and presentation time of the universal emotional expressions in the upper and lower facial regions. Results indicated that inconsistent expressions occurred significantly more frequently in masked than in genuine expressions. Additionally, inconsistent expressions were more frequent and longer in falsified negative (fear, disgust, and sadness) than happiness expressions. Micro-expressions occurred in 21.95% of participants in 2% of all expressions (14 micro-expressions in total), and all involved the upper or lower face only (unlike the traditional "full face" conceptualization). Implications for identifying concealed emotions in forensic and security settings will be discussed.},
}

@inproceedings{johnsonemberly2007parenting,
  title = {Parenting Stress and Maternal Depression in Rural Mothers},
  author = {Johnson-Emberly, Deborah},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Over the past 10-15 years, a consensus has emerged indicating that the causes of parental stress, dysfunctional parenting and child outcomes are best understood using dynamic multivariate models that acknowledge the interaction between variables and the changes in behaviours and cognitions in the parent and child as a result of recurring interactions (Abidin, 1990). Accepted models of parenting stress encompass child characteristics, parent characteristics, environmental characteristics and parent child interactive stress. Previous research has identified strong links between maternal psychological distress/ functioning and parenting stress, dysfunctional parental behaviours, and the social and emotional well being of the child. The stress of parenting is great for all parents. Unique aspects of rural life can compound the factors of parental stress. These include social isolation, employment issues and a general lack of available resources, such as access to health care and childcare. The connections between these sources of rural stress and parenting stress have not been studied. In addition, the mediating role of maternal depression on the direct pathway from general stress to parenting stress has not been investigated. A conceptual model for understanding these connections between rural experiences of stress, maternal depression, and parenting stress will be discussed in this presentation.},
}

@inproceedings{martin2007memory,
  title = {Memory complaints after temporal lobe resection are the exception, not the rule.},
  author = {Martin, Mora and Williams, Jaime},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Temporal lobe resection (TLR) is an efficacious and cost effective treatment for medically intractable complex partial seizures. A risk of mesial TLR is memory loss. Three converging methods asked, "Are patients aware of memory loss in their daily lives one year after surgery?" Method I examined whether 64 TLR patients from Nova Scotia reported group changes in self-reported and verbal memory ability pre- to post-operatively. Mean verbal memory ability declined significantly after left TLR; however, patients and their relatives rated the patients' memory to be significantly better after than before surgery. Method II examined the magnitude of change in subjective ratings for each individual (i.e., Reliable Change Index), based on control data obtained from unoperated epilepsy patients who were medical managed over the year. The majority of TLR patients were classified as unchanged or improved in memory self-ratings whereas fewer than 10% fell into the significant deterioration classification. Method 3 was a meta-analysis that synthesized outcomes of six publications on self-reported memory change pre- to post-op in persons with TLR. Twenty-two effect sizes were calculated based on a total sample of 450 patients and 171 relatives. The weighted mean effect size was +0.25. Hence the consensus is that memory is judged to be significantly better following TLR than before. We conclude that objective and subjective estimates of memory are dissociable. Both risks need to be discussed prior to elective surgery.},
}

@inproceedings{green2007doesa,
  title = {Does the risk of memory loss influence decision making by physicians and patients who contemplate temporal lobe resection for control of seizures?},
  author = {Green, Jaime Williams Jordan and McGlone, Jeannette and Authority, Capitol District Health},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Temporal lobe resection (TLR) is a successful, although underutilized treatment for complex partial seizures. One reason for this underutilized may be the perceived risk of severe and permanent memory loss. However, patients' and physicians' perceptions of the risk of memory loss following TLR have not been empirically investigated. In this presentation, we propose a series of studies using a triangulation of methodologies examining whether fear of memory loss contributes to decision-making about elective brain surgery. First, we propose conducting focus groups with non-surgical, pre and post TLR patients to uncover their thoughts and attitudes towards TLR surgery and the risk of memory loss. Second, we will survey epilepsy specialists querying their thoughts regarding memory loss including how they communicate the risk to patients and what role the risk has in recommending and proceeding with TLR. Finally, we will explore information available on the Internet regarding TLR and the risk of memory loss, including the accuracy and consistency of the information. Implications of the research will be discussed including the importance of effective epilepsy-related knowledge transfer and critical comments will be invited.},
}

@inproceedings{gawryluk2007multimodal,
  title = {A multimodal imaging approach for surgical planning in temporal lobe epilepsy},
  author = {Gawryluk, Jodie and D'Arcy, Ryan and Clarke, David},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Functional brain mapping has tremendous potential to guide neurosurgical planning. Preliminary studies have used functional magnetic resonance imaging (fMRI) and event related brain potentials (ERPs) to map the temporal lobe in a healthy control sample and have highlighted the importance of a multimodal imaging approach. The proposed program of research will combine (fMRI) and (ERPs) to focus on resective surgery for temporal lobe epilepsy (TLE). TLE is the most common type of seizure disorder and surgical intervention is often required for medically intractable cases. Functional MRI will allow for a spatial analysis of task related activation (targeting the temporal lobe), whereas ERPs will allow for analysis of specific processes related to that activation. The current program of research consists of two components: 1) fMRI and ERPs will be used to characterize medial and lateral temporal lobe function in TLE patients and healthy controls; 2) pre- and post-surgical comparisons will determine whether multimodal mapping can improve functional outcome.},
}

@inproceedings{chica2007two,
  title = {Two mechanisms underlying Inhibition of Return},
  author = {Chica, Ana B. and Taylor, Tracy L.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Inhibition of Return (IOR) refers to slower reaction times to respond to targets presented at previously stimulated, inspected, or attended locations (Klein, 2000). Taylor (1999; Taylor & Klein, 2000) showed that IOR can affect both input and output processing, depending on whether the oculomotor system was in a quiescent or in a prepared state, respectively. The motoric flavour of IOR was revealed by the finding that IOR delayed spatial responses even when there was no possibility of an effect on input processing (because there was no target at the location that was supposedly inhibited; the target was a centrally presented arrow). That the "motoric" flavour of IOR did not affect input processing was implied, but not directly demonstrated by Taylor's experiment. If the motoric flavour of IOR is truly non-perceptual and non-attentional, then targets presented at supposedly inhibited locations should not show evidence of this inhibition when the responses to these targets are not spatial. We combed the literature for any studies in which IOR was generated by an eye movement and its effects tested with a non-spatial discrimination task. Finding none, we conducted such a test. Strongly confirming the implication of Taylor's findings, we found that when the eyes move to the peripheral cue and back to the centre before the target appears (to emphasize the motoric component), IOR is generated in a detection task (in which motor preparation is important) but not in a colour discrimination task. The same colour discrimination task showed IOR when eye movements to the cue were prevented (and thus the motoric component of IOR was not activated).},
}

@inproceedings{mazerolle2007interhemisph,
  title = {Interhemispheric transfer of functionally lateralized visual stimuli: An fMRI study at 4T},
  author = {Mazerolle, Erin L. and D'Arcy, Ryan C.N.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Split-brain patients are generally unimpaired in daily life, but demonstrate deficits on tasks that require interhemispheric transfer. We studied interhemispheric transfer in healthy individuals using 4-Tesla functional magnetic resonance imaging (fMRI). In addition to visual interhemispheric transfer (examined previously), the experiment was designed to explore transfer of motor information. We hypothesized activation differences as a function of the type of cross (visual or motor). Word and face stimuli were presented to elicit lateralized brain processing in the left and right hemispheres, respectively. Visual transfer was manipulated via hemifield of presentation, and motor transfer was manipulated via response hand. Decreased behavioural performance was observed for crossed conditions. Both visual and motor transfers were associated with activation near and in the corpus callosum, but visual cross activation was more posterior (around the splenium), whereas motor cross activation was more anterior (around the body). This study highlights the benefits of high field fMRI for studying interhemispheric transfer across the corpus callosum.},
}

@inproceedings{standage2007framework,
  title = {A framework for novelty detection, pattern completion and memory consolidation in the hippocampus and cortex},
  author = {Standage, Dominic and Trappenberg, Thomas},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {A large volume of data support the hypothesis that the hippocampus rapidly encodes representations that bind distributed cortical memories until cortex can reactivate its own memories. We provide a mechanistic framework for this hypothesis, accounting for novelty detection, pattern completion and memory consolidation in the basal ganglia, hippocampus and cortex. Under this framework, everything subject to attention is encoded by early LTP in the hippocampus, but only novel, goal-directed events are subject to late LTP (l-LTP) in subfield CA1, the site of pattern completion under the framework. Attention and novelty detection emerge from hierarchical, bidirectional cortical processing, corresponding to coherent and incoherent activity respectively. Incoherent activity creates unique hippocampal representations, learned by synapses mediating coherent activity and generating a strong response in CA1. This response converges with goal-directed prefrontal activity in the basal ganglia, leading to dopamine release and l-LTP in CA1. Subsequently, coherent activity regenerates the CA1 representation, activating associated cortical areas. The rate of cortical consolidation depends on interference with existing representations.},
}

@inproceedings{saruk2007sex,
  title = {Sex, Drugs, and Abrupt Onset Distractors: Made you Look!},
  author = {Saruk, Nathan and Eskes, Gail and Christie, John and Duncan, Hilary and Klein, Ray},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Visuo-spatial neglect is a failure to attend, detect or respond to stimuli that appear in contralesional space after a stroke. Neglect is considered to be a disorder of attention resulting from impairment in exogenous control of orienting while endogenous orienting is believed to remain relatively intact. We examined the interaction of exogenous and endogenous control of orienting in an occulomotor capture paradigm in 3 groups: young and older healthy controls, and stroke patients with spatial neglect. Dependent ! variables included saccadic latency from target onset to saccade initiation and proportion of trials in which the eyes initially moved to an abrupt onset distractor (attention capture) before proceeding to the target. Consistent with previous findings, saccadic latencies were longer in the older group compared to the younger group, but both groups showed equivalent rates of overt attentional capture. In contrast, patients with neglect showed increased capture to right-sided distractors and decreased capture to left-sided distractors.},
}

@inproceedings{fawcett2007guns,
  title = {Of guns and geese: A general review of the 'weapon focus' literature},
  author = {Fawcett, Jonathan},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {A frequently cited factor in the accuracy of eyewitness testimony is weapon focus, defined as a deficit in later memory for an event or visual scene containing a weapon. Weapon focus has been attributed to interference from the arousal/threat created by the weapon (arousal/threat hypothesis) or by attentional focus on the weapon (unusual item hypothesis). Laboratory, simulation and field studies are separately reviewed, with emphasis on their implications for both of these hypotheses. It is concluded that weapon focus is a small effect observed primarily in laboratory studies, and not easily generalized to real-world scenarios. This talk is a prototype for a symposium presentation submitted to BBCS and a review article in preparation; therefore, questions or comments are encouraged.},
}

@inproceedings{flannery2007role,
  title = {The Role of Self-regulation in Pro-environmental Behaviour},
  author = {Flannery, Meredith},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {A major challenge in the encouragement of pro-environmental behaviours is demonstrating long-term maintenance of desired actions. Recent research suggests long-term health-related behaviour change may be linked to self-regulation skills (Hall et al., 2006). Like health behaviour, establishing new pro-environmental behaviours often involves problem solving and long-term planning that require self-regulation skills. The proposed study will examine the relation between self-regulation skills and pro-environmental behaviour in adults. Using Ajzen's Theory of Planned Behaviour, self-regulation skills will be assessed to help examine the degree to which "actual behavioural control" explains differences in pro-environmental behaviours at the individual level. Three dimensions of self-regulation will be examined according to a problem-solving framework in the literature on early child development of executive function: problem representation, planning, and execution. It is expected that individuals with better self-regulation skills will show more pro-environmental behaviours. Additionally, actual behavioural control should help to explain significant variance in pro-environmental behaviour.},
}

@inproceedings{ishigami2007hands,
  title = {Is a hands-free phone safer than a handheld phone?},
  author = {Ishigami, Yoko},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {The nature of the differences in driving-related performance between hands-free (HF) and handheld (HH) phone drivers is not well understood. One purpose of this review is to evaluate the effects of the phone type on driving (-related) performance across different levels of driving fidelity in the published literature. Talking on a phone, regardless of the phone type, has negative impacts on driving (-related) performance especially in detecting and identifying events. Moreover, the HF phones were rarely found to be necessarily safer than the HH phones. These patterns are similar across different levels of fidelity in studies.},
}

@inproceedings{wright2007stress,
  title = {Stress Responding and Adolescent Development in a Rat Model System: Ally cats and hood rats},
  author = {Wright, Lisa and Hébert, Kimberly and Muir, Katherine and Perrot-Sinal, Tara},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Recent studies demonstrate that the hypothalamic-pituitary-adrenal axis can be 'programmed' by experiential factors in early life, tying mature stress response output to past environmental conditions. Mesocorticolimbic dopamine function also contributes significantly to adult stress response regulation, and this system undergoes major developmental modifications during the adolescent period. In two experiments, we manipulated levels of adolescent stress using repeated exposure of rats to ethologically relevant cat odour stimuli (periadolescent predator odour; PPO) or a control condition. In Experiment 1, adolescent rats showed a clear avoidance response upon initial exposure to the cat odour. By the final PPO exposure, however, they showed several measures of hyperactivity and spent significantly more time near the odour relative to control rats. Furthermore, long-term effects on defensive behaviours persisted into adulthood, and adult expression levels of the D2 dopamine receptor were lower in prefrontal regions. In Experiment 2 specific sensitivity of the adolescent period was examined by comparing outcomes of PPO with identical manipulations administered in early adulthood. Adult endocrine and behavioural parameters were uniquely altered by manipulations in adolescence, but only behavioural effects were specific to cat odour priming. PPO enhanced adult responses to novelty but increased activity during cat odour stress testing. These findings indicate that adolescence is a sensitive period for stress response programming, and a potential mechanism for this could involve developmental alterations in mesocorticolimbic dopamine function.},
}

@inproceedings{mashoodh2007effects,
  title = {Effects of environmental manipulations on maternal behaviour and implications for the development of the rodent limbic system during the first week of life.},
  author = {Mashoodh, Rahia and Nelson, Stephanie and Sinal, Chris J. and Perrot-Sinal, Tara S.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Differences in expression of rat maternal behaviours are associated with differential development of endocrine, emotional, and cognitive responses to stress in offspring. It is hypothesized that plasticity of maternal behaviour serves as the interface between offspring development and the current environment demands. Consequently, offspring neural and behavioural profiles will be optimally programmed to suit the environment in which they are reared. In the first condition dams were exposed to a predation threat (cat odour) on the day of birth. To further gauge the extent to which environmental complexity modulated mother-infant interactions, pregnant dams were introduced to an enriched environment on GD16. Dams and pups lived in this environment until PND7, when pups were sacrificed, brains removed and hippocampi dissected. Using quantitative PCR, changes in excitatory GABA and expression of the transcription factor NGFI-A were used to measure the developmental consequences of these maternal environments.},
}

@inproceedings{brown2007four,
  title = {Four sources of error in the neuro-behavioural analysis of inbred, mutant, and transgenic mice.},
  author = {Brown, Richard and O'Leary, Tim},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {When we began to develop behavioural test batteries for mice over 10 years ago, we were naïve and, like many others, we thought that you just bought mice and tested them, using the apparatus and procedures published in journal articles. But we soon found out that this is not as simple as it sounds. We have discovered four major sources of error in our experiments and I will discuss how we have dealt with these problems. They are: The mouse problem. Mice have a mind of their own and do not want to do what you want them to do. Mouse strains differ in many unexpected ways. How do you determine the problems with each strain? The apparatus problem. Many types of apparatus for mice do not do what people claim in their papers, and modification of the apparatus gives different results. How do you determine which version of an apparatus to use? The procedure problem. There are many ways of using an apparatus, and different procedures give different results. Which procedure should be used? The experimenter-error problem. Experimenters make mistakes. How do you detect them, correct them, and eliminate them? POSTERS},
}

@inproceedings{salmon2007manipulabili,
  title = {Manipulability Affects the Time to Name Objects when they are in Graspable Orientations},
  author = {Salmon, Joshua and McMullen, Dr. Patricia},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Previous research has shown that during object naming tasks, participants are slower to name objects they could normally pick up with one hand (manipulable) compared to objects they could not pick up. The current research explores whether this effect of manipulablity on object naming is sensitive to the ability to grasp the object as assessed by its orientation. Participants were asked to name both manipulable and nonmanipulable objects shown in three different orientations (rotated 0º, 60º, and 300º clockwise). Preliminary results with twelve right-handers replicate previous research with participants being slower to name manipulable objects and slower to name objects rotated in the picture plane. Further, these results suggest an interaction, with the effect of manipulablity bigger at graspable orientations (300º relative to 60º degrees). This interaction appears to be strongest for the first block of trials, and disappears with practice. These results confirm that effects of manipulability on object naming are related to their ability to be grasped.},
}

@inproceedings{sabourin2007sex,
  title = {Sex Differences in Treatment Outcomes of Patients with Comorbid Depression and Substance Use Disorders},
  author = {Sabourin, Brigitte and Stewart, Dr. Sherry H. and Watt, Dr. Margo C.},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Substance use disorders (SUD) and depression are two prevalent and highly comorbid disorders. It is believed that comorbid depression in women with SUD's tends to be more independent of the SUD and less likely to remit following SUD treatment than comorbid depression in men with SUD's. On the other hand, there remains much uncertainty regarding prognosis of the SUD for individuals with comorbid depression, with studies showing either worse, equal, or better treatment outcomes for comorbid versus non-comorbid individuals. As part of the present study, clients entering treatment at Addiction Prevention and Treatment Services in Capital Health will be assessed for SUD's and depression upon entering treatment and again after three to four months of treatment. Sex differences in rates and in the presentation of comorbid depression will be determined. The study also aims to compare SUD treatment outcomes for women and men with and without comorbid depression, as well as to assess depression outcome after SUD treatment.},
}

@inproceedings{fulton2007genetics,
  title = {Genetics of Early Psychosis and the Influencing Effects of Adolescent Drug Use},
  author = {Fulton, Heather and Barrett, Sean and Stewart, Sherry},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Many argue that schizophrenia develops through a gene by environment interaction. Interestingly, most individuals with schizophrenia abuse drugs making drug use a possible environmental trigger. More specifically, when individuals with an underlying genetic vulnerability use certain drugs at a critical developmental window, an interaction may occur where they develop the disorder. A recent study by Caspi et al. (2005) implicated a particular genetic polymorphism; individuals who had this polymorphism and used cannabis in adolescence were at five-fold increased risk for the development of schizophrenia. However, the investigators did not control for use of several other substances (e.g., tobacco). Thus, the results may not be specific to cannabis. This study will investigate the role of genes in NS Early Psychosis Program patients and matched control participants, and then relate this information to each individual's substance use history to test the gene x environment interaction theory and its specificity to cannabis.},
}

@inproceedings{corkum2007impact,
  title = {Impact of Methylphenidate on Sleep in Children with ADHD},
  author = {Corkum, Penny},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Introduction: Children with ADHD are five times more likely to have sleep problems than typically developing children. Sleep problems can cause serious behavioural, learning/cognitive, emotional and social impairments. Our previous research has suggested that the primary treatment for ADHD (i.e., stimulant medications such as Ritalin) may be one of the underlying causes of sleep disturbances in children with ADHD. Methods: Participants (n=28) were diagnosed with ADHD based on an assessment conducted in a multisystem, multidisciplinary ADHD Clinic. All children from this clinic who were diagnosed with ADHD and were considered appropriate for a trial of stimulant medication were recruited to participate in the study. Sleep was measured using subjective (questionnaires, sleep diaries) and objective (actigraphs) measures during a one week baseline period and a three week randomized stimulant medication trial (placebo, low dose, moderate dose). Results: Results of repeated measures ANOVA indicated that sleep was negatively affected by stimulant medication. Based on actigraphy, the average change in sleep duration was a decrease of 63 minutes and sleep onset increased by an average of 40 minutes. However, the number of night time awakenings decreased and overall sleep efficiency was not affected. Similar results were found based on the sleep diary data, but not the questionnaire data. Conclusions: Children with ADHD had typical sleep before starting stimulant medication, however, during the acute medication trial there was a statistically and clinically significant change in their sleep. There was some evidence of increased consolidation of sleep, perhaps a compensatory mechanism for the sleep disruption caused by stimulant medication. Further prospective research examining both the short and long term implications of stimulant medication on sleep in children with ADHD is needed.},
}

@inproceedings{vincent2007self,
  title = {Self-reported sleep difficulties in a community-based sample of children and adolescents with recurrent pain},
  author = {Vincent, Nicolle and Chambers, Christine and Corkum, Penny and Rusak, Ben},
  booktitle = {33rd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2007},
  abstract = {Objectives: In clinical samples of children and adolescents who experience recurrent pain, there is evidence of more disturbed sleep compared to those without chronic pain complaints. This study examines self-reported sleep difficulties in a community-based sample with recurrent pain in comparison to a pain-free control group. Possible mediating variables are also explored. Methods: Participants were ninety children and adolescents, 8-15 years of age, who experienced recurrent pain or were healthy and pain free. Participants completed self-report measures of their sleep, pain, functional disability, depression, coping style, and family functioning. Results: Participants with recurrent pain reported significantly more sleep difficulties than did those in the pain-free control group. There was a significant positive association between increased reports of sleep difficulties and higher scores for pain (frequency, duration, intensity). Further analyses will be conducted to identify possible mediating variables. Conclusions: These results suggest that sleep disturbance is associated with pain in a community-based sample of children and adolescents with recurrent pain.},
}

@inproceedings{ishigami2008individual,
  title = {Are individual differences in absentmindedness correlated with individual differences in attention?},
  author = {Ishigami, Yoko and Klein, Raymond M.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {In recent years, absentmindedness in everyday life has been assessed using the Cognitive Failures Questionnaire (CFQ) (Broadbent et al., 1982). We used the CFQ and the Attentional Network Test (ANT) (Fan et al., 2002, Callejas et al., 2005) to examine the relationship between absentmindedness and attention (which has been little explored to date and with inconsistent findings). Using orthogonal subtractions of performance in selected conditions (see Klein, 2002) the ANT measures the efficacy of three isolable components of attention: alerting, orienting, and executive control. Two different versions of the ANT were administered in two experiments with 100 participants in each. Among three networks whose efficiency is assessed by this test, alerting and orienting, but surprisingly not executive control, were correlated with absentmindedness. The opposite correlations between the CFQ and orienting with the two versions of the ANT suggest that their measures of orienting tap separate constructs.},
  note = {Poster},
}

@inproceedings{corkum2008better,
  title = {Better Days Better Nights: Evaluation of a Behavioural Sleep Intervention for Children},
  author = {Corkum, Penny and Pottie, Trish and McGrath, Patrick},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Objectives: Sleep difficulties are one of the most common concerns reported by parents to family physicians and pediatricians (Owens, et. al., 2002), with approximately 15% to 37% of school-aged children being affected by some type of persistent sleep disturbance (Owens, et. al., 2000). Insufficient sleep can have pervasive negative effects on a child?s day-to-day functioning and development (Reid et al., 1999), on the family unit (Kataria, et al., 1987; Richman, 1981) and on child-parent interactions (Stores, 1996). Unfortunately, treatments for sleep problems are not widely implemented (Owens & Mindell, 2002). Although there is research support for the efficacy of behaviourally-based sleep interventions for typically-developing infants and preschool children (Ramchandani, et. al., 2000), there is a paucity of research examining these interventions for elementary school-aged children. Methods: A two-arm, randomized control trial is currently being conducted in which children (5-12 years old), with or without disruptive behaviour disorders, are assigned to a behaviourally-based sleep intervention or a waitlist control condition. The intervention program consists of five sessions, delivered from a distance using written materials and a non-professional telephone coach. The treatment effectiveness is being evaluated through multiple sleep methods (questionnaires, sleep diaries and actigraphy) and assesses change in sleep disturbance symptoms, daytime behavioural problems, and parental stress. Satisfaction ratings are also gathered from parents. The poster will provide an overview of the study design and treatment, as well as preliminary results from our administrative database regarding treatment effectiveness in terms of impact on sleep disturbances. Results: The preliminary analyses were based on a total of 24 children (12 treatment and 12 control). The treatment group demonstrated significant improvement in the overall sleep disturbances scale (F(2,21) = 4.20, p = .03). More specifically, there was a significant change in sleep onset (F(2,21) = 4.07, p = .03), but no difference in terms of bedtime resistance (F(2,21) = 2.30, p = .12), although the means changed in the expected direction. Parental satisfaction was very high in the treatment group. Conclusions: These results, although preliminary, suggest that the behaviourally-based sleep intervention was effective in improving some sleep patterns. The goal is to have 30 children in each arm who have completed their assignment. After the trial is completed, we will conduct analyses to determine if the results are similar based on actigraphy and whether improved sleep patterns results in improved daytime functioning. Support: Nova Scotia Health Research Foundation, Halifax, Nova Scotia},
  note = {Poster},
}

@inproceedings{omisade2008impact,
  title = {Impact of Partial Sleep Deprivation on Cortisol Patterns in Young Women},
  author = {Omisade, Antonina and Rusak, Benjamin and Buxton, Orfeu},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {This pilot study examined the effects of partial sleep deprivation on the daily rhythm of salivary cortisol in young women across a range of Body Mass Index (BMI) values. Twelve healthy women (ages 18-25; BMIs 18.3-51.9) spent 3 nights and 2 days at the Chronobiology Laboratory at the QEII HSC. During the first 2 nights (Habituation and Baseline), participants were permitted to sleep for up to 10 h. During the third (Experimental) night they slept for 3 h (05:00-08:00). Saliva samples were collected every 2 h from waking to 21:00 during Baseline and Experimental days. The participants also completed inventories assessing mood and cravings for various food groups at the end of each day. Sleep loss elevated afternoon/evening cortisol levels relative to baseline and attenuated the normal morning peak in salivary cortisol levels. Changes in cortisol patterns were not associated with BMI scores. There was an association between increased evening cortisol levels after sleep deprivation and increased hunger on the Experimental day, elevated cravings for most food groups, and lower mood. There was also an association between elevated evening cortisol on the Experimental day and time since the end of menses. These are the first reported effects of sleep loss on cortisol rhythms in women.},
  note = {Poster},
}

@inproceedings{mcglone2008memory,
  title = {Memory outcomes after temporal lobe epilepsy surgery: selective amygdalohippocampectomy vs anterior temporal lobe resection},
  author = {McGlone and Jeannette and Carter and Sherri and Williams, Jaime},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {There is no consensus whether cognitive effects such as memory loss are minimized if neurosurgeons remove a smaller than larger region of the temporal lobe. We present retrospective data on 16 patients who underwent selective amygdalohippocampectomy (SAH) versus 48 with anterior temporal lobe (ATL) resections for control of temporal lobe epilepsy. Demographics and medical histories were similar (i.e., age of onset, seizure frequency, medications, side of surgery, seizure outcome). There was no significant between-group difference on objective memory scores, except trends for SAH to have lower post-op Wechsler Paired Associate scores than ATL ( p <.10). There was no difference on subjective memory ratings using the Memory Observation Questionnaire (MOQ) pre-op or post-op. Within-group ANOVAs (pre to one-year post surgery) showed that objective and subjective scores did not decline significantly after surgery. Interestingly, ATL patients rated memory change more positively than SAH patients (i.e., mean difference on MOQ-SA t score of 8.8, T2,18.2, = 2.1, p < 0.06); a finding that was also seen in the relatives' ratings (MOQ-RA, MD = 9.2, T2,51 = 2.3, p <0.05; MOQ-RB, MD = 22.4, T2,52 = 2.0, p < 0.06). In this non-randomized sample, subjective memory outcomes favoured the larger ATL than smaller SAH resections.},
  note = {Poster},
}

@inproceedings{patterson2008recognition,
  title = {Recognition of Emotion in Faces and Voices in High-Functioning Individuals with an Autism Spectrum Disorder},
  author = {Patterson, Justin and B.A and Johnson, Shannon and Ph.D},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {It has been proposed that individuals with an Autism Spectrum Disorder (ASD) are impaired at recognizing the emotions exhibited by others. However, previous studies of emotion recognition in ASD have yielded conflicting results. In addition, there has been minimal work addressing the recognition of emotions across modalities in ASD. In two separate, but similar studies, we examined recognition of facial and vocal emotions in a total of 26 children and adolescents diagnosed with Asperger's Disorder and 21 typically developing controls. Participants viewed a series of faces depicting emotional expressions and selected the emotional label for each stimulus. Participants also listened to a series of nonsensical vocalizations expressing emotions and selected the correct emotional label. In Study 1, the Asperger's group was less accurate than controls for the recognition of sad facial expressions and the vocal expressions of both anger and interest. There were no group differences in Study 2. SUMMARY: Emotion recognition abilities of individuals with Asperger's Disorder},
  note = {Poster},
}

@inproceedings{carter2008predicting,
  title = {Predicting subjective memory decline following temporal lobe epilepsy surgery},
  author = {Carter and Sherri and Williams and Jaime and McGlone, Jeannette},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Memory ratings decline for <10% of temporal lobe epilepsy patients after surgical resections (see Williams, Martin and McGlone, submitted). This retrospective study examined 5/ 64 surgical epilepsy cases who reported significant postoperative memory decline on the Memory Observation Questionnaire (MOQ) determined by reliable change indices. Better pre-surgical memory performance and absence of mesial temporal sclerosis (MTS) were predicted. Cases were matched on age, sex, and full scale IQ (Average range), and then compared on objective memory, mood, and psychosocial adjustment. Wilcoxon tests revealed trends for higher pre-surgical memory performance and greater objective memory loss for those with increased memory complaints post-surgery, although findings did not reach .05 level of significance in this small sample (i.e., WMS Percent Delayed Recall - Stories, p = .08 and Verbal Paired Associates, p = .07). Contrary to expectations, neuropathology revealed 4/ 5 cases with MTS. Pairs did not differ on depression or psychosocial adjustment yet case review revealed adverse clinical outcomes for those with more memory complaints. Taken together, these findings concur with Lineweaver et al. (2004), suggesting that for those with normal pre-surgical memory abilities, greater complaints following surgery may coincide with actual memory decline and be a marker of poorer post-surgical outcome.},
  note = {Poster},
}

@inproceedings{oconnor2008alcohol,
  title = {Alcohol Use and Gambling are Associated with Different BAS Components},
  author = {O'Connor, Roisin M. and Stewart, Sherry H. and Watt, Margo C. and MacSwain, Kerry},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Motivational models attribute behaviour to individual differences in the Behavioural Inhibition (BIS) and Activation (BAS) systems. BAS sensitivity has been linked to risk for addictions. Factor analyses suggest that BAS is comprised of drive, fun-seeking, and reward-responsiveness components. Research suggests that the fun-seeking and drive components are most strongly related to alcohol misuse and other externalizing behaviours. We examined the relative contributions of each BIS/BAS subscale to the prediction of 533 undergraduates' self-reported alcohol use, smoking, and gambling behaviour. Factor analysis supported the expected 4 BIS/BAS factors. Controlling for sex and age, hierarchical logistic regressions revealed that only elevated fun-seeking was a significant predictor of any drinking or smoking in the past month, while only low BIS was a significant predictor of any gambling in the past month. Controlling for sex and age, hierarchical linear regressions revealed that only elevated fun-seeking was a significant predictor of alcohol use frequency and quantity, while only elevated drive was a significant predictor of gambling frequency and money spent. Findings suggest that different components of BAS sensitivity contribute to alcohol use and smoking vs. gambling (i.e., the tendency to seek out new potentially rewarding experiences vs. the tendency to strongly pursue appetitive goals, respectively).},
  note = {Poster},
}

@inproceedings{doucette2008mediational,
  title = {The mediational role of reassurance-seeking in the relationship between anxious attachment and hypochondriacal alienation: A preliminary test of the Interpersonal Model of Hypochondriasis},
  author = {Doucette and S and Sherry and B, S. and Stewart and H, S. and Hussman and J and Sherry and L, D. and Vincent, N},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Hypochondriasis involves a persistent fear of having a serious illness (American Psychiatric Association, 2000). This common difficulty is debilitating to the sufferer and costly to the healthcare system (Barsky & Borus, 1995). We conducted a preliminary test of the Interpersonal Model of Hypochondriasis (IMH; Noyes et al. 2003). The IMH proposes reassurance-seeking behaviours typical of individuals with hypochondriasis are fuelled by anxious attachment. These reassurance-seeking behaviours lead to instances of conflict with, and feelings of alienation from, other people. Such feelings of alienation are also believed to exacerbate health-related worry among persons with hypochondriasis. We hypothesized that reassurance-seeking would mediate the link between anxious attachment and interpersonal alienation. Fifty-nine undergraduates completed measures of anxious attachment, reassurance-seeking, and interpersonal alienation. Results suggest hypochondriacal reassurance-seeking is a marginally significant partial mediator in the anxious attachment - hypochondriacal alienation connection. This study advances understanding of how hypochondriasis is maintained which may inform future interventions.},
  note = {Poster},
}

@inproceedings{fawcett2008perception,
  title = {The perception of biological form and motion: An ERP Study},
  author = {Fawcett, Jonathan M. and Newman, Aaron J.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Previous research reporting event-related potentials (ERPs) sensitive to biological motion have not distinguished between stimuli depicting static human forms and motion. In the present study, we addressed the specificity of these ERP effects to biological motion by presenting static point-light displays of upright and inverted human forms that began to move after 400-600 msec. Pre-motion onset, equivalent N170 and N300 amplitudes were observed for upright and inverted human forms; post-motion onset, amplitudes of both N170 and N300 components were larger for upright stimuli. Results suggest that these components are not biological motion specific, but are enhanced by upright biological motion.},
  note = {Poster},
}

@inproceedings{lawrence2008disattenuati,
  title = {Disattenuation by Simulation: An estimation and inferential tool for correlation amidst estimable measurement error},
  author = {Lawrence, Mike},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Few empirical measurements can be made without some degree of measurement error, and when estimating the correlation between two variables it is well known that this error tends to lead to raw correlation values that underestimate the true correlation. Empirical estimates of measurement error, calculated across repeated measurements of the same entity, can be used to correct these attenuated correlation estimates. A general purpose tool is presented for calculating correlation estimates and corresponding inferential intervals in the context of estimable measurement error. The new method, dubbed disattenuation by simulation (DS), is founded on a simple simulation method that lends a combination of flexibility of application and inferential capacity heretofore unknown in traditional correction procedures. Monte Carlo simulation reveals that DS outperforms traditional approaches to correlation estimation and inference.},
}

@inproceedings{lawrence2008disentanglin,
  title = {Disentangling exogenous and endogenous temporal attention},
  author = {Lawrence, Michael A. and Klein, Raymond M.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The allocation of information processing resources over time, otherwise known as temporal attention, may be achieved by relatively automatic or controlled mechanisms. Loud noises, for example, may automatically elicit attention whilst learned strategies may be used to prepare resource allocation to impending important events based on previously detected temporal contingencies. With analogy to systems of allocation in spatial attention, these theorized mechanisms are termed exogenous and endogenous temporal attention, respectively. Where past research has confounded these theoretically distinct dimensions of temporal attention, the present work seeks to ameliorate this oversight, including a novel application of Rescorla's "truly-random control" procedure.},
}

@inproceedings{barresi2008what,
  title = {What am I?},
  author = {Barresi, John},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {"What am I?" is a question that has intrigued thinkers in all cultures at all times. My focus will be answers to this question given by thinkers in the western tradition. Transformations in answering this question have occurred, but the issues remain the same. What is my metaphysical nature? Am I a physical thing, for instance an individual living being, or an immaterial, and immortal substance? Am I even a persistent 'thing' at all? Perhaps I'm a process of some other thing, such as neural activity in the brain? Maybe, instead of being a thing or a material process I'm constituted by being conscious of my self or being self-aware. Or am I merely a concept constructed by the brain or mind but constituted by social processes? Indeed, perhaps, there is no single notion that satisfies all our intuitions about our selves and that I am essentially fragmented in nature.},
}

@inproceedings{thompson2008tag,
  title = {Tag, you're it: Tagging as an alternative to Y/N recognition in item-method directed forgetting},
  author = {Thompson, Kate and Fawcett, Jonathan and Taylor, Tracy L.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {In item-method directed forgetting, memory performance is commonly measured using yes/no recognition. Such a task asks the participant whether or not a word was presented during the study phase regardless of memory instruction. The present study proposes another, possibly more valid measure of directed forgetting. Following a standard item-method directed forgetting task, study words were tested using either a standard yes/no task or a tagging task. In the tagging task participants 'tagged' each word as remember, forget, or new. The benefits of the tagging method over a yes/no distinction are discussed.},
}

@inproceedings{noel2008role,
  title = {The Role of Pain in Influencing Children's Recalled Procedural Anxiety},
  author = {Noel and E, M. and Chambers and T, C. and McMurtry and M, C. and McGrath, P. J},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Aim of Investigation: Children are required to repeatedly undergo medical procedures over the course of their early lives and many find these experiences to be both painful and frightening. Children's memories of painful medical procedures have important implications for coping during subsequent procedures. Previous research indicates that children's memory for sensory aspects of pain is surprisingly accurate. We examined whether the level of pain children report experiencing immediately after a medical procedure is related to their recalled anxiety 2 weeks following the procedure (above and beyond the anxiety that children initially experience). Methods: Participants consisted of 27 children (12 males, 15 females) aged 5-10 years (M = 7.52, SD = 1.53) who had undergone venepuncture. Children completed a measure of pain (Faces Pain Scale-Revised: FPS-R, scores range from 0 to 10) immediately following the procedure and a measure of anxiety (Faces Anxiety Scale: FAS, scores range from 0 to 4) at two time points: immediately and 2 weeks following the procedure. Memory scores were calculated by taking the difference between anxiety ratings at each time point. Results: After controlling for initial anxiety, the level of pain that children experienced immediately following the procedure was related to their recalled anxiety ( r = .54, p < .05 ); children who experienced greater pain had higher levels of recalled anxiety. Children who initially reported lower levels of pain (FPS-R = 0-4) tended to accurately estimate their level of procedural anxiety 2 weeks following the procedure. Conversely, children who reported higher levels of pain (FPS-R = 6-10) immediately following venepuncture tended to report higher levels of procedural anxiety at follow up. Conclusions: These preliminary findings suggest that children's initial procedural pain experience may be related to how they recall their level of experienced procedural anxiety.},
}

@inproceedings{filliter2008self,
  title = {Self-Awareness of Autistic Symptoms, Empathy, and Systemizing in High-Functioning Children and Adolescents with an Autism Spectrum Disorder},
  author = {Filliter, Jillian H. and MHSA and Johnson, Shannon A.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Studies of theory of mind in Autism Spectrum Disorders (ASD) typically focus on the ability to perceive and understand others' mental states. It has been proposed that the mechanisms that underlie understanding of others' mental states are similar to those involved in attributing mental states to the self. We compared parent and self-report scores on the Autism Spectrum, Empathizing, and Systemizing Quotients (AQ, EQ, & SQ). Participants were 15 individuals with ASD and 16 age- and IQ-matched controls, ages 9 to 19 years. Comparisons of parent- and self-report scores revealed that ASD participants reported fewer autism symptoms and higher empathy levels relative to their parent, but there was no difference on the SQ. In contrast, parent- and self-reports for the control group did not differ for the AQ and SQ measures, but parents reported more empathizing than participants. These results suggest that those with an ASD have less self-awareness than their typically developing peers.},
}

@inproceedings{green2008programming,
  title = {PROGRAMMING THE STRESS RESPONSE: INVESTIGATING THE ROLE OF SEX DIFFERENCES IN EARLY HPA AXIS DEVELOPMENT},
  author = {Green, Amanda D. and Perrot-Sinal, Tara},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Males and females are known to differ in their responses to stressors, and these differences may be related to the observed sex differences in stress-related diseases. In mammals, differences between the male and female brains are thought to be primarily the result of gonadal hormone secretions, acting during development to 'organize' the wiring of the male and female brain, and in adulthood to 'activate' these differences in neural circuitry. In rodent models, the early postnatal period is a critical time for the sexual differentiation of the brain, and is also a time of significant plasticity in the developing stress system, though little work has directly focused on interactions between the two. We propose to characterize potential sex differences in the development of several brain structures involved in the modulation of the stress response, as well as investigate some of the potential mechanisms that underly these differences.},
}

@inproceedings{emberly2008who,
  title = {The who, what, when, where and how of knowledge translation: A content analysis of funded CIHR operating grants.},
  author = {Emberly, Debbie Johnson and MSc and Centre, Dalhousie University; IWK Health and Graham, Ian D. and PhD and Branch, VP Knowledge Translation and CIHR and Tetroe, Jacqueline and Analyst, Senior Policy and Branch, Knowledge Translation and CIHR},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Objective: To undertake a content analysis of funded Canadian Institutes of Health Research (CIHR) open access grant proposals to examine the types and budgets of knowledge translation (KT) activities proposed. Methods: A random sample of funded grant proposals (n=50 from funding years 2000/01 and 2005/06) was generated from the total funded operating grants in each of the four CIHR themes. Variables abstracted included characteristics of the grant, investigators, and KT activities. Grants were analyzed for the amount budgeted directed to end of grant KT activities, e.g., conferences, publishing and integrated KT activities, e.g., focus groups with research stakeholders. Results & Discussion: Overwhelmingly, the KT activities identified were end of grant diffusion activities, e.g., conference presentations, publication in peer-reviewed journals. The percentage of grants which identified KT as a specific objective within the proposed research program increased from an average of 10% of all funded applications in 2000/01 to an average of 30% in 2005/06. Innovative KT activities are emerging from the health systems/services and population health themes, e.g., involvement of stakeholders, website dissemination which have the potential to reach more stakeholders for less cost than traditional methods of dissemination. Implications of these findings are discussed in the context of the mandate of CIHR and the science of KT.},
}

@inproceedings{mclarnon2008personality,
  title = {Personality, Motivation and Patterns of Misuse of Prescription Anxiolytics and Sedatives},
  author = {McLarnon, Megan E and Meisner, Jessica and Darredeau, Christine and Barrett, Sean P and Psychology and of, 2 1Department and Psychiatry, Dalhousie University 2Department of},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Anxiolytic and sedative medications have important therapeutic uses and are widely prescribed in the treatment of anxiety and insomnia. In addition to their beneficial effects, these substances have psychoactive properties that render them vulnerable to misuse. Despite indications that recreational use of anxiolytics and sedatives is growing, there is a dearth of information available regarding the factors related to their misuse. Existing research has suffered from inconsistency in the operational definition of misuse. Specific personality characteristics and differing motives for use are thought to be related to vulnerability for problematic substance use. The current study investigates anxiolytic and sedative misuse in an adult Canadian sample using a battery of structured interview and self-report measures. Misuse will be operationally defined as the use of the medication for something other than its intended psychiatric purpose. It is expected that distinct clusters of anxiolytic and sedative users will be characterized based on patterns and contexts of use, demographics, personality, psychiatric symptoms, and motivation for use. Identification of the predictors and correlates of anxiolytic and sedative misuse will be essential in understanding this important public health issue.},
}

@inproceedings{battista2008further,
  title = {A Further Investigation of the Relations of Anxiety Sensitivity to Smoking Motives},
  author = {Battista, Susan R. and Stewart, Sherry H. and Fulton, Heather and Steeves, Dan and Darredeau, Christine and Gavric, Dubravka},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Prior research has shown that anxiety sensitivity (AS) is associated with smoking to reduce negative affect. However, given previous limitations in the measurement of smoking motives, it has yet to be definitively established that AS is specifically related to negative reinforcement smoking motives. The present study examined a sample of 119 smokers attending a tobacco intervention program who completed the Anxiety Sensitivity Index and the Reasons for Smoking Scale (RFS) at pre-treatment. In a principal components analysis of the RFS items, stringent parallel analysis supported a two factor solution (negative and positive reinforcement smoking motives). ASI total scores were significantly positively correlated with both RFS factors in bivariate correlational analyses. In partial correlations, the relation between the ASI and the RFS negative reinforcement factor remained significant when controlling RFS positive reinforcement smoking motives, but the correlation of ASI with RFS positive reinforcement motives was not significant after controlling for RFS negative reinforcement motives. These findings have implications for designing targeted tobacco interventions for high AS smokers.},
}

@inproceedings{fujise2008how,
  title = {How language background affects spelling: The role of first language in spelling English plurals},
  author = {Fujise, Keiko and Deacon, S. Hélène},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The current study examines whether and how one's first language affects the spelling of the English plural -s. This is examined by comparing the extent to which English learners utilize frequency-based approach (learning through frequent exposure) or rule-based approach (learning through explicit rules) when spelling the English plural -s. The two experimental groups will consist of late learners of English (i.e., exposure to English after age 12) whose first language is French or Japanese. English monolingual control group will also be included. Whereas French shares the notion of plurality and the writing system with English, Japanese shares neither with English. Consequently, French participants' greater amount of exposure to alphabets and to the notion of plurality may lead them to utilize frequency-based approach in spelling English plurals. On the other hand, Japanese participants may utilize rule-based approach because they do not have the luxury to resort to knowledge built up over time by exposure.},
}

@inproceedings{quinlan2008directed,
  title = {Directed Forgetting: Comparing Pictures and Words},
  author = {Quinlan, Chelsea and Fawcett, Jonathan and Taylor, Tracy},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The present study used an item method paradigm to examine whether or not a directed forgetting effect would generalize from words to pictures and vice versa. Participants were assigned to one of two study-test conditions: word-picture or picture-word. Either words or pictures were presented one at a time at study followed by a remember or forget memory instruction. Following the presentation of all the study trials, a yes/no recognition test measured memory performance for both the remember and forget items in the opposite form as study. Results showed that memory performance was significantly greater for to-be-remembered than to-be-forgotten items in both the word-picture and picture-word conditions, which indicates a directed forgetting effect. However, contrary to the predictions of various theoretical views of the picture superiority effect, there was no significant difference in the magnitude of the directed forgetting effect between the two study-test combinations (picture-word vs. word-picture). These findings have important implications for the underlying encoding mechanisms of words and pictures.},
}

@inproceedings{dummer2008development,
  title = {Development of Smiling in Early Infancy: Relations across age and context},
  author = {Dummer, Tim},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Infants seem designed to not only orient to but also attract the social elements in their environment that will ultimately aid in constructing knowledge. One effective means for securing adult attention is through the use of facial expressions. Infants display a variety of smiles that differ in terms of their use in social interactions and connection to feelings of enjoyment. Smiles more associated with sleep are termed 'reflexive' because they are believed to occur in the absence of known stimulation. Smiles more associated with alert waking states are termed 'elicited' because they become increasingly more contingent on particular external stimuli. Unfortunately, little is known regarding the function of reflexive smiles and their relationship to elicited smiles. Further, the developmental outcome of individual patterns of smiling during early infancy remains to be discovered. We intend to address the above issues (among others) using a longitudinal design by determining the type, frequency and duration of smiles occurring during active sleep and waking states (both social and non-social contexts).},
}

@inproceedings{price2008energy,
  title = {Energy Drinks: What Have You Binge Drinking??},
  author = {Price, Stephen},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Research has shown that substance use does not occur in isolation, but frequently in combination with other substances (e.g. Barrett et al., 2006). There is a growing concern that many young people are combining energy drinks (ED) with alcohol (ALC) despite labels warning against this practice. Sixty university students (M 26, F 34, age17-29, mean = 20.4, SD = 2.4) were recruited who were current or recent ED users. Participants were interviewed to elicit information about their motivations for, and patterns of, ED use, their lifetime substance use and detailed information regarding combined substance/ED use in the seven days preceding the interview. All participants completed self-report questionnaires (demographics, ADHD checklist, and a personality inventory). Analyses (t-tests) revealed significant differences between those who combine ED/ALC and those who do not, on mean drinks per session, total lifetime substance use, age of first use of ALC and the introversion/helplessness personality scores. Binary logistic regression provided a model for the prediction of ED/ALC co-use. Presentation: Talk},
}

@inproceedings{collins2008temporal,
  title = {The Temporal Parameters of Visual Proprioceptive Perception in Infancy},
  author = {Collins, Stephanie and Moore, Chris},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {In humans, differentiating between one's own body movements and those of others is critical. Bahrick and Watson (1985) proposed that the ability to recognize oneself in a mirror and/or live video is aided by the detection of the visual proprioceptive contingency between self and the display. The current study aims to determine at what point children can discriminate between a delayed and non-delayed image of their face. Five to 12-month-old infants will be randomly assigned to one of three delays (1, 2, 10 seconds) and view two computer monitors; one of which displays a live transmission of the infant's face while the other displays a delayed image. It is expected that infants will show a preference for the delayed images, indicating that they can discriminate between the live and delayed feeds. These results will allow us to determine the age at which infants can integrate visual and proprioceptive information.},
}

@inproceedings{fraser2008effects,
  title = {Effects of Socializing and Environmental Enrichment on Alzheimer's Mouse Models},
  author = {Fraser, Leanne},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The effects of environmental enrichment and group housing are currently being investigated. The study includes transgenic mouse models of Alzheimer's Disease (B6C3-Tg(APP695)3DboTg(PSEN1)5Dbo/J) and their wildtype littermates. Mice are being housed in either an enriched environment (rat cage with tubes, plastic house, nesting material, visual stimuli, and other toys) or an impoverished environment (mouse cage with pine chip bedding only). Within these two environments mice are either singly housed, or housed in groups of 2-4. At 3 weeks of age mice were placed into the experimental housing conditions. Mice will be assessed on a battery of tests at both 6 and 12 months of age. The test battery includes the open field test (exploratory behaviour and anxiety), rotarod test (motor ability), Morris Water Maze (visual learning and memory), olfactory digging task (olfactory learning and memory), and cue and context fear conditioning (learning and memory).},
}

@inproceedings{brinke2008dangerous,
  title = {Dangerous Decisions: Examining the Influence of Facial Trustworthiness Assessments on Decisions of Guilt},
  author = {Brinke, Leanne ten and (presenting), B.Sc. (Hons.) and Porter, Steve and Ph.D and Gustaw, Chantal and (Hons.), B.A.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Despite the common assumption that judges and jurors can accurately assess witness credibility, research suggests that they cannot detect deception above the level of chance. According to the Dangerous Decisions Theory (DDT; Porter & ten Brinke, 2008), intuitive evaluations of trustworthiness based on the face greatly influence interpretation of subsequent information about the target. In a courtroom setting, ensuing assessments of evidence may be highly flawed, as evidence is interpreted in a manner consistent with the initial (unreliable) impression of trustworthiness. A recent study by Porter, ten Brinke and Gustaw (2008) presented participants with vignettes describing severe or petty crimes, accompanied by a photograph of the supposed defendant, previously rated as highly trustworthy or untrustworthy in appearance. Participants required less evidence to arrive at a guilty verdict and were less likely to be influenced by exonerating evidence for the untrustworthy-appearing defendants. The current evidence is supportive of DDT and has implications for legal decision-making practices.},
}

@inproceedings{flannery2008executive,
  title = {The Executive and the Environmentalist: Do Executive Function Skills Help Predict Pro-environmental Behavior?},
  author = {Flannery, Meredith and Jacques, Sophie},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Recent research into health-related behaviour change suggests that executive function skills may help explain the inconsistency between people's intention to behave in a particular way and their actual behavior (Hall et al., 2006). Like health behaviour, successfully establishing new pro-environmental behaviours may also require executive function skills. Using Ajzen's Theory of Planned Behaviour as a framework, this study examined the extent to which executive function skills helped to explain above and beyond intention the variation in recycling and composting behaviour by undergraduate students. Executive function skills failed to explain significant variation in behavior. However, performance on the Stop Signal task showed a trend towards significance suggesting that the ability to inhibit a dominant response may be associated with successful behavior. Results are discussed in the context of improving pro-environmental behavior change strategies.},
}

@inproceedings{fairn2008effects,
  title = {Effects of immune activation on behaviour in the cricket Gryllus texensis},
  author = {Fairn, Evan R. and Adamo, Shelley A.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {As in vertebrates, activating an immune response in insects can result in a suite of behavioural changes called 'sickness behaviour' which are believed to function to increase resistance to infection. We tested whether immune activation causes a change in feeding, agonistic, or shelter-seeking behavior in the field cricket Gryllus texensis. Male crickets injected with heat-killed bacteria showed decreased feeding compared to controls but did not differ from controls in the amount of time spent in shelter. Immune challenged females did not differ from controls in amount of time spent feeding but spent less time in shelter than controls. Immune challenged male crickets generally lost agonistic encounters with control males and immune challenged males were less likely to engage in agonistic behavior.},
}

@inproceedings{stewart2008self,
  title = {Self-generated motives for gambling: Relations to gambling involvement, gambling problems, and co-morbid psychopathology in two population-based samples of gamblers},
  author = {Stewart, Sherry H. and Klein, Raymond M. and Barrett, Sean P. and (presenter), Daniel S. McGrath},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Motivational models have proven useful in understanding certain addictive behaviours, such as alcohol use; however, they have not been extensively investigated in the gambling area. In the present study, the utility of classifying gamblers into gambling motives groups was examined based on self-generated responses to a question about primary reason(s) for gambling. Secondary data analyses were performed on two gambling prevalence studies. Participant responses were coded in the context of Coopers' (1994) motivational model for alcohol use, adapted for gambling. Categories for primary gambling motives included: coping, enhancement, social, and other. Preliminary results indicate that coping-motivated and enhancement-motivated gamblers are characterized by a greater severity of gambling problems on the CPGI problem gambling index than socially-motivated gamblers. The results also suggest that additional categories may be required to address gamblers primarily motivated by recreation or financial incentives. Motive group differences in demographic variables, psychiatric symptoms, gambling activities, and other substance use will also be discussed.},
}

@inproceedings{mitchell2008development,
  title = {Development of normal coherent motion perception in kittens requires visual experience in the first 6 weeks of postnatal life},
  author = {Mitchell, Donald and Kennie, Jan},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Coherent motion perception (CMP) is a complex form of motion that is believed to be processed in primates in the middle temporal cortex (MT) and in cats in PMLS that are both visual cortical area beyond the striate cortex. Here we report that kittens reared in darkness to 6 weeks acquire only rudimentary abilities to perceive CMP despite recovering normal visual acuity. Data from animals deprived for different durations suggest that the critical period during which kittens require visual input is very short, lasting only to 6 weeks. The results suggest that higher visual cortical areas require light early in postnatal life for normal development and are also of interest with respect to the controversial viewpoint of Rosa and colleagues that MT (and possible PMLS in cats) may actually be primary visual cortical areas.},
}

@inproceedings{shaw2008exhibitionis,
  title = {Exhibitionist flasher uses wing mirrors with fluorescent fusilli for sexual entrapment.},
  author = {Shaw, Steve},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {A long-legged dolichopodid dipteran from local sea cliffs carries on his wings terminal spots that flash in sunlight over a wide angle, a display aimed to attract the opposite sex. Unusually, the spots behave as mirrors to deflect light incident upon them following the double angle mirror-galvanometer rule, but the wing spot zone is too thin (1.5 µm) to contain any reflector crystals. Instead, broad-band reflecting surfaces are formed from the flattened sides of ~5300 ultrathin, colourless hairs ("microtrichia"), extensions of the surface cuticle that jut out at 90° from the wing surface. The puzzle is how their action as mirrors can combine with wide-angle emission. The hairs are actually spiral mirrors, shaped a bit like fusilli pasta and packed like sardines, so an incoming fusillade of light has to undergo multiple randomizing reflections within the tightly packed fusilli. This generates a broadly diffused output beam (measured normal distribution, ±2 SD ≈ 88°). The microtrichia also fluoresce bright blue in ultraviolet light, prominent in sky-light. While their reflections are mirror-like, microtrichia appear to act as leaky waveguides for this blue fluorescence. Presumably, the flasher-receiver has blue receptors concentrated in part of her retina to take advantage of this parallel, fluorescent visual display.},
}

@inproceedings{howells2008forget,
  title = {Forget about the flankers},
  author = {Howells, Fawcett and Taylor},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {In the item-method of directed forgetting, decreased memory for forget cued words is generally attributed to lack of encoding when memory instructions are presented after each item. The present study examines the possibility of inhibitory mechanisms associated with forget-cued items by adding a flanker task using forget-cued, remember-cued and novel words as flankers in between the study and recognition phase of an item-method directed forgetting task. Flanker trials require a speeded decision about a target word (living or non-living) flanked by words from the same or opposite category. Typically, opposite-category flankers slow reaction times and increase identification errors of the target word. It is hypothesized that, if inhibition is involved in item-method forgetting, the typical flanker effect will be dampened or eliminated when the flanker words had previously been forget-cued, as compared to remember-cued or novel words. Results and implications are discussed.},
}

@inproceedings{matheson2008psychophysic,
  title = {The Psychophysics of configural face processing},
  author = {Matheson, H and McMullen, P},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The present study investigated observer sensitivity to the 2nd order configural relations of features (distances between features) within face and non-face stimuli. Using Just Noticeable Differences (JNDs) we have shown that observers are more sensitive to 2nd order relational information in face stimuli than house stimuli. Contrary to existing theories, inverting the stimuli reduced sensitivity to 2nd order relational information in both faces and houses when both types of stimuli were presented in the same task. However, when only the house stimuli were presented without the face stimuli, inversion failed to reduce sensitivity to 2nd order relational information in houses. Together these results suggest that 2nd order relational processing may not be face-specific, and can be flexibly applied to non-face objects when they are presented in the context of faces.},
}

@inproceedings{matheson2008face,
  title = {Face perception and the processing of race},
  author = {Matheson, H and Newman, A},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Using Event-Related Potentials, researchers have revealed an early negative component?the N170-- that is larger in response to faces than to other classes of object. It is thought that this component reflects processes that encode the structure of the face. Importantly it has been shown that the N170 is not sensitive to the age or gender of the face, suggesting that this type of information is extracted at later stages. However, it is unclear whether this stage is sensitive to the race of the face. In the present experiment, event related potentials were recorded while participants viewed faces of three different races. It was shown that race had no effect on the N170, a finding consistent with the notion that race is extracted from a face image after the basic structure has been encoded.},
}

@inproceedings{fulton2008patterns,
  title = {Patterns and Predictors of Tobacco use in Early Psychosis Patients and Controls},
  author = {Fulton, Heather G. and Barrett, Sean P. and Stewart, Sherry H. and Good, Kimberley and Leslie, Ron and Pencer, Alissa and Whitehorn, David and Milliken, Heather},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Psychosis is a severe disorder affecting more than 1% of the population. Smoking is highly prevalent in this disorder, especially in comparison to the general population. However, little research has examined how individuals with psychosis use tobacco in comparison to controls. Early psychosis patients' patterns of current and lifetime tobacco use were compared to controls. Patients reported their heaviest use of tobacco to be later in life and reported using tobacco more frequently than controls. As different proportions of patients and controls currently used tobacco, subsequent analyses were conducted only with current smokers. Current smokers with psychosis smoked more cigarettes per day and reported greater tobacco dependence levels than current smoker controls. In regression analyses, patient status predicted tobacco dependence levels over and above other variables (e.g., demographics). Results provide insight into how patients with psychosis use tobacco and how to tailor cessation programs to better serve this population.},
}

@inproceedings{mazerolle2008detecting,
  title = {Detecting fMRI activation in white matter: Interhemispheric transfer across the corpus callosum},
  author = {Mazerolle, E.L. and D'Arcy, R.C.N. and Beyea, S.D.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {SUMMARY: Functional magnetic resonance imaging (fMRI) activation is believed to be restricted to gray matter (GM). Both hemodynamic and neurophysiological evidence support this assertion. In spite of this, fMRI activation is not neatly restricted to GM, and an increasing number of studies are explicitly reporting WM activation. In the current study, we investigated WM activation using 4T fMRI. To elicit WM activation, an interhemispheric transfer task was employed using lateralized cognitive processing. The role of the corpus callosum (CC) in this type of task has been previously established in split brain patients. The analysis revealed CC activation in14/24 subjects. Of these 14 subjects, four had activation centered in the CC. Interestingly, this activation was consistently localized to the posterior body of the CC. In contrast, CC activation in the remaining 10 subjects was likely attributable to partial volume effects (i.e., contamination by GM signal). Ultimately, characterization of fMRI in WM may open new avenues of clinical research in which functional assessment of WM is critical.},
}

@inproceedings{butcher2008detection,
  title = {Detection of fMRI activation in white matter},
  author = {Butcher, Nancy J and Edwards, Tara N and Greiner, Birgit and Meinertzhagen, Ian A.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The synaptic vesicle cycle predicts the movement of vesicles through a synaptic terminal so that a reciprocal process of vesicle recovery and neurotransmitter pumping matches the shedding of synaptic vesicles during transmission. The visual system of Drosophila melanogaster provides an excellent model for the investigation of the structure and identity of presynaptic organelles and proteins involved in the synaptic vesicle cycle; not only do photoreceptor terminals in Drosophila have a regular structure but their synapses are genetically manipulable. In the present study, novel insight into the ultrastructure and identity of proteins and organelles involved in the synaptic vesicle cycle and vesicle endocytosis was provided. New advances in EM tomography enabled the resolution of a filamentous vesicle network within the photoreceptor terminal, and substantiated claims that the T-bar ribbon is a site of vesicle docking and shedding. These reconstructions of synaptic terminals may serve as a basis of comparison for synaptic mutants at a level of detail not previously available using conventional EM methods. Investigation of the two junctional proteins, Crumb (Crb) and Discs Large (Dlg), show that Dlg, but not Crb, is localized to photoreceptor terminals and facilitates the development of the endocytotic organelles known as capitate projections. Unexpectedly, dense core vesicles were found in mutant photoreceptor terminals, potentially uncovering a new function of Dlg in the photoreceptor terminal.},
}

@inproceedings{salmon2008jugglers,
  title = {Do Jugglers show Enhanced Processing of Peripheral Visual Stimuli?},
  author = {Salmon, Joshua and Newman, Aaron},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Action video game players show enhanced performance on a number of attentional tasks. In addition, those who learn a visual spatial language such as American Sign Language show enhanced attention to peripherally presented moving targets. The current research considered whether or not juggling, another visual spatial task, confers the same benefits as learning sign language or playing video games. Jugglers were matched to non-jugglers of the same age, gender, and handedness and tested on a number of attentional tasks (Multiple Object Tracking, Flanker-Compatibility, and Useful Field of View) as well as having event-related potential recorded during an attention-to-motion task. Preliminary results (N=12) suggests that juggling may indeed confer some benefits measurable by visuo-spatial tasks. However, the size of the effects for jugglers may not be as large as those found for video game players and signers, and may be limited to only certain tasks. Presentation: TALK Date: No preference. Equipment Needs: None, beyond a PC computer (preferably).},
}

@inproceedings{phillmore2008neural,
  title = {Neural response of male and female black-capped chickadees (Poecile atricapillus) to normal and altered conspecific song},
  author = {Phillmore, Sean P. Roach an Leslie S.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The purpose of the present study is to establish neural correlates for previous behavioural studies illustrating which particular aspects of the highly stereotyped song of the black-capped chickadee (Poecile atricapillus) are necessary for conspecific recognition by male and female chickadees. Birds will be exposed to synthetic song stimuli of four types corresponding to those used in the behavioural studies: normal songs, and songs with eliminated glissando, altered internote pitch ratio, or both. After sacrifice, levels of ZENK expression in the caudomedial nidopallium (CMM) and caudal medial nidopallium (NCM) will be examined (previous research has established ZENK expression as a reliable indicator of song perception and recognition). It is expected that ZENK levels in these areas will correspond to behavioural responses to normal and altered songs in male and female chickadees. It will be especially interesting to see the neural response of male chickadees to songs with altered internote pitch ratio, as males are able to perceive such differences but do not discriminate based upon them.},
}

@inproceedings{wright2008adolescent,
  title = {Adolescent endocrine and behavioural responses to predatory stimuli in a rodent model: Alley cats and hood rats, part II.},
  author = {Wright, Lisa D. and Muir, Katherine and McDonald, Holly and Perrot-Sinal, Tara S.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Hypothalamic-pituitary-adrenal function and defensive behaviours can be 'programmed' by external factors during early life in rats. Emerging evidence indicates that the adolescent environment is also important in this context, as prefrontal brain regions mature at this time and are responsible for cognitive regulation of stress responding. In order to identify potential mechanisms underlying long-term consequences of adverse adolescent conditions, we conducted a series of experiments designed to examine adolescent responses to stressor exposure. In Experiment 1, we examined responses to two different cat odour stimuli, following repeated adolescent exposures. We also compared adolescent and adult responses to repeated cat odour presentation (Experiment 2), and, finally, we compared adolescent responses to predation threat with responses to a social isolation stressor. Results underscore the importance of the nature of stressor stimuli in determining effects on adolescents, providing support for the hypothesis that adult stress responding will be optimized for predicted environmental conditions.},
}

@inproceedings{sherry2008does,
  title = {Does Perfectionism Impede Research Productivity? A Study of Psychology Professors},
  author = {Sherry and B, S. and Sherry and L, D. and Hewitt and L, P. and Flett, G. L},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Amid the "publish or perish" field of academic psychology, personality traits that influence research productivity (i.e., the number of and the impact of journal articles, book chapters, books, edited books, symposia, and posters) may represent important contributors to career outcomes. In the present study, self-oriented perfectionism (i.e., demanding perfection of oneself) and socially prescribed perfectionism (i.e., perceiving that others are demanding perfection of oneself) were hypothesized to impede research productivity. Psychology professors (N = 1,258) completed measures of demographics, personality traits, and research productivity. Results indicated higher levels of self-oriented perfectionism were associated with lower levels of research productivity above and beyond demographics, conscientiousness, and neuroticism. Socially prescribed perfectionism was unrelated to research productivity. The present study suggests psychology professors who demand perfection of themselves struggle to disseminate their research. Publications and presentations generated by psychology professors high in self-oriented perfectionism may be seen as occurring in spite of--and not because of--their perfectionistic behavior.},
}

@inproceedings{fairn2008effectsa,
  title = {Effects of immune activation on behaviour in the cricket Gryllus texensis},
  author = {Fairn, Evan R. and Adamo, Shelley A.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {As in vertebrates, activating an immune response in insects can result in a suite of behavioural changes called 'sickness behaviour' that are believed to decrease the impact of disease on fitness. We tested whether immune activation causes a change in feeding, agonistic (i.e. aggressive), or shelter-seeking behavior in the field cricket Gryllus texensis. Male crickets injected with heat-killed bacteria showed decreased feeding compared to controls but did not differ from controls in the amount of time spent in shelter. Immune challenged females did not differ from controls in amount of time spent feeding but spent less time in shelter than controls. Immune challenged male crickets generally lost agonistic encounters with control males and immune challenged males were less likely to engage in agonistic behavior.},
}

@inproceedings{newman2008envisioning,
  title = {Envisioning the Future: Building a Clinical Neuroscience Program at Dalhousie},
  author = {Newman, Aaron and Johnson, Shannon and Duffy, Kevin},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Neuroscience research has revolutionized our understanding of relationships between brain, behaviour, thought, and emotion. Tools such as genetic screening and brain imaging will eventually play a central role in the diagnosis and assessment of psychopathology, and evidence from neuroscience already has uses in everyday practice. Although clinical psychologists have a solid understanding of the biological bases of behaviour, a deeper knowledge of the neurophysiological underpinnings of normal and pathological psychological function will be essential in the future. To provide clinicians with this knowledge, and the skill set to use it, training programs must keep pace. Dalhousie, with its exceptional Clinical Psychology program and internationally-recognized strength in neuroscience, is perfectly poised to play a leading role in integrating clinical psychology and neuroscience. In this forum we will outline a 5-year plan to develop a program in Clinical Neuroscience at Dalhousie.},
}

@inproceedings{neal2008interactive,
  title = {Interactive and Observational Learning in Infants:},
  author = {Neal, Tristan and Moore, Chris and Collicot, Cherie},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Research in the past 20 years has established infant learning of novel words and social actions in joint attention (see Moore, 2006, for review). Recently, 18 month-olds have shown this learning by observing two people who are socially aloof from the infant interact (Akhtar, 2005; Floor and Akhtar, 2006) and 24 month-olds by observing one socially aloof person perform alone (Nielson, 2006). As of yet, no comparison of learning between these two observational contexts and that of joint attention has been made with the same children. This study compared novel word and action learning between these contexts in a group of twenty-two 14-26 month olds. The results supported previous study of novel action learning, however no evidence for novel word learning was shown. Sample size, children's age, task familiarity and motivation may have influenced the degree of learning demonstrated.},
}

@inproceedings{kalousek2008everyday,
  title = {EVERYDAY PAIN INCIDENTS IN CHILDREN AGED 12 TO 36 MONTHS},
  author = {Kalousek, Kate S. and Chambers, Christine T. and McGrath, Patrick J. and Yanchar, Natalie L. and Moore, Chris and Baeyer, Carl L. von},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Aim of Investigation: Everyday bumps and hurts are a common occurrence for children. These minor yet frequent incidents may have considerable influence on children's development of pain coping strategies. While several studies have documented the frequency and nature of everyday pains in preschoolers (3 to 5 years), little is known about everyday pain in younger children. We examined the frequency and nature of everyday pain incidents in a sample of toddlers during active play. Methods: An observational checklist (Dalhousie Everyday Pain Scale - Revised) was used by trained coders to document the nature of minor painful incidents (e.g., body location, cause of hurt, severity of incident, child distress) that took place during the play session. Results: 35 children (18 boys, 17 girls) aged 13-31 months (M = 22.5, SD = 5.2) and their parents (32 mothers, 3 fathers) were observed at an indoor play facility for up to 4 hours during 2 separate 2 hour play sessions (N= 17 for session 1; N=18 for session 2). Analyses will examine how child variables (i.e., sex, age, temperament) influence the nature of the painful incidents as well as parental response to such incidents. The influence of parental reaction (comfort/sympathy, distraction, ignoring, punishment) on the intensity of child distress will also be examined..},
}

@inproceedings{hamonhill2008remember,
  title = {I remember your smile: Recognizing facial emotions from a brief acquaintance.},
  author = {Hamon-Hill, Cindy and Barresi, John},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Does familiarity with a person's emotional responses in particular situations enhance an observer's ability to correctly recognize that person's responses in other situations? Dynamic facial displays of two people were individually paired with images to which they were responses, or paired with other images. For each display, observer's task was to judge whether a person was looking at the accompanying picture or not. Observers (N = 60) were exposed to a pre-test 'acquaintance' period for one of the stimulus faces. Acquaintance improved performance on paired displays previously seen (p <.001). Surprisingly, performance on previously unseen expressions did not differ from those for a complete stranger. Familiarity with the person's facial responses did not generalize to unfamiliar situations. PRESENTATION: Talk AVAILABLE: Either day.},
}

@inproceedings{brown2008epigenetics,
  title = {Epigenetics: The future of psychology},
  author = {Brown, Richard E.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {One of the most enduring dichotomies in psychology is the "nature vs. nurture" debate. The human genome project allows us to identify every gene in the human (and mouse, rat, fruit fly, etc) and to understand the contributions of genes to neural and behavioural development. We are also able to identify the physical, social and chemical factors which influence neuro-behavioural development. Epigenetics is the study of how environmental variables regulate gene expression. The action of environmental factors on neurochemical systems and intracellular transduction pathways of neural cells modify the structure of histone proteins in the chromatin of the cell nucleus and these histone proteins regulate gene expression. Thus, epigenetic processes provide the mechanism for environmental regulation of gene expression and the solution to the nature-nurture problem. This talk gives a brief outline of epigenetics and describes epigenetic approaches to the study of behavioural development, aging, learning, memory, social behaviour and neuropsychiatric disorders. Already epigenetic research is changing the way that psychological processes are understood.},
}

@inproceedings{petter2008acute,
  title = {The acute effects of exercise or mindfulness therapy on affect, fatigue, and pain in patients with Multiple Chemical Sensitivities},
  author = {Petter, Mark and Blanchard, Chris},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Multiple Chemical Sensitivities (MCS) is a condition characterized by sensitivity to low levels of food and chemical exposure, which results in a variety of physical symptoms including pain and fatigue. Symptoms may be caused by a number of common substances such as perfume, detergents, and exhaust. MCS has a large impact on the Nova Scotia health care system, as well as on the quality of life of those with the illness, and research into the effectiveness of treatments is needed. The Nova Scotia Environmental Health Centre (NSEHC) is a medical facility dedicated to research and treatment of MCS and other environmental illnesses. The NSEHC currently offers mindfulness and graded exercise therapy programs for MCS patients. The purpose of the proposed study is to compare the acute and chronic effects of these two treatment programs on the outcomes of pain, fatigue, mood, and arousal. In doing so, this study intends to delineate the impact of these programs on the MCS patients and examine whether they are the same. A further goal is to determine at what point within each of these programs patients tend to show the most improvement. The results of the present investigation may improve upon existing MCS treatment programs, and allow for the development of cost-effective, individualized programs. Preliminary results will be presented.},
}

@inproceedings{johnson2008lack,
  title = {Lack of Local Bias during Selective Attention Global-Local Processing in Autism Spectrum Disorders},
  author = {Johnson, Shannon A. and Blaha, Leslie M. and Bruce, Vanessa A. and Townsend, James T.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Previous studies of global-local (GL) processing in autism spectrum disorders (ASD; Rinehart et al., 2000; Plaisted et al., 1999) suggest a lack of both global advantage and global interference. However, methods employed in these studies have serious limitations that raise questions about the validity of the results. In the current study, we used traditional cognitive science methods to examine GL processing in ASD during selective attention tasks. Sixteen high-functioning individuals with an ASD and 16 age- and IQ-matched controls completed eight selective attention GL tasks using hierarchical letter and number stimuli. Repeated measures ANOVAs revealed a main effect of attended dimension with faster response times for the global versus local dimension for both groups on all tasks. Contrary to previous ASD studies, global interference was demonstrated by both groups and neither group demonstrated local interference. Overall, findings indicate typical GL processing in high-functioning ASD participants during selective attention conditions.},
}

@inproceedings{lavranos2008characteriza,
  title = {Characterization of Electrocommunicative Signals of Elephant Nose Fish (Gnathonemus petersii)},
  author = {Lavranos, Haralambos and Phillmore, Leslie and Gadbois, Simon},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Elephant nose fish use weak electric signals for both electrolocation and electrocommunication. In this study, we sought to characterize electrocommunicative signals in two ways: how they change over distance and in response to conspecifics. The signals follow the inverse square law and fall off in maximum, minimum, and root mean square amplitude. The size of the fish was not related to signal power. Small sample size and low signal resolution prevented us from concluding that individual fish discriminate between familiar and non-familiar conspecifics, however there is preliminary evidence that the fish discriminate between an environment with or without conspecifics.},
}

@inproceedings{robblee2008behavioural,
  title = {BEHAVIOURAL RESPONSE TO PLAYBACK OF VOCALIZATIONS BY BLACK-CAPPED CHICKADEES (Poecile atricapillus)},
  author = {Robblee, Laura and Roach, Sean and Phillmore, Leslie},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Black-capped chickadees have a well studied and large repertoire of vocalizations used for communication; the production of two of these vocalization types, fee bee song and chick-a-dee call vary with season: song is produced primarily in spring, whereas call is produced year-round (ref). We examined the behavioural responses of black-capped chickadees to playback of three types of vocalizations: (1) conspecific fee bee song, used by males for territorial defense and mate attraction, (2) conspecific chick-a-dee calls, used by both males and females as contact and alarm calls, and (3) heterospecific (Song Sparrow, Melospiza melodia) song. We measured the number of vocal responses, the average distance from the sound source, and general activity before, during, and after playback. Overall, there were not many vocal responses to playback of any kind. However, birds appeared to spend more time closer to the speaker during playback of conspecific vocalizations than heterospecific vocalizations, and birds that heard conspecific calls were more active than birds that heard either heterospecific songs or silence. Results are discussed in terms of seasonal influence on behavioural response to vocalizations, and have implications for neural processes underlying perception of vocalizations.},
}

@inproceedings{stewart2008developing,
  title = {Developing and Testing a New Gambling Motives Questionnaire},
  author = {Stewart, Sherry H. and Toneatto, Tony and Zack, Martin and Turner, Nigel E. and Grant, Valerie V.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Summary: We developed and evaluated a 15-item Gambling Motives Questionnaire (GMQ). In Study 1, principal components analysis of GMQ items completed by 193 gamblers revealed Enhancement (EM), Coping (CM), and Social (SM) Motives factors. Probable pathological gamblers (PPGs) scored higher across scales than non-pathological gamblers (NPGs) with larger differences for CM and EM. EM predicted gambling behavior, and CM and EM predicted gambling problems. CM predicted gambling problems more strongly in women; EM predicted gambling problems more strongly in men. With gambling behavior controlled, only CM remained associated with gambling problems. 243 problem gamblers, representing six primary gambling activities (e.g., bingo, sports betting), participated in Study 2. GMQ subscales were differentially associated with demographic variables (e.g., CM correlated negatively with being married, working, and income). Gambling motives also varied by gambling activity (e.g., bingo was associated with CM and sports betting with EM). The GMQ appears a promising clinical research tool.},
}

@inproceedings{terauds2008what,
  title = {It Is What It Is! (Or Is It, "It Is Where It Is!"?)},
  author = {Terauds, Katherine and Jacques, Sophie},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {The present study aimed to clarify the relative contributions of object and location information to children's awareness of the relation between a symbol and its referent. Three- and 4-year-old children were tested using a version of the DeLoache (1987) model-room search task. Performance on two types of models (congruent vs. conflict) and two types of trials (same-location search vs. different-location search) were compared as a function of whether object properties and object location matched or not. While there was no effect of age, children were able to use object property information but not object location information to search for hidden objects, and when they erred, they appeared to do so by using object-based information.},
}

@inproceedings{scantlebury2008potential,
  title = {The potential role of fetal amyloid-β in the pathogenesis of Alzheimer's disease among parous women: Are the kids really driving you crazy?},
  author = {Scantlebury, Jordan and Brown, Richard E. and Perrot-Sinal, Tara S.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Epidemiological research suggests that parous women (those with children) are more likely to have a diagnosis of Alzheimer's disease (AD) than nulliparous women (those without children), perhaps due to a decrease in the average age at disease onset. Parity has not been associated with AD in men. Recent discovery of a moderate increase in amyloid plaque (AP) density with reproductive experience in women, but not men, corroborates these reports. The relationship between parity and AD has been attributed to changes in estrogen and progesterone exposure accompanying pregnancy, but compelling evidence indicates that the role of sex hormones in AD has been exaggerated. The purpose of the proposed research is to investigate a parsimonious alternative mechanism whereby parity may enhance AD pathogenesis, namely, the possibility that amyloid-β (Aβ), which is developmentally expressed, is transported from the fetus to the mother during pregnancy. Aβ is the putative pathogenic peptide in AD, and the predominant hypothesis of AD etiology predicts that the presence of fetal Aβ will increase the rate of AP formation and neurodegeneration.},
}

@inproceedings{dukewich2008habituation,
  title = {An habituation account of inhibition of return},
  author = {Dukewich, Kristie R.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Inhibition of return (IOR) is an effect whereby reaction times (RTs) to a target presented at a location where a stimulus had recently been presented are increased compared to when a target is presented at a new location. Early reports that habituation is not responsible for the IOR effect are shown to be ill conceived. More importantly, a large portion of the literature can be accounted for using the habituation framework. The current paper reviews some of the support for this theory, and explores some of the predictions that this theory suggests. Behavioural Consequences of Preferred Direction Coding in Human Motor Cortex Cowper-Smith, C.D.1, B.Sc Westwood, D.A.2, Ph.D. To examine the behavioural relevance of the directional tuning preferences for neurons in primary motor cortex (M1), we analyzed the reaction time for consecutive, endogenously cued arm and eye movements (E1: arm-arm; E2: eye-eye). We also explored the existence of a common spatial coordinate system for arm and eye movements by including both types of movements in the same experiment (E3: hand-eye; E4: eye-hand). Participants fixated a central target that was surrounded by 8 equidistant peripheral targets. When the prime cue (a directional arrow) was displayed at fixation, participants responded with a joystick or eye movement to the indicated target and then returned to centre. The probe cue was delivered 1.5 seconds after the onset of the prime cue, and required a second response (joystick or eye movement); this movement could be to the same target or any of the other targets. The results suggest that arm and eye movements utilize different coordinate systems that do not map onto the known directional tuning curves of neurons in a straightforward manner. The results are broadly consistent with past research on motoric inhibition of return.},
}

@inproceedings{eskes2008using,
  title = {Using Temporal Order Judgments to Study Spatial Neglect.},
  author = {Eskes, Gail and Klein, Ray and Shore, David},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Spatial neglect after right hemisphere stroke is common and results in difficulties with orienting, detecting or responding to left-sided stimuli. Investigating the underlying mechanisms of neglect can be challenging, due to spontaneous improvement, learned compensatory strategies by patients, and heterogeneity of the neglect syndrome, both within a patient on different tests, as well as between patients. In this talk, we'll describe our approach to studying neglect using temporal order judgments (TOJs) and the preliminary results from a series of studies examining both bottom-up and top-down mechanisms controlling attention in neglect.},
}

@inproceedings{al2008using,
  title = {Using eye movements to answer basic and applied questions},
  author = {al, Raymond Klein et},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Helmholtz demonstrated that attention and gaze direction could be dissociated and more recently Posner developed the cuing paradigm as a model task for exploring the nature of attention shifts in the absence of shifts in gaze direction. Yet, normally attention and eye movements are closely coordinated. Scholars have, therefore, used oculomotor behavior as a tool for answering basic science questions about cognitive processes and for generating data to shed light on real-world problems. Some of the basic and applied research in the Klein laboratory that uses these strategies will be briefly described.},
}

@inproceedings{hoffman2008preserving,
  title = {Preserving Our History with Digital Video: The Snapshot Project, Year 2},
  author = {Hoffman, Ron and Schellinck, Heather},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {In the winter term last year, students in the Psychology/Neuroscience 3010 class began a project to record on digital media a video "snapshot" of the department as it exists today, by interviewing faculty members on camera and then producing a short edited version of each interview. Copies of the interviews on DVD have been enthusiastically received by the university archivist, and may some day be available in a departmental museum. This year's 3010 class completed an additional nine interviews. In this presentation, we will briefly describe the project and the training given the students, and show the resulting material that will go into the departmental and university archives.},
}

@inproceedings{omisade2008impacta,
  title = {Impact of Partial Sleep Deprivation on Cortisol Patterns in Young Women},
  author = {Omisade, Antonina and Rusak, Benjamin and Buxton, Orfeu},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {Departments of Psychology,1 Psychiatry2 & Pharmacology,3 Dalhousie University, Halifax, NS, Canada. Harvard Medical School4, Harvard University, Boston, MA, USA. This pilot study examined the effects of partial sleep deprivation on the daily rhythm of salivary cortisol in young women across a range of Body Mass Index (BMI) values. Twelve healthy women (ages 18-25; BMIs 18.3-51.9) spent 3 nights and 2 days at the Chronobiology Laboratory at the QEII HSC. During the first 2 nights (Habituation and Baseline), participants were permitted to sleep for up to 10 h. During the third (Experimental) night they slept for 3 h (05:00-08:00). Saliva samples were collected every 2 h from waking to 21:00 during Baseline and Experimental days. The participants also completed inventories assessing mood and cravings for various food groups at the end of each day. Sleep loss elevated afternoon/evening cortisol levels relative to baseline and attenuated the normal morning peak in salivary cortisol levels. Changes in cortisol patterns were not associated with BMI scores. There was an association between increased evening cortisol levels after sleep deprivation and increased hunger on the Experimental day, elevated cravings for most food groups, and lower mood. There was also an association between elevated evening cortisol on the Experimental day and time since the end of menses. These are the first reported effects of sleep loss on cortisol rhythms in women.},
}

@inproceedings{fawcett2008start,
  title = {Start Forgetting or Stop Remembering? Commonalities Between Directed Forgetting and Stop-Signal Inhibition},
  author = {Fawcett, Jonathan M. and Taylor, Tracy L.},
  booktitle = {34th Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2008},
  abstract = {By combining an item-method directed forgetting paradigm with a stop-signal task, the current study explored commonalities between directed forgetting and stop-signal inhibition. Following each study phase memory instruction, the current study presented a centralized green circle (Go-Signal) requiring a speeded detection response that was sometimes replaced by a red circle (Stop-Signal) cancelling that response. Although stop-signal reaction times were not affected by the preceding memory instruction, an instruction to Forget did facilitate stopping by delaying responses. These findings provide support for the view that intentional forgetting is an active cognitive process.},
}

@inproceedings{radu2009identifying,
  title = {Identifying Risk of Obstructive Sleep Apnea in a General Population using the Berlin Questionnaire, the Sleep Apnea Scale of the Sleep Disorder Questionnaire, and Polysomnography},
  author = {Radu, Luiza and Lau, Esther and Eskes, Gail},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Obstructive Sleep Apnea (OSA) is a common sleep disorder which has been linked to serious health issues, cognitive disabilities and driving risk, but is often under-diagnosed in adult populations. The Berlin questionnaire (BQ) and the Sleep Apnea scale of the Sleep Disorders Questionnaire (SA-SDQ) are screening tools used for identifying persons at risk for OSA, although validation studies using lab polysomnography in healthy populations are limited. We examined how well the BQ and the SA-SDQ predicted the presence of sleep apnea in a group of healthy individuals (n=34), with no previous history of sleep disordered breathing. Individuals (ages 33 to 85, 13 Males, 21 Females) were assessed for risk of OSA using the BQ and SA-SDQ followed by overnight in-laboratory polysomnography. Sleep apnea was defined by the Respiratory Disturbance Index (RDI; number of breathing disruptions/hour) and designated as mild (RDI = 5-15; 9 individuals) or moderate (RDI > 15; 7 individuals). Of those 16 with OSA symptoms, four were designated as OSA risk by the BQ. Additionally out of the 18 individuals with no OSA symptoms (RDI < 5), 14 were considered to be at a low risk for OSA by the BQ. These findings indicate that the BQ has low sensitivity. Our analysis further showed that the SA-SDQ was not an accurate predictor for sleep apnea (RDI > 5). Recommendations for BQ and SA-SDQ use will be discussed.},
  note = {Poster},
}

@inproceedings{moon2009case,
  title = {A Case Series Evaluation of a Manualized Treatment Program for Sleep Problems in Children with Autism Spectrum Disorder},
  author = {Moon, Erin and Corkum, Penny and Smith, Isabel},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {A preliminary investigation of the effectiveness of a manualized behavioural sleep intervention program for children with was conducted with three participants (2 males; 1 female; aged 8-9 years) with autism spectrum disorder (ASD) and dyssomnia. The primary objective of the program was to reduce sleep onset latency. The intervention consisted of a treatment handbook for parents; a distance treatment approach was used in which parents had weekly telephone contact with a trained facilitator. Within a case series design, both subjective (parent-report questionnaires and sleep diaries) and objective (actigraphy) measures were used to record changes in children's sleep and daytime behaviour. For all three children, mean sleep onset latency was reduced substantially following the intervention. These improvements were maintained after 12 weeks, providing initial support for the effectiveness of this intervention program.},
  note = {Poster},
}

@inproceedings{ryan2009effects,
  title = {The Effects of Prism Adaptation on Recovery of Functional Skills in Unilateral Neglect Patients - A Proposal},
  author = {Ryan, Matthew and Klein, Ray and Eskes, Gail},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Right Hemisphere stroke patients often present with Unilateral neglect, characterized by rightward bias in eye, head, and hand movement, and deficits exploring the left hemi-space. Prism adaptation has shown promise for uncovering neglect's underlying mechanisms and ameliorating spatial deficits. Patients wear goggles shifting vision rightward, then undergo leftward visuo-motor compensation while pointing at visual targets. Following adaptation, enduring improvements have been found in tests of neglect and spatial attention. Evidence for prism adaptation's efficacy in recovering activities of daily living is sparse. Experiments addressing improvements in this area have been anecdotal reports, shown null effects, and were small sample or case studies without control groups. The proposed study will assess Prism Adaptation's effect on a validated index of daily life activities by comparing two groups neglect patients: one receiving adaptation versus a control group. It is hypothesized the adaptation group will show greater progress in recovering functional skills.},
  note = {Poster},
}

@inproceedings{ouellette2009determining,
  title = {Determining the Existence of Separate Neural Networks for Static and Dynamic Facial Expression via Embodied Simulation},
  author = {Ouellette, Nicole and Hamon-Hill, Cindy and Barresi, John},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {This study attempted to give a behavioural correlate to recent neurological evidence for separate neural networks for processing of static and dynamic facial expressions. Ninety-six adults were engaged in an emotional recognition task. A dissociation of neurological processing was tested by utilizing a non-invasive behavioural procedure, which engaged the cortico-bulbar pathway, to interfere with embodied simulation. It was hypothesized that the static stimuli, relying on more motor mimicry along the cortico-bulbar route for an affective representation of the emotional state, would result in decreased performance (accuracy and reaction time) on the emotional recognition task. Dynamic stimuli, relying on a separate, extrapyramidal pathway for an affective representation of the emotional state, would not be affected. The results of this study support separable processing of static and dynamic stimuli. These findings highlight an important distinction between processing of static facial expressions and their more ecologically valid dynamic counterparts.},
  note = {Poster},
}

@inproceedings{davidson2009changes,
  title = {Changes in Circadian Rhythm Evident During an Acute Randomized Placebo-Controlled Trial of Methylphenidate},
  author = {Davidson, Fiona and Ironside, Sarah and Corkum, Penny},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Attention-deficit/hyperactivity disorder (ADHD) is a highly prevalent disorder in school-aged children. Stimulant medications are commonly used to treat ADHD, however, it has been suggested that they may alter the timing or regularity of circadian motor activity levels. The current project aimed to investigate the impact of stimulant medication on circadian rhythms in children with ADHD. Twenty medication-naïve children with ADHD were monitored for changes in motor-activity during a blinded placebo-controlled medication trial to examine the impact of immediate-release methylphenidate hydrochloride (MPH-IR). Motor activity was measured by actigraphy and activity profiles were analyzed to identify changes in circadian rhythms. MPH-IR was related to a measurable phase-delay in the timing of the daily rhythm and was found to increase night-time motor activity during sleep-onset latency. In this sample, strong and stable daily rhythms over each week of the medication trial were observed. Children taking MPH-IR have been found to experience prolonged sleep-onset latency.},
  note = {Poster},
}

@inproceedings{allen2009testing,
  title = {Testing the Existential Alienation Model: A Cross-sectional Study in an Undergraduate Sample},
  author = {Allen, S. and Graham, A. and McGrath, D. and Breen, E. and Tonet, J. and Sherry, D. and Stewart, S. and Sherry, S.},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Research suggests persons high in socially prescribed perfectionism (SPP; i.e., perceiving others are demanding perfection of oneself) are at risk for depressive symptoms. The present study examines mechanisms believed to explain the SPP-depression relationship. Specifically, the present study tests the Existential Alienation Model (EAM). This model hypothesizes that SPP contributes to cognitive dysfunction (e.g., catastrophic thinking) and to existential problems (e.g., difficulty accepting the past) which, in turn, contribute to depressive symptoms. To test these hypotheses, a cross-sectional study was conducted wherein undergraduates completed self-report measures assessing SPP, catastrophic thinking, difficulty accepting the past, and depressive symptoms. Path analyses provided support for the EAM such that catastrophic thinking and difficulty accepting the past mediated the relationship between SPP and depressive symptoms. Persons high in SPP may be vulnerable to depressive symptoms because they experience catastrophic thoughts about everyday events and encounter difficulties making sense out of their experiences.},
  note = {Poster},
}

@inproceedings{chu2009spontaneous,
  title = {Spontaneous Nav1.6 Rescue (snr): Discovery of a Modifier Allele that Attenuates the Motor Phenotype in a Voltage-Gated Sodium Channel Mutant},
  author = {Chu, Leona and Smith, Ben and Cote, Patrice},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The voltage-gated sodium channel Nav1.6 is concentrated at the nodes of Ranvier in central and peripheral neurons and is important for the propagation of the nerve impulse. Mice with a mutation in Nav1.6 are born normal but quickly deteriorate due to muscle weakness and paralysis. These mice are termed dmu (degenerating muscle). Here we report the discovery within our colony of dmu mutants of mice that do not display this motor phenotype. We have called these mice snr for spontaneous Nav1.6 rescue. These mice do however have abnormal electroretinogram (ERG) tracings that are identical to the ones typically seen in dmu mutants. These findings suggest that an independent gene affects the severity of the motor phenotype. Purpose: To characterize snr, a recently discovered spontaneous mutation within the dmu Nav1.6 mutant mouse strain. Methods: First, the genotype of dmu mutant mice is determined. Homozygous snr mice are then identified based on their phenotype and ERG measurements. ERG measurements will be performed at developmental stages to determine retinal morphology changes associated with age. Preliminary work were made in behavioral monitoring, sensorimotor coordination, overall motor function, and sensorimotor integration focusing on hindlimb function. Results: Data gathered from these experiments indicate that there is a rescue of the snr motor phenotype without recovery of visual acuity. Conclusions: Initial results strongly suggest that snr mice are a new substrain within the dmu mouse strain. Further genetic characterization of both dmu and snr mice will reveal the mode of inheritance of this new modifier allele.},
  note = {Poster},
}

@inproceedings{green2009expressions,
  title = {Expressions of CRH in Postnatal Rat Pups: Sex Differences in the Development of the HPA Axis},
  author = {Green, Amanda and Perrot-Sinal, Tara},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The importance of circulating gonadal hormones in adult stress responding has been well documented. However, little research has focused on the role of early life gonadal hormones in permanently organizing these dimorphisms. In rodents, the early postnatal period is critical for the sexual differentiation of the brain, and is also a time of plasticity in the developing stress system; thus, significant interactions between the two processes may occur. This study focuses on the developmental timeline of corticotrophin releasing factor (CRF) across early postnatal development in brain regions associated with the HPA axis, including the PVN, BNST, CeA and hippocampus. Preliminary results suggest a role of both sex and age in the number of CRF-ir neurons in the PVN, CeA and hippocampus. This research may contribute to our understanding of "normal" HPA axis development, as well as how/why early life stressors might disrupt HPA axis function in a sex-specific manner.},
  note = {Poster},
}

@inproceedings{gadbois2009wildlife,
  title = {Wildlife Conservation Canines in Kejimkujik National Park},
  author = {Gadbois, Simon and Flannery, Meredith and Austin, Deborah},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Conservation canines have been used for decades to find endangered or threatened species in the wild. Dogs have been used to find a wide range of species at risk. Together with Parks Canada, we are interested in using dogs to find Eastern Ribbonsnakes and Pine Martens in Kejimkujik National Park. Both species will benefit from accurate population density information and habitat use data. Our lab brings a synthetic and integrative approach to the use of canines in the field and the lab: knowledge of the wildlife habits and physiology of the target species and knowledge of animal learning principles and animal psychophysics. We are interested in field applications, methodologies and training techniques, including approaches never used with scent detection canines. Two main training techniques (errorless discrimination training and traditional discrimination training) will be compared. Once we demonstrate the effectiveness of our methodology, we may expand this work to other local and problematic species.},
  note = {Poster},
}

@inproceedings{gawryluk2009white,
  title = {White Matter fMRI in the Corpus Callosum},
  author = {Gawryluk, J. and Mazerolle, E. and Dillen, K. and Brewer, K. and Beyea, S. and D'Arcy, R.},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Although most fMRI studies restrict their focus to gray matter, an increasing number of studies have observed white matter (WM) activation. Our group recently reported the first prospective WM fMRI studies at 4T using interhemispheric transfer tasks. The initial study used a visual word/face task, which elicited activation in the isthmus of the corpus callosum. A subsequent study used optimized WM fMRI using an asymmetric spin echo (ASE) spiral imaging sequence and a visual-motor checkerboard task, which elicited activation in the anterior corpus callosum. The current study examined whether varying task type differentially activates WM within the same subjects, thereby allowing for the assessment of functional differentiation in the corpus callosum. The results show corpus callosum activation for both tasks, with location of activation varying according to task type. These findings provide further support for WM fMRI which may lead to advanced clinical applications for WM disorders such as multiple sclerosis.},
  note = {Poster},
}

@inproceedings{mcglone2009developing,
  title = {Developing a Comprehensive Measure of Perceived Stigma for Use with Literate Adults who have Epilepsy},
  author = {McGlone, Jeannette and Lee, Kaitlyn and Pohlmann-Eden, Bernd and Sadler, Mark and Gillespie, Jacqueline},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Perceived stigma has been associated with poorer self-management of seizures, lower quality of life, and negative psychosocial consequences in persons with epilepsy. Measuring level of perceived stigma in epilepsy is critical because of its high prevalence (~50%) and potential for intervention. One available instrument, the Felt Stigma Scale (Jaccoby, 1994) has good internal reliability and cross cultural applications, but its properties of brevity (only 3 items), one dimensionality, and being interview-based all limit application in treatment studies. This project adapts two new measures derived from the mental health literature for use with persons diagnosed with epilepsy. The Stigma Scale (TSS; King et al., 2007) and the Internalized Stigma of Mental Illness scale (ISMI; Ritsher, Otilingam, & Grajales, 2003) were selected because of their length, multidimensionality, strong psychometric and conceptual properties. Each contains a subscale that measures thriving despite adversity, hence we examined if those subscales correlated significantly with the total stigma score or with a traditional measure of Resilience. The results are promising.},
  note = {Poster},
}

@inproceedings{phelan2009relationship,
  title = {Relationships between Memory Performance and Intellectual Ability in Autism Spectrum Disorder},
  author = {Phelan, Heather and Filliter, Jillian and Johnson, Shannon},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Previous studies have found that individuals with Autism Spectrum Disorder (ASD) experience some difficulties with learning and memory, particularly the use of mnemonic strategies. Proponents of the Task Support Hypothesis assert that, when external supports are provided, individuals with ASD perform more similar to typically developing peers (Bowler et al., 1997). We administered the California Verbal Learning Test, Children's Version (CVLT-C) to 14 high-functioning youth with ASD and 14 matched controls. The control group had a significantly steeper learning slope and significantly higher total recall than the ASD group. For the ASD group, but not controls, recall performance improved significantly from free recall to cued recall, providing further support for the Task Support Hypothesis. Correlational analyses suggested significant associations between better performance and higher IQ for the ASD group. Findings indicate that task support, along with a higher IQ, is related to memory performance in children and adolescents with ASD.},
  note = {Poster},
}

@inproceedings{hamonhill2009disrupted,
  title = {Disrupted Embodied Simulation while Judging Appropriateness of Facial Emotion to Context},
  author = {Hamon-Hill, Cindy and Barresi, John},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {By having participants hold or bite a pen in their mouth for two of four blocks of trials, we tested whether inhibition of or interference with embodied simulation would affect one's accuracy for judging when a target's facial expression was appropriate to context. Dynamic facial displays of 4 targets were individually paired with images to which they were responses (match) or paired with other images (mismatch). Participants holding the pen improved on mismatch trials and worsened on match trials. Participants biting the pen performed better initially than hold participants on mismatch trials and did not exhibit a reversed pattern of accuracy. These results are indicative of a disruption in normal embodied simulation. The typical process of matching the emotional state of self to other may be disrupted when embodied simulation is interfered with. Due to the motor activation with the pen, the mismatched state of the self to given contexts may influence searching for a mismatch state in other.},
}

@inproceedings{wilson2009about,
  title = {An About-Face in Lie Detection: An Investigation of Spontaneous and Posed Facial Expressions},
  author = {Wilson, Kevin and Schellinck, Heather},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Facial deception research is frequently applied to high-stakes security and forensic settings; however, the breadth and quality of the field is limited. Recent studies have asked participants to pose facial expressions while viewing emotional images, assuming that this technique is analogous to examining spontaneous expressions. In this investigation, we attempted to elicit spontaneous facial reactions with commonly used visual stimuli, and compared them to posed expressions. Spontaneous reactions were rare. In a second experiment, we modified the stimuli by simultaneously presenting emotional images and sounds. The majority of participants demonstrated spontaneous facial expressions, which they were unable to conceal when instructed to do so. Our findings suggest that existing stimuli are inadequate for facial deception research, and that supplementing posed for spontaneous expressions conceals some cues to deception.},
}

@inproceedings{mitchell2009test,
  title = {A Test of Explanations for the Preference of Concordant Binocular Visual Experience in Early Visual Development},
  author = {Mitchell, Donald and Kennie, Jan},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Kittens that receive mixed early visual experience comprised of adjacent episodes of normal (binocular) and abnormal (monocular) visual exposure show a decided preference for the former. So long as about 30% of the total visual experience is normal, animals develop both normal visual acuity in both eyes and cortical architecture in terms of the dimensions of ocular dominance domains in V1. We tested whether this preference for binocular exposure arose because it matched the cortical architecture that existed at the time that mixed visual exposure was first imposed. To test this idea we induced an abnormal early cortical architecture by monocularly depriving animals from near birth so that now, at the time that mixed visual exposure was initiated, monocular exposure was the closest match to the existing cortical architecture. However, despite the match to the cortical architecture, monocular exposure did not appear to be preferred; indeed short daily episodes of binocular exposure were still very effective.},
}

@inproceedings{shaw2009lateral,
  title = {Lateral Adaptation Pooling in the Vision of White-Eyed Flies},
  author = {Shaw, Stephen},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {In insect eyes, convention holds that the ON- and OFF transient waves of the electroretinogram (ERG) come from first-order interneurons, lamina monopolar cells (LMCs): these occupy the position of bipolar cells in the vertebrate retina. Ease of recording the ERG has led to its resurgence as a diagnostic tool for understanding synaptic transmission in the model organism, Drosophila. The presence of ERG transients is used to assay whether the first synapse in the eye is working, in genetic rescue missions. These transients cannot come from the LMCs, however: one suggestive piece of evidence is that the transients are involved in extensive lateral adaptational pooling. This is believed not to be a property of LMCs, thought to be strictly local processors. The structure of the eye predicts that a LMC wave ought to be present in the ERG: a contender wave has been detected, but is small and hard to isolate in normal flies. White-eyed mutant flies are missing both of the eye's two main screening pigments, and light rays entering from a narrow angle experience increased internal scatter. Correspondingly, the mutant eye discloses a larger, more easily measured version of the supposed LMC wave. Surprisingly, tests show that this wave too is subject to lateral adaptational interactions, though nothing like this has been detected so far in direct intracellular recordings from LMCs. This discrepancy might be resolved if lateral interaction acted presynaptically at the level of the photoreceptor terminals via amacrine cells, before these release their neurotransmitter to activate the postsynaptic LMCs.},
}

@inproceedings{butcher2009ultrastructu,
  title = {Ultrastructure and Synaptic Characteristics of Neurons of the Mushroom Body Calyx in Drosophila Melanogaster},
  author = {Butcher, Nancy and Meinertzhagen, Ian},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Synaptic circuits form the functional basis of behaviour. To understand behaviour, we must first investigate the wiring and properties of neurons in these circuits. The fruit fly Drosophila provides an excellent genomic species to study neural circuits because it has a relatively simple nervous system and generates readily quantifiable behaviours. The mushroom body (MB) is a high-order integrative centre of the insect brain, which in Drosophila is required for olfactory learning and memory. The input neuropil, the MB calyx comprises three types of neurons: projection neurons (PNs) from the antennal lobe; Kenyon cells (KCs) intrinsic to the MB; and extrinsic neurons (ENs) from various sources. Using serial-section electron microscopy, we have characterized the morphology of these elements from computer 3-D reconstructions, and their synaptic organization. We find that each PN terminal bouton forms twenty or more output synapses per KC, and confirm that KCs have claw-shaped dendritic endings which encircle the PN bouton. The KC dendrites and PNs also receive inputs from EN elements, and ENs also receive occasional inputs from PN terminals. Thus PN and EN elements connect reciprocally. We also find evidence for extensive connections between ENs. The implications of these findings will be discussed.},
}

@inproceedings{easy2009from,
  title = {From DNA to Protein - the Cricket's Tale: Part One},
  author = {Easy, Russell},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Molecular and proteomic approaches can provide information on the cellular responses to stressful stimuli. Genetics can identify novel genes while a proteomic approach can identify proteins that play a role in an animal's stress response. We have used these methods to identify the presence/absence of receptors to the neurohormone octopamine in the tissues of the cricket (Gryllus texensis). Octopamine plays a critical role in the cricket's stress response. Once we identify the target tissues in the insect's immune system (eg. fat body, haemocytes) we will test for changes in protein expression following physiological challenges. We will use this information to explore how and why stress alters immune function.},
}

@inproceedings{mitchell2009cecilia,
  title = {Cecilia, You're Breaking My Heart!},
  author = {Mitchell, Donald and MacNeill, Katelyn and Kennie, Jan},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {We have previously documented severe deficits of global motion perception in kittens that are binocularly deprived of vision in the first 6 weeks. In addition, we have noted informally, an apparent deficit in their ability to follow the motion of laser pointer lights. To explore this quantitatively we have exploited robotic technology with the assistance of North Knight Software to construct CECIL (Cat Entertaining Computer Instructed Laser). We will recount our attempts to train cats to follow moving laser spots using Cecil (at first they appeared as interested as students in a class listening to an account of The Principle of Univariance in relation to colour vision). In addition we will explain our ideas with respect to the existence of possible critical periods for combining the perception of motion with action.},
}

@inproceedings{white2009biological,
  title = {Biological Motion Perception: An ERP Study on the Functional Role of the N300 Component},
  author = {White, Nicole and Fawcett, Jonathan and Newman, Aaron},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Previous event-related potential (ERP) studies of biological motion perception have identified two ERP components reliably observed in response to point-light stimuli: the N170 and the N300. The N300 has been hypothesized to reflect neural processing specific to biological motion, but in a recent study, static point-light stimuli were found to elicit an N300 component similar to that of biological motion. Thus, it is unclear this component indexes recognition of the human form, or processing of biological motion information. In order to further clarify the role of the N300 component, ERPs were recorded from 24 subjects while viewing three types of point-light stimuli: static point-light frames, stick figures, and classic biological motion. The N300 component was elicited in response to both static frames and stick figures, as well as to biological motion. The amplitude of the N300 was affected similarly by inversion and scrambling across all three stimulus types, indicating that the brain processes these stimuli in the same way. We therefore suggest that the N300 component indexes human form recognition and is not specific to biological motion.},
}

@inproceedings{trerice2009pointing,
  title = {Pointing Right to See Left},
  author = {Trerice, Andrew and Ishigami, Yoko and Ryan, Matthew and Radu, Luiza and Eskes, Gail},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Visuomotor adaptation to a prism-induced lateral displacement of the visual field to the right has been found to improve symptoms of spatial neglect due to right hemisphere damage. Whether the positive effect is based on bottom-up visuomotor plasticity or on top-down spatial representations is unclear, however. We tested a patient with neglect due to damage to subcortical regions (primarily basal ganglia), on a series of tests of perceptual or visuo-motor bias. These measures were administered before and after the patient adapted to a prism-induced rightward visual shift. Despite visuo-motor adaptation as verified by a midline pointing test, performance on tests of neglect was generally unchanged. Outcome measures included star cancellation, landmark, chimeric faces, temporal order judgment, and visual search tasks. The specific pattern of results will be discussed in relation to previous studies.},
}

@inproceedings{saintaubin2009letter,
  title = {Letter Names and Alphabet Book Reading by Senior Kindergarteners: An Eye Movement Study},
  author = {Saint-Aubin, Jean and Evans, Mary Ann},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {In this study, we monitored eye movements of 20 five-year-old children while reading an alphabet book to examine the manner with which the letters, word, and pictures were fixated and the relationship of attention to print to alphabetic knowledge. Children attended little to the print elements, took longer to first fixate print than illustrations, and labelled fewer letters than they did when presented with letters in isolation. After controlling for scores on a receptive vocabulary test, regressions revealed that children knowing more letters were quicker to look at the featured letter on a page, and spent more time looking at the featured letter, the word, and its first letter. Thus alphabet books along with letter knowledge may facilitate entrance into the partial alphabetic stage of word recognition.},
}

@inproceedings{harris2009inhibition,
  title = {Inhibition of Return for Vertically-Directed Saccades},
  author = {Harris, Jonathan and Westwood, David and Cowper-Smith, Chris},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {A great deal of research has examined IOR for saccades that are parallel with the horizontal but not vertical meridian. Thus, we used a saccade-saccade paradigm to investigate potential differences in the magnitude of IOR between the horizontal and vertical axis. In each trial, participants made two saccades in response to either endogenous or exogenous signals (S1 and S2). Gaze was returned to centre between S1 and S2. Trials were further characterized by S1 direction (left, right, down, or up) and S2 direction relative to S1 (same or 180° opposite). Our results show that within the horizontal axis, IOR was present and did not differ in magnitude between right and left. For the vertical axis, IOR was revealed for saccades made in response to downward but not upward S2s. These results are interpreted in the context of differences in visual search/spatial attention between upper and lower visual field.},
}

@inproceedings{sparks2009children,
  title = {Children's Spelling of Vowel Sounds: The Use of Morphological Strategies},
  author = {Sparks, Erin},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {English orthography encodes both phonological and morphological information, necessitating the use of multiple spelling strategies. The phonological quality of vowels depends in part on lexical stress patterns; vowels in stressed syllables are phonologically salient, whereas vowels in unstressed syllables reduce to the toneless phoneme schwa. Morphological derivations offer an additional source of vowel spelling information when the addition of a suffix to a stem word drives a lexical stress shift (and consequently changes the phonemic vowel quality; MAjor-maJORity), making the use of the relationships between words a potentially helpful spelling strategy. This talk will offer evidence for a trend toward children's use of the information provided by morphological manipulation when spelling unstressed vowels, as well as a planned research that will clarify whether children independently employ this strategy, and whether a simple intervention can facilitate its use.},
}

@inproceedings{deacon2009double,
  title = {Double or Nothing: Children's Integration of Letter- and-Meaning-Patterns in Spelling},
  author = {Deacon, Hélène and Leblanc, Diane and Sabourin, Chantal},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Learning to spell in English can be challenging because there are several levels of regularities. As an example, long and short vowels in English are, respectively, spelled with a vowel followed by a consonant singlet and doublet (e.g., diner and dinner). This letter-pattern regularity sometimes conflicts with meaning patterns, through which the spellings of root words are often, but not always, retained in related forms (such as dine - diner, but knit - knitter). The present experiment is designed to determine the relative influences of these two sources of information on children's spelling. We found that children's sensitivity to letter-patterns emerged early and was very robust, but, by grade 2, their sensitivity to meaning-patterns emerged in a manner that sometimes lead them to errors. This intriguing pattern of results will be discussed.},
}

@inproceedings{massoud2009binaural,
  title = {Binaural Integration in Asymmetric Hearing Loss},
  author = {Massoud, Sarah and Aiken, Steve and Newman, Aaron},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {It remains unknown whether the failure of binaural integration in patients with asymmetric hearing loss is primarily governed by the absolute hearing threshold in the more severely impaired ear or by the level of asymmetry between the two ears. In order to tease apart these causes, this study characterizes binaural integration as a function of interaural level difference in controls. ASSR recordings were made while participants listened to short blocks of Gaussian noise with an interaural correlation (IAC) alternating between 0 and +1 at 4 Hz. Stimuli were presented with sound levels varying in asymmetry from 0-40 dB with reference levels of 80, 60, and 40 dB. Significant neural responses at 4 Hz and 8 Hz indicated that binaural integration occurred at almost every level of asymmetry. Main effects of asymmetry or reference level were seen only on 8 Hz responses. Binaural integration appears to break down around an interaural asymmetry of 40 dB.},
}

@inproceedings{mazerolle2009classificati,
  title = {Classification of Keystroke Dynamics},
  author = {Mazerolle, Erin and Marchand, Yannick and Keselj},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Developed mainly to improve password security, keystroke dynamics is a biometric technique aimed at identifying users on the basis of their typing patterns. Features such as the time between key presses are inputted into machine learning, data mining, and/or pattern recognition algorithms in order to develop classifiers that can identify a genuine user versus an imposter. Another potential, but as of yet unexplored, application of keystroke dynamics is the study of psycholinguistics. As a first step, this study will evaluate whether word features (e.g., word frequency) can be identified on the basis of keystroke dynamics. An existing algorithm for classifying users will be implemented and modified in order to classify words on the basis of their linguistic features. This work will provide insight into the mechanisms of typed language production, which is important given the increased prevalence of computer-based communication.},
}

@inproceedings{christie2009introduction,
  title = {An Introduction to Statistics in R},
  author = {Christie, John and Lawrence, Mike},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {R is free computer software that can be used for everything from very simple to the most advanced data analysis. It is the language of statisticians. This will be a live tutorial of where to get started using R. It will begin with addressing the reasons you should use R. Advice on how to learn about the software as a user rather than as a programmer or statistician will follow. I will present some demonstrations of the simplicity and ease of use for basic analysis and visualization of data. This is everything you need to get started with R. See the next talk for more advanced capabilities of R.},
}

@inproceedings{lawrence2009psychology,
  title = {R for Psychology: A Live Demonstration},
  author = {Lawrence, Mike and Christie, John},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {This will be a live demonstration of using R for the analysis and visualization of data. Prepare to be impressed with how a free piece of software with a simple interface can address your need to understand your data. Please attend the prior talk for an introduction to R first.},
}

@inproceedings{phillips2009models,
  title = {Models of Spatial Hearing Mechanisms in Man},
  author = {Phillips, Dennis and Hall, Susan},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {There are two models of the neural mechanisms serving sound localization in the horizontal plane. One is based on a population of neural channels, each of which is narrowly tuned to its own particular azimuthal range, and is independently responsible for indicating the presence of a stimulus in that range. The second model assumes the existence of only two, hemifield-tuned channels, and it is the relative activity of these two channels that specifies source location. We present our recent psychophysical evidence that distinguishes which of these models is active in man.},
}

@inproceedings{dingle2009frontal,
  title = {A Frontal Channel in Human Spatial Hearing?},
  author = {Dingle, Rachel and Hall, Susan and Phillips, Dennis},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {While the discovery of an organized, topographical map of auditory space in the barn owl popularized the 'multi-channel' model of sound localization, this model fails to generalize to other animals. We now have compelling evidence that mammalian sound localization, at least in the horizontal plane, is based on the relative activity of two populations ('channels') of neurons that are broadly-tuned to contralateral auditory space. However, there is also some evidence from physiological realms that a third, 'frontal' channel exists, made up of neurons that respond to sounds situated at the auditory midline. Here we present a simple psychophysical task designed to probe the existence of this frontal channel.},
}

@inproceedings{kiefte2009auditory,
  title = {Auditory integration of temporally desynchronised channels in speech perception.},
  author = {Kiefte, Michael},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Although speech perception is highly robust in the face of temporal distortion, strong claims have been made regarding the importance of preserving low-frequency modulations (e.g., 3-8 Hz) for accurate speech perception. For example, local time reversal in the order of 250 ms results in a severe drop in intelligibility [e.g., Saberi and Perrott (1999), Nature, 398, p.760]. This study examines the perception of stimuli that were processed by four 1/3-octave filters, the outputs of which were desynchronized by a series of fixed delays. Intelligibility was found to be dependent on both speech rate and degree of temporal distortion. One possible explanations for this is that, when bands are desynchronized, integration across bands results in perceptually errors. However, perceptual segregation may also occur at very long delays resulting in two separate percepts which may explain the recovery of intelligibility at such delays. Several further experiments were conducted to test this hypothesis. It was found that, when the fundamental frequency was different in different bands, there was a relatively small reduction in intelligibility with increase in across-band asynchrony. However, if the fundamental frequency was flattened to a constant monotone for all bands, intelligilibilty decreased precipitously with increasing across-band asynchrony and there was no recovery for long delays. The results of these experiments suggest that the intelligilibility of sentences distorted in this manner depends critically on listeners' ability to integrate spectral information across channels and that the relationship between temporal distortion and the range of low-frequency modulation rates in speech is spurious.},
}

@inproceedings{wilson2009auditory,
  title = {Auditory Spatial Attention in Cochlear Implant Recipients: An ERP Study},
  author = {Wilson, Ryan and Roberts, Janet and Bance, Manohar and Newman, Aaron},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The success of cochlear implant (CI) surgery to treat hearing impairment is quite variable, particularly in post-lingually deaf adults. The current study investigated how well individuals with CIs can allocate auditory spatial attention in the context of competing stimuli, relative to normally hearing controls. We compared the event-related brain potentials (ERPs) of adult cochlear implant recipients with normally hearing controls during a "swinging story" task. Two stories were presented simultaneously from different speakers located to the left and the right of the participant respectively. Every 30-90s the stories switched location and participants had to maintain attention to one story. Linguistic probes ("ba" and "da") were presented from attended and unattended locations. ERP responses from 7 CI and matched control participants were compared for attended and unattended probes. We predicted that better auditory spatial attention ability would be associated with greater differences in N1 ERP amplitudes between attended and unattended probes.},
}

@inproceedings{cowpersmith2009motoric,
  title = {Motoric Inhibition of Return and the Coordination of Voluntary Arm and Eye Movements},
  author = {Cowper-Smith, Chris and Westwood, David},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The current view of motoric inhibition of return (IOR) depends critically upon the activation and subsequent inhibition of oculomotor processes. However, recent evidence suggests that skeletomotor activity can directly affect the magnitude of IOR. In order to address this possibility further, we analyzed the gradient of reaction times of consecutive voluntary arm and eye movements (E1: eye-eye; E2: arm-arm; E3: arm-eye; E4: eye-arm) that were offset by 0°, 45°, ±90°, 135°, or 180°. Participants fixated a central target that was surrounded by 8 equidistant peripheral targets. When signal 1 (S1; a directional arrow) was displayed at fixation, participants responded with a joystick or eye movement to the indicated target and then returned to centre. Signal 2 (S2) was delivered 1.5 seconds after the onset of S1 and required a second response (joystick or eye movement); this movement could be to the same target or any of the other targets. Our results show that different gradients of IOR occur depending upon the relative involvement of the eye and hand. These results are interpreted by positing that different task-specific forms of motoric IOR may operate to promote effective visual search and object interaction behaviours.},
}

@inproceedings{roberts2009brain,
  title = {Brain Activity following Cochlear Implant Treatment for Hearing Loss},
  author = {Roberts, Janet and Newman, Aaron},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Functional outcomes following cochlear implant (CI) treatment for hearing loss are variable in post-lingually deaf adults. Therefore, a greater knowledge about the effect of auditory experience on the processing abilities of the auditory system could have relevant applications in providing individualized treatments for hearing loss. Experiments testing congenitally deaf individuals have shown that deaf participants demonstrate a different pattern of neural activation in response to visual information than normally hearing control participants. The present study used the event-related potential (ERP) technique with a visual refractory period paradigm to see whether a similar effect was observed in CI participants with good and poor functional outcomes. Although no statistically significant group effects were found between CI and control participants, an interesting trend between the two groups of CI participants was observed, which provides additional motivation for recruiting more CI recipients in the future.},
}

@inproceedings{bilsbury2009origin,
  title = {On the Origin of Specious: Victorian Society and Galton Science},
  author = {Bilsbury, Tanya and Juckes, Tim},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Sir Francis Galton, the distinguished Victorian scientist, was a polymath to whom much is owed by many disciplines. Galton first distinguished himself as a geographer and tropical explorer; however, with the publication of Darwin's On the Origin of Species in 1859, he became almost exclusively concerned with heredity. Although Galton's work in this area produced firm contributions to science, such as the discovery of correlation and regression and the debunking of Darwin's theory of pangenesis, Galton often produced questionable science in which specious claims and spurious inferences trumped objectivity. These lapses in scientific judgment can be attributed to Galton's near-religious zeal for his theory of eugenics, which was presented as a scientific panacea for the issues faced by Victorian society. However, rather than changing the fundamental class structure of Victorian society, Galton's eugenics sought to improve the quality of individuals in the society, particularly those with what Galton deemed the greatest promise. While protecting and promoting the status and interests of the elite, eugenics also advocated removing supports from the lower classes. Galton's eugenics, and relatedly, his Procrustean treatment of data, make sense only in the context of his own place in Victorian society.},
}

@inproceedings{salmon2009speeded,
  title = {Speeded Object Recognition, Categorization, and the Influence of Object Manipulability},
  author = {Salmon, Joshua and McMullen, Patricia},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The time to name and recognize objects is influenced by whether or not the object is manipulable (graspable by one hand). In particular, non-manipulable objects are matched faster (in a picture-word matching tasks) than manipulable objects, when object familiarity is controlled for (Filliter, McMullen, & Westwood, 2005). The current study investigated whether or not the effect of manipulability would still be present when the Age of Acquisition (the age at which the vocabulary was acquired) was also controlled for. Participants were asked to categorize objects as manmade or natural. Identification was made more difficult with a backward mask, and short exposure durations (ED) of either 20ms or 100ms. Consistent with previous research, non-manipulable objects were categorized more quickly than manipulable objects (F(1,39)=12.451, p = .001). Objects shown at long ED (100ms) were categorized more quickly. Natural objects were also categorized more quickly than manmade objects. In addition, a significant three way interaction indicated that for natural objects the manipulability effect was only present at short EDs, but for manmade objects the manipulability effect was present at both EDs (F(1,39)=1.055, p = .042).},
}

@inproceedings{matheson2009specialized,
  title = {Specialized Visual Processes for Faces of Different Races},
  author = {Matheson, Heath and McMullen, Patricia},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {It is well established that people are better at recognizing faces of races they are more familiar with. In two studies we explore the visual processing differences between faces of different races. We employed 2 tasks that have been shown to elicit face-specific processing in the visual system and provide evidence that one, but not the other, is sensitive to experience with faces of different races. This suggests that disproportionate experience with faces of a single race leads to changes in specific face-processing mechanisms within the visual system, and provides evidence that memory for faces of different races is affected by differences in visual encoding.},
}

@inproceedings{wong2009assessing,
  title = {Assessing Response to Novelty as a Predictor of Risk-Taking and Reward Sensitivity in Outbred Mice},
  author = {Wong, Mike},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Animal models can help elucidate neurobiological etiologies of human addictive behaviour, as well as individual differences in addiction vulnerability. Locomotor response to a novel environment has been shown to be a reliable predictor of drug self-administration (SA) acquisition in rats, and is used to model a human personality trait associated with risk-taking. Rats showing high levels of activity in a novel environment, labeled high responders (HR), acquire SA to a variety of drugs more readily than rats with relatively lower levels of activity, or low responders (LR). HR rats show many physiological differences from LRs that may explain their propensity for drug seeking, namely high stress reactivity and mesolimbic reward pathway activity. Although mice are more commonly-used model organisms in genetics research than rats, the HR/LR model has not been adopted by mouse researchers. In order to determine whether the HR/LR model is suitable for use with mice, this study tested outbred CD-1 mice for some hallmark characteristics of HR and LR rats. The open field maze and elevated plus maze were used to assess locomotor response to novelty and risk aversion. Reward sensitivity was tested using a two-bottle sucrose preference test under free-feeding conditions and diet restriction stress. Thymus and adrenal glands were examined post-mortem for weight changes after the chronic diet-restriction stressor. Overall, the expected behavioural and physiological differences between HRs and LRs were not observed.},
}

@inproceedings{monaghan2009patterns,
  title = {Patterns and Predictors of Anxiolytic Diversion in Currently Prescribed Adults},
  author = {Monaghan, Tracy and McLarnon, Megan and Meisner, Jessica and Barrett, Sean},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Sedative and anxiolytic medications such as Ativan, Valium and Xanax are important for the treatment of anxiety disorders. However, the qualities which render these drugs useful may also contribute to misuse. Prescribed users diverting their medication to those without a prescription is one form of this abuse. The current study investigated the patterns of diversion in currently prescribed adults from Halifax Regional Municipality. Structured interviews and questionnaires detailed substance use and personality traits. Diverters differed from non-diverters in several important ways. Those who diverted were more likely to misuse their own prescription, mix medication with alcohol and receive diverted anxiolytics, stimulants or analgesics. Diverters further broke down to those who were motivated therapeutically or non-therapeutically. Non-therapeutic diverters were more likely to have used a greater number of lifetime substances and have higher sensation seeking scores. Findings could aid physicians with identification and prevention of those at greater risk to divert.},
}

@inproceedings{sherry2009perfectionis,
  title = {The Perfectionism Model of Binge Eating: A Short-Term, 4-Wave Longitudinal Study of Vulnerability, Pathoplastic, and Complication Effects},
  author = {Sherry, S. and Graham, A. and McGrath, D. and Breen, E. and Allen, A. and Tonet, J. and Sherry, D. and Stewart, S.},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Perfectionism is often considered central to binge eating. The Perfectionism Model of Binge Eating (PMOBE) hypotheses perfectionism is a vulnerability for binge eating, but not a complication (or consequence) of binge eating. The PMOBE also hypotheses perfectionism has a pathoplastic effect on binge eating by generating both pre-binge antecedents (e.g., interpersonal problems) and post-binge consequences (e.g., depressive affect) that maintain binge eating. A 4-wave longitudinal study involving a sample of 240 undergraduates was used to test these hypotheses. Participants completed self-report questionnaires once every 7 days for 4 consecutive weeks. Consistent with the PMOBE, vulnerability and pathoplastic effects were observed, but not complication effects. Perfectionism may represent a vulnerability for binge eating that encapsulates several core attributes of, or key concerns for, people who binge eat. Perfectionism may also have a pathoplastic effect on binge eating by generating pre-binge antecedents and post-binge consequences that prolong the course and influence the expression of binge eating.},
}

@inproceedings{mcglone2009emotional,
  title = {Emotional Intelligence and Epilepsy},
  author = {McGlone, Jeannette and Lee, Kaitlyn and Gillespie, Jacqueline and Pohlmann-Eden, Bernd and Sadler, Mark},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Two studies found that persons with average cognitive intelligence and long standing (> 20 years) temporal lobe epilepsy (TLE) displayed low average range emotional intelligence(EI). To investigate medical and non-medical contributing factors, the Bar-On Emotional Intelligence Questionnaire: Short Form was mailed along with measures of seizure frequency, severity, duration, perceived stigma, and resilience to persons whose epilepsy was either temporal lobe originating or not. The response rate was 37% (n = 27/73). Mean EI fell within the Average range (92.1, sd = 15.5). ANOVA revealed no effect of diagnosis (TLE vs Non TLE) or duration (mean = 11.9m, sd = 12.9). EI correlated significantly with seizure frequency (r = .6), severity (r = .6), perceived stigma (r = -.5) and resilience (r = .7). This sample experienced shorter durations and good outpatient management, i.e., medical factors that might enhance EI. Non-medical factors such as low perceived stigma and high resilience were linked to EI.},
}

@inproceedings{ishigami2009measuring,
  title = {Measuring the Components of Attention Across the Lifespan using the Attention Network Test (ANT)},
  author = {Ishigami, Yoko and Klein, Ray},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The Attention Network Test (ANT) measures the efficacy of the alerting, orienting, and executive networks. Ten sessions of the ANT (Fan et al., 2002, Callejas et al., 2005, or Rueda et al., 2004) were administered to younger children, younger adults, and older adults. Participants indicated the direction of a target (e.g., arrow), accompanied by congruent or incongruent distractors. The targets were preceded by visual or auditory cues. The results of the younger adults indicate that, despite some practice effects, all network scores remained highly significant even after nine previous sessions. The relatively poor reliability of network scores with one session of data rises to respectable levels as more data is added. The specific pattern of results of older adults and younger children will be discussed in relation to the younger adults' results.},
}

@inproceedings{hudsonellsworth2009selective,
  title = {Selective Control of Attention to Emotionally-Salient Stimuli},
  author = {Hudson-Ellsworth, Amanda},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Emotion regulation is essential for successful functioning in daily life. Along with influencing subjective experience and mental health, the ability to regulate emotions is crucial in interpersonal relations. Two key cognitive emotion control strategies have been identified: reappraisal and attention deployment. The latter of these techniques was the focus of the current study. As a means of affect regulation, attentional control involves consciously monitoring attention to emotion-evoking stimuli. The purpose of the current study was to objectively measure emotional inhibition by having participants complete a computerized action suppression task using three different cue valences. Relevant background material, study predictions, and preliminary data will be presented.},
}

@inproceedings{klein2009oculomotor,
  title = {Oculomotor Inhibition of Return (O-IOR)},
  author = {Klein, Ray},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Discovered by Posner & Cohen (1984) using a simple cue-target paradigm, inhibition of return (IOR) was originally conceptualized as an aftermath of orienting that discouraged attention and gaze from returning to previously attended locations and objects. Interest in IOR has grown steadily in the 25 years since it was discovered, partly because it is easy to study and partly because of its putative function as a foraging facilitator. Beginning with Taylor-Helmick's dissertation (Taylor, 1997) evidence has accumulated for two flavours of IOR: one flavour is elicited when the oculomotor system is tonically inhibited by the task requirement to remain fixated while the other flavour (Oculomotor-IOR) is elicited when the oculomotor system is engaged by some aspect of the task. Research from our lab, and others, focussing on the role of oculomotor processes in generating IOR and the effects of IOR, however generated, upon oculomotor processing, will be presented.},
}

@inproceedings{wojtowicz2009theory,
  title = {Theory of Mind and Anosognosia in Huntington's Disease},
  author = {Wojtowicz, Magdelena},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The clinical features of Huntington's disease (HD) include a broad range of motor, cognitive, and psychiatric symptoms; including chorea, cognitive impairment and gradual personality changes. In addition to these symptoms, Huntington's patients often demonstrate a lack of awareness regarding their own symptom severity (i.e., anosognosia). Research on anosognosia in HD has focused exclusively on self-report of motor symptom severity. However, diminished self-awareness may have a negative impact on a patient's ability to interact socially with family members and friends. In fact, behavioural symptoms such as social incompetence and psychiatric disturbances are reported to be more distressing than motor symptoms for patients and family members. The proposed study will examine the cognitive, psychological, and disease correlates of anosognosia in HD, as well as investigate the relationship between this phenomenon and theory of mind.},
}

@inproceedings{barresi2009forming,
  title = {On Forming a Concept of Person},
  author = {Barresi, John},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Human beings may be the only organisms capable of thinking of self and other in equivalent ways - as selves and persons. Most organisms think about their own activities differently than they do the activities of others. In a few large-brained organisms like chimps and dolphins they sometimes think of the activities of self and other in the same way. But, only humans think quite generally in this manner. In this talk I will trace the early development of this uniform concept of self and person and interpret it's meaning with respect to human social life and moral capacities.},
}

@inproceedings{johnson2009modeling,
  title = {Modeling Decision-Making Processes in Autism-Spectrum Disorders},
  author = {Johnson, Shannon and Filliter, Jillian and Pleskac, Tim and Queller, Sarah and Bryson, Susan and Smith, Isabel},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Mathematical models of complex cognitive tasks offer a powerful method for understanding atypical cognition and behaviour in clinical populations. In the current study, formal cognitive models of decision-making tasks (e.g., Iowa Gambling Task) were employed to examine the psychological and cognitive processes that underlie previously reported atypical decision-making performance in high-functioning children and adolescents with Autism Spectrum Disorders (ASD). Overall, task performance and mathematical modeling results converged to reveal a risk-averse decision-making pattern in the ASD group across tasks. These findings demonstrate a link between cognitive processes and core symptoms of ASD, including preference for sameness and aversion to change.},
}

@inproceedings{goodman2009relationship,
  title = {Relationships Between Executive Functions and Temperament in High-Functioning Youth with an Autism Spectrum Disorder},
  author = {Goodman, Laura and Baker, Jodie and Johnson, Shannon},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {In typically developing (TD) individuals, there are relationships between executive functioning (EF) and temperament. There is evidence for differences in EF and temperament in ASD, but associations have not been examined. Eleven youths with an ASD and 11 controls completed the Wisconsin Card Sorting Test (WCST) and Stroop Task. A temperament questionnaire was completed by the participant or a parent. We examined relationships between EF and attentional, inhibitory, and activation control. No group differences on EF performance were found. Compared to controls, temperament scores for the ASD group revealed less control of attention (t = -2.32, p < .05) and inhibition (t = -2.55, p < .05). For the TD group, better WCST performance was associated with more behavioural control of activation and attention. For the ASD group, better Stroop performance was related to higher behavioural inhibition scores. Understanding temperament in ASD may inform our understanding of variability in executive functions.},
}

@inproceedings{fawcett2009item,
  title = {Is Item-Method Directed Forgetting the Active Suppression of Rehearsal?},
  author = {Fawcett, Jonathan and Taylor-Helmick, Tracy},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {In an item-method directed forgetting task study words were presented, one at a time, each followed by an instruction to 'Rehearse' (R+), 'Not Rehearse' (R-) or 'Forget' (F). Reaction time (RT) was measured in response to visual (E1) or auditory (E2) detection probes presented 1400 ms, 1800 ms or 2600 ms following each instruction. RTs were longer following R- and F instructions than following R+ instructions; furthermore, participants subsequently exhibited greater yes-no recognition of R+ words than of R- or F words. These results support the notion that item-method directed forgetting is achieved by the active suppression of rehearsal.},
}

@inproceedings{thompson2009inhibition,
  title = {Inhibition in Item-Method Directed Forgetting: A Modification of the Independent Probe Technique},
  author = {Thompson, Kate and Taylor-Helmick, Tracy},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {The item-method directed forgetting paradigm has been widely used to experimentally assess the characteristics of intentional forgetting. The present study explores the involvement of inhibition after the instantiation of a Forget memory cue in directed forgetting. This was done by modifying the Independent Probe Technique developed by Anderson (Anderson & Spellman, 1995). In 3 experiments, the effects of inhibition were assessed by comparing memory for words that were semantically related to another study category (given the opposite memory cue) to words that were not semantically related to another study category. It was predicted that, if instantiation of a Forget memory cue caused inhibition of the word, this inhibition would spread to related words. Therefore, there would be decreased memory for R items that were related to F items compared to those R items that were not related to F items. Results are discussed.},
}

@inproceedings{lawrence2009chromometric,
  title = {Chromometric Explorations of Mind: Colour as an Index of Information Access and Accuracy},
  author = {Lawrence, Mike},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {This talk will summarize published and unpublished work employing a new chromometric approach to the measurement of information access and accuracy. Thus far this approach has been applied fruitfully to the study of visual working memory, attention, and the author will discuss proposals for further application to the study of directed forgetting.},
}

@inproceedings{tougas2009two,
  title = {Two Types of Manipulability and Their Effects on Picture-Naming and Picture-Word Matching},
  author = {Tougas, Michelle and McMullen, Patricia},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Object recognition studies have observed a manipulability effect wherein manipulable objects are slower to be named and matched than non-manipulable objects. These effects have been found with control for familiarity and manipulability. However, age of acquisition (AoA) has also been shown to have an effect on naming, and has not been controlled in previous studies. Previous studies also have not controlled for two aspects of manipulability: functionality and graspability. The current study conducted picture naming and matching tasks controlling for functional and graspable manipulability, familiarity and AoA. A manipulability effect was observed for graspable manipulability in the naming condition where highly manipulable objects were named more slowly. A reverse effect was found in both the naming and matching conditions for functional manipulability, where highly functional objects were named faster than less functional objects. These results support two different effects of manipulability on object processing and have implications for models of object recognition.},
}

@inproceedings{darcy2009what,
  title = {What's Up at NRC's Neuroimaging Labs},
  author = {D'Arcy, Ryan},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {This talk will provide an overview of activities and recent developments at NRC's Institute for Biodiagnostics (Atlantic). Basic and clinical research highlights involving human and animal MRI along with emerging EEG and MEG applications will be presented. 5:00 Closing Remarks 5:30 Dinner and Reception--2nd Floor Lounge},
}

@inproceedings{dukewich2009testing,
  title = {Testing the 'IOR as Habituation' Proposal using Stimulus Intensity},
  author = {Dukewich, Kristie and Lawrence, Mike and Klein, Ray},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Inhibition of return (IOR) is an effect whereby people are slower to respond to a target at a previously cued location compared to a target that is presented at a previously uncued location. Dukewich (2009) proposed that the IOR effect is a product of habituation based on repetitive spatial stimulation and outlined several predictions regarding the IOR effect that were based on the parametric characteristics of habituation. We tested the prediction, rooted in the habituation literature, that low-intensity stimuli would produce more IOR compared to high-intensity stimuli. Our results are not entirely consistent with the original prediction. Is there something wrong with our experiment? Is the prediction we have derived from the habituation literature incorrect? Or is the proposal simply disproved?},
}

@inproceedings{olthuis2009brief,
  title = {Brief CBT for High Anxiety Sensitivity: Effects on Implicit and Explicit Catastrophic Misinterpretations of Arousal Sensations},
  author = {Olthuis, Janine and Sabourin, Brigitte and Watt, Margo and Stewart, Sherry},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Anxiety sensitivity (AS) is a fear of anxiety and anxiety-related sensations (e.g., increased heart rate). This fear occurs because individuals with high AS tend to misinterpret and catastrophize these physiological sensations, believing that they can have serious physical, psychological, or social consequences. Research suggests that AS may be a cognitive risk factor for anxiety disorders. Past studies show that a brief cognitive behavioural therapy intervention, with a physical exercise interoceptive exposure component, is effective in decreasing AS in (non-clinical) high AS individuals. To better understand the mechanisms through which this intervention works, and the role played by catastrophic misinterpretation of anxiety-related arousal sensations, this study will test the effectiveness of this intervention in decreasing both AS levels and catastrophic misinterpretations (assessed implicitly and explicitly) of anxiety-related arousal symptoms. The research plan and expected findings will be presented. The results will help improve available interventions and prevention for anxiety disorder.},
}

@inproceedings{hartling2009testing,
  title = {Testing the Interpersonal Model of Health Anxiety: Interpersonal Neuroticism, Health-Related Worry, Health-Related Reassurance-Seeking, and Health-Related Alienation in Romantic Couples},
  author = {Hartling, N. and Doucette, S. and Fossum, K. and Hamilton, A. and Sutherland, S. and Sherry, D. and Stewart, S. and Sherry, S.},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {This study involves a preliminary test of two mediational models hypothesized in the Interpersonal Model of Health Anxiety (IMHA; Noyes et al., 2003; Sherry et al., 2008). According to the IMHA, health-related worry mediates the relationship between interpersonal neuroticism (i.e., anxious attachment and emotional instability) and health-related reassurance-seeking; and health-related reassurance-seeking mediates the relationship between interpersonal neuroticism and health-related alienation. Eighty-two couples were recruited to test these hypotheses and both self-reports and informant reports were collected. Mediated regression analyses partially supported one hypothesized model: Consistent with the IMHA, health-related worry partially mediated the relationship between interpersonal neuroticism and health-related reassurance-seeking. Support for this mediation model was specific to women and to self-reports. Interpersonal neuroticism may represent a dispositional personality structure that underlies and drives key symptoms of health anxiety (e.g., excessive reassurance-seeking). Health-related reassurance-seeking may function as a maladaptive form of interpersonally-focused emotional regulation among women high in interpersonal neuroticism.},
}

@inproceedings{graham2009perfectionis,
  title = {Perfectionistic Concerns, Catastrophizing, Difficulty Accepting the Past, and Depressive Symptoms: A Short-Term, 4-Wave Prospective Study},
  author = {Graham, A. and Allen, S. and McGrath, D. and Breen, E. and Tonet, J. and Sherry, D. and Stewart, S. and Sherry, S.},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Persons high in perfectionistic concerns (PC; i.e., hyper-sensitivity to failures, concern over evaluations, and doubts about abilities) appear vulnerable to depressive symptoms. This study tests a new model, which aims to explain why persons high in PC are vulnerable to depressive symptoms. The proposed model represents a dual pathway mediational model where catastrophizing and difficulty accepting the past are hypothesized to mediate the relation between PC and depressive symptoms. A 4-wave longitudinal study, involving 240 undergraduates, was conducted to test these hypotheses. Consistent with the proposed model, catastrophizing and difficulty accepting the past mediated the relation between PC and depressive symptoms (after controlling for baseline depressive symptoms). Persons high in PC appear to appraise stressful events in a catastrophic manner and to experience difficulty in negotiating a sense of purpose and meaning in their lives. Amid such cognitive and existential difficulties, persons high in PC appear vulnerable to depressive symptoms.},
}

@inproceedings{yorke2009effect,
  title = {The Effect of Academic and Social Integration in Real and Virtual Groups on Self-Efficacy among First-Year Students},
  author = {Yorke, Mateo},
  booktitle = {35th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2009},
  abstract = {Retention of university students is a major issue for Canadian universities. Low academic and social integration, along with career goals and intention to continue in university, influence attrition. The College Self-Efficacy Instrument (CSEI) is a good predictor of retention and attrition. This study measured first-year students' feelings of self-efficacy and then randomly assigned participants to one of three intervention task conditions (academic, school spirit, and control) and one of three social groups (social, virtual, and individual). Measuring participants' feelings of self-efficacy before, immediately after, and two weeks after the experiment showed a significant effect for the social group on the final measure of the CSEI, which suggests the importance of face-to-face, social interaction in the university environment.},
}

@inproceedings{allen2010who,
  title = {Who Said Pedestrian Means Dull: Observations on Street Crossing Behaviour},
  author = {Allen, Stephanie and Brown, Richard and O'Leary, Tim and Behaviour, the Students of Measuring},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Pedestrians represent the largest group of road users yet an alarming 20- 35% of the population crosses the street illegally at intersections (Keegan and O'Mahony, 2003; King et al., 2009). The high rates of illegal pedestrian activity increase to the potential for pedestrian-car crashes. Most pedestrian-car collisions occur when a pedestrian is crossing the street (Bungum et al., 2005), and as many as 32%-44% of car-pedestrian crashes involve illegal pedestrian behaviour (Austroads, 2000). A series of six observational studies were conducted in Halifax, Nova Scotia to explore pedestrian behaviour at various intersections throughout the city. Study one found that pedestrians crossed the street faster in the presence of a countdown timer than a simple walk symbol. Study two examining the effect of age (young/old) and shoe type (heels/no heels) found that older people and women wearing high heeled shoes crossed the street most slowly. Study three found that jaywalking and improper crosswalk use was more likely to occur on-campus than off. Study four found that individuals who talked/texted on a cell phone, or listened to headsets took longer to cross the street than individuals who where not engaging in such behaviours. Study five found that younger pedestrians and pedestrians in groups committed more crosswalk violations than older pedestrians and pedestrians walking alone. Consistent with study two, older pedestrians crossed more slowly than younger pedestrians, and females crossed more slowly than males. Furthermore, groups containing members of both sexes were slower to cross the street than same-sex groups. Study six examined the effect of high and low traffic and distracters on crossing behaviour. Overall significantly more individuals exhibited safe crossing behaviours than risky crossing behaviours, however at low-traffic time periods a higher percentage of individuals exhibited risky crossing behaviours than safe crossing behaviours. Consistent with study four, pedestrians that were distracted exhibited the most dangerous crossing behaviours. Results indicate that pedestrians that were either younger, in groups, on-campus, or distracted were significantly more likely to engage in risky crossing behaviours.},
  note = {Poster},
}

@inproceedings{satel2010computationa,
  title = {A Computationally Explicit Neurocognitive Theory of Inhibition of Return (IOR) Based on Short-Term Depression of Exogenous Signals to the Superior Colliculus},
  author = {Satel, Jason and Wang, Zhiguo and Klein, Raymond and Trappenberg, Thomas},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Inhibition of return (IOR) is an orienting phenomenon characterized by slower behavioral responses to targets that have been spatially cued, relative to uncued locations. There has been extensive discussion in the literature regarding the neural generators and stages of cognitive processing involved in IOR. There is, however, general agreement that at least a subset of IOR-like phenomena are mediated at the level of the superior colliculus (SC). Recent investigations have demonstrated that IOR is accompanied by reduced responses to exogenous inputs in the SC. Here, we present a neuroscientifically based computational model of the SC which implements an early sensory habituation account of IOR. A variety of key findings in the literature are generated by this model, including the biphasic pattern of facilitation at short stimulus onset asynchronies (SOAs) and IOR at long SOAs, vector averaging of IOR, and the co-existence of IOR and endogenous orienting at the same location. Quoting Neuroscience Institute <HYPERLINK "mailto:neurosci@Dal.Ca"neurosci@Dal.Ca>: in their labs.},
  note = {Poster},
}

@inproceedings{stover2010visual,
  title = {Visual and Non-Visual Learning and Memory Performance in the APPswe/PS1dE9 Mouse Model of Alzheimer's Disease},
  author = {Stover, Kurt and Brown, Richard},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The APPswe/PS1dE9 mouse model of Alzheimer's disease develops amyloid beta plaques in the retina and begins to show retinal degeneration by 12 months of age (Perez et al. 2009, Invest Ophthalmol Vis Sci, 50:793-800). As mice are commonly tested for learning and memory deficits using visually dependent tasks, we studied the relationship between visual ability, learning, and memory in transgenic and wildtype control mice at 6-8 (young) and 20-25 (old) months of age. In the visual water box, we found that young mice performed better than old mice on visual detection (F(1,41)=23.44, p<.0001) and pattern discrimination (F(1,41)=31.15, p<.0001), but there was no effect of genotype. Young mice had better visual acuity than old mice (F(1,41) = 9.43, p<.01) and transgenic mice tended to have worse visual acuity than wildtype mice (F(1,41)=3.26, p = .078). In the Morris water maze (MWM), a visually dependent test of learning and memory, old mice took longer than young mice to reach the platform (F(1,41)=44.35, p<.0001) and transgenic mice tended to take longer to reach the platform than wildtype mice (F(1,41)=3.8, p=.0583). Old mice took longer to reach the visual platform (F(1,39)=27.49,p<.0001), had slower swim speed (F(1,40)=43.20,p<.0001), and spent less time in the correct quadrant during the probe trial (F(1,40)=14.64,p=.0004), than young mice. There was no effect of genotype on these measures. Wildtype mice tended to cross the annulus more frequently then transgenic mice during the probe trial (F(1,40)=3.99, p=.0526) and young mice crossed the annulus more often than old mice (F(1,40)=8.67, p <.01). In the conditioned odour preference task, all mice spent more time digging in the CS+ than the CS- odour (F(1,20)=28.84, p<.0005), and there was no effect of age or genotype on amount of liquid consumed. On the conditioned taste aversion test there was no effect of age or genotype. These results demonstrate an effect of age and genotype on visual acuity and on performance (latency) in the MWM, a vision-dependent task. There was, however, no effect of genotype or age on memory in the non-visual tasks. It appears that amyloid plaques in the retina effect visual acuity and memory performance in the MWM, but not in non-visually dependant tasks. This indicates that there is a confound between sensory and cognitive deficits during aging and that non-visual tests should be used to ensure that the learning and memory deficits in aging are due to decrements in cognitive rather than sensory function. We are now examining the eyes and brains of these mice for amyloid plaques. Supported by grants from NSERC of Canada and the Alzheimer Society.},
  note = {Poster},
}

@inproceedings{fitzpatrick2010understandin,
  title = {Understanding the Origins and the Consequences of Perfectionistic Demands in Romatic Relationships: A 2-wave, 28-day Longitudinal Study},
  author = {Fitzpatrick, S. and Mackinnon, S. P. and Hartling, N. and Allen, S. and Orchard, B. and Miller, K. and Stewart, S. H. and Sherry, D. L. and Sherry, S. B.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Socially prescribed perfectionism is conceptualized as involving a dispositional tendency to perceive perfectionistic demands from others. Theory suggests early experiences with hyper-critical, demanding others lead to enduring mental representations of others as imposing perfectionistic demands upon the self. These mental representations may generalize, often inaccurately, to a romantic relationship. This position is termed the "dispositional hypothesis." Socially prescribed perfectionism may also arise from current, actual, and direct exposure to a hyper-critical, demanding romantic partner. This position is termed the "exposure hypothesis." It is unclear if depressive symptoms among persons high in socially prescribed perfectionism are better understood in terms of the dispositional or the exposure hypothesis. To test these hypotheses, 222 romantic couples were studied with a 2-wave, 28-day longitudinal design. Partial support for the dispositional and the exposure hypothesis was observed, with evidence most clearly implicating the dispositional hypothesis in depressive symptoms. Socially prescribed perfectionism may represent an admixture of dispositionally-based social perceptions and transactions with demanding others. 1:30-3:00 Session 3 Chair: Chris Cowper-Smith},
  note = {Poster},
}

@inproceedings{fawcett2010how,
  title = {How Forgetting One Thought Could Lead to Another: The Control of Working Memory Resources in Intentional Forgetting},
  author = {Fawcett, Jonathan and Taylor, Tracy and Nadel, Lynn},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {We combined an item-method directed forgetting paradigm with a secondary task requiring a response to discriminate the color of probe words presented 1400 ms, 1800 ms or 2600 ms following each study phase memory instruction. Discrimination responses were slower following F than R instructions at the two longest intervals. Critically, at the 1800 ms interval, incidental probe word recognition was worse following F than R instructions, particularly when the study word was successfully forgotten (as opposed to unintentionally remembered). We suggest that intentional forgetting is an active cognitive process associated with establishing control over the contents of working memory.},
  note = {Poster},
}

@inproceedings{hussin2010triple,
  title = {The Triple Test for Measuring Anxiety in Mice: Sensitivity to Chlordiazepoxide},
  author = {Hussin, Ahmed and Fraser, Leanne and Ramos, Andre and Brown, Richard},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {A new test for anxiety, the triple test, combines the open field (OF), elevated-plus maze (EPM) and the light-dark box (LDB) (Ramos, 2008, Trends in Pharmacol Sci 29: 493-498). We investigated the validity of the triple test for mice using the anxiolytic drug Chlordiazepoxide (CDZ). We also investigated the occurrence of one-trial tolerance to CDZ by conducting a second test 24hrs after the first. On two consecutive days, a total of 64 Swiss-Webster mice were injected with different doses of CDZ (0.0 (saline), 1.0, 7.5 and 15.0 mg/kg) and their behaviour was observed for 15 min in the triple test. On day 1, increasing doses of CDZ steadily increased open arm exploration (% time in open arms), entries, time in the light box of the LDB and overall locomotion (distance travelled). On day 2, all groups showed significantly diminished open arm exploration and increased time in the closed arms. This reduction on day 2 is attributed to one-trial tolerance to the drug effects since there was no decrease in general locomotion on day 2 (total distance travelled). The triple test has been now validated with different anxiolytics (such as diazepam, alprazolam and chlordiazepoxide) and different mouse strains (BALB/cJ, DBA/2J, and CD-1) (Fraser et al. 2010, Psychopharmacology, In press). The triple test, which occupies a relatively small area (165 x 65 cm) and has a relatively short trial (15-min), provides both locomotion- and anxiety-related measures; is capable of capturing genetic differences in behaviour; and is sensitive to at least three anxiolytic drugs. Further investgations are currently underway to test for sensitivity to anxiety-inducing drugs.},
  note = {Poster},
}

@inproceedings{lawrence2010solving,
  title = {Solving Speed-Accuracy Space},
  author = {Lawrence, Mike},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Speeded discrimination tasks yield two variables of interest: response time (RT) and error rate (ER). Researchers have long known the importance of inspecting both RT and ER to differentiate variables that cause a true improvement in performance versus those that simply elicit a trade-off between speed and accuracy. However, separate analysis of RT and ER risks losing power to detect the true nature of a variable's effect on performance, including the detection of speed-accuracy tradeoffs. A solution is achieved by analysis within speed-accuracy space itself using a combination of mixed effects analysis and bootstrap resampling.},
  note = {Poster},
}

@inproceedings{tonet2010does,
  title = {Does Depressive Affect Mediate the Link Between Socially Prescribed Perfectionism and Binge Eating?},
  author = {Tonet, J. and Graham, A. R. and MacDonald, M. and Sun, M. and Tiesmaki, M. and Yu, J. and Sherry, S. B.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Socially prescribed perfectionism is associated with various costly and maladaptive outcomes, including binge eating (Sherry & Hall, 2009). Persons high in socially prescribed perfectionism appear prone to self-defeating patterns that result in negative outcomes. The Integrated Model of Perfectionism (IMOP) was developed to clarify why such self-defeating patterns occur among persons high in socially prescribed perfectionism. The present study tests one key aspect of the IMOP. Specifically, depressive affect is hypothesized to mediate the link between socially prescribed perfectionism and binge eating. In testing the hypothesized mediational model, 130 undergraduates were recruited. Participants completed self-report questionnaires. Consistent with the hypothesized mediational model, depressive affect partially mediated the link between socially prescribed perfectionism and binge eating. Persons high in socially prescribed perfectionism appear to generate depressive affect and then to cope ineffectively with this affect through binge eating.},
  note = {Poster},
}

@inproceedings{butler2010making,
  title = {'Making the Most of Your Memory': A Pilot Study of a Cognitive Skills Training Group for Community-Dwelling Stroke Survivors},
  author = {Butler, Beverly and Eskes, Gail and Lyons, Renée and Ebert, Patricia},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Problems with attention, memory and executive functions have been shown to significantly interfere with physical recovery, independence, community re-integration, and quality of life after stroke. Rehabilitation through individualized training of compensatory strategies and/or cognitive skills-based training can be effective, but is time-intensive, and access to health care professionals with the necessary specialized training is often limited. Thus, we have undertaken the first randomized, controlled, cross-over trial of a group-based cognitive rehabilitation program for community-dwelling stroke survivors. Participants (n=8) who were enrolled and randomized to either the Early Intervention or Late Intervention group were at least six months post-stroke, were living in the community, and had subjective cognitive complaints. Outcome measures including subjective measures of cognitive functioning, mood, and quality of life, as well as objective tests of cognitive performance were collected at baseline and at three month intervals for nine months. Feasibility and outcome data from this pilot trial will be presented.},
}

@inproceedings{gawryluk2010white,
  title = {White Matter fMRI Activation in the Internal Capsule: Co-Localization with DTI Tractography},
  author = {Gawryluk, Jodie and Mazerolle, Erin and D'Arcy, Ryan},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Functional magnetic resonance imaging (fMRI) in white matter is controversial. The current study had two objectives: (1) to determine whether task-related white matter activation could be detected in the internal capsule; and (2) to determine whether diffusion tensor imaging (DTI) tractography would illustrate structural connections between the internal capsule activation and primary motor cortex activation. A motor task was used. Internal capsule activation was examined at the individual level and functionally-guided DTI tractography was performed. Tracts were seeded such that they had to pass through activated regions in both the primary motor cortex and the internal capsule. Analyses revealed that internal capsule activation was present in 90% of participants. Furthermore, 100% of these participants had tracts connecting the internal capsule activation to activation in the primary motor cortex, confirming structural connections between activated white and gray matter regions. This finding has implications for fMRI studies of brain connectivity.},
}

@inproceedings{hilchey2010effects,
  title = {The Effects of Attentional Control Sets on Eye Movement Latencies in IOR},
  author = {Hilchey, Matthew},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Inhibition of return (IOR) has typically been conceptualized as a bias against returning attention to previously inspected locations. This bias is typically indexed by slowed responses times to cued locations. In recent years, a debate has centered on which levels of processing are affected by IOR. On one hand, some have argued that IOR is fundamentally an attentional phenomenon. On the other hand, it has been argued that there may also be an oculomotor component to IOR in some instances. Experimental results are mixed on this matter with some researchers presenting evidence that IOR is a strictly attentional phenomenon in some instances and a motoric phenomenon in others (Taylor & Klein, 2000). Other patterns of results have suggested that motoric and attentional components of IOR may operate simultaneously (Abrams & Dobkin, 1994). Consideration will be given to experimental methods to explain the divergent findings.},
}

@inproceedings{brown2010hebb,
  title = {Hebb and Cattell: The Genesis of The Concepts of Fluid and Crystallized Intelligence},
  author = {Brown, Richard},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Donald Hebb was hired as a Lecturer in Psychology at Queen's University in 1939, and while he was there, he wrote up the work that he had done at the Montreal Neurological Institute with Wilder Penfield. In one of his papers (Hebb, 1942), he was critical of the concept of "Intelligence" and stated that: "Intellectual development involves (A) the development of direct intellectual power, by neural maturation, and (B) the establishment of routine modes of response to common problems, or of perceptual and conceptual modifications leading to qualitative modifications of behavior." (page 289). He called these Intelligence A and Intelligence B. Hebb (1941) presented these ideas at the APA meeting in Evanston, Illinois, in a symposium which included Raymond B. Cattell, a professor at Harvard University. Two weeks after the symposium, Cattell sent Hebb his manuscript, which contained a description of Hebb's ideas on Intelligence A and Intelligence B, but these were now termed "crystallized" and "fluid" intelligence. Hebb and Cattell exchanged many letters about this, as did their heads of department, George Humphrey (Queen's) and Edwin Boring (Harvard), before Cattell's paper was rewritten in such a way that everyone was satisfied. This talk examines the ideas of Hebb and Cattell on intelligence, their correspondence, the development of the ideas of fluid and crystallized intelligence, and how the following sentence came about: "Hebb has independently stated very clearly what constitutes two thirds of the present theory" (Cattell, 1943, page 179).},
}

@inproceedings{roach2010social,
  title = {Social Context and Electrocommunication in the Weakly Brown Nose Knifefish, Apteronotus Leptorhynchus},
  author = {Roach, Sean and Batt, John and Phillmore, Leslie},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Weakly electric fish use electric signals both for electrolocation and for electrocommunication. The brown nose knifefish generates a quasi-sinusoidal wave-type signal that is sexually dimorphic (600-800 Hz for females and 800-1000 Hz for males). Modulations in this signal (chirps and rises) seem to serve communicative functions that are socially mediated, although their specific roles (e.g., aggression, courtship, etc.) remain poorly understood. The first objective of these experiments is to further elucidate these roles via behavioural testing of free-swimming fish paired in varying arena sizes and with conspecifics of differing familiarity, and of fish exposed to altered playback signals. The second objective is to examine the possible relevance of the gene FoxP2, known to play an important role (often related to social modulation) in other vertebrate communication systems. This will be done by housing fish in different contexts (alone or with same- or opposite-sex conspecifics) and then examing neural FoxP2 immunoreactivity.},
}

@inproceedings{wang2010top,
  title = {Top-Down Modulation of Inhibition of Return},
  author = {Wang, Zhiguo and Klein, Raymond},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Inhibition of return (IOR) is an orienting phenomenon characterized by slower responses to spatially cued than to unced targets. In three experiments, we utilized a digit identification technique (Posner & Cohen, 1984) in which a small digit that required identification was presented following a peripheral cue. Around the time of the cue, the digit could appear in a cued peripheral box or in the central box, thus guaranteeing saccadic response to the cue in one condition and no saccade in the other condition. An IOR effect was observed only when a saccadic response to the cue was required. These findings suggest that behaviorally manifested IOR effects are modulated by top-down processes, such as attentional control setting (ACS). Our method for testing this hypothesis will be presented.},
}

@inproceedings{chevalier2010white,
  title = {White Matter Connectivity in Bilaterally Deaf Individuals vs. Hearing Controls},
  author = {Chevalier, Therese},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {In the event of sensory deprivation, such as hearing loss, cross modal plasticity may occur as brain areas are reallocated for other functions, such as visual processing. Previous studies have reported functional differences, such as auditory areas responding to visual stimuli, as well as differences in diffusivity along white matter pathways between individuals with sensory impairments and controls (Finney et al., 2001; Shu et al., 2009). Varied white matter connectivity is expected between persons with long standing deafness, and normally hearing participants. The ongoing research project employs Diffusion Tensor Imaging (DTI) to infer the integrity and orientation of white matter tracts noninvasively and in vivo. In deaf individuals compared to controls, we predict reduced connectivity in the ascending auditory pathway and between A1 and auditory association areas. As well we predict stronger connections between auditory association regions and multimodal polysensory regions such as posterior STS and parietal cortex. Preliminary findings regarding these differences will be presented.},
}

@inproceedings{goodman2010physiologica,
  title = {Physiological Arousal, Gaze Direction, and Face Recognition},
  author = {Goodman, Laura and Phelan, Heather and Rouette, Julie and Kerr, Michelle and Johnson, Shannon},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The relationship between physiological arousal and recognition for faces with direct versus averted eye gaze was examined in a sample of forty-nine typical adults. Participants were tested on face discrimination and recognition tasks and their physiological arousal was measured via skin conductance responsivity (SCR). Counter to our hypothesis, there was no significant difference between SCR for direct gaze faces and averted gaze faces; however, this finding is in keeping with some previous research. As expected, participants correctly recognized more male direct gaze faces compared to male averted gaze faces. As well, male participants showed a significant and unexpected relationship between increased physiological arousal and poorer overall facial recognition. In addition to being the first study to simultaneously test gaze direction, arousal, and recognition, our results suggest complex relationships between arousal and face processing that interact with the sex of the stimulus and viewer.},
}

@inproceedings{lawrence2010influence,
  title = {The Influence of Attention on the Probability and Fidelity of Memory},
  author = {Lawrence, Mike and Klein, Raymond},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Typical studies of memory employ discrete stimuli and yield dichotomous measures of performance: Ss either remember or forget each stimulus. An alternative approach employs stimuli that can be represented on a continuum, requiring Ss to identify the position of each stimulus on the continuum when memory is later tested. Where early application of this approach confounded multiple sources of performance error (the probability, fidelity, and bias of memory) more recent advances (Lawrence, in press) provide statistical tools to isolate and quantify these sources for analysis as dependent variables. Applying these tools to the study of how spatial attention affects memory, it is found that while exogenous spatial attention affects only the probability of memory, endogenous spatial attention affects both the probability and fidelity of memory.},
}

@inproceedings{shaw2010front,
  title = {Front-End Visual Adaptation: Presynaptic Inhibition at Photoreceptor Terminals in an Insect Eye},
  author = {Shaw, Steve},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {In natural scenes at any one time of day, the visual operating range is restricted by the available pattern contrast, less than 100:1. This 100:1 has to be accommodated within a total brightness scale of >10,000,000:1, as bright sunlight graduates down to dusk. The mismatch requires a range-setting mechanism at the visual front end, to continuously re-scale the operating range as the average ambient light intensity falls and rises -- 'light adaptation'. At the first synaptic zone (lamina) in the visual system of flies, the output terminals of photoreceptors R1-R6 receive multiple feedback synapses from a network of lamina intrinsic neurons, amacrine (Am) cells, themselves driven directly by the same photoreceptors: R1-6 Am. Results here reveal a powerful adaptive system that acts omni-directionally across the lamina zone, swiftly suppressing the output from the photoreceptor terminals -- presynaptic inhibition. The amacrines form the only feedback network poised to accomplish the job of rapidly adapting the visual output from the photoreceptors: they are present at the appropriate level, have the required lateral connectivity, are driven directly from the R1-6 terminals and make large numbers of feedback synapses on to them.},
}

@inproceedings{easy2010cricket,
  title = {The Cricket's Tale - Neurohormones and Mimics},
  author = {Easy, Russell and Adamo, Shelley},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Octopamine and its precursor tyramine are biogenic amines with essential roles in the stress response of insects. Though octopamine's function as a neuroactive chemical has been clearly demonstrated it has only recently been established that tyramine can also act as a neuromodulator in insects. Differentiating the roles of these different amines has been difficult. Identification of octopamine, tyramine and octopamine/tyramine receptors in four different tissues of the Texas field cricket (Gryllus texensis) has been demonstrated using molecular techniques. The presence of three different receptor classes in the neural tissues of crickets is interesting and suggests novel pathways in the stress response of insects. This information will help show what is happening at the cellular level during a host's stress response. Identification of molecules and mechanisms involved in disease susceptibility with a particular interest in the interplay between stress and immunity will be explored.},
}

@inproceedings{corkum2010comparison,
  title = {A Comparison of Sleep and Sleep Lab Adjustment among Children Who Are Typically Developing and Children with ADHD},
  author = {Corkum, Penny and Richards, Jennifer},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Sleep plays an integral role in health, yet approximately 30% of typically developing (TD) children and 50% of children with ADHD are reported by their parents to experience sleep problems. Interestingly, subjective reports (e.g. parent reports) of sleep problems are not always consistent with objective measures of sleep (e.g. polysomnography data gathered in sleep labs). One reason why there may be inconsistent findings between subjective and objective measures may be related to children's responses to the sleep lab environment. This research will examine if children with ADHD, compared to TD children, are differentially affected by the sleep lab environment. This study will first compare how sleep changes from the home environment to the sleep lab environment, and will then determine if children with ADHD are differentially affected by the sleep lab experience. The proposed research project has potential to account for the inconsistent findings in the ADHD-sleep literature.},
}

@inproceedings{wilson2010clinical,
  title = {The Clinical and Neuropsychological Impact of Intense Aphasia Treatment},
  author = {Wilson, K. Ryan and O'Rourke, Heather and Wozniak, Linda and Kostopoulos, Ellina and Marchand, Yannick and D'Arcy, Ryan and Newman, Aaron},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Intensive speech-language therapy can lead to significant improvements in language ability, even in chronic aphasia. One such program is the Intensive Residential Aphasia Communication Therapy program (InteRACT), an intensive 4-week long program with over 100 hours of speech-language language therapy. Our goal was to characterize the effects of intensive therapy on the N400, an ERP effect associated with lexical processing. Eight aphasic patients and 8 matched controls performed a task in which they had to determine whether a spoken word was a 'match' or a 'mismatch' for a presented image. Each aphasic completed the task immediately before and after the InteRACT program; controls performed the task twice with a 4-week interval between sessions. Seven of the 8 aphasics showed clinically significant gains on standardized language testing from the beginning to the end of InteRACT. Post-therapy, the aphasic and control groups showed different changes in the scalp distribution of the N400. Aphasics showed and a more left-lateralized scalp distribution while controls showed a posterior N400 in addition to an anterior positivity.},
}

@inproceedings{hamonhill2010both,
  title = {Both Music and Video Contribute to the Parsing of a Short Motion Picture Animation},
  author = {Hamon-Hill, Cindy and Cohen, Annabel and Klein, Raymond},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The current study investigated how music modulates the interpretation of animation (Heider & Simmel, 1944) by analyzing the parsing of visual and musical stimuli when processed individually and together. Forty-eight participants (mean age = 21(3.6) years) segmented the animation (92 sec), independent orchestral music (92 sec), and the animation and music combined. Temporal patterns of segmentation for the music and combined conditions were strongly correlated, r(93)= .454, p <.001. However, a significantly stronger correlation was obtained between the segmentation patterns for the animation and combined conditions, r(93)= .846, p <.001. Information from both modalities contributed to the parsing of the film, with greater dominance of the visual information.},
}

@inproceedings{ryan2010stimulus,
  title = {Stimulus-Response Compatibility in a Simulated "Real-World" Driving Task},
  author = {Ryan, Matthew and Klein, Raymond},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The performance advantage when stimulus (S) and response (R) locations correspond during non-spatial discrimination tasks is called the Simon effect. Laboratory studies demonstrate that this effect occurs across horizontal, vertical and diagonal S-R orientations. Here we investigate whether the Simon Effect will be observed in a more "real-world" situation akin to driving. With their hands placed on the left and right sides of a steering wheel and with response buttons under each thumb participants navigated a micro-ship through a virtual artery. During navigation, hand position changes from horizontal to vertical (clockwise and counterclockwise) while green and blue targets (pathogens) appear unexpectedly requiring a 2-choice discrimination response made by pressing an appropriate button. As effector location (thumb) varies while steering, so too will the relative S-R orientation. If the Simon effect generalizes to this driving task, RT and accuracy will improve as the relative distance between the S and R decreases.},
}

@inproceedings{ishigami2010cognitive,
  title = {The Cognitive Failures Questionnaire: A Fuller Exploration of Dimensions and Rotations},
  author = {Ishigami, Yoko and Frankland, Brad},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The Cognitive Failures Questionnaire (CFQ) is widely used to assess frequency of everyday slips/errors even though its factor structure is unclear. Using data from 2394 female and 921 male undergraduates, the present study compared the principle components structures for 3 through 7 factors, using both orthogonal and non-orthogonal rotations. The best structure was a 4-factor solution with non-orthogonal rotation. For the males, the best was a non-orthogonal 4-factor solution while for the females, the best was a non-orthogonal 3-factor solution. A subset of 484 students completed the CFQ more than once. It demonstrated good test-retest reliability at 1 year.},
}

@inproceedings{meg2010halifax,
  title = {Halifax is now home to Canada's most advanced magnetoencephalogrphy (MEG) brain imaging system. MEG is a noninvasive tool that offers the temporal resolution of EEG/ERP and spatial resolution than can rival fMRI. However, compared to those techniques it is faster to set up, less affected by head movements, more comfortable for the subject/patient, silent, and does not involve large magnets. This makes it an ideal tool for use with children and various patient populations. Through a partnership between the IWK Health Centre and the National Research Council Institute for Biodiagnostics, Elekta Neuromag OY has installed a 306 channel MEG imaging system and will be situated their North American R&D Headquarters at the IWK Health Centre. This presents a fantastic opportunity for researchers to do cutting-edge work with first-class support. However, as with any technique MEG is not exactly "plug 'n play" and requires some understanding to get up and running. In this talk I will briefly describe what MEG is and how it works, and then walk the audience through the process of designing a MEG study, moving a project through the approval process at IWK/NRC, implementing the study, and analyzing the data.},
  author = {MEG, What is and Newman, How Can I Use It? Aaron},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Friday, April 30th},
  note = {QA: needs-split-review; Split from T24 at: 'What is MEG and How Can I Use It?'},
}

@inproceedings{olthuis2010anxiety,
  title = {Anxiety Sensitivity and Negative Interpretation Biases: Implications for Anxiety Symptoms},
  author = {Olthuis, Janine and Stewart, Sherry and Watt, Margo and Sabourin, Brigitte},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Anxiety sensitivity (AS) is an established cognitive risk factor for anxiety disorders. The present study explored whether individuals high in AS display a similar negative interpretation bias as that identified in those with anxiety disorders. Furthermore, we investigated whether the association between AS and both panic and generalized anxiety symptoms could be accounted for by negative interpretation biases of ambiguous panic-related body sensations, general events, social events, and/or other body symptoms. Eighty-nine female undergraduates (44 low AS; 45 high AS) completed self-report measures of AS, negative interpretation bias, and panic and generalized anxiety symptoms. Findings showed that women high in AS had significantly greater negative interpretation biases. In addition, negative interpretations of ambiguous panic-related body sensations partially mediated the association between AS and panic symptoms while negative interpretations of ambiguous general and social events partially mediated the association between AS and generalized anxiety symptoms. Clinical implications are discussed.},
}

@inproceedings{phelan2010effects,
  title = {The Effects of Maternal Care on Offspring Fitness in the Zebra Finch (Taeniopygia guttata)},
  author = {Phelan, Heather and Phillmore, Leslie},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Variations in maternal care can cause adverse effects later in life for humans and rats (Liu et al. 1997). This study examined the role of maternal care on offspring fitness in the zebra finch (Taeniopygia guttata), a species that provides biparental care to their offspring (Zann, 1996). Offspring were raised in cages with either both parents or a single mother. Parental investment was assessed at days 8 and 13 post-hatch; behaviourally, single mothers compensated for the missing father in most measures. Attempts at assessing physiological stress responsivity provided inconclusive data. Discussion of results focuses on improving future data collection to provide a better picture of parenting behaviour and offspring outcome in the zebra finch.},
}

@inproceedings{sparks2010understandin,
  title = {Understanding the Relationship Between Morphological Awareness and Vocabulary},
  author = {Sparks, Erin and Deacon, Hélène},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Although a strong association between morphological awareness (MA) and vocabulary has been well-established, we know very little about the direction of their relationship. In this longitudinal study, we investigate the possibility of a bidirectional relationship between MA and vocabulary, with a focus on the distinction between inflectional and derivational morphology. Across grades 1 to 3, 100 children completed measures of vocabulary and of past tense, inflected, and derived MA, along with measures of phonological awareness, word reading, pseudoword reading, and nonverbal reasoning. Hierarchical regression analyses revealed that the direction of the relationship between vocabulary and MA depended on morpheme type. Vocabulary predicted subsequent growth in past tense MA, whereas broader measures of inflected and derived MA predicted subsequent vocabulary growth, with derived MA emerging as a stronger predictor of vocabulary. These findings suggest a dynamic relationship between vocabulary and MA that is sensitive to the morphological distinctions within a language.},
}

@inproceedings{white2010neuroplastic,
  title = {Neuroplasticity of Gesture Recognition Systems},
  author = {White, N. and Newman, A. J.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Human gesture recognition is a vital skill in everyday interactions. Studies have demonstrated that brain areas responsive to gestures with communicative content activate a distinct network of brain areas in both hearing and deaf subjects as compared to non-communicative human movements. In addition, in Deaf native signers, linguistic gesture activates Broca's area in much the same way as spoken language. Differences have been demonstrated in the neural systems active during gesture recognition between deaf native signers and normally hearing individuals. Most striking, the structures comprising the putative human mirror neuron system are not activated in deaf subjects in response to non-linguistic actions, while the brains of hearing subjects respond similarly to many categories of human movement. This study investigated differences in the neural networks involved in processing communicative and non-communicative gestures, recruiting deaf individuals not fluent in sign language in addition to normally hearing controls. We were unable to recruit a sufficient sample of deaf individuals to perform statistical analyses. In normally hearing individuals we observed a hierarchical recruitment of human action recognition structures as a function of the symbolic content of human actions similar to that observed in deaf signers. Body movements engaged only temporoocciptal regions while non-communicative hand movements engaged these areas in addition to parietal regions. Finally, communicative gestures engaged areas in the temporooccipital, superior parietal and frontal mirror neuron system regions. We conclude that communicative gestures are processed by normally hearing individuals similarly to sign language processing in deaf signers.},
}

@inproceedings{vriend2010effects,
  title = {The Effects of Sleep Restriction and Extension on Daytime Functioning in Children},
  author = {Vriend, Jennifer and Davidson, Fiona and Shaffner, Sunny and Corkum, Penny and Rusak, Ben},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {There has been little scientific work studying the effects of sleep loss in children. In this study, parents of 8-12 year-old children completed diaries about their child's sleep and the children wore actigraphs (recording devices that provide information about sleep and activity). During the first week, the sleep diary and actigraph information were used to estimate how long the child typically sleeps. During the second and third weeks, in random order, children went to bed either one hour earlier (sleep extension) or one hour later (sleep restriction) than their typical bedtime. After each week, children were tested on their ability to think and regulate emotions. We predict that children will have more difficulty with thinking and regulating their emotions when they sleep less. The results of this study will help to clarify the impact of inadequate sleep in children on both cognitive and emotional functioning.},
}

@inproceedings{cowpersmith2010what,
  title = {What's Your Next Move? Directional Biases for Sequential Limb and Eye Movements},
  author = {Cowper-Smith, C. D. and Eskes, G. E. and Westwood, D. A.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The purpose of our study was to determine, independent of the movement effector system, if movement results in a directional reaction time bias for subsequent movements. Participants either made two consecutive eye or arm movements in directions indicated by arrows presented at fixation. In experiment 1, only two possible target locations were shown during a trial. Here, movements were faster when offset by 90 or 180 degrees from the first movement. This pattern is consistent with inhibition of return (IOR) typically found for repeated movements made in the same direction. Unlike previous studies requiring repeated movements, in experiment two we presented four possible target locations. Here we found that eye and arm movements were faster only when offset by 90 degrees from the initial movement; the well-established advantage for movements offset by 180 degrees was eliminated. Our results reveal an effect of target set size on the spatial gradient of RTs for consecutive movements.},
}

@inproceedings{bilsbury2010effects,
  title = {The Effects of Race and Polarity on Second-Order Relational Face Processing},
  author = {Bilsbury, Tanya and Matheson, Heath and McMullen, Patricia},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {A large body of research has accumulated suggesting faces are processed by a specialized mechanism within the human visual system. According to some researchers, faces are analyzed in part by a 'second order relational' processor, a mechanism sensitive to the metric distances between face parts. Importantly, it is well established that other-race faces and contrast-reversed faces are associated with impaired performance on face processing tasks. Here, we explored whether these effects can be attributed to a disruption of second- order relational processing. We required participants to discriminate subtle displacements to the eye region of computer-generated Caucasian and African American faces, which were presented in normal, inverted, and contrast-reversed conditions. Results suggested that race does disrupt second- order relational processing, whereas polarity does not.},
}

@inproceedings{singleton2010plasticity,
  title = {Plasticity in Spatial Representation Following Tool Training and Attention Training},
  author = {Singleton, Anna and Eskes, Gail and Newman, Aaron},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The representation of peripersonal space in the brain has been shown to be highly plastic, and can be modified through brief periods of hand-held tool training. After training, participants treat the space near the end of a tool (formerly in extrapersonal space) in the same way as the space near the hand. It is unclear, however, if this extension is due to the tool training itself, or the added attention allocated to the tip of the tool in extrapersonal space. The present study measured the multisensory (auditory and tactile) reaction time and accuracy of participants before, immediately after and 15 minutes after a 15 minute tool or visual attention training session in either peripersonal or extrapersonal space. Results suggest that, unlike previous studies, an extension of peripersonal space did not occur with tool training, nor was an extension seen with attention training. Possible explanations are presented.},
}

@inproceedings{filliter2010examination,
  title = {An Examination of Sex Differences in Iowa Gambling Task Performances in Typically Developing Children and Adolescents},
  author = {Filliter, Jillian and Gillespie, J. and Rouette, J. and Phelan, H. and Johnson, Shannon},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Though males typically perform better than females in examinations of adult Iowa Gambling Task (IGT) performance, studies of sex differences on this task in children and adolescents have yielded inconsistent results. Sex differences in IGT performance were examined in typically developing children and adolescents (27 females, 30 males) aged 8 to 16 years. Groups were matched on age and IQ. A repeated measures ANOVA examining proportion of selections made from advantageous decks revealed a significant main effect of block (F(5,275) = 3.466, p = .005), with performance improving across blocks. Although neither a significant main effect of sex nor a block x sex interaction were observed, different patterns of performance were noted for male and female participants. Specifically, female performance improved across the six blocks of the task while male performance worsened until the fourth block and then improved over the last two blocks. Data collection is ongoing.},
}

@inproceedings{matheson2010test,
  title = {A Test of the Embodied View of Object Recognition},
  author = {Matheson, Heath and McMullen, Patricia},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {According to the embodied view of object representation, objects are represented in both sensory cortical areas and cortical areas involved in the programming of various actions associated with that object (e.g. grasping). Mounting evidence from behavioral research demonstrates that images of tools potentiate motor responses. We sought further evidence for this in an object naming task while observers squeezed a ball simultaneously. The objects were oriented to the right or to the left. It was hypothesized that this arbitrary motor act would prime object naming, especially for categories that are associated with motor acts (e.g. a hammer but not a lion); further, we hypothesized that this priming effect would be salient for objects oriented towards the right hand. Preliminary evidence supports these predictions.},
}

@inproceedings{quinlan2010effects,
  title = {Effects of Facial Expression on Item-Method Directed Forgetting},
  author = {Quinlan, Chelsea and Taylor, Tracy},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Negative emotional valence tends to increase item memorability. Our study determined whether faces expressing negative emotion are therefore more difficult to intentionally forget than faces expressing positive or neutral emotion. Using an item-method directed forgetting task to measure intentional forgetting, the current series of experiments presented neutral, happy, and angry faces one at a time, each followed by an instruction to Remember or Forget. Following the presentation of all faces, participants performed a yes-no recognition test. Although there was a directed forgetting effect (better recognition of Remember than Forget items) for neutral and happy faces, there was not a significant directed forgetting effect for angry faces. These findings suggest that a negative facial expression may make faces particularly difficult to intentionally forget. We consider whether this effect is due to the negative emotional valence and/or increased arousal associated with that valence.},
}

@inproceedings{williams2010development,
  title = {The Development of Fairness in Children},
  author = {Williams, Amanda and Moore, Chris},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Children begin to exhibit sharing behavior and understand concepts such as equality early in development, which influence how they interact with the social world. The current study examines the effects of inequality aversion in pre-school aged children within the resource allocation paradigm. In this task children distribute stickers to themselves and one of two partners, a friend or a non-friend, represented by drawings. The purpose of this study is to investigate whether 3 to 5 year old children are sensitive to inequality, and more specifically examine behaviors such as sharing and envy. Trials consist of three types; sharing (in which they choose two rewards for self, or one for self and one for partner), envy with no cost to self (in which they choose one reward for self and one for partner, or one for self and two for partner), and envy with a cost to self (in which they choose one reward for self and two for partner, or zero for self and partner). Data collection is ongoing but so far results show that in sharing trials most children make selfish, inequitable decisions. In contrast, in envy trials with no cost to self, children prefer an equal distribution of rewards. Finally, in envy trials with a cost to self most children will not make consistent self sacrifices to avoid the unequal distribution of rewards, however are more likely to make a self sacrifice when a non-friend stands to receive a greater reward then themselves.},
}

@inproceedings{stewart2010evaluating,
  title = {Evaluating a Personality and Motivational Model of Alcohol Use and Misuse in Canadian Aboriginal Youth},
  author = {Stewart, Sherry and Comeau, M. Nancy and O'Connor, Roisin and Collins, Pamela and Wilgenburg, Hendricus van},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Alcohol is a problem identified by many Canadian Aboriginal communities. Aboriginal youth are particularly susceptible to alcohol-related problems. We investigated a personality- and motivation-based model for understanding risky drinking in Aboriginal youth. 834 adolescents (53% male; mean age = 15.6) from 10 Aboriginal schools served as participants. Of these, 551 self-identified as lifetime drinkers. Drinkers completed the Substance Use Risk Profile Scale (Woicik et al., 2009) to assess personality risk for alcohol misuse, the Drinking Motives Questionnaire - Revised (Cooper, 1994) to assess risky reasons for drinking, a measure to assess typical alcohol use levels (Stewart et al., 1992), and the Rutgers Alcohol Problem Index (White & Labouvie, 1989) to assess negative drinking-related outcomes. Structural equation modelling demonstrated the excellent fit of a model which links personality to heavy drinking and drinking-related problems via risky drinking motives. Implications for the development of matched interventions for Aboriginal youth will be discussed.},
}

@inproceedings{mackinnon2010caught,
  title = {Caught in a Bad Romance: A Test of the Social Disconnection Model in Romantic Couples},
  author = {Mackinnon, S. P. and Hartling, N. and Orchard, B. and Fitzpatrick, S. and Allen, S. and Miller, K. and Stewart, S. H. and Sherry, D. L. and Sherry, S. B.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {What happens when two perfectionistic individuals enter into a romantic relationship? According to the social disconnection model (Hewitt et al., 2006; Sherry et al., 2008), couples high in perfectionistic concerns should be vulnerable to depressive symptoms because they experience heightened conflict with and alienation from each other. To test this model, 222 romantic couples were recruited and studied using a 2-wave, 28-day longitudinal design and analyzed using path analysis. Partners were more similar in perfectionistic concerns than expected by chance alone. A pattern of interpersonal influence was also observed in both women and men wherein perfectionistic concerns contributed to social disconnection which, in turn, contributed to depressive symptoms. Taken together, these results suggest (a) persons high in perfectionistic concerns may select partners high in perfectionistic concerns and/or evoke perfectionistic concerns in their partners and (b) perfectionistic concerns contribute to depressive symptoms through a subjective sense of disconnection from romantic partners.},
}

@inproceedings{duffy2010investigatio,
  title = {Investigation of Protease Activity in the Visual System},
  author = {Duffy, Kevin},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Brain proteases are involved in a multitude of cellular processes that are critical for the maintenance of normal neuron function. We have developed a method for the investigation of protease activity in thin brain tissue slices that provides far superior spatial resolution than alternatives. We revealed proteolysis by observing fluorescence signal produced by fragmentation of a casein substrate. The resolution of this technique permits ready examination of protease activity between adjacent neurons in the same tissue section. We have used this method to measure the activity of a calcium-dependent cysteine protease, calpain, within neurons of the visual system.},
}

@inproceedings{barresi2010effect,
  title = {The Effect of Own Knowledge on Attributing False Belief to Others},
  author = {Barresi, John and Bryson, S. and Longard, J. and Doan, M.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Research with brain-damaged adults indicates that two brain regions are involved in theory of mind (ToM). Damage to the temporal-parietal junction produces a general deficit in the ability to attribute false belief to others, while prefrontal damage produces a deficit only when one's own knowledge interferes with attributing false belief to another person. In the current study, we used a non-verbal ToM task, which distinguished between a condition that required inhibiting one's own knowledge from interfering with one's judgment of another person's belief from one that did not. We found that 4-year-olds performed well when inhibition of their own knowledge was not required, but did poorly when it was required. Younger children did poorly on both tasks, while older children did well on both tasks. This suggests that false belief understanding develops prior to children's ability to prevent their own knowledge from interfering with their judgment about beliefs in others.},
}

@inproceedings{macleod2010visual,
  title = {Visual Search in Autism: A Consistent Islet of Ability?},
  author = {MacLeod, Jeffrey and Bryson, Susan and Klein, Raymond},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Four published empirical studies have demonstrated that children and adults with Autism Spectrum Disorder (ASD) perform more efficiently than typical controls on difficult visual search tasks. Recently we (MacLeod, Bryson, & Klein, unpublished) attempted to replicate this result while investigating whether greater inhibition of return (IOR) in the aftermath of visual search can explain enhanced visual search efficiency in people with ASD. No differences in visual search efficiency or amount of IOR were detected between the ASD and control groups. Potential reasons for this non-replication of previous results are discussed, and a future study proposed.},
}

@inproceedings{couture2010cross,
  title = {A Cross-National Comparison and Validation of the Drinking Motives Quetsionnaire-Revised among College Students},
  author = {Couture, Marie-Eve and Stewart, Sherry and Cooper, M. L. and Kuntsche, E. and O'Connor, Roisin and Ham, Lindsay and Sher, K. and Mohr, C. D. and Armeli, S. and Tennen, H. and Demetrovics, Z.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The aims of this proposed study are to explore cross-national similarities and differences in the structure of the Drinking Motives Questionnaire-Revised (DMQ-R), in the mean levels of social, enhancement, coping, and conformity drinking motive endorsement, and in the links between drinking motives and alcohol-related problems. Confirmatory factor analysis, analysis of variance, and structural equation modeling will be performed on thirteen datasets from nine different countries. We expect that the four-factor structure of the DMQ-R and the relationships between coping and enhancement drinking motives with heavy drinking and alcohol-related problems will both remain constant across countries. However, we also expect cross-national differences in absolute mean levels of drinking motive endorsement across countries that are consistent with greater endorsement of 'riskier' drinking motives in those countries with higher levels of heavy drinking and alcohol-related problems. Preliminary results examining the structure of the DMQ-R across five different countries will be presented.},
}

@inproceedings{wojtowicz2010intra,
  title = {Intra-individual Variability in Attention and Executive Functioning in Multiple Sclerosis},
  author = {Wojtowicz, Magdalena},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {This study examines intra-individual variability in performance on tasks involving attention and executive functions in multiple sclerosis (MS). Greater intra-individual variability on the Attentional Network Test-I (ANT-I) was observed in MS participants compared to healthy controls. The increased intra-individual variability in MS participants was associated with worse performance on a standard clinical measure of cognitive functioning. The effect of task difficulty across conditions of the ANT-I on intra-individual variability was examined, however, only differences between congruent and incongruent flanker tasks were found to be statistically significant. These results indicates that intra-individual variability is an important consideration in studies of information processing for persons with MS and its measurement can provide additional insight into the cognitive functioning of individuals suffering from this condition.},
}

@inproceedings{nichols2010neural,
  title = {Neural Correlates of Second-Language Acquisition in French},
  author = {Nichols, Emily and Marchard, Yannick and Newman, Aaron},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {This study aimed to help understand how age of second language (L2) acquisition affects processing of inflectional morphology using event-related potentials (ERPs). A group of early learners of French as a second language was used in order to investigate this question. A lexical decision morphological priming paradigm was used in which participants viewed videos of native French speakers saying verbs. Embedded in the list of stimuli were inflected real words that preceded their uninflected (infinitive) stems with several items intervening (e.g., the prime marche followed several words later by marcher). Previous work using this paradigm has shown that priming with inflected forms attenuates N400 amplitude to morphologically related targets for regularly but not irregularly inflected words in native French speakers, suggesting differences in processing of regulars and irregulars. We found that early second language learners showed morphological priming effects for regulars, similar to native speakers. These differences in brain responses between regular and irregular morphological stimuli suggest that early learners of a second language have similar morphological processing to native speakers.},
}

@inproceedings{zhang2010locomotion,
  title = {Locomotion and Interneurons in the Spinal Cord},
  author = {Zhang, Ying},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The basic neural circuits that control locomotor activities such as walking, running and swimming reside in the spinal cord. While receiving commands and modulatory information from the brain and peripheral structures, spinal locomotor networks can also produce self-sustaining oscillatory outputs in isolation. Such neural circuitry is referred to as the central pattern generator (CPG). Using a particular group of spinal interneurons, V3, as an example, I would like to illustrate in my talk how we combine mouse genetics with various eletrophysiological, anatomical, and behavioral approaches to identify different groups of interneurons involved in the CPG networks that control the walking behaviors of the animal. In addition to the systematic characterization of the physiologicaland anatomical properties of V3 interneurons, we have demonstratedthat V3s play important roles in producing the stable and balanced locomotor outputs that generate a coherent gait. Our results indicate that V3 neurons are an essential element of CPG networks in the mouse spinal cord.},
}

@inproceedings{fawcett2010event,
  title = {Event-Method Directed Forgetting: A New Paradigm for Understanding the Intentional Forgetting of Events and Actions},
  author = {Fawcett, Jonathan and Taylor, Tracy and Nadel, Lynn},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Instructions to Remember (R) or Forget (F) were integrated within videos depicting simple visual events. Participants responded more accurately to true or false statements (E1-3) and cued-recall questions (E4) regarding R segments than F segments. This was true even when encouraged to encode F segments using concurrent discrimination (E2) or conceptual segmentation (E3) tasks. The final experiment (E5) demonstrated a larger R>F difference for specific statements (the woman added 3 cups of flour) than for general statements (the woman added flour) suggesting that participants likely encoded (and retained) at least a general representation of the events they had intended to forget. Results tentatively support a differential encoding strategy whereby participants preferentially encode R segments, selecting specific details for additional covert rehearsal.},
}

@inproceedings{birnie2010using,
  title = {Using the Cold-Pressor Task with Children: Researchers', Clinicians', Children's, and Parents' Experiences},
  author = {Birnie, Kathryn and Noel, Melanie and Chambers, Christine and Baeyer, Carl von and Fernandez, Conrad},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The cold pressor task (CPT) is an experimental method of inducing pain. Guidelines exist for its appropriate use with children; however, no research has investigated researcher, child, and parent experiences. 17 researchers who have used the CPT with >4000 children reported consistency in CPT methodology. Ethical concerns of research ethics boards did not lead to increased difficulty obtaining approval above other pediatric research. Researchers revealed both positive and negative feedback from families with two adverse events reported. 175 children and 194 parents who participated in one of five CPT studies rated their research experience very positively (M=8.4/10 and M=9.2/10, respectively). 20% of children indicated the CPT was their favorite aspect of participating, whereas 33.5% of children and 7.2% of parents reported it was their least favorite part. Children and parents were happy they had participated and would recommend participation to others. In general, researchers, children, and parents expressed positive experiences with CPT studies.},
}

@inproceedings{crowder2010relationship,
  title = {The Relationship Between Neurofilament Content and Soma Size in the Cat Geniculate Nucleus},
  author = {Crowder, Nathan and Duffy, Kevin},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Neurofilaments are cytoskeletal proteins that help to maintain the gross structure of neurons. Neurofilaments comprise three protein subunits: light (NF-L), medium (NF-M), and heavy (NF-H). Labeling for NF-H has been linked to the large Y-cell neurons of the cat lateral geniculate nucleus (LGN). However, it is unclear whether NF-L and NF-M also correlate with cell size in the LGN. We measured the soma size of cells that were labeled for either NF-L, NF-M, or NF-H, and found little difference in the size of neurons labeled for each neurofilament subunit, suggesting that NF-H may not uniquely identify Y-cells.},
}

@inproceedings{fulton2010olfactory,
  title = {Olfactory Testing in Combination with Diffusion Tension Imaging in De Novo Parkinson's Disease: A New Assessment Measure?},
  author = {Fulton, H. G. and Rohlheiser, T. M. and Good, K. P. and Leslie, R. A. and Fisk, J. D. and McKelvey, J. R. and Schoffer, K. and Scherfler, C. and Khan, N. M. and Robertson, H. A.},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {There is a great need to develop diagnostic tools to identify individuals at risk for or in the preclinical stages of developing of Parkinson's disease (PD) so that neuroregenerative therapies can be further developed. Evidence suggests olfactory deficits may predate PD diagnosis by 4-6years and thus may be a preclinical marker. Olfactory testing of fourteen early-stage PD patients and fourteen age- and gender-matched controls was carried out using the University of Pennsylvania Smell Identification Test (UPSIT). These participants were then scanned using diffusion tensor imaging (DTI). PD patients performed significantly worse on the UPSIT than controls, displaying substantial impairment in their ability to identify common odours. DTI assessment revealed significant white matter abnormalities in PD patients in the substantia nigra and anterior olfactory region compared to controls. Results suggest combined olfactory behavioral testing and imaging might serve as a useful screen to identify those at high risk for developing PD.},
}

@inproceedings{eskes2010acute,
  title = {Acute Hypoxia Effects on Working Memory},
  author = {Eskes, Gail and Allen, Stefan and Foster, Glen and Poulin, Marc},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Sleep apnea results in deficits in working memory that are resistant to treatment with continuous positive airway pressure (CPAP). While currently this resistance is thought to result from the long term impact of chronic hypoxia on cognitive function (due to numerous breathing disruptions at night), it is difficult to disentangle the contribution of other common comorbid factors (e.g., cardiovascular risk factors, sleepiness). While animal models suggest that intermittent hypoxia has direct effects on cognitive function that become chronic over time, data from human studies are scarce. Our study examined the impact of acute intermittent hypoxia on working memory in young healthy adults as a first step to understanding the underlying mechanisms for cognitive disturbance in this population. Preliminary results from this ongoing and a follow-up study conducted here at Dalhousie will be presented.},
}

@inproceedings{macneill2010development,
  title = {The Development of Visuomotor Beahviour in Normal and Dark-Reared Kittens},
  author = {MacNeill, Katelyn and Kennie, Jan and Mitchell, Donald},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The development of various visuomotor functions were examined in 3 light-reared kittens and 3 animals that were dark-reared to 6 weeks of age. Preliminary data will be presented for these two groups of kittens on their development of mobility and their ability to follow and strike at pendulums and a moving laser light. An interesting feature of the results from the dark-reared kittens was their rapid acquisition of good following and striking responses well in advance of their acquisition of good visual acuity. Future work will examine the changes in the fine structure of their responses to visual targets and the accuracy of those responses. 5:00 Closing Remarks 5:30 Dinner},
}

@inproceedings{tong2010what,
  title = {What is Unique about Learning to Read Chinese Words?},
  author = {Tong, Shelley Xiuli},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {This study evaluated the contribution of morphemic and submorphemic sensitivity to Chinese word reading and vocabulary with development in children. We tested 453 Cantonese-speaking kindergartners, second graders, and fifth graders (151 per grade) on tasks of morpho-lexical compounding and radical-semantic relatedness, focusing on morphemic and submorphemic sensitivity, along with other standard measures of Chinese character recognition, vocabulary knowledge, phonological awareness and nonverbal IQ. Results of this study showed that morphemic and submorphemic sensitivity both uniquely contributed to Chinese word reading and vocabulary knowledge, even after controlling for other reading-related measures. However, the extent to which each of these constructs contributes to Chinese word reading and vocabulary differs across grades. Findings of this study demonstrate that morphemic sensitivity and submorphemic sensitivity are independent predictors of Chinese word reading and vocabulary, and the developmental shift of the importance of these constructs in learning to read and comprehend Chinese.},
}

@inproceedings{quinlan2010effectsa,
  title = {The Effects of Faces, Emotion, and Context on the Mere Exposure Effect},
  author = {Quinlan, Chelsea and Johnson, Shannon},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {The mere exposure effect refers to the finding that the simple repeated exposure to a stimulus results in an enhanced preference for that stimulus. The purpose of this study was to explore the effects of both emotional faces and context on the mere exposure effect. The current study used a between-subjects design, which represented the factorial combination of the emotional face presented during the exposure phase (happy, angry) and the emotional face presented during the rating phase (happy, angry). Although there was no effect of emotional face on the mere exposure effect, there was an effect of context such that a mere exposure effect was present when the context matched (happy-happy, angry-angry), but not when the context mismatched (happy-angry, angry-happy). These findings are discussed in terms of both a cognitive and affective perspective of the mere exposure effect.},
}

@inproceedings{landry2010shifting,
  title = {Shifting in Autism - The Cue is The Key},
  author = {Landry, Oriane},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Individuals with autism also exhibit difficulties shifting visual attention on endogenous but not on exogenous orienting tasks. Experiment 2 demonstrated that the difficulty with endogenous shifting is a function of delayed response to the cue. Experiment 3 demonstrated that endogenous orienting can be elicited in response to arbitrary cues on the basis of cue-target contingency in typically developing children and adults. Individuals with autism, however, did not show orienting to arbitrary cues.},
}

@inproceedings{thompson2010exploring,
  title = {Exploring the Differential Withdrawal of Attention From F and R Items in Directed Forgetting},
  author = {Thompson, Kate and Hamm, Jeff and Taylor, Tracy},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Previous research has shown that, in item-method directed forgetting, attention is more readily withdrawn from F items than R items (as evidenced by a greater magnitude of IOR after F compared to R items). The present experiments attempt to test the hypothesis that this F>R IOR difference occurs only when the target localization response is made specifically to the location at which the word was presented. Participants were presented with four peripheral locations at which words and targets could appear. Participants localized the target with either two responses (i.e. general localization: 'right' vs. 'left') or four responses (specific localization: one for each location). The F>R IOR difference emerged only when participants made a specific response, and not when a general localization was made. These results are consistent with a recent characterization of the F>R IOR difference as reflecting a reluctance to respond to the source of unreliable (F) information.},
}

@inproceedings{roach2010seasonal,
  title = {Seasonal Variation in Response to Playback of Vocalizations by Black-Capped Chickadees (Poecile atricapillus)},
  author = {Roach, Sean and Cormier, Jacquelyn and Veysey, Andrew and Phillmore, Leslie},
  booktitle = {36th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2010},
  abstract = {Songbirds exhibit dramatic seasonal changes, including changes in vocal communication. The black-capped chickadee (Poecile atricapillus), a common songbird with a large repertoire of vocalizations, has a song (fee bee) that is sung primarily by males in the spring, and a chick-a-dee call that is produced year-round but most frequently in the fall and winter. In order to compare responses in breeding (spring) and non-breeding (fall/winter) birds, we captured male black-capped chickadees from the wild during those two seasons. We measured their behavioural (activity and vocalizations) and brain (expression of the immediate early gene ZENK in the auditory areas NCM and CMM) responses to lab playback of conspecific song, conspecific call, heterospecific (song sparrow, Melospiza melodia) song, or silence as a control. Neural responses differed between seasons, most notably with much more response to heterospecific song during the non-breeding (fall/winter) season. Thus, neural perception of conspecific and heterespecific vocalizations varies seasonally.},
}

@inproceedings{dewar2011personality,
  title = {Personality Factors and Susceptibility to Burnout in Nova Scotia Ground Ambulance Paramedics: A CrossSectional Study},
  author = {Dewar, Zach and Carter, Alix and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Burnout Syndrome is prevalent in human service professions but little research has been done on causes of burnout in paramedics. Burnout can compromise provider and patient safety, and can have long‐term health consequences. Research demonstrates that personality traits of providers can serve as protective or risk factors in the development of burnout syndrome. This study aimed to examine the association of personality traits with risk of burnout in paramedics, in an effort to better understand burnout syndrome in paramedicine. We used an online survey to ask paramedics in Nova Scotia about their work, burnout and personality. We then analyzed their results using linear regression, and found that neuroticism was a risk factor for burnout, with higher age, calls/month and years of experience contributing as other risk factors. These findings are consistent with previous research on other professions and allow for the tentative generalization of that research to paramedic populations.},
  note = {Poster},
}

@inproceedings{hestermann2011neural,
  title = {Neural and Behavioural Analyses of the 5XFAD Mouse model of Alzheimer's Disease},
  author = {Hestermann, Dietmar and O'Leary, Timothy and Blokland, Arjan and Brown, Richard},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {In the current study the 5XFAD (B6SJL‐Tg) mouse model and wild‐type mice (N=25) will complete a behavioural test battery which will assess anxiety, locomotor activity, motor ability, visuo‐spatial learning and memory, olfactory memory and visual ability. Following behavioural testing mice will be sacrificed and neural changes within brains will be assessed using histology techniques. Following research questions will be answered. What is the difference in behaviour, memory and cognitive function in 6‐9 month transgenic mice compared to wild‐type mice? This will be investigated by using behavioural tests. How is the neural structure affected in 6‐9 month old transgenic mice? Which brain areas important for visuo‐spatial learning and memory differ? Histology techniques are used to answer these questions. Of special interest is the amyloid plaque load resulting from elevated beta amyloid levels and changes in cell number indicating neurodegeneration. Areas of interest are the hippocampal formation and cortex.},
  note = {Poster},
}

@inproceedings{ishigami2011exploring,
  title = {Exploring the Modulation of Attentional Capture by Spatial Attentional Control Settings: Converging Evidence from EventRelated Potentials},
  author = {Ishigami, Yoko and Hamm, Jeff and Satel, Jason and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Attentional control settings (ACSs) are typically defined by a single target‐relevant location. The purpose of the current study is to seek converging evidence from ERPs for a spatial ACS defined by multiple target‐relevant locations, using the methods in Ishigami et al. (2008). Any one of four figure‐8s brightened uninformatively (cue) before presentation of a digit target, calling for a speeded identification. A spatial ACS was encouraged because in different blocks the digit targets appeared only on the horizontal or vertical axis. Performance was more impaired following the attended invalid cues than following unattended invalid cues. The amplitudes of early cue‐elicited visual evoked potentials (VEPs) were greater when the location the cue was presented in was target‐relevant than when the location was target‐irrelevant. Thus, both performance and ERP showed evidence of successful spatial ACSs defined by multiple target locations.},
  note = {Poster},
}

@inproceedings{liu2011antidepressa,
  title = {Antidepressants as Preventive Analgesics for Chronic PostSurgical Pain},
  author = {Liu, Jean and Sawynok, Jana and Allen, Gary and Reid, Allison},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Up to 50% of post‐operative patients may later develop chronic pain due to inadvertent nerve injury at the surgical site. While the extent of the pain experienced varies depending on the surgical procedure, the high incidence of chronic pain has given rise to the need for preventive treatments. Recent rodent experiments in our laboratory have shown that amitriptyline, an antidepressant, can prevent the long‐term development of post‐surgical pain if it is administered at a critical time in relation to a surgically‐induced nerve injury. Since amitriptyline prevents noradrenaline and serotonin reuptake, we predict that the efficacy of peri‐operative administration of the drug may be due to the modulation of descending noradrenergic and serotonergic pain inhibitory systems. We are currently comparing three different nerve injury models in order to determine whether changes occur in the descending noradrenergic pathways that could constitute a neural substrate for the action of amitriptyline.},
  note = {Poster},
}

@inproceedings{salmon2011modeling,
  title = {Modeling Mechanisms of Reversed Effects of Manipulability on Naming and Categorizing Objects},
  author = {Salmon, Joshua and McMullen, Patricia and Trappenberg, Thomas},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Our behavioural research has shown that manipulable objects are named more quickly and categorized more slowly than non‐manipulable objects (Salmon & McMullen, 2009). This pattern of effects was explored using extensions of a computational model of Yoon, Heinke and Humphreys' (2002) Naming Action Model (NAM) by determining the success of three possible mechanisms to simulate it. The first mechanism was based on semantic organization of the system (crowded versus sparse domains or semantic branching) whereby crowded categories (those consisting of many objects) were postulated to be categorized more quickly and named more slowly than sparse categories. The second mechanism was more perceptual, and based on the input of similar objects whereby highly similar objects were postulated to be categorized more quickly and named more slowly (note that ‐ similarity could refer to either visual similarity or the similarity between appropriate action responses: action similarity). The third mechanism was based on the effect of a dedicated Action Module postulated in the NAM model to be active for manipulable but not for non‐ manipulable objects. This Action Module was postulated to speed the naming of manipulable objects, but slow their categorization. Our computational simulation supported a 'reversal effect' due to the first two mechanisms, but not the third. Hence, a sparse versus crowded semantic architecture and similarity of the input objects could account for the 'reversal effect' but a dedicated Action Module could not. These results suggest that actions associated with objects can affect their identification at specific and non‐specific levels without appealing to a module dedicated to coding these associations.},
  note = {Poster},
}

@inproceedings{ngu2011localization,
  title = {The Localization of Neurofilament Subunits in the Rat Primary Somatosensory Cortex Throughout Postnatal Development},
  author = {Ngu, Lin Lin and Song and Cheung, Katharine and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Neurofilament is the predominant shape‐providing intermediate filament in neurons. Within the visual system neurofilament has been linked to particular cell types and functions. In primate visual cortex the protein is localized most heavily within cells that compose the regions outlining metabolically distinct ‘blobs’. In this study we examined whether the non‐uniform distribution of cell characteristics and physiological functions within the rat somatosensory system is linked to the localization of neurofilament subunits. In adult rats we observed neurofilament‐positive neurons preferentially located outside of metabolically distinct ‘barrels’. Investigation of neurofilament subunits throughout development revealed that for two subunits (medium and heavy) reactivity was initially located most densely within processes that formed barrels. These results demonstrate a distinction very early in postnatal development between the labeling patterns of neurofilament subunits that reveal either cells indigenous to the cortex (light) or processes whose is likely thalamic (medium and heavy).},
  note = {Poster},
}

@inproceedings{lawrence2011headgames,
  title = {headgames.org: A Secure Platform for WebBased Experiments},
  author = {Lawrence, Mike and Christie, John},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {With the growing prevalence of personal computers and internet connectivity, web‐based experimentation has become an increasingly enticing modality for psychological research. However, there as yet exists no unified solution for recruitment, participation tracking, and provision of compensation. We have therefore developed headgames.org, a website dedicated to connecting researchers and everyday web users, facilitating the conduct of web‐based experimentation. Specific features include demographically targeted recruitment, secure and confidential data transfer, and integration of a trusted solution for provision of financial compensation (PayPal). We invite proposals from the local community for projects to post during the now begun beta phase of headgames.org.},
  note = {Poster},
}

@inproceedings{brown2011epigenetics,
  title = {Epigenetics and the Future of Psychology and Neuroscience},
  author = {Brown, Richard},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The genomes of humans, rats, mice and fruit flies are now known and the effects of manipulating known genes on brain and behaviour are being investigated. Because environmental variables also modulate brain function and behaviour, the study of how epigenetic variables modulate the expression of genes regulating brain function and behaviour is important for the future of psychology and neuroscience. The action of environmental factors on neurochemical systems and intracellular transduction pathways of neurons alters the structure of histone proteins in the chromatin of the cell nucleus and these histone proteins regulate gene expression. Thus, epigenetic processes provide the mechanism for environmental regulation of gene expression and the solution to the nature‐nurture problem. This poster describes the importance of epigenetic approaches to the study of neural and psychological processes involved in behavioural development, aging, learning, memory, social behaviour and neuropsychiatric disorders.},
  note = {Poster},
}

@inproceedings{blaney2011neurodevelop,
  title = {A Neurodevelopmental Profile of the 3xTgAD Mouse Model of Alzheimer's Disease},
  author = {Blaney, Caitlin and Brown, Richard},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The 3xTg‐AD mouse model of Alzheimer's disease (AD) is a transgenic mouse possessing three human transgenes with mutations implicated in AD encoding for APPswe, PS1M146V, and tauP301L (Oddo S, et al., 2003, Neuron, 39, 409‐421). These mice develop extracellular amyloid beta plaques as well as neurofibrillary tangles at around six months of age and deficits in learning and memory starting at four months of age. Because maternal behaviour can have long‐lasting effects on offspring behaviour (Weaver IC, et al., 2004, Nat Neurosci. 7, 847‐854), we used a cross‐ fostering design to examine the interaction of maternal genotype and pup genotype on neurobehavioural development from 2‐24 days of age. The 3xTg pups showed earlier eye opening, pinnae detachment and earlier development of the hind limb grasp reflex and rooting reflexes than the wild‐type (WT) controls. The 3xTg mothers had lower levels of maternal behaviour than the WT mothers. Although WT mothers showed more maternal behaviour than 3xTg mothers, WT pups reared with 3xTg mothers showed advanced development of the rooting reflex, hindlimb grasp reflex and loss of the cross‐extensor reflex than when raised by WT mothers. These results suggest that there is a complex interaction between maternal care and pup genotype in the rate of early pup development of these mice. We are rearing these mice to adulthood to determine the relationship between maternal behaviour, early developmental parameters and the development of Alzheimer‐like behavioural disruptions in the aging 3xTg‐AD model mice.},
  note = {Poster},
}

@inproceedings{stroud2011orientation,
  title = {Orientation Specificity of Contrast Adaptation in Rodent Primary Visual Cortex},
  author = {Stroud, Aaron and LeDue, Emily and Crowder, Nathan},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Previous studies examining orientation specificity of contrast adaptation in cats have demonstrated the presence of two main subsets of cells in primary visual cortex (V1): 1) Non‐oriented adapting neurons, which adapt to stimuli of all orientations; and 2) Orientation‐specific adapting neurons that only adapt to stimuli matching the cell's preferred orientation. It has been proposed that local intracortical connections between neighbouring V1 neurons may mediate this aspect of cortical contrast adaptation. Adaptation is thought to be related to a cell's position in the pinwheel orientation map of V1. Mice lack these orientation columns, thus it is expected that visually responsive cells within V1 will adapt to gratings at any orientation. We recorded from neurons in V1 of mice and compared the amount of adaptation produced by gratings at both preferred and orthogonal orientations. Both types of stimuli produced contrast adaptation in most cells. Implications for cortical contrast coding are considered.},
  note = {Poster},
}

@inproceedings{burns2011cognitive,
  title = {Is Cognitive Performance Associated with Preclinical Markers of Parkinson's Disease?},
  author = {Burns, Laura and Good, Kim and Fisk, John and Robertson, Harold},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Parkinson's disease (PD) is the second most common neurodegenerative disorder, after Alzheimer's disease. It is clinically characterized as a chronic motor disorder. However, non‐motor disturbances such as impaired cognitive functioning also affect most patients, prior to treatment as well as throughout the duration of the illness. Specific deficits include: recall of verbal material, working memory, and processing speed. Often, these cognitive deficits are not clinically apparent, however, they have been detected in research settings. The current investigation uses a battery of neuropsychological tests, on twelve healthy controls and twelve patients with PD. An analysis of the differences between the groups will augment our existing research on olfactory deficits and neuroimaging biomarkers. We intend to further characterize the potential preclinical markers of PD so the future at‐risk population can be diagnosed before the motor symptoms become apparent and the damage is extensive.},
  note = {Poster},
}

@inproceedings{satel2011modeling,
  title = {Modeling Inhibition of Return as Short‐Term Depression of Early Sensory Input to the Superior Colliculus},
  author = {Satel, Jason and Wang, Zhiguo and Trappenberg, Thomas and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Inhibition of return (IOR) is an orienting phenomenon characterized by slower behavioral responses to spatially cued, relative to uncued targets, when the cue‐target onset asynchronies (CTOAs) are long enough that cue‐elicited attentional capture has dispersed. Here, we implement a short‐term depression (STD) account of IOR within a neuroscientifically based dynamic neural field model (DNF) of the superior colliculus (SC). In addition to the prototypical findings in the cuetarget paradigm (ie., the biphasic pattern of behavioral enhancement at short CTOAs and behavioral costs at long CTOAs), a variety of findings in the literature are generated with this model, including IOR in averaging saccades and the co‐existence of IOR and endogenous orienting at the same location. Many findings that cannot be accommodated by this model could be accounted for by incorporating cortical contributions.},
  note = {Poster},
}

@inproceedings{beckett2011effect,
  title = {The Effect of the Pulfrich Stereophenomenon on Reaching and Perceptual Judgment},
  author = {Beckett, Stéphanie and Westwood, David},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The resistance of action to perceptual illusions has been attributed to the use of stimuli whose illusory features result from processing beyond the divergence of the dorsal and ventral streams. If this is correct, then illusions originating from mechanisms occurring prior to V1 should affect action and perception similarly. One such illusion is the Pulfrich Stereophenomenon in which the illusion of depth is created when a moving stimulus is viewed with a neutral density filter (NDF) over one eye. Participants (n=11) made perceptual distance judgments or reaching movements in response to a moving stimulus displayed in a virtual aiming environment with and without a NDF over their left eye. The results showed a somewhat greater effect of the filter for action than perception, in contrast to most studies which show greater effects of illusion for perception than action. Implications for models of visual control of action and perception are discussed.},
  note = {Poster},
}

@inproceedings{brown2011visuospatial,
  title = {VisuoSpatial Learning and Memory in Six Mouse Models of Alzheimer Disease},
  author = {Brown, Richard and Gunn, Rhian and O'Leary, Timothy},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The Morris Water maze (MWM) is the most commonly used test for visuo‐spatial learning and memory in rodents and is frequently used to test cognitive deficits in mouse models of Alzheimer Disease (AD) (D'Hooge & De Deyn, 2001, Brain Res Rev 36, 60‐90). We have tested males and females of five strains of AD model mice (APPInd, APPSwInd, AppSwe/PS1, AppSwe/PS1dE9, 5XFAD) and their wildtype (WT) control strains in the MWM between 3 & 24 months of age and are now testing the 3XTg strain. Both longitudinal and cross‐sectional studies were completed. This paper summarizes the effects of genotype, age and sex on measures of learning (latency, search strategy) and memory (percent time in correct quadrant, annulus crossings) in the MWM and discusses background gene effects which influence performance independently of transgene effects. The most significant genotype effects were found in the APPInd and 5XFAD mice and there were few significant sex differences, although females appear to use a different search strategy than males. All strains showed reduced performance with age. Background genes for retinal degeneration and albinism affect performance independently of AD transgenes. The results demonstrate the use of the MWM as an analytical tool in dissociating the factors underlying visuo‐ spatial learning and memory in AD model mice.},
  note = {Poster},
}

@inproceedings{boerner2011can,
  title = {Can You Tell if Kids Have Pain or Not? Detecting Deception in Children's Facial Expression of Pain},
  author = {Boerner, Katelynn and Chambers, Christine and Craig, Ken and PillaiRiddell, Rebecca},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {In pediatric pain assessment, facial expressions are a primary source of information when making inferences about a child's pain. While most facial expressions appear spontaneous, children are capable faking or suppressing displays of pain, thereby biasing ratings. The present study will examine the accuracy of health professionals and parents in detecting deception in children's facial expressions of pain. Health professionals (pediatricians, pediatric nurses, and pediatric physiotherapists), and parents will view 48 randomized video clips of children in four pain conditions (faked, genuine, suppressed, and neutral) and will judge which condition the child was experiencing, specify which cues they used in their decision, rate the child's pain, and rate their degree of confidence in their decisions. Data collection for this research is currently underway and preliminary findings from participants collected to date will be presented.},
}

@inproceedings{reliability2011physiologica,
  title = {Physiological Arousal in Children and Adults with an Autism Spectrum Disorder:},
  author = {Reliability, Individual Differences and the Role of Context Dörthe Haacker, Shannon Johnson, Vickie Armstrong, Susan Bryson and Filliter, Jillian},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {A disturbance in the autonomic arousal level is a significant symptom in individuals with autism (Bryson, 2004). Whereas some studies have found elevated levels of arousal others report low levels of arousal (Musurlian, 1995; van Engeland et al., 1991). The dysfunction in the modulation of arousal might be related to core features of autism such as emotional dysregulation, orienting problems and gaze aversion. Those and other repetitive and self‐stimulatory behavioural pattern are viewed as attempts to modulate and regulate arousal. We will measure skin conductance responses, heart rate and respiration rate of children and adolescence with and without autism. Tasks will include basic orientation and habituation tasks in which conditions of novelty, context and predictability versus unpredictability are presented. We expect to find atypical levels of arousal that distinguish individuals with autism from typical controls (i.e. longer duration to reach habituation, higher responsiveness to novel stimuli and strength of orienting response). Furthermore, we expect that arousal patterns will be related to temperament profiles and autistic characteristics reported by parents.},
}

@inproceedings{palango2011speedaccurac,
  title = {SpeedAccuracy Tradeoff in Stroop Interference},
  author = {Palango, Virginia and Ivanoff, Jason},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Stroop interference reflects the effect of word reading on color identification. Scholars have typically measured the Stroop effect using response time as a dependant variable. Here, we assess the temporal dynamics of the Stroop effect by manipulating processing time and measuring accuracy using speed‐accuracy tradeoff (SAT) methodology. Consistent with previous findings, an analysis of the RT distribution demonstrated that the Stroop effect increased with processing time. Interestingly, the SAT analysis revealed no significant Stroop effect. These results have a number of implications pertaining to the sensitivity of SAT methodology, the disparity between the Stroop effect and other compatibility effects, and they suggest that caution be taken when interpreting the timecourse of cognitive processing with temporal measures.},
}

@inproceedings{clouter2011effects,
  title = {Effects of Training on a Dual nBack Task on the Components of Working Memory and Fluid Intelligence},
  author = {Clouter, Andrew and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Working memory ("WM") is the ability to temporarily hold and work with information in mind in order to apply it to complex tasks. WM function has a number of components, including two systems that temporarily hold and rehearse verbal/auditory (phonological loop) and visual information (visuo‐spatial sketchpad). The capacity of these temporary storage systems can be measured with working memory span tasks that require an individual to hold increasing amounts of information in mind, such as digit or visual span, operation span or reading span. When task demands are novel or complex such as those that require attention switching, inhibition, dividing attention or goal maintenance, a third component is involved, called the central executive or supervisory controller. The goal of the current study is to further investigate how the different components of working memory respond to training using a dual n‐back procedure, and how this training might generalize to related cognitive functions, such as fluid intelligence.},
}

@inproceedings{boudreau2011emergence,
  title = {The Emergence of Imitation: Preliminary Findings from a Prospective Study of Younger Siblings of Children with Autistic Spectrum Disorders},
  author = {Boudreau, Ainsley and Smith, Isabel and Brian, J. and Bryson, Susan and Roberts, W. and Roncadin, C and Szatmari, P. and Zwaigenbaum, L.},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Imitation deficits are among the earliest predictors of autism by 12 months of age (Zwaigenbaum et al., 2005). However, little is known about the emergence of imitation in typical and atypical populations. The study prospectively examines the emergence of imitation in the first year of life in infants at high risk (siblings of children with autism) and low risk (no family history of autism) for receiving a later diagnosis of autism. First, we will replicate Nichols' (2005) findings demonstrating a fixed sequence of approximations to imitation in low risk infants. Next, we will extend the findings to a high‐risk infant sibling sample using a novel detailed coding scheme. Initial evidence supports the use of a hierarchy of approximations to imitation as an approach to studying the emergence of imitation skills. Preliminary findings in overall imitation ability and approximations to imitation at 9 months of age will also be reviewed.},
}

@inproceedings{lawrence2011repent,
  title = {Repent Your Statistical Sins},
  author = {Lawrence, Mike},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Come exorcise your demons in this discussion of lamentably common misunderstanding and misapplication of statistical tools in psychology.},
}

@inproceedings{fairn2011immune,
  title = {Immune Activation Influences Agonistic Behaviour in the Texas Field Cricket Gryllus texensis},
  author = {Fairn, Evan and Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Immune system activation can influence investment in reproduction. Specifically, individuals mounting an immune response can (1) invest more in reproduction to compensate for a potential reduction in future reproduction ('terminal investment') or (2) invest less in reproduction due to a trade‐off with immunity. Here we test whether mounting an immune response affects investment in a behaviour associated with reproductive success (agonistic behaviour) in males of the field cricket Gryllus texensis. Immune‐challenged males were less aggressive than controls 5 minutes post‐treatment but not at 90 minutes or 24 hours post‐treatment. Immune‐challenged males won significantly less than half of fights against controls at 90 minutes post‐treatment but not 5 minutes or 24 hours post‐treatment. Our results suggest a potential trade‐off between immunity and reproduction in this species.},
}

@inproceedings{darcy2011remarkable,
  title = {The Remarkable Story of Captain Trevor Greene},
  author = {D'Arcy, Ryan and Lindsay, Stephen and Lepore, Debbie and Greene, Trevor},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Out of respect, Captain Greene took his helmet off when sitting down with the Afghan people in 2006. He was attacked from behind with an axe blow into the top of his head. Thought to be dead, no. Well then vegetative, no. Well then immobile for life, no. Captain Greene and his partner Debbie vowed he will walk again. In the summer of 2010, he stood alongside Debbie during their wedding vows. Functional MRI has tracked the reorganization of Captain Greene's motor regions over the last year ‐ 4 years after the injury.},
}

@inproceedings{roach2011repertoire,
  title = {Repertoire Composition, Song Structure and Singing Behaviour in the Hermit Thrush},
  author = {Roach, Sean and Johnson, Lynn and Phillmore, Leslie},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The primary objective of this study is to provide a thorough description of repertoire composition and singing behaviour in the hermit thrush (Catharus guttatus), heretofore unavailable in birdsong literature, as well as to compare song aspects between geographically distinct populations. We recorded spontaneously singing territorial males during the breeding season in Halifax and Maine, and then compiled song type repertoires, measured song type characteristics, and analyzed song syntax. Overall, individual song type repertoires were organized in a similar manner between populations, although there were some geographical differences with regard to structural characteristics (e.g., note duration) of song types. There was no evidence of song type overlap within or between populations; that is, repertoires were individually distinct. There were no differences in song syntax between populations, with all individuals singing with immediate variety and exhibiting a moderate level of stereotypy (neither 100% predictable nor completely random).},
}

@inproceedings{stewart2011effects,
  title = {Effects of GamblingRelated Cues on Automatic Activation of Gambling Outcome Expectancies},
  author = {Stewart, Melissa and Stewart, Sherry},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Research on outcome expectancies has been extremely influential in the field of alcohol addiction. Despite the theoretical significance of outcome expectancies in the field of addictions, a paucity of research has investigated the impact of outcome expectancies on gambling behaviour. The current study aims to investigate factors that facilitate the activation of gambling outcome expectancies using both response time (RT) and self‐report modes of assessment. Specifically, the present research will assess whether the presentation of gambling‐related cues leads to the automatic activation of outcome expectancies stored in gamblers' memory networks. We will also examine how the activation of positive outcome expectancies may be substantially enhanced by gambling‐ related cues among those with increased problem gambling severity. Gambling outcome expectancies will be assessed by having gamblers (N = 120) complete an outcome expectancy RT task, as well as self‐report measures of gambling outcome expectancies. Gambling behaviour outcomes will be assessed via self‐report.},
}

@inproceedings{richards2011impact,
  title = {The Impact of the sleep lab environment on sleep quality in children with attention deficit/hyperactivity disorder (ADHD) and typically developing peers},
  author = {Richards, Jennifer and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Children with ADHD have significant sleep problems relative to their typically developing (TD) peers. Research in this area has yielded inconsistent findings pertaining to sleep quality in children with ADHD. This could be due to the fact that research often uses polysomnography (PSG) to measure sleep, yet it is unknown if PSG data collected in a sleep lab is representative of children's typical sleep at home. This study examined whether children with ADHD's sleep quality was differentially affected by the sleep lab environment relative to TD children by collecting actigraphy data in the home environment and in a sleep lab. Data from 30 sex‐matched and age‐matched children, aged 6‐12 was analyzed. Results revealed that some sleep quality parameters were differentially impacted by the sleep lab among children with ADHD. Results also demonstrated that, irrespective of an ADHD diagnosis, sleep efficiency was better in the sleep lab compared to at home.},
}

@inproceedings{brown2011checklist,
  title = {A Checklist for Documenting Laboratory Factors Affecting the Behavioral Phenotyping of Mice},
  author = {Brown, Richard and O'Leary, Timothy and Gunn, Rhian and Schellinck, Heather},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Laboratory factors have a significant influence on the behavioral phenotyping of mouse models (Schellinck, H.M., et al. 2010. Adv.Study Behav., 41, 255‐366). Despite attempts to control such effects, they persist. Since the behavioural phenotype is the product of both genetic and environmental (epigenetic) factors, the laboratory environment will always be a factor in determining the behavioral phenotype of mouse models. Our aim in this presentation is to create a checklist of laboratory variables that can influence behavioral results. We examine four categories of confounding variables: the mouse itself, the housing environment, the test environment, and the experimenter. Such a checklist will serve a number of functions. First, it will alert researchers to "hidden" environmental variables that can influence behavior; second, it will provide an outline for writing informative methods sections; third, it will provide a procedure for discussing result; and fourth, it will provide a procedure for comparing results across different laboratories. Such a checklist may also be published as supplemental data to behavioral phenotyping papers. This is the first draft of such a checklist, which we plan to revise and publish.},
}

@inproceedings{stover2011learning,
  title = {Learning, Memory and Social Behaviour in the 3xTGAD Mouse Model of Alzheimer's Disease},
  author = {Stover, Kurt and Brown, Richard},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The 3xTG‐AD mouse model of Alzheimer's disease (AD) is a transgenic mouse possessing three human transgenes with mutations implicated in AD encoding for APPswe, PS1M146V, and tauP301L. These mice develop extracellular amyloid beta plaques as well as neurofibrillary tangles at around six months of age and deficits in learning and memory starting at four months of age. However mice from different colonies may have different behavioural phenotypes. Published studies have used mice from the University of California, Irvine (UCI). We obtained mice from Jackson Laboratories and will test them at two, six, and twelve months of age on a behavioural test battery to assess their learning, memory, and social behaviour and compare our results with those of mice bred at UCI. We have now tested mice at two months of age and found deficits in learning in the Morris water maze and better performance on the rotarod compared to wildtype controls.},
}

@inproceedings{mackinnon2011perfectionis,
  title = {The Perfectionism Model of Binge Eating: A SelfPerpetuating Cycle},
  author = {Mackinnon, Sean and Sherry, Simon and Graham, Aislin and Stewart, Sherry and Sherry, Daba and Allen, Stephanie and Fitzpatrick, Skye and McGrath, Dan},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Why do people binge eat? Theory suggests binge eating is a cyclical behaviour maintained by interpersonal, affective, and biological processes. The perfectionism model of binge eating (PMOBE) is a theoretical model which clarifies the processes underlying this cyclical behaviour. Specifically, concern over mistakes is seen as a destructive aspect of perfectionistic personality which contributes to a cycle of binge eating through four maintenance variables: interpersonal discrepancies, low interpersonal esteem, depressive affect, and dietary restraint. This research represents an empirical test of this theoretical model in an undergraduate sample (N = 200) using a three‐wave longitudinal design. Data were analyzed using path analysis and results provided consistent support for the PMOBE. Supplementary analyses also supported the incremental validity and the specificity of this model. The PMOBE offers a framework for understanding how key contributors to binge eating work together to generate and to maintain binge eating.},
}

@inproceedings{higginbotham2011relationship,
  title = {The Relationship between Empathy and the Visual Scanning of Emotional Faces},
  author = {Higginbotham, Dana and Johnson, Shannon and Filliter, Jillian and Matheson, Heath},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Research suggests that individuals with less empathic abilities have greater difficulty in tasks of facial expression recognition compared to those with higher empathic abilities. Within individuals with Autism Spectrum Disorder (ASD), the relationship between empathy and behavioural performance on face processing tasks can partly be accounted for by how individuals with ASD are visually scanning faces. Research has yet to examine whether scan patterns can also account for the differences in tasks of facial expression recognition between high and low empathic individuals without ASD. The present study examined the relationship between empathic characteristics and efficiency in visually scanning emotional faces among typically developing individuals. The results of this study suggest that less empathic individuals are spending similar amounts of time scanning informative facial regions and more time scanning uninformative facial regions. The present study was the first to examine the relationship between empathy and the visual scanning of emotional faces within a typically developing population.},
}

@inproceedings{wilson2011making,
  title = {Making Working Memory Better: Training the Central Executive},
  author = {Wilson, Ryan and Allen, Stefan and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {This study examined the locus of training effects in Working Memory (WM) performance as measured in the n‐back task. We hypothesized that training on the n‐back task would target domain general mechanisms and thus training in one domain (e.g., verbal) would generalize to the other domain (e.g., spatial). Four groups of healthy young adults trained on either verbal or spatial tasks. Subjects also completed verbal and spatial tests at both 0‐ and 2‐back load at baseline and at post‐training after 3 weekly training sessions via a website interface. Spatial training significantly reduced RT on both verbal and spatial 2‐back tasks, while verbal training reduced RT on only the verbal task. Both Verbal and Spatial trainers were more accurate for the verbal task and more accurate for the 0‐ than the 2‐back task. These results some domain specificity, at least in early training.},
}

@inproceedings{allen2011working,
  title = {Working Working Memory},
  author = {Allen, Stefan and Wilson, Ryan and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Working memory (WM) forms the scaffolding for much of cognitive behaviour and is often affected in neurological disease, thus effective treatments are needed. Working memory consists of a central executive (CE) that directs two maintenance buffers (verbal and spatial). Practice on WM tasks improves performance, but the locus and thus generalizability of improvements in working memory capacity are unclear. The purpose of this study was to examine the locus of training effects (i.e., maintenance buffer vs CE) in WM performance as measured in the n‐back task. In addition the Sternberg task was included as a transfer task to further examine generalizabiliy. Eighteen healthy young adults were randomly assigned for 3 days of training to a control group (non‐specific training), spatial training group (practice only on spatial n‐back) and verbal training group (practice on verbal n‐back). It was hypothesized that training on the n‐back will improve CE performance, and therefore performance benefits (e.g., reaction time and % accuracy) will generalize between domains (e.g., spatial & verbal) and further generalize to an untrained (transfer task) WM task, the Sternberg. Overall, results suggest domain transfer (from verbal to spatial and vv), but transfer to another working memory test was not seen. The locus of training effects will be discussed.},
}

@inproceedings{joshi2011effects,
  title = {The Effects of Repeated Stress in Adolescence on Sensorimotor Gating, Affect, and Memory in Male and Female Rats},
  author = {Joshi, Namrata and Perrot, Tara},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Repeated stress causes enduring effects when present during development, especially to brain regions under construction. I wanted to investigate whether repeated cat odour stress during adolescence results in enduring, sex‐specific changes in prefrontal cortex‐mediated sensorimotor gating, hippocampal function and measures of anxiety‐like and depression‐like behaviour in rats. Prepulse inhibition (PPI) of the acoustic startle response was used as a measure of sensorimotor gating. Performance in the elevated plus maze (EPM) and open field (OF) tests were used to determine levels of anxiety‐like behaviour. The appearance of anhedonia (a symptom of Major Depression) was assessed using the sucrose preference test (SPT) while hippocampal function was measured using a novel object recognition (NOR) test. The results obtained so far reveal clear sex differences in responding, with adult female rats showing a greater effect of the repeated stressor exposure suggesting that females may show greater vulnerability to the impact of adolescent stress.},
}

@inproceedings{gadbois2011there,
  title = {There is a Coyote in my Backyard!},
  author = {Gadbois, Simon},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {On October 27th 2009, Taylor Mitchell was killed by coyotes in the Cape Breton Highlands National Park. This was only the second fatal attack on a human on record, and the first on an adult. I was involved within weeks in the investigation of what may have happened. For the past 18 months I have been consulting with Parks Canada and talking to biologists at the Department of Natural Resources in the hope of finding a permanent solution to the current problem, real or perceived, with our local coyote population. I will discuss the known issues, the perceived ones, and the potential solutions, to deal with problem animals, or populations more likely to interact with humans.},
}

@inproceedings{landry2011examining,
  title = {Examining the Video Deficit Effect in 12-42 Month Olds},
  author = {Landry, Oriane and PSYO, the Students of},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Imitation is an important mechanism in social learning that can aid a child acquire new knowledge and skills. In the present study, twenty-nine infants and toddlers ranging in age from 12-42 months were assigned to five different groups depending upon age, and presented with a scripted imitation game, in both a live and video model, in which target words and actions were examined. Results revealed that at 12-18 months, children display little to no imitation of either words or actions in the live and video models. As age increases, children begin to improve their imitational skills, however an increase in performance of imitation in the video model requires a higher age level than the live model, as a video deficit is displayed. Performance of imitational skills of both actions and words in children in the 36-42 month-old group were just as well in the video condition as the live condition.},
}

@inproceedings{fraser2011characterizi,
  title = {Characterizing the Hemodynamic Response Function of White Matter Using 4T fMRI},
  author = {Fraser, Leanne and Stevens, T. and Liu, C. and D'Arcy, Ryan},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The idea of fMRI activation in white matter is controversial. However, recent research has shown reliable activation in the corpus callosum using tasks designed to elicit interhemispheric activation. Despite advancements in the detection of fMRI activation in white matter, all calculations and analyses of white matter data have been based on the assumption that the hemodynamic response function (HRF) of white matter is the same as that found in gray matter. We presented word and face stimuli to the visual hemifields. The task used a modified version in which single events were included to isolate the HRF. Functional MRI data were collected at 4 T, using an asymmetric spin echo spiral sequence. It was possible to extract time course data for isolated events. White matter responses were analyzed and compared to those in gray matter (parietal lobe, cingulate, visual cortex). Characterization and interpretation of the results will be presented.},
}

@inproceedings{vinette2011effect,
  title = {The Effect of Cognitive Load on Prism Adaptation},
  author = {Vinette, Sarah and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Prism adaptation (PA) has been found to ameliorate symptoms of visuo‐spatial neglect, a deficit in orienting one's attention to the left side of space arising from damage to the right hemisphere of the brain. PA is the process of adapting visuo‐motor function while wearing vision‐displacing prismatic goggles. Pointing performance is measured with various tests before, during and after an adaptation (exposure) period where goggles are worn. The difference in pointing accuracy between the pre‐test and post‐test is the aftereffect. Cognitive load during the exposure period has been reported to affect exposure performance and final after‐effect due to PA, although the findings are inconsistent and may depend upon the method of adaptation. This study examined the impact of cognitive load on exposure performance and aftereffects using two methods of adaptation that varied in amount of cognitive control needed for pointing. Adaptation appeared less affected by need for cognitive control than expected.},
}

@inproceedings{whitzman2011investigatin,
  title = {Investigating Sex Differences in Face Recognition and Gaze Direction},
  author = {Whitzman, Sarah and Goodman, Laura and Phelan, Heather and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {A robust finding in the face processing literature is that faces with direct gaze are more readily recognized than faces with averted gaze'. A recent study in the Johnson lab found that males exhibited better recognition for direct relative to averted gaze faces but that females did not. To further examine this sex difference, the current study examined gaze direction and face recognition in 40 (20 males and 20 females) healthy adults, using a computerized face recognition task. We also investigated the relationships between gaze direction and factors that have been shown to be important when processing facial stimuli (i.e., attractiveness, familiarity, distinctiveness, and androgyny). Overall, both male and female participants demonstrated poor face recognition regardless of the sex of the face stimulus. However, we found that both males and females rated direct gaze faces as more attractive, more familiar, and more masculine than faces with averted gaze; this has implication for future face processing research.},
}

@inproceedings{lewis2011factors,
  title = {Factors Influencing CardSorting Performance in 3yearolds},
  author = {Lewis, Denise and Tower, Meghan and Landry, Oriane},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The Dimensional Change Card Sort (DCCS) is a widely used task assessing cognitive flexibility in preschoolers. The task is a simplistic adaptation of the Wisconsin Card Sort Task in which children are presented with two targets and two possible sorting dimensions, and are explicitly told on every trial how to sort the cards (by shape or by colour). Nevertheless, 3‐year‐olds are notorious for successfully sorting in one dimension but perseverating when instructed to change dimensions. We will report on two experiments examining potential factors in 3‐year‐olds' performance: instruction and repetition.},
}

@inproceedings{easy2011all,
  title = {It's All in the Expression: Cricket Tales},
  author = {Easy, Russell and Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Many of the processes insects require to overcome an immune response involve the work of several genes and subsequently proteins. Transferrin is an iron‐binding protein that is considered an acute phase protein and is upregulated in response to a pathogen stress. Nitrous oxide is a signaling and effector molecule involved in the insect response to pathogen challenge. The prophenoloxidase‐ activating system is an essential component of the insect immune response with a role in wound healing and melanotic encapsulation. The ability to survive an immune challenge may be directly dependant on upregulation of these compounds. Using real‐time PCR we are examining how these compounds change in response to both stress and immune challenge. Once we have identified changes in expression, we will explore how stress influences the expression of immune‐related genes in response to an immune challenge.},
}

@inproceedings{hudson2011put,
  title = {Put on a Happy Face! Relating Emotional Competence and Emotion Regulation},
  author = {Hudson, Amanda and Jacques, Sophie},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Emotion regulation (ER) ‐ the ability to exert control over emotional displays ‐ may depend on several related skills. The current study aimed to decompose ER in 5‐ to 7‐year‐olds into its theoretical constituents. Children's responses to receiving a disappointing gift and parent‐reported ER were used as indices of ER. Predictor variables included neutral and affective inhibitory control, neutral and affective theory of mind, emotion knowledge, display rule knowledge, language, and parent‐reported social disposition and emotionality. ER following receipt of the gift was related to age, affective inhibitory control, theory of mind, and display rule knowledge. Parent‐reported ER was related to social disposition and emotionality. After controlling for all other variables, affective inhibitory control and aspects of display rule knowledge uniquely predicted ER in the disappointing gift paradigm. These findings suggest that ER requires 1) knowledge of contexts requiring ER and 2) inhibitory skills required to execute ER.},
}

@inproceedings{lawrence2011introducing,
  title = {Introducing an Endogenous Attention Systems Test},
  author = {Lawrence, Mike and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The Attention Network Test (ANT) has become a popular research tool for quantifying several phenomena of attention. However, non‐optimal design of this test limit it's power and interpretability. This talk will present a new attention test, designed to obviate the limitations of the ANT and extend its measurement to further phenomena of attention. Pilot experiments will be presented that validate its composition and applicability to both basic and clinical research.},
}

@inproceedings{jang2011human,
  title = {Human Sensitivity to Auditory Temporal Irregularity},
  author = {Jang, Moragh and Dingle, Rachel and Hall, Susan and Phillips, Dennis},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The human auditory system is extraordinarily sensitive to temporal periodicities in sounds, and to differences in the periodicities in sounds. What is far less clear is human sensitivity to deviations from perfect periodicity. This is important, because the failure of the auditory system to encode periodicities (e.g., in listeners with central auditory pathologies) is devastating perceptually, and experimental "jitters" of stimulus time structure in normal listeners is deleterious to speech perception. Detection thresholds for this kind of temporal jitter have not previously been presented. We report an experiment in which we directly measure sensitivity to the temporal irregularity of otherwise perfectly periodic click trains. Our data suggest that thresholds for the detection of temporal irregularity are not those expected from a simple Weber's Law, and that two perceptual operations may be contributing.},
}

@inproceedings{sparks2011sensitivity,
  title = {Sensitivity to Morphological and Orthographic Stress Cues When Reading Multisyllabic English Words},
  author = {Sparks, Erin and Deacon, Helene},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {In English words, certain letter patterns are associated with stress placement (e.g., age; trochaic stress), and research suggests that adults are sensitive to these stress cues. Our study investigates whether this sensitivity differs when a cue is orthographic vs. morphological, and links stress cue sensitivity to reading ability. 104 participants completed a lexical decision task; its items were grouped into sets ending in the same letter pattern. These endings represent either a(n) orthographic cue, consistent with stress (COURage); orthographic cue, inconsistent with stress (corSAGE); or morphological cue, consistent with stress (SHORTage). 40 of the participants also completed measures of word reading and morphological awareness. We expect fewer errors when an orthographic cue is consistent vs. inconsistent, fewer errors for morphological vs. orthographic cues, and that the magnitude of the latter effect will be related to morphological awareness. Moreover, we expect better readers to be more sensitive to all stress cues.},
}

@inproceedings{phillips2011visual,
  title = {Visual and Auditory Factors in Sound Localization Acuity},
  author = {Phillips, Dennis and Quinlan, Chelsea and Dingle, Rachel},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Historically, sound localization acuity was thought to be correlated with head size. Heffner and her colleagues (1992‐2007) have dispelled this notion by showing that sound localization acuity is highly (and inversely) correlated with the species' width of field of best vision, and that when this factor is partialed out, the relation of acuity to head size vanishes. Her hypothesis is that one function of the auditory system is to provide source location data to the visual system so that the latter can bring the field of best vision into alignment with the auditory target. Thus, if one has a narrow width of field of best vision, then one must be a highly accurate sound localizer to achieve that end. But through what mechanism would this evolutionary pressure exert its effect on sound localization acuity? This talk provides one answer to that question.},
}

@inproceedings{thompson2011exploring,
  title = {Exploring Attention in ItemMethod Directed Forgetting},
  author = {Thompson, Kate and Taylor, Tracy},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {In the item‐method directed forgetting paradigm, participants are presented with study items one at a time, which are each followed by an instruction to either remember or forget. Typically, a directed forgetting effect is seen, where subsequent memory is better for R items compared to F items. Interestingly, research suggests that the allocation of attention differs after R and F memory instructions, as well. For example, Taylor (2005) found a greater magnitude of IOR (longer reaction times to targets presented in the same, rather than a different location than the word) after F instructions compared to R instructions. The present experiments used similar attentional paradigms to continue investigating the attentional effects of directed forgetting in order to determine when they occur, what their effects are, and attempt to understand what their purpose might be.},
}

@inproceedings{song2011relationship,
  title = {The Relationship Between Inflammation and Neurotrophin Function in Depression},
  author = {Song, Cai},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Monoamine deficits, hyper‐HPA axis, inflammation and neurotrophin dysfunction may contribute to the etiology of depression. Most proinflammatory cytokines can activate the HPA axis and reduce monoamine syntheses. However, the relationship between inflammation and neurotrophic system, and between the HPA axis and neurotrophic system is unknown. In a depression model, olfactory bulbectomized rats, the microglia were activated, which was correlated with increased concentrations of proinflammatory cytokines interleukin (IL)‐1, IL‐6, tumor necrosis factor‐a, and interferon‐g in the hippocampus, and elevated CRF mRNA expressions in the hypothalamus. However, the expressions of brain‐derived neurotrophic factor and nerve growth factor were down‐regulated. TrK receptors were also down‐regulated, whereas receptor p75 was up‐regulated in the the model when compared to controls. An omega‐3 fatty acid reduced inflammation and the HPA activity, normalized neurotrophic system and improved animal behavior. These results suggest that inflammation may contribute to the dysfunction of the HPA axis and neurotrophic system in depression.},
}

@inproceedings{kerr2011development,
  title = {The Development of Preferences: Investigating Age Differences in the Mere Exposure Effect},
  author = {Kerr, Michelle and Filliter, Jillian and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The development of preferences is an emotional process that allows us to form values, commitments, and attachments. One of the simplest forms of preference acquisition is demonstrated by the mere exposure effect (MEE; Zajonc, 1968); the repeated exposure of a stimulus is sufficient for enhancing an individual's attitude toward it. Although research has consistently demonstrated a MEE in adults, children have yielded inconsistent findings (Houston‐ Price, 2009), and it has been suggested that children prefer novel rather than familiar stimuli (i.e. a reverse MEE; Bornstein, 1989). To examine this emerging preference for familiarity, we have taken a lab‐based approach to investigate the MEE in 30 typically developing youth aged 8 to 14 years. As hypothesized, the strength of the MEE was more pronounced in older children. The findings have interesting implications regarding the development of implicit memory systems, and the influence of parenting styles and media advertisements within the child population.},
}

@inproceedings{barrett2011tobacco,
  title = {Is tobacco addiction nicotine addiction?},
  author = {Barrett, Sean},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Both the positive (e.g. incentive motivation) and negative (e.g. withdrawal relief) reinforcing properties of tobacco smoking are often attributed to a single factor: nicotine. However, there is surprisingly little unequivocal evidence that nicotine per se has either negative or positive reinforcing properties in the absence of other pharmacological (e.g. psychoactive effects of non‐ nicotine tobacco ingredients) and non‐pharmacological factors (e.g. expectancy effects; sensory‐ motor aspects of tobacco use). In a recent series of studies, my research group has found that many of the negative reinforcing properties of smoking appear to be attributable to non‐nicotine tobacco constituents and/or the sensory‐motor aspects of smoking, while many of tobacco's positive reinforcing properties appear to be attributable, at least in part, to psychological factors such as expectancy. In this presentation the roles of nicotine and various non‐nicotine smoking factors for tobacco addiction will be discussed.},
}

@inproceedings{ishigami2011spatial,
  title = {Spatial and Temporal Dynamics of Visual Attention},
  author = {Ishigami, Yoko and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Snyder (1972), using visual search, and McLean et al. (1973), using rapid serial visual presentation (RSVP), examined illusory conjunctions of features (Treisman & Gelade, 1980) in the domains of space and time, respectively. Seeking to develop a methodology for exploring whether "slippage" (failure to bind features) in space and time are related, the purpose of our pilot study was to replicate the methods and findings of these two classic studies. Participants searched for a coloured letter presented in a circular array all at once (visual search) or in a rapidly presented stream of single letters presented at fixation (RSVP). After each trial in each paradigm, they performed two tasks: identifying and localizing (in either space or time, depending on the paradigm) the target letter. Replicating previous findings, errors came predominantly from items adjacent to targets. Details of error patterns will be described and implications of future studies will be discussed.},
}

@inproceedings{bessey2011validating,
  title = {Validating a Measure of Parental Sleep Beliefs in the SchoolAged Population},
  author = {Bessey, Meredith and Coulombe, Aimee and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Sleep problems are commonly reported in typically developing children, and are even more prevalent in clinical populations, such as children with ADHD and autism. Often times sleep problems in children go untreated, and parental beliefs about sleep may be a contributing factor. Developing a measure of these beliefs is an important first step in adapting and modifying these beliefs in order to improve treatment utilization and adherence. A newly developed sleep beliefs questionnaire was administered to parents of typically developing children (n=179) and of children with ADHD and autism (n=176). The goal of the current study was to begin to test the validity and reliability of the measure. A four factor structure emerged accounting for approximately 50% of the variance. The results indicate promise for this measure to be used in both typically developing and special needs populations, as a way to explore parents' beliefs about sleep and sleep problems in their children.},
}

@inproceedings{goodine2011development,
  title = {Development of Intrinsic Neurons in the Mushroom Bodies of Drosophila melanogaster},
  author = {Goodine, Katie and Butcher, Nancy and Meinertzhagen, Ian},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {In insects, the mushroom bodies are paired, higher‐order integrative brain structures implicated in olfactory learning and memory, courtship behaviors, spatial learning, and context generalization in visual learning. Extensive research on the anatomy and function of the mushroom bodies in the ant and honeybee has been conducted, and there is now growing interest in the mushroom bodies of the fruit fly Drosophila melanogaster because of its relatively simple organization and genetic manipulability. We investigated the use of genetic tools to label cells of the main input region of the mushroom bodies, the calyx, and to identify the number of mushroom body intrinsic neurons, called Kenyon cells, at three different developmental stages; the first prepupal stage (P0%), the eighth phanerocephalic pupal stage (P50%), and the freshly emerged adult stage (P100%). The implications of our findings will be discussed.},
}

@inproceedings{peloquin2011effects,
  title = {The Effects of Alcohol on Smoking Cue Reactivity},
  author = {Peloquin, Marcel},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Alcohol appears to alter smoking behaviour through physiological and psychological means. To tease these factors apart, experimental manipulation is required to understand the motivational and physiological roles alcohol has on tobacco use. 30 male and 30 female non‐dependent smokers who are moderate drinkers will be assigned to an alcohol, placebo group, or a control group. They will watch four 2‐minute videos, two during the ascending limb of alcohol absorption, and another two during the descending limb. Half the participants will watch smoking cues during the ascending limb and the other half during the second video of the descending limb. After each video presentation, participants will rate their desire to smoke on both the positively reinforcing and the negatively reinforcing dimensions of tobacco on questionnaires. This research will help determine if differences exist between psychological and physiological aspects of alcohol on smoking cues.},
}

@inproceedings{landry2011autism,
  title = {Autism as a Cognitive Style: Visual Orienting and the Broader Autism Phenotype},
  author = {Landry, Oriane},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Autism is characterized by severe impairments in social communication and behaviour. In my model of autism, later emerging impairments are a function of early emerging differences in attention, how and where infants direct their attention. There is compelling evidence that autism is caused by genetic factors; not only is there a higher incidence of autism within families, but there are also numerous autistic‐like traits exhibited by non‐impaired family members, referred to as the Broader Autism Phenotype (BAP). I will present recent data examining the relationship of the BAP to visual orienting.},
}

@inproceedings{matheson2011testing,
  title = {Testing the Embodied Account of Object Recognition},
  author = {Matheson, Heath and McMullen, Patricia},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Mounting evidence demonstrates that passively viewing images of tools both potentiates motor responses and activates frontoparietal networks responsible for programming action. To account for these findings, embodied theories of cognition propose that the same sensory‐motor neural networks are involved in encoding and retrieving object knowledge. We investigated whether motor programs play a necessary role in the retrieval of object knowledge. Participants performed an object naming task while squeezing a sponge with either their right or left hand. The objects were either man‐made (e.g. hammer) or natural (e.g. horse). We hypothesized that, if activation of motor programs are necessary to retrieve object knowledge, this arbitrary motor act should interfere with object naming, especially for categories that are associated with motor acts. Across two experiments we show that sensory‐motor simulations are involved in the retrieval of both man‐made and natural objects, suggesting that both are embodied.},
}

@inproceedings{wang2011sensory,
  title = {Sensory and Motor Mechanisms of Oculomotor Inhibition of Return},
  author = {Wang, Zhiguo and Satel, Jason and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {We propose two mechanisms underlying inhibition of return (IOR) in the oculomotor system: sensory and motor. Sensory mechanism: Repeated visual stimulation results in a reduction of visual input to the superior colliculus (SC); consequently, saccades to targets which appear at previously stimulated retinotopic locations will have longer latencies than those which appear at unstimulated locations. Motor mechanism: The execution of a saccade results in asymmetric activation in the SC; as a result, saccades which reverse vectors will have longer latencies than those which repeat vectors. In the IOR literature, these two mechanisms correspond to IOR effects observed following covert exogenous orienting and overt orienting in the absence of peripheral stimulation, respectively. We predict that these two independent mechanisms will have additive effects; a prediction that is confirmed in a behavioral experiment. We then discuss how our theory and findings relate to the IOR literature.},
}

@inproceedings{benoit2011sleep,
  title = {Sleep Architecture in Children with ADHD and Their Typically Developing Peers},
  author = {Benoit, Andre and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Over the last 30 years, there have been highly inconsistent findings across studies which used polysomnography (PSG) to compare sleep architecture profiles of children with ADHD to their typically developing (TD) peers (e.g., Sadeh, 2007). These inconsistent findings could be related to methodological issues (e.g., participant medication status, co‐morbidities). Therefore, the current study used PSG technology to analyze sleep architecture variables of a medication‐naïve, rigorously diagnosed sample of children aged 6 - 12 years with ADHD (n=15), compared to a sex‐ and age‐ matched sample of their TD peers (n=15). Multivariate analysis (MANOVA) revealed significant differences between ADHD and TD groups in terms of sleep architecture. Specifically, children in the ADHD group had a significantly longer latency to REM sleep, significantly fewer REM cycles, and less Stage 1 sleep than TD peers. Also, children in the ADHD sample had significantly longer sleep onset latencies, but significantly shorter sleep duration than TD peers.},
}

@inproceedings{gadbois2011odour,
  title = {Odour Matching in Dogs: Applications and Challenges},
  author = {Gadbois, Simon and Thompson, Kate and Hilton, Brittany and Christie, John and LoLordo, Vincent},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Odour matching is used with forensic canines (dogs used as «expert witnesses») and wildlife conservation dogs (to match individuals from scats). Unfortunately, we believe that the most common technique (even standardized in Europe), the scent line-up, is fundamentally flawed as it makes a perceptually difficult task even more challenging by adding an unnecessary element of memory. In the last year we have been investigating a number of other approaches including «same/different» responses to pairs of odours, and short delayed-matching-to-sample procedures. A comparison of all three approaches and the discussion of a true perceptual challenge (odour detection in matrices) will be presented.},
}

@inproceedings{hilchey2011there,
  title = {Are there bilingual advantages on nonlinguistic interference tasks?},
  author = {Hilchey, Matthew and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {It has been proposed that the unique need for early bilinguals to manage multiple languages while their executive control mechanisms are developing might result in long‐term cognitive advantages on inhibitory control processes that generalize beyond the language domain. We review the empirical data from the literature using non‐linguistic interference tasks to assess the validity of this bilingual inhibitory control advantage (BICA) proposal. Our review of these findings reveals that the bilingual advantage on conflict resolution, which by hypothesis is mediated by inhibitory control, is sporadic at best, and in some cases conspicuously absent. A robust finding from this review is that bilinguals typically outperform monolinguals on both compatible and incompatible trials. Together, these findings suggest that bilinguals enjoy a more widespread cognitive advantage (bilingual executive processing advantage, BEPA) that is likely observable on a variety of cognitive assessment tools but not on traditional assays of non‐linguistic inhibitory control processes.},
}

@inproceedings{quinlan2011role,
  title = {The Role of Faces in ItemMethod Directed Forgetting},
  author = {Quinlan, Chelsea and Taylor, Tracy},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {This study examined whether or not the specialized system used to process, encode, and recognize faces contributes to memory processes, such as the ability to remember and intentionally forget. Each experiment in this study consisted of an item‐method directed forgetting paradigm. In the study phase, facial expressions were presented one at a time, each followed by either an instruction to Remember or an instruction to Forget. Following the presentation of all items in the study phase, memory performance was measured using a yes/no recognition test. Although a directed forgetting effect (greater memory performance for Remember‐cued items than Forget‐cued items) was found for Neutral facial expressions across all of the experiments, this was not the case for emotional facial expressions (Angry and Happy facial expressions). Critically, it was found that there was a link between timing and the directed forgetting effect for emotional facial expressions such that when the stimulus presentation duration was decreased (i.e., really short), there was no effect of emotional valence on directed forgetting; however, when the inter‐trial interval was increased (i.e., really long), there was an effect of emotional valence (both negative and positive valence) on directed forgetting.},
}

@inproceedings{corrigan2011wait,
  title = {Wait a Minute, Forget That: Using Natural Speech Cues to Induce Directed Forgetting},
  author = {Corrigan, Ben and Fawcett, Jonathan and Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {To examine directed forgetting due to natural speech cues, participants were asked to rate audio presentations for their quality. The audio clips included mistakes (Errors), which were acknowledged (F instruction) and then corrected (Correction), as well as other items (Reference). During a surprise two‐alternative forced choice recognition task, participant's accurate recognition for Correction and Reference items was significantly higher than for Error (F) items. It is hypothesized that because participants were not intentionally attempting to memorize the material, the forget instruction initiated a cognitive process that withdrew attention from the Error items.},
}

@inproceedings{couture2011drinking,
  title = {Drinking Motives, Alcohol Use, and AlcoholRelated Problems: A CrossNational Comparison and Validation of the Drinking Motives QuestionnaireRevised Among College Students},
  author = {Couture, MarieEve and Stewart, Sherry and Kuntsche, E. and Cooper, M. and O'Connor, Roisin},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The aims of this study were to explore cross‐national similarities and differences in the structure of the Drinking Motives Questionnaire‐Revised (DMQ‐R), in the mean endorsement levels of social, enhancement, coping, and conformity drinking motives, and in the links between drinking motives and both heavy drinking and alcohol‐related problems among college students. Confirmatory factor analysis, analysis of variance, and structural equation modeling were performed on data from Canada, the United States, Hungary, Spain, the United Kingdom, Israel, Ireland, and Brazil. Results indicate that the structure of the DMQ‐R did not consistently yield adequate fit to the data across countries; however, the four‐factor structure of the measure was superior to an alternate three‐ factor structure across countries. Further similar drinking motives predicted heavy drinking and alcohol‐related problems across countries. Similarities were also found in the rank order of drinking motive endorsement across countries but some cross‐national differences emerged in the mean levels of endorsement of particular motives.},
}

@inproceedings{shaw2011aladdin,
  title = {Aladdin's Cave: New Lamps for Old in Illuminating the Tiny World of the Fly's Eye},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {The question of the origin of the several electrical responses recorded extracellularly from the eyes of flies has gained prominence with the adoption of this cellular model for molecular genetic studies of neural transmission, in Drosophila. In particular, the origins and dynamics of the electroretinogram's ON‐ and OFF‐responses are not understood and have been widely misinterpreted. An accidental discovery here has suggested that the usual method of free‐field illumination is of limited utility in exposing the properties of the ON and OFF signals. Introducing a new method of illumination to limit these deficiencies has allowed separation of the ON‐OFF system from the more elemental responses of the photoreceptors and monopolar neurons of the first synaptic zone, exposing these clearly for the first time in the electroretinogram. Currents from different monopolar neuron do not interact and as expected, sum independently and linearly. In contrast, the ON‐OFF system collects light from many facets across the eye in an apparently cooperative, non‐linear summative fashion.},
}

@inproceedings{green2011effects,
  title = {The Effects of Prenatal Psychological Stress and Postnatal Environmental Enrichment on the Development of Anxiety and Depressive Behaviours and Neural Changes in the HPA Axis},
  author = {Green, Amanda and Mungovan, Kal and MacLean, Meaghan and Perrot, Tara},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {We investigated the impact of a novel prenatal psychological stress (PPS) on sex‐specific ontogeny of behaviours related to social interaction, anxiety and depression, and the role of postnatal environmental enrichment (EE) to prevent/rescue these changes. Activity was decreased in juvenile EE offspring compared to standard cage. Juvenile females showed greater anxiety‐like behaviour than males and EE removed this difference. Juveniles exposed to EE also showed less depressive‐like and antisocial behaviour, although antisocial behaviour increased in males with exposure to both PPS and EE. In adulthood, PPS females displayed more depressive‐like behaviour compared to all other groups, and this correlated with their juvenile levels of depressive‐like behaviour. Interestingly, there were sex‐specific effects of PPS and EE on CRH‐ir cells in the PVN of the hypothalamus, with both PPS and EE affecting males to a greater extent. The implications of these findings will be discussed.},
}

@inproceedings{levesque2011reading,
  title = {Reading for Meaning: Investigating Children's Sensitivity to Morphological Structure During Contextual Reading},
  author = {Levesque, Kyle and Deacon, Hélène},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Children utilize multiple avenues of information in order to accurately read and understand written words. One such avenue is presumed to be the morphological structure of complex words (e.g., bold + ly). In particular, the frequency of the base morpheme (e.g., bold in boldly) appears to have a privileged role in children's reading. Complex words with high frequency bases (e.g., questionable) are read more accurately and understood to a greater extent than words with low frequency bases (e.g., conceivable). The current investigation stems from the fact that children appear to be sensitive to the morphological structure of words presented in isolation. Yet, it remains unclear to what extent the effects of base frequency are influenced by contextual reading. Thus, the purpose of this experiment is to explore the relationship between base frequency (high vs. low) and context (isolation vs. sentence) by examining their combined effect on word reading and comprehension.},
}

@inproceedings{chevalier2011white,
  title = {White Matter Connectivity in Bilaterally Deaf Individuals vs. Hearing Controls},
  author = {Chevalier, Therese and Newman, Aaron and Lim, Vanessa and Maessen, Heather and Bance, Manohar},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {In the event of sensory deprivation, such as hearing loss, cross modal plasticity may occur as brain areas are reallocated for other functions. Previous studies have reported functional differences, such as auditory areas responding to visual stimuli, as well as differences in diffusivity along white matter pathways between deaf and control participants. We used Diffusion Tensor Imaging (DTI) to infer the integrity and orientation of white matter tracts noninvasively and in vivo. Tractography was conducted from regions of interest, which included the primary auditory cortex, planum temporale, and V5 of the visual cortex in both hemispheres. Significant differences in connectivity were found between V5 and the planum temporale in the left hemisphere in deaf patients as compared to controls. Similar differences were noted at trend levels in the right hemisphere. These findings support the hypothesis that structural changes occur to facilitate cross modal cortical reorganization in response to sensory deprivation.},
}

@inproceedings{fawcett2011motivation,
  title = {Motivation and Data Quality Across the Term: How to Get Cleaner Data in Just Five Minutes},
  author = {Fawcett, Jonathan and Christie, John},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {We present a questionnaire currently in development to measure attitudes towards research following completion of a variety of experimental tasks. The questionnaire itself is available in both computerized and paper form and requires between two and five minutes to complete. It is our prediction that our questionnaire could be developed to allow researchers to predict the quality of the data a subject will return, thus allowing researchers to account for that in their models. Analyses of the pilot project we ran this year will be presented. We are actively seeking research laboratories in our department willing to help recruit subjects for this project.},
}

@inproceedings{ikpi2011effects,
  title = {The Effects of Eating Dennettia tripetala fruit on locomotor and anxietyrelated behaviours in CD1 mice},
  author = {Ikpi, Daniel and Brown, Richard and Bisong, Sunday},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Dennettia tripetala fruit induces a mild stimulating effect when ingested; it is used to spice foods in Southern Nigeria. It is believed to reduce social anxiety and increase sociability. The present study investigated the stimulatory effects of D. tripetala on locomotor and anxiety‐like behaviours in CD1 mice in the open field, elevated plus maze and light‐dark transition box. Thirty singly housed male CD1 mice were divided into 3 groups of 10. The Control group were fed normal rodent pellets. The Low‐dose group were fed a 10% D. tripetala diet (10g of D. tripetala mixed with 90g of rodent pellets). The High‐dose group were fed 15% D. tripetala diet (15g of D. tripetala mixed with 85g of rodent pellets) daily for 4 weeks before testing. Both doses of D. tripetala reduced the number of line crosses and the frequency of centre square entries in the open field while the high dose reduced the number of line crosses in the light‐dark box and the frequency of rearing in the open field. The low dose of D. tripetala increased the time in the open arms in the elevated plus maze, while the high dose decreased the number of stretch attend postures in the light‐dark box. The results indicate that chronic ingestion of D. tripetalareduced locomotor and exploratory behaviour in CD1 mice at both doses while the low dose may have an anxiolytic effect. Future studies will examine the effect of D. tripetalaon motor learning, motor control and sociability.},
}

@inproceedings{eskes2011improving,
  title = {Improving Cognitive Function in Healthy Aging},
  author = {Eskes, Gail},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Exercise can improve cognitive abilities in healthy older adults and delay the onset of age‐related cognitive decline. The mechanisms for the positive benefit of exercise and how these effects interact with other variables known to improve cognitive function (e.g., involvement in cognitive activities) were examined in 42 healthy post‐menopausal women. The association of physical fitness (VO2 max), cerebral blood flow and cognitive activity with neuropsychological performance was assessed through linear regression. Physical fitness, cerebrovascular reserve and total number of cognitive activities (but not total hours) were independent predictors of cognitive function. In addition, prediction of neuropsychological performance was better with multiple variables than each alone. Cognitive function in older adults is associated with multiple factors, including physical fitness, cerebrovascular health and cognitive stimulation. Interestingly, cognitive stimulation effects appear related more to the diversity of activities, rather than the duration of activity. Further examination of these relationships is ongoing in a prospective cohort study.},
}

@inproceedings{smith2011isolating,
  title = {Isolating Contributions of Voltage Gated Sodium Channel Isoforms to the Electroretinogram},
  author = {Smith, Ben and Cote, Patrice and Tremblay, Francois},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {10 Nav channel isoforms with differing properties contribute to global sodium influx but pharmacologically only two groups can be isolated. We have applied a series of Nav channel antibodies conjugated to an ampipathic peptide to isolate the contributions of individual isoforms to the summed electrical potential of the retina. Both pan Nav antibodies and a cocktail of antibodies against the 3 most common Nav channels in the retina (Nav1.1, 1.2, and 1.6) have similar effects on low frequency component of the electroretinogram (ERG). These antibodies replicate the effects of tetrodotoxin, the canonical Nav channel blocker. Individual Nav1.6, 1.2, and 1.1 antibodies indicate that Nav1.6 and to a lesser extent Nav1.2 carry the majority of voltage gated sodium current in neurons contributing to the ERG. Interestingly we found that both the pan Nav antibody and an antibody against the TTX resistant Nav channel 1.8 reduce the high frequency components of the ERG.},
}

@inproceedings{roddick2011use,
  title = {The Use of Olfactometry to Assess Learning and Memory in Mouse Models of Alzhiemer's Disease},
  author = {Roddick, Kyle and Schellinck, Heather},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Alzheimer's disease is a progressive, neurodegenerative disease that affects half a million Canadians. Patients with Alzheimer's disease show numerous cognitive and memory impairments. As a result of recent advances in genetic engineering techniques, an ever‐increasing number of genetically modified mice reported to model Alzheimer's disease are being developed. Before these mice can be used to test possible treatments for Alzheimer's disease, the validity of these models must be tested by assessing the symptoms they exhibit. Behavioural tests of working and long‐term memory in mice are available, however, the majority of these test rely upon visual tasks, while rodents are primarily olfactory animals. The use of two olfactometer tests, an odour discrimination task and a matching to sample task, are proposed as assessments of long‐term and working memory, respectively, which would be able to take advantage of the mouse's superior sense of smell. I will report the results of pilot studies using C57Bl/6J mice and outline the proposed experiments using two background strains used in Alzheimer' mouse models.},
}

@inproceedings{ledue2011investigatio,
  title = {Investigation of Cytoskeletal Proteins in Neurons of the Cat Lateral Geniculate Nucleus},
  author = {LeDue, Emily and Crowder, Nathan and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 37th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2011},
  abstract = {Cytoskeletal elements such as neurofilament and the actin‐binding protein spectrin maintain the structural integrity of neurons. The largest neurons in the cat dorsal lateral geniculate nucleus (dLGN), which compose the Y‐cell class, are distinguishable by their inclusion of the heavy neurofilament subunit. This observation raises the possibility that other classes of dLGN neurons can also be distinguished by their cytoskeletal content. In this study of the dLGN we examined the relationship between cell size and cytoskeletal composition. We determined that neurons labeled for all neurofilament subunits were significantly larger than the general population, and that spectrin labeling was not linked to cell size, as it was evident in almost all dLGN neurons. Double labeling for the inhibitory neurotransmitter, GABA, revealed that neurons reactive for GABA very rarely exhibited labeling for neurofilament, indicating that neurofilament is predominant in or exclusive to projection neurons.},
}

@inproceedings{jaime2012assessment,
  title = {An assessment of the visual-proprioceptive integration threshold in children with and without autism spectrum disorder},
  author = {Jaime, Mark and Longard, Julie and Moore, Chris},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {We investigated a group of 5- to 8-year-old children and a group of 8- to 11-year-old children with high functioning autism on their awareness of self-generated bodily movements by assessing their ability to integrate information provided through the visual and proprioceptive sensory modalities. Children were presented with a task in which they had to make judgments on whether their self-generated hand movements appeared live or delayed on a video monitor in the following 4 different delay conditions: a (1) 0 ms, (2) 100 ms, (3) 200 ms, and (4) 300 ms delay. We were interested in the threshold of time at which children detected a temporal asynchrony between visual and proprioceptive information, from here on called the visual-proprioceptive integration threshold (VPIT). In addition, we assessed their accuracy of delay judgment for each condition. Preliminary results suggest that, in typically developing children, the VPIT decreases and the accuracy of delay judgment increase as a function of age. Further, the VPIT for the older children with ASD appears to resemble that of the 7- to 8-year-old typically developing age group. These results suggest that as children develop, and are exposed to greater amounts of integrated first and third person information, they become more sensitive at detecting visual-proprioceptive temporal asynchronies of self-generated bodily movements. However, children with ASD may have a different developmental pathway in regards to visual-proprioceptive integration.},
  note = {Poster; booktitle inferred},
}

@inproceedings{reiss2012investigatin,
  title = {Investigating inhibition of return-related modulations of early sensory event-related components with central and peripheral cuing},
  author = {Reiss, Caroline and Satel, Jason and Hilchey, Matthew and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Inhibition of return (IOR) is a behavioral phenomenon indexed by increased response times to targets presented at previously cued locations, so long as the interval between the cue and the target exceeds ~300 ms. IOR can be generated by uninformative peripheral onsets (exogenous) or central arrow (endogenous) cues. This experiment replicates previous behavioural work which has demonstrated IOR in these two cue conditions (Taylor & Klein, 2000), with the advantage of also saving and analyzing electroencephalographic (EEG) recordings. We investigate a paradigm with saccadic responses to cues (mixed central and peripheral) followed by manual responses to peripheral targets. In addition to behavioral IOR, previous EEG studies have demonstrated that the target-elicited early P1 event-related potential component (ERP) is reduced in magnitude at peripherally cued, relative to uncued locations. Here, we observed significant IOR and P1 modulations for peripherally cued targets, replicating previous work. However, trials with central endogenous cues produced IOR (as expected), but no P1 modulations.},
  note = {Poster; booktitle inferred},
}

@inproceedings{dean2012performance,
  title = {Performance versus paper: Can typography save trees without sacrificing reading speed and comprehension?},
  author = {Dean, Christopher T. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The environmental impact of typography is under-recognized. While traditional typographic decision making is primarily based on aesthetics, intuition, and convention, we believe that a scientific approach can be used to save paper. Two experiments were conducted in which participants read eight passages, either silently or out loud. The passages were set in two different formats: standard, and paper-saving which reduced paper consumption by approximately 28%. The reading of each passage was timed and followed by a set of comprehension and subjective questions. Statistical analysis of our data revealed: 1) Reading silently was significantly faster than reading out loud while comprehension accuracy and time to answer the comprehension questions was affected by this variable. 2) Format had no significant effect on time to read, comprehension accuracy, or time to answer the comprehension questions. 3) Participants preferred standard over paper-saving parameters despite the fact they found paper-saving parameters more appropriate for a variety of contexts. The primary finding of this research demonstrates that with no loss in speed and comprehension, millions of trees a year can be saved if the paper-saving format we tested were adopted by most word processing softwares.},
  note = {Poster; booktitle inferred},
}

@inproceedings{satel2012effects,
  title = {The effects of ignored versus foveated cues upon inhibition of return and early event-related potential components to targets calling for manual localization responses},
  author = {Satel, Jason and Hilchey, Matthew and Story, Ross and Wang, Zhiguo and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Using 24 different variations of Posner's cue-target paradigm, Taylor & Klein (2000) discovered two mutually exclusive "flavors" of IOR: When the oculomotor system is inhibited, IOR affects input processes (perception/attention flavor); when the oculomotor system is not inhibited, IOR affects output processes (motor flavor). Studies of brain activity with ignored cues and manual responses to targets (for a review, see Prime & Ward, 2006) have typically reported that IOR reduces an early, sensory component (P1) of the brain's response to the target. Since eye movements are discouraged in these experiments, this P1 reduction might be a reflection of the perception/attention flavor of IOR. If, instead of ignoring the cue, participants make a prosaccade to the cue (and then return to fixation) before making a manual response to the target, then the motor flavor of IOR should be generated. In the present study we compared these two conditions while monitoring eye position and recording ERPs to the targets. If the P1 modulation is related to IOR, there should be no IOR modulation of the P1 component when the motoric flavor of IOR is generated by a prosaccade to the cue. Whereas target-elicited P1 reductions were similar, and behavioral IOR significant, in both conditions, behavioural IOR was significantly larger in the saccade condition. These findings suggest that either: 1) perceptual/attentional mechanisms of IOR are recruited whether the oculomotor system is inhibited or activated, or 2) P1 reductions do not provide an accurate reflection of IOR's behavioral manifestation.},
  note = {Poster; booktitle inferred},
}

@inproceedings{hilchey2012when,
  title = {When spatiotopic and retinotopic coordinates are dissociated inhibition of return is primarily spatiotopic while P1 reductions are primarily retinotopic},
  author = {Hilchey, Matthew and Satel, Jason and Wang, Z. and Story, R. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Although the visual coordinate system is initially retinotopic, it has long been known that the representation of IOR can be observed in spatiotopic coordinates when an eye movement is made between the cue and a target calling for a manual response (Posner & Cohen, 1984; Maylor & Hockey, 1985). Neuroimaging studies using event-related potentials (ERPs) have generally revealed that early sensory components (P1) are reduced by IOR (for a review, see Prime & Ward, 2006). All such studies, to date, have confounded retinotopic and spatiotopic reference frames. In Experiment 1 we investigated whether the target-elicited P1 component would be modulated by IOR while we unconfounded these reference frames by interposing an eye movement between cue and a target calling for a manual response. With seemingly conflicting results, recent behavioral studies have investigated the frame of reference for IOR using saccadic responses to targets (Mathot & Theeuwes, 2010; Pertzov, Zohary & Avidan, 2010). Experiment 2 seeks to determine whether oculomotor IOR is spatiotopic (Pertzov et al.) or retinotopic (Matthot & Theeuwes) immediately following an intervening eye movement. In Experiment 1, P1 reductions at the cued location were greater in retinotopic, than spatiotopic, coordinates even though IOR showed the reverse pattern. Similar behavioral results (stronger spatiotopic IOR) were obtained in Experiment 2 when probed with eye movement responses. These results show that immediately after a saccade IOR is coded in spatiotopic coordinates and that the magnitude of P1 reductions does not provide an accurate reflection of IOR's behavioural manifestation.},
  note = {Poster; booktitle inferred},
}

@inproceedings{hashish2012speed,
  title = {Speed-accuracy trade-offs in inhibition of return during active oculomotor inhibition},
  author = {Hashish, Mahmoud and Hilchey, Matthew and Satel, Jason and Ivanoff, Jason and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Inhibition of return (IOR) refers to the phenomenon of increased response times (RTs) to targets at previously cued locations when the interval between a to-be-ignored spatial cue and a target exceeds ~ 300 ms. Recent work has revealed that this phenomenon can be expressed differently depending on the extent to which the oculomotor system is active during a task, resulting in either a perceptual/attentional "flavour" or a motoric "flavour" of the IOR effect. There are several studies with results consistent with the motoric "flavour" of IOR (a speed-accuracy trade-off) in which the eye movement system was not explicitly engaged (but may not have been actively inhibited either). The purpose of this investigation was to repeat one of these experiments (Ivanoff & Klein, 2001) while ensuring that the eye movement system was actively inhibited. In this project, eye movement was monitored through the usage of eye tracking equipment and software. If the motoric patterns reported by Ivanoff and Klein (2001) were generated because they did not monitor eye movements and their participants were not actively inhibiting the oculomotor system, then when we did encourage such active inhibition, a perceptual/attentional flavour of IOR should be obtained (i.e., the speed-accuracy trade-off will be eliminated). This is precisely what we found.},
  note = {Poster; booktitle inferred},
}

@inproceedings{redden2012calling,
  title = {Calling close plays at first base in baseball},
  author = {Redden, Ralph J. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {This project investigated the law of prior entry in a practical real-world setting. We examined close plays at first base in baseball, a scenario in which accurate performance demands that the umpire monitor two events simultaneously - both the ball's arrival at the glove and the runner's arrival at the base. However, umpires are trained to attend the ball when making calls at first base, risking potential bias. To explore this scenario empirically, we placed participants in the role of an umpire while watching video clips of close plays at first base taken from MLB games during the 2007 and 2008 seasons. Further, different groups of participants were provided different focus instructions: some were instructed to attend the ball/glove, some were instructed to attend the runner/base and others were not provided any focus instructions.},
  note = {Poster; booktitle inferred},
}

@inproceedings{collins2012investigatio,
  title = {An investigation of the possible reciprocal relations between alcohol consumption and impulsivity in university students: A four-wave longitudinal study},
  author = {Collins, Jamie-Lee and Stewart, Sherry},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {This study seeks to investigate the possibility of reciprocal relations between alcohol consumption and impulsivity in university students using a four-wave longitudinal study design. Participants are 150 male and female university students who completed a number of online questionnaires, which included the Substance Use Risk Profile Scale (SURPS) to assess for impulsivity and a Lifestyle Questionnaire to assess for alcohol consumption. Cross-lagged analyses are being used to determine the relationship between alcohol consumption and impulsivity levels, which is appropriate since this is a statistical technique used for non-experimental longitudinal research designs. The results from this research will potentially be beneficial in the treatment of alcohol use disorders to determine if impulsivity is a personality dimension that should be targeted in treatment.},
  note = {Poster; booktitle inferred},
}

@inproceedings{satel2012sensory,
  title = {Sensory and motor mechanisms of oculomotor inhibition of return},
  author = {Satel, Jason and Wang, Z. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {We propose and simulate, with a dynamic neural field model, two mechanisms underlying inhibition of return (IOR) in the oculomotor system: sensory and motor. Reflecting sensory adaptation (or habituation), repeated visual stimulation results in a reduction of visual input to the superior colliculus (SC); consequently, saccades to targets which appear at previously stimulated locations will have longer latencies than those which appear at unstimulated locations. In contrast, the execution of a saccade results in asymmetric activation in the SC; consequently, saccades which reverse vectors will have longer latencies than those which repeat vectors. In the IOR literature, these two mechanisms correspond to IOR effects observed following covert exogenous orienting and overt orienting in the absence of peripheral stimulation, respectively. We predict that these two independent mechanisms will have additive effects; a prediction that is confirmed in a behavioral experiment.},
  note = {Poster; booktitle inferred},
}

@inproceedings{pacia2012unloading,
  title = {Unloading: The effect of task externalization on memory load and subsequent working memory performance.},
  author = {Pacia, Cressida and Smilek, D.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {For most of us, work and life are fraught with seemingly endless upcoming tasks. According to David Allen, a popular productivity guru, incomplete tasks, whether we are consciously reflecting on them or not, overload our memory. These thoughts consume cognitive resources and negatively impact our performance in everyday life. He proposed that in order to maximize our productivity, we should externalize, or "unload," these tasks that weigh on our minds by writing them down. The present study tests this idea by examining whether writing down our planned tasks (unloading) improves performance on working memory exercises. 36 undergraduate students participated in this study, with 12 participants in each of the 3 conditions: full unload, partial unload, and no unload. All participants completed baseline working memory measures, and then were given a few minutes to think about all of their personal tasks that must be completed in the next two weeks. Then, participants in the full unload condition were instructed to make a list of their upcoming tasks with the understanding that they could keep their list for future reference. Participants in the partial unload condition also wrote out their tasks, but were told that they would not be able to keep the list. Finally, participants in the no unload condition were not asked to do anything further and thus did not have an opportunity to "unload." All participants then completed a second set of working memory tasks. The results showed that participants who wrote things down showed improved working memory, regardless of whether they were allowed to keep the list. Participants who did not write out their upcoming tasks did not show changes in working memory scores. This supports our hypothesis that writing things down positively influences working memory. The finding that no difference was found between the full unload and partial unload conditions suggests that it is the act of removing thoughts that weigh on one's mind that affects performance, not the creation of a reliable memory aide. While discussion focuses on outstanding issues to be addressed, the present findings suggest that individuals could achieve significant cognitive benefits by engaging in a very simple and convenient practice: writing down their upcoming tasks.},
  note = {Poster; booktitle inferred},
}

@inproceedings{good2012changes,
  title = {Changes in Attention Network function in early Parkinson's Disease},
  author = {Good, Kim and Wojtowicz, Magda and Baladi, D. and Lewis, Denise and Burns, L. and Robertson, H. and Fisk, John},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Attention difficulties have been noted in Parkinson's disease (PD), although the exact nature and extent of these deficits, over and above slowed response speed, remain unclear. The Attention Network Test (ANT) is a relatively brief computerized task that measures the functioning of three networks: alerting, orienting and executive control. Abnormal performance in all three attention networks has been previously reported in PD patients. However, because of its design, the ANT does not allow examination of the interactions among attention networks. Moreover, the exogenous and endogenous components of orienting are confounded in this task. In the current study, we investigated the attention network performance in PD patients using a modified version of the ANT, the Attention Network Test of Interactions (ANT-I), which remedies these methodological limitations.Twelve (12) individuals with mild PD (Hoehn and Yahr stages 1-2) and 12 healthy age and education comparable controls completed the ANT-I in addition to other Neuropsychological tests of verbal memory and executive functions. PD participants' overall response speed on the ANT-I was not significantly slower compared to controls (t(22)=1.75, p=ns) although they did demonstrate greater within-subject variability in response speed (t(13.3)=2.45, p<0.04) and more errors (t(12.1)=2.49, p<0.04). A mixed model ANOVA revealed significant main effects for the orienting (F(2,44)=19.2, p<0.0001) and executive networks (F(1,22)=138.5, p<0.0001), but not for the alterting network. In addition, a significant group by orienting by executive network interaction (F(2,44)=4.7, p<0.02) was found with the PD participants demonstrating smaller flanker compatibility effect in the presence of spatial cues. This is the first study to identify attention network dysfunction in individuals with early stage PD using the ANT-I. PD participants did not demonstrate significantly slower overall response speed but did demonstrate greater response speed variability and more errors. In addition, PD participants demonstrated a smaller flanker compatibility effect in the presence of uninformative spatial cues with relatively slower response on congruent flanker trials under these conditions. These findings illustrate the important of investigating interactions between attention networks when attempting to understand the behavioral consequences of neurodegenerative disorders.},
  note = {Poster; booktitle inferred},
}

@inproceedings{gawryluk2012exploring,
  title = {Exploring the value of white matter functional magnetic resonance imaging},
  author = {Gawryluk, Jodie R. and Gunde, Eva and Mazerolle, Erin and Beyea, Steven D. and D'Arcy, Ryan C. N.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Structural MRI is not sensitive to the full scope of white matter (WM) damage in multiple sclerosis (MS), which may explain why lesion volume is poorly correlated with clinical symptoms. To accurately access the total burden of MS, it is necessary to assess functional changes in the WM in addition to structural measures. Functional magnetic resonance imaging (fMRI) is the dominant approach for examining brain function. To date, however, fMRI has only directly been able to measure neural activation in gray matter, and WM function/dysfunction was thought to be inaccessible. Our research group developed techniques that allow for direct measurement of WM activation using fMRI. As an important next step, we determined whether WM activation can be linked to tests measuring WM function. We used an adapted Symbol Digit Modalities Test in a 4T fMRI study. Results from 17 healthy individuals revealed WM activation in the corpus callosum. The findings link our new techniques in fMRI to an established clinical test of WM function.},
  note = {Poster; booktitle inferred},
}

@inproceedings{parker2012using,
  title = {Using mimicry to increase prosocial behaviour in preschoolers},
  author = {Parker, Charlene and Moore, Chris and Hauf, Petra},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The effects of mimicry on children's social and non-social behavior were tested in the current study. Children were randomly assigned to 2 conditions. During the priming phase the experimenter and child each played with an identical set of toys and the experimenter interacted with the child in a specific way. In the mimicry condition, the experimenter played with the same toy at the same time and in the same manner as the child. In the control condition, the experimenter played with a different toy in a different manner than the child at all times. During the testing phase each child performed two tasks in a counterbalanced order: a resource allocation task, and a delay of gratification task. Effects of mimicry on pro-social and non-social behaviors were determined by performance on the resource allocation task and the delay of gratification task, respectively. It was expected that children in the mimicry condition would perform better on the resource allocation task, but that children's performance would not vary between conditions on the delay of gratification task. Results will be discussed with regard to the effects of mimicry on pre-school children.},
  note = {booktitle inferred},
}

@inproceedings{mazerolle2012understandin,
  title = {Understanding why white matter fMRI is scarcely reported: Sensitivity to white matter activation increases with field strength},
  author = {Mazerolle, Erin L. and Gawryluk, J. R. and Dillen, K. and Beyea, S. D. and D'Arcy, Ryan C. N.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Functional magnetic resonance imaging (fMRI) activation in white matter is controversial. Given that many of the studies that report fMRI activation in white matter used high field MRI systems, we investigated the field strength dependence of sensitivity to white matter fMRI activation. Data were acquired during a motor task (finger tapping) at 1.5T and 4T. Group and individual level activation results were considered in both the motor cortex and the posterior limb of the internal capsule. In addition, we also evaluated the temporal signal to noise (tSNR) of the different tissue types as a function of field strength. We found that field strength dependent sensitivity increases were greater for white matter than gray matter. A similar pattern of results was observed for tSNR. We propose that, because physiological noise is lower in white matter than gray matter, field strength related increases in physiological noise might be less problematic for white matter. We further posit that the smaller T2* differences between gray and white matter at 4T compared to 1.5T allow for more uniform sensitivity across tissue types at high field, and conclude that high field MRI may be critical for fMRI studies aimed at investigating activation in both gray and white matter.},
  note = {booktitle inferred},
}

@inproceedings{chevalier2012differences,
  title = {Differences in Canadian and American norms for the WAIS-IV},
  author = {Chevalier, Thérèse M. and Stewart, Garth and Boddington, Meg and Nelson, Monty and Brodie, Norman and McInerney, Robert},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Large discrepancies have been noted between Canadian and American normed scores on the WAIS-IV, particularly for lower functioning individuals. This creates the potential for bias in diagnosis and decision making. To date there has been little research on discrepancies between Canadian and American norms on the WAIS and the validity of the normative data that has been developed from the respective standardization samples. Based on data from 338 individuals who underwent routine neuropsychological testing in Western Canada, this study will examine differences between test scores based on Canadian vs. American norms, and whether demographic variables such as age and education affect this discrepancy. It is expected that the magnitude of difference between American and Canadian IQ scores will be greater for those with IQ scores at the lower extreme than those with average IQ scores, and that other demographic or person variables will contribute to the variance between scores. Preliminary results will be presented.},
  note = {booktitle inferred},
}

@inproceedings{shaw2012optical,
  title = {Optical emissions by insect wing spots},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Butterfly wing spots reflect incident light back out, as visual signals to observers. A small group of flies also developed wing spots in males but these act differently, redirecting sunlight passing through the wing out towards female observers. These spots also fluoresce, but fluorescence is a photon-inefficient process: whether fluorescence emission could be bright enough to be seen above the general background reflection from the wing surface seemed problematic. With UV excitation, blue fluorescence emission in fact added ~44% extra photons atop background (ΔI/I ratio ≈ 0.44); green fluorescence emission was much weaker and red emission, even feebler. The next question, though, is whether fly photoreceptors can even detect this blue emission above background photon noise, at the low levels of illumination present where these flies live -- on north-facing marine cliffs. At the head-to-head distance at which courtship display takes place, a females's view angle is reduced to barely 1°, dictating that only six identically aligned photoreceptors can view his wing spot. In low-level blue illumination, recordings from single photoreceptors in Calliphora to a 1° source establish that a response ΔI/I of only 0.42 can be attained above photon noise. The six aligned photoreceptors have axons that converge into the same synaptic column, however, where they become strongly electrically intercoupled through multiple gap junctions. Electrically averaging six visual responses via these junctions could improve the signal/noise ratio in each axon by up to √6 (2.45-fold). A ΔI/I → 0.17 then might be achievable for the electrical response, good enough to allow reliable detection of a larger optical fluorescence ΔI/I of ~0.44.},
  note = {booktitle inferred},
}

@inproceedings{barresi2012pneumatology,
  title = {Pneumatology and the birth of psychology as an empirical science in eighteenth century Britain},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {During the 18th century, science and religion were often partners in the advance of knowledge and enlightenment. An example of this cooperation occurred in the development of an early modern version of psychology. After the collapse of Aristotelian metaphysics of soul as living principle in the seventeenth century and its replacement with Cartesian metaphysics where the soul became conscious mind, room was made for a novel approach to the investigation of soul. Traditionally, pneumatology, or the science of spirits, focused on metaphysical and religious notions of the human soul, angels & demons, and God. But right from the start in 18th century, there was an understanding that the human soul could be approached naturalistically. Teachers of pneumatology at dissenting religious academies in Britain tracked the development of this new empirical approach to soul as mind throughout the century, and through publications, they also participated in its development.},
  note = {booktitle inferred},
}

@inproceedings{macneil2012heavy,
  title = {Heavy episodic drinking among dating partners: A longitudinal actor-partner interdependence model},
  author = {MacNeil, Matt A. and Mushquash, Aislin R. and Sherry, Simon B. and Stewart, Sherry H. and Mackinnon, Sean P. and Antony, Martin M. and Sherry, Dayna L.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Heavy episodic drinking (HED) is a serious health problem for many young adults. For about two decades, rates of HED have remained consistently high among young adults. Although research has identified a variety of intrapersonal, interpersonal, and environmental contributors to HED, much of the research focuses on intrapersonal factors. Thus, more research is needed to test the role of specific interpersonal factors in HED. This study tests the partner influence hypothesis, which suggests romantic partners influence each other's HED over time. A sample of 208, non-married, heterosexual dating couples completed HED measures at baseline and again 28 days later. Actor-partner interdependence analyses showed significant actor effects, which suggests HED is stable within each partner over time. Additionally, results showed significant partner effects, where HED in both young men and women in romantic relationships positively influenced their partners' future HED over 28-days. Results also suggest both women and men are affected more by their own prior levels of HED than by their partner's prior levels of HED. Nevertheless, small partner effects were observed for both women and men. Results support the partner influence hypothesis, suggesting HED is a behavior maintained, in part, by a pattern of interpersonal influence. These results suggest the importance of considering both intrapersonal and interpersonal factors when developing prevention and intervention programs for HED in young adults.},
  note = {booktitle inferred},
}

@inproceedings{satel2012uncovering,
  title = {Uncovering the neural mechanisms of inhibition of return using event-related potentials},
  author = {Satel, Jason and Hilchey, Matthew and Wang, Zhiguo and Reiss, Caroline and Story, Ross and Klein, Ray},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Inhibition of return (IOR) is a cognitive phenomenon whereby response times are slower to cued as compared to uncued targets at cue-target onset asynchronies greater than ~300 ms. A number of studies have investigated IOR using a traditional cue-target paradigm (where the cue is ignored), while recording electroencephalographic activity. Event-related potential analyses have revealed that amplitudes of the early sensory P1 and the later Nd components are reduced for cued, as compared to uncued targets. In a series of studies expanding on this line of research, we have replicated previous results showing that cueing modulates P1, both when peripheral cues are ignored, and when they are foveated. However, IOR scores only correlated with P1 modulations when peripheral cues were ignored. When central, endogenous cues were mixed with peripheral cues, IOR was only observed for foveated central cues, while P1 modulations were only observed for ignored central cues. Mixing central with peripheral targets eliminated the P1 modulations, but IOR was observed for both target types. Finally, when an eye movement was interposed between cue and target appearance, P1 modulations were only observed for retinotopically cued targets, while the later Nd component was reduced only for spatiotopically cued targets. We propose that P1 modulations are the result of repeated activation in retinotopic maps, while Nd modulations may be a reflection of spatiotopic IOR.},
  note = {booktitle inferred},
}

@inproceedings{brown2012what,
  title = {What are we really measuring in tests of anxiety in mice?},
  author = {Brown, Richard E. and Gunn, Rhian K. and O'Leary, Tim P.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Anxiety in mice is measured in the elevated plus maze (EPM; Hogg, 1996, Pharm Biochem Behav, 54, 21-30); open field (OF; Prut & Belzung, 2003, Eur J Pharm, 463, 3-33); and light/dark box (LDB; Bourin & Hascoet, 2003, Eur J Pharm, 463, 55-65), and studies often use all three (Kliethermes et al., 2005, Neurosci Biobehav Rev, 28, 837-50). We examined anxiety and locomotor behavior in 10 week old male and female mice of 15 inbred strains (129S1/SvImJ, A/J, AKR/J, BALB/cByJ, BALB/cJ, BTBR T+ tf/tf, C3H/HeJ, C57BL/6J, CAST/EiJ, DBA/2J, FVB/NJ, MOLF/EiJ, SJL/J, SM/J and SPRET/EiJ) on the EPM, LDB and OF. Across all three tests we found that (1) measures of locomotion are significantly positively correlated; (2) frequency of defecations are highly positively correlated; (3) behavioral measures of anxiety are poorly correlated, and; (4) within each test, measures of anxiety and locomotion are correlated. In a factor analysis locomotor measures accounted for 22.2% of the variance, whereas anxiety-related measures accounted for only a small proportion of the variance. This analysis casts doubt on the concept of genetically determined strain differences in a "trait" of anxiety and indicates that locomotor behaviors are the most reliable measures of strain and sex differences in these apparatus. This suggests that we must reconsider the concept of strain-specific "anxiety" traits and focus on activity levels. Whether or not newly designed apparatus for measuring anxiety such as the triple-test (Fraser et al., Psychopharm, 2010, 211, 99-112) will help us resolve this issue is being examined.},
  note = {booktitle inferred},
}

@inproceedings{bessey2012sleep,
  title = {Sleep lab adaptation in children with ADHD and their typically developing peers},
  author = {Bessey, Meredith and Richards, Jennifer and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {There are inconsistent findings as to the type and frequency of sleep problems in children with ADHD. High rates of sleep problems are consistently found on parent report, but are not always verified on polysomnography (PSG). It is hypothesized that this discrepancy may be due to differential sleep lab adaptation (i.e., how well or how poorly children adjust to a sleep lab environment). Research has not investigated this specific question, although one study examined changes in sleep patterns from the first to second night of PSG collection and found that children with ADHD demonstrated a stronger first night effect compared to typically developing (TD) children. In the current study, actigraphy variables were compared between the home environment and the sleep lab during PSG collection for children with ADHD (n = 25) and TD children (n = 25). Further, sleep lab adaptation reports from parent, child and PSG Research Assistant (RA) were compared between groups. Actigraphy variables revealed that both groups of children slept for significantly less time in the sleep lab than at home. Additionally, TD children, but not children with ADHD, had improved sleep efficiency in the sleep lab. It was also found that all children had significantly less wake after sleep onset in the sleep lab than at home. Sleep onset latency did not differ across environments and there was no interaction with group. Parents of children with ADHD reported that their children's sleep onset at the sleep lab was atypical. PSG RAs noted more sleep difficulties for children with ADHD, but the children themselves did not report any difficulties. For some sleep variables, data collected in the sleep lab may not be representative of children's sleep in the home environment. Based on actigraphy data there was no differential impact on sleep for children with ADHD, and therefore, sleep lab adaptation is not a likely reason for the discrepancy between parent report and PSG findings.},
  note = {booktitle inferred},
}

@inproceedings{mcwhinney2012spatial,
  title = {Spatial MEG laterality maps for language},
  author = {McWhinney, Sean R. and Bardouille, T. and Newman, Aaron J. and DeBay, D. and Sadler, R. M. and Clarke, D. B. and Esser, M. J. and D'Arcy, Ryan C. N.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Functional neuroimaging has been used with increasing prevalence in recent years as a non-invasive method of language laterality assessment. Historically, laterality of language and memory has been assessed using the intracarotid sodium amobarbitol test (i.e., the Wada test). This is an invasive investigation and provides spatially limited measures of laterality. Despite advances in neuroimaging, recent laterality assessments suffer similar limitations, such as a one-dimensional laterality index (LI). This oversimplification has neglected the potential value of functional neuroimaging. We demonstrated a language laterality assessment that uses magnetoencephalography (MEG) to produce "complex laterality vectors". These values were used to create "laterality maps" that indicate both the strength of activity and degree of laterality for a function. To demonstrate, language was assessed in healthy controls and in patients with epilepsy. It was shown that laterality maps provide information about the spatial characteristics of language activation, and that this information would be unavailable using the traditional LI. Importantly, it was possible to differentiate between weak LI scores that resulted from weak vs. strong bilateral activation, as well as strong LI scores that resulted from weak vs. strong unilateral activation. The ability to clarify these ambiguous situations, and to display complex patterns of activation, make laterality maps an ideal representation of language dominance.},
  note = {booktitle inferred},
}

@inproceedings{quinlan2012musicality,
  title = {The Musicality Effect},
  author = {Quinlan, Chelsea K. and Taylor, Tracy L.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The purpose of this study was to explore whether or not singing a word would result in greater memory than simply reading a word aloud and/or reading a word silently. In order to explore this research question, we conducted three experiments, each of which consisted of a study phase followed by a test phase. In the study phase, participants were presented with words that they were instructed to sing, read aloud, or read silently. In the test phase, participants were tested using yes/no recognition. When the instruction condition (sing, read aloud, read silently) was manipulated within-subjects, we found that there was greater memory for words that were sung compared to words that were read aloud as well as words that were read silently. Also, we found that there was greater memory for words that were read aloud than words that were read silently (i.e., production effect). However, when the instruction condition was manipulated between-subjects, we found that there was no memory difference for words that were sung, read aloud, or read silently. Together, these findings suggest that while singing may be an effective memory strategy, it may require that words that are sung be intermixed with words that are read aloud and/or words that are read silently. We will discuss these findings in terms of relative distinctiveness.},
  note = {booktitle inferred},
}

@inproceedings{roddick2012assessment,
  title = {Assessment of olfactory learning and memory, reversal learning, and olfactory sensitivity in the 5xFAD mouse model of Alzheimer's disease},
  author = {Roddick, Kyle M. and Schellinck, Heather},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {As a result of continued advances in genetic engineering techniques, an ever-increasing number of mouse models of Alzheimer's disease (AD) are being developed. Before these animals can be used to assess the potential of novel drug therapies, the validity of the models must be tested. Despite the well-known capacity of rodents for learning olfactory tasks, the majority of memory tests rely upon visual cues. Here we report on the use of an operant-olfactometer to assess olfactory learning and memory in 6 month old 5xFAD mice. The transgenic mice showed no deficits compared to wildtype littermates at this age in either an olfactory discrimination task, or a reversal learning task. An olfactory sensitivity task found impaired performance in transgenic mice, as well as greater sensitivity in female mice than male mice.},
  note = {booktitle inferred},
}

@inproceedings{clouter2012effects,
  title = {Effects of training on a dual n-back task on the components of working memory and fluid intelligence},
  author = {Clouter, Andrew and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Objective: To investigate the specificity and generalizability of working memory training. Design: Randomised, single blind, controlled design. Setting: University research laboratory and community. Participants: 24 healthy participants (ages M = 20.7, SD = 2.5 yrs; 5 male, 19 female). Five withdrew due to time constraints. Interventions: Dual n-back training group: Five daily training sessions each week for three weeks. Sessions consisted of 20 blocks of an adaptive dual (visual and auditory) n-back task. Active control group: Same training program without adaptive progression to harder levels. Main Outcome Measures: Cattell's Culture Fair Intelligence Test (IQ); Monty Hall problem and Stroop task (executive function); Operation Span and Symmetry Span (verbal and spatial working memory span). Results: Operation Span and Symmetry Span: Only the training group showed a significant improvement, p < .0001, 95% CI [11.68, 30.17] and p = .0465, 95% CI [0.18, 26.76], respectively. No other measure showed a significant benefit from active training. Conclusions: Neurological disease and injury frequently affect working memory and dual task performance, leading to reduced quality of life and creating a need for effective cognitive interventions. In this study, dual task coordination benefited from training, but these benefits did not generalise to executive functions or fluid intelligence as previously reported. However, individual differences in performance on the training task has been shown to impact transfer of training benefits. More research is needed to identify critical factors that underlie generalizability of working memory training. Investigation of individual differences in the study is ongoing.},
  note = {booktitle inferred},
}

@inproceedings{green2012prenatal,
  title = {Prenatal psychological stress and postnatal environmental enrichment have age and sex specific effects on the development of anxiety/depressive behaviours and changes in glucocorticoid receptors},
  author = {Green, Amanda D. and Mungovan, Kal and MacLean, Meagan and Esser, Michael J. and Perrot, Tara S.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Stressful events during gestation can cause sex-specific effects on brain and behavior, and may contribute to some of the differences observed in adult stress responding and psychopathology. We investigated the impact of a novel prenatal psychological stress (predator exposure - PE), in the rat, 3x daily during the last week of gestation on juvenile (PND15) and adult behaviours related to social interaction (play behaviour), anxiety (open field test - OFT) and depression (forced swim test - FST and sucrose preference test), and the role of postnatal environmental enrichment (EE) to prevent/rescue these changes. Adult animals were sacrificed and brains were collected for western blot analysis of glucocorticoid (GR) and mineralocorticoid receptor (MR) levels. In the juvenile OFT, PS females spent less time than males in the open field center and EE removed this difference. In the juvenile FST, PE or EE pups showed less immobility than controls. Juveniles exposed to either PE or EE also showed less antisocial behaviour, but with both PE and EE, anti-social behaviour increased. In the adult sucrose preference test, PE females consumed significantly less sucrose than all other groups, and this correlated with increased immobility in the juvenile FST. Analyses of hippocampal GR and MR levels are ongoing. Both PE and EE altered anxiety and depressive behaviours, but the effects were highly age and sex specific. Some alterations indicative of pathologies (OFT anxiety in males or adult female depressive behaviors) caused by the early environment did not manifest until adulthood, while changes caused by early EE (decreased OFT anxiety in males, decreased FST immobility in females) were lost in adults. Together, these results suggest an important, though complex, role for early life psychological stressors and early life behaviours in creating an adult vulnerability to anxiety or depressive disorders.},
  note = {booktitle inferred},
}

@inproceedings{fairn2012immune,
  title = {Do immune-challenged crickets change behaviour to conserve resources and avoid predators?},
  author = {Fairn, Evan R. and Adamo, Shelley A.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Vertebrates mounting an immune response often exhibit a suite of behavioural changes (i.e. sickness behaviour) that can include a decrease in food intake, water intake, reproduction, locomotion, and exploratory behaviour. It is believed that sickness behaviour is adaptive, possibly functioning to conserve resources required to survive infection and reduce exposure to predators when in a debilitated state. Little is known about whether immune-challenged invertebrates exhibit similar behavioural changes. Here, we investigated sickness behaviour in the Texas field cricket Gryllus texensis. Consistent with a previous study, we found that this species decreases feeding, but not drinking, during an immune response. We found no evidence that immune challenge affects locomotion, exploratory behaviour/boldness in a novel environment (with or without simulated predator), or propensity to engage in courtship. Decreased motivation to feed during an immune response could result in reduced energy expenditure and decreased exposure to predators by decreasing foraging. However, our results suggest that this species does not employ a broad predator avoidance and energy conservation strategy when immune-challenged.},
  note = {booktitle inferred},
}

@inproceedings{wilson2012effects,
  title = {The effects of distracters on working memory},
  author = {Wilson, Ryan and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Working Memory (WM) is used to hold and manipulate information in an active, short-term store while performing a range of daily tasks such as reading, mental arithmetic and problem solving. These tasks must be completed in the face of distractors, which appear to become increasing difficult to ignore as we age (e.g. Gazzaley et al., 2005). The purpose of this study was to investigate the effect of distractors on both the maintenance and manipulation components of WM performance. We predicted that WM performance would be most disrupted by distractors when the task required continuous updating of the active short-term store. Ten healthy young adults (mean age = 24.2; 6 female) completed a series of n-back WM tasks designed to assess the effects of task-irrelevant distractors on WM performance. Analysis of both reaction time (RT) data and accuracy was conducted using mixed effects modeling with updating (maintenance vs updating) and distractors (present vs not present) treated as fixed effects. Accuracy was high across all conditions (94-96%). The presence of task-irrelevant distractors increased RT in both maintenance (RT=514ms vs 634ms for absent vs present distractors respectively) and updating n-back tasks (679 ms vs 769 ms, respectively), although the increase was smallest during the updating tasks. Contrary to our prediction, these results suggest that increased task difficulty can reduce attention to task irrelevant distractors, perhaps due to the need for greater attentional control. These data suggest that the role of distractors in WM deficits that accompany aging or brain damage deserve investigation.},
  note = {booktitle inferred},
}

@inproceedings{hassall2012what,
  title = {What do I do now? Exploration and exploitation in a sequential risk-taking task?},
  author = {Hassall, Cameron D. and Holland, Katharine and Pleskac, Timothy J. and Krigolson, Olave E.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Effective decision making requires exploring new options and exploiting previous learning. Many experimental tasks fail to capture the exploration/exploitation trade-off, either because learning occurs too rapidly, or because they lack valid operational definitions for these behaviours. The Balloon Analogue Risk Task (BART: Lejuez et al., 2002) requires sequential gambles from participants. Each subsequent gamble involves more potential payout, but also more risk. Although BART responses may become somewhat automatic with learning, participants will occasionally pause to assess whether or not they should continue to gamble. These and other behavioural findings suggest that the BART may be a good candidate for studying the exploration/exploitation trade-off (Wershbale & Pleskac, 2010). Here, we reproduced earlier results by Pleskac et al. (2009) showing a decrease in exploration over time. In other words, participants became less likely to deliberate over their decisions (explore) as they became more familiar with the BART. Furthermore, we observed an event-related potential (ERP, specifically P300) difference between exploration and exploitation trials. Finally, we found that the feedback error-related negativity (fERN), an ERP component sensitive to rewards and punishments, was enhanced for higher-valued gambles, indicating that participants maintained an accurate representation of potential reward. Taken together, these results suggest a possible neural marker of exploration that is validated by both behavioural and neuroimaging data.},
  note = {booktitle inferred},
}

@inproceedings{sparks2012lexical,
  title = {Lexical stress and the Missing Letter Effect: The roles of grammatical and orthographic stress cues during reading},
  author = {Sparks, Erin and Deacon, Helene and Tucker, Rebecca and Carver, Sally},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Although English does not explicitly encode stress in its writing system, it does contain regularities that probabilistically cue stress placement. One regularity is grammatical: nouns tend to be trochaic (DOCtor); verbs tend to be iambic (enJOY). A second regularity is orthographic: certain letter patterns are associated with either trochaic or iambic stress. In two experiments, we explore the role of these stress cues in skilled reading using the Missing Letter Effect (Corcoran, 1966). Test words are embedded in passages that participants read while simultaneously detecting a target letter. We then compare letter detection rates in words whose stress cues are either consistent (trochaic nouns/iambic verbs; trochaic words with trochaic cues) or inconsistent (iambic nouns/trochaic verbs; trochaic words with iambic cues) with their stress patterns. We expect fewer letter detections in the consistent conditions, reflecting more efficient processing of these words than those with inconsistent stress cues.},
  note = {booktitle inferred},
}

@inproceedings{joshi2012impact,
  title = {The impact of repeated stress on memory and models of affect in male and female rats reared in isolation for a short period during adolescence},
  author = {Joshi, Namrata and Perrot, Tara and Leslie, Ron},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Repeated stress causes enduring effects when it occurs during post-embryonic development. Brain regions undergoing rapid maturation during this period are particularly impacted and the problem is believed to be exacerbated in case of limited or no social support. The rearing of animals in isolation during this period of development has been used to model such an absence of social support and has been shown to cause enduring changes in response to stress including behaviour representative of certain affective disorders. I have investigated the effect of isolating rats for a brief period of time during adolescence upon the changes produced by the stress of repeated exposure to cat odour administered during the same period (i.e. predator odour stress). Previous experiments with this model of chronic stress indicated that some effects were produced on acoustic startle modulation, while memory and behaviours representative of affective disorder were largely unaffected. I hypothesize that rearing animals in isolation produces more of an increase in stress-related disruption compared with the effects of predator odour stress alone. Performance in the elevated plus maze was examined in order to determine levels of anxiety-like behaviour. The sucrose preference test was used to assess depression-like behaviour and a novel object recognition test was used to assess memory in order to monitor hippocampal function. Preliminary results indicate little or no effect of isolation on the changes brought on by stress exposure.},
  note = {booktitle inferred},
}

@inproceedings{klein2012flavors,
  title = {On the flavors of inhibition of return (IOR)},
  author = {Klein, Raymond M. and Hilchey, Matthew and Satel, Jason},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {In her 1997 dissertation, using variants of the model task pioneered by Posner, Tracy Taylor (Taylor & Klein, 2000) discovered 2 distinct "flavours" of IOR. When saccadic responses were precluded, the effect of IOR was confined to the input pathway (attentional/perceptual favour); yet, when saccadic responses were executed (either to the cue or target, or both) IOR was confined to the output pathway (decision/motor flavour). Recent work from our laboratory validates this important distinction, explores its implications, and identifies the motor flavour as the type of IOR that has been hypothesized to be a novelty seeking foraging facilitator.},
  note = {booktitle inferred},
}

@inproceedings{pereira2012does,
  title = {Does ADHD affect perception of emotions in others?},
  author = {Pereira, Josh and Hamon-Hill, Cindy and Barresi, John},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {According to Barkley (1997), impaired social skills associated with Attention Deficit Hyperactivity Disorder (ADHD) are due to higher levels of emotional reactivity, with no disruption in their perception of others' emotions. However, in recent reports adults with ADHD displayed less accuracy than control participants in recognizing facial affect (Friedman et al. 2003; Rapport et al. 2002) and a negative association between accuracy in emotion recognition and experienced emotion (Rapport et al. 2002). We tested emotion recognition in adults with ADHD using an ecologically valid paradigm and observed no difference in accuracy between the control and clinical group. We did observe slower reaction times for the ADHD group, p = .003, on static but not dynamic facial stimuli, p = .01. Higher reported levels of experienced emotion for the ADHD group, relative to controls', were negatively associated with reaction time, r =-.452, p = .01, but not with accuracy. Instead, decreased accuracy was associated with difficulty in identifying emotions for the ADHD group, r = -.417, p = .04. We suggest our results can be explained by testing with naturalistic stimuli that do not require emotional labeling.},
  note = {booktitle inferred},
}

@inproceedings{mclarnon2012misuse,
  title = {Misuse of prescription anxiolytics and sedatives in the community and among clients of substance use treatment programs in the HRM},
  author = {McLarnon, Megan E. and Barrett, Sean P.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Misuse of prescription drugs is a widespread phenomenon in Canada and a topic of increasing concern among health care providers. While anxiolytic and sedative medications have important therapeutic uses in the treatment of anxiety and insomnia, these substances have psychoactive properties that render them vulnerable to misuse. Understanding the correlates and contexts of misuse is essential for developing targeted treatment and prevention strategies. This presentation will summarize a series of studies conducted with adults in the Halifax Regional Municipality, including community samples and those drawn from local substance use treatment programs. Collectively, these studies show that anxiolytic and sedative misuse is a heterogeneous phenomenon, with varying patterns of use linked to individuals' motivations for misuse. Furthermore, these investigations demonstrate that prescription anxiolytic and sedative misuse is linked to individual-level factors (e.g., personality dimensions, past history of substance use) as well as to medication-related variables (e.g., type of anxiolytic or sedative, prescription status). By improving our understanding of prescription anxiolytic and sedative misuse and providing a more comprehensive characterization of this important public health issue, these findings have practical implications in both clinical and research contexts.},
  note = {booktitle inferred},
}

@inproceedings{stahlschmidt2012food,
  title = {Food availability and the tradeoff between reproduction and immune function},
  author = {Stahlschmidt, Zachary and McKee, Robbin and Adamo, Shelly},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Reproduction and immune function are both integral fitness components in many taxa--from plants to humans. Life history theory predicts investment into one of these traits comes at a cost to the other trait (e.g., high fecundity is associated with reduced immune function). Two hypotheses have been proposed regarding the proximate mechanisms underlying this tradeoff. According to the classic "resource allocation" hypothesis, organisms with a finite number of resources can optimize either reproduction or immune function, but not both. The "pleiotropic effects" hypothesis asserts that each trait involves mechanisms that are detrimental to the other trait independent of resource availability (e.g., oxidative bursts used during immune activation destroy pathogens but may also damage reproductive tissue). To address these hypotheses, we used adult female Texas field crickets (Gryllus texensis) and a two-factorial design: immune challenge (chronic injections of heat-killed bacteria, chronic sham treatment, or unhandled control) and food availability (ad libitum or intermittent access to food). We discuss the effects of these two factors on body mass, fecundity (number and size of eggs, hatching success, and hatchling phenotype), and the ability to withstand oxidative stress. Together our results clarify the importance of resource availability and pleiotropic effects in the widespread tradeoff between reproduction and immune function.},
  note = {booktitle inferred},
}

@inproceedings{levesque2012there,
  title = {Is there a 'crow' in 'crown'? Evidence for direct and phonologically-mediated connections between orthography and semantics in developing readers},
  author = {Levesque, Kyle and Deacon, Hélène},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {An important goal of reading development is the ability to access meaning quickly and efficiently from orthography. In the current study, we explored whether children are sensitive to embedded sub-word orthographic patterns via a semantic competition paradigm. Using this paradigm, 108 children in grades 2 and 3 were asked to make "yes/no" category decisions to items. Participants' responses to the same words were compared across congruent ("is battery related to the category vehicles?") vs. incongruent conditions ("is battery related to the category animals?"), both of which require a "no" response, yet differ in respect to whether the embedded sub-word is related to the given category (bat in battery is related to animals but not vehicles). Semantic competition effects were observed; children were less accurate to categorize words when the embedded word was related in meaning to the category (incongruent items) as opposed to when the sub-word shared no meaning with the category (congruent items). These findings demonstrate that connections between orthography and semantics are formed in the early stages of reading development and that, even in young readers, semantic information is activated from sub-word orthographic patterns. Furthermore, semantic interference effects were most evident when sub-words shared the same pronunciation as their carrier words (e.g., bat in battery), supporting the notion that phonology plays an important role in the orthography-to-semantics connections of developing readers.},
  note = {booktitle inferred},
}

@inproceedings{salviano2012effects,
  title = {Effects of social separation on depression, anxiety, learning, and memory in the 5XFAD mouse},
  author = {Salviano, Marcelo F. and Goad, B. E. and Gunn, Rhian K. and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {In humans, loneliness increases the risk of depression and of late-life dementia (Wilson et al, 2007, Arch. Gen. Psychiatry 64, 234-40). Social isolation also increases depressive-like behavior in female C57BL/6J mice (Martin & Brown, 2010, Behav. Brain Res. 207, 196-207). The aim of this study was to investigate the effects of social separation on behavior of male and female 5XFAD mice and their B6SJL wildtype (WT) littermates. Mice were housed in same-sex littermate groups until five months of age and then half were separated for one month before testing. Separated females, but not males, had reduced weight gain and increased wildness scores. Separation increased the frequency of bouts of immobility in the tail suspension test for both males and females. Separation did not affect measures of activity in the elevated plus maze or light-dark box but female 5xFAD mice showed less anxiety than WT females. There were no effects of separation on learning or memory in the Morris water maze, but separated mice showed less freezing in the contextual memory test. These results indicate that social separation results in an increase in depressive-like behavior in female mice but does not affect measures of activity, anxiety, spatial or conditioned fear memory. Although females seem more sensitive to the effects of social separation than males, the 5XFAD mice do not seem more sensitive than their WT littermates.},
  note = {booktitle inferred},
}

@inproceedings{singh2012effect,
  title = {Effect of L2 proficiency on modulating oculomotor control in Hindi-English bilinguals},
  author = {Singh, Niharika and Mishra, Ramesh},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The cognitive impact of bilingualism has recently attracted attention of many researchers. Bilinguals' performance on several non-linguistic interference task , using manual response, have indicated that bilinguals posses better executive control as compared to monolinguals. We wanted to determine whether similar bilingual advantage would result in an overall saccade response using an oculomotor non-linguistic Stroop task and how proficiency modulates such advantage. The high proficient bilinguals showed overall faster saccade latency on all the trial types than the low proficient bilinguals thus providing evidence for domain -general advantage extending to the oculomotor control in the bilinguals},
  note = {booktitle inferred},
}

@inproceedings{schlaginweit2012impact,
  title = {The impact of nicotine lozenges and stimulus expectancies on cigarette craving},
  author = {Schlaginweit, Hera},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Cigarette craving plays an important role in the outcome of cessation attempts. Craving arises during nicotine abstinence, yet non-nicotine factors such as stimulus expectancies, beliefs about the effects of a substance, also play an important role in craving and cessation. The current study will use a balanced placebo design to examine the impact of nicotine and stimulus expectancies on cigarette craving. 52 male and 52 female smokers will be divided into two groups, a nicotine lozenge and a placebo lozenge group. Within each group, half the participants will be correctly informed of the lozenge type received, while the other half will be deceived about lozenge type received. Following lozenge consumption craving will be assessed, participants watch two 2-minute video clips (a neutral and a smoking cue), and craving will be reassessed. A two-way mixed measures analysis of variance will be conducted to determine whether nicotine and stimulus expectancies have differing effects on cigarette craving. It is hoped that this research will lead to a better understanding of factors, such as craving, impeding and facilitating successful smoking cessation, even when aided with a nicotine replacement therapy, such as the nicotine lozenge.},
  note = {booktitle inferred},
}

@inproceedings{kintzel2012ready,
  title = {Ready, set, point! The effects of alertness on prism adaptation in healthy adults},
  author = {Kintzel, Franziska and Ishigami, Yoko and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {One therapeutic approach for patients with spatial neglect is prism adaptation (PA), which targets the orienting deficit underlying neglect. Evidence suggests that alerting and orienting functions interact. Alerting tones reduced patients' abnormal orienting bias, measured by temporal order judgments. We examined the interaction of alerting with orienting during a PA procedure. Ten healthy young participants each in 3 conditions were tested: PA only, PA + alerting tones, and control group. Outcome measures included 3 subjective-midline tasks (SMTs), and visual search (VS). During the adaptation period, participants pointed towards targets while wearing clear or prismatic goggles that shifted the visual field rightwards. Warning tones were presented on 25% of trials in the PA + alerting condition. With ANT-I as pre-test, we validated the alerting effect by using similar warning cues. Preliminary results showed typical after-effects of PA in PA conditions on SMTs, but not on VS. Alerting cues either increased or decreased SMTs after-effects, depending upon whether the task was visually guided. Thus, interaction between alerting and orienting appears complex, and alerting seems to enhance responses similar to ones given during PA.},
  note = {booktitle inferred},
}

@inproceedings{easy2012interactions,
  title = {Interactions between the immune response and stress response in insects (cricket, Gryllus texensis): Conflict and collaboration},
  author = {Easy, Russell and Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Immune responses and stress responses often conflict when they occur simultaneously, leading to immunosuppression. In this study we examine some of the molecular underpinnings of these interactions. We examine the effect of both the immune response and stress response on the expression of heat shock protein 90 (Hsp90), glutathione-s-transferase (GST) and nitric oxide (NO) synthase gene expression using quantitative PCR. We examine the effects on gene expression in the fat body, a tissue important for both the stress and immune responses in crickets. Hsp90 is a protective chaperone molecule and increases in response to heat stress 100 fold compared to control animals. GST is part of a class of enzymes involved in detoxification of oxidative stress products. It is upregulated 50 fold, compared to non-injected animals, when crickets are injected with paraquat, a toxic pesticide. Following an immune challenge with heat killed Serratia marcescens Hsp90 is upregulated 21 fold at 3 hours and 100 fold at 12 hours and drops to 60 fold at 24 hours compared to non-challenged animals. There is a 2 fold upregulation of GST at 3 hours but no change at 1, 6, 12 or 24 hours. The enzyme NO synthase, which produces NO, is upregulated 5 fold at 24 hours compared to non-injected controls. The effects of acute stress, and acute stress in combination with an immune challenge, on gene expression will be discussed.},
  note = {booktitle inferred},
}

@inproceedings{tanmacneil2012individual,
  title = {An individual differences approach to understanding predictors of first-year undergraduate students' reading ability},
  author = {Tan-MacNeil, Kim and Deacon, Hélène and Noble, Annie},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {There is a need for research with adults that explores the factors that determine individual differences in reading ability. This would offer a key test of the lifespan-applicability of reading development models (e.g., Ehri, 2009; Share,1995) from an individual differences perspective. We examine how three key reading-related variables -- phonological awareness, morphological awareness, and orthographic processing -- predict first-year undergraduates' performance on word reading, reading comprehension, and ecologically valid measures of reading. 120 students completed a range of standardized and experimental measures of reading outcomes. Hierarchical multiple regression will be used to evaluate how phonological awareness, morphological awareness, and orthographic processing independently and together predict reading ability in adults. This research will evaluate, for the first time, the combined and independent effects of these variables on adult reading ability, and contribute to our understanding of reading across the lifespan.},
  note = {booktitle inferred},
}

@inproceedings{nealis2012narcissistic,
  title = {Narcissistic perfectionism: A framework for understanding grandiose, entitled, demanding and critical people},
  author = {Nealis, Logan J. and MacNeil, Matthew and Smith, Martin and MacLean, Stephane and Ramasubbu, Cynthia and Sherry, Dayna L. and Stewart, Sherry H. and Sherry, Simon B.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Some types of perfectionism (e.g., self-critical perfectionism) are well-defined by theory and well-supported by evidence (McGrath, Sherry, et al., 2012), while others are poorly understood. Though the connection between narcissism and perfectionism is occasionally discussed in passing (Sorotzkin, 1985), sustained theoretical commentary or empirical research on this topic is scarce. The present study tested the factorial validity of the narcissistic perfectionism construct, a hypothesized constellation of traits involving narcissistic grandiosity, a sense of entitlement, unrealistic demands for others, and intense criticism of others. Participants (N = 323) completed questionnaires measuring traits of interest (e.g., Hewitt & Flett, 1991; Raskin & Terry, 1998). Confirmatory factor analysis indicated the hypothesized measurement model for narcissistic perfectionism fit the data adequately, thereby supporting the factorial validity of the narcissistic perfectionism construct. Discriminant validity analysis also indicated narcissistic perfectionism is meaningfully distinct from existing measures of self-critical perfectionism. The present study advances understanding of the narcissistic style of perfectionism by articulating and by quantifying the underlying structure of narcissistic perfectionism, including what factors contribute to this constellation of traits and the relative importance of each trait.},
  note = {booktitle inferred},
}

@inproceedings{korgan2012effects,
  title = {Effects of prenatal stress and environmental enrichment on juvenile temporal lobe epilepsy},
  author = {Korgan, Austin and Green, Amanda and Perrot, Tara and Esser, Michael},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Epilepsy is prominent in the general population, affecting ~1-2% of the population worldwide. Febrile seizers, provoked by fever, are common among children, though normally these episodes are mild and do not result in prolonged deficits. However, prolonged or atypical febrile convulsions can have a long-term impact, including increased risk of medial temporal lobe epilepsy (TLE) and damage to limbic system structures. The objectives of the current study will attempt to identify interventions that minimize the effects of febrile convulsions. Using an ethologically relevant predator exposure, we subjected pregnant Sprague-Dawley rats to regular elevations in prenatal glucocorticoid levels. Postnatal environmental enrichment was then utilized as a potential moderator of any prenatal effects. Then, on PND 14, LPS and kainic acid induced febrile seizures were observed for behavioral measurement. Initial results show strong dam dependent effects of seizures on behavior, Fos immunoreactivity and glucocorticoid levels.},
  note = {booktitle inferred},
}

@inproceedings{davidson2012validating,
  title = {Validating the behavior rating inventory of executive functioning for children with ADHD and their typically developing peers},
  author = {Davidson, Fiona and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Many children with Attention-Deficit/Hyperactivity Disorder (ADHD) display impairments in executive functioning (EF), particularly working memory and response inhibition. The Behavior Rating Inventory of Executive Functioning (BRIEF) has been widely used both clinically and in research for measuring EF in children with ADHD, despite the fact that it has not been validated against objective neuropsychological measures of EF. Therefore this study will examine the concurrent validity of the BRIEF (both parent and teacher ratings) compared to performance-based neuropsychological measures of EF. This will be examined for both children with ADHD and their typically-developing (TD) peers. The four EF domains of interest are: working memory, planning, inhibition, and set shifting. The sample will include children with ADHD and typically developing children matched for age and sex, between the ages of 8 and 12 years. It is expected that children with ADHD will be rated by parents and teachers as having more EF problems, and will also demonstrate more EF impairments than TD children on objective measures of EF. Additionally, it is expected that ratings from the BRIEF will correlate with scores from the performance-based measures of EF. It is hoped that the proposed study will establish the concurrent validity of the BRIEF for measuring EF in children with ADHD and their TD peers.},
  note = {booktitle inferred},
}

@inproceedings{leroux2012impact,
  title = {Impact of menstrual cycle phase on metabolic effects of sleep restriction},
  author = {LeRoux, Amanda},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Spontaneous short sleep and imposed sleep restriction are linked to altered metabolic and endocrine function. Sleep restriction has been associated, for example, with increased cortisol and ghrelin levels, decreased leptin levels and increased appetite. Most of these studies have used male participants, but a few recent studies have confirmed similar findings in women. One such study showed effects of sleep restriction of cortisol and leptin levels, but a retrospective analysis of the data also suggested that menstrual cycle phase was a strong modulator of these effects of sleep loss. These preliminary results suggest that reproductive hormones may have a significant impact on how sleep loss affects the endocrine system in women. In the proposed study, we will recruit ten women at two different stages of their menstrual cycle (mid-follicular & mid-luteal, n=20) and examine whether menstrual phase affects the impact of sleep restriction (3 hrs of sleep for one night) on levels of the hormones cortisol, ghrelin and leptin . A secondary goal is to examine how sleep loss affects self-reports of mood, hunger and food preferences, and whether menstrual cycle phase also modulates these effects. It is hoped that this research will shed light onto information about how normal hormonal patterns during the life cycle of women affect their response to sleep loss. The results will also be important for a better understanding of how sleep loss affects risks for weight gain and hormonal disruption, a well as the development of associated chronic diseases in women.},
  note = {booktitle inferred},
}

@inproceedings{adamo2012women,
  title = {Women in Science, Women in Medicine: Why the difference in retention rates from trainee to practioner?},
  author = {Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Although as many women as men receive a Ph.D. in the biological sciences, more men than women are successful at obtaining a tenure-track position. A number of reasons have been suggested for these 'leaks in the pipeline'. One prominent theory suggests that women drop out of science because of the incompatibility between a scientific career and raising a family. Supporting this hypothesis are data showing that while unmarried women are as likely as men to achieve tenure, women with children were 1/3 less successful. Having children has no apparent effect on the odds that men will gain a tenure-track position. This paper presents a preliminary comparison between the fields of science and medicine in their ability to attract and retain women. The reasons for the difference will be discussed.},
  note = {booktitle inferred},
}

@inproceedings{deacon2012what,
  title = {What children learn as they learn to read},
  author = {Deacon, Hélène and Benere, Jenna and Castles, Anne},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Children bring a number of skills to the process of learning to read, and they learn a great deal from their reading. It has been argued that one of the skills that children use as they read is orthographic processing skill, or the ability to form, store and access representations of words and letter-patterns. We examined this assumption in an empirical study designed to clarify the direction of the relationship between orthographic processing and reading. We conducted a three-year longitudinal study of children from Grades 1 to 3. We included standard measures of orthographic processing skill, at both the lexical and sublexical level, and word reading accuracy, as well as controls of vocabulary, non-verbal reasoning, and phonological awareness. In all analyses, word reading predicted progress in acquiring orthographic processing skill, regardless of grade level or orthographic processing measure. In contrast, orthographic processing skill did not predict progress in word reading. Our results suggest that, between Grades 1 and 3, children acquire orthographic processing skill through their reading and that this ability, as characterized by the most common tasks used to date, does not play an independent role in supporting reading acquisition. We discuss the implications of these findings.},
  note = {booktitle inferred},
}

@inproceedings{williams2012influence,
  title = {The Influence of empathy on prosocial behaviour in children},
  author = {Williams, Amanda and O'Driscoll, Kelly and Moore, Chris},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Although empathy has been linked to prosociality and generosity in adults, the relationship between empathy and prosocial behavior in children is not well understood. It was the objective of the current study to explore the influence of empathy on prosocial behavior in children, and more specifically investigate effects of empathy on sharing and envy. Children between the ages of 5-6 years were randomly assigned to one of two conditions before engaging in a sticker sharing task. In the empathy condition children watched a video of a young girl upset that her dog had gone missing (distressing situation), while in the control condition children watched a video of the same girl preparing for a yard sale (neutral situation). A manipulation check showed that children who had viewed the distressing video rated the emotional state of the child in the video, as well as their own emotional state, more negatively than those who had viewed the neutral video. When asked to allocate resources between self and the child in the video, it was found that children in the empathy condition made more prosocial allocations; more often sharing, and less often withholding benefits, than those in the control condition.},
  note = {booktitle inferred},
}

@inproceedings{cowpersmith2012inhibition,
  title = {Inhibition of return: A simple motor execution bias},
  author = {Cowper-Smith, Chris D. and Eskes, Gail E. and Westwood, D. A.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Inhibition of return (IOR) is thought to improve the efficiency of visual search behaviour by biasing attention, eye movements, or both, toward novel stimuli. Previous research suggests that IOR might arise from sensory, attentional or motor programming processes. In the present study, we were interested in determining if IOR could instead arise from a simple late-stage motor output bias, independent from effects on earlier processes. Participants made consecutive saccades (from a common starting location) to central arrowhead stimuli. We removed the possible contribution of sensory/attentional and motor preparation effects in IOR by allowing participants to fully prepare their responses in advance of an execution signal. When responses were delayed to allow response preparation, we continued to observe IOR. Our data therefore provide evidence that IOR can result from a simple motor execution bias that may arise from inhibitory effects on motor output neurons controlling the extraocular muscles directly.},
  note = {booktitle inferred},
}

@inproceedings{newman2012debate,
  title = {DEBATE: Open vs traditional peer-reviewed publishing in science},
  author = {Newman, Aaron and Fawcett, Jon and Lawrence, Mike and Matheson, Heath and more},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The world of publishing, both within academia and more broadly, has been revolutionized by digital technology. With the technology necessary to distribute one's work available to virutally everyone, it is clear that the old paradigms cannot be maintained. At the same time, scientific publishing has a long and proud tradition of curation through rigourous peer review. While few would argue that peer review is a bad thing, we are also aware that peer review has a dark side: irrational reviewers (positive or negative, though we focus more on the latter); coldly rational reviewers who deliberately sabatoge manuscripts to prevent being scoped; editors who lack the expertise to evaluate arguments properly; and the fact that journals deliberately restrict themselves to the publication of the "best" papers in order to improve their reputations, rather than because all rejected papers are "bad" science. As well, in moves reminiscent of the music industry over the last 15 years, we have witnessed academic publishers take coprporate and legislative steps to protect their profit margins at the expense of academic freedom, for instance by requiring libaries to purchase "bundles" of journals at great expense, including journals that the libraries do not want, as well as publishers' support of recent legislative moves in Canada and the US to radically strengthen copyright protection at the expense of academic freedom. Against this draconian landscape, however, academics are faced with the reality that our careers, including hiring, promotion, and funding decisions, hinge not only on how much we publish, but where. In this debate, one side will argue in favour of open publishing and highlight current best practices, while the other side will argue in favour of a relatively unchanged status quo. Arguments and rebuttals will be followed by an open discussion with the audience..},
  note = {QA: needs-split-review; booktitle inferred; Split from T44 at: 'DEBATE: Open vs traditional peer-reviewe'},
}

