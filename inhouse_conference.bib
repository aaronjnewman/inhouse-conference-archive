@inproceedings{klein1989what,
  title = {What the eye tells the brain declines with increasing retinal eccentricity: but does it do so differently for good and poor readers?},
  author = {Klein, Ray and Berry, Glen and Briand, Kevin and D'Entremont, Barbara},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Geiger & Lettvin answer this question affirmatively in a recent article in the prestigious New England Journal of Medicine. In their study normal readers were more accurate at reporting letters near fixation than dyslexic readers, but at greater eccentricities the dyslexics were better. This pattern survived several methodological improvements imposed by psychophysically minded psychologists (W. Dember et al), suggesting a basic difference in the eye-brain interface. Close scrutiny of both studies reveals several methodological flaws, which leave wide open the possibility that the dyslexic and normal readers use different attentional strategies. Following closely the task used by Geiger & Lettvin and Dember, but improving upon their displays to minimize the possibility of strategy differences, we seek to provide a more definitive answer to our title. Other research bearing on the nature of dyslexia may be described.},
  note = {QA: needs-split-review; Split from 32 at: '3 3. Ray Klein'},
}

