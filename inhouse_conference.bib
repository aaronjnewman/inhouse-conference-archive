  booktitle = {Fourth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1978},
  abstract = {The synapses of the perforant pathway from the entorhinal cortex to the fascia dentata are organized in a clearly laminar fashion. Those fibres orginating most laterally in the enterhinal area terminate most distally on the granule cell dendrites, while the most medially originating fibres terminate most proximally. This system has been classically regarded as a functional unit. Physiological studies of short-term synaptic plasticity, however, suggest two functionally dis- crete subsystems. This data is in agreement with recent histochemical studies.},
}

