@inproceedings{darcy1997assessment,
  title = {Assessment of language comprehension with event-related potentials},
  author = {D'Arcy, Ryan},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The objective of the proposed research involves the assessment of receptive language comprehension with event-related potentials (ERPs). While there exists a panoply of electrophysiological investigations oflanguage, recent studies (Byrne et al., 1995; Connolly et al., 1995; Ingles et al., 1996) have adapted standardized neuropsychological measures for computer presentation with ERPs. These investigations have demonstrated that ERP components (e.g., N400 and P300) can be elicited bystandardized test stimuli and thus utilized to evaluate language functions in the absence of a behavioral response. Receptive language dysfunction is frequently noted in aphasic individuals suffering from a stroke, but is not always readily assessable with traditional psychometric measures due to limitations in motoric and communicative responses. Accordingly, the proposed investigation will adapt three prominent neuropsychological tests, the Token Test (De Renzi and Vignolo, 1962), sections of the Western Aphasia Battery (Kertesz, 1979), and a section from the Psycholinguistic Assessment of Language Processing in Aphasia (Kay, Lesser, and Coltheart, 1992). Performance on the computer tasks will be contrasted with the respective standardized tests for validation. It is hypothesized that ERP components will successfully differentiate behavioral responses for test items within an individual's ability, but not beyond The results of this investigation, independent of the outcome, will provide insight into the neurological basis of language and the utility of ERPs in assessment.},
}

@inproceedings{barresi1997becominga,
  title = {Becoming conscious of 'consciousness': Notes for a history of an important psychological concept},
  author = {Barresi, John},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {During the 17th century the term of 'consciousness' suddenly appeared as a psychological concept. Since then this concept has become increasingly important both in the foundations and later developments of 'mental philosophy' and scientific psychology. Although during the heyday of behaviourism it diminished in importance, interest in consciousness has been revived again toward the end of this century. In the present talk I will look at the origins of the use of this term, its ancient sources in Greek and Latin, its major 'discovery' in Descartes, and its later development in the works of Cudworth, Locke, Leibniz, Hume, and others in the late 17th and early 18th century.},
}

@inproceedings{klein1997attentiona,
  title = {Attention (to the moving line): "Where you lead, I will follow".},
  author = {Klein, Raymond M. and Hamm, Jeff P.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {When a line is presented in the vicinity of a recent luminance change (peripheral cue) it is perceived to be drawn over time away from its "cued" end even though the line is actually presented all at once. This study was designed to determine if attention, exogenously attracted to the cue, would come under the exogenous control of this illusory motion and follow the drawn line from its cued end to its terminus. Each trial began with the display of 4 small squares at the corners of an imaginary square centered about fixation. After 750 ms one of the 4 squares brightened briefly (50ms) in the cued conditions. Simultaneous with the offset of the cue a horizontal line was presented joining the upper or lower boxes. After 100 ms one of the 4 squares was transformed into a horizontal or vertical rectangle for 150 ms. The subject's task was to make a horizontal/ vertical decision as rapidly as possible. The different events (cues, lines and targets) were combined factorially so that neither cues nor lines were informative about target location. Responses to targets at an uncued location that was at the end of an illusorilly drawn line were as fast as to targets in the neutral and "valid" conditions, and much faster than the remaining invalid conditions, strongly suggesting that attention follows the motion in the "shooting line" illusion.},
}

@inproceedings{simpson1997integration,
  title = {Integration of Environmental and Intentional Information within the Saccadic Programming System: A Computational Perspective.},
  author = {Simpson, Sol and Trappenberg, Thomas and Klein, Raymond},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Saccadic reaction time (SRT) is influenced by both the observer's environment (exogenous factors) and intentions (endogenous factors). To investigate these two SRT contributions, the time interval between the removal of a fixation point and the presentation of a peripheral target (the Gap Paradigm) as well as the probability of a target appearing at a given location were varied. It was hypothesized that if endogenous information affects SRT within the same functional layer of the saccadic programming system that is responsible for exogenous control (the superior colliculus), the effect of target location information would be significantly larger in conditions where the fixation stimulus was removed prior to target presentation than in conditions where the fixation stimulus remained present following target onset. This interaction was obtained with saccadic but not manual RTs, suggesting that the lateral inhibition of fixation cells in the rostral pole (RP) of the superior colliculus (SC) onto the saccade related cells of the SC may memate the effects of both exogenous and endogenous inputs on SRT. This presentation will attempt to explain this interaction using a computational perspective within which a neural field model of saccadic programming is constrained by recent neurophysiological data 12 1997 In-House Convention},
}

@inproceedings{moore1997word,
  title = {Word learning in the context of referential and salience cues},
  author = {Moore, Chris and Angelopoulos, Maria},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Previous research has shown that word learningcan occur in the context of joint attention, however it remains unclear whether such learningoccurs because the child understandsthe referentialintent of the speakeror because the speaker'sreferentialbehavior tends to make the intendedobject more salient In this work, both referentialand saliencecues were independentlymanipulatedin a study of novel word learning. Eighteen-and 24-month-old children were presented with a novel word in the context of two toys, which could be activatedby remote conttoL In the match condition,the toy which was the target of the adult's referentialbehaviorwas activatedwhile the other was not In the mismatch condition, the toy which was the target of the referentialbehavior was not activatedwhile the other was. Two control conditionshad either both toys simultaneouslyactivatedor neither toy activatedwhile the adult made referenceto one. Comprehensionand productionposttests assessed the extent of acquisitionof the novel word. The results showed that at 24 months children tended significantlyto pick out the target toy in response to the novel word under all conditionsand that there was no significantdifferenceacross conditions. There was also no difference across conditionsin children's ability to produce the novel word appropriately. At 18 months, however, there was a differencein performanceacross conditions. In the mismatchcondition, the children were more likely to pick out the activatedtoy in response to the novel word, while in the other three conditions,they were more likely to pick out the target toy. These results imply that word learningin joint attentionsituationsmay initiallyoccur becauseof the salienceof the target object but soon does occur becausethe child understandsthe referentialintent of the speaker.},
}

@inproceedings{suzannemaclellan1997what,
  title = {What does that Robot want from me now? An investigation of young children's abilities to repair contingent queries.},
  author = {SuzanneMacl..ellan},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The ability of 2-year-oldchildrento respond differentiallyto specificand neutral contingent queries was examinedwith a toy robot as the communicativepartner. 22 children (mean age =2:9 years) were asked contingentqueries immediatelyfollowing 10 of their utterances in a free play session. 5 specific queries (ie."That's a what?") and 5 neutral queries (ie. ''What?") were asked to each subject Children'sreplies were coded to determine the type of response strategy used: repetition;specification; or reformulation.Results revealed that children were significantlymore likely to specifypart of their originalutterancefollowinga specificquery, whereasfollowinga neutral query they were significantlymore likely to repeat their entire utterance. No differenceswere observed in the number of reformulations made. Results will be discussed in terms of the young child's developing theory of mind. Additionalresearch being designed as a follow up to these results will also be discussed.},
}

@inproceedings{elizabethmaclaughlin1997inhibition,
  title = {Inhibition as the Primary Deficit in ADHD},
  author = {Eliz.abethMacLaughlin},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Researchers are continually trying to isolate a core deficit in children with attention deficit hyperactivity disorder (ADHD). Recently, Barkley (1997) proposed that behavioral inhibition was the primary deficit, and that it set the stage for the observed deficits in executive function and response execution in children with ADHD. Pure behavioral measures of inhibition, however, may be confounded by socialization, and offer little in the way of an explanation of the mechanism(s) underlying the behavioral disturbances. Cognitive or attentional inhibition may be a more reliable and valid construct for study. Deficits in this area correspond with evidence suggesting that ADHD may result, in part, from frontal lobe dysfunction. Research on cognitive inhibition in children with ADHD will be reviewed, and further studies will be proposed that could validate and enhance Barkley's model.},
}

@inproceedings{symons1997teaching,
  title = {Teaching Children How to Locate Information: Strategy Instruction for Students in the Elementary School Grades},
  author = {Symons, Sonya and MacLatchy-Gaudet, Heather},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The present study examined the effects of instructing elementary school students how to most efficiently locate information in a children's encyclopedia. The instructional protocol emphasized the importance of using the index, reading the text carefully and self- monitoring. 155 students from grades 3, 4, and 5 were randomly assigned to one of three groups: Strategy for Locating Information (SLI), Strategy for Locating Information without Monitoring (SLI-M), or Non-Instructed Control (CON). Although students in both the SLI and SLI-M groups found more correct answers than those in the CON group, the monitoring component was important in improving search efficiency (as measured by number of correct answers found per minute). Students who received instruction were more likely to use the Index than other students, and they also searched fewer total pages than the CON group.},
}

@inproceedings{brown1997national,
  title = {The National Conference on Psychology as a Science},
  author = {Brown, Richard and McGrath, Pat},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {From 8-11 May, 1997, CPA and BBCS have invited 45 Canadian psychologists to a conference to discuss the future directions in MRC, NSERC and SSHRC funded research. The goal of the National Conference is to "develop a vision of research and training in psychology that is in tune with the increased realization that many of our Society's most pressing needs and exciting opportunities will benefit directly from accurate and sophisticated knowledge of human thought, emotion and behavioural processes". "We must identify research priorities that will allow psychology to make a meaningful contribution to the national research agenda, as described in a recent report on Science and Technology entitled 'Healthy, wealthy and wise: A framework for an integrated federal science and technology strategy'." In brief, the question that we have been posed is: "Whither psychology in the 21st century?".},
}

@inproceedings{fidler1997does,
  title = {Does manipulation of thirst change ethanol consumption by rats anticipating footshock?},
  author = {Fidler, Tara L. and LoLordo, Vincent M.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Rats were given the opportunity to drink ethanol, sucrose or water in a distinctive environment prior to shock sessions in a third environment. Since thirsty rats will learn to consume otherwise aversive fluids when there is no other fluid available we wanted to show that our rats were motivated to consume ethanol for reasons in addition to thirst Therefore on some days the rats had an opportunity to consume water in their home cages prior to being placed in the drinking environment Preliminary results appear to show that water consumption in the drinking environment is more affected by this manipulation than is consumption of ethanol or sucrose. However, fear in the shock box (as measured by bolus production) appears to be differentially affected in the ethanol and sucrose groups.},
}

@inproceedings{forestell1997pitfalls,
  title = {Pitfalls in odour and taste preference conditioning},
  author = {Forestell, C.A. and LoLordo, V.M.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The standard procedure used to condition flavour preferences involves a within subject differential conditioning paradigm in which the cue flavours and the appropriate reinforcers are presented simultaneously. In the ensuing test phase, animals typically show a robust preference for the CS+ which does not readily extinguish. The present research, which investigated the ability of a taste to potentiate the formation of a conditioned odour preference has necessitated several modifications to this standard procedure. These included the use of a reverse order conditioning procedure adapted from Boakes & Lubart instead of a simultaneous procedure, between subjects rather than within subject comparisons, and animals which received restricted rather than ad lib water access. Each of these procedural modifications will be assessed in terms of its influence on our failure to obtain robust odour and taste preferences.},
}

@inproceedings{lee1997effect,
  title = {Effect of Male Removal on Gestation Length and Time of Parturition in Female California Mice (Peromyscus californicus)},
  author = {Lee, Anna W. and Brown, Richard E:},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {California mice are a monogamous species with biparental care (Gubemick & Alberts, 1987, J. Comp. Psychol., 101, 169-177). The presence of the male facilitates reproductive success by increasing pup survival and reducing the female's inter-birth-interval (Cantoni & Brown, Anim. Behav., in press). The present study investigated the effect of male removal on day 32 of gestation on the timing of parturition. When compared to control pairs, females which had their mates removed had a longer gestation length and gave birth later in the day. Possible nemoendocrine mechanisms underlying the effects of the male on the reproductive physiology of the female California mouse will be discussed.},
}

@inproceedings{emsley1997anatomical,
  title = {Anatomical and Neurochemical Characterization of the Development of the Embryonic Brain of Drosophila melanogaster},
  author = {Emsley, Jason G.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Current and proposed research consists of three inter-related projects. Current work involves the production of a detailed, three-dimensional anatomical map of the developing embryonic brain and ventral nerve cord (vnc) of Drosophila. This map will be a detailed template onto which information about cell lineage, gene expression, neurotransmitter expression, and biochemical activity can be mapped. The second phase focusses on localization of serotonergic expression in the embryonic brain and vnc. The expression of nitric oxide (NO) during embryonic neural development will also be characterized. NO is a putative neurotransmitter which has been implicated in neuronal development, death, and plasticity.},
}

@inproceedings{groot1997little,
  title = {A Little Light Learning?},
  author = {Groot, Marleen de and Rusak, Ben},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The circadian system responds directly to biologically relevant environmental stimuli such as the light-dark cycle. A recent study (Stewart & Amir, 1996) showed that an external stimulus that does not induce phase shifts or expression of the immediate-early gene product c-fos in the SCN of rats can be made to do so after being paired repeatedly with a phase-shifting light pulse in a Pavlovian conditioning paradigm. Using appropriate conditioning and control procedures, we are attempting to assess whether this phenomenon is reliable and occurs in both rats and hamsters. Animals were housed in isolation boxes containing an activity wheel, a light source and a fan. Wheel-running activity was monitored throughout the study, and was used as the behavioural measure of circadian phase. The animals were entrained to a standard light dark cycle, and conditioning took place during the dark phase of the cycle. The unconditioned stimulus (US) used was a fifteen minute light pulse, and a twenty minute air disturbance served as the conditioned stimulus (CS). Results of our initial studies will be described.},
}

@inproceedings{thompson1997relations,
  title = {Relations between Benzodiazepine Use, Agoraphobic Avoidance, and Autobiographical Memory in Clinical Anxiety},
  author = {Thompson, Carol and Westra, Henny and Stewart, Sherry and MacDonald, Alan},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The purpose of this study was to investigate overgeneral reporting of past personal events in clinically anxious patients, as a function of benzodiazepine (BZ) use and avoidance of fearful situations. Using the Autobiographical Memory Test, BZ-using anxiety patients, nonmedicated anxiety patients, and controls were asked to recall specific personal memories in response to cue words which varied in emotional valence. Results showed that, among BZ-using patients, more overgeneral memories were recalled in response to negative cues as cumulative BZ dose increased. A positive relationship between overgeneral recall and a tendency to avoid anxiety-arousing situations (as measured by the Mobility Inventory) was also found in the clinically anxious groups but not in the control group. These results suggest that, among clinically anxious patients, overgeneral reporting of past personal events is related to BZ dose and to a tendency to avoid anxiety-arousing situations. Clinical implications of these findings will be discussed. 16 1997 In-House Convention},
}

@inproceedings{rioux1997you,
  title = {Are you feeling childish about your present concerns? Some reasons why.},
  author = {Rioux, David},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {A narrative research methodology developed by H.J.M. Hermans (1992) is being used to investigate relationships between peoples' earliest memories and their present concerns which have been postulated by Adlerian and Cognitive-Perceptual (CP) theories. Adler viewed earliest memories as relatively constant reflections of one's lifestyle, while CP theory predicts shifts in earliest memories with changing present concerns (Bruhn, 1992). Opposing predictions based on these two hypotheses were tested in an experiment involving forty-five students who participated in two sessions separated by a month. In each session they provided narrative descriptions of six earliest memories and six present concerns as well as self-rated affective profiles for each of these life experiences. Comparisons of life experiences and affect profiles over time will address the issue of permanance among earliest memories, where Adler's theory would predict one's very earliest memory to be the same across two sessions and relate more strongly to present concerns than would other memories, and CP theory holds that all early memories are subject to change along with changing present concerns.},
}

@inproceedings{hoffman1997footprints,
  title = {Footprints on the Internet: What do they tell us?},
  author = {Hoffman, Ron},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The Psychology Department home page officially went on the World-Wide Web on November 29th, 1996. The site lives on a server provided by the University Computing and Information Services, and a log is kept of all visits to the pages in the site. Every time a page is visited, information is logged about the visitor. In this talk, we'll have a look at what these "footprints" in the log tells us about who has visited the site, where they come from, and what gets looked at. Secret features of the Psychology site will be revealed. The feedback features of the site will get special attention.},
}

@inproceedings{schmidt1997surveys,
  title = {Surveys and Tests on the Web: A Tutorial},
  author = {Schmidt, Billy},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {As many members of the department are aware, I have created a tool that allows non- programmers to implement surveys and tests electronically on the world-wide web. The tool is freely available to members of the department, and I would like to see it used to benefit researchers at Dalhousie, regardless of whether they use it to collect data from the web populous or internally from subject pool participants. I will demonstrate the creation of a web survey from start to finish, and suggest possible uses within the department},
}

@inproceedings{breau1997predicting,
  title = {Predicting Children's Pain},
  author = {Breau, Lynn},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {This srudy examined the pain experienced by 112 children aged 4 to 6 receiving routine DPTP immunization. Pain during the immunization was measured using the Child Facial Coding System (Chambers, et al., 1996). The Child Facial Coding System is an observational scale used to record the intensity of 13 facial actions believed to be indicative of pain in children. Ratings of one second intervals were made from videotape over a 30 second period which included: 10 seconds prior to injection, 10 seconds during injection, and 10 seconds after injection. After immunization, each child, their parent, and an observer rated the child's pain on a Faces Pain Scale. The adults also rated the child's pain on a Visual Analogue Scale. The results indicate that post- immunization pain ratings were related to: the informant, the sex of the parent, the age of the child, whether the child was on medication during the previous month, whether they were currently on medication, and whether they had previous experience with needles. Principal components analysis of the 13 facial actions resulted in four factors common to all three periods: horizontal mouth movements, open mouth, blinking, and eye squeezing. The relative importance of these factors, however, varied by time period. Finally, different combinations of facial actions and medical history were found to predict post-immunization pain ratings, depending on theinformantandthemeasureused.},
}

@inproceedings{tripp1997what,
  title = {What Hurts and What Helps During Dental Hygiene Treatment?},
  author = {Tripp, Dean and Sullivan, Michael and Neish, Nancy},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Given the lack of research quantifying pain during various dental hygiene procedures, pain and pain coping attempts were explored in 48 patients (27 male, 21 female) undergoing routine dental hygiene treatment Dental anxiety and self-efficacy of pain coping attempts were also explored in relation to pain. The majority of patients (79%) report none or very little pain during clinical procedures. In direct contrast, 21 % of sample reported pain scores that were extreme in comparison to the majority. Empathic discussions with the hygienist, self-distraction from the pain, and information seeking from the hygienist, were the most often employed pain coping strategies. In dividing the sample by pain reports (i.e., low and high pain), no group differences in regards to dental anxiety, age, education, brushing habits, or the degree of tre~tment difficulty were found. However, the low pain group flossed more (t=3.01, l2.,.<.005)and had greater levels of self-efficacy for pain coping attempts (t=2.28, l2.,.<.027)than did the high pain group. There were no differences in how many pain coping strategies were reported between low and high pain groups as well as low and high self-efficacy for pain coping. Results suggest that feelings of personal control during dental hygiene treatment may be a factor in successful pain management. Future research is discussed in terms of other trait-like cognitive factors such as pain catastrophizing.},
}

@inproceedings{mcgrath1997x,
  author = {McGrath, Patrick J. and Romos, Christina and Camfield, Carol and Campbell, Mary Ann and Hennigar, Allan},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Primary caregivers of 20 children (age=14.5 years and recruited, language level=lO months) were and pain, interviewed to recall 2 instances of short sharp and pain, 2 of longer-lasting and reviewed, describe their child's behaviour. Transcribed interviews were and sets of non-overlapping items were developed. Thirty one behaviours were extracted from the interviews. The specific behaviors were often different from one child to another but the classes of behaviors (Vocal, Eating/Sleeping, Socia1/Personality, Facial Expression, Activity, Body and Limbs and validity, Physiological) were common. Relibility of using the checklist on interviews was good (kappa=.77). The checklist has excellent content and will be useful for caregivers of cognitively-impaired, non-communicating children to report on pain behaviors},
  note = {QA: needs-split-review; Split from T37 at: '18 Behaviors caregivers use to'},
}

@inproceedings{honig1997transpositio,
  title = {Transposition of an Intermediate Numerosity Discrimination},
  author = {Honig, W. K. and Matheson, W.R.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Pigeons were trained to respond differentially to an array with a relative numerosity (proportion of red to blue elements) intermediate to that of two other arrays in a successive conditional discrimination, and were then transferred to different sets of numerosities. The mechanism of transfer appeared to be absolute, rather than relational. The procedure was then changed to a simultaneous forced choice of the intermediate numerosity among three arrays. Performance within sessions suggested the operation of a relational process. The apparent discrepancy between the two results, and the relative influence of numerosity and entropy, will be discussed.},
}

@inproceedings{gingras1997spatial,
  title = {Spatial localization in normal and amblyopic cats},
  author = {Gingras, Guy and Mitchell, Donald},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The main deficit in human amblyopia (blunt vision) concerns the coding of space and in particular, the relative localization of image features. This behavioral research project will study spatial localization tasks in normal and amblyopic cats using Gabor stimuli and a jumping stand in order to ascertain if the animal performance is similar to human data Two parameters will be evaluated: the size and the contrast of the stimuli. The ultimate goal of the study is a better understanding of the neuronal mechansims potentially responsible for the visual deficits described in human amblyopia},
}

@inproceedings{watt1997learning,
  title = {Learning Experiences in the Development of Anxiety Sensitivity},
  author = {Watt, Margo C. and Stewart, Sherry H. and Cox, Brian J.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The present study invo~ved a conceptual replication of Anlce Ehlers' (1993) work on panic and childhood learning experiences, but also extended her work by investigating the relationship between these learning experiences and the development of anxiety sensitivity (AS). Five hundred and fifty-one students participated in a retrospective assessment of their childhood and adolescent learning experiences with respect to somatic symptoms. Panic- reporters in the study revealed a pattern of learning history results similar to Ehlers', however, a different pattern emerged in the learning histories of highly anxiety sensitive individuals (HAS). Unlike panickers, and contrary to predictions, the learning experiences of HAS individuals were found not to be specific to anxiety symptoms but involving parental reinforcement and modeling of sick-role behaviour related to somatic symptoms in general. HAS subjects reported both more anxiety and cold symptoms prior to age 18 than individuals with lower levels of AS. In addition, both cold and anxiety symptoms elicited special attention and/or instructions for HAS individuals to take special care of themselves. These findings are contrasted with the results for panickers in the sample who reported learning experiences (modeling and parental reinforcement) specific to anxiety-related symptoms. Purported links between AS, panic, and hypochondriasis are discussed.},
}

@inproceedings{macdonald1997dose,
  title = {A Dose-Response Study of the Effects of Alcohol on the Response to Hyperventilation in High and Low Anxiety Sensitive Participants},
  author = {MacDonald, Alan and Skinner, Michelle and Stewart, Sherry and Conrad, Brent},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Previous research suggests that high levels of anxiety sensitivity (AS; fear of anxiety symptoms) may constitute a risk factor for alcohol abuse. The present study evaluated the hypothesis that high AS levels may heighten risk for alcohol abuse by increasing a person's sensitivity to the stress response dampening (SRD) effects of alcohol, which could negatively reinforce drinking in this population. Additionally, the study investigated whether relatively high doses of alcohol are needed in order to see significant SRD effects among high AS individuals and thus explain their more frequent drinking to the point of legal intoxication. Seventy-seven student participants (39 high AS; 38 low AS) were randomly assigned to one of three beverage conditions: placebo, low dose alcohol, and high dose alcohol. Following beverage consumption and absorption, participants underwent a three minute voluntary hyperventilation challenge to induce bodily arousal symptoms. High AS placebo participants reported greater affective and cognitive reactivity in response to the challenge than low AS placebo participants, indicating increased fear and catastrophising during hyperventilation among sober high AS individuals. Both the high and low doses of alcohol eliminated the differences in responding between AS groups by normalizing the affective and cognitive reactivity of the high AS students to the challenge. However, only high AS subjects administered the high alcohol dose (blood alcohol concentration (BAC) =0.08) showed reduced cognitive and affective reactivity to the hyperventilation challenge when compared to high AS subjects administered placebo. Finally, all subjects (high and low AS alike) in both alcohol conditions showed reduced somatic reactivity to the challenge compared to subjects in the placebo condition. Clinical and theoretical implications of the findings are discussed.},
}

@inproceedings{sun1997looking,
  title = {Looking through the tly's brain - application of confocal laser scanning microscopy to the study of Drosophila development.},
  author = {Sun, X.J. and I.A. Meinenzhagen. Combined with powetful digital imaging techniques, confocal laser scanning microscopy},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {(CLSM) provides unprecedented views of biological specimens. We present here some recent CLSM data to study the development of the brain in the fruitfly Drosophila melanogaster. Using antibodies against the synaptic vesicle protein synaptotagmin, and various other markers, synaptic regions and specific cell types in Drosophila's brain are readily revealed in three dimensions throughout development. This technique reveals new images of, and insights to, the functional architecture and make-up of the brain in this genetically manipulable animal. The use of this technique in genetic screens will be shown by CLSM analyses of structural brain mutants. 20 1997 In-House Convention},
}

@inproceedings{chen1997electrical,
  title = {Electrical- and dye coupling between presynaptic photoreceptor axons in fly visual system},
  author = {Chen, Bin and Shaw, Steve},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Photoreceptors from different facets of the fly's compound eye converge in stereotyped groups of 6, the cylindrical synaptic modules ("cartridges") that make up the first synaptic zone behind the eye (lamina). There they make about 1200 histaminergic synapses to postsynaptic neurons, in big flies. In addition, electronmicroscopy shows that each pair of terminals in the cartridge is interconnected presynaptically by about 30 small maculate gap junctions each, raising the expectation that the 6 contributing photoreceptor axons to a cartridge should be strongly electrically coupled (Shaw & Stowe, 1982). We will briefly review older evidence (Shaw 1984, van Hateren 1986) that the terminals are indeed electrically coupled, when probed optically to stimulate cells from the six different facets of the 6-way convergence. The results allow the degree of coupling to be estimated, confirming that it is indeed strong. When neurons have been found to be electrically coupled with gap junctions in other neural systems, injections with small fluorescent tracers have often showed them to be "dye- coupled" as well. Lucifer Yellow (MW 457) is small enough to pass through the central connexon channel of some gap junctions. Unfortunately, many tests so far (Hardie, Shaw) have completely failed to detect dye-coupling between photoreceptor terminals. This has now been repeated with the slightly smaller, more recently introduced tracer, biocytin (MW 372). After many test injections, biocytin has been found to spread to either one or two other terminals in the same cartridge group, always on a next-neighbour basis. This finally confirms the other evidence, and suggests that coupling strength is greatest between next- neighbour cartridge terminals, as expected.},
}

@inproceedings{shimohigashi1997gene,
  title = {The gene shaking-B (Passover) regulates the number of gap junctions in the visual system of Drosophila: the jump between behaviour and molecules},
  author = {Shimohigashi, I. M and Meinertzhagen, I.A},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Gap junctions are the structural contacts that mediate electrical coupling between neurons in nervous systems. In vertebrates, gap junctions form from connexin proteins, but in invertebrates the corresponding proteins remain elusive. Recently, however, the shaking-B gene in Drosophila is suggested to encode a connexin-like protein, and mutants of shaking- B, including Passover, a null mutant with a defective escape jump, exhibit coupling defects. An antibody raised against the shak-B peptide expresses in the the lamina, where terminals of the eye's photoreceptors are electrically coupled by gap junctions. Compared with the wild type, there are significantly fewer (ca 20%) gap junctions in the shak-B mutant, but only in the upper levels of the lamina. At deeper levels, the numbers are smaller in both mutant and wild type, and both the same. Thus, the lamina's population of gap junctions is partitioned into at least two strata, and the numbers in the mutant imply the existence of at least two genetic factors, possibly proteins, encoding the number of gap junctions.},
}

@inproceedings{santor1997neural,
  title = {Neural Statistics, Human Failing, and the Backward Propagation of Error '1'45:-},
  author = {Santor, D.A.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {This brief talk introduces the basics of neural networks and machine learning and illustrates how for some (if not many tasks) we're better off not relying on human judgement. T46. Recurrent network dynamics Thomas Trappenberg The brain does not process information in a strictly linear fashion. It has rather a large amount of recurrent pathways which we believe are the root of its rich dynamical behavior. In this talk we will discuss some properties of very simple recurrent abstract neural networks. We will demonstrate their behavior with some simulations. T47. The evolution of the blood-brain barrier in the insect eye: is there a barrier in Archaeognatha? Steve Shaw and Lesley Varney In vertebrates, the blood-brain barrier (BBB) is located in the brain capillary walls and stabilizes the brain's micro-environment, protecting it from potentially harmful incursions of blood chemicals, etc. The evolution of the barrier mechanism is not easy to study by comparative methods, since all known vertebrates have it. The other larger group of terrestrial colonizers, winged insects (Pterygota), also have a BBB with the same role at the surface of the CNS, and which extends out into the eye. In trying to trace its evolution, we have looked to see if the eye barrier is present in the more primitive wingless insects (Apterygota), from which pterygotes originally evolved back in the Paleozoic era. We collected Petrobius maritimus (jumping bristletails) of the most primitive extant apterygote family Machilidae (Archaeognatha) on the shore near Parrsboro. Compared to other apterygotes, they have very well developed compound eyes. A colony of about 40 has been kept successfully for about 6 months in the lab. Using microelectrodes to pressure-inject small fluorescent tracers into the haemolymph (blood) of the head. we observed that these dyes lit up the eyes within a few minutes of injection. Specimens fixed and sectioned showed that dye is indeed present in the eye, concentrating particularly in the outermost optical layer, the cornea, which could only have reached by diffusing up from the base of the eye. We are currently setting up to check this, using electron-microscope tracers. Next, bugs were injected on a tilt stand (goniometer) mounted directly on the microscope, allowing fluorescence emission from part of the eye surface to be measured optically in real time with a sensit},
  note = {QA: needs-split-review; Split from T44 at: 'Neural Statistics, Human Failing, and th'},
}

@inproceedings{trappenberg1997recurrent,
  title = {Recurrent network dynamics},
  author = {Trappenberg, Thomas},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The brain does not process information in a strictly linear fashion. It has rather a large amount of recurrent pathways which we believe are the root of its rich dynamical behavior. In this talk we will discuss some properties of very simple recurrent abstract neural networks. We will demonstrate their behavior with some simulations.},
}

@inproceedings{shaw1997evolution,
  title = {The evolution of the blood-brain barrier in the insect eye: is there a barrier in Archaeognatha?},
  author = {Shaw, Steve and Varney, Lesley},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {In vertebrates, the blood-brain barrier (BBB) is located in the brain capillary walls and stabilizes the brain's micro-environment, protecting it from potentially harmful incursions of blood chemicals, etc. The evolution of the barrier mechanism is not easy to study by comparative methods, since all known vertebrates have it. The other larger group of terrestrial colonizers, winged insects (Pterygota), also have a BBB with the same role at the surface of the CNS, and which extends out into the eye. In trying to trace its evolution, we have looked to see if the eye barrier is present in the more primitive wingless insects (Apterygota), from which pterygotes originally evolved back in the Paleozoic era. We collected Petrobius maritimus (jumping bristletails) of the most primitive extant apterygote family Machilidae (Archaeognatha) on the shore near Parrsboro. Compared to other apterygotes, they have very well developed compound eyes. A colony of about 40 has been kept successfully for about 6 months in the lab. Using microelectrodes to pressure-inject small fluorescent tracers into the haemolymph (blood) of the head. we observed that these dyes lit up the eyes within a few minutes of injection. Specimens fixed and sectioned showed that dye is indeed present in the eye, concentrating particularly in the outermost optical layer, the cornea, which could only have reached by diffusing up from the base of the eye. We are currently setting up to check this, using electron-microscope tracers. Next, bugs were injected on a tilt stand (goniometer) mounted directly on the microscope, allowing fluorescence emission from part of the eye surface to be measured optically in real time with a sensitive detector. The measured time profiles confirm that dye uptake is extremely rapid (tl/2 = 0.4 - 1.4 min), although it then disappears again from the eye. Finally, the path-length for diffusion into the eye has been measured and the expected diffusion profile modelled, from a solution to the diffusion equation for the case with no barrier. This predicts similar values of 11/2 (0.8 - 1.1 min) without further assumptions, confirming that the eye space must be completely open to the circulation. The situation in flies (advanced pterygotes) is quite different, with very slow penetration and loss of dyes. The key reason for the lack of a barrier in machilids may be the primitive stage of evolution of the tracheal system in the group, which needs upgrading before barriers cutting off the retina become feasible.},
}

@inproceedings{home1997digitize,
  title = {Digitize that Image},
  author = {Home, Jane-Anne},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {This talk will introducethe process of digitizingimages and the subsequenttechniquesthat can be used to analyze or process a digitizedimage. I will give a brief review of some of the techniques hat have been successfullyused in recent years, with some insights on what a digitized image is and some hints on getting the best image possible. I will then summarizethe resources that are availableon campus and show how you can also use digital photographywithout owning specializedequipment},
}

@inproceedings{stanley1997central,
  title = {The central nervous system of the ascidian Ciona intestinalis},
  author = {Stanley, Sarah},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Ascidians, also called tunicates, are a group of marine creatures that exhibit several of the defining chordate features of the vertebratebrain. They are thought to lie closest to the presumed ancestral group of all chordates,includingvertebrates, from the body plan of their tiny tadpole larva, only several millimetersin length. Despite its size, the larva has a perfectly diminutive chordate central nervous system (CNS) with only several hundred cells in total. This makes the ascidianlarva an attractiveanimal in which to perform detailed studies of a primitive and relatively simple CNS of the vertebratetype. 3-D computerreconstructionswere made of all the CNS cells of individual larvae from the Southern Hemisphere, from serial sections. The cells within the CNS were classified by their nuclei and the appearanceof their cytoplasm,as one of twelve possible types. Cell counts were compared with those from a previous study on larvae collected from the Northern Hemisphere. Several novel conclusionson larval morphology were drawn from this serial-sectionstudy and the resulting reconstructions. These data indicate a remarkable similarityin larval organizationbetween individualsof this species.},
}

@inproceedings{greaven1997self,
  title = {Is Self-Handicapping in Young Adolescent Girls Related to Mothers' Parenting?},
  author = {Greaven, Sonia H.- and Santor, Darcy A. and Thompson, Richard and Zuroff, David C.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The use of self-handicapping strategies, which has been studied primarily in adults, may be related to the acceptance and reinforcement children experience while growing up. This study explored whether young adolescent girls' tendency to self-handicap was associated with their mothers' parenting characteristics. Mothers' ratings of care and stress were related to self-handicapping in their young adolescent daughters, as well as to their daughters' level of dysphoria. Regression analyses showed that higher maternal care was associated with lower levels of self-handicapping over and above the effect of their daughters' dysphoria, while mothers' stress from parent-child interactions was predictive of dysphoria in their daughters but not of self-handicapping.},
}

@inproceedings{brown1997evolutionary,
  title = {An Evolutionary Approach to the Signaling and Detection of Altruism},
  author = {Brown, William M.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {In order for altruismbetweennon-kin to be evolutionarilystable cheatingmust be detectable. However,the divisionof labour in many human cooperativeventures may render overt cheatingundetectable.It is hypothesizedthat non-cheatingindividuals communicatetheir dispositionswith hard-to-fake,nonverbal signals. Previous experimentshave been consistentwith this hypothesis (Frank,Gilovich, & Regan, 1993; Palameta & Brown, 1996). Video-clipsof 4 altruists and 4 non-altruistswere matched for physical attractiveness,expressivenessand content. One-hundredand twenty university students made open-endedpersonalityassessmentsof the 8 targets. In addition, targets' facial micro-movementswere coded by two blind raters. Results will be discussedin light of current conceptualmodels explainingthe evolutionof altruismbetweennon-relatives.},
}

@inproceedings{phillips1997son,
  title = {Son of Gap Detection: In One Ear and Then the Other},
  author = {Phillips, D.P. and Taylor, T.L. and Hall, S.E.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Last year, in fit of unbridledenthusiasm,we presented two lines of evidence that suggested that all was not as it appearedto be in the world of gap detection. Recall that gap detection is an auditoryperceptionparadigmused to probe the temporalprocesses involved in speech recognition. It measuresthe shortest-durationsilent period that is detectablebetween two noises. Historically,researchershave kept those noise markers identical - which is not the case for the interestinggaps in speech. Last year, we showed that when the gap- detectionparadigmis modified to mimic the speech signal (e.g., by making the noise markers spectrallydissimilar,so that they activatedifferentperceptualchannels),two differentperceptualprocesseswere engaged. One of these processes seemed to explain why there is a categoricalboundaryin the perceptionof voice onset times, and why it has the value that it does (about 35 ms). This year, we report an experimentin which we performed a new interrogationof this perceptualtiming process.},
}

@inproceedings{johnjchristieourdatafromspatialparadigmsthattypicallygeneratenegativeprimingtipper1997ethereal,
  title = {On the (ethereal, ephemeral) nature of neg3tive priming},
  author = {John J. Christie Our data from spatialparadigmsthat typicallygenerateNegativePriming (Tipper, Brehaut},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {and Driver, 1988)reveal that there may be importantartifactsin unbalancedexperimentsof this kind: The costs in the ignoredrepetitionconditionare not due to specialprocessingof the distractor. We subsequentlyconductedbalancedand imbalanceddesigns in the identity task while removingpotentialartifactsfrom localization. We generatedtypicalnegative priming effects with an imbalanceddesign; but these effects disappearedwhen subjectsno longer expected a target repetitionevent on the probe trial. Given that these basic paradigmsused to study negativepriming are broughtinto questionit is likely that all of the paradigmsthat are believedto produce negativepriming need to be re-examined. Additionally,the dramaticdifferencesin the results of the spatiallocation and identity paradigmswithout biases may provide a platformfor explainingdifferencesbetween these two paradigms pointed out by others (Fox, 1995). 6 1997 In-House Convention},
}

@inproceedings{adamo1997voices,
  title = {Voices from within: Parasitic manipulation of host behaviour},
  author = {Adamo, Shelley A.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The parasitic wasp Cotesiacongregatainjects its eggs into the larvae of the tobacco horn worm, Manducasexta. Homworms were found to feed normally during the growth of the parasitic wasps. However, M. sexta stopped feeding several hours prior to the emergence of the wasp larvae. Hosts were not debilitated by the parasites and survived another 2 weeks without feeding after the wasps emerged. In the field, unparasitized M. sexta ate C. congregatapupae (n=l0/10) suggesting that the suppression of host feeding prevents predation of the parasitic wasps by the host. The decline in host feeding correlated with a long-lasting increase in the concentration of octopamine in the host's hemolymph (22.2 ± 2.1 pg/µL (n=7) to 143.7 ± 7.8 pg/µL hemolymph (n=16)). Injections of octopamine depressed feeding in unparasitized M. sexta. The wasp larvae were not the source of the host's increased octopamine. Feeding was also temporarily depressed in M. sextaby injecting sephadex beads, bacteria (Serratiamarcescens)or lipopolysaccharides (derived from S. marcescens).In all 3 cases, octopamine concentration in the hemolymph increased after injection (18.7 ± 4.2 to 54.7 ± 7.8 pg/µL hemolymph for bacteria-injected, n=lO)). Feeding resumed with the decline in octopamine levels. Sephadex beads, bacteria, lipopolysaccharides and the emerging wasp larvae all activate the host's immune system. The data are consistent with the hypothesis that part of the parasite's ability to suppress host feeding involves permanently activating mechanisms that suppress feeding during an immune challenge.},
}

@inproceedings{fentress1997perceptions,
  title = {Perceptions of movement},
  author = {Fentress, John},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {1997In-HouseConvention 7},
  note = {QA: needs-split-review; Split from T9 at: 'Tl 0. Perceptions of movement'},
}

@inproceedings{schellinck1997behavioral,
  title = {Behavioral sequences in canids: a new perspective on the plasticity of action and movement patterns},
  author = {Schellinck, Heather M and Keveme, E. Barry},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The pregnancy of a female mouse (Mus musculus) is blocked by olfactory cues contained in the urine from a strange male but not in the urine from the stud male. We investigated the role of Major Urinary Proteins (MUPs) in determining these urinary cues by exposing pregnant female mice to one of the following: (A) urine from strange males; (B) chemically purified MUPs derived from strange male urine, with their ligands attached or (C) chemically purified MUPs derived from strange male urine, with their ligands removed via chemical extraction; (D) urine from stud males to which had been added chemically purified MUPs from strange males, with their ligands removed; (E) urine from stud males or (F) chemically purified MUPs from stud males with their ligands attached. (G) chemically prepared ligand, 2-(sec-butyl)thiazoline. Statistical analysis revealed that the exposure of pregnant females to (A) urine from strange males, (B) strange MUPs either with or (C) without the ligand attached or (D) combined with stud urine blocked significantly more pregnancies than exposure of female mice to (E) stud urine or (F) MUPs and ligand extracted from the urine of stud males or (G) chemically preapred ligand These results indicate not only that (1) the MUPs of male mice demonstrate pheromonal activity whearas the volatile ligands do not but also that (2) the MUPS of strange males confer the specificity required to induce pregnancy block in females. 8 1997In-House Convention T13. The Hebb-Williams Maze: Fifty years of research (1946-1996) Richard Brown & Lianne Stanford The Hehir Williams (H-W) maze was design},
  note = {QA: needs-split-review; Split from T9 at: 'Tl 1. Behavioral sequences in canids:'},
}

@inproceedings{dick1998effects,
  title = {The Effects of Pain on Event-Related Potentials},
  author = {Dick, Bruce},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The importance of accurate pain assessment and measurement cannot be overstated. This presentation will briefly outline the progress in pain assessment leading up to the research to be presented. As a result of collaboration between the Pediatric Pain Lab and the Cognitive/Clinical Neuroscience Unit, research has investigated the utility of event-related potentials (ERPs) as a pain measurement tool. This work capitalizes on the cognitive relation between pain and distraction and is founded on an attentional resource allocation model. Distraction appears to channel attention away from pain stimuli, and the P300 ERP wave amplitude has been found to be related to attentional resource utilization. The proposed model therefore predicts that pain will act as a consumer of attentional resources and will consequently influence the amplitude of the P300. Preliminary study data will be presented along with a discussion of possible brain mechanisms that underlie these findings.},
}

@inproceedings{tremblay1998vrml,
  title = {VRML Analyses of Movement},
  author = {Tremblay, Ben},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The complexity of movement demands representations that allow the investigator to dissect individual movement properties, and also establish rules for how these properties combine in space and time. We shall show preliminary representations of movement made possible by computer VRML methodologies. Eshkol-Wachman choreography systems of individual movement parameters can be modeled, and thus analyzed.},
}

@inproceedings{darcy1998application,
  title = {The application of event-related potentials (ERPs) in the assessment of receptive language functions},
  author = {D'Arcy, Ryan C.N. and Connolly, John F. and Eskes, Gail A. and Phillips, Stephen J. and Harrison, Edmund R.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {While there is a long and distinguished history of basic research with event-related potentials (ERPs), more concentration on the clinical applications of this technique is paramount. Language is well suited for investigations of an applied nature because various ERP components associated with linguistic processing have been identified. Accordingly, we have explored the feasibility of adapting standardized neuropsychological measures of language for computer presentation with ERPs. These investigations have demonstrated that ERP components related to speech perception and recognition memory can be elicited by standardized test stimuli and utilized to evaluate language independent of behavior. Specifically, studies of vocabulary and comprehension have demonstrated that: 1) test items within an individual's ability can be differentiated on the basis of their neural responses; and 2) these experimental findings have been demonstrated at the individual level, thus maintaining clinical applicability. The potential implications of this novel technique will be discussed along with the presentation of recent experimental findings from the Psycholinguistic Assessments of Language Processing in Aphasia (Kay et al., 1992).},
}

@inproceedings{moore1998gaze,
  title = {Gaze following and the control of attention in infancy},
  author = {Moore, Chris},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {In this talk I will consider the development of gaze following during infancy. I will suggest that the phenomena of gaze following are best interpreted in terms of developing attentional control. The infant's own attention is initially controlled exogenously by a particular set of social stimuli but gradually comes under more endogenous control. Only towards the end of infancy, does such endogenous control provide us with a warrant to claim that infants understand the attentional states of others.},
}

@inproceedings{fidler1998stress,
  title = {Stress and Finickiness},
  author = {Fidler, Tara L. and LoLordo, Vincent M.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Finickiness, suppressed consumption of a novel bitter solution relative to baseline consumption levels, has been observed following stress in humans and animals. In studies reported previously (for example see Job and Barnes, 1995, Behavioral Neuroscience, 109, 106-116) the finickiness effect has been reported only following the sorts of shock parameters that result in learned helplessness, 100+ shocks of 2-60 s in duration. Our rats demonstrated finickiness for novel quinine 40 minutes after a shock session, consisting of 60 shocks of 2-s duration on a FT-60 s schedule. The effect was reinstated 27-28 days later with only 10 shocks. Uncontrollable shock stress may increase the aversiveness of bitter tastes.},
}

@inproceedings{brown1998signaling,
  title = {Signaling Benevolence: An Evolutionary Perspective on the Encoding and Decoding of Altruism},
  author = {Brown, William M. and Palameta, Boris and Moore, Chris},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Emotions associated with benevolence can be viewed as evolved commitment devices that help solve social dilemmas which require trust (Frank, 1988). Non-kin altruism may be evolutionarily stable if these emotions are signaled and decoded accurately. It was hypothesized that altruists produce involuntary facial signals which are detectable by others. One-minute video-clips were constructed of 5 self-reported altruists and 5 self- reported non-altruists. Altruist/non-altruist pairs were videotaped while playing the game "Mastermind" jointly against the experimenter. In one condition the altruist received credit for game performance; while in the other condition the non-altruist received credit. Under blind conditions, one-hundred and sixty eight undergraduates rated the 10 video-targets' helpfulness, concern, attentiveness and expressiveness. Results suggest that individuals can detect altruists. Altruists were viewed as significantly more attentive and concerned than non-altruists when playing the game for their partner's benefit. Non-altruists were rated significantly more attentive and concerned than altruists when playing the game for their own benefit. Regardless of condition altruists were viewed as more helpful than non- altruists. Results will be discussed in light of current conceptual models explaining the evolution of altruism among non-relatives.},
}

@inproceedings{christie1998attention,
  title = {An Attention Based Negative Priming Effect Really!!},
  author = {Christie, John},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Negative Priming (NP) was once thought to be the way to prove a hypothesis first put forth by Treisman (1964). If one ignored an item, while attending another, the ignored item would be inhibited. For the first time hundreds of researchers started to study inhibitory effects of attention through the use of NP. However, since NP was discovered nearly all of the founders of the phenomenon have abandoned this attentional explanation in favour of a memorial one. Those who have not abandoned the inhibitory attentional explanation have decided to stick with models that can only account for a fraction of the available data. While current memorial explanations are difficult, if not impossible, to defeat, one NP effect has been found that is best explained by attentional orienting. The reasons for the generation of this particular effect may also allow one to design other experiments to examine inhibition.},
}

@inproceedings{blackbum1998development,
  title = {Development of a brief battery of attentional tasks.},
  author = {Blackbum, J .R. and Mcinerney, R.J. and Klein, RM.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {In order to determine whether attentional capacity changes as individuals spend time playing a video lottery terminal (VLT), we have developed a battery of computerized attentional tasks that may be administered both before and after a session of VL T play. Six previously characterized tasks have been modified to make them appear similar to each other and to make them more like games for our gambling subjects. The six tasks were a continuous performance task (CPT), a CPT-AX task, a Simon effect task, a flanker task, a Rapid Serial Visual Perception (RSVP) task, and a stop signal task. A factor analysis of data from twenty undergraduate subjects will be presented, indicating whether there are identifiable factors of attention and whether the battery can be shortened by removing redundant tests.  l},
}

@inproceedings{song1998melatonin,
  title = {Melatonin and Light Effects on Circadian Rhythms and Thermoregulation},
  author = {Song, Xiaowei and Rusak, Ben},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Internally generated biological rhythms are synchronized to the external day principally by light-dark cycles. Melatonin is secreted by the pineal gland at night and it too can influence rhythm synchronization, apparently by having effects opposite to those of light. Melatonin has, therefore, been used to treat disorders of rhythm entrainment in humans. The normal nocturneµ_cle~linein body temperature in human appears to be related to melatonin ~ecJe_ti9_n. Light exposure at night reverses the nocturnal temperature decline by inhibiting melatonin secretion, an effect that can be opposed by giving exogenous melatonin. Melatonin administration also appears to attenuate the phase-shifting effects of nocturnal light. Since it is not clear how melatonin and light interact to affect circadian rhythm synchronization and thermoregulation, we are studying light and melatonin interactions using rodent model systems, in which levels of the two factors can be manipulated for both nocturnal and diurnal species. Changes of core body temperature, hypothalamic temperature, and locomotor activity in response to light exposure and melatonin administration are being monitored continuously. Preliminary findings related ot the effects of light and melatonin on body temperature, activity, and circadian rhythms will be discussed.},
}

@inproceedings{saintaubin1998influence,
  title = {The influence of parafoveal identification on letter detection accuracy revisited},
  author = {Saint-Aubin, Jean and Klein, Raymond M.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {When asked to detect target letters while reading a text, subjects miss more letters in highly frequent function words than in less frequent content words. According to the parafoveal- processing hypothesis, omissions occur when a word is identified parafoveally, instead of being fixated. Function words would be more likely to be identified parafoveally, because their high frequency allows identification on the basis of minimal visual information. This hypothesis has been tested with rapid serial visual presentation in which fixation was encouraged by presenting words one at a time on a computer screen. Detection accuracy was compared for target letter t embodied in the or in content words. Eighteen subjects read three prose passages, each presented at a different speed : 200, 350 or 500 msec per word. Contrary to the parafoveal-processing hypothesis, results showed more omissions for the at the fastest presentation rate. However, due to ceiling effects, there were no effects at the slower presentation rates. i • - •.'},
}

@inproceedings{yoon1998neural,
  title = {Neural interactions during syntactic and semantic processing of compound sentences},
  author = {Yoon, Myong G. and Connolly, John F.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Using event-related brain potential (ERP) methods, we tested whether the putative semantic processing subsystem (the neural provenance of the N400) and the putative syntactic processing subsystem (that of the P600) function independently or they interact during the neural processing of semantically anomalous and/or syntactically incorrect compound sentences. We found that the two neural subsystems interfered each other during on-line processing of a simultaneous semantic anomaly and inflectional rule violation. On the other hand, the semantically incongruous state of a verb enhanced the neural responses (P600) to the inflectional disagreement in the same verb. The latter result shows an example of the positive mutual interaction (i.e., enhancement) between the putative semantic and syntactic subsystems. Strain and Sex Differences in MHC-Congenic Mice in Learning the Hebb- Williams Maze L. Stanford & R. E. Brown Using a mouse version of the Hebb-Williams Maze (HWM), we examined learning in male and female mice of two congenic strains (C57Bl/6J & B6-H-2K) for cereal reward. During acquisition males required fewer sessions than females to learn the task. There were significant differences in the number of errors over the 12 test mazes, a maze pattern by trial interaction, sex by trial, and sex by trial by maze pattern interactions, but no strain differences. The maze was then filled with water and the mice were tested under escape motivation to reach a raised platform in the goal box. In the swim-escape test the B6-H-2K mice reached criterion earlier than the C57Bl/6J mice. In the test trials, there were significant main effects for maze pattern and trial as well as the interaction of maze pattern by trial, but no strain or sex differences. These data illustrate the strength of the HWM to detect differences in learning and memory.},
}

@inproceedings{stewart1998relationship,
  title = {Relationships of Anxiety Sensitivity and Dimensions of Alexithymia in a Young Adult Sample},
  author = {Stewart, Sherry H. and Devine, Heather and Watt, Margo C.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The relationships between anxiety sensitivity (AS) and alexithymia dimensions were examined in a non-clinical sample of young adults, after controlling for item redundancy between the Anxiety Sensitivity Index (ASI) and the 20-item Toronto Alexithymia Scale (TAS-20). A sample of 238 undergraduate students completed the ASI and the TAS-20, as well as measures of trait anxiety and panic atta~k history. As hypothesized, high AS students (n =36) scored significantly higher than low AS students (n =41) on the two TAS-20 subscales suspected of sharing a functional relationship with AS (i.e., difficulty identifying emotions; difficulty describing emotions), whereas no AS group differences were found for the TAS-20 subscale believed to be functionally unrelated to AS (i.e., external-oriented thinking). Moreover, the pattern of relationships between ASI scores and alexithymia dimensions persisted following the removal of TAS-20 items identified as potentially conceptually redundant with the ASI, confirming the prediction that the relationship between AS and alexithymia is not merely an artifact of item redundancy. The results also revealed that individuals who both experience frequent anxiety (trait anxiety) and who greatly fear their anxiety symptoms (AS) appear most likely to use alexithymic coping strategies. Finally, the results showed that high AS in the absence of a history of panic attacks appears sufficient to motivate the use of alexithymic coping strategies. Potential clinical implications of the findings will be discussed. 12 1998 In-House Convention},
}

@inproceedings{palameta1998waist,
  title = {Waist-to-Hip Ratio and Perceptions of Female Attractiveness},
  author = {Palameta, Boris and Staples, Christina and Bird, Debbie},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {In a series of influential papers, Dev Singh has argued that human males are selected to use .. J I ·~':·_ h-·:. female waist-to-hip ratio (WHR) as a criterion for mate choice, because low WHRis an ~ ! honest signal of health and fertility. This paper reports the results of experiments designed to test some of Singh's hypotheses. A computer program (Adobe Photoshop) was used to manipulate the WHRs of photographed figures in 4 ways: 1) remove weight from waist (reduce WHR); 2) remove weight from hips (increase WHR); 3) add weight to waist (increase WHR); 4) add weight to hips (reduce WHR). Consistent with Singh's theory, underweight and average-weight figures were rated as more attractive when weight was removed from the waist rather than the hips. However, the reverse was true for overweight figures. Furthermore, despite their low WHRs, figures with experimentally enlarged hips were not perceived to be more attractive than figures with enlarged waists. Gender differences in attractiveness ratings were also investigated.},
}

@inproceedings{rusak1998yet,
  title = {"Yet a little sleep, a little slumber, a little folding of the hands to sleep" (Proverbs 6:10)},
  author = {Rusak, B. and J and LeBlanc and Morehouse, R. and Rajda, M. and Thompson, S. and Kutcher, S.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {In the clinical psychiatric literature (including the DSM IV), a sleep disorder known as Delayed Sleep Phase Syndrome (DSPS) has been described. It is characterized in both adolescents and adults as a disorder of the timing of sleep and waking, in which sleep onset is strongly delayed when the individual is allowed to sleep at his or her preferred time, but is structurally normal. Under usual work or school conditions, however, sleep is severely disrupted because the individual is essentially incapable of shifting from the very delayed timing to more socially acceptable patterns. It is generally regarded as a disorder of circadian system entrainment. DSPS can have very serious consequences for school attendance, school performance and job opportunities. The incidence of this disorder has been estimated in several studies, but these estimates have varied over a couple of log units. We undertook an epidemiological survey of -1600 adolescents in Halifax Regional Municipality to assess sleep disorders, mood disorders and their relation to reported school performance, with an emphasis on identifying the incidence of DSPS in this population. While most of the data remain to be analysed, we will report on our preliminary findings and discuss the difficulties of definition and diagnosis in this area.},
}

@inproceedings{shore1998exploring,
  title = {Exploring The Potential Link Between Saltation, Reading, And Perceptual Grouping},
  author = {Shore, David I. and Klein, Raymond M.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {We explored the auditory variant of the saltation illusion (the mislocalization of a brief stimulus followed by a stimulus at a different location) and developed a unique measurement tool. Prior research has shown that auditory saltation is more robust for adult dyslexics and, as such, has been proposed as a measure of temporal processing. Subjects participated in three tasks: a subjective rating of the saltation illusion, a click enumeration task, and the Olson reading tests. Click enumeration is proposed to provide an index of perceptual grouping while the Olson test provides separate measures of orthographic and phonologic coding. Individual differences in these three measures were compared. The complex interactions between these three measures are discussed in relation to proposed links between temporal processing, perceptual grouping and reading.},
}

@inproceedings{symons1998joy,
  title = {The joy of "hide-and-seek": Why is it harder to find people than objects within a false belief task},
  author = {Symons, Doug},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {In order to better understand the interface between social and cognitive development in the preschool period, current research in my lab has focused on false-beliefs held for social referents. The paradigm we have developed is based on the standard Maxi task in which a participant is asked where a story-character will look for a caregiver or object relocated within the task without the character's knowledge. We are interested in why children do more poorly on tasks involving people compared to objects, and have varied the reason for relocation of the sought item to determine why. A series of studies will be presented to show that animacy and intentionality confound performance and delay standard age-effects when the sought item is a person. One explanation is that developing a theory of mind actually reduces performance when the sought-item has a mind, and ultimately, such awareness fits in with relationship constructs.},
}

@inproceedings{forestell1998paradigm,
  title = {A Paradigm for Investigating Olfactory Conditioning and Differential Immediate Early Gene Expression in Mice},
  author = {Forestell, Catherine and Schellinck, Heather},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The purpose of the present experiment was to determine whether mice can acquire a conditioned response to an odour paired with a caloric reinforcer. Food restricted mice were exposed to a differential conditioning procedure in which experimental animals received odour A paired with sucrose in a dish covered with bedding and odour B presented alone in a dish with bedding. Control animals were either exposed to odour A and odour B alone, or to no odour with bedding. On day 5, animals were placed in a chamber divided into three equal sections with odour A and odour B on each end of the chamber. Experimental animals spent significantly more time digging in the dish which contained Odour A than Odour B relative to control animals. On day 6, all animals received exposure to odour A, odour B or no odour, 2 hours prior to perfusion. Evidence for immediate early genes expression for c-fos was assessed in brain structures such as the olfactory bulbs, amygdala and the basal ganglia. Immunohistochemical results will be discussed. I  ' -y ' 14 1998 In-House Convention},
}

@inproceedings{bloom1998contralatera,
  title = {Contralateral Dopaminergic Neurons are Involved in Generating the Reinforcing Effect of Brain Stimulation},
  author = {Bloom, Seth and Nakajima, Shinshu},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {It is well known that the mesolimbic dopaminergic path plays an important role in generating a reinforcing effect of brain stimulation. The majority of studies in this field, however, dealt with only one side of the brain-the side where the electrode is implanted, and the contralateral effect has been ignored. The functional relationship of contralateral dopaminergic pathways involved in brain stimulation reward was examined. Rats were implanted with two cannulae into the VTA and the NAc contralateral to a lateral hypothalamic stimulating electrode and trained to bar-press. The frequency of stimulation pulses was systematically changed, and a frequency-response curve was plotted for each rat before and after 6-OHDA injections into the VTA. Haloperidol was also injected into the NAc before and after placing the lesion to further examine the role that contralateral dopaminergic pathways play in self-stimulation. The reward threshold increased after either a 6-OHDA lesion if the VTA or a blockade of dopaminergic terminals in the NAc. The results suggest that a contalateral pathway is involved in the reinforcing effect of hypothalamic stimulation.},
}

@inproceedings{comeau1998depression,
  title = {Depression and Substance Use Disorder Comorbidity Patterns Among Adolescents},
  author = {Comeau, Nancy and Santor, Darcy},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Objectiv~ Since the introduction of DSM-ill-R, clinicians and investigators have shown increasing interest in the study of conditions comorbid with affective disorders. Understanding depression and substance use disorder comorbity patterns among adolescents is needed to guide treatment, research, and prevention/early intervention approaches. Metho_d: 1) The literature on the comorbidity of depression and substance use disorder among-adolescents from the past 10 years was reviewed to explore the most prevalent patterns of depression-substance use disorder comorbidity; 2) examine the correlates and longitudinal predictors of comorbidity; and 3) determine the extent to which comorbid patterns convey unique information concerning etiology and treatment. ~~: a body of literature concerning the comorbidity of depression and substnace use disorder, with a substantially smaller amount of data conecerning other comorbid conditions. In manu areas the literature was sparce, and pertinent questions concerning comorbidity patterns remain unexplored. Nonetheless, available data warrant that interventions among adolescents dealing with these comorbid conditions are likely to be quite important to society. ~onclusjo!!~: Additional studies of the frequency of cormorbidity and associated factors are greatly needed, to include studies of differential effects of treatment of adolescents with various comorbid depression and substance use disorders, as well as of depression and substance use disorder adolescents who differ in etiological factors . Department of Psychology and Neuroscience 24 th Annual In-House Psychology Convention},
}

@inproceedings{cole1998development,
  title = {Development and evolution of Ascidian nervous systems},
  author = {Cole, Alison},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {I am interested in mechanisms of neuronal differentiation in development. Ascidians are closely related to vertebrates and are thought to be the closest extant form resembling the early chordate common ancestor. The combination of invertebrate characters with their vertebrate heritage make ascidians ideal for studies in neuronal development. I hope to extend a previous study tracing the cell lineage development in larval Ciona intestinalis through confocal reconstructions with various immuno-probes, as well as further identifying cells with regard to their transmitter phenotype. This work will establish whether or not lineage and cell type differentiation are related. I also hope to explore the evolutionary relations between the ascidian groups by comparing the development of the dorsal nervous system across different ascidian species.},
}

@inproceedings{klein1998causes,
  title = {On the causes, effects, functions and neural implementation of "inhibition of return"},
  author = {Klein, Ray and Taylor, Tracy},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Immediately following an uninformative peripheral stimulus (cue) there is a short-lasting facilitation of response times in the region of the cue which is followed by a longer lasting inhibition. This inhibitory effect of the cue upon subsequent responses to targets was named inhibition of return (IOR) to capture the dominant interpretation that, after having oriented to a location in space, attention is inhibited from returning there. This phenomenon has been the subject of intense interest because of its putative role in improving our ability to forage the visual environment for consequential information (Posner & Cohen, 1984; Klein, 1988; see Taylor & Klein, in press, for a review). I will present evidence from various methods in cognitive neuroscience which converge on: oculomotor programming as the cause of the inhibition, localization dependent processes as affected by the inhibition, enhanced search efficiency as one function of the inhibition, and the superior colliculus as the main neural structure involved in generating the inhibition. @},
}

@inproceedings{lee1998effect,
  title = {Effect of Male Removal on Gestation Length in Female California Mice (Peromyscus Calif ornicus)},
  author = {Lee, A.W. and Cantoni, D. and Brown, R.E.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {California mice are a monogamous species that show biparental care. In mated pairs, the presence of the male facilitates reproductive success by increasing pup survival and reducing the female's gestation length. Under wheel running conditions for food, females living with their mate have a mean gestation length of 33 days. Females which have their mates removed 2 days postpartum, have a mean gestation length of 52.5 days, suggesting that these females had delayed implantation. The present study investigated the effect of male removal near the middle (Day 17) or end (Day 32) of the gestation period. Females living with their mate with ad lib food, have a mean gestation length of 34 days. Females which have their mates removed on Day 32 of gestation have a mean gestation length of 36 days. Females which have their mates removed in on Day 17 of gestation either have a mean gestation length of 36 days or fail to give birth. These results suggest that the presence of the male is important throughout the gestation period in maintaining a normal, gestation length in female California mice. Aspects of the male's behavior during parturition which may facilitate parturition will be discussed. 16 1998 In-House Convention T31. Copy Cat: Spatial Localization Deficits in Cats with Experimentally Induced Amblyopia are Identical to Those Experienced by Human Amblyopes Guy Gingras and Donald E. Mitchell, Department of Psychology, Dalhousie University Although human amblyopia is defined as uncorrectable poor visual acuity, not all forms of acuity are affected equally. The worst deficits are observed on tasks that measure the ability to locate differences in the position of objects in space. This research had as its goal a comparison of the performance of normal cats and humans on the same localization task (a test of the ability to detect a misalignment between 3 Gaussian blobs) and to document the deficits on this task of cats with various forms of early visual deprivation (monocular deprivation or strabismus). Deprived cats demonstrated localization deficits that changed with spatial scale (blob size) in a manner identical to that observed in human amblyopes. Moreover, like human amblyopes, the spatial deficits on the alignment task were considerably larger than the deficits of grating acuity. The results justify the use of these animals models of human amblyopia. T32. Instant identification of popular songs: Insights into auditory memory representations E. Glenn Schellenberg 1, Paul Iverson 2 , Margaret C. McKinnon3 1Dalh},
  note = {QA: needs-split-review; Split from T29 at: 'Effect of Male Removal on Gestation Leng'},
}

@inproceedings{gingras1998copy,
  title = {Copy Cat: Spatial Localization Deficits in Cats with Experimentally Induced Amblyopia are Identical to Those Experienced by Human Amblyopes},
  author = {Gingras, Guy and Mitchell, Donald E.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Although human amblyopia is defined as uncorrectable poor visual acuity, not all forms of acuity are affected equally. The worst deficits are observed on tasks that measure the ability to locate differences in the position of objects in space. This research had as its goal a comparison of the performance of normal cats and humans on the same localization task (a test of the ability to detect a misalignment between 3 Gaussian blobs) and to document the deficits on this task of cats with various forms of early visual deprivation (monocular deprivation or strabismus). Deprived cats demonstrated localization deficits that changed with spatial scale (blob size) in a manner identical to that observed in human amblyopes. Moreover, like human amblyopes, the spatial deficits on the alignment task were considerably larger than the deficits of grating acuity. The results justify the use of these animals models of human amblyopia.},
}

@inproceedings{schellenberg1998instant,
  title = {Instant identification of popular songs: Insights into auditory memory representations},
  author = {Schellenberg, E. Glenn and Iverson, Paul},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {We examined memory representations for popular songs by testing listeners' ability to identify brief excerpts from familiar recordings. Although songs are defined solely by pitch and temporal relations, such representations might also contain information about timbre (sound quality). Listeners were required to match 200- or 100-ms excerpts with the song titles and artists. Performance was well above chance levels for 200-ms excerpts, and poorer but still better than chance for 100-ms excerpts. Performance fell to chance levels when dynamic information was disrupted by playing the 100-ms excerpts backwards, and when high-frequency information was omitted from the 100-ms excerpts; performance was unaffected by the removal of low-frequency information. In sum, successful identification required the presence of dynamic, high-frequency spectral information. This finding indicates that the timbre of specific recordings is encoded into memory representations of popular songs.},
}

@inproceedings{phillips1998space,
  title = {Space, the Final Frontier (for Gap Detection)},
  author = {Phillips, D.P. and Hall, S.E. and Harrington, I.A. and Taylor, T.L.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The detection of brief periods of quiet ("gaps") in the ongoing stream of speech is extraordinarily important for the identification of the stop consonants. In a previous lifetime, we argued that the perceptual task of detecting such a gap can exploit either a discontinuity detection mechanism, or a relative timing mechanism, depending on whether the noises that bound the gap are the same or different. That is, the gap detection operation can either be executed within a particular perceptual channel, or as a cross-correlation of the activity in different channels. In our previous work, we forced the use of different perceptual channels by using gap markers that stimulated different populations of peripheral neurons. This year, we describe the gap detection behavior of listeners in an experiment in which the gaps were bounded by markers that stimulated the same sets of peripheral neurons, but different central perceptual channels.},
}

@inproceedings{boehnke1998gaps,
  title = {Gaps: The Next Generation},
  author = {Boehnke, S.E. and Phillips, D.P. and Hall, S.E.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {In the previous abstract, Phillips et al. showed that separating the leading and trailing noises of a gap stimulus in space results in the gap detection task becoming a "between- channel" one. We thus suspected that the gap detection paradigm might be used to determine the tuning of spatial channels in human hearing. Consequently, I have looked at the effect of systematic changes in the spatial location of the leading and trailing markers of a gap stimulus. This task requires a relative timing operation to occur between two populations of central neurons coding for spatial locations of the leading and trailing markers. Intriguing results point to the existence of three spatial channels - left hemifield, right hemifield, and midline. Equally fascinating however, is that these results map almost perfectly onto the underlying neurophysiology of the central auditory coding of the binaural cues for sound location.},
}

@inproceedings{semba1998presynaptic,
  title = {Presynaptic adrenergic receptors inhibit REM sleep by attenuating pontine cholinergic transmission.},
  author = {Semba, Kazue},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Mesopontine tegmental cholinergic neurons are thought to be responsible for inducing REM sleep by releasing acetylcholine (ACh) in the pontine reticular formation (PRF). However, many of these neurons appear to be active (thus, potentially releasing ACh in the PRF) not only during REM sleep but also during wakefulness. One explanation for this apparent paradox is that, during wakefulness, ACh release in the PRF is strongly inhibited by noradrenaline acting on presynaptic adrenergic receptors on cholinergic terminals. Noradrenaline is likely to be released in the PRF during wakefulness by locus coeruleus neurons. Our data using behavioural, in vitro electrophysiological, and in vivo microdialysis techniques support this hypothesis, and suggest that presynaptic mechanisms might play an important role in the control of behavioural state .},
}

@inproceedings{emsley1998embryonic,
  title = {The Embryonic Brain of Drosophila melanogaster, or A Portrait of the},
  author = {Emsley, Fruitfly as a Young Egg Jason},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The fruitfly, Drosophila melanogaster, has long been used a vital tool for neuroscientific research of a genetic and anatomical nature. Because of its stereotypical pattern of development and its relatively simple nervous system, Drosophila is a powerful tool for understanding the relationship between gene and neurotransmitter expression and development. I will present several views of the development of this simple nervous system, considering how information about gene and neurotransmitter expression can be related to the actual anatomy of the developing CNS. Semi-thin sections of embryonic tissue have been serially aligned and, from these sections, I have developed a computerised, three-dimensional anatomical atlas of the Drosophila nervous system. Images of this atlas will be considered, alongside images produced via fluorescence immunohistochemistry and confocal microscopy.},
}

@inproceedings{test1998tim,
  title = {Tim Bredy, Will Moger and Richard Brown},
  author = {Test, Behavioural Differences in MHC-Congenic Mice: The Step-Down Passive ~ Avoidance},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Although there are a multitude of physiological and pathological traits in which the major histocompatibility complex (MHC) might influence behaviour (lvanyi, 1978, Proc. R. Soc. Lond. B, 202, 117-158), MHC-congenic mice have primarily been tested for mate selection and individual recognition by odour (Yamazaki et al., 1976, J. Exp. Med.,144, 1324-34; Manning et al., 1992, Nature, 360,581-583). The present experiment investigated the possiblity that two strains of MHC congenic mice (C57Bl/6J vs. B6 H-2K) would differ in their ability to learn and remember a passive avoidance task. Glucocorticoids influence learning and memory (Smith, 1996, Beh. Brain Res., 78, 25-36) and there are strain differences in hippocarnpal glucocorticoid binding capacity in mice (Patacchioli et al., 1990, Beh. Brain Res., 37, 185-188). Plasma corticosterone concentrations were therefore measured using radioirnrnunoassay following the passive avoidance test. There was a significant strain difference in the ability of the no shock control group to habituate to the step-down passive avoidance apparatus that can be attributed to a strain difference in learning. The results indicated no strain differences in retention. Corticosterone levels are presently being analyzed. Strain differences in passive avoidance learning and in corticosterone levels may explain some of the MHC-related strain differences in mate selection, intermale aggression and other behaviours.},
  note = {QA: needs-split-review; Split from T36 at: 'Behavioural Differences in MHC-Congenic '},
}

@inproceedings{emclaughlin1998tenacious,
  title = {The tenacious blink},
  author = {E.McLaughlin, R.Klein and Shore, D.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {When stimuli (e.g., letters) are presented in rapid succession, individuals are typically poor at identifying a target (probe) that follows an earlier target (prime) by 100-500 ms. Four studies investigated the nature of this perceptual failure, which is known as the "attentional blink". These studies show that the strength and quality of the attentional blink is very robust. Studies 1 and 2 compared two distinct methods of measuring the blink: letters presented within a stream of numbers versus single letters followed by pattern masks, with the ISi between letters held constant across studies. As predicted, blink strength was highly correlated within subjects across studies. Studies 3 and 4 investigated whether manipulating the quality of the physical evidence for the target stimuli (either prime or probe) would affect the attentional blink. These maniputions had the expected effect upon the processing of the degraded target (accuracy was a monotonic function of the quality of the evidence), but contrary to our expectations, manipulating the difficulty of extracting the identity of either the prime or probe target had no impact on the strength of the blink. The implications of these findings for understanding the mental processes underlying the blink will be discussed.},
}

@inproceedings{jerrett1998examination,
  title = {An Examination of Differences in the Time-Course of Oxazepam's Effects on Implicit Versus Explicit Memory},
  author = {Jerrett, Susan},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The present study was designed to examine the effects of oxazepam on implicit versus explicit memory processes, as a function of this drug's time course. The effects of oxazepam (30 mg) or placebo on directly comparable tests of implicit memory (word-stem completion) and explicit memory (cued-recall) were examined at three time points: 100 minutes post-drug (prior to the peak plasma concentration of oxazepam; i.e., "pre-peak" condition), 170 minutes post-drug (close to peak; i.e., "peak" condition) or 240 minutes post-drug (following peak: i.e., "post-peak" condition). Sixty volunteers were randomly assigned to either the drug condition or the placebo condition in a double-blind design and were tested on both memory tests at one of the three time points. In the "pre-peak" condition, oxazepam impaired cued recall performance but did not impair priming. In the "peak" condition, oxazepam impaired performance on both memory tasks. In the "post- peak" condition, cued recall performance in the oxazepam group remained significantly impaired. However, oxazepam-induced impairments in priming were only marginal, suggesting that oxazepam-induced impairments in implicit memory processes begin to wane following peak drug concentrations. These findings support the hypothesis that benzodiazepines exert time-dependent effects on implicit memory processes. The results also support the theoretical distinction between implicit and explicit memory processes, since the directly-comparable implicit and explicit tasks showed different impairment curves _I over time.},
}

@inproceedings{duquesnay1998antisense,
  title = {Antisense oligonucleotides decreases the phase shifting ability of light},
  author = {Duquesnay, Renee and Robertson, Harry A and Rusak, Benjamin},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Circadian rhythms are synchronized primarily by cues from daily light-dark cycles. Light that occurs at a time of day when it can shift (and therefore synchronize) the internal circadian clock also causes increases in gene expression in cells of the suprachiasmatic nucleus (SCN). We have investigated whether blockade of this increased gene expression locally in the SCN can alter the phase-shifting responses of the circadian system of hamsters to light. Hamsters were implanted with indwelling cannulas aimed at the SCN and were housed in constant darkness. Hamsters received either control injections or injections of antisense oligonucleotides for the IEGs c-Fos and JunB into the SCN at circadian time (CT) 12 and were exposed to a 30 min light pulse at CT 18. Preliminary results indicate that the antisense oligonucleotides can reduce the phase-shifting effects of light, and suggest that gene expression induced by light plays a role in mediating light effects on the circadian pacemaker.},
}

@inproceedings{greaven1998life,
  title = {Life stress and depressive severity in adolescents with mood disorders},
  author = {Greaven, Sonia H. and Santor, Darcy A. and Kusumakar, Vivek},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {This study investigated the occurrence of life stressors with mood disorders in an adolescent population. Forty-two clinically-referred adolescents with primary mood disorders (30 major depressed, 12 bipolar disordered), between the ages of 12 and 21 (M = 16.06 years) participated. Each participant underwent a systematic lifetime diagnostic interview (K-SADS-PL),two measures of current depressive severity, and a computerized inventory of life stressors within the past two years. Results indicated that the total number of life stressors, as well as the severity of the stress associated with these, were related to current depressive severity. Examination of correlations with specific stressor categories revealed that overall, minor hassles, as opposed to major life events, were related to depressive severity.},
}

@inproceedings{r1998neuraltransp,
  title = {Neuraltransplantation for Parkinson's disease and Gene therapy for malignant brain tumors},
  author = {r, Ivar Mendez and .J},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {No abstract f42) Cognitive Sequelae of Cancer and its Treatment in Children Veronique Mackenzie-Bourne and Richard E. Brown We reviewed 60 papers on the cognitive and neurologic sequelae resulting from the three main cancer treatments, alone and in combination, for the treatment of brain tumours and acute lymphoblastic leukemia. The initial goal of this paper was to examine studies concerning long-term effects in cancer survivors under fifteen years of age and over the age of sixty-five. The main body of literature, however, focuses on children. Long-term cognitive effects in older survivors of childhood and adult cancers have not been studied. The research reviewed suggests that some forms of cancer treatment are worse than others for resulting cognitive sequelae, e.g. whole-brain irradiation and some chemotherapeutic agents (e.g. methotrexate), especially in children under 3 years of age. However, a direct link has yet to be found between cancer treatment and long-term cognitive dysfunction. This is due, in part, to a lack of consistency in research design, method, and populations studied. Research concerning the cognitive problems of treating cancer in the elderly and in determining the long-term effects of cancer treatments in elderly people who are survivors of earlier cancer must also be developed.},
}

@inproceedings{groot1998pavlovian,
  title = {Pavlovian Conditioning in the Circadian System: Fact or FANtasy?},
  author = {Groot, Marleen de and Rusak, Benjamin},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Environmental stimuli such as light can shift or entrain circadian rhythms and induce physiological changes in cells comprising the central circadian pacemaker (the suprachiasmatic nucleus: SCN), including altering the expression of immediate-early genes (IEGs). A recent study (Stewart & Amir, 1996) showed that a stimulus that does not normally have any of these effects can be made to do so after being paired repeatedly with a phase-shifting light pulse in a Pavlovian conditioning paradigm. We assessed whether such Pavlovian conditioning can occur in the circadian system. During training phases, a 20 min air disturbance (CS) was either paired or explicitly unpaired with a 60 min light pulse (US) twice daily for ten-and-a-half days. Behavioural and gene expression results show that the CS does not come to mimic the effects of light on the circadian system following pairing. The failure to find evidence of conditioning could not be explained by a lack of sensitivity to the CS used, since all subjects showed clear behavioural responses to the presentation of the CS during both the training and testing phases of the studies.},
}

@inproceedings{patterson1998suppression,
  title = {Suppression of protein kinase C in the basal forebrain reduces the rewarding effect of brain stimulation.},
  author = {Patterson, Robin L. and Nakajima, Shinshu},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Activation of D1 and D2 dopamine receptors in the nucleus accumbens (NAc) is important for the rewarding effect of various reinforcers including brain stimulation. Blockade of D2, but not D3 or D4, receptors in this region with dopamine antagonists increases the threshold of reinforcement for brain stimulation. Activation of D 1 receptors is necessary to activate D2 receptors._ In the present study, the reward mechanism within NAc was studied by using falphostin C, a selective inhibitor of protein kinase C. The subjects were 42 male albino rats--:-nachof them was implanted with a bipolar electrode into the medial fore brain bundle and two cannulae bilaterally into NAc. They were trained to press a bar to receive electrical stimulation, and the threshold of reinforcing effect was measured before and after the injection of calphostin through the cannulae. Bilateral injection of calphostin into NAc increased the threshold of reinforcing effect in 2 hours and the effect reached the maximus in 4-6 hours. Recovery was observed in 24 to 48 hours after injection. Unilateral injection, either ipsilateral or contralateral to the electrode, was not effective. The results suggest that the rewarding effect of medial fore-brain stimulation is mediated by the activity of protein kinase C in NAc neurons.},
}

@inproceedings{anon1998symposium,
  title = {Symposium To Hebb and Beyond},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Donald Hebb was one of Canada's most famous and distinguished scientists, whose contributions were manifold and writings prolific. Hebb is widely recognized for his neoconnectionist assumption that correlated firing results in improved synaptic transmission (increase in connection weight) and his proposal of the cell assemblies. Hebb was a major advocate of psychology as a science and was a major force in directing its evolution in the 20th century. In order to examine Hebb and his work in a broader context, we will attempt to situate Hebb and his ideas within history, both in terms of the people who influenced him as well as in how his ideas shaped (or failed to shape) subsequent researchers. Some of the areas influenced by Hebb include LTP,kindling, neural networks, animal learning and memory, mental imagery, stopped retinal image, pain, aging and the role of early experience in cognitive and perceptual development. A life history of Hebb connecting significant life events to the various areas of interest integrates the diverse fields in which Hebb made a notable impact. For example, the publication of the Organization of Behavior ( 1949), which was influenced by the writings of William James and Santiago Ramon y Cajal, has exerted an ever-growing influence on those interested in mind, brain and how brains implement mind.},
  note = {QA: needs-split-review; Split from T44 at: 'Symposium To Hebb and Beyond'},
}

@inproceedings{ferrier1998what,
  title = {What does that robot want from me now? Young children's abilities to repair contingent queries.},
  author = {Ferrier, Suzanne},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The ability of two-year-old's to respond differentially to specific and general contingent queries was examined with the use of an immobile robot as the conversation partner. Twenty-one 2;9-year-old and 21 2;3-year-old children were queried (5 specific and 5 general) immediately following 10 of their spontaneous utternaces in a free play session. The type of response strategy (repetition or specification) was coded for each queried utterance. Regardless of age, children tended to respond to a general query with an exact repetition of their original utterance. Age differences were found, however, in their replies to a specific query. The 2;9-year-olds most often replied with the specific information requested, whereas the 2;3-year-olds often repeated their original utterance, providing their partner with too much information. These findings suggest that it is not until 2;9 years of age that children efficiently satisfy their communicative partner's informational needs when conversational exchanges involve only linguistic cues.},
  note = {QA: needs-split-review; Split from T44 at: 'What does that robot want from me now?'},
}

@inproceedings{song1998temperature,
  title = {Temperature Selection and Use of Torpor by the Marsupial Sminthopsis Macroura},
  author = {Song, Xiaowei and Zoology, Fritz Geiser Department of and Sciences, School of Biological and England},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Australia *present address: Rusak Lab, Department of Psychology, Dalhousie University Many small mammals display daily torpor to minimize energy expenditure during the rest phase when faced with unfavorable environmental conditions. However, given a choice of thermal environments, it is not clear whether these daily heterotherms select ambient temperatures based on whether these minimize metabolic rates during torpor or during normothermia. It is also not clear whether they prefer being normothermic or torpid. In this study, we investigated temperature selection, activity patterns body temperature patterns, and the use of torpor in Sminthopsis macroura in a thermal gradient when food was freely available or restricted. Animals employed torpor regularly immediately after cessation of activity even when excess food was provided. Nevertheless, they selected high ambient temperature near the zone of thermoneutrality during both normothermia and torpor. Reduced food supply did not affect either temperature preference during torpor. Our study shows that S. macroura selected a high ambient temperature to reduce energy costs during normothermia. Nevertheless, daily torpor was frequently employed at the high temperature, especially when food was restricted.},
  note = {QA: needs-split-review; Split from T44 at: 'Temperature Selection and Use of Torpor'},
}

@inproceedings{breau1998measurement,
  title = {Measurement of Pain in Non-verbal, Cognitively Impaired Individuals},
  author = {Breau, Lynn and McGrath, Patrick J. and Camfield, Carol and Rosmus, Christina and Finley, G. Allen},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {A preliminary investigation of the properties of the Non-communicating Children's Pain Checklist was conducted. Caregivers of 38 individuals with Cerebral Palsy, Austism/PDD or a neurological disorder completed the checklist at home: twice when that person was in pain, once when they were in distress, and once when they were calm. Caregivers also completed the Checklist concerning their participant's past pain behaviour in general. Analyses were conducted to assess the Checklist's internal consistency, concurrent validity, sensitivity, specificity, and reliability. The results indicate that, when used by caregivers on actual events in a natural environment, the checklist can discriminate between calm and pain, is reliable over time, correlates with a visual analogue measure of pain, and is internally consistent. No differences were found between diagnostic groups, although reported behaviour did vary as a function of the relationship of the caregiver to the individual, and that individual's level of verbal comprehension.},
  note = {QA: needs-split-review; Split from T44 at: 'Measurement of Pain in Non-verbal, Cogni'},
}

@inproceedings{mcglone1998evidence,
  title = {Evidence Based Decision Making: Construct Validity of a Sodium Amobarbital Recognition Memory Protocol},
  author = {McGlone and J and Black and S.E and Evans and J and Grantmyre and A and Moscovitch and M and Parkin and A and Sadler and M and Sita and A and Squires and E and Stuss and D and Wilson, B.A},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Purpose: We tested whether the Intracarotid Arnobarbital Protocol had criterion and concurrent validity. It was hypothesized that a recognition memory test designed for intracarotid injections and used to predict the risk of global amnesia prior to an elective temporal lobectomy should identify persons who are severely amnesic due to other neurological causes. •Speech tasks would be unaffected by amnesia, but would identify aphasia. The impact of aphasia on memory outcome would be negligible. Methods: Fifteen persons with severe amnesia and one aphasic were administered a four- item yes/no recognition memory protocol and a speech protocol. No drug injection occurred. Standardized neuropsychological tests were used to divide the amnesic group into those with Global Amnesia (i.e., retain no ongoing memories), Dissociated Amnesia, and Amnesia plus other neuropsychological deficits (i.e., Non-Dissociated). Results: Two Global Amnesic persons obtained scores at or below chance (i.e., failed) on the memory protocol. Unexpectedly, the remaining 13 severely amnesic persons (Dissociated and Non-dissociated), obtained passing memory scores. Amnesia had no impact on the speech protocol. An aphasic individual passed the memory protocol and was impaired on the speech protocol. Conclusions: This IAP memory protocol showed good criterion validity in identifying Global Amnesia, but it was insensitive to other disabling, severe amnesic disorders. Discriminant validity was shown by amnesic persons perf orrning well on IAP speech tasks. These results suggest that this IAP protocol might have validity in predicting a post surgical Global Amnesic disorder, but it did not identify and therefore could not predict other severe amnesic disorders 24 1998 In-House Convention},
  note = {QA: needs-split-review; Split from T44 at: 'Evidence Based Decision Making:'},
}

@inproceedings{macdonald1998effects,
  title = {The Effects of Alcohol and Alcohol Expectancy on Responses to Hyperventilation in High Anxiety Sensitive Individuals},
  author = {MacDonald, Alan and Hutson, Rochelle and Stewart, Sherry},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {High anxiety sensitivity (AS) levels are significantly associated with increased beliefs about the tension-reduction properties of alcohol (Karp, 1993). The present study examined the effect that these alcohol expectancies might have on alcohol's reactivity dampening effects in high AS young adults (Baker, MacDonald, Stewart & Skinner, under review), in addition to alcohol's pharmacological anxiolytic effects. A three cell beverage condition design was used to assess the contributions of expectancy vs. expectancy plus pharmacology: told alcohol-given alcohol (A-A, pharmacology + expectancy); told alcohol- given placebo (A-P, expectancy only); and told placebo-given placebo (P-P, control). High AS student participants were randomly assigned to each condition. Following alcohol consumption and absorption, participants underwent a 3 minute voluntary hyperventilation challenge. Preliminary analyses indicate that A-A participants show greater reductions in affective, cognitive and somatic symptoms in response to challenge than A-P and P-P participants. However, A-P participants do not show reduced affective and cognitive symptoms to challenge compared to P-P participants. In fact, correlational analyses suggest a positive relationship between subjective intoxication measures and levels of affective reactivity within the the A-P group (a "reverse expectancy" effect), and a negative relationship between these measures in the A-A group. Implications of these results for prevention of alcohol abuse in high AS individuals are discussed.},
  note = {QA: needs-split-review; Split from T44 at: 'The Effects of Alcohol and Alcohol Expec'},
}

@inproceedings{mendella1998role,
  title = {Role of Sulfated Cholecystokinin Octapeptide (CCK-SS) in the Modulation of Separation-Induced Ultrasonic Vocalizations in 12 Day Old Rat Pups},
  author = {Mendella, Paul D. and Szczesniak, Anna Maria and Brown, Richard E.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Rat pups emit ultrasonic vocalizations (UV's) when separated from the dam and littermates. Anxiogenic drugs increase UV s, while anxiolytic drugs decerase UV s. The neuropeptide cholecystokinin (CCK) induces anxiety in health human volunteers and in individuals diagnosed with panic disorder. The purpose of the present investigation was to assess the effects of CCK-8S on UVs, locomotor activity, and body temperature in 12 day old rats pups, 15 or 30 minutes following drug treatment. Pups were injecteJ intraperitoneally with either vehicle or CCK-8S (0.5, 1.0, 2.0, 4.0 µg/kg). After 15 minutes, male pups emitted more UVs and less turing behaviour than female pups. This is one of the few studies to find sex differences in rat pup UVs. After 30 minutes CCK-8S (4.0 mg/kg) significantly reduced line crossing frequency. In addition, male pups completed fewer head raises compared to female pups 30 minutes following drug treatment. Neither UV rate or body temperature was significantly altered by CCK-8S after 15 or 30 minutes. These findings suggest that CCK-8S is not directly involved in the modulation of anxiety-related behaviour in the separation-induced UV model of anxiety.},
  note = {QA: needs-split-review; Split from T44 at: 'Role of Sulfated Cholecystokinin Octapep'},
}

@inproceedings{forestell1998saccharin,
  title = {Saccharin must be added to the taste cue to condition robust taste preferences},
  author = {Forestell, Cathy and LoLordo, Vin},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {A reverse-order differential conditioning procedure was employed to condition taste preference in rats. During training, one taste solution (CS+) was presented 3 min after a calorific reinforcer (glucose), and another taste solution (CS-) was presented 3 min after water. For half of the animals, both taste solutions always contained saccharin, whereas for the remaining animals, the tastes were mixed in water. Subsequently, two-bottle tests revealed a significant preference for the CS+ relative condition. These results suggest that without the presence of sacchrin in the CS solutions, conditioned preferences do not occur.},
  note = {QA: needs-split-review; Split from T44 at: 'Saccharin must be added to the taste cue'},
}

@inproceedings{simpson1998simulating,
  title = {Simulating oculomotor behavior within a neural field model},
  author = {Simpson, S. D. and Klein, R. and Trappenberg, T.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Oculomotor programming can be viewed as the process of integrating exogenous (environmental) and endogenous (intentional) signals into a unified motor goal. Just as many experimental researchers recognize the importance of understanding both the bottom- up and top-down influences on oculomotor programming, we believe it is important to recognize that computational modeling of such systems should also be constrained by multiple levels of analysis; specifically by behavioral and neurophysiological data obtained from the area of interest. By extending and modifying a current neural field model of oculomotor programming (Kopecz and Schoner, 1996) we have developed a computational account of both behavioral and neurophysiological data from a variety of saccadic paradigms including target location preparation (Munoz & Dorris, this meeting), antisaccades (Everling et al, this meeting), and distractor manipulations. In the model, environmental and endogenous signals are integrated within a buildup layer allowing for competition among possible oculomotor programs. The activity of this buildup layer serves as input to a burst layer whose activity represents a specific oculomotor command. This poster will describe the model's architecture and demonstrate its ability to simulate saccadic reaction time patterns and neuronal activity of buildup and burst neurons within the Superior Colliculus. Possible enhancements to the model will also be discussed .},
  note = {QA: needs-split-review; Split from T44 at: 'Simulating oculomotor behavior within a '},
}

@inproceedings{hancock1998whose,
  title = {Whose turn is it? Using impoverished social environments to explore human interaction.},
  author = {Hancock, Jeff},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Contmeporary analyses of human language use portray concersations as a hierarchically organized process requiring coordination of linguistic, paralinguistic and semantic information at several differen levels of activity (e.g. Clark, 1996). One implication of this heirarchical model of human communication is that activities identified at lower levels of coordination (e.g. establishing predictable temporal and sequential patterns of signals, manipulating joint attentional states) must be implemented in order for higher level activities to emerge (e.g. agreed upon knowledge states and social attibutions). Fortunately, in most face-to-face interactions mature speakers display exquisite control over the lower level activities in this hierarchical collaborative process. However, more impoverished social contexts (e.g. immature speakers, computer-mediated communication) may undermine the effective coordination of the lower level activities with the implication that emergent mutually agreed upon knowledge states and social attributional processes will also be disrupted. In this presentation I will describe my initial attempts to manipulate lower level communicative activities within the context of computer-mediated, text-based interactions. 6 1998 In-House Convention},
}

@inproceedings{shoemaker1998voice,
  title = {The Voice from Within: Parasitic Manipulation of Host Hormones and Behaviour},
  author = {Shoemaker, Kelly and Adamo, Shelley},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {When the larvae of the parasitic wasp, Cotesia congregata, emerge from their parasitized host, Manduca sexta, the host exhibits an irreversible decline in feeding and locomotion. The decline is not due to debilitation. In a search for the mechanism(s) underlying the lack of sensory responsiveness, we are measuring the levels of biogenic amines, such as octopamine, in the central nervous system of both control and parasitized M. sexta using HPLC-ED (high performance liquid chromatography with electrochemical detection). Octopamine is thought to regulate behavioural responsiveness in insects. In our experiments, we allow C. congregata to parasitize M. sexta on the first day of the fourth instar. Then, at various times during development, we dissect out the ventral nerve cord of control and parasitized and M. sexta and determine levels of biogenic amines. Preliminary data suggest that octopamine decreases and dopamine increases in concentration during parasitism.},
}

@inproceedings{rossy1998how,
  title = {How Pain Castrophizers Cope with Stressful Life Events},
  author = {Rossy, Nadine H. F. and Sullivan, M. J. L.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Individuals differ markedly in the degree of distress they experience when faced with an aversive situation. Research ahs shown that individuals who 'catastrophize' are more likely to experience heightened pain and emotional distress than indiviudals who do not catastrophize.While the relation between catastrophizng and pain has been studied extensively, little is know about how pain catastrophizers cope with non-painful stressful situations. The present study examined the relation between catastrophizing and methods of coping with stressful major life events. Approximately 150 undergraduates were asked to fill out the Ways of Coping questionnaire, the Pain Catastrophizing Scale and the Pain Self- Efficacy Scale. Following completion of these measures, participants were asked to immerse one arm in ice water for one minute. Consistent with previous research, we predicted that Catastrophizing would be associated with heightened pain intensity during the ice water immersion. Based on research showing a relation between catastrophing and depression, we predicted that catastrophizers would report greater use of avoidant and escape startegies to deal with non-painful life stressors. No predictions were made about the relation between the subscales of the Ways of Coping Scale and responses to the ice water immersion.},
}

@inproceedings{larrea1998prevalence,
  title = {The Prevalence of Cognitive Impairment and Dementia as defined by Neuropsychological Test Performance},
  author = {Larrea, Fernando A. and Fisk, John D.},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {The Canadian Study of Health and Aging (CSHA) estimated the prevalence of dementia for those aged 65 and older to be 8%. Other studies have produced both higher and lower prevalence estimates. Methodological factors that may contribute to these differences include: the use of, or the reliance on, neuropsychological testing, the consideration of functional impairment as a criterion of dementia, and the inclusion of the category of cognitively impaired, not demented (CIND) in the diagnostic classification. In order to examine these issues we conducted a reanalysis of the CSHA database for those individuals which completed neuropsychological testing. If the diagnosis of dementia required only the presence of impairments on neuropsychological testing, an increased prevalence estimate of dementia relative to the final (i.e. consensus) diagnostic opinion resulted. Adding functional impairment for the diagnosis of dementia reclassified many of the individuals as CIND and reduced this discrepancy in the prevalence estimates of dementia. However, the prevalence of CIND as defined by neuropsychological testing was higher than that defined by consensus diagnosis. The implications of these findings for neuroepidemiological studies of dementia and CIND will be discussed.},
}

@inproceedings{kp1998vancouver,
  title = {Vancouver Unimanual Tactile Word Identification Test (VUTWIT) ability in patients with schizophrenia: relationship to olfactory function.},
  author = {KP, Good and JS, Martzke and W, Lopeter and WG, Honer and LC, Kopala},
  booktitle = {24th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1998},
  abstract = {Previous research has shown that olfactory identification deficits are common in patients with schizophrenia. Whether the olfactory deficits are specific to the olfactory system or represent more generalized processing abnormalities has not yet been resolved. Task complexity, generalized memory dysfunction and attentional compromize appear to be unrelated to olfactory deficits. However, comparison tasks used in these studies differed from the olfactory tasks in their reliability. The purpose of this study was to investigate the specificity of olfactory identification deficits in patients with schizophrenia by utilizing two analogous tasks of identification ability which were psychometrically similar, but differed in the sensory modality tested. The University of Pennsylvania Smell Identification Test (UPSIT) was adminsitered unirhinally and the Vancouver Unimanual Tactile Word Identification Test (VUTWIT) unimanually to 24 patients with schizophrenia and 44 normal controls. Controls outperformed patients on right and left UPSIT and VUTWIT. Significant Spearman correlations were observed between left VUTWIT and right and left UPSIT. These data suggest that in patients with schizophrenia, olfactory identification deficits may not be olfactory in origin, but rather may reflect other processing difficulties.},
}

@inproceedings{porter1999profiles,
  title = {Profiles of Psychopathy in Incarcerated Sexual Offenders},
  author = {Porter,  Steve and Birt, Angie and Campbell, Mary-Anne},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {We investigated whether psychopathy would contribute to an understanding of the nature and heterogeneity of sexual violence. Using the Psychopathy Checklist-Revised (PCL-R; Hare, 1991), level of psychopathy, callousness (Factor 1), and antisocial patterns (Factor 2) were examined in a diverse sample (N = 329) of incarcerated adult male sex and non-sex offenders. The offenders were categorized according to their crimes (extra-familial molesters, intra-familial (incest) molesters, mixed offense molesters, rapists, mixed rapist/ molesters and non-sex offenders). Mixed rapist/ molesters, rapists, and non-sex offenders scored significantly higher on the PCL-R than molesters, although all sex offender groups showed elevated Factor 1 scores. Most (64%) mixed rapist/ molesters were psychopathic, indicative of a "sexual psychopath" whose thrill-seeking is focussed on diverse sexual victims. There were different interpersonal and social deviance profiles among the groups and an interaction between factor scores and offense type. These profiles have implications for recidivism, treatment, and, more generally, a comprehensive theory of sexual violence.},
  note = {Poster; booktitle inferred},
}

@inproceedings{connolly1999neuropsychol,
  title = {Neuropsychological Assessment of Receptive Vocabulary and Comprehension With Event-related Brain Potentials},
  author = {Connolly, John F. and D'Arcy, Ryan C.N. and Major, Alma M. and Allen, Sheri L. and Eskes, Gail A. and Phillips, Stephen J.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The clinical application of evoked potentials has proven invaluable for assessing sensory functions. Recently, we have adapted standardized neuropsychological tests for computer presentation with simultaneous event-related brain potential (ERP) recordings for assessing cognitive functions. The Vocabulary and Similarities sub-sections of the Wechsler Adult Intelligence Scale-Revised as a Neurological Instrument (W AIS-R-NI) were used to assess receptive single word vocabulary and verbal concept formation, respectively. The Written Comprehension section of the Psycholinguistic Assessments of Language Processing in Aphasia (PALPA) was used to assess receptive sentence comprehension. Test items from all three paradigms consisted of a study phase and a test phase. During the study phase, the test question and response alternatives were presented on a computer screen. Participants were requested to study the question, select an answer, and remember the answer. During the test phase, the response alternatives were presented individually and ERPs were recorded. Participants were requested to identify the correct and incorrect response alternatives. Items which the individual indicated as 'correct' were differentiated from alternative items by the presence of a P300 response. The P300 response was hypothesized to represent recognition memory and contextual updating processes following the presentation of a meaningful stimulus. Receptive language dysfunction is frequently noted in aphasic individuals suffering from stroke or traumatic brain injury. However, due to communicative limitations, these patients cannot be readily assessed with traditional methods. In these and similar instances, it is possible to assess language and other cognitive functions with neural responses that are relatively independent of behaviour.},
  note = {Poster; booktitle inferred},
}

@inproceedings{clements1999differences,
  title = {r Differences)n,Children's C~~ceptual Strategies When•f;J:iinkipg4bo11t~•Century of Rats in Mazes},
  author = {Clements, Robert L.H. and Brown, Richard E.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Between 1898 and 1900, Willard S. Small studied development and general behaviour in rats at Clark University. In order to quantify their learning ability, he tested them in a rat-sized model of the Hampton Court Maze. With this study, Small (1901, The American Journal of Psychology, 12:207-239) was the first to combine laboratory investigation using rats and the concept of an intellectually puzzling maze. Over the last one hundred years, a wide variety of mazes have been used to study basic questions regarding the sensory and neural basis of learning, motivation and perception. A multitude of species have been tested in mazes, from worms to humans. Innumerable mazes have been developed and used widely in psychological research, including the T-maze, Lashley's type 3 maze, Tolman's sunburst maze, the Hebb-Williams maze, Barnes Maze and the 8 arm radial maze. Mazes such as the Porteus maze, developed in 1917, and newer computerized virtual mazes, are still used as standardized tests for human mental abilities. The current literature lacks a comprehensive overview of the use of mazes in scientific research. Our paper provides a history of this fascinating apparatus and its use. An in-depth review of the literature found over 11,000 papers on maze learning in the last 100 years and we are going to tell you about every last one of them, with particular emphasis on some of the currently popular mazes used in psychology (Morris water maze, 8-arm radial maze, elevated plus maze). The discussion summarizes the advantages and disadvantages of using mazes in psychological and medical research.},
  note = {Poster; booktitle inferred},
}

@inproceedings{forestell1999olfactory,
  title = {Olfactory Conditioning and Differential Immediate Early Gene Expression in Mice},
  author = {Forestell, Catherine A and Schellinck, Heather M and Brown, Richard E and LoLordo, Vincent M},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The present experiment investigated whether adult mice acquired conditioned responses to an odour paired with a caloric reinforcer and which parts of the brain are involved in the formation of this association by looking for differences in c-fos-like-immtinoreactivity. Food restricted mice were exposed to a differential conditioning procedure in which experimental animals received an odour (CS+) paired with sucrose pellets in a dish covered with bedding and another odour (CS-) presented alone in a dish with bedding. Control animals were either exposed to the odours separately in a dish containing bedding and no reinforcement, or to no odour. After 32 conditioning trials, animals were placed in a chamber divided into three equal sections with CS+ and CS- on each end of the chamber. Experimental animals spent significantly more time digging in the dish containing CS+ than CS- relative to control animals. On the next day, all animals received exposure to CS+, CS-, or no odour for 10 min, 2 hours prior to perfusion. Fos-like-immunoreactivity was assessed in brain structures such as the glomerular layer of the olfactory bulbs, piriform cortex, the hippocampus, and the periventricular nucleus of the thalamus.},
  note = {Poster; booktitle inferred},
}

@inproceedings{mcfadyen1999effects,
  title = {Effects of Methylphenidate Hydrochloride (Ritalin) Injections During Development on Locomotion, Exploration, Fear, and Cognitive Processes in Mice},
  author = {McFadyen, Melanie and Carrey, Norman and Brown, Richard},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Although the use of the stimulant methylphenidate (Ritalin) is increasing among children, little is known about the potentially deleterious effects it may have on their cognitive and behavioural development. Our study uses a mouse model to examine the developmental effects of methylphenidate (MPH) (daily 40 mg/kg sc vs. saline injections) in male CD-1 mice, from postnatal days 26-32. The mice were tested from postnatal days 33-37 for locomotion and exploration in the open field (day 1), anxiety in the elevated plus maze (day 1), and learning the Morris water maze (days 2-5), with a visible platform for three days and a hidden platform on day 4. Our results indicate that MPH-treated mice were more active in the open field, entering more centre squares than the saline controls; MPH-treated mice spent more time in the open arms and exhibited more head dips in the elevated plus maze than controls, and that, while there was no significant difference between MPH and saline-treated mice in the time taken to find the visible platform in the Morris water maze, the MPH-treated mice showed a tendency to take longer to find the hidden platform. The results indicate that treatment with methylphenidate has significant effects on later anxiety, reducing fear and increasing locomotion, but less of an effect on learning in a swimming task. However, since the methylphenidate-treated mice were hyperactive, their learning may be affected more in tests of inhibition.},
  note = {Poster; booktitle inferred},
}

@inproceedings{macdonald1999factor,
  title = {A Factor Analytic Investigation of the Alcohol Expectancy Questionnaire -3rd Version},
  author = {MacDonald, Alan B. and Stewart, Sherry S.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The Alcohol Expectancy Questionnaire - 3rd version (AEQ-III; Goldman, Greenbaum & Darkes, 1997) is a self-report instrument consisting of 68 items designed to assess positive expectancies or beliefs about the outcomes of drinking alcohol. The AEQ-III is a revised version of the original, 90-item AEQ, and has not yet been evaluated extensively from a psychometric perspective. The purpose of the present study was to explore the factor structure of the AEQ-III in an undergraduate university sample and attempt to replicate the factor structure found by Goldman et al. (1997). Eight-hundred and nine undergraduates students were administered the AEQ-III. Exploratory principal components analysis with oblique (Oblimin) rotation identified that six factors best explain the underlying dimensions of this measure in this population. These factors include: 1) Social Assertiveness (SA); 2) Global Positive Changes (GP); 3) Social & Physical Pleasure (SP); 4) Sexual Enhancement (SE); 5) Arousal/Aggression (AA); and 6) Relaxation (R). The factor structure proposed by Goldman et al. (1997) was replicated. Implications for the use of this measure in determining potential alcohol expectancies and patterns of drinking in young adults are discussed.},
  note = {Poster; booktitle inferred},
}

@inproceedings{darcy1999profound,
  title = {Profound Amnesia Does Not Impair Performance on 36-item Digit Memory Test - A Test of Malingered Memory},
  author = {D'Arcy, Ryan C.N. and McGlone, Jeannette},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Global amnesia spares immediate span of attention while compromising retrieval after a delay filled with distractions. Accordingly, we hypothesized that the Digit Memory Test (DMT) would classify persons with severe, disabling amnesia as "non-malingerers" better than malingering tests utilizing interference or recall paradigms. Fourteen cases with profound amnesia, including 2 persons with global amnesia, obtained scores of 100% correct on the 36-item DMT. However, the Rey 15-item Test of malingering and a multiple choice delayed recognition memory test yielded false positive outcomes. We conclude that the DMT has excellent specificity with respect to correctly identifying persons with severe memory disorders due to neurological lesions by correctly classifying all as "non-malingerers".},
  note = {Poster; booktitle inferred},
}

@inproceedings{gingras1999spatial,
  title = {The Spatial Localization Deficit in Visually Deprived Kittens: Comparison with Human Amblyopes},
  author = {Gingras, G. and Mitchell, D.E. and Hess, R.F.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Purpose In order to provide data that could assist resolution of a debate over the nature of the underlying neural deficit in amblyopia, we measured the deficits in spatial localization of visually deprived kittens by use of the same tests as those employed for the assessment of human amblyopes. Methods. The tests were conducted on one normal and 6 selectively deprived kittens. Four of the kittens were monocularly deprived by eyelid suture while on two others esotropia was induced by section of the lateral rectus muscle of one eye when either 17 or 29 days old. Of the 4 monocularly deprived kittens, 2 were deprived from near birth to 60 (C773) and 82 (C772) days of age while the others were deprived for either 6 (C791) or 30 (C775) days beginning at respectively, 35 and 38 days. When the animals were 5 months of age, measurements were made of the accuracy with which they could detect a misalignment between three Guassian blobs of high contrast. The outer two blobs were in vertical alignment and measurements were made, by use of a jumping stand and a method of descending limits, of the minimum detectable horizontal misalignment of the middle blob for both the deprived (or deviating) and nondeprived eyes. Measurements of alignment accuracy were made at different spatial scales (where the stimuli were spatial scaled versions of one another) and as a function of contrast. Results. For both the normal animal and the nondeprived eyes of each of the visual deprived kittens, there was a comparable proportional relationship between alignment accuracy and Guassian blob size to that observed in humans. Moreover, there was a similar weak dependency on stimulus contrast. As with amblyopic humans, the deficits in alignment accuracy were scaled in proportion to blob size but were in general larger than those reported in human amblyopes. The deficits were greatest in the strabismic cats where the alignment accuracy of the deviating eye was 30 times worse than that of the other eye. The deficits in the deprived eye of the monocularly deprived animals were not related in any simple way with either the length of the deprivation or the deficits in grating acuity. Conclusions. The similarity of the pattern of results to that observed in human amblyopes suggests that by suitable titration of the timing of deprivation it will be possible to produce deficits similar to those exhibited in human deprivation and strabismic amblyopia thereby allowing for converging information on the nature of the underlying neural deficits.},
  note = {Poster; booktitle inferred},
}

@inproceedings{mclaughlin1999inhibitory,
  title = {Inhibitory Control in Children With Attention Deficit Hyperactivity Disorder},
  author = {McLaughlin!, E.N. and Kleinl, R.M.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {In an effort to fully explore the validity and nature of the recently proposed inhibitory control deficit theory of attention deficit hyperactivity disorder (ADHD; cf Barkley, 1998), we tested children with and without ADHD on five different tests of inhibitory control. The Colour-Word Stroop test assessed negative priming and inhibition of distracting information. A Simon/Erikson task tested filtering ability and inhibition at the response selection stage. A delayed eye movement task examined the ability to suppress reflexive and memory-guided saccades. Inhibition of return was measured in a covert visual orienting task. A stop-signal task measured the ability to inhibit a visually-triggered response. We will report on the degree to which children with ADHD differ from controls on the measures of inhibition derived from these tasks, as well as on the degree to which these inhibitory mechanisms tend to covary.},
  note = {Poster; booktitle inferred},
}

@inproceedings{darcy1999increased,
  title = {Increased Processing Demands During Target Error Detection on the Computerized Token Test},
  author = {D'Arcy, Ryan C.N. and Connolly, John F.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Recently, we have adapted the Token Test (De Renzi and Vignolo, 1962, Brain, 665-678) for computer presentation with simultaneous event-related brain potential (ERP) recordings. The Token Test is a standardized neuropsychological measure of auditory comprehension. The objective of this study was to investigate whether variations in stimulus complexity influenced the cognitive processes involved in spoken word identification. The computer Token Test (CTI) was designed as a target detection task that required individuals to understand spoken sentences in order to detect an incorrect target word. For each trial on the CTI, participants were instructed to study a short animation sequence presented on a computer monitor. The animation sequence consisted of a pointer that touched either one or two tokens. Immediately after the animation, participants heard a single sentence description that was either correct or incorrect. ERPs were recorded to the onset of incorrect target words within the spoken sentences. In the Similar condition, the initial phonemes of the incorrect words were similar to the initial phonemes of the correct words (e.g., circle/square). In the Different condition, the incorrect target words had different initial phonemes and thus could be identified as incorrect at word onset (e.g., green/red). The ERP responses to words in the Similar condition elicited a negativity in the 250ms to 350ms region, which was not observable in the ERP responses to incorrect words in the Different condition. The negativity was hypothesized to reflect increased processing demands during error detection when the initial phonemes of the target words were similar.},
  note = {Poster; booktitle inferred},
}

@inproceedings{buffettjerrott1999relationship,
  title = {The Relationship Between Anxiety Sensitivity Scores of Parents and Their Adult Children},
  author = {Buffett-Jerrott, Susan E. and Stewart, Sherry H. and Watt, Margo and Jang, Kerry L.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Calamari et al. found a strong positive relationship between the anxiety sensitivity scores of parents on the ASI, and their young children on the CASI. In a twin study, Stein et al. found evidence for heritability on the social and physical subscales of the ASI but not on the psychological subscale. The present study examined ASI scores of 160 university students and their parents. Results indicate that total ASI scores of parents and their adult children are marginally related. Consistent with the findings of Stein, there are significant positive relationships for the physical and social subscales, but not the psychological subscale. Overall, the results are consistent with Calamari's findings that ASI scores of parents and their children are correlated. However, the magnitude of the relationship is much smaller in the present study. This is likely due to the many intervening events besides parental influences that may affect the development of anxiety sensitivity in individuals as they get older.},
  note = {Poster; booktitle inferred},
}

@inproceedings{israeli1999neuropsychol,
  title = {Neuropsychological Predictors of Quality of Life in Stroke Survivors},
  author = {Israeli, Anne and function and Eskes, Gail},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The current study was conducted to assess whether cognitive and activities of daily living, as measured using the Neurobehavioral Cognitive Status Exam and Barthel Index, would predict short-term outcome following stroke. Forty-two patients with first stroke completed the NCSE within two weeks of admission to an acute stroke service. Discharge BI scores were calculated 2-4 days prior to discharge. Three months post-stroke outcome was measured with the BI, the Reintegration to Normal Living Scale and the Medical Outcomes SF-36, obtained via telephone interview. A series of stepwise regressions revealed that discharge BI scores and BI, the Orientation subscale of the NCSE predicted follow-up and RNL scores, but did not predict MOS-SF-36 scores. During the acute phase following stroke, basic cognitive processes such as orientation and outcome, activities of daily living may provide relevant information regarding short-term},
  note = {Poster; booktitle inferred},
}

@inproceedings{jfconnolly1999left,
  title = {Left Temporal Cortex Activation Reflects Distinct Time Courses of Word and Context Comprehension},
  author = {J.F.Connolly and P.Helenius and E.Service and R.Salmelin},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The time course and cortical basis of reading comprehension were tracked using magnetoencephalography CMEG). The cortical structures implicated most consistently with comprehension were located in the immediate vicinity of the left auditory cortex, where final words totally inappropriate to the overall sentence context evoked enduring activation between 250 ms and 600 ms after word onset. Contextually appropriate but unexpected words produced weaker activation, which terminated earlier. We propose that the point in time (350 ms after word onset) where the response to appropriate but unexpected endings started to diverge from those to contextually inappropriate endings reflects the boundary between understanding a single word and the meaning of a whole sentence.},
  note = {Poster; booktitle inferred},
}

@inproceedings{tripp1999pain,
  title = {Pain, Pain Coping Strategies, Affective Distress, and Return to Function in Athletes Following ACL Surgery},
  author = {Tripp, Dean},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {This study has examined pain, coping, and functional recovery in athletes who have had Anterior Cruciate Ligament (ACL) reconstructive surgery. All patients were examined pre and post-op on a variety of measures. Post-op assessment periods were: 24, 48, and 72 hrs, 2, 8, 16 weeks. As may be expected pain and functional disability peaked shortly after surgery and gradually declined over the course of 16 weeks. The relationship between pain coping and effective distress however tells a much more interesting story ... stay tuned.},
  note = {booktitle inferred},
}

@inproceedings{shoemaker1999adaptive,
  title = {Adaptive Changes in Egg-laying in the Cricket, Gryllus integer, in Response to Infection by the Potentially Lethal Bacterium, Serratia marcescens},
  author = {Shoemaker, Kelly and Adamo, Shelley},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Animals must distribute resources to both somatic and reproductive activities, and the energy allocated to reproduction at each age is selected so that lifetime reproductive success is maximized. However, if the probability of future reproduction declines due to age or illness, then it would be adaptive for animals to re-allocate current resources, and increase reproductive effort at the expense of survival. Previous tests of this hypothesis have been performed primarily on birds or mammals, where parental care complicates the issue. We are currently testing the hypothesis in the field cricket, Gryllus integer. G. integer females lay eggs, but do not exhibit parental care. Their life history suggests that they should increase egg-laying when infected with a potentially lethal pathogen, such as the bacterium, Serratia marcescens. Experiments are in progress.},
  note = {booktitle inferred},
}

@inproceedings{greaven1999timing,
  title = {Timing of Transitions in Adolescence},
  author = {Greaven, Sonia H. and Santor, Darcy A. and Kusumakar, Vivek},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The study of adolescent transitions, which mark the development of the individual from childhood to adulthood, must address the issue of temporality. Although the changes associated with adolescence have been shown to occur in an interrelated manner (e.g., Lerner et al, 1996), the effects of the timing of adolescent transitions has not been adequately explored. The prevalence of various transitions in a normal adolescent population (N = 596) was examined. The analyses of these data determine a) whether each of 12 transitions has been experienced by a majority of adolescents, and b) which transitions are viewed as most important by the adolescents. The effect of timing of transitions will be addressed in 3 ways. First, whether the timing of transitions in comparison with the adolescents' social referent will affect how the transitions are experienced. Secondly, whether particular subsets of these changes occur in an interrlated and/or sequential manner. Finally, the question of whether the lack of a given transition within a normative sequence represents a potential risk factor will be addressed.},
  note = {booktitle inferred},
}

@inproceedings{rossy1999issues,
  title = {Issues of Confidentiality in Testimony Given by Psychotherapists},
  author = {Rossy, Nadine H.F.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The role of a psychotherapist is changing dramatically. Psychotherapists are professionals who examine issues that an individual may have through the use of a variety of techniques. In addition, a psychotherapist may act as a resource seeker, detective, confidante, mediator, and team coordinator. More recently, psychotherapists have acquired two roles in the legal arena. In the legal arena, the psychotherapist may act as an expert witness or a fact witness. As an expert witness the psychotherapist is asked to give his/her opinion about legal issues and/or may act as a forensic consultant. In contrast, as a fact witness, the psychotherapist testifies to the direct observation of the client during therapy. The issues of confidentiality, informed consent, and legal privilege that arise for a psychotherapist in the role of fact witness will be presented as well as alternative courses of action that may be taken. It is concluded that a need for education about this dilemma exists.},
  note = {booktitle inferred},
}

@inproceedings{jaskie1999role,
  title = {The Role of Semantic Memory in Category-Specific Visual Agnosia},
  author = {Jaskie, Karen E. and McMullen, Patricia A.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Category-specific visual agnosia (CSV A) is a disorder of object recognition in which the ability to recognize objects belonging to one or more categories is selectively impaired following brain damage. In one form of CSV A, the ability to recognize living things is impaired, while recognition of non-living things remains relatively intact. Case studies of CSVA have indicated damage to both semantic memory mechanisms and visual perceptual mechanisms. A variety of theories have been developed to explain the existence of a living/non-living double dissociation. McRae et al. (1997) emphasize the importance of intercorrelations amongst individual semantic features. Upon analyzing 190 different concepts, they found that there was a much higher intercorrelation between the features of living things than artefacts. Using a lexical decision priming task, we plan to investigate differences in the connectivity of the features of living things and the features of artefacts within the network of semantic memory.},
  note = {booktitle inferred},
}

@inproceedings{large1999orientation,
  title = {Orientation Effects in Face Recognition: How Similar Are They to Object Orientation Effects?},
  author = {Large, Mary-Ellen},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {A common debate in face and object recognition literature is whether faces and objects share similar processing systems or not. As an extension to this debate my proposed research investigates whether faces exhibit the same characteristic responses to orientation as objects. Joliceur (1985) found that the time to name rotated objects (between 0 deg and 120 deg) varies systematically as a function of departure from an upright orientation. With practice the magnitude of this orientation effect decreases significantly. Tarr and Pinker (1989) demonstrated, using novel abstract stimuli, that this effect diminishes because orientation-specific templates are formed each time the objects are identified. However, Murray et al (1993) failed to support this view when they used line drawings of real objects. Further work by Schellinck, McMullen and Hamm (manuscript) using feature scrambled objects suggests that practice effects are based on orientation-invariant features. The purpose of further study is to discover whether a practice effect occurs with photographic face stimuli. If a practice effect is found the next stage will be to investigate whether this phenomenon is based on orientation-specific templates or orientation invariant representations.},
  note = {booktitle inferred},
}

@inproceedings{braaksma1999awareness,
  title = {Awareness and Implicit Memory Using Event Related Potentials During Recovery from Anesthesia in Adolescence},
  author = {Braaksma, Deanna and Finley, Allen and McGrath, Patrick and Connolly, John},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Explicit and implicit memory has been shown after General Anaesthesia (GA) suggesting that information was processed deeply enough to access its semantic content. A late latency Event Related Potential (ERP) component, the N400, is sensitive to the semantic features of language and requires attention to both the eliciting stimulus and its context. In the present study, auditory ERPs to semantically congruent and incongruent word pairs will be used to assess unconscious cognitive processing and the presence of implicit memory during recovery from anesthesia. Adolescents who are booked for minor procedures under GA will be recruited from a Childrens Day Surgery ward. Eight channels will be recorded and word pair stimuli will be presented preoperatively and during and after recovery from GA. Implicit memory will be assessed using a word association task to primed words. It is hypothesized that the presence of an N400 will be related to the presence of implicit memory.},
  note = {booktitle inferred},
}

@inproceedings{ivanoff1999animate,
  title = {Animate and Inanimate Entities},
  author = {Ivanoff, Jason and Klein, Raymond M.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Two experiments examined the interaction between the Simon effect (SE) and inhibition of return (IOR). The SE refers to better performance when the task-irrelevant location of the imperative stimulus and response spatially correspond relative to when they do not correspond. IOR refers to better performance when the location of a precue and target do not correspond elative to when they do correspond, when cue location is task irrelevant and stimulus onset asynchrony (SOA) is generally greater than 400 ms. In the present investigation, the form of the precue provided subjects with response selection information, and the target provided response execution information. To the extent that IOR has a motoric component, inhibition at the cued location should reduce the SE. Similarly, this prediction is in line with an attention shifting account of the SE: there should be a smaller SE at the cued location relative to the cued location. At the long SOA, IOR was larger when the spatial location of the target and response corresponded relative to when they did not correspond. Similarly, SE was greater at the uncued than at the cued location. The magnitude of IOR was influenced by the intentions to produce a response. The results support an attentional-motor view of IOR and they support an attention-shift account of the SE.},
  note = {booktitle inferred},
}

@inproceedings{differences1999cued,
  title = {Cued Judgments of True and False Memory Reports: The Effect of Training and Individual},
  author = {Differences},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {., i Mary Ann Campbell & Stephen Porter The false memory debate has highlighted the complexity of evaluating memory reports in both legal and therapeutic settings (e.g., "recovered" memories of abuse, erroneous eyewitness statements and false confessions). As such, the present study examined the influence of cue training and individual differences on the ability to make accurate credibility judgments of true and false memories. Information about the personality characteristics and baseline measures of perceived cues to false memory reports were obtained from the sample of 100 university undergraduate students. Half of the sample received information about cues research has shown to be characteristic of true or false memories (training group). A control group received no training. Both groups viewed a video of a common target recounting a truthful and implanted childhood memory in separate interviews and were asked to judge the credibility of both reports and indicate the cues used to assist their judgments. Judgment accuracy was assessed separately for true and false reports. Although results are not yet available, a significantly greater use of appropriate cues and better detection accuracy of the trained group compared to controls would support the hypothesis that training improved detection of false memory reports. The results of this study will offer insight into the benefits of training and the role of individual differences in judgments of memory credibility. Further, the findings will contribute to a framework on which the training of law enforcement professionals and therapists could be developed to assist in making more accurate credibility assessments. Wur'f.v-y ?J/'-f/i,ttY,_j},
  note = {booktitle inferred},
}

@inproceedings{nichols1999executive,
  title = {Executive Function Abilities and Social Behaviour in Young Children},
  author = {Nichols, Shana L and Moore, Chris},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Interest in executive function abilities in young children has flourished within the area of developmental psychopathology. However, little is known about the normal development of executive functions and the relationship between executive function abilities in young chidren and social behaviour has been largely unstudied. Recently, Moore, Barresi, and Thompson (1998) found a relationship between children's performance on an inhibitory control task and their ability to engage in future-oriented sharing behaviour. Further research is needed in order to address the nature of executive function development in young children and its implications for emerging social behaviour. The goal of the present research was to explore possible links between executive functions and social behaviour in three-and-a-half year olds. Executive function tasks included measures of inhibitory control, attentional flexibility, and working memory. Social behaviour was examined in two ways: behavioural observations during a free play session and a future-oriented sharing task.},
  note = {booktitle inferred},
}

@inproceedings{kiss1999electrophysi,
  title = {Electrophysiological Studies of Task Complexity: Does P3b Latency Reflect Stimulus Evaluation Time?},
  author = {Kiss, Ivan and Fazikas, Wolf and Pazderka-Robinson, Hannah and Floden, Darlene},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {P3B latency has been considered a measure of stimulus evaluation time (Kuras, McCarthy & Donchin, 1977; McCarthy & Donchin, 1980; Magliero et al., 1984). However, it is not clear which of the processes involved in stimulus evaluation are indexed by P3B; whether it reflects detection of salient stimulus features, completion of cognitive processes required for full target identification beyond the physical stimulus level or some intermediate stage. We have completed two experiments in which task difficulty was manipulated with minimal changes to stimulus properties and response requirements. P3b latency measures and the emergence of additional ERP features confined to more difficult processing tasks suggest that: 1) P3b does not index completion of stimulus evaluation 2) Longer latency components emerge with more complex tasks. We also report results of preliminary studies involving a "depth of processing" manipulation which suggest that P3b latency is sensitive to semantic processing requirements.},
  note = {booktitle inferred},
}

@inproceedings{clark1999self,
  title = {Self-processes in Early-elementary Age Children},
  author = {Clark, Sharon},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {A sense of self is thought to emerge from early interactive relationships with significant others. Internal working models form two complementary models of self and other and include the child's beliefs concerning worthiness of care in the conceptualisation of self, and statements regarding the dependability and acceptance of the attachment figure in other. Concurrent and predictive relations of child-mother attachment security to self-concept and self-esteem in 29, 5-year-old children (girls n = 10, boys n = 19) were examined. Self-esteem was defined as the evaluative component of the self and self- concept as the descriptive component of self. Attachment security was measured at age 2 and at age 5. Children who were able to admit imperfections in themselves and maintained a positive valence on the self-esteem measure had higher attachment security scores at age five than at age two and had higher self-concept scores than the other children. Data currently being collected will be discussed along with these earlier findings.},
  note = {booktitle inferred},
}

@inproceedings{newman1999event,
  title = {Event-Resolution Imaging: Overcoming the Limitations of Signal Averaging in ERP Research},
  author = {Newman, Randy Lynn},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The interpretation of event related potential data has typically relied on the process of signal averaging to extract meaningful information from background noise. The major limitation of this process is that numerous trials are required to generate a single meaningful waveform. A new method of interpretation developed by Thoughtform Corporation, called event-resolution imaging (ERi), appears to overcome this limitation. ERi employs a variety of methods to discover a set of features which best discriminates and identifies epoch types. This information is encoded as an interpretation map, which is subsequently used to analyze and interpret raw EEG data on an epoch by epoch (i.e. single trial) basis. The result of this analysis, is the production of a high signal-to-noise, non-averaged waveform. A demonstration of ERi will be performed, to be followed by a discussion of its potential role in current ERP research.},
  note = {booktitle inferred},
}

@inproceedings{larrea1999there,
  title = {Are There Differential Effects of a Selective Reminding Procedure on the Learning Characteristics of Individuals with Alzheimer's Disease and Isolated Memory Impairment?},
  author = {Larrea, Fernando A. and Fisk, John D.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {There is currently debate regarding the effect of cues on the learning of subjects with Alzheimer's Disease (AD). Some have suggested that cuing is particularly important in AD, whereas others don't support this facilitation effect. This study examined responses on the Buschke Cued Recall Test (BCRT) to compare free and cued recall in groups of subjects in the Canadian Study of Health and Aging with either AD or isolated memory impairment. Subjects with isolated memory impairment performed better than the AD subjects on all measures. However, both groups benefitted to a similar extent from cues on the initial learning trials and both had a similar rate of learning on the free recall trials. The quantitative but not qualitative differences in performance of the groups suggests that many subjects with isolated memory impairment are in the pre-clinical stages of AD. The positive learning slope for the AD group suggests that a cued recall procedure can facilitate learning in AD subjects. Keynote Speech:},
  note = {booktitle inferred},
}

@inproceedings{language1999peter,
  title = {' Dr. Peter Jusczyk},
  author = {Language, The Discovery of Spoken},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {To acquire a native language, a learner has to correctly identify the units (words, phrases, and clauses) that are combined and manipulated in forming utterances in that language. A failure to identify the appropriate units in the speech input would greatly complicate learning how sentences are structured in the native language. There is considerable evidence that, during the second half of the first year, infants rapidly converge on the specific properties that distinguish the sound organization of their native language from other languages. Infants' developing sensitivity to native language sound structure not only plays a role in helping to segment words from fluent speech, but has consequences for learning about the language's grammatical organization. Thus from an early age, infants appear to use information in the speech signal to group the input in a way that facilitates the discovery of the structure of utterances. Findings from our laboratory show that infants detect cues to clausal and phrasal units in utterances well before they actually begin producing and combining words. Furthermore, the groupings that infants perceive in the input influence what information they encode and retain about speech. In addition, there is evidence that infants are sensitive to the sequential order of elements in the information that they retain. I will discuss some of these findings and their implications for understanding how learners discover the organization of their native language. Jusczyk, P. W. (1997). The discovery of spoken language. Cambridge, MA: MIT Press. T23. An Investigation of Sentence Reading Using Event-related Functional Magnetic Resonance Imaging (fMRI) / Ryan C.N. D'Arcy, John F. Connolly, Larry Gates, and Elisabet Service Neurophysiological studies of reading have successfully elucidated electrical and magnetic correlates of cognitive processing, such as semantic analysis manifested by the N400. We used an established paradigm from ERP/MEG research to study the neuranatomical regions of activation during sentence reading. The participants read a series of sentences with terminal words that were either semantically congruent or incongruent (e.g., The pizza was too hot to: eat/sing). In both condi},
  note = {QA: needs-split-review; booktitle inferred; Split from T22 at: 'The Discovery of Spoken Language'},
}

@inproceedings{darcy1999investigatio,
  title = {An Investigation of Sentence Reading Using Event-related Functional Magnetic Resonance Imaging (fMRI) ,,},
  author = {D'Arcy, / Ryan C.N. and Connolly, John F. and Gates, Larry and Service, Elisabet},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Neurophysiological studies of reading have successfully elucidated electrical and magnetic correlates of cognitive processing, such as semantic analysis manifested by the N400. We used an established paradigm from ERP/MEG research to study the neuranatomical regions of activation during sentence reading. The participants read a series of sentences with terminal words that were either semantically congruent or incongruent (e.g., The pizza was too hot to: eat/sing). In both conditions, activation was observed in those neuroanatomical regions (e.g., visual cortex) thought to be involved in reading. However, additional activation was observed in several regions, including the left angular gyrus, for the semantically incongruent condition. The findings concurred with previously localized N400 dipoles using MEG with the same experimental paradigm.},
  note = {booktitle inferred},
}

@inproceedings{klein1999looking,
  title = {Looking at Looking by Mind and Brain},
  author = {Klein, Ray and collaboration, the SOPOS},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Cognitive neuroscience is concerned with how the mental representations and processes that underly complex behavior are implemented by neural structures and processes in the brain. Our interdisciplinary team focussed on the control of gaze direction (overt visual orienting), in particular the control of fixation and saccadic eye movements, as a 'model system' for exploring the interplay between volitional and reflexive control systems, the mechanisms of preparation, the influence of objects on actions. With a few examples, I will illustrate our interdisciplinary approach, which is characterized by a joint consideration of normal performance, the behavior of neurons during normal performance and the changes in performance that occur as a result of manipulations of (e.g. damage to) brain structures. Our understanding of how the brain controls looking is both reflected in and driven by our neural field model which is able to simulate oculomotor performance and the behavior of neurons in a wide range of tasks.},
  note = {booktitle inferred},
}

@inproceedings{hancock1999asymmetry,
  title = {An Asymmetry in Children's Comprehension of Verbal Ironic Criticisms and Compliments},
  author = {Hancock, Jeff},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Extant research on children's comprehension of verbal irony has focused on critical forms of irony to the exclusion of less typical complimentary forms. Two experiments examined children's ability to detect and comprehend ironic criticisms and compliments presented in videotaped stories. In experiment 1, children more frequently detected the non-literal nature of ironic criticisms than ironic compliments (first-order attribution). However, children that successfully detected the non-literal nature of an ironic statement were able to comprehend the intended meaning of both types of irony equally well (second- order attribution). Experiment 2 employed the same procedure but also manipulated the degree to which ironic statements echoed the previous statement in the story. A similar pattern of results was obtained, although this manipulation reduced the asymmetry in detecting the non-literal nature between ironic criticisms and compliments. The asymmetry across these two exemplars of irony suggests that a single underlying cognitive development (e.g., second-order attribution) may be a necessary condition for the detection of irony, but not sufficient.},
  note = {booktitle inferred},
}

@inproceedings{boehnke1999stripping,
  title = {Stripping A way a Layer of Perception: Binaural & Monaural Spatial Channels},
  author = {Boehnke, Susan E. and Phillips, D.P.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Two of the major perceptual dimensions of a sound are its frequency content and its spatial location. While the structure of the perceptual channels mediating frequency processing are well understood, the perceptual channels used for sound localization are not. We have used gap-detection methodologies to investigate this. The size of gap-detection thresholds can indicate whether sounds on either side of the silent period (gap) are activating the same or different perceptual channels. We varied speaker locations of the leading and trailing gap markers around the head, and obtained gap thresholds. The results supported a model of two broadly-tuned hemifield channels overlapping through the midline. The next step is to examine the channel tuning under monaural conditions in the same listeners (repeating the experiment with one ear plugged). This eliminates the binaural cues that contribute to sound localization, viz., the interaural differences in the arrival time and intensity of a sound. That is, ear plugging removes a layer of processing contributing to our perception. Results from this monaural study will be presented.},
  note = {booktitle inferred},
}

@inproceedings{santor1999controlled,
  title = {A Controlled Trial of Interpersonal Therapy and Sertraline in Adolescents with Depression},
  author = {Santor, Darcy A. and Kusumakar, Vivek},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Interpersonal Therapy was initially developed as a brief, focused treatment to alleviate symptoms of depression and address current interpersonal problems experienced by individuals with depression. Although several studies have shown that IPT is effective in treating depression in adults, only one open trial of IPT for the treatment of unipolar depression in adolescents has been conducted. However, there are some concerns with this study, namely that treatment was provided by just one highly-trained clinician and that the sample in which effects were observed was extremely homogeneous. To address some of the concerns with the original open trial conducted, we conducted an open trial of IPT with a sample of 24 depressed adolescents who were matched on age and gender to a sample of 24 depressed adolescents receiving Sertraline. IPT was provided by 10 therapists, trained specifically in Interpersonal Therapy, each of whom saw between 1 and 3 clients. Results showed young persons improved substantially whether they received IPT or Sertraline; however, young persons receiving IPT improved more. h' l J_ fl'vij._,.J 4 ClLWL~},
  note = {booktitle inferred},
}

@inproceedings{ying1999nicotine,
  title = {Nicotine, Muscarine and Circadian Rhythms},
  author = {Ying, Shui-Wang and Rusak, Benjamin},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {There has been a long history of controvery about how the neurotransmitter acetylcholine affects circadian rhythms, and especially what role it plays in the synchronization (entrainment) of these rhythms by environmental lighting cycles. Some studies reported that cholinergic drugs act via nicotinic receptors to mimic the effects of light while others reported that nicotinic receptors were not relevant, but that muscarinic receptors mediated cholinergic effects on rhythms. In a combination of in vivo and in vitro neuro-physiological studies of cells in the suprachiasmatic nucleus, we have examined how each of these classes of cholinergic receptors interact with excitatory and inhibitory amino acid transmitters involved in circadian rhythm entrainment. Actions on nicotinic receptors appeared to be presynaptic and involved in the regulation of release of glutamate and GABA reaching SCN cells from other neurons, while actions via muscarinic receptors appeared to be postsynaptic; i.e., directly on SCN neurons.},
  note = {booktitle inferred},
}

@inproceedings{villarroel1999molecules,
  title = {Molecules of Synaptic Transmission},
  author = {Villarroel, C' Alfredo},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Synaptic transmission is the process used by neurones to communicate with other neurones and skeletal muscle. During synaptic transmission, a neurotransmitter released at a nerve ending diffuse to the synaptic space to reach receptors at the target cell. There it binds to ligand-gated channels, the neurotransmitter receptors that mediate fast-synaptic transmission .. During the last decade, research has revealed the process of ion movement through these channels. Initially, computer models, which showed the interactions between ions and the channel protein, guided the design of mutation. The study of mutated channels elucidated the process of ion selectivity, the process by which a channel can distinguish among ions. Pore size well as polarity of the filter determined ion conduction. Research on acetylcholine, glutamate (NMDA as well as AMPA/ Kainate) receptors, however, has not yet uncovered the mysteries of Ca conduction. Presently, I am interested in the study of natural mutation that occur in some neurological diseases.},
  note = {booktitle inferred},
}

@inproceedings{podhorna1999nitric,
  title = {Nitric Oxide and Anxiety in Rat Pups},
  author = {Podhorna, Jana and Brown, Richard E.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The role of nitric oxide (NO) in anxiety was studied in the model of ultrasonic vocalization (USV) in rat pups using drugs that manipulate formation of NO in the brain. Both the selective neuronal nitric oxide synthase (NOS) inhibitor (7-nitroindazole) and the non- selective NOS inhibitor (L-NAME) decreased USV in a dose-dependant manner. However, the non- selective inhibitor also suppressed locomotion. The inactive isomer of the NOS inhibitors, D-NAME, produced no effect on USV or locomotion. The NO precursor, L-arginine, had no effect on USV but increased locomotion at low doses. Thus, drugs that decreased NO synthesis showed anxiolytic effect. However, only the selective NOS inhibitor had a selective anxiolytic effect, i.e., reduced USVs without causing sedation. Increased synthesis of nitric oxide in the brain had no apparent effect pro-anxiety effect but increased locomotion in this model of anxiety.},
  note = {booktitle inferred},
}

@inproceedings{materi1999why,
  title = {Why You Get Sleepy When You Stay A wake Too Long: The Role of Adenosine},
  author = {Materi,  Leticia and Rasmusson, Doug and Semba, Kazue},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The release of the neurotransmitter acetylcholine (ACh) is associated with an increase in the excitability of cortical neurons, as during wakefulness in general, and in attentive states in particular. However, as we stay awake and vigilant for a long period of time, we get drowsy. What causes this? To obtain clues to answer this question, we have investigated how the neuromodulator adenosine, which is released by brain cells during increased metabolism, affects ACh release, using in vivo microdialysis in anesthetized rats. We found that adenosine inhibits ACh release evoked by stimulation of brainstem reticular formation. This inhibition was concentration-dependent, mimicked by adenosine Al, but not A2a, receptor agonist, and blocked by caffeine, a non-selective adenosine receptor antagonist. These results suggest that, during prolonged wakefulness, adenosine released as a result of increased neuronal activity could diminish ACh release, inducing global inhibition of the cerebral cortex and a decrease in vigilance.},
  note = {booktitle inferred},
}

@inproceedings{legs1999one,
  title = {In One Ear and Out the Other? Sound Transmission in a Generalized Bug Leg},
  author = {legs, & Steve Shaw Insects such as crickets bear specialized ears complete with ear drums on their front and directional, use them to locate distant singing mates. It is therefore behaviorally advantageous for these ears to be strongly and delays, the directional sensitivity of the cricket ear at around kHz is better than dB. Insects are rather small to achieve directionality by using sound- shadowing or time and crickets do it by an interference mechanism, reinvented more recently by humans for directional microphones. Sound traveling outside the body to the front door of the tympanum interferes with sound traveling down enlarged tracheal air tubes inside the body to the back door of the tympanum. Internal transmission is effective even via a large trachea crossing from the opposite side of the body. Directionality is conferred because cancellation varies in effectiveness with position, as the bug rotates itself relative to the sound source. Specialized mechanisms usually don't just emerge de novo, but evolve from some related but more general precursor state present in an ancestor -- a preadaptation. Vibration detectors are present in the tibia of each leg below the knee, forming the subgenual organ, from which, in crickets in early development, the sensory neurons bud off that will later form the ear. Cockroaches, an ancient ancestor- model group, have been examined physiologically to see if some parts of the directional mechanism are recognizable in a more general insect leg, since the roach SGO also responds to sound, best around kHz. The results presented from semi-intact roaches will show that sound can indeed travel down the leg's tracheae to the SGO, that this can interfere with and surface, completely cancel sound entering through the leg's and that low frequencies can even spread across the midline from the opposite leg, within the tracheal system. Much of the groundwork for response directionality must have been laid down quite early on in insect legs, which crickets later took over and refined},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  note = {QA: no-abstract; booktitle inferred},
}

@inproceedings{anon1999left,
  title = {Left Limb Movement Improves Visual Scanning in Hemispatial Neglect f::,,,"-.,r· 9 Beverly Dt:i"rffittt(l,2), Gail Eskes(l,2), Ed Harrison(l,2), & Alison MacDonald(2), Dalhousie},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Hemispatial neglect is a deficit in directing attention/movement toward the contralesional space. Robertson and North (1992;1993) reported in case studies that active left-limb movement in left hemispace can improve visual scanning in neglect, but that passive left-limb movement was not effective. We attempted to confirm and extend the findings regarding passive limb movement using functional electrical stimulation (FES) to produce passive movement. Subjects with neglect (n=6) detected visual targets under conditions of no movement and passive left-limb movement in left hemispace. Three non-paretic subjects also participated in an active movement condition. The passive movement group showed an improvement in target detection on the left (p<.05), while 3/3 subjects improved with active movement. Intentional motor programming does not appear required for activating perception-action circuits involved in attention. In addition, FES may have a role in the rehabilitation of hemispatial neglect.},
  note = {QA: no-authors; booktitle inferred},
}

@inproceedings{waschbusch1999criterion,
  title = {The Criterion Validity of Parent Ratings of their Child's Cognitive Abilities },
  author = {Waschbusch, ' Daniel A. and Daleiden, Eric and Drabman, Ronald S.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Examined the criterion validity of parent ratings of their child's cognitive abilities. Participants were 192 children referred to an outpatient mental health clinic for cognitive testing. Criterion measures were children's scores on the Woodcock-Johnson Psycho-Educational Battery - Revised and the Wechsler Intelligence Scale for Children - Third Edition. Results supported the validity of parent ratings of their child's fluid reasoning, visual-motor processing and verbal-auditory processing. Parent ratings of comprehension-knowledge and memory did not perform well. The findings provide evidence that parents may be accurate reporters of some of their child's specific cognitive abilities.},
  note = {booktitle inferred},
}

@inproceedings{houlihan1999nicotine,
  title = {Nicotine: How Does it Affect Performance in a Memory Scanning Task?},
  author = {Houlihan, Michael E.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Nicotine absorbed from cigarette smoke improves performance on many cognitive tasks. Although overall response times generally are faster after smoking/nicotine, few studies have tried to isolate the effect of smoking/nicotine on the speech of the short-term memory (STM) scanning substage of information processing. The present study investigates the effect of smoking/nicotine on STM scanning using both reaction time (RT) and event-related potentials (ERPs). An STM scanning task was performed before and after smoking each of two cigarettes. One cigarette had a 0.05-mg nicotine yield and the other had a 1.I-mg yield (FTC method). Two, three or four consonants were displayed as a memory set. After a brief interval, a single probe consonant was displayed. If the probe was in the memory set (positive probe), a right button press was required and if the probe was not in the memory set (negative probe), the left button was pressed. RT was faster after smoking the 1.1-mg cigarette but not after smoking the 0.05-mg cigarette. However, memory-scanning speed, as estimated from the increase in RT as a function of increasing set size, was not affected by nicotine. Smoking the higher- yield cigarette reduced NI latency to the negative probes (at Cz) and also reduced N2 latency to both the memory set and negative probes. These ERP latency effects were small compared to the effects of nicotine on RT suggesting that nicotine shortens RT by affecting response-related processes. Nicotine produced a sustained positive shift in ERP amplitude beginning around 100 ms post stimulus.},
  note = {booktitle inferred},
}

