@inproceedings{bisong2012preliminarya,
  title = {Preliminary findings on the anti-epileptic and anti-anxiety effects of leaf-extracts of Chinese lantern tree (dichrostachys glomerata) in albino mice},
  author = {Bisong, Sunday A. and Osim, E. E.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The leaves of the Chinese lantern tree (Dichrostachys glomerata) are used as a spice and for medicinal purposes in Africa. The use of the leaf-extracts of this plant as an anti-epileptic drug in traditional medicine has left more questions than answers. The aim of this study was to test the anti-epileptic and anti-anxiety effects of the ethanol leaf-extracts of D. glomerata in mice. Ethanol leaf-extracts of D. glomerata (DG) were phytochemically analyzed and lethality studies done. The phytochemical constituents of ethanol leaf-extracts of D. glomerata included 10.60% alkaloids, 0.02% saponins, 2.55% tannins, 4.2% flavonoids, 2.16% cardiac glycosides, traces of moisture, ash, protein and some other reducing compounds and its LD50 was 13.5mg/kg, from which an ED50 of 4.5 mg/kg was calculated. To test anti-epileptic effect of the extract, seizures were induced in 20 mice using 80 mg/kg of penthylene tetrazol (PTZ). Ten mice were given PTZ alone (80mg/kg, i.p.) and the other 10 mice given PTZ 30 minutes after pre-treatment with ethanol leaf-extract of D. glomerata (4.5mg/kg i.p.). The latency to onset of seizures was significantly longer and the duration of seizures was significantly shorter for mice treated with ethanol leaf-extract of D. glomerata + PTZ when compared to the PTZ alone group (p<0.001). The effect of the ethanol leaf-extract of D. glomerata on anxiety-like behaviour associated with epilepsy was studied in another 40 male albino mice, divided into four groups. Mice were either given 0.9% normal saline (0.1ml/10g body weight, i.p. - control), saline + PTZ , ethanol leaf-extracts of D. glomerata (4.5mg/kg i.p.) alone or ethanol leaf-extracts of D. glomerata extract 30 minutes before giving PTZ. Anxiety-like behaviours were scored in the elevated plus maze (EPM), light/dark box (LD) and open field (OF) tests within 1 hour after drug treatment. The percentage time in the open arm of the EPM differed between drug treatments (F(3,36) = 3.872; p<0.05). It was lower in the PTZ treated mice (P< 0.05) than controls, but did not differ in the other groups of mice. The frequency of stretch attend postures (SAP) in the EPM test also differed between treatment groups (F(3,36) = 9.032; p< 0.001). SAPs were higher in the PTZ treated mice than in control (p< 0.001), DG and PTZ + DG treated mice (p< 0.01), but did not differ between control, DG and PTZ + DG treated mice. The number of head dips in the EPM also differed between the treatment groups (F(3,36) = 7.745; p< 0.001). PTZ treated mice did more head dips compared to controls (p< 0.05), DG alone (p< 0.01) and PTZ + DG treated mice (p< 0.01). The number of head dips were also lower in the PTZ + DG treated mice than control (p< 0.001). Percent time in the light in the LD test and the frequency of SAP did not differ between treatments. However, the trend is similar to that observed in the EPM test. The frequency of grooming differed between the treatments (F(3,36) = 2.704). Mice treated with PTZ groomed more than controls (p< 0.01), mice treated with DG (p< 0.05), and PTZ + DG (p< 0.001). Mice treated with PTZ + DG also groomed less than controls (p< 0.05), mice treated with PTZ (p< 0.001) and mice treated with DG (p< 0.01). Centre square entries in the OF test differed between treatments (F(3,36) = 4.596; p< 0.01), with PTZ treated mice making fewer entries than controls (p<0.001). While DG treated mice did not differ from controls in centre square entries, mice treated with PTZ + DG entered less than controls but more than PTZ treated mice (p< 0.05). The time spent freezing differed between treatments (F(3,36) = 6.795; p< 0.01). Mice treated with PTZ froze more than controls, DG and PTZ + DG treated mice (p< 0.01), which did not differ. These results indicate that D. glomerata decreased epileptic seizures and decreased anxiety associated with PTZ-induced epilepsy in mice.},
  note = {booktitle inferred},
}

@inproceedings{ledue2012spatiotempor,
  title = {Spatiotemporal tuning in mouse primary visual cortex},
  author = {Ledue, Emily E. and Zou, Michelle Y. and Crowder, Nathan A.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Humans can discriminate the speed of a moving visual stimulus; however, how speed is processed by the visual system is not well understood. In primates motion processing occurs most extensively in the middle temporal area, but a portion of complex cells in macaque primary visual cortex (V1) also show speed tuning. Conversely, simple cells respond preferentially to a certain temporal frequency rather than speed. The speed of a sine-wave grating is defined as the ratio of the temporal and spatial frequencies. The mouse has become a popular model of cortical processing due to its ease of use for in vivo imaging and because genetic manipulation of the mouse is well established. Unlike in the macaque, mouse V1 neurons do not appear to show speed tuning and preferred speed changes in proportion to the spatial frequency of a stimulus. To confirm these findings and further evaluate the mouse as an animal model to study motion processing, we used single unit in vivo electrophysiology to measure spatiotemporal tuning in mouse V1. We presented neurons with drifting sine-wave gratings of various spatial and temporal frequency combinations to generate spatiotemporal response functions. We quantitatively assessed the speed tuning of neurons using two methods: 1) we fit our spiking responses with a two-dimensional Guassian function and 2) we performed a partial correlation analysis to determine whether model responses selective for speed or temporal frequency better described our data. Our results substantiate earlier findings that very few neurons in mouse V1 code for stimulus speed.},
  note = {booktitle inferred},
}

@inproceedings{rancourt2012semantic,
  title = {Semantic memory structure in children and adolescents with autism spectrum disorder},
  author = {Rancourt, Kate M. and Filliter, Jillian H. and Kerr, Michelle and McMullen, Patricia A. and Johnson, Shannon A.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Performance on categorization and prototype formation tasks in people with autism spectrum disorder (ASD) suggests that their semantic memory structure may be atypical, and that categorization performance might be related to variations in central coherence (i.e., 'big picture thinking') and everyday functioning. Data from characterization and semantic memory tasks administered to 20 youths (8-18 years of age) with ASD, and 20 age-, IQ-, and gender-matched, typically-developing comparison participants are being collected. Participants will complete two measures of central coherence (the Embedded Figures Test and a Homograph Reading Task), and parents will complete a measure of adaptive functioning (Adaptive Behaviour Assessment System-II). Semantic memory tasks include: 1) Match-mismatch task: participants decide if a simultaneously presented picture and word are a match or mismatch (the level of identify of matches and mismatches is varied throughout the task), and 2) Triadic comparison task: three nouns are presented simultaneously and the participant decides which two are most similar. On the match-mismatch task, we expect youths with ASD will be faster to identify objects at more specific (i.e., subordinate; e.g., 'blue jay') levels of categorization, compared to controls who will be fastest at the basic level (i.e., general category; e.g., 'bird'). On the triadic comparison task, we expect 1) less efficient category structure in youths with ASD, and 2) that objects will be organized based on concrete rather than abstract features, whereas the opposite will be true for controls. Finally, we anticipate that faster performance at the subordinate level on the match-mismatch task, and less efficient category structure on the triadic comparison task, will be related to poorer central coherence performance and poorer adaptive functioning. Results of this research will provide information about the ways that youth with ASD learn, which could inform intervention research and practice.},
  note = {booktitle inferred},
}

@inproceedings{phillmore2012sex,
  title = {Sex on the brain: do gender and breeding condition affect FoxP2 expression in chickadees?},
  author = {Phillmore, Leslie and MacGillivray, Heather and Martin, Stephanie and Wilson, Ryan},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Seasonal plasticity in behaviour, such as increased song production in spring, are mirrored by corresponding plasticity in the brain in many songbird species. Regions of the brain important for song, such as HVC, increase in volume when birds are in breeding condition, while specificity of response in NCM and CMM, regions important for song perception, decreases. FoxP2 is a gene associated with language expression and comprehension in humans, and is also important for song learning in songbirds. FoxP2 expression in Area X, a region important for song learning and maintenace, is high during development in male songbirds, while they are learning songs, and fluctuates seasonally in seasonal learners such as canaries, who change their vocal repertoire between breeding seasons. We wanted to examine whether FoxP2 changed in male and female chickadees, a species in which only males reliably sing, but both males and females produce learned vocalizations at different rates across the year, and exhibit plasticity in those vocalizations. We found that in males but not females, HVC volume was larger in breeding than non breeding birds, and that as expected, males had larger HVC than females. We also found no changes in FoxP2 expression across breeding condition, suggesting that levels of FoxP2 in chickadees may not change due to year-round production of learned vocalizations.},
  note = {booktitle inferred},
}

@inproceedings{ishigami2012does,
  title = {Does phasic alerting of neglect patients overcome their spatial deficit in visual awareness?},
  author = {Ishigami, Yoko and MacIsaac, Mary E. and Shore, David and Klein, Raymond M. and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Temporal order judgement (TOJ) tasks can be used to measure spatial orienting biases (quantified by the Point of Subjective Simultaneity, PSS) in visual-spatial neglect. Robertson et al. (1998) demonstrated that warning tones could improve the right-sided bias in neglect, suggesting an interaction between the alerting and orienting networks. We attempted to replicate this finding using 2 TOJ tasks that required either a spatial- or colour-discrimination judgment to look at the potential effects of response bias. We tested eight neglect patients and nine controls. Participants indicated which stimulus (left/right or red/blue for the spatial and colour conditions, respectively) was presented first. Warning tones were presented 25% of the time. Two participants with typical right-sided bias without tones showed improvements with tones in the PSS in the spatial condition, replicating Robertson et al. Four participants with paradoxical left-sided bias without tones showed improvement with tones in the PSS in both spatial and colour conditions. These results suggest that alertness manipulation may be effective for some patients, and that effects may depend on directions of initial bias without tones and/or response options.},
  note = {booktitle inferred},
}

@inproceedings{allen2012directing,
  title = {Directing our attention back to nature: An exploration of the relationship between exposure to nature and attention in typically developing children},
  author = {Allen, Stephanie and Lawrence, Mike and Rainham, Daniel and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {A growing body of research indicates that contact with natural environments positively affects our ability to focus and direct our attention. However, while the media has begun to speculate about the relationship between nature exposure and attention in children, few studies have empirically examined this relationship. Understanding if and how exposure to nature affects attention in children is of particular importance given that demands on children's attention are increasing and time spent in nature is decreasing. Current theory and existing research will be discussed, as will the design of our initial study that will examine the effects of nature exposure on attention in children.},
  note = {booktitle inferred},
}

@inproceedings{duffy2012complete,
  title = {Complete darkness promotes instability of the neuronal cytoskeleton},
  author = {Duffy, Kevin R. and Mitchell, Donald E.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {A short period of monocular deprivation in early postnatal life can alter the function and structure of neurons within the visual system. Such deprivation can also reduce labeling for a predominant component of the cytoskeleton, neurofilament, which acts to stabilize the gross structure of mature neurons. In a previous study that examined recovery from monocular deprivation we showed that elimination of visually-driven activity by dark-rearing not only fully blocked recovery of neurofilament in deprived regions of the thalamus but additionally promoted its overall reduction even within non-deprived regions. In this study we have examined directly the influence of dark-rearing on the level of neurofilament in the primary visual cortex. In tissue slices and in immunoblots we show a reduction of neurofilament within the visual cortex of animals that were kept in complete darkness for at least 10 days. We reason that removal of structure-providing protein by a pulse of dark-rearing may promote a more flexible neuronal state that raises the capacity for recovery from visual deficits consequent to amblyogenic rearing.},
  note = {booktitle inferred},
}

@inproceedings{mitchell2012substantiall,
  title = {Substantially enhanced visual recovery from early monocular visual deprivation in kittens promoted by short periods of darkness},
  author = {Mitchell, Donald E. and Duffy, Kevin R. and MacNeil, Katelyn and Holman, K.},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Short periods of darkness reduce labeling for a cytoskeleton that supports neuron structure by forming a stable intracellular scaffold (Duffy et al , In-House Conference 2012). Could this reduction of cytoskeleton protein increase plasticity in the visual cortex and thereby enhance the capacity for recovery for recovery from amblyopia? We measured the consequences for the vision of the two eyes of a 10 day period of darkness (DR) imposed at different times following early monocular deprivation (MD) in kittens. The period of DR prevented development of amblyopia when it occurred immediately after MD, and also promoted rapid recovery (in just 5-7 days) when imposed later. Although the close temporal similarity of the changes in cytoskeleton proteins and the behavioral effects of 10 days DR suggest a close link between the two, DR may have other effects including changes in the cortical excitatory-inhibitory balance. As an initial step in therapy, complete elimination of light to both eyes for 10 days may facilitate current treatment procedures for human amblyopia.},
  note = {booktitle inferred},
}

@inproceedings{lawrence2012introducing,
  title = {Introducing a combined attention systems test},
  author = {Lawrence, Mike and Osler, Brittony and Fisher, Megan and Kerr, Michelle and Allen, Stephanie and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {The Attention Network Test (ANT) and its variants (ANT-I, LANT, ANT-R, etc) have become popular research tools for quantifying several phenomena of attention. However, non-optimal design of these tests, limit their power and interpretability. This talk will present a new attention test, the Combined Attention Systems Test (CAST), that was designed to obviate the limitations of its predecessors and extend measurement to further phenomena of attention.},
  note = {booktitle inferred},
}

@inproceedings{cunningham2012acoustic,
  title = {Acoustic startle response, prepulse inhibition, and dopamine D2 receptor levels in the rate medial prefrontal cortex after chronic predator odour exposure and social isolation stressors in adolescence},
  author = {Cunningham, Ceilidh and Perrot, Tara},
  booktitle = {Psychology and Neuroscience 38th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2012},
  abstract = {Stress and glucocorticoid release are implicated in programming the developing brain and the prefrontal cortex is particularly vulnerable to the programming effects of stress in adolescence, a period during which the medial prefrontal cortex (mPFC) undergoes significant development. Additionally, alterations in prefrontal dopaminergic activity are implicated in stress-related psychopathologies. Previous research demonstrated a reduction in dopamine D2 receptors in the rat medial prefrontal cortex after chronic predator odour exposure during adolescence. No previous work has examined the effects of chronic adolescent stress on both D2 receptor level and dopaminergic activity in the mPFC. In the current study, chronic predator odour and social isolation were used as naturalistic models of chronic psychological stress during the rat adolescent period (PND 21 to 59). Changes to acoustic startle response (ASR) and prepulse inhibition of startle (PPI) were assessed concurrent to stressor exposure in adolescence and adulthood. D2 receptor levels were also measured in the mPFC using western blot procedures. The results of this study indicate that ASR and PPI change in adulthood compared to adolescence and are affected by chronic predator odour and social isolation stressors in adolescence. No changes in the level of mPFC D2 receptor were observed. The results of this study provide further knowledge of how chronic stress during adolescence affects mPFC dopaminergic activity, possibly allowing for a better understanding of the etiologies of psychopathologies such as schizophrenia.},
  note = {booktitle inferred},
}

@inproceedings{gralnick2013perfectionis,
  title = {Is Perfectionism a Vulnerability Factor for Depression After Controlling for Neuroticism?},
  author = {Gralnick, Tara M. and Sherry, Simon},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Extensive evidence suggests neuroticism (i.e., a dispositional tendency to experience negative emotional states) is a higher order personality trait that shares substantial variance with perfectionism dimensions and depressive symptoms (Graham et al., 2010; Sherry et al., 2012). Such evidence raises an important question: are perfectionism dimensions vulnerability factors for depressive symptoms after controlling for neuroticism? The present meta-analysis examined the existing evidence testing if perfectionism dimensions (i.e., self-oriented perfectionism, socially prescribed perfectionism, concern over mistakes, doubts about actions, and perfectionistic attitudes) predict changes in depressive symptoms after controlling for neuroticism. A comprehensive meta-analysis of 10 longitudinal studies involving 1858 participants from undergraduate, community, and psychiatric samples indicated all five perfectionism dimensions significantly predicted changes in depressive symptoms after neuroticism was taken into account. Perfectionism dimensions consistently predicted changes in depressive symptoms across a wide range of samples, methods, and measures. Observed effect sizes were small to moderate in magnitude. Results lend credence to and bring coherence to theoretical accounts, case histories, and empirical studies suggesting perfectionism dimensions are part of the premorbid personality of people vulnerable to depressive symptoms. Results also suggest perfectionism dimensions are unique lower order personality traits that add incrementally to understanding of depressive symptoms above and beyond neuroticism. Perfectionism dimensions appear neither redundant with nor captured by neuroticism. Findings from the present meta-analysis are incongruent with a view of self-oriented perfectionism as an adaptive personality trait associated with positive outcomes. In contrast, results indicate self-oriented perfectionism may represent a form of counterproductive overstriving that confers vulnerability to depressive symptoms. Although self-oriented perfectionism is often labeled as adaptive, such assertions appear premature.},
  note = {Poster},
}

@inproceedings{brown2013creating,
  title = {Creating a Living History of Neuroscience},
  author = {Brown, Richard E. and Molnár, Zoltán and Young, Damian and Mason, John and Corsi, Pietro},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Much of the history of neuroscience is being lost or discarded. We have instituted a plan to save and use historical objects for teaching and research. We started with a wooden box of glass microscope slides belonging to Sir Charles Sherrington and labelled "Histology Demonstration Slides" found in the University Laboratory of Physiology at the University of Oxford, and have now included glass slides from Le Gros Clark and historical equipment. We have identified a number of slides used in publications by Sherrington and Le Gros Clark and equipment used in classical experiments in the history of neuroscience at Oxford. Of particular interest is the slide box of Sherrington. This box contains 21 drawers of slides from Sherrington's years at St Thomas Hospital (1888-1895), Liverpool University (1896-1914) and Oxford University (1914-1935). It also contains slides presented to him by other leading contemporary neuroscientists (Ruffini, Brown, Saunderson, Fritsch). We recognized a slide of intestine from a Cholera case (Sherrington 1887, Proc Royal Soc, 42, 474). Slides of blood (amphibian, dog, human) and preparations from bone marrow indicate that Sherrington maintained his interest in haemathology and microbiology after working in the laboratories of Virchow and Koch. There are numerous serial sections through normal peripheral nerves and nerves in which the sensory or the motor roots were sectioned and stained after degeneration. There are preparations where nerves can be followed to muscle spindles (cat), but there are also slides where no spindles can be found at all (e.g. in the eye muscle of a monkey). The collection includes 11 spectacular slides from Gustav Fritsch from 1891. These include slides from Fritsch's 1881 publication "Vergleichend-anatomische Betrachtung der elektrischen Organe von Gymnotus electricus" Veit, Leipzig. These slides are accompanied by similar preparations on electric organs of fish made by Sherrington. We are documenting these objects on a website [HYPERLINK "https://learntech.imsu.ox.ac.uk/historyofmedsci/"https://learntech.imsu.ox.ac.uk/historyofmedsci/] which can be used to integrate historical information into teaching and research programs. This poster demonstrates new ways of presenting historical research in neuroscience for teaching and research.},
  note = {Poster},
}

@inproceedings{mclin2013addictive,
  title = {Addictive Personalities},
  author = {McLin, Sari and Keay, Mairi},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Research has discovered that there are four personality risk factors, as well as other factors such as resilience, that affect how individuals are susceptible to addictions. Addictions, being harmful and dangerous for those affected, are very difficult to treat and yet it is very important to do so. The purpose of this experiment is to determine how individuals with different risk and protection factors respond to a quitting smoking program. Smoking habit and risk factor surveys, as well as piCO measurements, were completed by a sample population of adolescents. The data was then evaluated for correlation values and p-values using statistic software. It was discovered that individuals with high risk personality types (Anxiety Sensitive and Impulsive) and high risk resilience levels as a whole did not respond particularly differently to the quitting smoking program compared to those with lower risk. Individuals with high risk Hopeless Introvert personality type did respond notably less to the program than those with lower scores. It was also discovered that individuals receiving treatment did not reduce their smoking significantly compared to those with no treatment, suggesting the treatment program was not effective in inducing a reduction in smoking habits.},
  note = {Poster},
}

@inproceedings{brown2013searching,
  title = {Searching for dissociations among multiple memory systems in mouse models of Alzheimer's disease},
  author = {Brown, Richard E. and O'Leary, Tim and Stover, Kurt and Fraser, Leanne},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {We have examined age-related changes in learning and memory in different mouse models of Alzheimer's disease (AD). This brief report examines age-related changes in spatial learning and memory (acquisition and 24 hour memory in the Morris water maze reference memory task), procedural learning and memory (accelerating rotarod), and olfactory memory, in male and female 3x-Tg AD and 5XFAD mouse models of AD and their appropriate control strains between 3 and 18 months of age. The 5xFAD mouse has two transgenes; the APP transgene with the Swedish (K670N/M671L), Florida (1716V) and London (V7171) mutations and a presenilin transgene with M146L and L286V mutations, all of which are controlled by the murine Thy-1 promoter. The controls are wild-type littermates. The 3xTg-AD mouse has three transgenes, the human amyloid precursor protein (APPswe), a mutated mouse presenilin-1 (PS1M1461), and a transgene associated with tau pathology (Tau301L). The B6129S1F2 mice are used as controls. Data will look at age, sex and strain differences on each test to examine the effects of the transgenes on different memory systems. Confounding effects of background strain, behavioural measures and housing conditions will be discussed.},
  note = {Poster},
}

@inproceedings{whitehead2013analysis,
  title = {Analysis of Neurobehavioural Development in the 5xFAD Mouse Model of Alzheimer's Disease},
  author = {Whitehead, Jocelyne C. and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Introduction. The 5xFAD mouse model of familial Alzheimer's disease has two mutant transgenes with five mutations [the Swedish (K670N/M671L), Florida (1716V) and London (V7171) mutations are expressed in the APP transgene, while the presenilin transgene has mutations (M146L) and (L286V)] that are all controlled by the murine Thy-1 promoter. The 5xFAD mouse develops ?-amyloid plaques by 2 months of age, with synapse loss and deficits in long-term potentiation, spatial learning and memory and contextual fear memory at 4 months of age. The phenotypes expressed in the 5xFAD mouse model are consistent with symptoms of FAD patients. Since these genes are expressed at an early age, it is possible that the 5xFAD mice differ in their early development from littermate controls. Objectives. We therefore used a test battery to examine neurobehavioural development of male and female 5xFAD and wild-type littermates from postnatal day 2 to 24. Methods. The test battery assessed developmental milestones, sensory-motor reflexes, motor and cognitive abilities using behavioural and reflex tests that are reliable measures of the development of the central nervous system. Results. There were no differences between pup genotypes on any of the developmental tests. There were, however some sex differences as males weighed more than females, opened their eyes earlier and developed the hind-limb grasp reflex earlier than females. Males also reached the home cage bedding faster than female pups during the homing test. Female pups performed better than males in the forelimb grip strength test, which may be due to their lower body weight. Female transgenic pups weighed less than female wild-type pups, and did not habituate to a novel object. This suggests that the transgene may be affecting pup development in a sex-dependent manner. Maternal behaviour was observed from postnatal day 1 to 15 in mothers whose pups were included in the neurodevelopmental test battery and mothers whose pups remained undisturbed. No differences in levels of maternal care were found, indicating that testing the pups did not reduce maternal behaviour. Conclusion. This is the first study to examine ontogeny in the 5xFAD mouse model of Alzheimer's disease and the results indicate that the transgenes do not affect pre-weaning development in these mice.},
  note = {Poster},
}

@inproceedings{cunningham2013tossing,
  title = {Tossing and turning: the effects of overnight sleep restriction on women with unipolar depression},
  author = {Cunningham, Jasmyn and Sardiwalla, Yaeesh and Bernier, Denise and Rusak, Benjamin},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {It has been firmly established that mood in approximately fifty percent of depressed patients improves after being subjected to sleep restriction. As pharmacological and cognitive treatments for depression are known to be limited in effectiveness, a greater understanding of the mechanisms behind positive response to sleep restriction could lead to novel, individualized treatments. This pilot study aimed to better understand the effects of sleep restriction in responders (participants whose moods respond positively to overnight sleep restriction), as well as the correlation between baseline diurnal variation and responsiveness to sleep restriction. This was done through the analysis of self-reported mood and chronotype questionnaires filled in before, during, and after overnight sleep restriction by both healthy controls and depressed participants. In addition, the study monitored the levels of activity of the participants using a wrist actigraph for the entirety of the study period. Results showed no overall responders to sleep restriction, however several participants were negative responders to certain items of the Hamilton Depression Inventory (mood symptoms worsened). No conclusions could be made regarding links between baseline diurnal variation and response to sleep restriction. Depressed subjects showed reduced levels of activity prior to sleep restriction (baseline) compared to control subjects. The levels of activity during sleep restriction in this study do not show a positive percentage change for any participant, merely less negative percentage changes in certain individuals. The main limitation of the study was the very small sample size, but it would be quite feasible to conduct further study in this area with several modifications. Friday's Posters},
  note = {Poster},
}

@inproceedings{kinzel2013can,
  title = {Can alerting cues enhance prism adaptation?},
  author = {Kinzel, Franziska and Ishigami, Yoko and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The identification of appropriate and effective interventions for spatial neglect is critical for improving outcomes and overall quality of life post-stroke. One promising rehabilitation technique is prism adaptation (PA). PA involves adapting to goggles fitted with prisms that shift the visual field rightward by pointing at a target. After goggle removal, a leftward shift of orienting is observed. However, PA effects are inconsistent across studies and outcome tasks, possibly due to the multidimensional nature of the impairments (i.e. both orienting and vigilance/sustained attention deficits) underlying neglect. For example, alerting cues can target sustained attention deficits and directly improve orienting in neglect. Therefore, the purpose of this research was to examine the impact of combining alerting cues with PA in healthy controls, as a first step in determining the feasibility of this technique in patients with spatial neglect. Method: In two studies, healthy young participants (n=60) were randomly assigned to one of 3 conditions: PA only, PA + alerting tones on 25% of trials (PA+alerting), or sham prism group. Outcome measures included 2 Subjective Midline Tasks (SMTs), Proprioceptive Straight Ahead pointing (PSA: midline pointing with eyes closed) and Visual Straight Ahead pointing (VSA: visually guided midline target pointing), as well as Visual Search (VS). The SMTs were administered immediately after PA and after a delay of 30 minutes. During the adaptation period, participants pointed toward line targets while wearing sham (clear) or prismatic goggles that shifted the visual field rightwards. Auditory alerting cues (400 Hz, 89 db) were presented 300-1100 ms before the target in the PA+alerting. Results: Expected aftereffects were obtained in all the PA conditions on the SMTs in terms of leftward deviations in pointing, but not on VS. The impact of alerting depended on the outcome test. In SSA, alerting tones decreased the after-effects at the 30 minutes delay (3.3 vs 2.5 degrees, p< .05, PA vs PA +alerting, respectively). In VSA, alerting tones increased after-effects at both immediate and delayed test (7.4 vs 8.4 degrees and 5.1 vs 5.7 degrees, p's< .05; PA vs PA +alerting, respectively). Conclusions: The impact of alerting tones is not always positive and may depend on similarities between exposure task and outcome tasks. Adding alerting tones to PA as a rehabilitation technique may potentially improve some functional outcomes for patients with spatial neglect.},
  note = {Poster},
}

@inproceedings{jones2013measuring,
  title = {Measuring the components of attention in the young healthy adult population},
  author = {Jones, Stephanie A. H. and Butler, Beverly and Klein, Raymond and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Behavioural and neurological research has supported a three-component model of attention whereby separate, but interacting, brain networks are responsible for alerting/vigilance, orienting and executive attentional abilities (Posner & Petersen, 1990). Alerting or vigilance refers to our ability to maintain a state of arousal over time, orienting involves directing our attention to a particular task, location or stimulus, and executive attention includes the higher order conscious processing required to use the detected information (e.g. decisions and memory). These networks are commonly impaired in many brain diseases. As correct measurement of attentional abilities is fundamental to the goal of understanding and treating attention deficits, we developed a theoretically-driven computerized test battery for measuring attentional abilities, presumably reflecting these networks: the Dalhousie Computerized Attention Assessment Battery (DalCAB). Ninety-two healthy participants from 18 - 30 years of age completed the automated battery on two separate occasions. The purpose of the present study was to examine the factor structure of DalCAB in the healthy young adult population. Specifically, we sought to determine if these data fit the proposed three network model of attention using exploratory factor analysis (EFA). EFAs of nineteen reaction time sub-scores and five accuracy sub-scores (for a total of 24 variables) will be conducted. Results will be discussed relative to the three component model of attention.},
  note = {Poster},
}

@inproceedings{salmon2013step,
  title = {A step towards building better video "games" for rehabilitation: A survey investigating entertainment preferences in adults},
  author = {Salmon, Joshua P. and Wilson, Graham C. and Klein, Raymond M. and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {As the healthcare system becomes increasingly burdened with demands for rehabilitation services, the need for accessible therapies is growing. Video game approaches offer a promising supplement to existing therapy programs. Research has shown that video games can improve such cognitive functions as memory, processing speed, executive function and attention in both young and older adults. The current challenge however, is finding (or designing) video game approaches that simultaneously match the therapeutic needs of the patient population while remaining fun and engaging. As part of a larger research program, to develop better rehabilitation software or "games" for patients recovering from Stroke or Parkinson's disease, the current study conducted a nation-wide survey of adult entertainment preferences. Measures of favorite television, book, film and movie genres were also collected, as well as information about frequency of use of various technologies, devices and video games. The results from this research offer a window into how adults spend their time with technology, and what approaches in designing new software for older adults might be most effective. The ultimate goal of this research is to apply this information to design more engaging game-like therapies that will encourage and motivate patient rehabilitation.},
  note = {Poster},
}

@inproceedings{carver2013auditory,
  title = {Auditory Temporal Processing Across the Lifespan: Gap Detection and Temporal Regularity},
  author = {Carver, Sally and Ovens, Laura and Phillips, Dennis P.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {As people age, many tend to 'lose' their hearing (presbyacusis). Historically, the hearing science community thought that presbyacusis was attributable entirely to peripheral deficits. The more recent view is that there is also a central auditory nervous system deficit, specifically a temporal processing deficit that cannot be explained by an absolute sensitivity loss. The purpose of the present study was to investigate the nature of those 'central' auditory processing deficits while controlling for peripheral hearing loss using a multiple regression analysis, and to do so in both musicians and non-musicians. Our preliminary findings suggest that there is little negative effect of age on any of four temporal processing tasks when absolute sensitivity to sound is controlled for. Our data also hint that musicians might actually improve in their temporal processing capabilities with age. Our data support the view that lifelong musical practice might protect against age-related impairments in temporal processing.},
  note = {Poster},
}

@inproceedings{brown2013introduction,
  title = {Introduction},
  author = {Brown, Richard},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {A historical overview of the people and events in our department from at least 1970. This year I will focus on the contributions of Jeannette McGlone and Heather Schellinck, who will retire this year.},
}

@inproceedings{joshi2013effect,
  title = {Effect of a combination of isolation rearing and predator odour stress on measures of startle in male and female rats},
  author = {Joshi, Namrata and Leslie, Ron and Perrot, Tara},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The purpose of our work is to examine the effects of adolescent stress exposure on prefrontal cortex (PFC) function by examining pre-pulse inhibition (PPI), startle amplitude (SA) and habituation using a novel model of stress in rats which combines isolation rearing with repeated exposure to predator odor. Our previous work established that repeated predator odour stress alone during adolescence does not significantly affect these measures (unpublished data). In the present study, Long-Evans rats of both sexes were given a combination of isolation rearing and repeated predator odour stress to determine if the removal of the social support offered by a cagemate could result in reducing the animals' resilience to odour stress. Animals were isolated for most of the adolescent period (PND28-54); six odour exposures were given during this period (on PND34, 38, 43, 47,53 and 69). Measures of SA and PPI were assessed repeatedly throughout adolescence and early adulthood. Preliminary analysis of the data has revealed a reduction in PPI following exposure to a combination of isolation and predator odour exposure. Females showed a transient effect of stress that emerged during adolescence itself, while among males, stress reduced PPI only after the final exposure in early adulthood.},
}

@inproceedings{stahlschmidt2013choices,
  title = {Choices mothers make: Tradeoffs of reproductive decision-making in crickets},
  author = {Stahlschmidt, Zachary and Adamo, Shelley},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Reproductive decision-making is important across taxa, and post-fertilization decisions, such as oviposition-site selection (OS), can have profound effects on parent and offspring fitness. Egg-laying females must weigh their own needs (e.g., predation avoidance or foraging) against those of their offspring (e.g., a suitable developmental environment), which can lead to tradeoffs among these factors. We used several experiments with the Texas field cricket (Gryllus texensis) to examine how females navigate such tradeoffs during OS. Specifically, we investigated tradeoffs associated with predation risk. For example, does increased predation risk alter females' thermal preferences for OS or result in reduced egg-laying? We also manipulated food availability to examine a tradeoff between feeding and egg-laying and to determine whether food limitation promotes risky OS. Last, we manipulated the number of oviposition sites to investigate if females "put all of their eggs into one basket", which likely benefits females, or if they prefer to oviposit into multiple sites, which may benefit offspring. We discuss our results and show that widespread environmental factors (e.g., food availability, temperature, and predation risk) can exert complex interactive effects on important reproductive decisions.},
}

@inproceedings{quinlan2013enhancing,
  title = {Enhancing the Production Effect in Memory},
  author = {Quinlan, Chelsea K. and Taylor, Tracy L.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The current literature demonstrates that reading aloud is the most effective form of production; however, the distinctiveness account suggests that other forms of vocal production that include an additional distinct element should produce an even greater production effect. In three experiments, we found that reading items aloud loudly and singing items at study resulted in a greater production effect than reading items aloud in a normal voice, with the largest benefit for singing. Our findings support the distinctiveness hypothesis by demonstrating that other forms of production can have a more pronounced effect on subsequent memory than reading aloud at study.},
}

@inproceedings{higgins2013implicit,
  title = {Implicit Sequence Learning in Normally Hearing Adults: Implications for Predicting Success with Cochlear Implants},
  author = {Higgins, Kristen and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Cochlear implants (CIs) are a type of medical prosthesis that requires extensive learning to use effectively, and success rates vary widely in both adults and children. Importantly, the variables predicting success with CIs have yet to be determined, although researchers have investigated many possible predictors. One cognitive ability that may relate to success with CIs is the ability to learn and remember sequential patterns of information. Conway et al. (2010) found that implicit sequence learning ability is related to language processing abilities under challenging acoustic conditions. Specifically, they found that participants' ability to implicitly learn sequences that were based on an artificial grammar (compared to their ability to learn ungrammatical sequences) was positively correlated with their ability to understand speech in noise. The current study proposes to build on Conway et al.'s (2010) study by using fMRI technology to examine the relationship between the neural processes underlying implicit sequence learning in normally hearing adults and their ability to perceive speech in noise. A larger overall study will examine these processes in deaf CI candidates and examine relationships between their pre-implant cognitive abilities and post-implant language outcomes.},
}

@inproceedings{chevalier2013which,
  title = {Which reading, learning, and organizational strategies are associated with successful academic performance in students with a history of reading difficulties?},
  author = {Chevalier, Thérèse M. and Deacon, S. Helene and Parrila, Rauno and Ritchie, Krista},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Research has shown that individuals who report a history of reading difficulties have similar reading performance to those with diagnosed reading disabilities, and both groups have more difficulty than their peers in adjusting to the demands of reading and writing at a university level. Despite academic challenges, these students are pursuing post-secondary education more frequently than in the past. Through a joint project with Helene Deacon's lab and Student Services at Dalhousie University, all incoming students in the fall of 2010 were invited to complete self report surveys designed to identify students with a history of learning difficulties and to evaluate their use of reading, learning, and organizational strategies. Based on the academic achievement of the 473 students who completed the surveys, this study will identify which strategies are most highly associated with academic success in students with and without a history of reading difficulties. Preliminary results will be presented.},
}

@inproceedings{hassall2013wake,
  title = {Wake up and smell the shifting probabilistic outcomes},
  author = {Hassall, Cameron D. and Krigolson, Olav E.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Real-world decision making can be challenging due, in part, to changes in an underlying reward structure: what was the best option last week might be less rewarding today. Here, we discuss our ability to adapt to shifting stimulus-response-outcome rules in the context of a gambling game known as a "two-armed bandit". Participants made gambles in simulated environments known to be either certain (an "honest" casino) or uncertain (a "dishonest" casino). Our electroencephalographic and behavioural data suggest that humans are able to adapt to subtle changes in underlying reward structures, especially when given cues as to which environment they are in. Finally, we suggest that reward-processing areas within medial-frontal cortex may be partially responsible for detecting (and adapting to) these shifting probabilistic outcomes.},
}

@inproceedings{dolan2013controlling,
  title = {Controlling Prosody in Directed Forgetting of Speech Errors},
  author = {Dolan, Sarah and Taylor, Tracy and Fawcett, Jonathan},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Past research has shown that corrections made by a speaker following commission of an error (e.g. "oh no, I meant…") permit the listener to intentionally forget the erroneous information while improving memory for the correction itself. However, prosodic cues such as emphasis of the corrective statement could be responsible for the improvement observed for corrections. To explore this possibility, we transcribed and recorded five-minute popular scientific podcasts using monotonic computer-generated voices, which contained no prosodic cues. Each podcast contained occasional factual errors followed by an immediate self-correction. After listening to the clips, participants were given a surprise test of recognition memory for erroneous, corrective, and reference statements. Unlike in past research, performance for erroneous and corrective statements were both below performance for reference statements; errors and corrections did not differ. We propose that this discrepancy resulted from the lack of prosodic elements in our stimuli, which, in natural speech, differentiate errors and corrections.},
}

@inproceedings{hudson2013emotion,
  title = {Emotion Regulation: Global Construct or Valence-Dependent Skill?},
  author = {Hudson, Amanda and Jacques, Sophie},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Emotion regulation, described for our purposes as the process by which individuals control overt emotional displays, has received increasing attention over recent years. However, the majority of this research has focused on children's ability to control negative emotions, and investigations of positive emotion regulation have been relatively lacking. The current study aimed to relate 5- to 10-year-olds' regulation of negative emotions (namely disappointment) with their ability to regulate positive emotions (happiness/excitement) to examine whether emotion regulation is robust across contexts or whether it fluctuates depending on situational demands (i.e., regulation of positive vs. negative emotions). A secondary objective involved comparing cognitive and socioemotional correlates of positive and negative emotion regulation. To measure regulation of negative emotions, we used a disappointing gift paradigm in which children received an attractive gift bag containing a disappointing gift (a plastic cup). To examine regulation of positive emotions, a novel measure of positive emotion regulation was devised in which children had to cease playing an exciting game to help the experimenter clean up a staged accident. Correlational analyses revealed a significant negative correlation between regulation of negative emotions in the gift paradigm and regulation of positive behaviors during the staged accident. In other words, children who best regulated negative emotions appeared to experience more difficulty regulating positive emotions, and vice versa. These findings suggest that emotion regulation is not a generic skill, but one that varies systematically depending on the valence of the elicited emotion. In addition, children's positive and negative emotion regulation correlated differently with measures of theory of mind and inhibitory control, adding strength to the notion of emotion regulation as a valence-dependent skill.},
}

@inproceedings{oore2013age,
  title = {Age-related changes in motor ability and motor learning in triple transgenic (3xTg-AD) and control (B6129SF1/J) mice on the accelerating Rotarod},
  author = {Oore, Jonathan and Fraser, Leanne and Brown, Richard},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The motor performance of the triple transgenic (3xTg-AD) mouse model of Alzheimer's disease (AD) is still largely uncharacterized. Male and female 3xTg-AD and control (B6129SF1/J) mice were tested in a cross-sectional design at 2-, 6-, 9-, 12-, and 15-months of age on the accelerating Rotarod to look at motor ability and motor learning. At all ages, transgenic mice had a steeper motor learning curve and performed better on each day than controls. Female mice showed increased motor ability compared to males, while male mice had a steeper learning curve than female mice. Age on its own did not have a meaningful effect on Rotarod performance, though age and genotype were found to interact; however, the precise trend is not clear. It was concluded that the behavioural differences seen in the 3xTg mice may shed light on the neuropathological development of AD.},
}

@inproceedings{stewart2013randomized,
  title = {A randomized controlled trial of a novel motivation-matched treatment for problem gamblers: "BEAT Gambling"},
  author = {Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Our previous work has suggested that subtyping gamblers according to their underlying motivations for gambling has clinical utility in terms of predicting gambling behavior and problems. We recently developed a novel 6-session treatment for problem gamblers, called "BEAT gambling" (Brief Escape and Action Treatment for Gamblers), in which distinct interventions are provided to meet the needs of Escape (i.e., coping-motivated) vs. Action (i.e., enhancement-motivated) problem gamblers. We conducted a randomized controlled trial where 70 problem gamblers (25 Action; 45 Escape) were randomly assigned to either the BEAT gambling intervention or to a Treatment as Usual (TAU) control provided by problem gambling therapists in the community. Both treatments led to significant improvements on a variety of gambling and associated mental health outcomes. Consistent with hypotheses, our novel BEAT gambling intervention was superior to TAU on several outcomes including gambling frequency, readiness to change, gambling craving, problem gambling "caseness", and treatment retention.},
}

@inproceedings{pan2013physical,
  title = {Physical and Mental Fatigue},
  author = {Pan, Sisi},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Fatigue happens either during a prolonged time or with sustained efforts. Pathological fatigue is a symptom that has been identified in many neurological conditions, such as multiple sclerosis (MS) and stroke. Despite of the prevalence of fatigue, the underlying mechanism of this phenomenon has not yet been revealed. To date, most of fatigue research used a dichotomous definition of fatigue based on one's subjective perception and behavioural performance. This could be helpful in general clinical practices, but it seemed insufficient to explain the nature of fatigue since the subjective and behavioural measures often do not correlate. The fatigue-related brain activity was another route to integrate different measurements and to formulate a unitary theory of fatigue. The neurophysiological measures of physical fatigue attributed the decline of motor output to peripheral, spinal, and supraspinal origins. Two models have been proposed to explain the proportion of fatigue due to a suboptimal brain function -- the homeostasis hypothesis and the central fatigue hypothesis. Each of them proposed a neural mechanism for fatigue: the imbalance between facilitatory and inhibitory processes (e.g. cognitive control vs. sensory inhibition) or the alteration in the striato-thalamo-frontal feedback loop. Both models emphasized the role of frontal lobe in physical fatigue, where most structures have been associated with cognitive functions, such as goal maintenance, inhibition, and conflict reconciliation. The role of frontal lobe in fatigue can be illustrated by the gradual decline of frontal-related cognitive function, such as inhibition, during effortful physical or cognitive task.},
}

@inproceedings{morzycki2013effects,
  title = {The Effects of Alcohol and Energy Drink Co-Administration: Preliminary Results from a Randomized-Controlled Study.},
  author = {Morzycki, Alex and Barrett, Dr. Sean},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Introduction: Mixing alcohol and energy drinks has become increasingly popular among young adults. Given the novelty of this trend, only a small body of research presently exists. There appears to be an academic division as to whether or not it is safe to consume these two substances in tandem. Of the research that exists, it appears that mixing alcohol with energy drinks can lead to negative repercussions, including increases in risk-taking behavior and increased alcohol intake. Furthermore, research suggest that users may have an altered perception (i.e. underestimation) of how intoxicated they are, leading to poor decision-making. Objectives: The present study wished to address three questions. (1) Do energy drinks cause a subsequent increase in alcohol intake? (2) Do energy drinks affect latency to administer alcohol. (3) Do energy drinks cause an alteration in the subjective reporting of mood. Hypothesis: We predicted that energy drinks would cause an increase in alcohol intake as well as a decrease in latency to administer a first drink of alcohol, relative to caffeine only and control conditions. We predicted an analogous effect on the subjective measures (SRS & BAES) we assessed. Method/Results: In a randomized double-blind study using a validated measure of human self-administration, it was found that energy drinks caused a significant increase in total alcohol intake relative to an inert substance. Furthermore, it was determined that a beverage containing only caffeine caused a significant decrease in the latency to obtain alcohol, relative to an inert substance. No significant effect of condition was found on the subjective reporting of various mood descriptors. Conclusion: This study hopes to give preliminary insight into the physiological and behavioral processes which effect alcohol consumption when co-used with energy drinks.},
}

@inproceedings{moffatt2013subjective,
  title = {Subjective craving measures and neural correlates associated with tobacco cue reactivity in former, current and never-smokers},
  author = {Moffatt, Amelia and Lewis, Denise and Armstrong, Mackenzie and Balter, Leonie and Schlagintweit, Hera and Barrett, Sean and Good, Kim},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Through classical conditioning, smoking-related cues become strongly associated with the reinforcing effects of tobacco and elicit craving behavior in addicted smokers. These cue-induced cravings have been shown to activate the mesolimbic dopamine reward circuit. Individuals who have demonstrated the ability to cease smoking (former smokers) are a neglected research group. It is unclear what are the effects of smoking cues are on those individuals who were once strongly dependent on cigarettes. The current study aimed to examine both the neural activity and subjective cravings in response to smoking-related cues in former, current and never-smokers. Blood oxygen level dependent functional magnetic resonance imaging (BOLD fMRI), using an observation-response task, was employed. During the FMRI scan, subjects were required to watch two stimulus videos (one with neutral cues, the other with smoking-related cues), and respond to craving and mood questionnaires following each stimulus video. Our behavioral data revealed that current smokers had significantly higher craving levels following smoking cue presentation, compared to our never and former smokers. The neuroimaging data showed that current smokers displayed significant brain activity within the mesolimbic reward circuit during smoking cue presentation. Former smokers demonstrated no appreciable activity in the reward pathway; however, did show increased activity in prefrontal brain regions. These results suggest that despite former smokers showing little craving behavior, the regions of the brain required for top down processing (willpower), may be engaged in these individuals.},
}

@inproceedings{taylor2013attention,
  title = {Attention and Gaming: Development and validation of a game-like prism adaptation procedure in healthy participants},
  author = {Taylor, Kristina and Champod, Anne Sophie and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Prism adaptation is a promising rehabilitation technique for visuo-spatial neglect. In this two part study we first investigated if a computerized game-like prism adaption procedure (i.e., Peg-the-Mole) can induce aftereffects in a sample of 30 healthy adults (aged 18 to 23). A second study was then conducted to assess the validity of Peg-the-Mole and to determine if the aftereffects would generalize to a throwing task in 40 healthy adults (aged 18 to 30). Study 1 determined that Peg-the-Mole with deviating goggles is effective in inducing both proprioceptive only (p = 0.003) and proprioceptive visual aftereffects (p = 0.000) when compared to non-deviating goggles. Study 2 determined that Peg-the-Mole with deviating goggles is not different from the standard prism adaptation procedure with deviating goggles on measures of proprioceptive only (p = 0.754), visual only (p = 0.072), and proprioceptive visual (p = 0.115) aftereffects and generalization of aftereffects to a throwing task (p = 0.351) and both conditions with deviating goggles are significantly different than without deviating goggles on all measures (p = 0.000). Furthermore, Peg-the-Mole was more enjoyable than the standard prism adaptation procedure (p = 0.001). This study demonstrates that alterations can be made to the standard PA procedure to make it more feasible for use in patients' homes as well as making it a more enjoyable rehabilitation technique.},
}

@inproceedings{speth2013usability,
  title = {A Usability Study for the Better Nights, Better Days Web-Based Intervention for Pediatric Insomnia},
  author = {Speth, Tamara and Corkum, Penny and Coulombe, Aimée},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Introduction and Objectives: Pediatric insomnia is a highly prevalent and pervasive problem that affects both children and their caregivers. While effective behavioural treatments exist, they are generally inaccessible and therefore used by a small number of parents. The Better Nights, Better Days web-based intervention for pediatric insomnia was designed to help overcome the accessibility issues related to behavioural treatments. Before the intervention is ready for evaluation through randomized control trials (RCTs), the current usability study is necessary to ensure parents' satisfaction and comfort with the intervention. Methods: Data will be collected in two cycles. Cycle One will involve an evaluation of the intervention by the Better Nights, Better Days Team, as well as a group of front-line health care professionals, and a group of parents who have a child with insomnia. This cycle of usability testing will take place during the development process, as a way to make improvements to the intervention before the website is fully constructed. As the proposed study will be taking place during the development process, participants will be asked to provide feedback on the intervention as the sessions are developed. There will be three waves of data collection in total. Cycle Two will be a pilot study with a new group of parents who have a child with insomnia, and will involve a full run-through and testing of the intervention. Results: We have not begun data collection for the current study. Conclusion: The current study will collect feedback on the Better Nights, Better Days intervention, both during and after the development process. The study will help to refine the intervention before beginning RCTs, and will allow researchers to ensure an enjoyable and effective user experience, which will help to improve the sustainability of the intervention.},
}

@inproceedings{mackinnon2013perfectionis,
  title = {Perfectionistic self-presentation predicts social anxiety: A 21-day diary study},
  author = {Mackinnon, Sean P. and Battista, Susan R. and Sherry, Simon B. and Korecky, Marla and Lambe, Laura and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Perfectionistic self-presentation is theorized to maintain social anxiety from moment-to-moment. Despite this theorized relationship, no research has tested this relationship using experience sampling methodology. The present research tested whether perfectionistic self-presentation predicted social anxiety beyond numerous key covariates using a daily diary design. Undergraduates (N = 165; 75.6% women; 84.8% White) completed questionnaires each day for 21-days using palm pilots. Generalizability theory and multilevel factor analyses suggested daily measures of perfectionistic self-presentation, social anxiety, perfectionism cognitions, and depressed mood were reliable and valid daily measures. Moreover, perfectionistic self-presentation was a robust predictor of social anxiety at the between-subjects and within-subjects levels, even when controlling for socially prescribed perfectionism, perfectionism cognitions, and depressed mood, extending prior cross-sectional research on this topic. By understanding daily personality processes, we can better understand the processes that perpetuate and maintain social anxiety, and ultimately how to devise more effective ways to treat social anxiety.},
}

@inproceedings{gunde2013linking,
  title = {Linking neuropsychology to brain imaging: reliability of the Symbol Digit Modalities Test (SDMT)},
  author = {Gunde, Eva and Stevens, M. and Song, X. and Beyea, Steven and D'Arcy, Ryan},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The SDMT is reliable and sensitive neuropsychological tool used to evaluate psychomotor and information processing speed and cognitive dysfunction in Multiple Sclerosis (MS). Reliability of functional magnetic resonance imaging (fMRI) has been reported with a range of 21% - 78% and a mean of 29% with regards to several tasks, including those applied for pre-surgical planning. The objective of this study is to test reliability of the SDMT using fMRI with the ultimate goal of developing the test as a clinical imaging tool to detect early changes in brain function and follow functional decline in MS. Here, we present preliminary findings of an ongoing study. Seven participants with remitting relapsing type of MS attended three visits a week apart with no experience of a relapse or a worsening of clinical symptoms. Functional maps of the SDMT were created for cortical and subcortical areas. Reliability of the SDMT was tested by applying the ROC-r analysis developed for pre-surgical mapping. This method allows for individualized thresholding of each functional map and provides the best overlap of active clusters at test-retest sessions. Overlapping cluster coefficients were calculated using the Rombouts method. Comparing the individual functional maps of the three visits, the average test-rest Rombouts coefficients show overlap of 45% for cortical, 36% for subcortical, and 40% for both, cortical and subcortical regions. Reliability of the SDMT is promising, as it is well above the overall mean cluster reliability reported in the literature and comparable to reliability (~46%) of tasks requiring higher order processing. Measuring reliability is a critical step towards developing the SDMT as a clinical imaging tool. We are currently increasing our sample size as well as recruiting healthy participants to obtain more accurate and representative information of the reproducibility of this test.},
}

@inproceedings{bailey2013preparing,
  title = {Preparing Parents to be Present for their child's Anesthesia Induction},
  author = {Bailey, Kristen and Bird, Sally and Fralic, Jessica and McGrath, Patrick and Chorney, Jill},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Background: Surgery is a painful and anxiety provoking experience for thousands of children who are admitted to Canadian hospitals each year. Recent literature suggests that preoperative anxiety is a significant predictor of postoperative pain and postoperative analgesic use (Kain, Mayes et al., 2006). Thus, managing children's preoperative anxiety is an important aspect of children's perioperative care. Parental presence during anesthesia (PPIA) is one of the most commonly used but controversial ways to help children manage their anxiety. A recent Cochrane review concluded that PPIA did not change child or parent outcomes as compared to no PPIA (Yip et al., 2009); however, studies included in this review did not take into account baseline characteristics (i.e., parent anxiety) nor did they prepare parents to be in the operating room which are both factors thought to be related to children's preoperative anxiety (Kain et al., 2006; 2007). Objective: Therefore the purpose of the present study is to compare the effectiveness of a brief family-centred video-based preparation intervention for PPIA (PPIA prep) to a PPIA with standard logistical preparation (PPIA std). Participants & Setting: The present study will recruit 100, (2-10 year old) children scheduled to undergo elective surgery at the IWK Health Centre and their parents. Design & Procedure: Parents will be randomized to receive either PPIA prep or PPIA std just prior to their child's surgery. Children of parent's randomized to each group, will be compared on measures of anxiety, pain, analgesic use and time required to recover from the surgery in hospital. Hypotheses: It is expected that children with parents in the PPIA prep group will have lower anxiety before surgery and less pain and analgesic use after surgery and will be discharged sooner than children with parents in the PPIA std group.},
}

@inproceedings{meinertzhagen2013but,
  title = {But that's just anatomy: The search for synapses, circuits and wiring diagrams in the Drosophila brain.},
  author = {Meinertzhagen, I.A. and Takemura, S. and Chklovskii, D. and Scheffer, L. and Lu, Z. and Horne, J.A.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Animal behavior arises from computations in neuronal circuits, but our understanding of these computations has been frustrated by the lack of detailed maps of synaptic connections, or connectomes, of identified neurons. For example, despite intensive investigations over half a century, the neuronal implementation of local motion detection in the insect's visual system remains elusive. A semi-automated pipeline developed at Janelia Farm has used serial-section electron microscopy to reconstruct a connectome, comprising 377 neurons and 14,798 synapses, within the largest neuropile of the Drosophila brain, the optic medulla. By matching reconstructed neurons to examples from light microscopy, we assigned neurons to cell types and assembled a connectome of the medulla's repeating module. Within this module, we identified cell types constituting a motion detection circuit compatible with the elementary motion detector (EMD) first identified as a cybernetic model over 50 years ago, and showed that the connections onto individual motion sensitive neurons in this circuit were consistent with their direction selectivity. Our results identify cellular targets for future functional investigations, and demonstrate that connectomes provide key insights into neuronal computations.},
}

@inproceedings{gadbois2013sniffer,
  title = {Sniffer dogs as non-invasive wildlife monitoring research assistants: The Wood Turtle (Glypetmys insculpta)},
  author = {Gadbois, Simon and Adams, David},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The Canid Behaviour Research Team has been working with Wildlife Conservation Canines since 2009. Following work with Ribbon Snakes (Thamnophis sauritus) and Eastern Coyotes (Canis latrans) we present data from a pilot study conducted in Middle Musquodoboit, Nova Scotia. Like most of the turtle species in Nova Scotia, wood turtles (Glyptemys [formerly Clemmys] insculpta) have experienced significant population decline in recent decades. Two dogs were assessed as potential "turtle dogs". Preliminary results, seasonal challenges in detection and search, and training considerations will be discussed.},
}

@inproceedings{floyd2013detection,
  title = {Detection and Discrimination of Hypoglycemic States by Dogs},
  author = {Floyd, Catherine and Macdonald, Meghan and Cummings, Elizabeth and McLaughlin, Elizabeth and Gadbois, Simon},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Type 1 diabetes mellitus is a life long-long chronic disease that requires constant blood glucose monitoring. Hypoglycemia, or low blood sugar, is a serious complication of diabetes and often occurs at night when little if any glucose monitoring occurs. This is a particularly serious problem in children as they are often unable to recognize and wake during low glucose levels. Continuous glucose monitors that sound an alarm when abnormally low or high blood sugar is detected are available, however, these devices are expensive to operate, may lead to infection, and can be inaccurate, often failing to detect true hypoglycemic states. There are many anecdotal reports that pet dogs alter their behaviour in response to low blood sugar in their owners. This occurs during both waking and sleeping states of the owner and dogs often show alert responses before the person detects their low sugar. American companies are claiming to train diabetes alert/assistance dogs, however there has been no empirical research to date that indicates whether dogs are able to detect and discriminate hypoglycemic states from normoglycemic states. To empirically test the ability of dogs to detect hypoglycemia via olfactory cues, the current study collected saliva, breath, and sweat samples from children and youth with Type 1 diabetes in normoglycemic and hypoglycemic states. The samples were presented to three volunteer dogs using a match-to-sample procedure, errorless discrimination training, and habituation/dishabituation. Data collection is currently underway.},
}

@inproceedings{clouter2013influence,
  title = {The influence of working memory load and task modality on the Simon effect},
  author = {Clouter, Andrew},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {In a typical Simon task, participants make task-relevant spatial responses that differ in spatial location (e.g., different response keys) to stimuli with task-irrelevant spatial locations. For example, a participant may have to press a right key for blue squares and a left key for red squares; the location of the squares is task-irrelevant. The Simon effect refers to the finding that responses are both slower and less accurate when the spatial location of the stimulus and that of the response key are incongruent. As a result of the conflict between the task-irrelevant spatial location of the stimulus and the relevant spatial location of the response, Simon tasks are commonly used as measures of executive attention, as Simon tasks allow a measure of the ability of participants to resolve the conflict that is generated. Executive attention and working memory are seen increasingly as overlapping cognitive constructs. In fact, one model of working memory suggests that working memory is a combination of short-term memory and attentional control. Some studies suggest that higher working memory loads reduce attentional control when the contents of the working memory task and the task-irrelevant content overlap. One may suppose that in the spatial tasks, where both the spatial location of the task-relevant stimuli and the spatial response mapping are encoded in working memory, a higher working memory load may reduce the Simon effect. A common finding in studies of the Simon effect is that the effect generally decreases with higher response times. One explanation for this finding is that a spatial stimulus activates a tendency to respond in the direction of that stimulus. Thus, when the spatial location of the stimulus and the appropriate response key are incongruent, response times are increased. However, the tendency to respond in the direction of the stimulus decays over time. To address these issues, in this study we manipulated working memory load (0-back and 2-back) and task type (spatial and verbal working memory tasks). Results suggest Simon effect differences in the two working memory load conditions. Simon effects were significant in the low-load condition, but not in the high-load condition. In addition, Simon effects differed in the two tasks. The verbal tasks show a Simon effect that decreases with higher reaction times, while the spatial tasks show the opposite trend. Analysis of the effect of working memory load by task type shows that the spatial tasks show a Simon effect that increases with higher reaction times in both load conditions; the verbal task shows the expected decrease in the effect with higher reaction times in the low-load, but not the high-load, condition. An important lesson to be drawn from this analysis is to examine the effect of interest over the response time distribution; the Simon effect differences by task would not have been apparent here otherwise.},
}

@inproceedings{richards2013anonymity,
  title = {Anonymity & Sharing Behaviour in Children},
  author = {Richards, Jennifer and Moore, Chris},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Background Despite abundant research on sharing behaviour in children, there is a paucity of research investigating whether the sharer's anonymity impacts sharing. More surprisingly, previous studies (that have assumed that young participants can understand anonymity) have failed to verify that young children understand this complex concept. Method We are assessing 3- and 5-year-olds to examine at what age children understand the concept of anonymity by asking forced-choice questions about their status as a 'known' or 'anonymous' sharer within a dictator game paradigm. From there, children share stickers as 'known sharers' or 'anonymous sharers'. Results Preliminary data analyses (N=40) suggest that 3-year-olds do not understand the concept of anonymity; however, 5-year-olds do. It also seems that being a 'known' or 'anonymous' sharer does not influence 5-year-old's sharing. Conclusion Given that these results indicate that 3-year-olds do not understand anonymity, previous research findings using this age group in paradigms featuring anonymity should be interpreted cautiously. Likewise, preschool-aged children's sharing may be driven by something other than their status as an 'anonymous' or 'known' sharer (such as a desire for equal sharing, regardless if they are anonymous).},
}

@inproceedings{longard2013early,
  title = {Early Expressive and Receptive Language Trajectories in Children with Autism Spectrum Disorder},
  author = {Longard, Julie and Bryson, Susan and Moore, Chris},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The early expressive and receptive language trajectories of children with Autism Spectrum Disorder (ASD) are poorly understood. The current study was conducted as part of a multi-site prospective study examining the early development of high-risk infant siblings of children with ASD (hereafter, high-risk infants). We investigated expressive and receptive language trajectories based on corresponding domain standard scores on the Mullen Scales of Early Learning (MSEL) at four time points (6, 12, 24, and 36 months). In the combined sample of high-risk (n=371, 56% male) and low-risk (n =152, 52% male) infants, expressive and receptive language trajectories were examined using semi-parametric group-based modeling. A 3-group solution provided optimal fit to the variation in both expressive and receptive language. The three trajectories were characterized by the following performance across time: (1) increasing from average to above average, (2) maintaining average, and (3) declining from average to below average. A diagnosis of ASD at 36 months was predictive of membership in the declining trajectories for both expressive and receptive language. The current findings have important implications for early intervention in ASD.},
}

@inproceedings{redden2013inhibition,
  title = {Inhibition of Return: Two causes investigated using speed-accuracy trade-off functions},
  author = {Redden, Ralph},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Inhibition of return (IOR) can be described as an inhibitory aftermath of orienting seen in the form of slower response times in the direction or location that was previously attended. First discovered by Posner and Cohen (1984) the phenomenon has been shown to exist in two mutually exclusive forms (Taylor & Klein, 2000): an effect on motoric processes (an output form) and an effect on attentional/perceptual processes (an input form). The factor proposed to modulate which form of IOR is observed is the state of activation of the oculomotor system: output based when the system is not suppressed; input based when it is suppressed. Whereas Chica, Taylor, Lupianez, and Klein (2010) discovered that when caused by an eye movement to an uninformative peripheral cue, the delay in responding to targets at the originally cued location (the IOR effect) was accompanied by more accurate responding. By generating speed-accuracy tradeoff functions using response-signal methodology as proposed by Wickelgren (1977) and implemented by Ivanoff and Klein (2006) and Zhao, Heinke, Ivanoff, Klein and Humphreys (2011) under conditions of eye monitoring, we determined the output form of IOR is characterized by a criterion shift, as compared to the input form, which is characterized by a change in performance.},
}

@inproceedings{weaver2013shaping,
  title = {Shaping adult phenotypes through early life environments},
  author = {Weaver, Ian C.G.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {A major question in the biology of stress and environmental adaptation concerns the neurobiological basis of how neuroendocrine systems governing physiological regulatory mechanisms essential for life (metabolism, immune response, organ function) become harmful. The current view is that a switch from protection to damage occurs when vulnerable phenotypes are exposed to adverse environmental conditions. In accordance with this theory, sequelae of early life social and environmental stressors, such as childhood abuse, neglect, poverty, and poor nutrition, have been associated with the emergence of mental and physical illness (i.e., anxiety, mood disorders, poor impulse control, psychosis, and drug abuse) and an increased risk of common metabolic and cardiovascular diseases later in life. Evidence from animal and human studies investigating the associations between early life experiences (including parent-infant bonding), hypothalamus-pituitary-adrenal axis activity, brain development, and health outcome provide important clues into the neurobiological mechanisms that mediate the contribution of stressful experiences to personality development and the manifestation of illness. This talk will summarize essential aspects of our current molecular understanding of how early environment influences brain development in a manner that persists through life and highlight recent evidence from rodent studies suggesting that maternal care in the first week of postnatal life establishes diverse and stable phenotypes in the offspring through epigenetic modification of genes expressed in the brain that shape neuroendocrine and behavioral stress responsivity throughout life.},
}

@inproceedings{schinkel2013comparison,
  title = {A Comparison of Maternal versus Paternal Non-Verbal Behaviour during Child Pain},
  author = {Schinkel, Meghan G. and Moon, Erin C. and Chambers, Christine T. and McGrath, Patrick J.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Introduction and Aims: Parental behaviour is known to play a significant role in children's response to pain. However, the majority of research to date has focused solely on maternal behaviour during child pain. A recent study conducted by Moon, et al. (2011) found generally no differences between mothers' and fathers' verbal behavior during child pressor pain. The present study aimed to build on this work through comparing mothers' and fathers' non-verbal behaviour during child pain. Methods: The non-verbal behaviour of mothers (N = 20) and fathers (N = 20) of 20 children (10 boys, 10 girls) who participated in the cold pressor task as part of the study by Moon et al. (2011) were coded from video-tape. Children had completed the CPT once with their mothers present and once with their fathers present in a counterbalanced order. Parental non-verbal behaviour was coded across 13 categories of behaviour, including distraction, humor, physical comfort and reassurance, facial and behavioural sympathy, procedure related attending behaviour and fidgeting. Coding was completed by two research assistants. Percent agreement ranged from 88% to 100% across the behaviour codes. Results: A series 2 (child sex) x 2 (parent sex) mixed analyses of variance (ANOVAs) revealed generally no significant differences in mother vs. father non-verbal behaviour, with the exception of fidgeting (i.e. any form of fidgeting or behaviours expressing agitation such as feet tapping, tapping fingers, bouncing knee), F(1,18) = 6.57, p < .05, with fathers engaging in significanly more fidgeting than mothers (fathers: M = 0.39, SE = .08; mothers: M = .23, SE = .06). There were no significant effects of child sex or parent by child sex interactions. Discussion: Concurrent with findings on parental verbal behaviour, mothers and fathers non-verbal behaviour generally did not differ during their child's pain experience. However, fathers appeared to fidget more often than mothers during child pain, perhaps indicating a greater amount of restlessness or discomfort in response to watching their child in pain or uncertainty about how to respond.},
}

@inproceedings{mitchell2013more,
  title = {More light from darkness: new results on the recovery from early visual deprivation in kittens following 10 days of complete darkness.},
  author = {Mitchell, Donald and MacNeill, Katelyn and Holman, Kaitlyn and Smithen, Matthew and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Last year we reported on the fast visual recovery from early monocular deprivation (MD) promoted by a 10 day period of complete darkness imposed either immediately or 5-8 weeks after a one week period of MD. In this update we show that the effects are no less dramatic following much longer periods of MD (from eye opening to 6-8 weeks of age) and as well report on the consequences of shorter or interrupted periods of darkness. Measurements of depth thresholds indicate that only about one-third of animals acquire stereoscopic vision despite recovering normal visual acuity in both eyes.},
}

@inproceedings{shaw2013origin,
  title = {Origin of the sustained negative response in the ERG of Drosophila SNR mutants},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The electroretinogram (ERG) in the fruitfly Drosophila melanogaster is an important diagnostic tool for the molecular genetics of synapses. The presence or absence of two of its three components, the ON- and OFF-transient responses, allows diagnosis of the working of the synapse from the photoreceptors to their postsynaptic follower neurons, following some genetic manipulation. In mutants where this synaptic outlet is blocked, the ON- and OFF-transients disappear, but a third component still remains: a Sustained Negative Response (SNR) that is believed to originate only in the photoreceptors themselves or their axons. The SNR remains in mutants ebony and tan that interrupt synaptic transmission by disrupting re-use of the photoreceptors' neurotransmitter, histamine, through enzymatic defects. Experimentally, if the SNR does come from the photoreceptors, a bright local flash delivered to ~1/10th of the ~770 facets of the eye should elicit a larger SNR than a dimmer flash from a 1° point source that illuminates only a few facets maximally, while the rest get very little stimulus. This proposition has been tested in three alleles of ebony and one of tan, always yielding the opposite result: the brighter 72-facet flash gives a much smaller response than the 1° flash that stimulates only 1-3 facets maximally. Confirming the calibrations, in the white-Hdc mutant in which the synapse again is blocked, the 72-facet input gives the larger responses, because the brighter local flash is now able to scatter widely throughout the transparent white eye. The results can be explained if the SNR does not originate in the photoreceptors, but instead comes mostly from a wide-field integrating cell system: this prefers tiny inputs delivered over many facets to saturating inputs aimed into only 1/10th of the eye.},
}

@inproceedings{lawrence2013psychometric,
  title = {Psychometric evaluation of a brief but comprehensive computerized attention test},
  author = {Lawrence, Mike and Allen, Stephanie and Johnson, Shannon and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {We present a brief computerized test that achieves measurement of a variety of phenomena of attention, including psychometric data from typically-developing child and young adult populations.},
}

@inproceedings{sterniczuk2013non,
  title = {Non-traditional risk factors predict dementia and mortality in healthy individuals},
  author = {Sterniczuk, Roxanne and Theou, Olga and Rusak, Benjamin and Rockwood, Kenneth},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {As age-related health deficits accumulate over time, so does the risk for adverse health outcomes. Previous work re-analyzing data from the Canadian Study of Health and Aging suggested that several risk factors which are not traditionally associated with dementia, may impact an individual's level of frailty and their risk of Alzheimer's disease (AD). We investigated whether an index consisting of such non-traditional factors, could predict future reports of incident AD and dementia, as well as mortality, in a similar manner to traditional risk factors, in a larger, multi-national cohort. Secondary analyses were conducted on data from the Survey of Health, Ageing, and Retirement in Europe and consisted of cognitively healthy individuals 50 years or over, from 12 European countries (N = 11,817). Three AD risk factor indices (RFIs) were constructed to predict a ~4-year risk for a self or informant report of AD, dementia and survival; a 31-item non-traditional RFI, a 6-item traditional RFI, and a 37-item combined RFI. While controlling for age, sex, education, and traditional risk factors for AD within our regression risk models, the non-traditional RFI significantly predicted the risk of dementia and mortality after an average of 4.3 years. The combined RFI exhibited the strongest prediction of dementia and mortality. Although non-traditional risk factors may not individually contribute to dementia or mortality, a decline in overall health status is strongly associated with an increased risk for these adverse outcomes. Health professionals should place greater importance on the examination of overall health decline, rather than just assessing traditional risk factors for illness.},
}

@inproceedings{asadnejad2013effects,
  title = {The Effects of Alcohol and Snus on Dependent Smokers? Cigarette Craving & Cigarette Self-Administration},
  author = {Asadnejad, Parisa and Barrett, Sean},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Dependent smokers use cigarette and alcohol widely together; however, factors affecting the impact of alcohol on smoking behavior are not known. This study assessed the effects of snus (smokeless powder tobacco) and alcohol on cigarette craving and smoking behavior in 19 dependent smokers. Randomized placebo controlled double blind design was used and each participant was assessed in 2 sessions. A progressive ratio task was used over 60 minutes as a behavioral measurement. Mood and cigarette craving were assessed through subjective measurements. Tobacco craving increased significantly after drinking alcohol and placebo beverages. Snus significantly reduced individuals' motivation to start smoking. Snus and alcohol together did not have any significant effect on cigarette craving and smoking behavior. In conclusion, the effect of alcohol on cigarette craving involves its interaction with nicotine; however, when used with snus, its interaction with nicotine alone will not have any considerable impact on smoking behavior.},
}

@inproceedings{leroux2013impact,
  title = {T4) Impact of Menstrual Cycle Phase on Metabolic Effects of Sleep Restriction},
  author = {LeRoux, Amanda},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {There is extensive evidence that spontaneous short sleep and imposed sleep restriction are linked to altered metabolic and endocrine function. Sleep restriction has been associated, for example, with increased cortisol and ghrelin levels, decreased leptin levels and increased appetite, especially for carbohydrate- and fat-rich foods. While most of these studies have been conducted using male participants, a few recent studies have confirmed some of these findings in women. Parallel laboratory and epidemiological studies have shown a link between chronic short sleep and body weight gain. A retrospective analysis of results from one study in women suggested that menstrual phase was a strong modulator of these metabolic effects of sleep loss. In the current study, we recruited young healthy females of reproductive age (n=18; Mean age: 22.4; Mean BMI: 21.7) to examine whether menstrual cycle phase modulates the impact of sleep restriction on levels of the metabolic hormones cortisol and leptin. A secondary goal is to examine how sleep loss affects self-reports of mood, hunger and food preferences, and whether menstrual cycle phase also modulates these effects.},
}

@inproceedings{tims2013relationship,
  title = {The Relationship Between Orthographic Processing and Word Reading},
  author = {Tims, Talisa and Deacon, Helene and Castles, Anne},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Orthographic processing is an important skill for word reading in children. Orthographic processing refers to the ability to form, store, and retrieve orthographic representations. As a construct, orthographic processing can be broken into orthographic knowledge (access to existing orthographic representations) and orthographic learning (formation and storage of new orthographic representations). Previous research has consistently found a relationship between orthographic knowledge and word reading. However, studies attempting to determine the directionality of the relationship between orthographic processing and word reading have found conflicting results. Thus, in this study, we propose to use measures targeting orthographic learning instead of orthographic knowledge in order to better elucidate the nature of this relationship. The proposed study measures orthographic learning in second and third grade students at three time points over the course of one and a half years. Children will complete various measures of word reading, phonological awareness, reading comprehension, orthographic knowledge, and orthographic learning. Data collection for the first and second testing points are complete and data collection for the third and final testing point is proposed to be completed by June 2013. This presentation will focus on the theoretical background and predictions for this study.},
}

@inproceedings{christie2013rescuing,
  title = {Rescuing Eye Movement Modellers From a 40 Year Rut},
  author = {Christie, John and Hilchey, Matt and Klein, Ray},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {For 40 years it has been established that when two stimuli are presented close to one another eye movements toward those stimuli tend to land between them. This is the global effect of stimuli on eye movements. In contrast, when two stimuli are presented far apart eye movements land at one of the stimulus locations--a local effect. Contrary to conventional wisdom, by measuring the effect through priming, we find a strong global effect for stimuli very far from each other. This effect is even stronger than the local effect at all stimulus spacings. Researchers need to reconsider one of the fundamental "principles" they use in modelling human and primate eye movements},
}

@inproceedings{wright2013hood,
  title = {Hood Rats and Alley Cats: Potential for Protective Effects of Prenatal Stress in an Animal Model of Seizure},
  author = {Wright, Lisa D. and Korgan, Austin and Perrot, Tara S.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {There is a large body of literature demonstrating detrimental effects of prenatal stress on various measures of neural development and long-term health outcomes in rat offspring. Much of this work, however, has involved stressing pregnant rat dams using restraint or a combination of unnatural disruptions to the homecage environment. The present project sought to examine the effects of repeatedly exposing pregnant rat dams to a naturalistic stressor, predatory threat, every day during the third trimester. After giving birth, their male and female offspring were raised either in standard housing conditions or in an enhanced environment that was larger and contained a burrow. Outcomes that were measured in the adult offspring included seizure susceptibility and corticotrophin-releasing-hormone (CRH) production in a subregion of the thalamus, as well as in an overlying subregion of cortex. We found that adult offspring of dams exposed to cat stress exhibited less seizure behaviour and had lower levels of CRH-producing cells in cortex, relative to offspring from control dams. However, these differences were ameliorated in offspring raised in an enhanced environment, suggesting that any protective effects garnered through prenatal stressor exposure of rat dams could also be acquired later on, through post-natal environmental enhancement.},
}

@inproceedings{stamp2013comparison,
  title = {Comparison of Risk and Protective Personality Traits in Smoking and Non-Smoking Teens},
  author = {Stamp, Jennifer and Peters, Dawn and MacAllister, Lynda},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Research has identified a number of distinct personality dimensions that place an individual at risk for substance misuse. The Substance Use Risk Profile Scale (SURPS) assesses four of these: hopelessness-introversion (HI), anxiety sensitivity (AS), impulsivity (IMP), and sensation-seeking (SS). Psychological resilience is the ability to overcome challenges (measured by the Connor-Davidson Resilience Scale, or CD-RISC), and although not well studied in the context of substance misuse, predicts favourable outcomes in individuals experiencing trauma. The present study aimed to compare these personality constructs in smoking and non-smoking teens in rural high schools in Nova Scotia. We sought to: 1) compare measures on the SURPS and CD-RISC in smoking and non-smoking teens and 2) determine the relationship between personality and response to a school-based quitting smoking program. Overall smokers had higher significantly higher scores on the HI and SS dimensions of the SURPS, and lower scores on the CD-RISC. CD-RISC scores were positively correlated with age of first use, and negatively correlated with self-reported smoking at baseline. Amongst the smokers, there were no significant relationships between personality risk factors and baseline smoking or response to treatment.},
}

@inproceedings{williams2013influence,
  title = {The influence of social comparision on sharing and envy in children.},
  author = {Williams, Amanda and Isenor, Katie and Moore, Chris},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Though prosocial behaviour emerges early in development, there are numerous factors that influence its manifestations. This study explored how social comparison influences prosocial behaviour in five and six-year-old children. Children first played a computer game against a fictional child, and were randomly assigned to a winning condition- in which they won nine out of ten trials against their partner, or losing condition- in which they lost nine out of ten trials. Next, they were asked to distribute resources between themselves and their partner from the computer game in a sticker sharing game that included sharing, and envy trials. Though we expected to see more prosocial behaviour for the winning condition in both trial types- more sharing, and decreased envy, children in the winning condition showed more prosocial in sharing trials alone. We suspect the competitive nature of the game increased envy across both conditions, and plan to follow-this up by including a non-competitive condition.},
}

@inproceedings{aitken2013effects,
  title = {Effects of housing conditions on neurogenesis in black-capped chickadees (Poecile atricapillus)},
  author = {Aitken, Sean},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {In chickadees, it has been shown that captivity leads to suppressed neurogenesis in the hippocampal complex compared to free-flying birds. It is not known whether differential housing condition influences the degree to which neurogenesis is suppressed. We captured birds during winter and subjected them to different housing conditions: Outdoor aviary, indoor aviary, and indoor cage. Birds were injected with BrdU and observed for six weeks after which time their brains were assessed for neuronal proliferation and survival. Results from this study will allow us to determine the effects of housing condition on neurogenesis while considering associated factors including behavioural differences and climate. These results will provide insight to what factors underly differences in neurogenesis between captive and free-flying birds. Further, results will aid in understanding the influence of environmental context in field and laboratory studies using songbirds.},
}

@inproceedings{ryan2013connectome,
  title = {The connectome of the larval central nervous system (CNS) of Ciona intestinalis},
  author = {Ryan, Kerrianne},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {The complete wiring diagram (connectome) of any CNS has been reported only for C. elegans. Using serial-EM, we report the connectome for a Ciona larval CNS with 166 neurons, 4 ascending neural tube axons, and 70 non-neuronal cells. It incorporates the elements of sensory integration along with a central pattern generator for larval swimming, with outputs through paired motoneurons in the visceral ganglion (VG) and proximal tail, a region containing 11 ascending and 20 descending neurons. Information in the sensory vesicle (SV) arises from: photoreceptors with outer segments (23 in the pigment cup, 7 in the lumen of the SV); 2 otolith associated antenna cells; 16 enigmatic, anaxonal coronet cells; and axons from rostral trunk epidermal (RTEN) and papillar (PN) neurons. Information is integrated in both the posterior SV by 31 interneurons and within the VG where an intrinsic circuitry allows for further integration of signals. This pathway constitutes the means of control of initiation of motor response as well as its modulation. The input provided to motor neurons within this region in turn determines their activity at cholinergic neuromuscular synapses and results in a variety canonical behaviours. This connectome will be presented via circuit diagrams that will be essential both to interpret functional studies in Ciona larvae as well as to predict those functions. Inherent in this discussion of circuitry is a critical analysis of the nature of synaptic connections and functional cell types in this basal Chordate species.},
}

@inproceedings{sullivan2013investigatio,
  title = {An Investigation of the Neural Correlates of Impaired Olfactory Identification Ability in Patients with First Episode Psychosis: An FMRI Study},
  author = {Sullivan, Randii-Lynn and Milliken, Heather and Schellinck, Heather and Brown, Richard and Fisk, Jordan and Macalindon, David and Lewis, Denise and Armstrong, Mackenzie and Good, Kimberley},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Olfactory identification deficits (OID) are present in a proportion of patients with first episode psychosis and may be prognostic for a poorer outcome. The neural underpinnings of this impairment have not been identified. The purpose of this study was to examine the neuronal correlates of OID in patients with first episode psychosis by comparing a subgroup of patients who have OID (n=6) to a subgroup of patients with intact (normal) olfactory identification (NOI n=6) and contrast their functioning to a group of healthy control subjects (n=16) using BOLD FMRI while being passively presented with odours or clean air. Using a region of interest (ROI) approach, BOLD activation was examined across groups. The first contrast compared healthy controls to the two patient groups during odour presentation. Healthy control subjects activated the orbitofrontal cortex (OFC) and anterior cingulate during odour presentation whereas patients did not. Comparing the two patient groups, the NOI group activated insular regions (more right than left) and right amygdala while OID patients did not. These results support the notion that brain activation is indeed compromised in secondary olfactory brain regions in patients with psychosis, whereas in those patients who have olfactory identification deficits, the abnormality may lie in primary olfactory cortex network. In patients with intact olfactory identification, compensatory regions may be invoked.},
}

@inproceedings{telbis2013effect,
  title = {The Effect of Alcohol on Smoking Cue Reactivity in Non-Dependent Smokers},
  author = {Telbis, Dessi P.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {Introduction: Non-dependent smokers report greater urge to smoke in response to smoking cues and alcohol. Moreover, smoking cue-craving is perceived as more intense in females and as blood alcohol levels are rising. This study examined the role of alcohol and sex on tobacco craving induced by smoking cues in non-dependent smokers on the ascending limb of the blood alcohol curve. Methods: Seventy-five non-alcoholic non-dependent smokers (38 male; 37 female) were recruited from the general population. During one double-blind placebo-controlled session, participants assessed the effects of smoking cues on cigarette craving as measured by the QSU-B, following the administration of a moderately intoxicating dose of alcohol or a taste-matched placebo beverage. Results: The results revealed that acute alcohol consumption lead to an increase in factor 1 and 2 desire to smoke in females in response to a non-nicotine stimulus on the ascending limb of the blood alcohol curve. Discussion: The findings suggest that females may be more susceptible to craving in response to smoking-related cues particularly early in the alcohol absorption period.},
}

@inproceedings{duffy2013monocular,
  title = {Monocular deprivation alters the size of FoxP2 (X cells) cells in the cat lateral geniculate nucleus},
  author = {Duffy, Kevin R. and Holman, Kaitlyn and Mitchell, Donald E.},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {A central characteristic of the visual system is the streaming of information through parallel pathways. In the cat lateral geniculate nucleus (LGN), parallel processing streams derive from two principal neuron types, namely X and Y cells. It is well known that disruption of visual experience by monocular deprivation has a profound impact on the structure and function of Y cells, but the extent to which deprivation influences X cells remains unclear. Recently the FoxP2 protein has been shown to selectively label X cells in the ferret LGN, providing an opportunity to examine whether X cells are modified by monocular deprivation. In this study, FoxP2 labeling was examined in the LGN of normal (n=2) and monocularly deprived (n=3) cats. We first determined that the labeling characteristics of neurons reactive for FoxP2 were consistent with it being a marker for X cells in the cat LGN. Monocular deprivation for either a short or long duration did not change the number of FoxP2-positive neurons between non-deprived and deprived LGN layers. However, cell measurements revealed that in deprived layers, X cells were reduced in size by 20% after 7 days of deprivation, and by 30% after 7 weeks of deprivation. The observed alteration to X cells in the context monocular deprivation is in agreement with the associated impairments to vision.},
}

@inproceedings{shinomiya2013synaptic,
  title = {Synaptic circuits in the lobula of the fly's visual system},
  author = {Shinomiya, Kazunori},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {I have conducted a neuroanatomical approach to reveal functional circuits in the visual system of the fruit fly Drosophila melanogaster, especially focusing on a neuropil called the lobula, the highest-order component of the optic lobe. The fly receives light stimuli at the compound eyes. Visual information is subsequently processed in the primary visual centre of the brain, or the optic lobe. The optic lobe comprises four neuropils including the lamina, medulla, lobula and lobula plate. The lobula receives inputs mainly from the medulla, and sends outputs to the lobula plate as well as to the higher-order visual centres in the central brain. Recent behavioural and live-imaging studies have revealed some lobula neurons signal features of colour, movement and shape. Although these neurons have been identified using light microscopy, low-resolution images with light microscopy are not sufficient to investigate synaptic connections of these cells. Therefore, in this study, I recruited serial-section transmission electron microscopy (ssTEM) to analyse neuronal morphology and synaptic connections of the lobula in a higher-resolution. Relay neurons from the medulla, transmedulla (Tm) cells, account for most cell types connecting the medulla and lobula. Among them, Tm1, Tm2 and Tm9 cells have presynaptic terminals in the first (Lo1) and second (Lo2) strata of the lobula. First I reconstructed these terminals and confirmed their columnar distributions. Lo1 also contains dense arbors arising from T5 cells. T5 cells provide outputs to the lobula plate tangential cells (LPTC), which are known to signal motion. To trace T5's highly branched arbors, I used Gal4-driven membrane-targeted horseradish peroxidase (HRP) with a T4/T5 driver. T5 turned out to receive inputs from all the Tm1, Tm2 and Tm9 terminals, as well as other Tm subtypes which terminate deeper in the lobula. Previous anatomical, functional and behavioral studies reveal that Tm1 and Tm2 are responsible for motion and shape detection, while Tm9 is associated with color discrimination. The result indicates that T5 not only conveys motion information but also some aspect of spectral information to the lobula plate. Other neurons and pathways, including colour-processing pathways, will be focused using both unlabeled and HRP-labeled ssTEM section series.},
}

