  title = {"Matt Stone looks just ravishing in his pink dress" Irony in computer-mediated conversations.},
  author = {Hancock, Jeff and Dunham, Philip},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The text-based conversations that occur in email and internet chat environments eliminate many of the non-verbal signals, such as facial expressions and tone of voice, that we rely on to interpret a speaker's intent. The present study assessed the impact of computer-mediated communication (CMC) on the use of ironic forms (e.g., irony, hyperbole, understatement, rhetorical questions) in conversations between strangers. Given the reduction in the cues available in CMC to signal irony, we expected less use of irony in this impoverished environment than in face-to-face conversations. Comparison of 40 conversations across these two communicative environments indicated that, contrary to initial expectations, substantially more ironic language was produced in the CMC condition. This general finding has several implications for current theoretical accounts of the comprehension and production of verbal irony.},
}

@inproceedings{large2001priming,
  title = {Priming effects of global and local attention on the categorization of objects: A pilot study.},
  author = {Large, Mary Ellen and McMullen, Paddy},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Images of objects are identified more quickly at the basic level (dog) than the subordinate level (beagle) because subordinate level identifications require more visual processing in order to differentiate exemplars who share many common features. The differences in speed of processing between basic and subordinate level categorizations may be explained by global (coarse aspects of structure) and local (fine detail) attentional differences. To investigate this possibility the priming effects of a global and local attentional task on the categorization of objects at the basic and subordinate level were examined. Additionally, distractors varied in their degree of similarity to the target. It was found that after priming at the local level participants responded more quickly to both basic and subordinate categorizations when the distractors were similar and after priming at the global level they responded more quickly to basic and subordinate categorizations when the distractors were dissimilar. This result suggested that an important distinction in the speed of processing for basic and subordinate categorizations is not the level of categorization per se but the visual context in which the categorizations occurs.},
}

