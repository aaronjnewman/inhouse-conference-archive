@inproceedings{bishop1991relationship,
  title = {The relationship between catastrophizing and negative affect Two studies were conducted to examine the cognitive-affective correlates of catastrophizing. Catastrophizing has been defined as a tendency to engage in excessively negative cognitions related to aversive stimuli such as pain. Study 1 examined the reliability and construct validity of a self-report measure of catastrophizing cognitions. A 13 item scale, developed for this study was shown to have high internal consistency (alpha = .90). In addition, the scale showed the same relationship with subcomponents of depressive symptomatology shown with clinical measures of catastrophizing. Study 2 examined subjects evaluations of the valiance of positive, negative and pain-related words following a success or failure experience. Results indicated that catastrophizers who experienced success on a problem solving task rated positive and pain-related words more negatively than noncatastrophizers. Study 2 also addressed the test-retest reliability of the catastrophizing measure. The results are discussed in terms of the relationship between catastrophizing and negative affect},
  author = {Bishop, Scott},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
