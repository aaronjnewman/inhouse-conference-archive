@inproceedings{akhtar1991comprehensio,
  title = {Comprehension strategies of young children Previous research (Shatz, 1978) has indicated that young children are biased to respond to language with action. This study attempted to replicate this finding in a group of 64 24 month olds. These children heard 30 prerecorded sentences differing in syntax presented through a speaker in a robot (thereby eliminating extralinguistic cues such as gesture and gaze). Their responses were videotaped and coded as Action, Informing, or Other. Results indicated that the children were not biased to respond with action, and were able to discriminate among the five sentence types. The data suggest that this discrimination may be based on surface markers such as the presence of an action verb, and the mention of an object present in the immediate context},
