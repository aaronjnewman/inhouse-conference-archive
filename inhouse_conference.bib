@inproceedings{brown1997hebb,
  title = {The Hebb-Williams Maze: Fifty years of research (1946-1996)},
  author = {Brown, Richard and Stanford, Lianne},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The Hehir Williams (H-W) maze was designed as a test of animal intelligence and since 1946 has been used to study the learning abilities of a wide variety of species including fish, raccoons and cows, as well as mice and rats. The H-W maze is an open field, with a start box, a goal box and moveable barriers. Each animal runs through a battery of twelve mazes of increasing difficulty, created with the movable barriers. As well as comparative studies of learning using different species, the H-W maze has been used to assess the effects of environmental enrichment or deprivation on learning and the impact of hormones, X-irrad.iation, specific brain lesions, changes in diet, and a variety of drugs on learning. Currently, the H-W maze is used to study genetic influences on learning and the effects of prenatal manipulations of diet, stress, hormones and drugs on learning, as well as the neural basis of learning. The present talk discusses the value of the H-W maze for studying advanced cognitive tasks and its potential as a tool for measuring "intelligence" in congenic strains of mice, transgenic mice and knockout mice.},
}

@inproceedings{stanford1997measuring,
  title = {Measuring learning in CDl mice in the Hebb-Williams Maze: Practical problems in the use of a complex maze test of intelligence},
  author = {Stanford, Lianne and Stapleton, Jennifer and Dill, Patti and Oarke, Alison and Randhawa, Harleen and Dixon, Deana and Syed, Asma and Mamoun, Yasmin and Brown, Richard},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Although the Hehir Williams (H-W) maze was developed as "a method of evaluating animal intelligence", the procedures used for testing subjects in this maze have varied greatly. The most commonly used procedure is that developed by Rabinovitch and Rosvold (1951, Can. J. Psych., 5, 122-128). As we plan to use this maze to study learning in different mouse strains, it is important to develop a standardized procedure. Using data from pilot studies with CDl mice, this talk will focus on maze design, floor patterns, scoring procedures, motivation and all of the little things that can go wrong. We will also include some video footage of mice learning the H-W maze.},
}

@inproceedings{mcmullen1997separate,
  title = {Separate Orthographic Input and Output Lexicons: Evidence from a Surface Dysgraphic},
  author = {McMullen, P.A. and Braithwaite, A. and J.M.McGlone},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {A surface dysgraphic was investigated to determine: 1). his writing deficit within a cognitive model and 2). support for a single or separate input and output orthographic lexicons. Regular words and nonwords were spelt perfectly, unlike irregularly spelt words (66% errors). All of these words were read perfectly. These results, along with normal cross-case transcription (e.g. CaSe- cAsE) supported intact orthographic input and output lexicons. Written rhyme fluency and deciding if words that sounded the same were spelt the same (e.g. tough-buff) was poor. Results were most consistent with a disconnection between phonological and orthographic output lexicons.},
}

@inproceedings{yoon1997influences,
  title = {Influences of sentential contexts on event related brain potential responses to semantic anomaly and/or verb inflectional disagreement in compound sentences.},
  author = {Yoon, Myong G and Connolly, John F},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {We studied the characteristic patterns of neural responses of the human brain to various combinations of semantic anomalies and/or verb inflectional disagreements during rapid reading of compound sentences by analyzing the event related brain potentials (ERP) recorded from normal adult subjects. [l] ERP of semantically anomalous verbs showed negative shifts peaking at about 400 msec (N400) with respect to the semantically appropriate verbs. The onset time of the N400 responses depended on the syntactic contexts of the verbs. [2] ERP of inflectionally incorrect verbs made positive shifts at about 600 msec (P600) with respect to control verbs. A repetition of the inflectional disagreement in the second clause diminished the P600 response. The result suggests that the repeated inflectional disagreement tends to be ignored by the neural mechanism which has responded to the previous inflectional disagreement as P600. [3] The predominant component of neural responses to semantically anomalous and inflectionally incorrect verbs was P600 rather than N400. Thus inflectional disagreement (rather than semantic anomaly) seems to be a predominant linguistic feature, detected by those neurons whose activities happened to be monitored by our recording methods. [4] Inter-sentential influence of the semantically anomalous transitive verb (with respect to its subject) upon its (acceptable) object; ERP to the object words of semantically anomalous verbs showed large negative shifts during a period between 300 and 750 msec. The magnitude and duration of the negative shift in the object word was far grater than that in the anomalous verb itself. The result reveals the prominent influence of the two diffemet sentential contexts on the same terminal words . [5] Inter-sentential influence of inflectional disagreement of semantically normal transitive verb upon its appropriate object in the second clause; ERP to the object words of the inflectionally incorrect normal verbs showed large negative shifts during a period beginning 300 msec. This large negative shift in the object words reflects the influence of the preceding inflectional relations between the subjects and the verbs in the compound sentences.},
}

@inproceedings{stewart1997gender,
  title = {Gender differences in anxiety sensitivity dimensions},
  author = {Stewart and H, S. and Taylor and S and Baker, J. M},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {The present study examined whether there are gender differences in the hierarchical factor structure of the Anxiety Sensitivity Index (ASI), and/or patterns of ASI factor scores. Principal components analyses on the ASI items of male (N =290) and female (N =528) students revealed nearly identical lower-order factor structures across genders (i.e., physical, psychological, and social concern factors). Nearly identical unidimensional higher-order solutions were also found across genders. Analyses on ASI lower-order factor scores showed that: females scored higher than males only on the physical concerns factor; females scored higher on the physical concerns factor than on the psychological and social concerns factors; and males scored higher on the psychological and social concerns factors than on the physical concerns factor. Females also scored higher than males on the higher-order ASI factor. The study provides support for the conceptual distinctions between the three lower-order ASI factors, as well as the first empirical demonstration of a hierarchical structure for the ASI. Men and women also appear to differ on AS dimensions in ways consistent with sex role socialization practices.},
  note = {QA: needs-split-review; Split from T16 at: 'Tl 7. Gender differences in anxiety se'},
}

@inproceedings{israeli1997memory,
  title = {Memory bias for food information in restrained eaters},
  author = {Israeli, Anne and Stewart, Sherry},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {Research on cognitive patterns in individuals high in dietary restraint indicate an attention bias toward food related information (see Francis, Stewart, and Hounsell, in press). The cwrent study was conducted to see if restrained eaters show a memory bias for food words in comparison to animal words (control list) in relation to individuals low in restraint Thiny females (Mean age= 21.50, SD= 2.97) encoded a list of words (15 food, 15 animal) presented in an incidental learning task. Participants were then asked to freely recall as many words as they could remember and fill out questionnaires including the Restraint Scale (Herman & Polivy, 1980). Participants were classified as high in restraint (n=16) and low in restraint (n=14) on the basis of the scale. Preliminary analyses indicate that individuals high in restraint remember more food than animal words and individuals low in restraint do not demonstrate such a bias. The results support (Bemis-Vitousek & Hollon's (1990) theory that restrained eaters have highly organized cognitive structures (schema) which permit then to avoid dangers (food) in their environment},
  note = {QA: needs-split-review; Split from T16 at: 'Tl 8. Memory bias for food'},
}

@inproceedings{macgregor1997translation,
  title = {A translation of borderline and histronic personality disorders},
  author = {MacGregor, Michael and Davidson, Karina and Gustys, Stephanie},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {This paper addresses the translation of Borderline and Histrionic personality disorders into the language of the Five-Factor model of personality. Based on theoretical expectations, we investigated the empirical relationship between the Five-Factors of personality and these two personality disorders in a non-clinical sample. As expected, the personality disorders were characterized by high levels of Neuroticism. For Borderline personality disorder, our expectations regarding Agreeableness were confirmed, however, those for Extraversion were not As well, additional relationships were found between both Openness and Conscientiousness and Borderline personality disorder. For Histrionic personality disorder, our expectations for Extraversion were confirmed, however, those for Openness were not Additionally, both Agreeableness and Conscientiousness demonstrated and unexpected relationship with Histrionic personality disorder. While some of the expected relationships between the Five-Factors and Borderline and Histrionic personality were confirmed. others were not It appears that theoretical or clinical expectations are not necessarily confirmed by empirical findings in a non-clinical sample. Results are discussed in terms of the utility of the Five-Factor model in describing personality disorders.},
  note = {QA: needs-split-review; Split from T16-split2 at: 'A translation of borderline'},
}

@inproceedings{barresi1997becoming,
  title = {Becoming conscious of 'consciousness': Notes for a history of an important psychological concept},
  author = {Barresi, John},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {During the 17th century the term of 'consciousness' suddenly appeared as a psychological concept. Since then this concept has become increasingly important both in the foundations and later developments of 'mental philosophy' and scientific psychology. Although during the heyday of behaviourism it diminished in importance, interest in consciousness has been revived again toward the end of this century. In the present talk I will look at the origins of the use of this term, its ancient sources in Greek and Latin, its major 'discovery' in Descartes, and its later development in the works of Cudworth, Locke, Leibniz, Hume, and others in the late 17th and early 18th century.},
  note = {QA: needs-split-review; Split from T16-split2-split1 at: "T20. Becoming conscious of 'consciousnes"},
}

@inproceedings{klein1997attention,
  title = {Attention (to the moving line): "Where you lead, I will follow".},
  author = {Klein, Raymond M. and Hamm, Jeff P.},
  booktitle = {23rd Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1997},
  abstract = {When a line is presented in the vicinity of a recent luminance change (peripheral cue) it is perceived to be drawn over time away from its "cued" end even though the line is actually presented all at once. This study was designed to determine if attention, exogenously attracted to the cue, would come under the exogenous control of this illusory motion and follow the drawn line from its cued end to its terminus. Each trial began with the display of 4 small squares at the corners of an imaginary square centered about fixation. After 750 ms one of the 4 squares brightened briefly (50ms) in the cued conditions. Simultaneous with the offset of the cue a horizontal line was presented joining the upper or lower boxes. After 100 ms one of the 4 squares was transformed into a horizontal or vertical rectangle for 150 ms. The subject's task was to make a horizontal/ vertical decision as rapidly as possible. The different events (cues, lines and targets) were combined factorially so that neither cues nor lines were informative about target location. Responses to targets at an uncued location that was at the end of an illusorilly drawn line were as fast as to targets in the neutral and "valid" conditions, and much faster than the remaining invalid conditions, strongly suggesting that attention follows the motion in the "shooting line" illusion. T22. Integration of Environmental and Intentional Information within the Saccadic Programming System: A Computational Perspective. Sol Simpson, Thomas Trappenberg, & Raymond Klein Saccadic reaction time (SRT) is influenced by both the observer's environment (exogenous factors) and intentions (endogenous factors). To investigate these two SRT contributions, the time interval between the removal of a fixation point and the presentation of a peripheral target (the Gap Paradigm) as well as the probability of a target appearing at a given location were varied. It was hypothesized that if endogenous information affects SRT within the same functional layer of the saccadic programming system that is responsible for exogenous control (the superior colliculus), the effect of target location information would be significantly larger in conditions where the fixation stimulus was removed prior to target presentation than in conditions where the fixation stimulus remained present following target onset. This interaction was obtained with saccadic but not manual RTs, suggesting that the lateral inhibition of fixation cells in the rostral pole (RP) of the superior colliculus (SC) onto the saccade related cells of the SC may memate the effects of both exogenous and endogenous inputs on SRT. This presentation will attempt to explain this interaction},
  note = {QA: needs-split-review; Split from T16-split2-split1 at: 'T21. Attention (to the moving line): "Wh'},
}

