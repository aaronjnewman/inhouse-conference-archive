@inproceedings{stewart1999relations,
  title = {Relations Between Personality Domains and Drinking Motives in Young Adults},
  author = {Stewart, Sherry and Devine, Heather},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The purpose of the present study was to place drinking motives within the context of the Five-Factor Model of personality. Specifically, we sought to determine whether certain personality domains of the Revised NEO Personality Inventory (NEO-PI-R; Costa & McCrae, 1992) predict Enhancement, Coping, Social, and/or Conformity drinking motives from the Revised Drinking Motives Questionnaire (DMQ- R; Cooper, 1994). A sample of 256 university student drinkers (Mage= 21.3 years) completed the NEO-PI-R and DMQ-R. In bivariate correlations, the two negative reinforcement motives (Coping and Conformity) were positively correlated with Neuroticism and negatively correlated with Extraversion, whereas the two positive reinforcement motives (Enhancement and Social) were positively correlated with Extraversion and negatively correlated with Conscientiousness. Multiple regression analyses revealed that personality domain scores predicted two of the four drinking motives (i.e., the internal drinking motives of Coping and Enhancement), after controlling for the influences of alternative drinking motives. Enhancement Motives were predicted by high Extraversion and low Conscientiousness, and Coping Motives by high Neuroticism. These results provide further validation of Cox and Klinger's (1988; 1990) 2 x 2 (valence [positive vs. negative reinforcement] x source [internal vs. external]) model of drinking motivations, and confirm previous speculations that drinking motives are distinguishable on the basis of higher-order personality domains. Understanding the relations between personality and drinking motives may prove useful in identifying young drinkers whose drinking motivations may portend the development of heavy and/or problem drinking.},
  note = {booktitle inferred},
}

@inproceedings{mcwilliams1999investigatio,
  title = {An Investigation of Dissimulation in a Chronic Pain Sample},
  author = {McWilliams, Lachlan A.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Research aimed at detecting pain patients' dissimulated responses on psychological self-report measures has been conducted under the assumption that a small number of patients may intentionally exaggerate their psychological symptoms in order to receive increased financial compensation (e.g., continued disability benefits). In the present study, a sample (N=85) of chronic pain patients assessed at a multidisciplinary rehabilitation program was utilized to investigate the incidence of various self- presentation styles. Previous assumptions were not supported as scores on the validity scales of the Personality Assessment Inventory (Morey, 1991) were indicative of a high frequency of overly positive self-portrayals and the absence of unrealistically negative self-portrayals. Correlations between the validity scales and subscales of the Multidimensional Pain Inventory indicated significant negative associations between positive self-presentations and pain-related variables such as pain severity and pain-related distress. The implications of these findings for research and clinical practice will be discussed.},
  note = {booktitle inferred},
}

@inproceedings{adamo1999does,
  title = {Does Sex Make You Sick?: Trade-offs Between Immunity and Reproduction in the Cricket, Gryllus integer},
  author = {Adamo, Shelley},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Animals have finite energy budgets. The immunocompetence hypothesis postulates that males will down-regulate their immune systems at the time of sexual maturity and divert this energy into reproduction. This theory is controversial, largely due to the difficulty in testing it in vertebrates. The theory can be better tested in crickets, which have simpler immune systems. I estimated the amount of energy invested in immunity during a male's lifespan by 1) counting the number of circulating immune cells and 2) by measuring the titres of an anti-microbial protein (prophenoloxidase). The ability of the immune system to destroy parasites and kill bacteria was also tested at different ages. There was no evidence for a decline in energy invested in immunity in sexually mature males over their lifespan or relative to females. It is possible that immune system costs have already been minimized, and further reductions in immune capacity would lead to a shortened lifespan and reduced total lifetime fecundity.},
  note = {booktitle inferred},
}

@inproceedings{stanford1999using,
  title = {Using Mouse IQ to Assess Learning and Anxiety Behaviour in Barrelless Mice},
  author = {Stanford, Lianne and Brown, Richard E. and Taylor, Sean and Neumann, Paul E.},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {The barrelless (brl) mouse strain was derived from a naturally occurring mutation observed in ICR mice at the Universite de Lausanne (Switzerland). brl/brl mice show a lack of specific cortical organization known as barrelfields. In control mice, barrelfields are formed by the whisker neuron thalamocortical organization. A high-resolution genetic map of the region around the brl locus revealed that the gene for adenylyl cyclase 1 (Adcyl) was missing in the mutant. Adenylyl cyclase 1 is associated with neuroplasticity in the hippocampus and cerebral cortex (Abdel-Majid et al. 1998. Nat Genet, 19, 289- 91). Using targeted mutagenesis, and Adcyl knockout mouse model was created that performed poorly in some measures of the Morris water maze task (Wu et al., 1995, PNAS, 92, 220-4). To further investigate the role of Adcyl in memory processes, brl/brl and control (brl/- C57BV6J) mice of both sexes were studied using tests that measure locomotion and exploration (open field), anxiety (elevated plus maze), novel object recognition, and spatial learning (Morris Water maze). Differences between genotype and sex in a variety of measures on each test will be reported. This will provide insight into potential behavioural deficits due to the cortical misorganization present in the brVbrl mice. The importance of using multiple tasks to assess cognitive function in mice will also be discussed.},
  note = {booktitle inferred},
}

@inproceedings{brown1999prospective,
  title = {Is Prospective Altruistic Detection an Evolved Solution to the Adaptive Problem of Subtle in Cooperative Ventures?},
  author = {Brown, William M. and Moore, Chris},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Reciprocal altruism in humans may be made possible in part by the existence of information-processing mechanisms for the detection of overt cheating. However, cheating may not always be readily detectable due to the division of labour. Subtle cheating poses a serious problem for the evolution of altruism. This paper argues that subtle cheating may have exerted selective pressures on early hominids to be sensitive to information regarding the genuineness of an altruistic act. In a two experiments, subjects were required to complete Wason selection tasks designed to allow for the detection of altruism. Performance on the altruist-detection tasks was compared to performance on control Wason selection tasks (Experiment 1) and to performance on control and cheater detection tasks (Experiment 2). Participants were significantly better at solving cheater detection and altruist detection versions compared to control versions of the problems and there was no significant difference between altruist and cheater detection. Results are discussed in relation to recent conceptual models for the evolution of altruism. Specifically, it is argued that non-kin altruism may be an evolutionarily stable strategy if altruists can detect one another and form mutually beneficial social support networks.},
  note = {booktitle inferred},
}

@inproceedings{forestell1999role,
  title = {Role of Suppressed Feeding in Manduca sexta in Response to a Bacterial Infection.},
  author = {Forestell, Cathy and Adamo, Shelley},
  booktitle = {25th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1999},
  abstract = {Typically animals suppress their intake of food when sick. Traditionally, this was viewed as a maladaptive response since increased energy is required for an effective immune response. However, there is some evidence to suggest that infection-induced anorexia may aid the host in suppressing bacterial growth. It has been suggested that infected animals suppress their feeding to deprive invading bacteria of iron, an essential element for their survival. In this study, iron levels were manipulated in tobacco homworms infected with the insect pathogen, Serratia marcescens. On day one of the fifth instar, animals were fed either an iron-rich diet, a diet with normal amounts of iron, or an iron-free diet and the effect on the amounts of free and bound iron in the hemolymph was assessed. Six hours later, these animals were injected with an LD50 dose of Serratia marcescens. It is hypothesized that the animals fed the iron-rich diet will show a greater mortality than those fed the normal iron diet, whereas those fed the iron-free diet will show lower mortality than those fed the normal iron diet.},
  note = {booktitle inferred},
}

@inproceedings{bond2000examination,
  title = {An examination of strain differences in nest building in virgin, pregnant and lactating C57BL/6 and DBA/2 mice (Mus Musculus).},
  author = {Bond, Tamara L.Y and Brown, Richard E and Hawken, Christianne and Neumann, Paul E},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {C57BL/6 (B6) and DBA/2 (D2) mice differ in maternal behaviour and nest building. However, the results on nest building have been contradictory. Although lactating B6 females spend more time nest building than lactating D2 females (Brown et al., 1999, Physiol Behav, 67:599-605), pregnant D2 females build better pre-parturient nests (Broida & Svare, 1982, Physiol Behav, 25: 153-157). To resolve this discrepancy, we recorded nest quality in virgin, nulliparous, pregnant and lactating females. Virgin B6 and D2 females were housed with either a male or female of their own strain for fifteen days. Females were then housed singly and their nests rated daily on a scale of one to four. Some of the females of each strain that were housed with males failed to give birth and some litters died before the pups reached four days of age. There were no strain differences in the nest ratings of virgin females or females who did not give birth, nor did these groups differ. Therefore, these two groups were collapsed into one group of nulliparous females. No differences were observed between strains in the proportion of pups surviving per litter or in pup weight gain. B6 and D2 females whose litters survived built better nests than nulliparous females. Among females whose litters survived, B6 females built better nests than D2 females both before and after birth. Although both strains increased their nest building on the day of parturition, there was a strain by day interaction that resulted from a dramatic increase in nest building by D2 mice on the day of parturition. However, the increase in nest building by D2 mice at parturition was not large enough to ameliorate the difference in nest building between the two strains. Mothers of both strains whose litters died built better nests than nulliparous females but nest ratings did not differ between strains. The nest ratings of D2 mothers whose litters died did not differ from those of D2 mothers whose litters survived but B6 mothers whose litters died built poorer nests than B6 mothers whose litters survived. One hypothesis to account for these results is that females of these two strains differ in hormone levels during pregnancy.},
  note = {Poster},
}

@inproceedings{nichols2000executive,
  title = {Executive Function Abilities and Prudence and Altruism in Preschoolers},
  author = {Nichols, Shana and Moore, Chris},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The aim of the current study was to assess the cognitive basis for emerging social behaviour during the preschool period. A comprehensive battery of executive function tasks measuring inhibition, attentional flexibility, and working memory, and a future-oriented prudence and altruism task was administered to 58 preschoolers aged 3;6. Age and language partialled correlations revealed that children who were unable to inhibit copying a puppet's actions, and those who could not refrain from peeking during the wrapping of a present were more likely to choose two stickers for later on a delay of gratification for self task. Children who waited longer before peeking were also more likely to choose one sticker over two for themselves in the present. There was no relationship between performance on any EF task and future-oriented sharing behaviour. Contrary to the predicted outcome, there was a significant negative relationship between performance on both inhibition tasks and children's choice to forego an immediate reward. A hypothesis is put forward regarding the possibility that poor inhibitors were choosing two stickers for different reasons than would be expected. Further longitudinal relationships between the EF variables and performance on the future-oriented prudence and altruism task will be discussed as children were also tested at age 4;0.},
  note = {Poster},
}

@inproceedings{penner2000effects,
  title = {Effects of Chronic Ritalin Administration on Postnatal Mouse Pup Development},
  author = {Penner, Marsha and McFadyen, Melanie},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {Methylphenidate hydrochloride (MPH, Ritalin) is a psychostimulant that is used primarily in children for the treatment of ADHD. Despite having been used for several decades, the consequences of chronic MPH administration has not been well characterized in the developing nervous system. Thus, our experiment investigated the effects of repeated administration of MPH on development using several tests from the Dalhousie Developmental Test Battery including isolation-induced ultrasonic vocalizations (UVs), spontaneous locomotor activity, and several tests of neuromotor development in outbred CD-1 mouse pups. From postnatal days (PNDs) 3 to 11, mice received daily injections (s.c.) of, 1) a high dose of MPH (20mg/kg), 2) a low dose of MPH (5mg/kg), 3) an equivalent amount of saline, or 4) no injection. Mice were tested 30-70 minutes post-injection on PNDs 3, 5, 7, 9, and 11. Both the high and low doses of MPH resulted in significant increases in locomotor activity at all ages tested, but had no significant effect on the number or duration of UVs emitted. Contrary to our expectations, performance on tests of neuromotor development was not clearly affected by either dose of MPH. Furthermore, MPH treatment had no effect on body weight. These results suggest that chronic MPH treatment has no short-term effects on the developing nervous system.},
  note = {Poster},
}

@inproceedings{mccabe2000effect,
  title = {Effect of diazepam on the behaviour of "anxious" C57BL/6 mice in the step-down passive avoidance task},
  author = {McCabe, Sean and Podhorna, Jana and Brown, Richard},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {In humans, anxiety impairs learning and memory in a variety of tasks. C57BU6 mice display higher levels of anxiety than other strains of mice in various models of anxiety such as the elevated plus maze and open field. Moreover, C57BU6 mice show memory impairments in models such as the passive avoidance task that involve a fearful or "emotional" stimulus. Diazepam has been used to treat anxiety in humans, but has been found to possess amnesic properties by impairing the acquisition process. In animals, benzodiazepines administered before learning trials in passive avoidance tasks impair memory retention but not acquisition. The present study examined the effects of diazepam on acquisition and retention of the passive avoidance task in male and female C57BU6 mice. Diazepam or saline was administered to the mice 30 min before the learning trials. Female mice appeared to be more sensitive to the sedative effects of diazepam than males. However, diazepam did not impair acquisition or retention of the passive avoidance task in either sex. These results suggest that diazepam does not produce the amnesic affect in anxious C57BU6 mice that is seen in other strains of mice.},
  note = {Poster},
}

@inproceedings{newman2000event,
  title = {Event Resolution Imaging: Overcoming the limitations of signal averaging in ERP research},
  author = {Newman, Randy Lynn and Connolly, John F. and Arcy, Ryan C.N. D' and Cook, Daniel},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The interpretation of ERPs has typically relied on signal averaging to extract information from background noise (i.e. EEG). A new signal detection method, event-resolution imaging (ERi), has demonstrated the ability to extract information from the EEG with little or no averaging. ERi uses a three-step process of pattern learning, pattern recognition, and validation. During pattern learning, multiple epochs from two distinct conditions are analyzed to detect and subsequently discriminate robust patterns in space (multiple electrode sites), time, frequency, and phase. This information is encoded as a template that is subsequently used to analyze unclassified, unaveraged or few-trial averaged EEG data. We tested the feasibility of ERi by reanalyzing data recorded during performance in a neuropsychological reading test (PALPA; D' Arey, Connolly, Eskes, 1999). Using traditional averaging, correct and incorrect trials in the P ALP A were differentiated on the basis of a P300 response to correct trials. For each epoch analyzed, ERI generated a high signal-to-noise waveform and subsequent classification. Initial results on 5 trial averages indicated an average accuracy level of 72.3%, and results for a single trial analysis indicated an average accuracy of 62.3%. Data of a learning disabled participant, who exhibited no P300 activity in averaged data, were classified with 76% accuracy. Interestingly, for this individual ERi found that 100% of correct trials failed to exhibit correct-trial template features (i.e. no P300) as seen in all healthy individuals. ERi appears to be a powerful tool for use in basic and clinical research.},
  note = {Poster},
}

@inproceedings{eskes2000role,
  title = {The Role of the Frontal Lobes in Implicit Memory},
  author = {Eskes, Gail and Szostak, C. and Stuss, D. T.},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {While the role of the frontal lobes in explicit memory is well supported, the findings for implicit tasks are less conclusive. We investigated the role of the frontal lobes in perceptual and conceptual implicit priming. Three memory tasks were given under both implicit and explicit retrieval instructions using word fragment completion, picture fragment completion and category exemplar generation. Four groups were studied: Left dorsolateral lesions, right dorsolateral lesions, medial lesions (left, right or bilateral), normal controls. Word fragment completion priming was impaired by left dorsolateral lesions, with other priming tests unaffected by any lesion. Explicit performance showed a different pattern, with category exemplar cued recall impaired by all lesions. These findings support the role of the frontal lobes in both implicit and explicit retrieval mechanisms.},
  note = {Poster},
}

@inproceedings{birt2000criminal,
  title = {Criminal Career Profiles as a Function of Psychopathy and Sexual Violence},
  author = {Birt, Angela R. and Porter, Stephen and Woodworth, Mike},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The problem of sexual violence has become increasingly apparent in recent years. In this study, the complete criminal and conditional release performance histories of 217 federally incarcerated sex offenders and 101 non-sex offenders were examined. Offenders were categorized according to the nature of their sexual violence and all offenders were rated on level of psychopathy (PCL-R, Hare, 1991). Results indicated that (a) certain sex offender groups had higher levels of psychopathy than others, (b) psychopathy exacerbated the violent and non-violent crime committed by all offender groups, and (c) Mixed Rapists/ Molesters were the most dangerous as indexed by their psychopathy prevalence, criminal profiles, and conditional release performance. These findings have implications for the management and treatment of sexual violence.},
  note = {Poster},
}

@inproceedings{vieira2000effects,
  title = {Effects of parental experience and the presence of the father on pup growth and development in Peromyscus californicus. Mauro L.},
  author = {Vieira and Brown, Richard E.},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {This experiment investigated the effects of the presence of the father and parental experience on pup development and behavior in California mice. Twenty-seven litters of California mice were used as subjects. Litters housed with single experienced mothers (n=9), experienced fathers and mothers (n=9) and inexperienced fathers and mothers (n=9) were studied. Behaviors of pups were recorded every second day from 10 to 30 days of age. The results indicated that the presence of the father did not influence pup behavioral development and physical growth. Pups of first time parents were more active and had advanced locomotor activity in comparison with pups from experienced parents. It is suggested that the parity of the parents has greater influence on the development and behavior in California mice than the presence of father. Financial support: CAPES (Brazil) and NSERC (Canada).},
  note = {Poster},
}

@inproceedings{large2000coding,
  title = {Coding for orientation in the representation of faces},
  author = {Large, Mary-Ellen and McMullen, Patricia},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {A common debate in face and object recognition literature is whether faces and objects share similar processing and representational systems. Experiment 1 investigated whether patterns of response to faces rotated through multiple orientations were similar to those observed for objects. Participants named digital images of faces presented at multiple orientations over a series of 8 blocks. The findings suggested same effects of orientation on rotated faces and object naming during the first block of presentations. However, unlike objects, effects of orientation required many more blocks to diminish. Experiment 2 investigated the kind of representations underlying these practice effects. Participants repeatedly named faces at two orientations. After training, response times were recorded for faces rotated at the trained orientations and two "surprise" orientations. If, like objects, practice effects transferred to faces presented at "surprise" orientations this would suggest that orientation-invariant representations were encoded. Conversely, no transfer of practice effects would suggest that orientation- specific representations were encoded.},
  note = {Poster},
}

@inproceedings{stapleton2000investigatio,
  title = {An Investigation of Factors Influencing Accuracy at Detecting Deception},
  author = {Stapleton, Jennifer A. and Porter, Stephen},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {Although empirical research has demonstrated that there are reliable verbal and nonverbal cues to deception (e.g., Porter & Yuille, 1996), the ability to detect deceit eludes most people. The purpose of the present study was to investigate possible factors influencing accuracy at detecting deception, including cue usage, personality characteristics, gender, handedness, and confidence. Participants were asked to judge the honesty of eight videotaped speakers relating an account of a personal experience. Half of these tapes were presented audio-visually while the other half were presented with audio only. Participants provided both a baseline report of cues they generally used in detecting deceit and cues they actually relied upon in formulating each judgment. Major findings were that: both target attractiveness and female gender were negatively associated with accuracy; lies were easier to identify than truths; left- handers were better at detecting deceit than right-handers; and the number of overall cues used was positively correlated with accuracy.},
  note = {Poster},
}

@inproceedings{mclaughlin2000subscale,
  title = {Subscale scores on the Child Anxiety Sensitivity Index (CASI) predict unique variance in DSM-IV anxiety symptoms beyond trait anxiety},
  author = {McLaughlin, Elizabeth and Stewart, Sherry and Taylor, Steve},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The CASI is a self-report questionnaire, which surveys children's fear of the physical, social, and psychological consequences of anxiety sensations. Groups of items pertaining to each of these consequences have been empirically shown to form three distinct lower-order factors on the adult version of the scale. Our first goal was to validate this factor structure in the CASI. Secondly, we wanted to determine whether scores on each CASI factor predicted symptoms of anxiety disorder subtypes, after taking out variance due to trait anxiety. The CASI, a measure of DSM-IV anxiety symptoms (Spence Children's Anxiety Scale), and the STAIC were administered to 349 school-aged (7- 15 years) children. Scores on each of the three CASI factors predicted unique variance in conceptually related anxiety symptoms.},
  note = {Poster},
}

@inproceedings{jaskie2000one,
  title = {One or Multiple Mechanisms Underlying Orientation-Invariant Identification of Objects?},
  author = {Jaskie, Karen and McMullen, Patricia},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {What are the mechanisms underlying orientation-invariant identification of objects? We are investigating the conditions under which orientation-invariant identification of objects occurs, and whether one or several mechanisms underlie that process. Orientation-invariant recognition occurs at the superordinate and basic levels of identity, as well as after practice with naming rotated objects. The underlying mechanism(s) might be based upon the extraction of orientation-invariant features, or, upon the global attributes (requiring intact spatial arrangement of the features) of objects. We presented four blocks of feature-scrambled objects followed by a block of intact, rotated objects, in a verification task where level of identity was controlled. If the mechanism is feature-based, superordinate- and basic-level identification of scrambled objects should be faster than subordinate-level. Furthermore, practice at identifying scrambled objects should diminish orientation effects in the final block. A global-based mechanism would not produce these effects.},
  note = {Poster},
}

@inproceedings{forestell2000beauty,
  title = {Is beauty in the eye of the beholder? Restraint, body shape and weight in attractiveness ratings of self and others.},
  author = {Forestell, Catherine A. and Humphrey, Tara M. and Stewart, Sherry H.},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The present study tested the degree to which body-shape characteristics of line drawings influence restrained and nonrestrained eaters' ratings of attractiveness for female figures. Female line drawings (Tassinary & Hensen, 1998, Psychological Science: 9, 150-155), which varied systematically in weight and waist and hip circumference, were used as stimuli. Thirty-two female undergraduate Psychology students (15 nonrestrained and 17 restrained, according to the Restrained Eating Scale; Herman & Polivy, 1980, Obesity. pp 208-225), were asked to rate these stimuli in attractiveness, identify the ideal body figure, and the figure which best represented their own body type. Restrained eaters did not differ from nonrestrained eaters in their ratings of attractiveness nor in their perception of the ideal female figure. However, after controlling for body weight and shape, it was found that restrained eaters did perceive themselves as larger than nonrestrained eaters. Thus it appears that the motivation to diet in restrained eaters may stem from an overestimation of their perceived body size.},
}

@inproceedings{woodworth2000truth,
  title = {Truth, Lies, and Videotape: An Investigation of the Ability of Federal Parole Officers and University Students to Detect Deception},
  author = {Woodworth, Mike and Porter, Steve and Birt, Angela R.},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The ability of a group of Canadian federal parole officers to detect deception was investigated over the course of two days of lie detection training. To isolate factors relating to detection accuracy, three groups of undergraduate participants made judgments on the same 24 videotapes: (1) a feedback group which received feedback on accuracy following each judgment; (2) a feedback+ cue information group which was given feedback and information on empirically-based cues to deception; and (3) a control group which did not receive feedback or cue information. Results indicated that at baseline all groups performed at or below chance levels. However, overall, all experimental groups (including the parole officers) became significantly better at detecting deception than the control group. The results indicate that detecting deceit is difficult but training and feedback can enhance detection skills. Tl 1. Individual differences in the development of face recognition: Support for a maturational change at age eight. Paddy McMullen, Phil Dunham and Fran Dunham Carey & Diamond (1977) suggested that before the age of 8, children recognize a face by its individual features. After this age, a whole-face (holistic) strategy has developed. Boys and girls aged 7 and 11 performed tests of Mooney faces (a test of holistic processing), Embedded figures (a test of feature- based processing) and upright and inverted face recognition. Children aged 7, successfully recognized upright faces but were at chance at the recognition of inverted faces. More importantly, upright face recognition correlated with Embedded figures performance (r= 0.56, p<0.01) and not with Mooney face performance. Children aged 11, recognized upright and inverted faces above change levels. Notably, their results showed the opposite pattern to those of the younger children. Upright face recognition now correlated with Mooney face performance (r= 0.45, p<0.05) and not with Embedded figures performance. The maturational hypothesis of face recognition was tested from an individual differences approach and supported.},
}

@inproceedings{podhorna2000effects,
  title = {The Effects of a Novel Psychoactive Drug Flibanserin on Ultrasonic Vocalizations in Rat Pups},
  author = {Podhorna, Jana and Brown, Richard},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {This study compared the effects of flibanserin, a novel 5-HTlA agonist/5-HT2A antagonist; diazepam, a traditional anxiolytic; and imipramine, a traditional antidepressant, on separation-induced ultrasonic vocalizations (USVs), locomotor behavior, negative geotaxis and body temperature of 7-8-day-old rat pups. Flibanserin (5, 10, 25 and 50 mg kg -1) reduced USVs but had no effects on locomotor behavior or geotaxic response. Low doses of flibanserin (0.5, 1, 2 and 4 mg kg -1) had no effect on any behavior. Diazepam (0.25, 0.5, 1 and 2 mg kg -1) not only reduced the USVs but also increased rolling and increased the latency of the geotaxic response. lmipramine (10, 15, 20 and 30 mg kg-1) reduced USVs, increased total locomotor activity and rolling but had no effect on negative geotaxis. None of the drugs altered body temperature. Our data showed that flibanserin is as effective in reducing the USVs as diazepam and imipramine but has a lower incidence of motor impairment side effects. This suggests that flibanserin might be effective for the treatment of mood disturbances such as anxiety.},
}

@inproceedings{ruyak2000recovery,
  title = {Recovery Sleep Patterns Following Treatment of Patients with Obstructive Sleep Apnea},
  author = {Ruyak, Peggy and Rusak, Ben and Morrison, Debbie},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {The primary purpose of this investigation was to study the effects of continuous positive airway pressure (CPAP) on the patterns of REM sleep and Slow Wave Sleep (SWS) in patients with obstructive sleep apnea (OSA). Analyses of baseline and CPAP treatment data from 38 patients with OSA included sleep stage, CPAP pressure, and number of arousals during the treatment night. The study involved the re- analysis of existing data from patients treated with CPAP on a second night following an initial baseline night of polysomnographic recording. Data were scored to allow for examination of the detailed time course of occurrence of NREM and REM recovery sleep during the treatment night. The results of the experiment will further describe the phenomenon of REM and SWS rebound during the first night of CP AP treatment.},
}

@inproceedings{mcglone2000neurobehavio,
  title = {Neurobehavioural outcomes in men and women undergoing coronary artery bypass surgery with or without cardiopulmonary bypass},
  author = {McGlone, Jeannette and Hirsch, Gregory and Legare, Jean-Francois and Buth, Karen},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {Replacing the clogged arteries feeding the heart is a well-established operation for patients with ischemic heart disease. It is called coronary artery bypass grafting (CABG). The traditional methods of placing the patient on a heart-lung machine during the operation will be compared with a newer technique of operating on the beating heart. This talk reviews the literature and outlines a randomized, prospective, clinical trial comparing the neuropsychological and quality of life outcomes of patients undergoing these two techniques. The aim of this study is to evaluate longer term (six month) psychosocial outcomes. For the first time, the goal is to investigate the outcomes of women compared to men. Students looking for comprehensive projects over the next 3 years, persons interested in critiquing the proposal, and the mildly curious are most welcome. Tl 5.},
}

@inproceedings{butler2000effects,
  title = {Effects of passive limb movement on the Visual Scanning abilities of Neglect subjects in Two Coordinate Spaces},
  author = {Butler.2, Beverly and 1.2, Gail Eskes and 1.2, E. Harrison and 2, & Alison MacDonald and 1, Dalhousie University and Centre, Queen Elizabeth II Health Sciences},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {Hemispatial neglect is a deficit in directing attention/movement toward the contralesional space. Robertson (1995) reported that passive left limb movement did not improve visual scanning in a single case of neglect, and suggested that active limb movement was required. Contrary to this finding, Ladavas et al. (1997) and our own pilot study, showed that passive movement may improve visual scanning in neglect patients in peripersonal space. The present study attempted to replicate and extend these passive movement effects. Neglect subjects (n=6), right-hemisphere damaged non-neglect controls (n=6) and non- brain-damaged controls (n=5) detected visual targets in peripersonal and extrapersonal space under conditions of no movement and passive left limb movement (produced by functional electrical stimulation) in left hemispace. We were unable to replicate the passive movement effects on visual scanning in this group of neglect patients in peripersonal or extrapersonal space. However, the neglect group showed a gradient of decreasing target detection from right to left, which was not evident in either of the control},
  note = {QA: needs-split-review; Split from T14 at: 'Effects of passive limb movement on the '},
}

@inproceedings{practices2000influences,
  title = {The Influences of Child Age and Parent Informant on the Associations Between Parenting},
  author = {Practices and Problems, Child Behaviour},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {This project investigated the influences of child age and parent informant (mother versus father report) on the associations between parenting practices and conduct problem behaviour in a community sample of children aged 5 to 12. Valid sample size for the computed regressions varied from 335 to 339. Parenting practices were assessed using a modified version of the Alabama Parenting Questionnaire (APQ; Frick, 1991). Conduct problems were defined by DSM-IV criteria for Oppositional Defiant Disorder (ODD) and Conduct Disorder (CD), and assessed through the use of the Assessment of Disruptive Symptoms, DSM-IV Version (ADS-IV; Pelham, Gnagy, Greenslade, & Milich, 1992). Both mothers and fathers acted as informants for the two questionnaires. Preliminary analyses suggest that the parenting practices of maternal involvement, poor monitoring and supervision of children's activities, as well as inconsistent discipline, are significantly associated with number of CD and number of ODD symptoms in children. The magnitude of these associations varied according to whether it was the mothers or the fathers who reported the practices. In contrast with previous research in a clinical sample, results did not show a significant child age trend in the associations. This project has significant implications for the parent training component of the psychosocial interventions that are currently used for CD and ODD.},
  note = {QA: needs-split-review; Split from T14-split1 at: 'The Influences of Child Age'},
}

@inproceedings{practices2000influencesa,
  title = {The Influences of Child Age and Parent Informant on the Associations Between Parenting},
  author = {Practices and Problems, Child Behaviour},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {This project investigated the influences of child age and parent informant (mother versus father report) on the associations between parenting practices and conduct problem behaviour in a community sample of children aged 5 to 12. Valid sample size for the computed regressions varied from 335 to 339. Parenting practices were assessed using a modified version of the Alabama Parenting Questionnaire (APQ; Frick, 1991). Conduct problems were defined by DSM-IV criteria for Oppositional Defiant Disorder (ODD) and Conduct Disorder (CD), and assessed through the use of the Assessment of Disruptive Symptoms, DSM-IV Version (ADS-IV; Pelham, Gnagy, Greenslade, & Milich, 1992). Both mothers and fathers acted as informants for the two questionnaires. Preliminary analyses suggest that the parenting practices of maternal involvement, poor monitoring and supervision of children's activities, as well as inconsistent discipline, are significantly associated with number of CD and number of ODD symptoms in children. The magnitude of these associations varied according to whether it was the mothers or the fathers who reported the practices. In contrast with previous research in a clinical sample, results did not show a significant child age trend in the associations. This project has significant implications for the parent training component of the psychosocial interventions that are currently used for CD and ODD. Tl 7.},
}

@inproceedings{newman2000time,
  title = {Time Course of Linguistic Processing as indexed by Event-Related Brain Potentials (ERPs)},
  author = {Newman, Randy Lynn and Connolly, John F.},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {While most theories of visual word recognition agree that access to meaning is meditated by phonology, some theories contend that words can access their meaning directly, without phonological mediation. ERPs, unlike behavioral measures of word recognition, provide an on-line measure of cognitive processing without requiring overt behavioral responses. Indeed, a number of ERP components have been found to be sensitive to orthographic, phonological, and semantic information. The goals of the present study were to disentangle orthographic and semantic processing, and to define phonology's role on route to accessing semantic information. ERPs were recorded to the terminal words of visually presented sentences. Phonological/ orthographic and/or semantic characteristics of terminal words were manipulated in 4 conditions in which: (1) the terminal word was the highest cloze probability ending (e.g. Larry writes with his left hand.) (congruent); (2) the terminal word was orthographically inappropriate, but was phonologically identical to the highest cloze probability ending (e.g. The game was called off when it started to rayne. [rain]) (Pseudofoil); (3) the terminal word was orthographically appropriate, but was semantically incongruent to the sentence context (e.g. The pizza was too hot to sing.[eat]) (incongruent); or (4) the terminal word was orthographically inappropriate and was phonologically distinct from the anticipated highest cloze probability ending (e.g. The teacher wrote the problem on the heet. [board]) (incongruent-nonword). A negative peak was observed in the 250-300 msec range (the N270) in three conditions in which the orthography was unexpected. That is, even if the orthography was corrent, as in the congruent condition, it was orthographically distinct from the highest cloze probability ending for that sentence. A second, left tempro-parietally distributed negative peak in the 350-450 range (the N400), was observed in both congruent conditions. Interestingly, the N400 was absent in the WR condition, suggesting that phonology plays an important role in mediating access to semantic information. Overall, these findings demonstrate the ability of ERPs to measure subtle aspects of linguistic processing.},
  note = {QA: needs-split-review; Split from T16 at: 'Time Course of Linguistic'},
}

@inproceedings{reading2000ryan,
  title = {Ryan C.N. D'Arcy!, John F. Connollyl,2, Frank P. MacMaster2, Robert Vandorpe3, Larry Gates3, Sultan Darvesh4, and Matthias Schrrtidt5 I. Cognitive/Clinical Neuroscience Unit, Department of Psychology, Dalhousie University; 2. Department of Psychiatry, Dalhousie University; 3. Department of Radiology, Dalhousie University; 4. Department of Medicine (Neurology and Geriatric Medicine), Dalhousie University; and 5. Department of Diagnostic Imaging, The Hospital for Sick Children, Toronto},
  author = {Reading, Transcallosal While Matter Activation Revealed by Functional Magnetic Resonance Imaging During},
  booktitle = {26th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2000},
  abstract = {Functional :MRI has been used to demonstrate gray matter activation associated with sensory and cognitive functions. We provide the first evidence of f:MRI activation in ~'.h_i!e_~aJJer(1.5T). This activation was observed in comrrtissural fiber tracts passing through the splenium of the corpus callosum during sentence reading. The time course data from white matter voxels revealed that, like gray matter activation, the responses were time-locked to the stimulus presentation. However, as expected, the white matter peak amplitudes were markedly attenuated relative to the responses in the visual cortex. Reliability of the white matter activation was established by replicating fully the effect in a participant following a six-month interval. The active white matter regions localized the comrrtissural fibers that connect functionally specialized visual word form areas. These findings provide the first noninvasive identification of the neural architecture involved in sentence reading.},
  note = {QA: needs-split-review; Split from T16-split1 at: 'Transcallosal While Matter Activation'},
}

@inproceedings{wang2000investigatio,
