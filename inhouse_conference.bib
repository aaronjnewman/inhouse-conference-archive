  year = {1983},
  abstract = {The effect of simultaneous high frequency stimulation (HFS) delivered to both the perforant path (PP) and the medial septum (MS) on the field potential subsequently evoked by a test stimulus (applied to the PP) or a pair of test stimuli (applied to both MS and PP) recorded from the fascia dentata of six pentobarbital anaesthetized rats was examined. When PP and MS pulses were paired the septal modulation of the population spike without alteration of the EPSP was dramatically enhanced only in the hemisphere in which the MS and PP HFS had been synchronous.},
