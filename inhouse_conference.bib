@inproceedings{lawrence2013bayesa,
  title = {Bayes in brief: philosophy and application},
  author = {Lawrence, Mike},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {While quantitative methods in psychology and neuroscience have traditionally been dominated by the "null hypothesis significance testing" (NHST) philosophy of statistics, recent advances in computing have permitted alternative approaches, most notably Bayesian methods. This talk will briefly distinguish the philosophical backgound of NHST and Bayesian methods followed by a walk-through of a simple Bayesian analysis. The talk will conclude with discussion of the power of Bayesian methods to address more advanced analyses.},
  note = {QA: needs-split-review; Split from T50 at: 'and neuroscience'},
}

@inproceedings{barresi2013why,
  title = {Why psychology and neuroscience separated as sciences},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {For Aristotle psychology was an integral part of the biology of animate beings. But, with the rise of Christianity and its emphasis on Plato’s earlier idea of the immortality of the rational human soul, Western thinkers were ready for Descartes’ revolutionary theory, which distinguished sharply between the conscious rational soul of humans and body-machines. While subsequent thinkers rejected Descartes’ idea that all other animals were mere automata, without conscious minds, the majority of 18th and 19th century scientists continued to distinguish conscious processes of minds and purely material processes of animate bodies, including the brain. A consequence of this historical development has been that psychology and neurobiology have been separate disciplines until quite recently.},
  note = {QA: needs-split-review; Split from T50-split1 at: 'Why psychology and neuroscience separate'},
}

@inproceedings{brown2013how,
  title = {How Donald Hebb brought psychology and neuroscience back together},
  author = {Brown, Richard},
  booktitle = {Psychology and Neuroscience 39th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2013},
  abstract = {In the 1940's, there were many "Schools" of psychology, such as Gestalt Psychology, Structuralism, Functionalism, Behaviourism, etc., each of which looked at behaviour in a different way. There were also a plethora of "physiological" theories of behaviour proposed by Pavlov, Lashley, Morgan, and others. Each theory focused on a different aspect of behaviour: learning, memory, development, motivation, emotion and clinical problems. What Hebb did, with two simple concepts, the modifiable synapse and the cell assembly, was to provide a neural mechanism which could account for all of the different categories of behaviour that psychologists were struggling to explain with their separate theories. The result was to change Psychological theory and reintroduce the idea that a neural mechanism was the basis for all behaviour, normal and abnormal and that one of the aims of Psychology was to understand that physiological mechanism. Hebb's aim was to show that the psychological study of the "mind" required a biological approach.},
  note = {QA: needs-split-review; Split from T50-split1 at: 'How Donald Hebb brought psychology and n'},
}

