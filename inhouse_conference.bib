@inproceedings{white1980dropped,
  title = {Dropped Ducks.},
  author = {White, L. and Ryon, J.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
  abstract = {Vould your newborn off spring benefit from a fal 1 off a ten-storey building? An equivalent drop seems to increase the chance that a newly hatched captive wood duckling (Aix sponsa) will survive. In a pilot study last May we found that the activity of wood ducklings dropped from a height of at least a metre also differed from those gently placed into their brooder. This year we plan to investigate this phenomenon further, under controlled conditions.},
}

@inproceedings{goddard1981biochemical,
  title = {Biochemical Correlates of Kindling-Induced Epilepsy in the Hippocampus: The Role of Calcium Binding Protein (CaBP).},
  author = {Goddard, G. V. and Miller, J. J. and Baimbridge, K. G.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Rats were kindled to full motor convulsions by daily electrical stimulation of the hippocampal commissure. Radioimmunoassay revealed 25-30% reduction of CaBP in hippocampal tissue but not cerebellum or cerebral cortex and no change in calmodulin or total soluble protein. CaBP may regulate cellular discharge during strong synaptic activation.},
}

@inproceedings{grasse1981accessory,
  title = {The Accessory Optic System in the Frog (Rana Pipiens)},
  author = {Grasse, K.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {The anatomy and physiology of the accessory optic system (AOS) has been investigated using single-unit extra-cellular recording and HRP- histochemistry. Units were evaluated electrophysiologically for their direction and speed selectivity. Extremely small HRP injections (½ nanoliter or less) revealed a variety of novel anatomical features of the afferent and efferent organization of this system.},
}

@inproceedings{bower1981approach,
  title = {Approach - Withdrawal Analysis of ~ledian Raphe Stimulation in the Rat.},
  author = {Bower, B. L. and Nakajima, S.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Rewarding stimulation of the median raphe nucleus reduced acceptability of sugar water, reduced aversiveness of a quinine solution, but did not influence the latency to escape from footshock. The results suggest that the nature of rewarding effect produced by raphe stimulation is different from that produced by hypothalamic stimulation.},
}

@inproceedings{brown1981paternal,
  title = {Paternal Behaviour in Male Rats.},
  author = {Brown, R. and Elrick, D.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Adult rats which have never been exposed to infants will either kill or ignore them, but males who have cohabited with a female and her litter during lactation show low levels of pup-care. Paternal behaviour in male rats probably involves two processes: the inhibition of infanticide and the activation of pup-care behaviours. I will discuss data from three experiments which examine the effects of social experience on infanticide and pup-care in male rats. These experiments demonstrate that infanticide can be inhibited by social experiences with lactating females and pups and that male rats will show some paternal behaviour after exposure to rat pups.},
}

@inproceedings{cauller1981circadian,
  title = {Circadian Modulation of Hippocampal Excitability.},
  author = {Cauller, L.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {The magnitude of the granule cell potential evoked by a constant stimulus to the input fibres is greater during the night than the day. This circadian rhythm is evident when the dataare grouped by behavioral/ EEG state and contravaries with the responsiveness of the granule cells to the synaptic input. I am interested in the interaction of this rhythm with long-term potentiation of those synapses.},
}

@inproceedings{j1981perception,
  title = {Perception and Knowledge.},
  author = {J, Barresi},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {A Kantian theory of the relationship between perceiving (e.g. seeing) and understanding (e.g. seeing as) is described and illustrated using examples from 'dot pattern' research.},
}

@inproceedings{fauvel1981neuroetholog,
  title = {A Neuroethological Perspective on the Asymmetry of Gaze.},
  author = {Fauvel, T.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {When a large part of the visual field moves around an animal, a sawtooth-like nystagmus of the eyes results. The strength of nystagmus appears to depend not only on the direction of motion in the field but also on where the field is in visual space. Ethological factors may have guided the evolution of the neural networks which underlie these asymmetries of gaze.},
}

@inproceedings{radel1981ultrastructu,
  title = {Ultrastructure of the Goldfish Retino-tectal Synapse.},
  author = {Radel, J.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Electronmicrographs will be examined in an attempt to characterize (a) degenerating terminals of the optic fibers following enucleation, (b) the post synaptic sites of the primary visual neuron in the tectum, (c) normal presynaptic optic fiber terminals and (d) presynaptic terminals of regenerating optic fibers.},
}

@inproceedings{yoon1981trophic,
  title = {Trophic Interaction Between Neurites of Retinal Tissue and Co-cultured Tectal Tissue of Adult Goldfish In Vitro.},
  author = {Yoon, M. and Baker, F.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {The patterns of neuritic outgrowths from a retinal tissue into its topographically matching tectal tissue (explanted from adult goldfish) were studied in vitro under various experimental conditions. The tectal tissue tendedto attract the retinal neurities to invade it. Within the tectal explant, the retinal neurites seemed to grow selectively towards the appropriate layers of their usual passage and termination in vivo.},
}

@inproceedings{moore1981synapses,
  title = {Synapses in the Fly's Visual System.},
  author = {Moore, D. and Meinertzhagen, I. A.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {The nwnber of functionally appropriate synapses formed by a nerve cell is rarely defined. For identified photoreceptors of the fly, we provide evidence of the number of synapses, their constancy per cell, and their correlation with the area of presynaptic membrane (so providing constant membrane area per synapse).},
}

@inproceedings{rodger1981classificati,
  title = {A Classification and Comparison of Multiple Comparison Methods},
  author = {Rodger, R. S.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Methods for evaluating multiple comparisons and multiple contrasts can be classified in a two-by-two table. One factor is whether the methods use decision-based error-rates or experiment-wise error-rates. The other factor is whether the comparisons or contrasts to be evaluated were planned (independently of the data used to evaluate them) or were selected post-hoc. The techniques t, Dunnett, Bonferroni, Duncan, Rodger, Scheffe, Tukey and Newman-Keuls fit neatly into this scheme. The factor identifications therefore provide a basis for choosing which method to use. It is relatively easy to depict graphically the increase in "harshness" of the methods as the number of groups (J) increases. for the popular value a= .OS, Scheffe's method becomes excessively harsh with increasing J while Tukey's half-versus-half is worse. Rodger's and Tukey's (comparisons only) increase their harshness moderately while Bonferroni's inequality (for J-1 contrasts), Dunnett's procedure and the Newman-Keuls method (on the average) are somewhat more generous. Duncan's procedure is the most generous of the post-hoc methods and Student's tis, of course, the most generous of all the methods. These facts are also relevant to a choice of methods. Finally, the various methods have limitations (to be illustrated) in what they can do and these also need to be taken into account when a method for analysis is selected.},
}

@inproceedings{lynch1981students,
  title = {Students' Opinions of Class Evaluations.},
  author = {Lynch, P. and Clark, J. W.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {The present study was conducted to measure the relationship between students' attitµdes of class evaluations and the overall rating of the quality of a class. An opinion questionnaire was given to students enrolled in three, second-level psychology classes. The findings were that: (1) the overall opinion of the three classes did not systematically vary with sex of student, sex of professor, majors or non-majors, or with year of study; (2) there is no evidence to suggest that the ratings of classes did not reflect in large measure the value of the classes-},
}

@inproceedings{henken1981dnasynthesis,
  title = {DNASynthesis in the Goldfish Optic Tectal Explant.},
  author = {Henken, D. B.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {An in vitro examination of the time course of cell proliferation in the periepen'aymal strata of the optic tectum will be carried out. A pulse-chase labelling technique using 3H-thymidine will be employed to label newly synthesized DNAin dividing radial glial cells.},
}

@inproceedings{bennett1981parental,
  title = {Parental Behavior of Virgin Hand-Reared Timber Wolves (Canis lupus) on First Exposure to Young Pups.},
  author = {Bennett, N. and Havkin, Z. and Ryon, J.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Two female and one male four-year old virgin hand-reared timber wolves were individually introduced to a group of three pups between 48 and 52 days of age. The first regurgitation to the pups by each adult occurred within 3, S, and 27 minutes, and all adults showed a wide range of parental behaviors within an hour. Although wolves are known to adopt alien young readily, the speed with which parental behavior was elicited from these adults, in addition to their complete lack of experience with pups or parents, makes these observations particularly striking. Indiscriminate attraction to pups is probably related to communal pup rearing in wolf packs.},
}

@inproceedings{kaye1981loss,
  title = {Loss of Binocular Depth Perception After Lesions of Cat Visual Cortex.},
  author = {Kaye, M. and Mitchell, D. and Cynader, M.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Three normal adult cats distinguished depth separations, equivalent to 4 minutes disparity, binocularly but not monocularly. Subsequent complete ablation of cortical areas 17 and 18 largely spared visual behaviour and acuity, but made even binocular depth discrimination substantially worse than pre-operative monocular discrimination. Visual cortex ablation selectively impairs depth perception.},
}

@inproceedings{flynn1981differential,
  title = {Differential Outcome Effects in a Delayed Conditional Discrimination.},
  author = {Flynn, M. and Dodd, P. and Honig, W. K.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Each trial began with red or green on the pigeon's key. This was followed by a retention interval (RI) when the key was dark. The test stimulus, a vertical or a horizontal line on the key, was presented next. On positive trials, the pigeon received food or water for pecking at the test stimulus. Negative trials ended with a blackout. Only sequences of red-vertical and green-horizontal were positive. For two birds the reinforced outcomes were differential, as all positive trials beginning with one color ended with grain, and all positive trials beginning with the other color ended with water. For two birds, these outcomes were non-differential, as food and water were randomly assigned to trials beginning with either color. One short (1-sec) and one longer retention interval were presented in each session. The longer interval increased in the course of training. Performance at the 1-sec RI was similar for the two conditions; however, at the longer RI's, retention was better with the differential outcomes. This confirms recent research by Peterson and his associates who used a different form of delayed conditional matching. In their work, the proportion of non-reinforced trials depended on the subject's accuracy, while in the present study half the trials ended in blackout. Both studies indicate that different reward expectancies enhance the short-term retention of the initial stimulus.},
}

@inproceedings{meinertzhagen1981synaptic,
  title = {Synaptic Connections of the Dragonfly Interneurons.},
  author = {Meinertzhagen, I. A. and Arnett-Kibel, C. J.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {The synaptic connections of five classes of second-order interneuron of the visual system of the dragonfly Sympetrum have been analyzed from serial electronmicroscopy. Each is different; three are monochromatic while two have unique spectral and dichroic inputs.},
}

@inproceedings{hansen1981validity,
  title = {Validity of Signal Locus Predictor and Relative Likelihood of Signal: When What You See Is Not What You Get.},
  author = {Hansen, E. and Klein, R.},
  booktitle = {Seventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1981},
  abstract = {Current work in our lab investigates effects of movement of attention in visual space (in the absence of eye movements) on subjects' detection of stimulus changes, using a reaction time cost-benefit paradigm. The experiments and preliminary data to be presented attempt to explain the absence of priming effects in low-probability stimulus-response sets. Two interpretations are possible: (1) attention is directed to stimulus attributes other than locus in a dual-stimulus situation; (2) attentional segregation occurs between response systems in a dual-response situation.},
}

@inproceedings{brown1982development,
  title = {The Development of Odour Preferences in 18 to 20 Day Old Rats.},
  author = {Brown, R.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Rats were reared with their mother alone, their mother and father together or 12 hrs per day with their mothers and 12 hrs per day with their ·.~ fathers separately. When tested for odour preferences with a set of "female odours" [own mother (OM), alien mother (AM), non-lactating female (NLF), and no-odour control (NOC)], both males and females showed the preference scale OM>AM>NFL>NOC, regardless of rearing condition. When tested with a set of , , •.,"male" odours (own father, alien father, non-father male, and a no-odour con- trol), male odours were preferred to the no-odour control, but no male odour was preferred to another male odour. These results indicate that the odour of the lactating female is preferred to other odours which rats experience during the same period. These results also suggest that infant rats are able to discriminate between their own mother's odour and that of another lactating female.},
}

@inproceedings{mitchell1982short,
  title = {Short-term Effects on Visual Acuity of Surgically Induced Strabismum in Kittens.},
  author = {Mitchell, D. and Ruck, M. and Kaye, M.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {In order to throw more light on the origin of strabismic amblyopia, frequent measurements were made of the visual acuity of each eye of young kittens following imposition of either a surgically-induced esotropia or exotropia. Whereas-the immediate effects of the surgery were quite substantial in the case of kittens rendered esotropic (cross-eyed), the effects on the exotropic kittens were slight and quite transitory. These differences in the immediate effect of surgery may provide a partial explanation for the vast differences in the degree of amblyopia exhibited eventually by the two groups of strabismic kittens.},
}

@inproceedings{mendelson1982directional,
  title = {Directional Selectivity in the Cat Primary Auditory Cortex.},
  author = {Mendelson, J.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Extracellular responses to frequency modulated sweeps were examined in the cat primary auditory cortex. The stimuli presented were; 1) in-phase binaural sweeps, 2) anti-phase binaural sweeps, and 3) monaural sweeps (in both directions) to the contralateral only and to the ipsilateral ear only. Cellular responses were used to initially group cells as EE or EI. Cells were then classified according to the preferred direction of the sweep. Preliminary results showed that of the EE cells, 43% preferred up sweeps in both ears, 14% preferred down sweeps in both ears, and 43% exhibited no directional preference. Of the EI cells, 50% preferred an up sweep to the contralateral ear and a down sweep to the ipsilateral ear, 33% preferred a down sweep to the contralateral ear and an up sweep to the ipsilateral ear, and 18% exhibited no directional preference. The results imply the EE cells may be involved in localizing sounds which are presented along the vertical axis while EI cells may be used for local- izing sounds along the azimuthal axis.},
}

@inproceedings{fairless1982context,
  title = {Context Effects in the Approach-Withdrawal Behavior of Pigeons.},
  author = {Fairless, J.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {When an illuminated key is presented repeatedly in some relation to food, the keylight eventually gains considerable control over the behavior of hungry pigeons. The form of this aquired responding is dependent on the relative rate of reinforcement during and in the absence of key illumination. Approach to the keylight develops when its presentation is associated with a food rate greater than that associated with the overall situation, while withdrawal from the keylight develops when its associated food rate is less than that otherwise available. Current research in our lab indicates that traditional characterizations of the learning which underlies this behavior may be too narrow. Our data suggest that approach-withdrawal behavior re- flects a primitive decision making process in which reinforcement rates associated with various stimuli are compared prior to the production of a response.},
}

@inproceedings{honig1982retention,
  title = {Retention Interval Duration as a Discriminative Cue for Pigeons.},
  author = {Honig, W.K. and Dodd, P.W.D.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Responding to a vertical line on the pigeon's key yielded reinforce- ment if that line followed a 2-sec retention interval (RI), while horizontal was correct following a 10-sec RI. In both cases a white light marked the onset of the RI. Pigeons learned this discrimination. When the white light was replaced by red and green, correlated with RI duration, it was found that the new initial colors acquired little stimulus control. Thus, duration of the RI can serve as a salient cue which can block or overshadow control by more traditional visual cues.},
}

@inproceedings{mcleod1982vocalization,
  title = {Vocalizations of the Pilot Whale (Globicephala melaena).},
  author = {McLeod, P.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Vocalizations produced by wild pilot whales were recorded in the inshore waters of Newfoundland. Sounds were categorized on the basis of acous- tic properties and temporal associations to create a catalog of the species vocal repertoire. One sample of 43 minutes duration (1408 phonations) was used to look for sequential patterning of sounds. Underwater broadcasts of sounds to pilot whales were conducted. No consistent reaction to broadcasts was found. A comparison of the vocalizations recorded from different pods showed considerable differences in the sounds produced. The importance of measuring variability and the possible sources of variance in the vocalizations of social delphinids are discussed.},
}

@inproceedings{grasse1982self,
  title = {Self-Motion, Gibsonian Flow-Fields, and the Accessory Optic System.},
  author = {Grasse, K.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  note = {QA: no-abstract},
}

@inproceedings{shaw1982novel,
  title = {Novel, Inhibitory, Adaptive Control of Photoreceptor Output.},
  author = {Shaw, S . R.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {A main function of the first synapse in the visual pathway is to match the systgm operating range to the ambient lighting level, which can vary enormously,>10 . In insects, the main control point is the photoreceptor terminal itself, and control is exercised by novel mechanisms of presynaptic lateral- and self-inhibition. Our results using intracellular recording and EMmapping techniques suggest that the several processes of one particular cell must be acting independently of one another. If this is confirmed, it will provide the first clear evidence contradicting the century old 'Neurone Doctrine' of Cajal.},
}

@inproceedings{klein1982hemispheric,
  title = {Hemispheric Asymmetries in Global and Local Processing.},
  author = {Klein, R. and Kelbrat, T.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Navan has proposed that the extraction of global information in a visual stimulus precedes and directs the extraction of local features. Our reading of the recent global/local literature suggests instead the parallel operation of two isolable subsystems. The purpose of our experiment was to test the twin hypotheses that the left hemisphere is the local processing system and the right hemisphere is the global processing system.},
}

@inproceedings{clarke1982tooling,
  title = {Tooling UpFor Clinical Auditory Neurophysiology.},
  author = {Clarke, D.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Clinical research has been underway for several years now in labs around the world using multiple channel electrical stimulation of the auditory nerve ("cochlear implants") as a means of alleviating inner ear deafness (a problem afflicting some 200,000 North Americans). Research in this lab, using the domestic cat, will continue the auditory nervous system single unit studies which have made a major contribution to this advance. The requisite lab facilities are almost all in place with special attention having been given to stimulus presentation. With the aid of specialists in acoustics, sound de- livery and measurement systems have been designed that are hoped to make an innovative contribution to the field.},
}

@inproceedings{meinertzhagen1982spectrally,
  title = {Spectrally Encoded Pathways in the Dragonfly Visual System.},
  author = {Meinertzhagen, I.A. and Menzel, R. and Kahle, G.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Much circumstantial evidence suggests that dragonflies have highly developed colour vision, different species having different wavelength sen- sitivities. Intracellular recordings followed by injections of the dye lucifer yellow enabled the localisation of receptors with identified spectral sensitivity within one species, Syrnpetrum rubicundulurn. Combined with receptor correctivity analyses (Meinertzhagen and Annett-Kibel) the results suggest that broad band green-sensitive receptors provide the predominant input to two visual interneurons, while orange-, UV- and violet-sensitive receptors provide selective inputs to two other interneurons.},
}

@inproceedings{fantie1982septa,
  title = {Septa! Modulation and Long-Term Potentiation in the Hippocampus: A Neuronal Model of "Physiological Context"?},
  author = {Fantie, B.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Stimulating the entorhinal cortex produced a monosynaptic evoked potential in the ipsilateral hippocampus. High frequency stimulation causes long periods of marked increase in response to a test stimulus (Long Term Poten- tiation, LTP). Pairing entorhinal and septa! stimulation augments. the population spike component of this evoked potential. Stimultaneous high frequency stim- ulation of entorhinal cortex and septum enhances LTP and septa! augmentation only in the hemisphere in which septa! and entorhinal stimulation were synch- ronous.},
}

@inproceedings{earle1982analgesia,
  title = {Analgesia and Preference for Signalled Versus Unsignalled Shock.},
  author = {Earle, J.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Rats will spend more time in the half of a shuttlebox in which shocks are always predicted by a tone than on the other side, where shock is unsignalled. One account says that signals that predict shock acquire the capacity to elicit analgesia and attenuate the aversiveness of shock. Therefore the rat prefers the side on which the shocks hurt less. We have shown that analgesia is elicited by a signal for shock. In rats which receive a tone randomly with respect to shock neither prefer- ence nor analgesia results. The analgesia in the paired groups was found to be unaffected by in- jections of opiate antagonists, suggesting that the mechanism underlying the analgesia was not endorphinergic.},
}

@inproceedings{kaye1982consequences,
  title = {Consequences for Binocular Depth Perception of Neonatal and Adult Lesions of Cat Visual Cortex.},
  author = {Kaye, M. and Mitchell, D. and Cynader, M.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {We have shown previously that removal of cortical areas 17 and 18 in adult cats produces a moderate reduction in visual acuity and severe def- icits in depth perception, apparently including a loss of stereopsis. We re- port here that removal of these areas during the first month of life per- mits development of normal acuity and monocular depth discrimination, but the total absence of binocular advantage suggests a selective elimination of stereosis.},
}

@inproceedings{rusak1982physiology,
  title = {Physiology of Visual Projections Influencing Circadian Rhythm Entrainment.},
  author = {Rusak, B.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {I have previously used behavioural, lesion and stimulation techniques to study the neural mechanisms regulating mammalian circadian rhythms. I am now beginning neurophysiological studies of the visual pathways that may be invoJved in rhvthm entrainment. I will describe my preliminary attempts to record in visu~l structures related to the circadian system and my plans for future work.},
}

@inproceedings{cynader1982interhemisph,
  title = {Interhemispheric Communication and Postnatal Development.},
  author = {Cynader, M. and Lepore, F. and Guillemot, J.P.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {The corpus callosum is a bidirectional pathway interconnecting the two cortical hemispheres. We have been able to influence the functional effectiveness of the part of the callosal pathway dealing with the visual cortex by allowing animals restricted visual exposure. We have arranged the right hemisphere to receive information only via a pathway through the left hemisphere throughout postnatal development. This results in a change in the functional capabilities of the corpus callosum so that it becomes a one-way pathway rather than a two-way path.},
}

@inproceedings{fantie1982effect,
  title = {The Effect of Constant Light on Sexual Behaviour of Virgin Male Rats.},
  author = {Fantie, B.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {After 6 months of exposure to constant light (LL) only 2 of 16 male rats ejaculated during their initial exposure to a receptive, soliciting female compared with 16 of the 18 maintained on a light/dark (12:12) schedule. Six of the LL rats were then switched to a LD schedule for 5 weeks while the remaining 6 were kept on LL. When tested again, 4 LD and 1 LL rat ejaculated.},
}

@inproceedings{minor1982escape,
  title = {Escape Deficits Following Inescapable Shock in the Rat: The Role of Odor and a Submissive Action Pattern Hypothesis.},
  author = {Minor, T. and LoLordo, V.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Rats were exposed to escapable, inescapable, or no electric shock in small wheel-turn chambers containing odors of previously shocked rats. All rats were tested for the acquisition of lever-press escape 24 hr later in the presence of a novel odor, or the odor of previously shocked rats. The characteristic deficit in escape performance for inescapably shocked rats was absent when testing occurred in the presence of the novel odor. These data suggest that learned helplessness is transferred via odors in the rat.},
}

@inproceedings{fentress1982stretching,
  title = {Stretching the Striatum.},
  author = {Fentress, J.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {The striatum is part of the mammalian brain that has long been thought to play an important role in integrated action. In this talk I shall briefly review some findings on striatal development obtained during my sabbatical at The Salk Institute, and offer some suggestions about how the role of the striatum might be assayed at several levels of behavioral expression.},
}

@inproceedings{warner1982maximizing,
  title = {Maximizing, Therapeutic Benefits and Minimizing Professional Involvement.},
  author = {Warner, A.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {The number of parents seeking assistance and guidance in coping with their children's behavior developments and problems is much greater than the number of mental health professionals available to work with them. One solution is the development of videotape programs on child development issues for parents which provide important information and coping strategies. They can reach larger numbers of people with interesting, yet conceptually sound information. The presentation primarily consists of the screening of one such videotape, part one of a three part series on introducing parents to information, methods, and potential problems in toilet training.},
}

@inproceedings{shaw1982postsynaptic,
  title = {Postsynaptic Control of Cortical Plasticity.},
  author = {Shaw, C. and Cynader, M.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Various models of cortical plasticity are divided about the role that the cortical cell actually plays when the brain is altered as a result of unusual visual experience. We set out to examine the role of the postsyn- aptic cell activity in this plasticity process by constantly infusing L-gluta- mate onto the cortex during a plasticity paradign, allowing the other side of the brain to serve as a control. L-glutamate causes uncontrolled firing of cortical cells and breaks down the correlation between environmental in- put and cellular response. Our results indicate that this breakdown of in- put/output correlation prevents environmental modification of the visual cor- tex.},
}

@inproceedings{bryson1982hemispheric,
  title = {Hemispheric Asymmetries for Letters and Their Mirror Images.},
  author = {Bryson, S.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {A series of reaction time studies were conducted to determine how memory for the lateral orientation of letters might be mediated by the human brain. Single letters were presented to each visual field. The letters appeared in both their forward and backward orientations. Right-handed adults used a manual response to distinguish between 1) two letters, 2) upper- and lowercase letters, and 3) letters and numerical characters. In each experiment, forward letters were identified faster than backward ones when they were pre- sented to the right visual field, whereas no forward-backward letter difference was found for the left visual field. The findings are discussed in terms of the idea that memory for the correct orientation of letters is generally lateralized to the left hemisphere.},
}

@inproceedings{hadskis1982signals,
  title = {Signals for Safety and Benzominergic Receptors.},
  author = {Hadskis, K. and Minor, T. and Robertson, H. and LoLordo, V.M.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Diazepam produces muscle relaxation and relief from anxiety by occupy- ing benzodiazepine receptors located throughout the central nervous system. Stimuli predicting safety in an otherwise dangerous situation also produce re- lief and relaxation. To determine whether safety signals exert their influence by releasing an endogenous benzodiazepine, rats were exposed to a situation in which a safety period was either present or absent. Despite large differen- ces in behavior, ulcer,tions, and plasma corticosterone no differences were found for binding of H diazepam.},
}

@inproceedings{radel1982degeneration,
  title = {Degeneration of Optic Nerve Fibers in the Goldfish Tectum.},
  author = {Radel, J.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {I will present a brief account of the ultrastructural changes occurring among the optic fibers within the tecturn at different times following optic nerve crush.},
}

@inproceedings{smith1982attention,
  title = {Attention, Automaticity, and the Cerebral Hemispheres.},
  author = {Smith, L. and Klein, R.},
  booktitle = {Eighth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1982},
  abstract = {Can one hemisphere become skilled at a task, while the other remains a novice? Each hemisphere learns and practices separate attention- demanding tasks, and when performance for both tasks/hemispheres becomes effortless (automatic), the task is changed for one but not the other hemisphere, or each hemisphere is tested on the task learned by the other one. The pattern of performance, compared with the 'whole brain' case, will have relevance to the nature of interhemispheric communication, atten- tional resources, and the mechanism of automaticity.},
}

@inproceedings{klein1983nostrils,
  title = {Nostrils, Hemispheres and Human Performance},
  author = {Klein, R.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {It has recently come to our attention that the distribution of EEG activity over the two hemispheres is tightly linked to the pattern of air flow through the two nostrils (Werntz et al., in press a,b). This was true both when air flow was allowed to vary with the nasal cycle and when subjects were instructed to manually block one nostril and breathe attentively through the other. In our investigation we will seek to determine if human performance on hemisphere specific (verbal and spatial) tasks will be appropriately influenced by which nostril is breathing.},
  note = {booktitle inferred},
}

@inproceedings{shaw1983pupil,
  title = {Pupil Responses in Pupil-Less Eyes ( .G~,~--?)},
  author = {Shaw, S.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {The pupil response (PR) in insect eyes is a rapid, profourid darkening brought about by illumination, supposedly caused by migration of screening pigment granules (SPGs) inside the photoreceptors. Incidental observations revealed surprisingly large changes in optical transmission (>90%), in eye mutants largely lacking pigments (<1% normal). In EM sections, SPGs are largely absent, suggesting that- the conventional explanation for the PR is incorrect. Suggestively, mitochondria congregate distally in certain photoreceptors, with a distribution characteristic of the PR. The pupil pigment, possibly associated with these mitochondria, dissolves away during EM fixation.},
  note = {booktitle inferred},
}

@inproceedings{matsubara1983clustering,
  title = {Clustering of Local Connections Within the Visual Cortex},
  author = {Matsubara, J.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  note = {QA: needs-split-review; booktitle inferred; Split from 10 at: 'J. Matsubara'},
}

@inproceedings{smith1983semantic,
  title = {Semantic Priming},
  author = {Smith, L. and Klein, R.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {The time-course of accessing information from semantic memory was investigated by preceding a target stimulus for a lexical decision (word-nonword) with a prfme word over a range (-40 to +640 msec) of temporal intervals. With respect to target words, the prime word was either semantically related, unrelated or neutral. Three sets of materials were used to vary the type of semantic relation (i.e., categorical, associative, or indirect) between the prime and target. Generally, a related prime facilitated decision times to words, and an unrelated prime inhibited decision times, relative to the neutral condition. The magnitude and time-course of these effects were different for three sets of materials. We take all of these effects to have implications for the nature of the retrieval mechanisms and structure of semantic memory.},
  note = {booktitle inferred},
}

@inproceedings{robertson1983visual,
  title = {Visual Form Perception in Hearing-Impaired Children: Perceptual Deficit £E_ Developiii"ental Lag? J;_,._._-, 14c,v>'},
  author = {Robertson, B. and McNulty, J.A.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {There is evidence to suggest that differences exist between hearing- impaired and normally-hearing children in the perception of visual patterns, particularly on tasks requiring discrete elements to be organized into complete forms. Hearing-impaired adults and children have been compared to normally-hearing subjects on a variety of visual perception tasks, and the hearing-impaired show a hemispheric lateralization preference that differs from the controls': a right hemisphere preference in language processing, ana a bilateralized processing of spatial or nonverbal material. Hearing-impaired children also show a superiority in colour discrimination when compared with normally-hearing children, matched for age. The main research question is to determine if these differences are due to a neurological deficit or a developmental lag. The lag may be a result of delayed lateralization and/or a lack of language experience. The present study uses a cross- sectional design, and nonverbal, coloured materials to investigate the visual perception of patterns in hearing-impaired children, compared with matched, normally-hearing controls.},
  note = {booktitle inferred},
}

@inproceedings{meinertzhagen1983effects,
  title = {The Effects E! Light- and Dark-Rearing Upon Synaptogenesis in Fly Photoreceptors : +(,!>},
  author = {Meinertzhagen, I.A.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {Bees reared in no light demonstrate reduced sensitivity of spectral phototactic behaviour to wavelengths in the green and a reduced lamina component of the ERG; they also have reduced populations of synapses the receptor terminals of one of their pairs of identified green-sensitive photoreceptor (Hertel, ~ 983). In the fly, we have examined the effects of light and dark-rearing upon the adult frequencies of photoreceptor synapses. In Musca, dark-rearing causes a small but consistent increase in synapse frequency, the opposite result to that predicted from Hertel's result in the bee. We are therefore trying to investigate whether this effect is upon the rate of synapse formation or whether upon the rate of subsequent synapse loss, i.e., whether upon the early or late phases of synaptogenesis.},
  note = {booktitle inferred},
}

@inproceedings{briand1983feature,
  title = {., ;', ',, Feature Integration and Attention : .t--v-iA'-( 1-.:},
  author = {Briand, K.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {..,,- !·t,JI'." Recent proposals by Treisman suggest that a critical role of focused attention is the "glueing together" of independently coded or separable dimensions of an object into a unified percept. When use of attention is prevented, dimensions will be combined incorrectly, leading to the perception of "illusory conjunctions"; combinations of dimensions which were not in fact present. An attention priming paradigm previously used in Ray Klein's lab was utilized to study the effects of spatial allocation of attention on the tendency for individuals to make such conjunctions. To this point, it seems that combinations of items which could give rise to illusory conjunctions show different effects of allocation of attention than do items which cannot give rise to such conjunctions.},
  note = {booktitle inferred},
}

@inproceedings{harrington1983early,
  title = {r .Lt.-Y 1 ~,--.·,u, . ,;.,.,_,l,.,1 ;+ Early Weight Gain and Behavioral Responsivity as Predictors of Dietary Obesity in Rats _ t,:/_},
  author = {Harrington, M.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {Female Sprague-Dawley rats were reared in litters of 4, 8, or 20. When animals reached adulthood, each animal's acoustic startle reflex, tail- pinch feeding responses and activity in an open field containing a palatable food were assessed. After completing these behavioral tests, rats were exposed to either palatable foods or a control diet for 59 days, following which all subjects were maintained on the control diet for 66 days. Rats reared in litters of 4 or 20 both gained less weight after exposure to palatable foods than did rats reared in litters of 8. Diet-induced weight gain correlated positively with acoustic startle reflex and with latency to eat in response to tail pinch.},
  note = {booktitle inferred},
}

@inproceedings{kruk1983relationship,
  title = {Relationships Between Performance in Visual Tests and Flying in~ Aircraft Simulation , •.  ~ ✓ L_,.yVr-t,~,,,},
  author = {Kruk, R.},
  booktitle = {Ninth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1983},
  abstract = {The results of laboratory visual tests and performance in flying an aircraft simulator were compared among student pilots, instructor pilots, and fighter pilots. The visual tests included velocity discrimination of an expanding flow pattern, manual training of motion in depth and in the frontal plane, and motion and contract thresholds for a moving square and a static sinewave grating. The simulator tasks included landing in poor visibililty, formation flight, and bombing a target at low level. The results suggest that there exists considerable variability among pilots in ability to see a runway in poor visibility, achieve and maintain position in formation flight, and hit a target from a low level attack and that significant proportions of performance variability in these tasks may be related to individual variations in ability to discriminate flow pattern velocity and manually track visual motion vs. measured by laboratory tests.},
  note = {booktitle inferred},
}

