@inproceedings{brandstatter1991dynamic,
  title = {The dynamic properties of synapses in the fly's lamina In the first optic neuropile, or lamina. beneath the fly's (Musca domestica L.) compound eye photoreceptor terminals (Rl-R6) and intemeurons are reciprocally connected. At each afferent synaptic sites a presynaptic ribbon in R-R6 abuts a postsynaptic tetrad containing processes of two monopolar cells, Ll & L2. L2 in tum provides feedback input to Rl- R6 at a synaptic dyad. We have examined both afferent and feedback synapses, in each case following the loss of their main target cells. When R 1-R6 degenerated by photoablation, presynaptic ribbons of feedback synapses separated from teh presynaptic membrane and soon appeared free floating in L2's cytoplasm. Despite the presence of floating ribbons the number of L2 synapses increased twofold during an overlapping period of reactive synaptogenesis. When L1 and U degenerated by lesioning, presynaptic ribbons of afferent synapses were only mod~tely affected with slight decreases in their frequency. Thus many presynaptic ribbons in Rl-R6 outlive their postsynaptic partners. This difference in the reaction of photoreceptor and monopolar cells following the loss of postsynaptic partners, reflects a greater dependence of monopolar cells upon their targets, Rl-R6, than of Rl-R6 upon their targets, L2 and Ll.},
  author = {Brandstatter, J.H. and Seyan, H.S. and Meinertzhagen, I.A.},
