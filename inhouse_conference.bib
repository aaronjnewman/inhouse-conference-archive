@inproceedings{bolivar1991secret,
  title = {The secret to creating life Do humans equate spontaneous movement with being alive and having internal states? Do children think the same way as adults on these issues? Recently, researchers have been grappling with the effects of movement patterns on animacy and intentionality attributions. Unfortunately, most of these researchers have used objects familiar to the subject and hence they are subject to biases associated with previous experience. In the present study, we examine the role of endogenous movement in the attribution of animacy, motivation and internal states to unfamiliar objects. Subjects in grades 1, 4 and 7 and university were asked to respond to the following statement "Tell me a story about what you have just seen", after viewing a computer generated display consisting of two circular stimuli exhibiting three types of movement Results indicate that age, gender, as well as movement patterns all contribute to differences in these attributions.},
  author = {Bolivar, Valerie and Barresi, John},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  note = {QA: needs-split-review; Split from 34-split1 at: 'Valerie Bolivar'},
}

@inproceedings{farrell1991effect,
  title = {The effect of regional compactness upon region discrimination time is modulated by oculomotor programming Podgomy & Shepard (1983) demonstrated that reaction time to determine if a target is on or off an attended region decreased with increasing compacbless of that region. Six experiments explored the nature of this compacbless effect and its relationship to visual attention. Subjects viewed a 3 x 3 grid in which there were shaded and unshaded regions. In four experiments their task was to determine a) if a target letter appearing in the shaded or unshaded region was a Tor L, orb) if a target stimulus was presented in the shaded or unshaded region. Eye position monitoring was used to ensure that subjects were not shifting gaze to inspect the display. The compacbless effect was not obtained in any of these experiments. In two further experiments eye position monitoring was NOT employed and the pattern reported by Podgomy & Shepard • a negative correlation between RT and compacbless • was observed. The RT/compactness relationship discovered by Podgomy & Shepard appears to be mediated by the programming of the oculomotor system and does not reflect the distribution of endogenously conttolled attention.},
  author = {Farrell, Mark and Klein, Raymond M.},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  note = {QA: needs-split-review; Split from 34-split1 at: 'Mark Farrell'},
}

