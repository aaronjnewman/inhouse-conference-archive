@inproceedings{re2017brain,
  title = {A Brain Museum Tour of Europe},
  author = {RE, Brown},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Europe has a rich history of neuroscience research and clinical neurology, but where can the history of European neuroscience be found? The historical artifacts, documents and discoveries of European neuroscience exist in many museums, but these are often forgotten or neglected within Europe and relatively unknown outside of Europe. The purpose of this project is to present a tour of the brain museums of Europe on a WEBSITE, showing the museums with materials relevant to the history of neuroscience in each country. The history of neuroscience relies of objects from the past and this website describes the collections related to brain research in European museums. Using this website will enable students and researchers to locate historical objects in museums and plan visits to these museums for teaching and research. The presentation will consist of a poster/oral presentation and a website which meeting participants can browse for information. The present poster/Website contains information on 31 brain museums in 18 countries, with more being added as we find them. The website is a work in progress and we hope that users will provide us with information about brain museums which we have not yet discovered. If you are planning a trip to one of the European cities with a brain museum, this website will guide you to the location and the exhibitions on view. Enjoy your tour of Brain Museums in Europe! This project is sponsored by the FENS History of Neuroscience Committee. If you know of brain museums not presented on this poster, please contact Richard Brown at rebrown@dal.ca.},
  note = {Poster},
}

@inproceedings{e2017does,
  title = {Does active sharing lead to increased positive affect in children?},
  author = {E, Puddicombe and T, Pratt and J, Longard and C, Moore},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Although accumulating evidence suggests sharing can lead to increased positive affect in adults and children, it remains unclear whether children must be active participants in the sharing, or if they might show the same affective benefits when observing sharing. The current study investigated whether active sharing has an additional affective benefit above and beyond passively observing sharing or passively receiving rewards. Participants included 63 typically-developing 5- and 6-year-olds. We used a between-subjects yoked design to match participants across the three experimental conditions to control the number of stickers children received across 10 trials of a resource- allocation task. Two independent coders rated children's videotaped facial affect. We found children in the active sharing condition showed significantly higher positive affect than those in the passive sharing condition, and children in the passive sharing condition showed significantly higher positive affect than those in the passive receiving condition. Interestingly, children did not display more positive affect on sharing as opposed to no sharing trials. Another factor, such as active choice, may account for the affective benefit in this context.},
  note = {Poster},
}

@inproceedings{g2017ehealth,
  title = {eHealth intervention recruitment: Relative success of digital, media, and traditional recruitment methods for Better Nights, Better Days},
  author = {G, Rigney and CT, Chambers and R, Godbout and R, Gruber and W, Hall and G, Reid and R, Stremler and SK, Weiss and M, Witmans and EA, Begum and P, Corkum},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Introduction Approximately 25% of children experience insomnia, which can impact their physical and psychosocial health, as well as their caregiver's well-being. Few children receive evidence-based interventions, due in part to a shortage of available resources. Internet service delivery (eHealth) has the potential to be a powerful tool to overcome barriers to treatment. To this end, we developed Better Nights, Better Days (BNBD) - an innovative eHealth program for primary caregivers aiming to provide accessible and evidence-based care for insomnia in typically developing children aged 1-10 years. We were interested in the uptake for this intervention delivery method. Methods A randomized controlled trial (RCT) is being conducted to evaluate the efficacy of BNBD, targeting 400 English speaking primary caregivers across Canada. As BNBD is an eHealth intervention, the recruitment strategy was primarily based on online tools. A comprehensive social media campaign was developed and executed in collaboration with social media experts. As part of the online screening questionnaire, individuals were asked to indicate how they heard about the study (e.g., advertisement, Facebook, family member or friend). The success of recruitment was measured based on participant engagement and report. Results The BNBD RCT launched September 2016. Within three months over 2,000 individuals entered the study database to begin screening, and the target number of 400 English speaking primary caregivers had consented, with their study participation currently ongoing. Results from the online screening questionnaire indicated 36% heard about BNBD through social media platforms (i.e., Facebook and Twitter), 26% through media and advertisements, and 25% from a family member or friend. Conclusion The high rate of recruitment speaks to both the need for intervention, and the effectiveness of online recruitment methods. Connecting to millennial parents requires the use of online resources, particularly social media. This strategy increases study visibility through a dynamic online presence.},
  note = {Poster},
}

@inproceedings{c2017time,
  title = {On the Time-Course of Cued Temporal Attention},
  author = {C, McCormick and R, Redden and M, Lawrence and R, Klein},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {A fruitful tool for studying endogenous control of temporal attention is the Kingstone paradigm (1992). Kingstone's cues had two functions: providing information about the foreperiod and signalling to begin timing of that foreperiod. Interested in how exogenous alerting might interact with endogenous alerting we implemented two novel manipulations. First, we separated these two cue functions. Second, borrowing from Lawrence & Klein (2013) we manipulated warning signal intensity: one signal entailed an increase in intensity (I^), which generates alerting exogenously; the other signal entailed a qualitative change with no change in intensity (NO), which would not be expected to generate alerting exogenously. When intensity was manipulated randomly from trial-to-trial, endogenous shifts of attention in time were unexpectedly absent. We hypothesized that participants invested substantial cognitive resources to detect the NO intensity signals and that interfered with their endogenous utilization of the pre-cues. To test this idea, in the second experiment we blocked the manipulation of signal-intensity. Consistent with our hypothesis, the Kingstone pattern was replicated in the I^ condition.},
  note = {Poster},
}

@inproceedings{jt2017novice,
  title = {Novice Inter-Rater Reliability in Spike Sorting: Tetrodes vs. Single Channel Electrodes},
  author = {JT, Shapiro and AC, Korgan and JL, King and NA, Crowder},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Measuring the response properties of individual neurons within the brain remains a fundamental technique in neuroscience. A challenge in analyzing this in vivo electrophysiological data, called spike sorting, involves distinguishing which action potentials arise from the jumbled activity of several simultaneously recorded neurons. Most modern spike sorting software uses semi-automated tools that require a skilled analyst, and thus spike sorting accuracy depends on subjective judgments. Multi-channel electrodes (e.g. tetrodes) have the capacity to yield more data than single-channel electrodes, but it may be more difficult for analysts to learn to spike sort multi-channel data because of the additional complexity. In this study two novice analysts with similar levels of training sorted identical recordings from mouse visual cortex that were acquired with single-channel electrodes or tetrodes to determine whether their accuracy was dependent on the type of data being analyzed. The novice analysts performed similarly with both kinds of electrophysiological data},
  note = {Poster},
}

@inproceedings{e2017assessing,
  title = {Assessing Attention: A tablet-based proof of concept with the Dalhousie Computerized Attention Battery (DalCAB)},
  author = {E, Patrick and L, Cutmore and J, Kroeker and S, Jones and J, Salmon and G, Eskes},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Attention deficits can occur with medical, neurological or psychiatric illnesses and limit a person's independence and quality of life. We developed the Dalhousie Computerized Attention Battery (DalCAB) to measure various aspects of attention and have established the validity and reliability of a desktop version of DalCAB in healthy younger and older adults. In this project we sought to investigate whether performance on a touch-screen tablet version of the DalCAB would generate similar performance patterns compared to a normative data set collected on a desktop computer. One hundred healthy young adults (mean(SD) age = 22(3.7) yrs) participated in two studies. Study one (n=40) examined the optimal position of the 2-response touch buttons on a Surface Pro 4 touchpad screen and Study two (n=60) explored the effect of tablet position and screen size. Performance patterns were analyzed within each study and also compared to normative data from fifty young adults (mean(SD) age = 21.78(2.9) yrs) previously collected on an Apple iMac desktop version with a mouse. Within study analyses of tablet data showed that all expected performance patterns were obtained consistently across both studies, and these patterns were not strongly affected by the location of the response touch buttons, the tablet placement or the screen size. Reaction time (RT) performance patterns from the tablet were similar to the desktop patterns, although RTs on the tablet were slower overall, sometimes resulting in greater differences between task variables. These results indicate the robustness of attention performance patterns, and the DalCAB tablet version is a promising alternative to the desktop version. Thus, this study extends the potential applicability and marketability of the DalCAB to different populations and environments.},
  note = {Poster},
}

@inproceedings{s2017years,
  title = {15 Years of ANT Research: Exploring the evolution of the Attention Network Test},
  author = {S, Arora and R, Klein},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The Attention Network Test (ANT) is a computer-based tool widely used to disassociate and measure three networks of attention: alerting, orienting and executive functioning. Originally developed 15 years ago by Posner and his colleagues (Fan et al., 2002) the ANT has been cited for use in over 500 experiments. The present survey investigates the evolution of the ANT and the ways in which it has been employed and extended. Through the development of a comprehensive database, we are able to explore: the various modifications from original ANT that have been simulated, the applications to which it has been used, and attention network scores across various conditions, groups, and regions.},
  note = {Poster},
}

@inproceedings{ea2017utilization,
  title = {Utilization of Research Electronic Data Capture (REDCap) in a web-based Randomized Controlled Trial},
  author = {EA, Begum and P, Corkum},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Research Electronic Data Capture (REDCap) is a web-based electronic data capture software that allows researchers to build project-specific data collection instruments to manage research data, store data securely, and facilitate data analysis. Its randomization module makes it an idea tool for longitudinal studies and randomized controlled trials (RCTs). This software is currently being utilized in a national RCT, Better Nights, Better Days, coordinated through Corkum LABS. This resource has demonstrated capabilities to facilitate study procedures while maintaining the security of study data, reducing staff time, and incidental costs. Measures are housed in the REDCap platform and administered automatically to participants in a sequential manner throughout the study. Randomization was performed within REDCap. REDCap also provides features to export data in multiple formats (SPSS, Excel, R Statistical Software, SAS, or STATA). The RECap database can be easily modified for future studies.},
  note = {Poster},
}

@inproceedings{sa2017first,
  title = {First-time mothers' attributions for postpartum sexual changes: Associations with sexual and relationship well-being},
  author = {SA, Vannier and K, Adare and NO, Rosen},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The transition to parenthood presents women with notable sexual and relationship challenges. There is considerable research examining physiological predictors of postpartum sexual and relationship well-being, but less is known about psychological factors. Causal attributions for sexual changes may be of particular importance because one specific cause may be difficult to pinpoint given the wide range of postpartum sexual concerns and problems among first-time parents. Attributions can be conceptualized on four dimensions: internal/external (i.e., is the event due to the self or the situation), stable/unstable (i.e., will the event occur again in the future), global/specific (i.e. will the cause of the event affect other situations), and partner responsibility (i.e., is the partner the cause). In the current study 117 first-time mothers completed measures assessing attributions for postpartum sexual changes, sexual satisfaction, functioning, and distress, and relationship satisfaction. Internal, stable, and global attributions were associated with greater sexual distress and lower relationship satisfaction. Partner attributions were associated with lower sexual and relationship satisfaction. These associations remained after controlling for time postpartum, breastfeeding, sexual frequency, and relationship duration. As postpartum sexual changes are common, attributions for these changes may be a valuable target for intervention by clinicians and healthcare professionals.},
}

@inproceedings{j2017pediatric,
  title = {Pediatric Insomnia Treatment in the Context of Obstructive Sleep Apnea: A Usability and Pilot Study},
  author = {J, Isaacs and P, Corkum and R, Godbout and M, Witmans},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {1-5% of children suffer from obstructive sleep apnea (OSA), a disorder marked by upper airway blockage during sleep. Over 50% of children with OSA exhibit insomnia symptoms. Of the children with both OSA and insomnia, 20- 25% still have insomnia after OSA treatment (i.e., CPAP, adenotonsillectomy). Access to treatment for residual insomnia among children previously treated for OSA is limited. Better Nights, Better Days - Obstructive Sleep Apnea (BNBD-OSA), is a parent-directed online intervention for treating residual insomnia following successful OSA treatment. The intervention represents an extension of BNBD, an online program which treats primary childhood insomnia. In order to test the usability and initial success of BNBD-OSA, 10 parents will complete the program and describe their experiences with it. Changes in children's sleep patterns will be directly measured with a sleep diary and actigraphy. BNBD-OSA will allow distance treatment for pediatric insomnia in the context of OSA, significantly reducing the personal and economic costs of childhood sleep disorders.},
}

@inproceedings{brown2017influence,
  title = {The influence of Pavlov on Lashley and Hebb},
  author = {Brown, R.E},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Ivan P. Pavlov was awarded the Nobel Prize for Physiology or Medicine in December, 1904 "in recognition of his work on the physiology of digestion". By this time Pavlov had started to study reflexes and he gave the first definition of the "conditioned reflex" and described how he came to study "psychical reflexes" in his "Madrid speech" (April 1903). In 1906, Pavlov [spelled Pawlow] gave the Huxley Lecture, entitled "The scientific investigation of the psychical faculties or processes in the higher animals" which was published in The Lancet (6 Oct. 1906). The English-speaking world thus became aware of Pavlov's work on conditioned reflexes, and in 1909, Robert M. Yerkes and Sergius Morgulis published a review of Pavlov's research in The Psychological Bulletin entitled "The method of Pawlow in animal psychology". One of the earliest proponents of classical conditioning in the USA was John B. Watson, the founder of "Behaviorism", whose 1915 Presidential Address to the American Psychological Association was entitled "The place of the conditioned reflex in Psychology" (The Psychological Review, March 1916). Watson described his experiments on conditioned motor reflexes using the method of Bechterev, and the research of Karl S. Lashley on conditioned salivary reflexes in humans. Watson conducted his most infamous experiment on "Conditioned emotional reactions" on "little Albert" in 1920. Pavlov visited America in 1923 and 1929 and his Lectures on conditioned reflexes were published in English in 1928. As discussed by Ruiz et al (2003. Spanish J. Psychol. 6, 99-111), Pavlov provided American psychologists with three approaches to the study of brain and behaviour: (1) an objective philosophical approach as opposed to subjective methods such as introspection; and (2) a methodological approach through the use of conditioned reflexes. While these were embraced by Americans, (3) the theoretical approach to the study of higher nervous activity through conditioned reflexes, was not so readily embraced. Although Pavlov's methods of conditioned reflexes influenced the theories of Edwin Guthrie, B.F. Skinner, Clark Hull and Kenneth Spence, Guthrie and Lashley (1930) were critical of Pavlov's theory of neural function. Pavlov did not believe in the American theory of Behaviorism and wrote a scathing reply to these critiques (1932). Meanwhile, Pavlov's student, Boris Babkin moved to Canada where he influenced Donald Hebb. Hebb developed a neurophysiological theory that integrated the ideas of Pavlov and Sherrington on reflexes with the theories of Lashley, Kohler and Tolman into a coherent theory that provided a neural mechanism that explained perception, attention, learning and memory. Hebb considered the neural mechanisms of perceptual integration and came up with a theory that reconciled the two opposing theories of neural function in associative learning: the S-R telephone exchange theory and the field theory of equipotentiality. Hebb developed three ideas to provide a "modern" view of the neural changes underlying cognitive function: (1) the "Hebb synapse" or "Hebb learning rule"; (2) the cell assembly and (3) the phase sequence. The Rescorla - Wagner model (1972) stimulated new behavioural research into classical conditioning while neurobiologists use classical conditioning to study the neural mechanisms of learning and memory in both invertebrates and vertebrates. Today Pavlovian conditioning is used to study the neurobiology of learning and memory at four levels: (1) behavioural; (2) neural systems and circuits; (3) cellular mechanisms of synaptic plasticity; and (4) molecular mechanisms of neural plasticity underlying learning and memory. Of note are Kandel's studies of the cellular and molecular mechanisms of memory in Aplysia; the work of LeDoux, Faneslow and others on the neural circuits of conditioned fear and the work of Thompson on the role of the cerebellum in conditioned motor responses. Pavlovian conditioning is also used to understand abnormal behaviour and to develop clinical methods of behaviour therapy. Thus, much of the history of Psychology and Neuroscience in America has been influenced by the concepts of classical conditioning as developed by Pavlov, criticized by Lashley and incorporated into Hebb's neurophysiological theory.},
}

@inproceedings{k2017impact,
  title = {The impact of fetal and neonatal experience on mammalian brain development and stress responsivity},
  author = {K, Lee and I, Weaver and D, Goguen},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {In humans, experimental and prospective epidemiological research suggests that gestational maternal stress has been shown to produce stable, long-term effects on the physical and psychological development of offspring. Our current research focuses on the role of the transcription factor and chromatin remodeling protein, ATRX, in hippocampal neuron survival in response to psychological stress exposure during the third trimester. Using wild-type and ATRX heterozygous mice, we will examine the effects of psychological gestational stress (PSG) on the quality of maternal care, and on cognitive ability and the expression of anxiety-like behaviors in offspring. Additionally, we will attempt to reverse the effects of PSG by performing rescue experiments either by ATRX overexpression, or by H2AX ubiquitination/histone deacetylase inhibition to promote repair protein recruitment to DNA damage sites in vivo.},
}

@inproceedings{j2017emotion,
  title = {Emotion Regulation in Couples Affected by Female Sexual Interest and Arousal Disorder},
  author = {J, Dubé and NO, Rosen},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Introduction. Female sexual interest/arousal disorder (SIAD) is a sexual dysfunction characterized by absent or significantly reduced sexual interest or arousal, accompanied by significant distress. Women with clinically low sexual desire and arousal have reported more difficulties with emotion regulation than controls; however, whether emotion regulation was associated with women's (and partners') adjustment to the condition has not been assessed. The symptoms of SIAD typically occur in the context of a romantic relationship, meaning that partners are also impacted and will have their own emotional responses to the condition. Therefore, it is essential to take a dyadic approach - which past research has neglected to do - in the study of emotion regulation in SIAD. Aim. The current study aims to investigate how emotion regulation in couples affected by SIAD relates to their relational and sexual wellbeing (e.g., sexual satisfaction, distress, and desire). Methods. Women with SIAD and their partners (N =102) will complete standardized self-report questionnaires assessing emotion regulation, relationship satisfaction, sexual satisfaction, sexual desire, and sexual distress. Data will be analyzed per the Actor-Partner Interdependence model using multilevel modeling. Predicted Results. Individuals with more effective emotion regulation will report greater relationship satisfaction and sexual wellbeing. Further, individuals with more effective emotion regulation will have partners who report greater relational and sexual wellbeing, compared to those with poorer emotion regulation.},
}

@inproceedings{nj2017moderating,
  title = {The Moderating Role of Self-Compassion on the Relation between Alcohol-Involved Sexual Assault and Negative Emotional Outcomes in Undergraduate Men and Women},
  author = {NJ, Strickland and SH, Stewart and I-L, Kehayes and C, Wekerle and C, Moore and Team, Caring Campus},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Approximately 15% of students have experienced alcohol-involved sexual assault (AISA; Elliott et al., 2004). Victim- drinking AISA may result in higher rates of self-blame, and self-compassion (SC; i.e., extending the same kindness and care towards oneself that one would to someone else in a similar situation) may promote resilience by attenuating the association between AISA and negative emotional outcomes. Undergraduates (N = 1,255) completed measures tapping past-term victim-drinking AISA (see Kehayes et al., under review), SC (i.e., Self-Compassion Scale; SCS; Neff, 2003b), anxiety and depression (K-10; Kessler et al., 2002), and self-perceived mental health (Ahmad et al., 2014). It was hypothesized that: AISA would be positively associated with anxiety, depression, and poor self- perceived mental health (H1), high SC would be positively related to mental health, and negatively related to anxiety and depression (H2), and SC would moderate (i.e., buffer) the association between AISA and these negative outcomes (H3). Preliminary results showed that, partially supportive of H1, AISA was related to higher depression (r = .07, p < .05). In addition, consistent with H2, high SC was associated with better mental health (r = .56, p < .05), and lower depression (r = -.61, p < .05) and anxiety (r = -.47, p < .05). In partial support of H3, tests of moderation showed a significant interaction between the self-criticism scale of the SCS and AISA on self-perceived mental health. However, instead of the hypothesized buffering effect, it was found that endorsing the self-criticism subscale of the SCS predicted lower levels of mental health, regardless of whether AISA was experienced, but those who had low levels of self-criticism only had poor mental health if they have experienced AISA. These results suggest that for people who are not already self-critical, experiencing AISA can lead to worse outcomes. Results will be further explored following confirmatory factor analyses of the SCS.},
}

@inproceedings{rv2017behavioural,
  title = {Behavioural, Molecular and Epigenetic consequences of Perinatal Infection throughout Development and into Adulthood.},
  author = {RV, Wheeler and S, Alam and ICG, Weaver and TB, Franklin},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Human studies have indicated a link between perinatal infection (PI) and the development of autism-spectrum disorder (ASD) suggesting an epigenetic etiology. Similarly, mice exposed to PI have an ASD-like phenotype, behaviourally and molecularly. In the current study, we injected pregnant C57/BL6 mice with lipopolysaccharide or polyinosinic:polycytidylic acid to induce a bacterial or viral response, respectively. The offspring were tested during development and at adulthood for social communication and interaction, and repetitive behaviours. Additionally, the expression of several synaptic and regulatory epigenetic genes were analyzed in the brains of offspring at post-natal day zero. PI mice displayed abnormal social behaviours, repetitive behaviours and gene expression compared to control mice. Future directions investigating the potential for PI-induced epigenetic alterations will also be discussed.},
}

@inproceedings{s2017there,
  title = {Is there a relationship between working memory and reading in university students?},
  author = {S, Rehan and L, Rubinfeld and G, Eskes},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {University students with a history of reading difficulties (HRD) experience reading and academic difficulties in the university setting and are in need of support; however, without a diagnosis of a learning disability, they are not eligible for academic accommodations. A critical relationship between working memory and reading has been well- documented and working memory (WM) deficits are common in individuals with reading deficits. We are conducting a study that aims to characterize the reading, attention, WM abilities of HRD undergraduate students and to investigate the effectiveness of core WM training in improving these students' working memory and reading abilities. As a first step, we have explored the relationship between WM and reading in a control group of 23 undergraduate students without a history of reading difficulties (NRD; M(SD) age = 20.7(1.1)). Hierarchical linear regression analyses revealed that verbal working memory performance using the Operation Span was a significant predictor of performance on all measures of word reading (b = .49), non-word reading (b = .59), reading rate (b = .61), and reading comprehension (b = .76). In contrast, visual working memory performance on the Symmetry Span was not a significant predictor of reading performance (ps>.05). Results confirm the relationship between verbal working memory and reading and support our plan to investigating WM training in HRD undergraduate students.},
}

@inproceedings{a2017male,
  title = {Male Experience, Female Investment and Offspring Anxiety Behavior: Where Father's Nature Meets Mother's Nurture},
  author = {A, Korgan},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Detecting past experiences may inform a female about prevailing ecological conditions, in addition to paternally- induced phenotypes that may be disseminated to offspring. We examined whether a male rat's exposure to metabolic stressor (high-fat diet; HFD) influences a female's attraction towards a male, subsequent mother-infant interactions and the development of defensive (emotional) responses in the offspring. Females displayed less interest in males following HFD conditions. Mothers that reared young in larger, semi-naturalistic housing provided more licking and grooming and active arched-back-nursing behavior toward their offspring compared to dams housed in standard housing, although some effects interacted with paternal diet exposure. Paternal diet and maternal rearing environment revealed sex-dependent differences in offspring weight, juvenile social interactions and anxiety-like behavior in adolescence. Additionally, paternal predator experience and maternal housing independently affected variations in crf gene promoter acetylation and crf gene expression in response to an acute stressor in offspring. Our results show for the first time in mammals that male HFD consumption may contribute to stable behavioral variation among females in preference for mates and maternal care, even when the females are not directly exposed to HFD. These results, together with our previous findings, suggest that paternal HFD exposure and maternal rearing conditions can influence maternal behavior and development of defensive responses of offspring.},
}

@inproceedings{v2017perfectionis,
  title = {Perfectionistic Concerns Confer Risk for Anxiety Symptoms: A Meta-Analysis of 11 Longitudinal Studies},
  author = {V, Vidovic and MM, Smith and SB, Sherry and SH, Stewart and DH, Saklofske},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Over 30 years of case reports, theoretical accounts, and empirical research implicate perfectionism in anxiety, yet the extent to which perfectionism predicts longitudinal changes in anxiety remains unclear. To address this, we conducted a meta-analysis of research testing whether socially prescribed perfectionism, concern over mistakes, doubts about actions, self-oriented perfectionism, and personal standards predict change in anxiety, after controlling for baseline anxiety. Our literature search yielded 11 relevant studies for inclusion (N = 3, 144). Meta-analysis, using random- effects models, revealed socially prescribed perfectionism, concern over mistakes, and doubts about actions, but not self-oriented perfectionism or personal standards, displayed small positive relationships with follow-up anxiety, after controlling for baseline anxiety. Thus, our study highlights the unique role of different perfectionism dimensions in psychopathology, and offers novel insight into the pre-morbid personality of individuals particularly prone to symptoms of anxiety.},
}

@inproceedings{hm2017examining,
  title = {Examining Links Between Sexual Savouring and Sexual and Relationship Well-Being},
  author = {HM, Richardson and SA, Vannier and NO, Rosen},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Savouring refers to an individual's active ability to anticipate, focus on, and appreciate positive experiences. Savouring has three components: anticipation (e.g., enjoyment of events before they occur), savouring the moment (e.g., prolonging enjoyment by own effort), and reminiscing (e.g., enjoying looking back on happy times). Savouring has been linked to positive outcomes such as greater life satisfaction, self-esteem, and happiness. There has been no research examining savouring of positive sexual experiences, however, the previous literature linking savouring to general positive outcomes suggests that more savouring may promote greater sexual and relationship well-being. In the current study, 303 participants completed online measures assessing sexual savouring, distress, frequency, functioning, satisfaction, and relationship quality. Sexual anticipation was associated with higher sexual functioning and satisfaction. Sexual savouring of the moment was associated with higher sexual frequency, functioning, and satisfaction, greater relationship quality, and lower sexual distress. Sexual reminiscing was associated with lower male sexual functioning. These results suggest that individuals who anticipate and savour their positive sexual experiences may experience greater overall sexual and relationship well-being.},
}

@inproceedings{kosel2017understandin,
  title = {Understanding the Neural Bases for Social Deficits in Alzheimer's Disease},
  author = {Kosel and F and T, Franklin},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Alzheimer's Disease (AD) is a progressive neurodegenerative disorder characterized by abnormal accumulation of b- amyloid protein in the brain. Due to the widespread nature of the disease, lesions can be seen throughout the brain, causing a variety of deficits. In order to characterize these deficits, a number of mouse models--such as the 5xFAD strain--have been developed; however, most studies have focused on motor behaviour, cognition, or sensory perception, but little consideration has been given to social deficits. Mice--like humans--are highly social animals, and research has linked social isolation and defeat with a number of behavioural, cognitive, and physiological changes. As a result, this study aims to elucidate the impact of neurodegeneration on social behaviours in the 5xFAD mouse strain. In particular, this work examines responses to olfactory social cues, social vs nonsocial preference, social memory, and aggression in male and female 5xFAD transgenic and wild-type control mice at 3, 6, 9, and 12 months of age.},
}

@inproceedings{c2017self,
  title = {Self-Distraction During Exercise in Clients with High (versus Low) Anxiety Sensitivity},
  author = {C, Pridy and M, Watt and SH, Stewart},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Anxiety sensitivity (AS) is fear of sensations experienced during emotional arousal or physical activity. High AS is associated with increased risk of psychopathology (Reiss, 1991). People with high AS are avoid exercise because it induces feared sensations (Smits, et al., 2010). Running has, however, been employed as interoceptive exposure (IE) to enhance efficacy of a brief CBT intervention for high AS (e.g., Watt et al., 2006). Self-distraciton during IE trials may enhance or detract from their effectiveness. Stevinson and Biddle (1998; 1999) outlined a comprehensive model of four exercise-related cognitive styles combining the two dimensions of attentional focus (internal/external) and task relevancy(relevant/irrelevant). The proposed project will develop and validate a 20-item Attention and Distraction during Exercise Questionnaire (ADEQ), tapping the four cognitive styles outlined by Stevinson and Biddle, plus qualities of music used for listening during exercise. We will test predictions that high (vs. low) AS participants will favour a self-distractive, externally-focused task irrelevant cognitive style; that high AS participants will prefer an externally-focused and task irrelevant style when deliberately self-distracting from distressing interoceptive cues or an internally-focused and task-relevant style when catastrophizing about feared exercise-induced sensations; and that an externally-focused and task irrelevant style will moderate the known, direct relationship between AS and exercise avoidance. Baseline data gathered during the proposed study will assist in future efforts to determine whether limiting self-distraction during an exercise-based intervention for high AS can help to maximize treatment benefits.},
}

@inproceedings{h2017investigatin,
  title = {Investigating the neural signature of Inhibition of Return using a multimodal paradigm},
  author = {H, MacNeil and R, Klein and G, d'Entremont},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Inhibition of Return (IOR) is the phenomenon whereby attention is inhibited at locations that have previously been attended to as a mechanism to reduce unnecessary attention. Previous research looking at event-related potentials (ERPs) using electroencephalography (EEG) has suggested that P1 reductions are the electrophysiological markers of IOR. However, recent work has demonstrated that P1 reductions may simply be the result of repetitive sensory stimulation rather than of IOR itself. This suggestion has been examined using multi-modal IOR paradigms to compare P1 components in conditions in which the modality is repeated to conditions in which IOR is generated across modalities. The present study aimed to expand on these findings. It was hypothesized that IOR would be observed across all four conditions of Cue Modality and Cue-Target Onset Asynchronies (CTOA) of either 700 ms or 1000 ms, and that P1 reductions would only be seen in the visual-visual conditions. The results supported the hypothesis that IOR effects would be generated across all four conditions. The effect of Cue Modality on P1 amplitude was insignificant, however it did show a trend suggesting increased P1 cueing effects for the Visual Cues compared to the Tactile Cues. The results of this study lay out the framework to further test this hypothesis in future research using a larger sample size.},
}

@inproceedings{de2017choice,
  title = {On the choice of animal models in neuroscience},
  author = {DE, Mitchell},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {I recently was a member of a panel that reviewed the value of various animal models for study of the neural basis of human amblyopia and its treatment. This talk will summarize our findings as well as our recommendations for future research to provide cohesion across animal models and suggestions for a protocol to guide the steps towards translations of results from animal models to human clinical trials. Our recommendations on the latter may generalize to animal models of other neurological disorders.},
}

@inproceedings{jl2017roles,
  title = {The roles of parvalbumin and somatostatin expressing interneurons in modulating contrast adaptation in mouse primary visual cortex},
  author = {JL, King and AC, Korgan and NA, Crowder},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Contrast adaptation is a visual phenomenon induced by prolonged viewing of a high contrast stimulus, which then decreases the perceived contrast of a subsequently presented stimulus. At the cellular level it has been well established that contrast adaptation causes characteristic shifts in the contrast response functions of primary visual cortex (V1) neurons, but the neural circuitry responsible for this shift is still unclear. Our lab recently demonstrated that when V1 is silenced during adaptation, via optogenetically stimulating GABAergic interneurons, the magnitude of adaptation is attenuated, and the adaptation that does occur is similar to that measured in thalamic inputs. The current work is aimed at building on these findings and untangling the local interneuron circuitry contributing to contrast adaptation in V1. To determine the roles of specific GABAergic interneurons, we partially suppressed V1 during the adaptation period by weakly activity either parvalbumin (Pvalb+) or somatostatin (Sst+) expressing interneurons optogenetically. Our preliminary results suggest that neither Pvalb+ or Sst+ neurons are solely responsible for the shift in neural contrast response functions after adaptation, but the gain control mediated by Pvalb+ interneuron activation has a larger impact on adaptation than Sst+ activation.},
}

@inproceedings{km2017effect,
  title = {The Effect of French Immersion on Native English Processing in the Brain},
  author = {KM, Tagarelli and Z, Lazar-Kurz and AJ, Newman},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {French Immersion programs have been in place across Canada since the 1970s, and they are particularly popular in the Maritimes, where up to 32% of English-language schools have such programs. Beyond developing second language skills, students in French Immersion programs have been shown to outperform their English-only peers in first language and other academic skills. However, we know virtually nothing about how this early and prolonged exposure to a second language influences brain development and processing. The current study uses event-related potentials to examine language processing in individuals who have gone through French Immersion, compared to those who have not.},
}

@inproceedings{e2017exploring,
  title = {Exploring Parent-Reported Perioperative Distress Behaviours in Children with Autism Spectrum Disorder},
  author = {E, Cameron and S, Snow and I, Smith and J, Chorney},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The perioperative experience can be distressing for children. Reports state that between 40% and 50% of typically developing children experience perioperative distress. While perioperative distress has been well outlined in typically developing children, similar observations have not been made in children with autism spectrum disorder (ASD; a heterogeneous neurodevelopmental disorder). This study aimed to report the frequency of, and define distress behaviours in children with ASD. Participants in this study included 45 families of children with ASD undergoing day surgery in the IWK Health Centre. Parents completed the Perioperative-Distress Questionnaire to assess their child's perioperative distress. Ninety percent of children with ASD experienced distress during one-or-more time points throughout the surgical experience. Commonly reported distress behaviours included: disorientation, aggression, and verbal requests to leave. This is the first study to examine the frequency of, and describe perioperative distress in children with ASD. Children with ASD seem to have greater perioperative distress levels compared to typically developing children.},
}

@inproceedings{le2017potential,
  title = {Potential molecular conflict between detoxification and immune defense in Manduca sexta},
  author = {LE, Hall and SA, Adamo},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Like other animals, larval M. sexta lose their appetite after an immune challenge, yet the biological function of this illness-induced anorexia is poorly understood. This research examines the hypothesis that illness-induced anorexia allows the caterpillar M. sexta to shift molecular resources from food detoxification to immune function. Caterpillars that received an immune challenge were more likely to die after ingesting permethrin than that those did not. Conversely, a sublethal dose of permethrin reduced resistance to the Gram negative bacterium S. marcescens. These results suggest that there is a negative interaction between detoxification and immune defense. We used qPCR to test for a potential molecular conflict between detoxification and immune pathways. While expression of immune genes appear unaltered by a combined immune-toxin challenge, expression of certain detoxification genes are lessened in the presence of a combined challenge. These results indicate a potential molecular resource trade-off between immunity and detoxification pathways.},
}

@inproceedings{d2017illness,
  title = {Illness-induced anorexia may help promote immune function by reducing the use of glutathione, a limited resource, by detoxification pathways.},
  author = {D, Miller and L, Hall and S, Adamo},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {In response to an immune challenge, most animals have reduced appetite, a behaviour called 'illness induced anorexia'. Despite the ubiquity of this response, its potential biological function is not well understood. The caterpillar M. sexta shows increased susceptibility to pesticides when the immune system becomes activated. Similarly, sublethal amounts of pesticide increase susceptibility to disease. Recent qPCR data suggests a molecular conflict between the pathways for food detoxification and immune defense, centered on the use and availability of glutathione (GSH). GSH is an antioxidant tripeptide used in both detoxification and immune-response pathways. To test the hypothesis that limitations in the availability of GSH leads to trade-offs between immune function and detoxification, we compared whether supplemental GSH could reduce the increased morbidity and mortality of caterpillars given both an immune and toxic challenge simultaneously. Preliminary data suggest that supplemental GSH can rescue caterpillars exposed to both challenges, suggesting that GSH may drive a tradeoff between the two pathways. Illness-induced anorexia would shift GSH resources toward immune function.},
}

@inproceedings{a2017susceptibili,
  title = {Susceptibility to monocular deprivation following immersion in darkness just prior to the critical period peak},
  author = {A, Lingley and KR, Duffy},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Immersion of animals in complete darkness reveals that the maturation and plastic capacity of visual circuitry depends on binocular visual experience. Recent investigations have shown that imposing 10-days of darkness immersion during juvenile life instates a neurobiological context wherein an animal's susceptibility to subsequent modification of visual experience is augmented. For instance, our previous study showed that immersion of 12-week old cats in complete darkness for 10-days promotes neurobiological changes that render the effects of subsequent monocular deprivation (MD) much more severe than those observed in age-matched controls. This result suggested that darkness immersion promotes an animal's capacity for plasticity, recapitulating a developmental state akin to a much younger animal. The current study sought to explore whether short-term darkness immersion could similarly promote visual plasticity at the peak of the critical period (p30), when an animal's sensitivity to visual perturbation is at its biological maximum. Although 7-days of MD at this age produced potent alterations of neuronal soma size in the dorsal lateral geniculate nucleus (dLGN), 10-days of preceding darkness immersion had no influence on the subsequent MD effect. Similarly, MD imposed following darkness-induced changes in dLGN neurofilament immunoreactivity equivalent, but not greater than those observed in animals subject to MD alone. These results suggest that the propensity of darkness to promote susceptibility to MD depends on the animal's initial capacity for visual plasticity. Further, it appears that the ceiling for critical period plasticity may be constrained by factors resistant to the effects of darkness.},
}

@inproceedings{bartel2017drinking,
  title = {Drinking frequency, drinking quantity, and alcohol-related problems as trait-states:A 4-wave, 18-month longitudinal study of female undergraduates},
  author = {Bartel and SJ and SB, Sherry and LJ, Nealis and JL, Collins and DL, Lee-Baggley and SH, Stewart},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Background: Drinking behavior and alcohol-related problems in female undergraduates are topics of growing interest and importance. Research in this area widely assumes that alcohol frequency, alcohol quantity, and alcohol-related problems are trait-like (i.e., strongly temporally stable). Under the assumption of trait-like stability, a single assessment is enough to capture a person's usual pattern of drinking behavior and alcohol-related problems; however, in making this assumption, research in this area fails to consider that there may be substantive state-like variability in drinking behavior and alcohol-related problems. To address this shortcoming, we tested a trait-state model of drinking behaviors and alcohol-related problems in female undergraduates using a 4-wave, 18-month longitudinal design. We hypothesized alcohol frequency, alcohol quantity, and alcohol-related problems would show both trait-like stability and state-like variability across our four waves of data collection, thereby supporting the trait-state model. Methods: A sample of 207 female undergraduate drinkers completed self-report measures of alcohol frequency, alcohol quantity, and alcohol-related problems four times (i.e. every 6-months for 18 months). Results: Generalizability theory analyses indicated alcohol frequency, alcohol quantity, and alcohol-related problems all exhibited both trait- like stability and state-like variability. While a greater proportion of the variance in alcohol quantity and alcohol- related problems was attributable to trait-like stability, a greater proportion of the variance in alcohol frequency was attributable to state-like fluctuations. Conclusions: Drinking patterns of female undergraduates tend to fluctuate over time, particularly frequency of use. It should not be assumed that a single assessment of drinking behavior and alcohol-related problems is a valid representation of a young woman's drinking patterns. Keywords: trait, state, trait-state, alcohol, alcohol problems, generalizability theory},
}

@inproceedings{e2017radarwatch,
  title = {RadarWatch: Validating an attention training game with a focus on vigilance decrement},
  author = {E, Patrick and R, Drake and J, Kroeker and J, Chisholm and R, Klein and D, Westwood and G, Eskes},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Attention deficits can occur with medical, neurological or psychiatric illnesses and limit a person's independence and quality of life. Thus, rehabilitation of these deficits would be beneficial. Posner and colleagues have provided a framework for the attention system that involves three independent but interacting attentional brain networks. The alerting or vigilance network underlies the ability to develop and sustain a state of mental alertness, which consequently produces more rapid detection, selection, and responding. We have recently developed a vigilance game, Radar Watch, that involves tracking a radar screen for designated targets over extended periods of time. Typically in vigilance tasks, the ability to detect and respond to targets decreases as time on the task increases, a phenomenon known as the vigilance decrement. Research has demonstrated that this decrement can occur within the first 5 - 30 minutes of a task and is influenced by how often a target appears. The purpose of the current study was to examine for the presence of a vigilance decrement in Radar Watch. We also investigated if the target rate (high or low) influenced the vigilance decrement. Twenty young adults (mean(SD) age = 20.7(4.3) yrs) were randomly assigned to one of two groups, high target rate or low target rate, and were asked to monitor the radar display for a designated target for approximately one hour. Reaction time (RT) and accuracy of target detection was measured over 6 blocks of 60 radar sweep trials. Preliminary but promising results, as well as future applications, will be discussed in the context of the alerting network and stroke rehabilitation.},
}

@inproceedings{e2017orthographic,
  title = {Orthographic knowledge as a predictor of gains in lexical access},
  author = {E, MacKay and H, Deacon and N, Conrad},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Word reading is a foundational skill in children's reading development. One construct related to and important for word reading is lexical access. Lexical access is defined as the activation and/or retrieval of words in the mental lexicon (Perfetti, 1992). Theoretically, orthographic knowledge, or the knowledge of specific and general letter patterns, has been suggested as important for successful and fast lexical access. As such, we will longitudinally examine if orthographic knowledge predicts gains in fast lexical access for 104 English-speaking children from grades four to five. We will do so with an autoregressor cross-lag design. To form our composite of orthographic knowledge, we administered measures of lexical and sublexical orthographic knowledge in grade four. To assess lexical access, we administrated a measure of word naming measure to students in grade four and five. A measure of phonological awareness and a measure estimating nonverbal ability were administered as controls. To examine if orthographic knowledge predicts gain in fast lexical access, we will employ Structural Equation Modeling. Our model will include orthographic knowledge at grade four as the independent variable and lexical access at grade five as the dependent variable. Fourth grade lexical access, phonological awareness, and nonverbal ability will be entered as controls. Given theoretical predictions, we expect to find that orthographic knowledge predicts gains in speed of lexical access. The results of this study will inform key theories of reading development by providing novel support for the role of orthographic knowledge in successful and timely lexical access.},
}

@inproceedings{k2017connectome,
  title = {The Connectome of a Ciona intestinalis larva},
  author = {K, Ryan},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The nervous systems that drive animal behaviour are founded on synaptic connections between cells therein. Small nervous systems allow us to examine the entirety of a nervous system in great detail, revealing both ultrastructural and network details. We have used anatomical connectomic approaches by means of serial-section EM (ssEM) to analyze the number and distribution of synapses within the networks of the larval brain of Ciona intestinalis. Larval responses to environmental cues rely on the network of underlying neuronal connections that translates these cues into motion. The anatomical connectome reveals the components and connections of pathways for sensory integration of visual, gravity, and peripheral information both to and from pathways of other sensory systems. These sensory pathways feed into motor networks described through the current analysis that are involved in central pattern generation and a putative escape response. Cell by cell analysis of morphology and all synaptic connections enables the identification of new cell types and the classification of all neurons in this small model chordate nervous system. The network complexity allowing integration at multiple levels provides a substrate for more complex larval behaviour based on interactions between pathways that converge on the motor generating network of the Ciona intestinalislarva.},
}

@inproceedings{ia2017second,
  title = {A second complete connectome: the larval CNS of the ascidian Ciona intestinalis},
  author = {IA, Meinertzhagen and Z, Lu and K, Ryan},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The diminutive brains of invertebrates, especially those of larval stages with few cells, are Nature's bounty for connectomic analyses. Pride of place for the first complete connectome report goes to C. elegans (White et al., 1986, Phil. Trans. Roy. Soc.). Drosophila also supports powerful genetic methods and interesting behaviours, especially for vision, olfaction and courtship, but its neurons branch profusely to yield many slender neurites that require special methods to reconstruct at EM level. Pursuing an alternative possibility of an interesting simple brain in a model species, we have used ssEM to compile a complete densely reconstructed connectome for the CNS in the tadpole larva of Ciona intestinalis (Ryan et al., 2016, eLife), a chordate tunicate, a sister group of vertebrates. The dorsal, tubular CNS of the ~1-mm tadpole larva is built on a similar plan to vertebrate brains, its ~330 cells distributed rostrocaudally in three centres: a brain vesicle, motor ganglion and caudal nerve cord. Although early neural development is well studied, detailed cellular organization of the swimming larva's CNS is hitherto unreported. Neurons are unipolar with at most a single dendrite and few synapses. The 177 neurons formed 6618 CNS synapses including 1772 neuromuscular junctions, augmented by 1206 gap junctions. Some synapses are bidirectional, others form reciprocal or serial motifs; 922 were polyadic. Axo-axonal synapses predominate. Most neurons have ciliary organelles, and many features lack structural specialization. Glia and myelin especially are both lacking. Despite equal cell numbers on both sides, neuron identities and pathways differ left/right, asymmetries probably associated with the extreme reduction in cell numbers. Brain vesicle asymmetries include a right ocellus and left coronet cells. Some neuron types show homology with vertebrate neurons, as revealed by their similar circuits. Posters},
}

@inproceedings{r2017god,
  title = {God and Karma: Exploring Generosity Levels among Christians and Buddhists in Hong Kong},
  author = {R, Curtis},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {In most religions around the world, generosity toward others is a moral virtue. Social psychologists are currently working to better understand the factors motivating religious believers to act prosocially toward their ingroup members, as well as others. This study investigated generosity behavior among 40 Christians and 40 Buddhists in Hong Kong, China. Participants played four iterations of a dictator game, in which they divided the equivalent of one day's wage between themselves, a nearby member of their own religion, a faraway member of their own religion, and a faraway member of a different religion. Buddhists kept significantly less money for themselves than Christians. I discuss possible reasons for this outcome, including belief types, religious identity, and methodological concerns. My results highlight a need within the psychology of religion for additional research investigating motivating factors among believers of religions with agentic versus non-agentic moralizing forces.},
}

@inproceedings{ee2017item,
  title = {Item-based Rasch Analysis of the Merrill-Palmer-Revised Scales of Development for Children with Autism Spectrum Disorder},
  author = {EE, Dempsey and IM, Smith},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {Gold-standard diagnostic assessment for children suspected of having autism spectrum disorder (ASD) includes cognitive testing. Psychometrically strong cognitive measures are also indispensable in longitudinal research. Assessment of cognition in ASD is complicated by variable skill levels and uneven profiles of strengths and weaknesses, as well as inherent social communication differences. Few tests have been validated for use with this population. The Merrill-Palmer-Revised Scales of Development (M-P-R) is a standardized cognitive assessment that is well-validated and reliable for use with typically developing preschoolers. However, the suitability of the M-P-R for assessing children with ASD has not been well-researched. The current study's aim is to use an application of Item Response Theory, Rasch Analysis, to investigate the psychometric properties of the M-P-R in a large group of preschoolers with ASD. This presentation will focus on preliminary results of the Rasch Analysis.},
}

@inproceedings{s2017when,
  title = {When white is red in the eye of the Drosophila beholder, and philosophy 101},
  author = {S, Shaw},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {A persistent belief in the fly's-eye community has been that certain useful, easily assayed electrical responses come from particular neurons lying postsynaptic to the fly's photoreceptors -- vertebrate bipolar neuron equivalents. This belief stems from two failures, one observational and one 'philosophical'. The supposed gold-standard test for a feature like this electrical signature is to delete the putative gene for it (ort1 in Drosophila), show that responses vanish, then reintroduce ort1 again by clever genetics, rescuing responsiveness. In order to mark reintroduction, groups who did this used a gene marker along with ort1, the readily detectable white- eye phenotype. This assumes that the electrical responses from white are identical to those from red-eyed, wild-type flies, but the ON-OFF visual responses from the latter reveal very different properties from those in w1118 flies: they must have different cellular origins. Despite its cachet, the deletion-rescue formula fails to disclose the origins of visual responses in non-mutant flies. As to why "gold-standard" genetics produces disappointing results, the formula fits a category well known to logicians -- "the fallacy of affirming the consequent". If you assume that there is only a single solution to the question posed when there actually could be 2 or more alternative solutions, you've bought into your own story, #1. The correct answer could instead be #2 (or #3…), which you failed to eliminate.},
}

@inproceedings{e2017foxp,
  title = {FoxP2 Protein Expression in Zebra Finches Reared by Single Parents},
  author = {E, Gayda},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The zebra finch (Taeniopygia guttata), a sexually dimorphic songbird native to Australia, is one of the best-studied models of vocal learning. Finches have specialized neural circuitry critical for song learning; of significant importance is the basal ganglia component, Area X. In addition, songbird brains express FoxP2, a transcription factor that belongs to a family of genes involved in vocal communication in both humans and songbirds. Levels of FoxP2 protein in Area X decrease across the period of song development, however, it is unclear whether abnormal rearing, such as lack of appropriate tutor modelling, affects typical FoxP2 protein expression. Therefore, the purpose of this study was to analyze FoxP2 protein expression in zebra finches reared in typical biparental nests, and atypical paternal-only, or maternal-only nests. To do so, FoxP2 immunohistochemistry and quantification was completed with birds that had been reared to adulthood under these conditions. FoxP2 protein expression was not robust enough to detect Area X as a discernable nucleus in any birds. Therefore, an exploratory search for FoxP2 protein labelling was completed. There was evidence of lateralized expression of FoxP2 in the striatum of typically reared birds, but birds reared by a single father or single mother did not show this lateralization.},
}

@inproceedings{g2017cue,
  title = {Cue-induced Functional Connectivity in the Nucleus Accumbens and Anterior Cingulate Gyrus in Smokers with and without Psychosis},
  author = {G, Ellsworth-Spotton},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {The rate of smoking in patients with psychosis is 70 % (Moran, Sampath, Stein & Hong, 2012). Smoking stimuli presented to smokers will elicit a craving response (McBride, Barrett, Kelly, Aw, & Dagher, 2006). The mesolimbic dopamine pathway is implicated in smoking and psychosis and hyperdopamingeria is seen in both groups (Chambers, Krystal & Self, 2001; Fonder et al., 2005). Six patient smokers and six control smokers underwent an fMRI, during which participants were presented with cues. fMRI data was analyzed using FSL and the anterior cingulate gyrus and nucleus accumbens were regions of interest (ROI) for seed based functional connectivity. Patients demonstrate a higher degree of functional connectivity between the ROIs and brain regions involved in emotion, memory and craving. This research broadens the understanding of the neurobiological mechanisms behind the high smoking rate in psychotic individuals and helps to gain a greater understanding of the addiction pathways in these individuals.},
}

@inproceedings{m2017employing,
  title = {Employing Rescorla's truly random condition to measure truly exogenous covert attention},
  author = {M, Habibnezhad and M, Lawrence and R, Klein},
  booktitle = {Psychology and Neuroscience 43rd Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2017},
  abstract = {In studies measuring the exogenous attention, cues are employed to capture attention. Ideally, cues are supposed to be both spatially and temporally uninformative of the target stimulus. Studies carried out to measure exogenous attention have successfully made the cues spatially uninformative, while temporal contingency between the cue and the target has been minimized with different measures, none of which guarantees complete uninformativeness of the cues. The present study used Rescorla's truly random condition to produce such cues.},
}

@inproceedings{nogueiraarjona2018drinking,
  title = {Drinking to keep pace: Testing the moderating influences of sensation seeking and extroversion},
  author = {Nogueira-Arjona, Raquel and Shannon, Trevor CJ and Kehayes, Simon B Sherry Ivy-Lee and Sherry},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Peterson et al. (2005) showed that modelling contributes to college students' alcohol use, with highly extroverted males being most susceptible to matching strangers' drinking levels in a lab- based context. We examined if: a) there was a significant relationship between target and buddy drinking levels in college students' dyadic drinking situations; b) both target extraversion and sensation-seeking positively moderate this target-buddy drinking levels relationship. Data were collected from 149 targets (74% F) and their same-sex drinking buddy. The target completed personality measures, and both completed a past 30-day Timeline Follow Back examining drinking levels and context. Linear mixed-effects modeling confirmed the first social matching hypothesis, and revealed that extraversion, but not sensation-seeking, positively moderated the relationship between buddy and target daily dyadic drinking levels. Findings extend previous research to a real-world context, modeling of a buddy's drinking levels, and to women. Results may guide modifications to personality-based interventions for college drinking. 44th In-‐House Conference Psychology Neuroscience},
  note = {Poster},
}

@inproceedings{pappin2018investigatin,
  title = {Investigating the Effect of Visual Noise on Cognitive Load and Memory using Item-Method},
  author = {Pappin, Jessie and Taylor, Tracy},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {The present study investigated the effect of visual noise induced cognitive load on item- method directed forgetting. Study words were presented to participants superimposed on one of three levels of visual noise. Study words were followed by a memory instruction to remember or forget the previously seen word. Participants' completed a recognition test for both remember and forget words. The directed forgetting effect, defined as better recognition of remember words than of forget words, was seen in all levels of visual noise. Recognition accuracy was significantly lower in the high noise condition than in both the medium and low condition. These findings suggest that high levels of visual noise can facilitate item-method directed forgetting.},
  note = {Poster},
}

@inproceedings{lazarkurz2018prism,
  title = {Prism Adaptation in Older Adults: an ERP Analysis},
  author = {Lazar-Kurz, Zoë and Eskes, Gail and Newman, Aaron and MacLean, Stephan and MacKearney, Katie},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {In this study, we measured prism adaptation (PA) in older adults as a marker for neuroplasticity. Currently, little is known about the neural correlates of PA, and even less in older adults. Event related potentials (ERPs) were recorded in response to a target reaching task while wearing prism or clear lenses. Past research in young adults suggested two ERP components facilitate PA: the P300 and the feedback error related negativity (fERN; MacLean et al., 2015). In our study of Psychology Neuroscience 44th In-‐House Conference older adults, while behavioural tests converged with young adults, only the fERN was elicited, not the P300. As seen in young adults, the fERN amplitude was related to spatial accuracy of the pointing in relation to the location of the target. These preliminary results may suggest the neural mechanisms associated with PA differ in older and younger adults. However, these results need to be verified by directly comparing younger participants with the same procedure.},
  note = {Poster},
}

@inproceedings{gerrie2018vivo,
  title = {In vivo application of the photoswitch BENAQ in a rat model of acquired retinal degeneration},
  author = {Gerrie, Autho: Heather},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Abstract: Millions of people worldwide suffer from degenerative retinal diseases, such as retinitis pigmentosa (RP) and age-related macular degeneration (AMD). There are currently no therapies available to reverse vision loss, leaving individuals with the prospect of irreversible blindness. AMD and RP specifically target the photoreceptor cells of the retina and induce progressive deterioration. As the primary light sensitive cells of the retina, photoreceptor loss results in decreased visual acuity and severe visual impairment. To reduce the consequences of retinal degeneration, a series of azobenzene photoswitch drugs have been developed as a potential therapeutic strategy. Photoswitches are able to confer light sensitivity onto non-light responsive cells, such as retinal ganglion cells, causing them to fire in response to light stimulus. However, the effects of photoswitches have only been demonstrated in congenital models of photoreceptor degeneration, despite the acquired nature of some retinal diseases, including AMD. Additionally, it is not well understood how the visual cortex responds when a photoswitch is applied to the retina. Therefore, this project sought to test cortical response to photoswitch application in a model of acquired retinal degeneration.},
  note = {Poster},
}

@inproceedings{macneil2018investigatin,
  title = {Investigating the ability of superoxide to pass dendritic spine plasma membranes in},
  author = {MacNeil, Hannah and Fine, Alan},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Reactive oxygen species such as superoxide have been shown to carry out individual processes involved in long-term potentiation (LTP). Superoxide in neurons is produced extracellularly and until recently, it was assumed that it could not pass through the membrane. Recent findings suggest that superoxide can pass membranes in epithelial cells via chloride channels. I hypothesized that a similar mechanism occurs in hippocampal neurons, allowing superoxide to perform distinct functions in intracellular signalling involved in LTP. The current study tested the hypothesis that superoxide can pass through the plasma membrane in spines of rat hippocampal neurons by detecting superoxide with fluorescent dye and imaging the cells before and after superoxide production. The trend of the results supports the original hypothesis, as a significant increase in florescence was observed in some putative spines 10 seconds after superoxide production, and this increase was eliminated when chloride channels were blocked.},
  note = {Poster},
}

@inproceedings{harris2018unresolved,
  title = {The unresolved role of the cell adhesion molecule family, neurexins, and activity on the},
  author = {Harris, Sydney and Kolar, Annette and Quinn, Dylan and Krueger, Stefan},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Synapse elimination and formation is a necessary part of post-natal development. It optimizes the wiring of neuronal circuits, ensuring proper processing of sensory input and behavioural output. The process of synaptic refinement is regulated by neural activity, which affects the structural and functional integrity of synapses through possibly global homeostatic mechanisms. Besides activity, cell adhesion molecules critically influence synapse refinement. Neurexins, a family of cell adhesion molecules, previously implicated in modulation of synaptic transmission, have been shown to stabilize synapses. It is presently unclear whether neurexins affect synapse refinement structurally or by modulating synaptic transmission. To address this, we inhibited AMPA-type and NMDA-type glutamate receptors in hippocampal neurons in the presence and absence of neurexin 44th In-‐House Conference Psychology Neuroscience knockdowns. Although chronic blockade of glutamate receptors led to a decrease in eliminated synapses, the density was unaltered. Moreover, only one of two neurexin knockdowns caused significant decrease in synapse density and significant increase in synapse elimination in a glutamate receptor blockade, preventing us from providing a conclusive result.},
  note = {Poster},
}

@inproceedings{purdon2018behavioural,
  title = {Behavioural phenotypes of the MDGA2+/- mouse model of autism spectrum disorder (ASD)},
  author = {Purdon, Michaela K. and Fertan, Emre and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {A MAM domain-containing glycosylphosphatidylinositol anchor 2 (MDGA2) gene has been linked to ASD in humans [Bucan M. et al., 2009, PLOS. 5:6]. Connor S. A. et al. [2016, Neuron 91:5, 1052-1068] showed that haploinsufficency in the MDGA2+/- mouse model produced behavioural phenotypes paralleling those seen in humans with ASD. The MDGA2+/- mice used by Connor et al. (2016) were bred using a C57BL/6N background which has an rd8 mutation that causes retinal spotting. We used 2-month old transgenic (MDGA2+/-) mice and wildtype (MDGA2+/+) littermate controls on a C57BL/6J background to determine whether visual impairment was a confounding variable in the Connor et al. (2016) study. Results show differences on tests of sociability, motor ability, and cognition, indicating visual impairments and/or background strain may influence the behavioural phenotype of this model.},
  note = {Poster},
}

@inproceedings{lee2018effects,
  title = {Effects of Atrx haploinsufficiency and mother-pup interactions on cognitive, social and},
  author = {Lee, Kristen and Goguen, Donna and Weaver, Ian},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {A child's early-life conditions both before birth and in infancy has profound effects on long-term physical and mental health outcomes of an individual. The relationship between the quality of early environment and long-term developmental programming appears to be mediated, in part, by the degree of positive attachment in parent-infant bonding and parental investment during early life. We have previously shown that offspring of low maternal care mothers have reduced forebrain Atrx levels . Children born with mutations in the Atrx gene have intellectual disability and autistic-like behavior. Using wildtype and Atrx heterozygous C57/B6 mice, we examined the role of ATRX and prenatal stress in mitigating the effects of variations in maternal behavior during early brain development and social emotional and cognitive behaviors into adulthood. Our results suggest that prenatally stressed offspring have social and behavioral deficits associated with reduced Atrx levels.},
  note = {Poster},
}

@inproceedings{klein2018using,
  title = {Using the Hebb Legacy to Integrate Psychological Science},
  author = {Klein, Raymond M. and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {The birth of our relatively young science has been described (Boring, 1950) as the product of a marriage between physiology and philosophy. Whereas we might be described as an incredibly successful offspring we are presently experiencing something of a disintegrating identity crisis. As proposed by Posner & Rothbart (2004, 2007) the framework advocated by D. O. Hebb (1949), in the "Organization of Behavior: A Neuropsychological Theory", and other works, can provide the foundation for the integration of our discipline and the framework for averting this crisis. Hebb (1949) proposed that synaptic change is the basis of neural activity (which we now call the "Hebb synapse") and developed the idea of a "cell assembly" or neural network to account for the ability of the brain to retain information in the absence of sensory stimulation. Hebb sought to explain psychological concepts, from learning and memory to brain development, motivation, emotion and brain disorders in neuroscientific terms. As noted by Posner & Rothbart, technological advances in neuroimaging, genetics and computational modeling, offer a firm and realistic foundation for research and training aimed at understanding how environment and heredity interact to shape the neural networks that underlie the organization and disorganization of behaviour, cognition and affect.},
  note = {Poster},
}

@inproceedings{mahu2018specificity,
  title = {Specificity of Four Personality Correlates of Concurrent Substance Use Among Opiate},
  author = {Mahu, Ioan and Barrett, Sean and Conrod, Patricia and Lawrence, Mike and Chinneck, Annie and Julie},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {The leading treatment for opioid addiction in Canada is methadone maintenance therapy (MMT). While efficacious for treating opiate addiction, MMT fails to address patients' concurrent polysubstance use. This study was designed to validate the Substance Use Risk Profile Scale (SURPS; Woicik et al., 2009) in a MMT sample, and to demonstrate theoretically-relevant relationships of personality to recent substance use. One-hundred-thirty-eight MMT patients from four clinics in Quebec and Nova Scotia participated. Bayesian confirmatory factor analysis established the structural validity of the four-factor personality risk model in this population. SURPS subscales were then used as predictors for specific forms of recent substance use. Hopelessness predicted past 30-day opiate and tranquilizer use, anxiety sensitivity predicted past 30-day tranquilizer use, and sensation seeking predicted past 30-day stimulant, alcohol, and marijuana use. Impulsivity predicted past 30-day injection drug use (particularly stimulant injection). Thus, personality influences substance use patterns, even at latter stages of addiction.},
  note = {Poster},
}

@inproceedings{lee2018want,
  title = {Do I Want Babies Now? Reproductive Investment of Gryllus texensis under the Interaction of},
  author = {Lee, Marco and Adamo, Ann Johnsen Co-supervisors: Shelley and Miyashita, Atsushi},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {To maintain maximum fitness in a variable environment, individuals must adapt to environmental cues by altering investments into current reproduction, somatic maintenance and future reproduction. The terminal investment hypothesis predicts that as prospects of future reproduction decrease, investment into reproduction should increase. However, the threshold for terminal investment may shift with age and disease risk. Interactions between immune challenge (IC) and age were examined by monitoring lifetime reproductive investments of female crickets that were exposed to an IC at different ages. We predicted that younger females would over-invest in immunity relative to older females because younger females will lose proportionately more of their total reproductive output if they die of disease than will older females who have already laid many of their eggs. We also predicted that the increased investment in immunity would lead to younger females having lower current reproduction compared with older females. Regardless of treatment, older females laid more eggs over a 7-day period than did young females. Contrary to our prediction, phenoloxidase, an immune enzyme, showed greater activity in older females.},
  note = {Poster},
}

@inproceedings{lownie2018erp,
  title = {An ERP study of reading ability and polyunsaturated fatty acid consumption in childhood},
  author = {Lownie, Clara J and Galilee, Alena and Newman, Aaron J},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Diet is one of many environmental factors influencing a child's ability to acquire proficient reading skills. Polyunsaturated fatty acids (PUFA) are a group of nutrients that are critical to the neurodevelopment of several cognitive abilities, such as reading. This study used electroencephalography to record electrical activity in the brain following visual word stimuli within a reading task. Specifically, this research focuses on one event-related potential component, the N170, associated with two reading related phenomena; print tuning and lexical tuning. The amplitude of the N170, behavioural measures of reading, and estimated consumption of PUFA in children grades 2 to 6 in the Halifax Regional Municipality were analyzed. While the findings of this exploratory study do not provide conclusive evidence to support the hypothesis that estimated PUFA consumption is correlated to print or lexical tuning, these results suggest that print and lexical tuning effects may actually be negatively correlated to PUFA consumption. Psychology Neuroscience 44th In-‐House Conference},
  note = {Poster},
}

@inproceedings{park2018investigatin,
  title = {Investigating the Path from Childhood Maltreatment to Alcohol Problems in a Sample Child},
  author = {Park, Tristan and Stewart, Sherry H and Al-Hamdani, Mohammed and Thompson, Kara and Christine},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {PTSD symptoms and drinking motives have both been identified as mediators in the relationship between trauma and alcohol misuse. We sought to extend recent research suggesting that both PTSD symptoms and, in turn, drinking motives mediate the relationship between childhood maltreatment and alcohol misuse. Five-hundred and sixty-four adolescents (54% female; mean [SD] age = 15.9 [1.1] years) in the care of child welfare services completed validated measures of childhood maltreatment, PTSD symptoms, drinking motives, and alcohol misuse as part of the Maltreatment Adolescent Pathways longitudinal study. Results supported a chained mediation model where childhood maltreatment was associated with elevated PTSD symptoms, which in turn predicted higher coping motives, which was associated with higher alcohol misuse. Single mediator models for PTSD symptoms and coping motives were not significant. The results suggest that both PTSD symptoms and coping motives are necessary to explain the relationship between childhood maltreatment and alcohol misuse.},
  note = {Poster},
}

@inproceedings{strickland2018self,
  title = {Self-compassion as a resilience factor for alcohol-involved sexual assault and negative emotional},
  author = {Strickland, Noelle},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Experiencing alcohol-involved sexual assault (AISA) may result in self-blame, while self- compassion (SC; extending kindness towards oneself) may promote resilience from the negative emotional consequences of AISA by attenuating and/or counteracting the association between AISA and negative emotional outcomes. Undergraduates (N = 785) completed measures tapping past-term AISA (Kehayes et al., in press), SC (i.e., Self-Compassion Scale; SCS; Neff, 2003), and anxiety and depression (K10; Kessler et al., 2002). The SCS was scored as two higher-order domains (SC, self- criticism) and six lower-order facets (self-kindness, mindfulness, common humanity, over- identification, self-judgement, isolation). Rather than attenuation, the higher-order SCS domains showed main effects: high SC and low self-criticism counteracted the adverse effects of AISA on anxiety and depression. Similarly, the lower-order SCS facets of high self-kindness and low over- identification counteracted the adverse effects of AISA on anxiety/depression - with the additional SCS facets of low self-judgement and isolation counteracting the effect of AISA on depression.},
  note = {Poster},
}

@inproceedings{puddicombe2018what,
  title = {What Influences Children's Sensitivity to Violations of Authority as a Moral Foundation?},
  author = {Puddicombe, Emily and Curtis, Robin and Moore, Chris},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {According to Moral Foundations Theory (Haidt, 2012), human beings are innately sensitive to five core moral domains, which can be influenced by upbringing and culture. One of these foundations is authority. However, limited research has investigated children's sensitivity to authority as a moral foundation. Studies have found that children's age, potential punishments, and authoritative figure's status influence children's response towards authority. The current study used the Moral Foundation Questionnaire for Kids to measure 31 children's sensitivity to authority when presented with six vignettes depicting violations of authority towards teachers and parents. Badness ratings and punishment choices were taken for each vignette. A mixed two by two ANOVA revealed no main effect of age on children's badness ratings and no main effect of authoritative figure type on children's overall badness ratings. However, an independent samples t-test found older children were significantly more punishing than younger children. Limitations and implications are discussed. 44th In-‐House Conference Psychology Neuroscience},
  note = {Poster},
}

@inproceedings{hanzal2018changes,
  title = {Changes in Anxious Mood, Stress, and Cannabis Use Across the Menstrual Cycle: A Daily},
  author = {Hanzal, N and Joyce, KM and Stewart, SH},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Addictions research has predominantly focused on substance abuse in male-dominated research samples, indicating that findings may not generalize to women. Menstrual cycle (MC) phase appears to influence changes in addictive/risky behaviour. The current study examined phase-specific changes in anxious mood, stress, and cannabis use quantity across the MC. Consistent with the self-medication hypothesis (SMH), it was predicted that the quantity of cannabis used would increase during the (pre-)menstrual phases relative to other MC phases. It was also predicted that this increase in quantity of cannabis use would be associated with an increase in stress levels and anxious affect. For the current study, data were obtained from 14 female cannabis users using a 32-day daily diary method, with questions pertaining to anxious mood, stress, and quantity of cannabis used. Findings suggest that the quantity of cannabis used is phase-specific, while stress nor anxious affect are phase-specific variables.},
  note = {Poster},
}

@inproceedings{puddicombe2018alertness,
  title = {Alertness and Human Performance},
  author = {Puddicombe, Lindsey and O'Connor, Bronwyn and Howard, Samantha and Sawchyn, Piper},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Alerting is an attentional mechanism that increases arousal and helps us prepare to make responses. Human performance can be measured using reaction time and accuracy. A prior study by Posner et. al(1973) looked at the relationship between reaction time and accuracy when alerting at different time intervals. They found when reaction time was fastest; error rate was highest, which is a speed- accuracy trade-off (SAT). Our follow-up experiment required participants to indicate whether targets appeared on the left or right side, using either compatible or incompatible responses. Our manipulation was our method for alerting: participants would hear either an exogenous or endogenous warning signal. The goal of our study was to see if these different signal types had differing effects on human performance. The interval duration and the compatibility cues had a significant effect on both reaction time and accuracy. The differences between endogenous and exogenous signals are further considered.},
  note = {Poster},
}

@inproceedings{perrot2018psychology,
  title = {Psychology & Neuroscience: Where we've been and where we're going},
  author = {Perrot, Tara},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  note = {QA: no-abstract},
}

@inproceedings{shephard2018caffeine,
  title = {Caffeine cue reactivity: The impact of caffeine-related stimuli and expectancies on caffeine},
  author = {Shephard, Aaron and Morriscey, Carol and Barrett, Sean},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Caffeine is consumed by approximately 90% of adult, yet its potentially addictive properties have been understudied. Cue reactivity is an observable physiological and subjective response that can be used to measure a drug's addictive potential. Although cue reactivity is documented with many different substances, including cocaine and tobacco, no previous studies have examined this effect with caffeine. This study aims to address gap. Participants will be adult daily coffee drinkers. Following 12-hour caffeine abstinence, participants' caffeine craving will be assessed. They will then receive either caffeine-containing or placebo gum and be given either accurate or inaccurate information regarding the gum's caffeine content. Following an absorption period, they will be exposed to neutral and coffee related stimuli, before having their level of craving measured again. It is hypothesized that coffee cues will induce craving in participants and that this will occur regardless of actual or perceived caffeine consumption.},
}

@inproceedings{pridy2018music,
  title = {Music's charms vary by anxiety sensitivity level},
  author = {Pridy, Colin B. and Watt, Margo C. and Romero-Sanchiz, Pablo and Lively, Christopher J. and Sherry},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Music's many uses include mood- and arousal-regulation. Anxiety sensitivity (AS; fear of arousal-related somatic sensations) is a risk factor for anxiety-related disorders. This study examined relations between AS dimensions (physical, cognitive, social concerns) and music-listening motivations. Undergraduates (N = 817; 77.8% female; Mage = 19.06, SDage = 2.71) completed the Anxiety Sensitivity Index-3 and three validated music-listening motive measures. An exploratory 44th In-‐House Conference Psychology Neuroscience factor analysis (EFA) was conducted to determine factors underlying these various music-listening motive measures. Six underlying music-listening motives: coping, revitalization, connection, social enhancement, conformity, and sensory-motor. Regressions tested the relation of each AS dimension to these music-listening motive dimensions. AS cognitive concerns uniquely predicted coping, connection, and conformity music-listening motives while AS social concerns uniquely predicted coping and revitalization music-listening motives. Results add music-listening to the growing list of behaviours (e.g., alcohol use, smoking) linked to higher AS that are aimed at arousal- and negative mood-regulation.},
}

@inproceedings{drake2018does,
  title = {Does AFO support for walking reduce dual-task costs in individuals post-stroke?},
  author = {Drake, Richard S. and Parker, Kim and Clifton, Kerry and Adderson, James and Mountain, Anita and A, Gail},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Cognitive-motor interference, as measured by dual-task walking (performing a mental task while walking), is common with hemiplegia due to stroke. Ankle-foot orthoses (AFOs) are custom-made splint devices that provide stability to the foot and ankle and help prevent foot drop, a gait deficit common after stroke. AFO use has been shown to improve gait parameters such as speed and step time, which are often negatively impacted by dual-task walking. We investigated the protective effect of AFOs (i.e., whether AFOs could reduce cognitive-motor interference) in dual-task walking in 21 individuals with post-stroke hemiplegia using a 2 (with/without AFO) by 2 (with/ without dual task) repeated-measures design. The results suggest that the use of an AFO improves gait overall (e.g., improved step length), particularly while dual-tasking, although its effect on gait variability (e.g., stride regularity) is less straightforward. Theoretical and clinical implications of dual- task effects during walking will be discussed.},
}

@inproceedings{rossi2018partner,
  title = {Partner Perceptions of Women's Pain Self-Efficacy in Postpartum Dyspareunia: A Longitudinal},
  author = {Rossi, Meghan and Merwin, Kathleen and Rosen, Natalie},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Childbirth is a significant risk factor for the development of dyspareunia (pain during intercourse). Women with postpartum dyspareunia that are higher in pain self-efficacy (PSE) may be more motivated to seek out methods of reducing pain and exhibit more adaptive cognitive-affective reactions to pain. Partner perceptions of women's greater PSE have been linked to women's lower pain during intercourse. Prior research suggests that partners can be biased in their perceptions of the patient's pain experience, which may have consequences for the couples' well-being. This study aims to examine whether partner perceptions of women's PSE are biased at 3 months postpartum and whether this bias predicts women's pain and functional impairments in both members of the couple at 6 months postpartum. Data will be analyzed according to the Truth and Bias Model of Judgment via Response Surface Analysis. Findings may improve our understanding of how couples manage pain after childbirth.},
}

@inproceedings{brandelli2018parental,
  title = {Parental Perceptions of Pain and Treatment Adherence in Juvenile Idiopathic Arthritis},
  author = {Brandelli, Yvonne and Chambers, Christine and Huber, Adam and Stinson, Jennifer and Parker, Jennifer},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Juvenile Idiopathic Arthritis (JIA), a disease characterized by pain and swollen joints, affects over 24,000 children across Canada. While pharmacological and non-pharmacological treatments aim to manage the pain and prevent irreversible joint damage, adherence is often a challenge. This study will examine the parents' role in treatment adherence. It is hypothesized that there will be less treatment adherence in families where parents demonstrate pain catastrophizing and fears of pain, and that medication, side effects, and levels of pain will moderate these relationships, and barriers to treatment will mediate these relationships. One-hundred-and-fifty caregivers of children under the age of 18 with JIA will be recruited via social media to complete a Psychology Neuroscience 44th In-‐House Conference 20-minute battery of questionnaires. Data will be analyzed through multiple linear regressions and moderated mediation analyses. This study will identify how parental attitudes around pain relate to treatment adherence, which can have long-term effects on their child's health and well-being.},
}

@inproceedings{deacon2018reading,
  title = {Reading and learning in the wild: Young readers learning of the spellings and meanings of},
  author = {Deacon, S. Hélène and Mimeau, Catherine and Chung, Sheila Cira and Chen, Xi},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {We explore whether younger readers can learn the spellings and meanings of words through their independent reading. A total of 66 Grade 1 and 2 English-speaking children read stories containing novel words referring to new inventions (e.g., a veap, used to clean fish tanks). Following on this independent reading, children in both grades were above chance in choosing correct spellings and meanings for the new words. We also found that individual differences in skill in learning the spellings of novel words were related to word reading. In contrast, individual differences in skill in learning the meanings of the novel words were related to specifically to reading comprehension. These findings suggest that independent reading is a means through which children can acquire rich information about the meanings and spellings of new words and that children's skill in this learning might support reading skills in general.},
}

@inproceedings{ryken2018prosodic,
  title = {Prosodic Cues in Text: The Missing Link Between Prosodic Sensitivity and Reading},
  author = {Ryken, Alex},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Reading comprehension, or the ability to understand the meaning of text, is one of the most important skills children learn in school. Understanding how various metalinguistic skills support reading comprehension is essential to improving literacy curriculum. One skill which is related to reading comprehension in young readers is prosodic sensitivity, which is an awareness of the rhythmic cues in speech. However, the reason for this relationship is unclear. One possibility is that young readers are aware of how prosodic cues are represented in text, e.g. through punctuation. The proposed research will test the possibility that awareness of how prosodic cues are represented in text mediates the relationship between prosodic sensitivity and reading comprehension in young readers. This will be done by testing 150 grade 3-5 students individually in schools and examining their reading comprehension, prosodic sensitivity, and awareness of how prosodic cues are represented in text.},
}

@inproceedings{patterson2018psychometric,
  title = {A psychometric validation of a developmental psychopathology measure: The Youth},
  author = {Patterson, VC and Pencer, A and Pavlova, B and Awadia, A and Zwicker, A and Vallis, E Howes and Campbell, N and V},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Severe mental illness (SMI) is defined as any major psychotic or affective disorder. Antecedents, early manifestations of risk for SMI, may allow for targeted intervention to prevent the onset of SMI. However, there are no brief self-report measures that screen for antecedents in youth. The Youth Experience Tracker Instrument (YETI) measures six antecedents: affective lability, anxiety, basic symptoms, psychotic-like experiences, insomnia, and depressive symptoms. This study aims to establish the psychometric properties, factor structure, and optimal cut-off points of the YETI. The sample was 208 offspring of parents with and without SMI aged 8 to 17-years participating in the FORBOW study. A confirmatory factor analysis procedure was used to establish the questionnaire's structure. Receiver operating curves were used to select a cut-off point for the scale. This study's findings will validate a new instrument that may facilitate detection of youth at high risk for the development of SMI.},
}

@inproceedings{aziz2018role,
  title = {Role of Working Memory in Visual Search among Older Adults},
  author = {Aziz, Jasmine R. and Klein, Raymond M. and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Visual search is a goal-directed process whereby we scan for and locate important objects (targets) in our environment, from choosing products on shelves at the grocery store to scanning for pedestrians while driving. Working memory involves temporarily holding and/or manipulating information in mind. During visual search, working memory helps us to remember target features and previously searched locations. Visual search and working memory abilities both decline with age, which can interfere with daily activities (e.g., shopping, driving). This study will examine the role of working memory in visual search in older adults. We will manipulate working memory demands by varying whether a picture of the target (target template) is displayed during the search. We will relate this template effect to search performance, working memory abilities, and how frequently participants look at the template when displayed. Findings may assist in developing strategies promoting working memory and visual search abilities in aging.},
}

@inproceedings{schwartz2018expressions,
  title = {Expressions of Distress among Indigenous and Non-Indigenous Adults Living in an Urban},
  author = {Schwartz, Flint and Bombay, Amy},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Despite high levels of reported psychological distress in Indigenous peoples in Canada, research has not explored potential differences in expressions of psychological distress in this diverse population. This study seeks to explore: 1) how Indigenous adults express their distress through somatic versus psychological symptoms relative to non-Indigenous adults; 2) how symptom type relates to single-item mental/physical health self-ratings in both groups; and 3) whether associations vary by cultural orientation (acculturation and/or enculturation). Ongoing participant recruitment involves Indigenous and non-Indigenous adults experiencing symptoms of psychological distress, anxiety, and/or depression within the Halifax Regional Municipality. Measures include the Vancouver Index of Acculturation, the Kessler Psychological Distress Scale, single-item self-rated physical/mental health, and a demographics questionnaire (N=150). A series of regression analyses will assess the research questions and the potential moderation by cultural group, acculturation, and/ or enculturation. Implications for more culturally responsive mental health care and health research will be discussed.},
}

@inproceedings{anderson2018effects,
  title = {Effects of Caffeine on Sensory Gating in Schizophrenia},
  author = {Anderson, T and McKearney, K and Tibbo, P and Fisher, D},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {A predominant symptom of schizophrenia (SZ) is a deficit in sensory gating, or an inability to selectively filter out extraneous stimuli. Sensory gating also has deep connections to neurological functioning and is a large component of alerting effects of caffeine consumption. On average, individuals with SZ consume nearly double the norm of caffeine compared to typical populations (predicted self-medication). The EEG-derived event-related potential P50 is a robust index of sensory gating and provides the high temporal resolution needed to investigate this early automatic process. 15 SZ patients and 15 healthy controls were given caffeine and placebo treatments in two EEG recording sessions. Participants were recorded passively listening auditory click stimuli (typical populations suppress attentional response). P50 amelioration from caffeine was only seen in patients and not healthy controls. Indicating that a dose of 250 mg of caffeine was sufficient to ameliorate P50 indexed sensory gating in patients but not controls.},
}

@inproceedings{habibnezhad2018employing,
  title = {Employing Rescorla's truly random condition to measure truly exogenous covert attention},
  author = {Habibnezhad, Mohammad and Lawrence, Michael A and Klein, Raymond M},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Attention prioritizes processing of some information over the other. Attention can be engaged either exogenously (by an external event e.g. a loud noise) or endogenously (intention to focus on a task e.g. reading). Because endogenous control is thought to be engaged when stimulus Psychology Neuroscience 44th In-‐House Conference properties (such as spatial location) can be predicted, measuring purely exogenous orienting requires removing such predictability. Following this guide, previous studies of exogenous spatial orienting have used peripheral cues that were spatially uninformative about the upcoming target's location. However, these cues were almost always temporally informative about the upcoming target's time of presentation and this may have elicited some degree of endogenous control. We employed Rescorla's truly random procedure to eliminate the temporal information communicated by cue and target contingency. Forty participants were recruited to complete a variation of Posner's cueing paradigm, in which cues and targets were presented temporally randomly in one of two equiprobable peripheral locations. The results demonstrated a biphasic pattern of early facilitation and late inhibition (IOR). To evaluate the effect of removing temporal contingencies, we intend to implement the next experiment using fixed SOAs, mixed SOAs and non-aging paradigm.},
}

@inproceedings{solomon2018motor,
  title = {Motor Execution and Imagery are Unique Processes},
  author = {Solomon, Jack P. and Kraeutner, Sarah N. and Bardouille, Timothy and Boe, Shaun G.},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Motor Imagery (MI), the mental rehearsal of movement, is a method of motor learning that has been thought to parallel motor execution (ME). The neural mechanism(s) underlying the primary difference between MI and ME, the lack of movement in MI, is not well understood. Here we generated evidence from neuroimaging data to test two theories that exist to explain inhibition of movement in MI. We hypothesized MI and ME would diverge at the early stages of performance. Eighteen participants performed a grasping task using both MI and ME while we recorded their brain activity to ascertain common measures of brain activity that relate to movement planning and execution. Our results show that in the frequency domain, MI and ME differ early in the preparation phase for movement but the field strength only differed post-movement. This refutes our hypothesis but, still challenges the assertion that MI and ME are parallel processes.},
}

@inproceedings{alhamdani2018effects,
  title = {The effects of self-affirmation messaging and illness sensitivity on drinking intentions},
  author = {Al-Hamdani, M and Smith, S and Stewart, SH},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Little is known about the direct/indirect effects of self-affirmation alcoholic beverage labels, or illness sensitivity, on intentions to reduce drinking. Two studies addressed these gaps. Experiment 1 examined the effect of self-affirmation labels on alcohol appeal and intentions to reduce drinking. Labels were designed to increase attention to harms followed by an attempt to maintain self-integrity. Experiment 2 compared two models of the effects of self-affirmation labels and illness sensitivity on drinking-reduction intentions: direct vs. indirect via negative affect. In Experiment 1, self-affirmation reduced alcohol appeal and increased intentions to reduce drinking. In Experiment 2, negative affect mediated effects of illness sensitivity/self-affirmation on drinking- reduction intentions and the direct and indirect models were equally plausible. Results support the use of self-affirmation messaging in alcohol labelling practice to deter problematic drinking. Results also emphasize the importance of negative affect as a mechanism through which self-affirmation/ injury sensitivity increase intentions to reduce drinking.},
}

@inproceedings{joyce2018changes,
  title = {Changes in coping and social motives for drinking and alcohol consumption across the},
  author = {Joyce, Kayla and Hudson, Amanda and O'Connor, Roisin and Thompson, Kara and Hodgin, Megan and Tara},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Alcohol use increases during the (pre-)menstrual (characterized by negative affect) and ovulatory (characterized by positive affect) phases of the menstrual cycle (MC), suggesting women may drink for particular emotion-focused reasons during specific phases. Ninety-four normally- cycling women completed daily dairy surveys, examining state drinking motives and alcohol consumed across an entire MC. Women reported increases in drinking to cope premenstrually, peaking menstrually, and declining mid-cycle. Women reported a slight increasing trend across the 44th In-‐House Conference Psychology Neuroscience cycle in social motives, while enhancement motives remained stable across the cycle. Drinking to cope predicted greater alcohol quantities menstrually. While social motives predicted greater alcohol quantities during the follicular and ovulatory phases, enhancement motives were unrelated to drinking quantity. Results indicate that clinicians should be attentive to MC phase when treating reproductive-aged women with alcohol use disorders (AUD). Findings may help develop new, and improve existing, interventions for women with/at risk of, comorbid mood and AUD.},
}

@inproceedings{stamp2018making,
  title = {Making Science Accessible: A-RAD-ical Approach},
  author = {Stamp, Jennifer},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Dissemination of scientific research findings from the community of experts to the broader public is challenging, especially since the source literature makes for intimidating reading. Therefore people turn to headlines or websites for information, which often provide oversimplified or erroneous explanations. The Accessible Research Article Database (ARAD) is a collaboration between faculty from Dalhousie University and Science Atlantic, with the aim of building a collection of easy-to-understand, primary research articles suitable for undergraduate teaching. Contributions come from course instructors based upon two criteria: 1) article is relatively short and 2) contributor deems it to be accessible to an undergraduate science student. Then novice science students evaluate the articles for difficulty, identify jargon, and record reading time. To date, there are over 90 evaluated articles for Psychology and Neuroscience, organized by topic based on introductory textbook chapters, and housed in a shareable Google spreadsheet. The project is expanding into other scientific disciplines (Biology and Physics) and the creation of a searchable database.},
}

@inproceedings{leebaggley2018art,
  title = {The Art and Science of Behaviour Change},
  author = {Lee-Baggley, Dayna},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Dr. Dayna Lee-Baggley, Assistant Professor in Faculty of Medicine, is a new cross- appointee in the Department of Psychology and Neuroscience. She will provide an overview of her clinical work as a health psychologist and her research on behaviour change. She has an active research program on chronic disease, behavior change, obesity, professional resiliency and Acceptance and Commitment Therapy. Clinical and research opportunities for students will be reviewed.},
}

@inproceedings{hood2018pornography,
  title = {Pornography Consumption and Attitudes Supportive of Violence against},
  author = {Hood, Graham and Juckes, Tim},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {College-aged males consume pornography often (>4-5 a week) and for a considerable duration (>30 minutes at a time). We correlated consumption and type of pornography with attitudes towards women. We tested 28 male undergraduates (18-26 years old, mean age 22) using the Dalhousie Pornographic Typology and Consumption Scale (DPTCS). We collected consumption habits (i.e., frequency, duration, frequency of masturbation, internet search preferences, and consumption preferences) and viewing preferences based on 33 search terms (e.g., Softcore, Submission, Amateur Lesbians) commonly found on pornography streaming sites (e.g., Pornhub.com). Some search terms target DREVA pornography (Degrading, Rough, Extreme, Violent, and Abusive). Participants used the 33 search terms in an extremeness card sort and ratings weighted consumption scores. Weighted consumption was correlated with attitude scores on the Illinois Rape Myth Acceptance Scale and the Attitudes Supportive of Violence Scale. Results showed a positive correlation between the card sort and attitudes (r = 0.35). However, consumption habits negatively correlated with attitudes (r = -0.42), and DREVA-only consumption correlated negatively with attitudes (r = -0.33). Results suggest college-aged males recognize extremeness but consumption Psychology Neuroscience 44th In-‐House Conference is not detrimental to their attitudes toward women. This is a pilot study; results should be interpreted with caution.},
}

@inproceedings{curtis2018exploring,
  title = {Exploring the Effects of Afterlife Beliefs on Generosity and Prudence},
  author = {Curtis, Robin},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Priming thoughts of supernatural monitoring and punishment has been shown to increase prosocial behaviour among certain religious adherents. This study investigated whether priming thoughts of the afterlife might have similar effect. 80 Christians and 80 atheists were recruited from the undergraduate population. Participants completed a survey, including a writing prime, in which half described their expected situation after graduation, and half described their expected situation after death. Preliminary results in pre- and post-prime generosity and prudence measures suggest that contemplating the afterlife may facilitate generosity toward strangers among Christians, while inhibiting money-saving behaviour among atheists. Implications and follow-up directions are discussed.},
}

@inproceedings{fertan2018what,
  title = {What do we actually measure when "measuring behaviour"?},
  author = {Fertan, Emre and Wong, Aimee A. and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Behavioural tests are commonly used in neuroscience to study the function of brain regions, validate animal models of neurological diseases, and test therapeutics. One common problem with these behavioural tests is that researchers often choose the easiest test to measure a specific behaviour and fail to take any external factors into account when interpreting the results. In this talk, I will provide three examples from our laboratory which demonstrates that test results may not always show what we think they do. 1. In the triple test of anxiety, 5xFAD mice are not less anxious, as found in other studies, but they are avoiding the closed arms of the EPM. 2. In the Hebb-Williams maze female 3xTg-AD mice have low food motivation, which results in poor cognitive performance. 3. By treating glaucoma in DBA mice, we showed that spatial learning in the MWM is confounded by vision deficits.},
}

@inproceedings{spinella2018impact,
  title = {The impact of cannabidiol (CBD) and stimulus expectancy on subjective and physiological},
  author = {Spinella, Toni C. and Barrett, Sean P.},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Despite the increasing availability and upcoming legalization of recreational cannabis use, research findings are mixed on its potential risks and benefits. Additionally, the mechanisms underlying the potential therapeutic effects of cannabidiol (CBD) remain unclear. This study seeks to examine the independent and combined influences of CBD-related expectation and pharmacology on stress response. Adult participants will be recruited from the Halifax community. Prior to stress induction participants will be randomly assigned to one of four conditions in a balanced placebo design, where the content and instructions regarding the content of the oral pill will vary between participants. Subjective ratings of stress will be collected, and heart rate and cortisol levels will be assessed before and after the stress induction paradigm. Findings from this study will provide insight into how CBD impacts subjective and physiological responses to stress, a critical step towards informing future research, clinical practice, and public health policy.},
}

@inproceedings{mackinnon2018everything,
  title = {Everything your undergrad students are (supposed to be) learning about statistics: Part 1},
  author = {Mackinnon, Sean},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  note = {QA: no-abstract},
}

@inproceedings{christie2018everything,
  title = {Everything your undergrad students are (supposed to be) learning about statistics: Part 2},
  author = {Christie, John},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Statistical Methods II (PSYO 3502) is a mandatory course for our psychology and neuroscience honours students. In 2012 the course was heavily revised with incremental improvements ongoing. It focuses on understanding the edge cases (p = .051), thinking meta- analytically, figuring out how to analyze data on your own, and reading results sections critically, 44th In-‐House Conference Psychology Neuroscience including checking to see if authors both back up what they say, and making logically coherent arguments. It builds on the simulation techniques that were introduced in 2501 but has the students generate the simulation themselves. It does not build a large library of statistical techniques. It expands from 2501 with repeated measures designs, factorial designs, and logistic regression. A small amount of the time is spent at the end of the course demonstrating multi-level designs and model comparison.},
}

@inproceedings{kashetsky2018songbirds,
  title = {Do songbirds care about human singing?},
  author = {Kashetsky, Tovah and Ali, Nafisah and Brien, Will and Phillmore, Leslie},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {In songbirds, the immediate-early gene ZENK is expressed in neural regions critical for auditory processing after playback of acoustic stimuli. Expression levels change with breeding condition or sex of the bird and complexity of stimuli, but most studies find that own-species, or conspecific, vocalizations produce the most ZENK immunoreactivity (Zenk-ir) compared to vocalizations of other species (heterospecific), white noise, pure tones, or silence. In this study we asked whether stimuli considered heterospecific to a songbird, the zebra finch, could induce higher-than-expected Zenk-ir if the stimuli were made meaningful to the bird. To do this, we quantified Zenk-ir (and another immediate-early gene c-fos) in response to playback of human vocalizations the birds had learned to associate with reward or punishment in an operant conditioning paradigm. Compared to birds that had never heard these stimuli before, operant consequences appear to increase Zenk, but not c-fos response to heterospecific stimuli, meaning these regions are important for processing meaningful, not necessarily conspecific, stimuli.},
}

@inproceedings{redden2018using,
  title = {Using temporal order judgments to dissociate two inhibitions of return},
  author = {Redden, Ralph S and Hurst, Austin J and Klein, Raymond M},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Early work on inhibition of return (IOR) using a temporal order judgment (TOJ) task showed no effect on arrival time judgments, suggesting this inhibitory effect is acting at a post- perceptual information processing stage. Recent work, however, suggests that there are two forms of IOR; one affecting the quality of inputs and the other affecting responding, whereby the type of effect that is manifest is contingent upon the activation state of the reflexive oculomotor system. We tested this theory in a TOJ task, where subjects were required to either make a prosaccade (output form) or antisaccade (input form) after the onset a spatially uninformative peripheral cue, and subsequently execute a TOJ response. We found inhibited perceptual processing when the input form was generated, but no effect on TOJs in the group that elicited the output form. These findings provide converging evidence that there are two forms of IOR: an input effect operating on a saliency map, and an output effect operating on a priority map.},
}

@inproceedings{gaughan2018effect,
  title = {The Effect of Memory Instruction on Spatial Associations},
  author = {Gaughan, T and Taylor, TL},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {In a directed forgetting paradigm, participants are presented with a series of words and instructed to remember or forget each word. When instructed to forget, attention is withdrawn from the word as well as the location the word was presented in. Certain words have associations to specific locations in space, such as "sky" having an "up" association. The present study examined the effect memory instruction has on spatial associations. Participants were presented with an item- method directed forgetting paradigm. Words had an association to upper or lower space, or no spatial association. Following an instruction to remember or forget each word, participants localized a target that appeared above, below, or at center and response times were collected. A subsequent memory test revealed a directed forgetting effect: participants recognized more words that were instructed to-be-remembered than words instructed to-be-forgotten. Contrary to the literature, response time analyses revealed no indication that memory instruction has an effect on congruency. Psychology Neuroscience 44th In-‐House Conference},
}

@inproceedings{douglas2018measuring,
  title = {Measuring the N400 effect in a naturalistic setting},
  author = {Douglas, Caitriona and Tremblay, Antoine and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Recently, neuroscientists researching social cognition have begun using a two-way EEG technique called hyperscanning to record the brain activity from two participants simultaneously to better understand naturalistic social interactions. Researchers have demonstrated that it is possible to detect ERPs using hyperscanning in a social joint-task scenario (Loehr et al., 2015). Given that much of psycholinguistic research involves studying ERPs, we developed a hyperscanning method to detect ERPs in a naturalistic conversational setting. We recruited pairs of participants to have a scripted conversation using a script that contained specific amounts of low and high frequency nouns as stimuli because a frequency-modulated N400 effect had been previously reported in the literature (Rugg 1990; Hendrix et al. 2017; Van Petten et al. 2014) We successfully detected the N400 ERP in a conversational setting using hyperscanning, but did not find a significant difference in amplitude between the low and high frequency conditions.},
}

@inproceedings{klein2018testing,
  title = {Testing the networks of attention: From the ANT to the Attention-Trip},
  author = {Klein, Raymond M and McCormick, Colin and Arora, Swasti and Rehan, Sana},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Even though W. James asserted that "everyone knows what attention is" the term, attention, is not a single, simple concept. Rather, attention refers to several basic neuro-cognitive processes. Perhaps the most influential taxonomy of attention, according to which there are three isolable networks of attention (alerting, orienting and executive control), has been advanced by Posner and colleagues. The Attention Network Test (ANT) was developed to serve as a quick and easy to administer assay of these networks. The ANT has been widely used to measure the efficacy of these three attention networks. World-wide and local interest in this test will be described and some limitations will be discussed. Our development of a more engaging version, that we call the Attention-Trip, will be presented along with some recent data we have collected using this game-like task.},
}

@inproceedings{galilee2018ortho,
  title = {Ortho-semantic learning of novel words in Grade 3 students: An ERP study},
  author = {Galilee, Alena and Beck, Lisa and Mimeau, Catherine and Deacon, S. Hélène and Newman, Aaron J},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {It has been proposed that reading development field should move from examining established knowledge of orthography and semantics to assessing children's capacity to learn the meaning of both spelling and meaning of new words, referred as ortho-semantic learning (Deacon, 2012). Our main objective was to examine how event-related potentials (ERP) change with ortho-semantic learning. Thirteen native English speaking students in Grade 3 learned novel word spellings and meanings by reading short stories. Immediately after learning, participants completed a lexical decision task in which they were presented with real words, novel words from the stories, non-words, consonant strings, and false fonts. Two different ERP components were investigated: N170 (word recognition) and N400 (lexical semantics). Our preliminary results suggest that after brief exposure, the ortho-semantically novel words were processed similarly to real words. Additional analyses will examine relationships between individual differences in word reading, ortho-semantic learning, and the ERPs.},
}

@inproceedings{shaw2018provisional,
  title = {A provisional equivalent circuit for the fly's eye space.},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Why elements of the fly's visual electroretinogram (ERG) occur with the sizes and polarities that they do remains unexplained, because the equivalent circuit of the eye's extracellular space is not understood. Exploring this involves locating where extracellular barrier(s) are formed, and demonstrating how both photocurrents and microelectrode currents escape from the eye. Measured resistance depth profiles and dye diffusion point to an extracellular resistance barrier (Rbarrier) in and around the lamina synaptic zone. The conventional suggested current path runs from 44th In-‐House Conference Psychology Neuroscience the retina through the optic lobe, but results here point to a new route, currents escaping via the cornea. This pathway has a 3-5 fold lower resistance (Rcornea) than the deep route through the optic lobe (Rbarrier + Rdeep). Responses are measured relative to a reference electrode in the haemolymph, but this ground reference is necessarily interposed between Rdeep and Rcornea. The resulting equivalent circuit dictates that circulating photocurrents produce positive voltages around the lamina synapse, which then invert negative out into the retina. This correctly predicts the observed polarity of ERG responses from the photoreceptors and some other sources.},
}

@inproceedings{kosel2018characteriza,
  title = {Characterization of social deficits in the 5xFAD mouse model of Alzheimer's disease},
  author = {Kosel, K and Munoz, P Torres and Yang, JR and Franklin, TB},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Alzheimer's disease is a progressive neurodegenerative disorder that is characterized by a number of cognitive and behavioural effects; while memory loss is the most well known, patients also present with a number of neuropsychiatric symptoms, including depressive symptoms, anxiety, irritability, agitation, and aggression. This study examines whether a transgenic mouse model of Alzheimer's disease (5xFAD) that exhibits learning and memory deficits can also be used to model social changes in humans with the disease. We tested 5xFAD mice in behavioural tests for olfactory perception, responses to odour cues, sociability, social novelty preference, and free social interaction. Results indicate that transgenic female mice may exhibit altered processing and/or responses to social cues compared to wild-type controls, and that transgenic males may exhibit increased aggression compared to wild-type controls. This suggests that the 5xFAD strain may provide a useful model of social deficits present in Alzheimer's disease patients.},
}

@inproceedings{dewolfe2018gender,
  title = {Gender Differences in Physical Activity are Partially Explained by Anxiety Sensitivity},
  author = {DeWolfe, Christopher EJ and Watt, Margo C and Romero-Sanchiz, Pablo and Stewart, Sherry H},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Objectives - Women engage in less physical activity than men. Given that women have greater anxiety sensitivity (i.e., fear of arousal-based body sensations) and anxiety sensitivity is inversely related to physical activity participation, this study sought to determine if anxiety sensitivity mediates gender differences in physical activity. Method - A sample of 802 undergraduates completed the Anxiety Sensitivity Index-3 (Taylor et al., 2007) and a Lifestyles Questionnaire assessing physical activity levels. Results - A significant indirect effect of gender on physical activity Women engaged in significantly less physical activity and had significantly greater anxiety sensitivity. 44th In-‐House Conference Psychology Neuroscience Anxiety sensitivity was significantly and inversely related to physical activity. Conclusions - Results suggest that anxiety sensitivity partially explains gender differences in physical activity. Anxiety sensitivity reduction interventions might increase physical activity participation and reduce the existing gender gap.},
}

@inproceedings{king2018modulating,
  title = {Modulating GABAergic interneuron activity in mouse primary visual cortex alters response to},
  author = {King, Jillian L and Gill, Cheryl and Shapiro, Jared T and Crowder, Nathan A},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {The visual system has long been used to study cortical information processing. The genetic tools available in mice have allowed researchers to examine the roles of specific types of neurons in the primary visual cortex (V1) with a level of control that was previously inconceivable. Studies that have optogenetically modulated the activity of parvalbumin (Pvb+) and somatostatin (Sst+) expressing GABAergic interneurons indicate that these two populations may counteract the activity of pyramidal neurons (Pyr) differently, although there have been contradictory findings. Vasoactive intestinal peptide (VIP+) expressing GABAergic interneurons have been under-examined because it is believed that they have a negligible role. In the current study, we combined single-unit electrophysiology with optogenetic modulation of either Pvb+, Sst+ or VIP+ interneurons to provide additional data to help resolve the contradictory findings regarding Pvb+ and Sst+, and to determine whether VIP+ interneurons have a role in Pyr responsivity.},
}

@inproceedings{brown2018frailty,
  title = {Frailty as a measure of healthspan and lifespan in transgenic mice},
  author = {Brown, Richard E and Kane, Alice E and Wong, Aimee A. and Howlett, Susan E},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Mouse models of AD have differences in life expectancy. Frailty is a measure of aging which is independent of chronological age and can be used to compare age-related changes in mice with different lifespans. This study used the mouse frailty index (FI) which is based on deficit accumulation to explore genotype and sex differences in lifespan and healthspan of 3xTg-AD mice. Male 3xTg-AD mice aged 300-600 days had a higher FI score than either male wild-type or female 3xTg-AD mice, and the elevated frailty scores were accompanied by parallel increases in mortality. Frailty increased exponentially with age and higher rates of deficit accumulation elevated mortality risk in all groups. When mice were stratified by FI score, frailty predicted mortality, at least in females. The mouse clinical FI provides a valuable tool that can be used to evaluate healthspan in mice of different strains and in transgenic mice. Psychology Neuroscience 44th In-‐House Conference},
}

@inproceedings{pelley2018hubel,
  title = {Hubel & Wiesel - Their Contributions to Visual Research},
  author = {Pelley, Jessica},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {David H. Hubel and Torsten Wiesel were pioneers in studying the function and plasticity of the visual system. In 1958, at Johns Hopkins University, they began a collaboration that would continue for over 20 years. Their seminal work, including the 1959 paper "Receptive fields of single neurones in the cat's striate cortex" was some of the first research demonstrating that simple stimuli could have profound effects on the brain and behaviour. These findings ultimately led to the 1981 Nobel Prize in Physiology or Medicine "for their discoveries concerning information processing in the visual system". Their influences have extended to the Dalhousie community, influencing the research conducted by Donald Mitchell, Kevin Duffy and Nathan Crowder concerning the visual system. In 1998, David H. Hubel was awarded an honorary degree from Dalhousie University, and visited the medical school in 2004 as a Picchione Scholar to speak about his research on the influences of the environment on early-life brain development. Overall, the research of Hubel and Wiesel was crucial in developing the field of visual neuroscience and their lifetime contributions continue to impact and guide research within the Dalhousie community.},
}

@inproceedings{barresi2018freud,
  title = {Freud's Rat Man And The Meaning Of The Rat Torture},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Freud's 1909 case of obsessional neurosis of a patient called the Rat Man is unique in being the only case for which he saved his process notes. I provide a novel interpretation to the 'rat torture', which is the signature obsession in this case. This torture involves rats entering the anus of a prone victim from a pot. Freud provided an elaborate account of why the patient feared that this punishment would be given to his lady love and dead father. I propose, instead, that the patient's father engaged in anal sexual abuse with his children and provide evidence from the process notes that supports this hypothesis. I point out how this explanation is more congruent with Freud's original "seduction" theory than to his later "fantasy" theory of the basis for neuroses, and relate these two theories to recent debates over the possibility of recovered memories of childhood sexual abuse. Posters},
}

@inproceedings{myles2018patterns,
  title = {Patterns and Functions of Non-Suicidal Self-Injury among Adolescents with Concurrent},
  author = {Myles, Elizabeth M. and Apantaku-Olajide, Tunde and Brunelle, Caroline},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {In adolescents who engage in non-suicidal self-injury (NSSI), the prevalence of comorbid substance use can be as high as 60%. The co-occurrence of both behaviours in the same individual increases the risk of harmful consequences. The purpose of the current study was to examine adolescents exhibiting non-suicidal self-injury (with or without concurrent substance use) and compare the principal motives underlying its use. A total of 53 participants (Mage = 15.23, SD = 1.59), who underwent psychiatric assessment at the Child and Youth Addiction and Mental Health Services, between 2012 and 2015, completed a series of relevant questionnaires. Significant differences in intrapersonal reinforcement functions between the unitary NSSI and the comorbid groups, specifically with respect to positive reinforcement motives, were found. Based on these results, the nature of self-injurious behaviour may be experienced differently in individuals who also engage in substance use.},
}

@inproceedings{oleary2018effects,
  title = {Effects of probiotic treatment on maternal care, with outcomes for adolescent stress resiliency and gut health},
  author = {O'Leary, Authors Elizabeth},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Abstract: Prenatal and early postnatal events are important for shaping our development, including the stress response. The mechanisms by which early life events shape both the brain and stress response involve maternal care behaviour provided to offspring. The connection between the brain and intestinal tract, the "gut-brain axis", has also demonstrated modulatory effects on stress responding. The administration of probiotics in pregnancy, or early life has demonstrated to provide protective effects for early life stress, resulting in positive outcomes for offspring. To date, there has been no investigation into the effects of probiotics on maternal care behaviour quality, and subsequent offspring outcomes, such as anxiety-like behaviours, corticosterone levels, and gut health. To investigate these effects, we propose the following research aims: a) investigate differences in maternal care behaviours due to probiotic administration, and gut health outcomes in dams/ offspring and b) investigate offspring anxiety-like behaviours/stress responding, and biomarkers of stress and inflammation.},
}

@inproceedings{corkum2018better,
  title = {Better Nights, Better Days: An accessible and sustainable transdiagnostic intervention?},
  author = {Corkum, Penny and Team, the BNBD},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {Introduction: Behavioural insomnia in children is a common and impairing problem. Providing intervention in an accessible manner is critical. As such, we have been building and evaluating a suite of eHealth Interventions, called Better Nights, Better Days (BNBD). Methods: We are currently conducting a Canada-wide randomized control trial (RCT) for parents of typically developing children (BNBD-TD), have conducted four foundational studies to inform the development of BNBD for children with neurodevelopmental disorders (BNBD-NDD) and conducted focus groups to inform the development of a version for adolescents and young adults (BNBD-Youth). Results: While the RCT is still in progress, the results from the foundational studies have provided strong support for BNBD. Conclusions: BNBD shows promise as an accessible and effective eHealth intervention across ages and diagnoses. Sustainability of this program will be discussed. Psychology Neuroscience 44th In-‐House Conference},
}

@inproceedings{orr2018influence,
  title = {The influence of role-playing games on perceived social competence.},
  author = {Orr, Matthew},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {This study examined the relation between tabletop role-playing games and social competence in young adults. A mixed methods approach was used to extend previous research in this area. The Strengths and Difficulties Questionnaire was used to assess perceived social competence from participants and semi-structured interviews were conducted to collect detailed qualitative data about experiences with role-playing games. Six young adults (3 men, 3 women) between the ages of 19 and 24 (M = 21.2, SD = 2.6) participated. Responses on the SDQ indicated that people who play role-playing games have typical strengths and difficulties with respect to social competence. The qualitative description indicated the emergence of four themes: Content Focus, Social Focus, Creativity Focus, and Identity Focus. These themes are consistent with findings from previous case study research, in that role-playing games may have the potential to improve social competence.},
}

@inproceedings{muyingo2018meta,
  title = {A Meta-analysis of Partner Effects on Alcohol Use},
  author = {Muyingo, Lydia and Stewart, Sherry and Sherry, Simon},
  booktitle = {Psychology and Neuroscience 44th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2018},
  abstract = {The Partner Influence Hypothesis postulates that one partner's alcohol use (AU) influences the other's AU over time. While studies have documented romantic partner influences on drinking, results about the magnitude and sex-specific nature of such effects remains unclear. A meta-analysis (MA) is proposed to clarify the existence of partner influences on drinking in romantic couples, provide a more definite answer about the magnitude of such effects and to examine sex differences in the extent of partner influence. A comprehensive search will be conducted across six databases. Studies that have measured both members of a couple's AU across at least two time-points will be included. Data will be analyzed using Actor-Partner Interdependence Modelling and pooled effect sizes, and effect moderators will be examined. The results of this study will clarify the existence and strength of partner influences on AU. Moreover, the proposed MA could demonstrate how interpersonal relationships affect risky behavior.},
}

@inproceedings{barnard2019examination,
  title = {An examination of spectrin protein across development in human visual cortex, and following monocular deprivation in cat lateral geniculate nucleus.},
  author = {Barnard, Ilne L. and Goodyear, Lauren J. and Holt, Rhiannon N. and Kanji, Aliana and MacNeil, Katelyn and Pancura, Devan R. and Presunka, Madison and Proctor, Alexandra C. and Robertson, Madelaine K. and Duffy, Kevin R.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Disruption to normal vision during so-called critical or sensitive periods can modify the structure of neurons and neural connections, and can lead to a severe vision impairment called amblyopia. Decades of research on synaptic plasticity mechanisms have revealed the NMDA receptor plays a critical role in mediating the refinement modification of visual neural circuitry during the critical period. Spectrin is an actin-binding protein that has been implicated as a regulator of NMDA channel activity through its stabilizing effect on the receptor. Spectrin therefore is understood to play an enabling role in visual neural plasticity. In the current study, we quantified the level of spectrin protein in samples of human primary visual cortex (V1) across the lifespan, and we also measured the effect of monocular deprivation on spectrin labeling within the lateral geniculate nucleus (LGN). Our examination of human V1 revealed maximum spectrin at ages when plasticity levels are high. Further, we discovered that a brief period of monocular deprivation, sufficient to provoke structural modification, reduced spectrin within layers of the LGN serving the deprived eye. In aggregate, these results demonstrate a relationship between spectrin and neural modification in V1 and LGN, consistent with playing a regulatory role in visual system plasticity.},
  note = {Poster; booktitle inferred},
}

@inproceedings{macdiarmid2019independence,
  title = {On the independence of attentional mechanisms in temporal orienting: A replication study},
  author = {MacDiarmid, Kate and Al-Shammary, Fatema and LeBel, Cathryn and Rossi, Isabella},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Attention has been theorized to be composed of two networks: the exogenous network, which involves bottom-up processing; and the endogenous network, which involves top-down processing. A replication of a 2018 study by McCormick and colleagues was performed to provide further evidence for the independence of endogenous and exogenous networks in temporal attention (attention in time). We hypothesized that endogenous and exogenous temporal attention would be found to be independent from one another, as demonstrated by the effects of two measures: cue type and signal type. Fifteen participants performed a computerized task that measured reaction time as these two measures were manipulated. Data analysis revealed a significant effect of both cue and signal independence, as well as the cue and signal variance. Implications and limitations are discussed.},
  note = {Poster; booktitle inferred},
}

@inproceedings{ryken2019reading,
  title = {Reading comprehension, prosodic sensitivity, and the role of prosodic cues in text},
  author = {Ryken, Alexandra M. and Deacon, S. Hélène and Wade-Woolley, Lesly},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Reading comprehension, or the ability to understand the meaning of text, is one of the most important skills children learn in school. Understanding how various language skills support children's reading comprehension is essential to supporting early literacy development. One language skill which is related to reading comprehension in young readers is prosodic sensitivity, which is an awareness of the rhythmic cues in speech. However, the reason for this relationship is unclear. This study tested the possibility that children's awareness of how rhythmic cues are represented in text, e.g. through punctuation, may mediate the relationship between prosodic sensitivity and reading comprehension. Approximately 150 students in grades 3-5 were assessed, and awareness of prosodic cues in text did emerge as a partial mediator in the relationship between prosodic sensitivity and reading comprehension. Children may be using their awareness of rhythmic cues in text when attempting to understand what they read.},
  note = {Poster; booktitle inferred},
}

@inproceedings{reeve2019knowledge,
  title = {Knowledge of Spoken Words by Domestic Dogs: A New Instrument for Use With Dog Owners},
  author = {Reeve, Catherine and Jacques, Sophie},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Dogs are sensitive to human social cues (Miklosi & Topal, 2013) and can interpret physical and verbal cues from humans to gain information about new situations (Merola et al., 2012), or successfully complete tasks (Kaminski & Nitzschner, 2013). No reliable tool exists for determining which and how many words dogs know. The current study included a new measure designed to assess the number of words to which dogs respond differentially and systematically. Our tool was modeled after the MacArthur-Bates CDI (Fenson et al., 1994) for use with preverbal infants. Our first goal was to assess the content validity and usability of our online instrument, while our second was to use owners' responses to identify predictors of dogs' word understanding. Participants included 168 owners of dogs of various ages and breeds. Owners answered questions about themselves and their dog, and identified and rated the level at which their dog responded to each word in a checklist. Owners reported that their dogs responded selectively to 18 to 202 (M=89 words; SD=36) and variables such as dog owners' experience with dog training, how quickly dogs reportedly learned new tricks, and breed type showed predictive utility. Principal component analyses revealed that words to which dogs respond loaded onto 3 distinct, yet related components: general words, verbs, and nouns. Our tool not only allows for a standardized measurement of dogs' receptive abilities, but may eventually also become an important tool used to predict the potential of working dogs.},
  note = {Poster; booktitle inferred},
}

@inproceedings{watters2019forgetting,
  title = {Forgetting on purpose; How and what do we intentionally forget?},
  author = {Watters, Kaelen and Pandey, Anjali and Taylor-Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {This study examined the extent to which the visual characteristics of to-be-remembered and to-be-forgotten words are encoded into long-term memory. Using an item-method directed forgetting task, participants completed a study phase consisting of list of words presented one at a time, each followed by an instruction to remember or forget. In a subsequent test phase, participants then made yes-no recognition decisions to: 1) 'remember' and 'forget' words from the study phase; 2) unstudied foil words; and, 3) unstudied foil words that looked similar to the 'remember' and 'forget' words. We expected a directed forgetting effect, with greater recognition of 'remember' words than 'forget' words. However, our main interest was in determining whether visual similarity to studied words increases the false alarms made to unstudied words and, if so, whether this tendency is influenced by whether the unstudied word looks similar to a 'remember' item or a 'forget' item.},
  note = {Poster; booktitle inferred},
}

@inproceedings{usai2019investigatin,
  title = {Investigating the neural bases of self-monitoring of speech in people with aphasia: an ERP study},
  author = {Usai, Francesco and Ouellette, Heather and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Aphasia is a communication disorder that can impair the ability to find the right words, name things correctly, and to monitor one's own speech for the presence of errors. Little is known about the neural bases of self-monitoring of speech in aphasia. To address this gap, we recorded EEG from people with aphasia (current n=2) while performing a picture-naming task, and observed the effect of response accuracy on the error-related negativity (ERN), an EEG effect associated with performance monitoring across different cognitive domains. The time course and scalp topographies of EEG were contrasted for incorrect and correct responses. For one participant, this contrast resembled the ERN, while the other showed an effect with a similar time course but with opposite polarity (i.e., a positivity). These differences may be explained by the different neuropsychological profile of the two subjects, although these preliminary results provide encouraging evidence that the ERN may be a useful marker of self-monitoring in aphasia.},
  note = {Poster; booktitle inferred},
}

@inproceedings{brown2019behavioural,
  title = {Behavioural characterization of the Nrxn1+/- mouse model of autism spectrum disorder},
  author = {Brown, Spencer L. and Sahiti, Qendressa and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Autism spectrum disorder (ASD) is a neurodevelopmental disorder that is characterized by deficits in social interaction, increased repetitive and stereotypical behaviours, and abnormal responses to sensory stimulation. Previous research has linked the causation of ASD to complex gene-environment interactions, which are not fully understood. Neurobiologically, ASD has been associated with abnormalities in synaptic connectivity in the brain, and mutations in the neurexin cell adhesion protein family have been identified in individuals with ASD. The Nrxn1+/- mouse is a novel knock-out model of ASD that carries only one functional allele of neurexin 1. The behavioural phenotype of this mouse is unknown and knowledge of the behavioural phenotype is essential because the diagnosis of ASD is based on behavioural symptoms. In this study we tested 20 Nrxn1+/- mice (10M, 10F) and 20 C57BL/6J wild-type control mice (10M, 10F) at two months of age in a behavioural test battery. This included 16 tasks that evaluated cognitive and motor performance, mood and anxiety, stereotypical behaviour, social interaction, and visual ability. While the Nrxn1+/- mice showed no cognitive or social deficits compared to the wild- type mice, they performed worse on some motor tests and showed increased levels of anxiety. These preliminary results give some indication of the behavioural effects of the expression of neurexin 1. We are currently extending our test battery and testing mice at other ages to determine if they show age-related changes in their behavioural phenotype.},
  note = {Poster; booktitle inferred},
}

@inproceedings{cochrane2019why,
  title = {Why Don't We Spend Time In Nature?: A Thematic Theory-Driven Analysis},
  author = {Cochrane, Sara and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Spending time in nature has been shown to have several health-enhancing benefits, including improved physical health, mental health, cognitive functions, and overall well-being. However, despite a stated interest in spending time outside and in natural environments, people spend only 5% of their time in nature. The objective of this study was to better understand why people do not spend time in nature. We developed a semi-structured interview based on the Theory of Planned Behaviour (TPB) to examine beliefs and attitudes, as well as subjective norms, intentions, and perceived behavioural control about health-related behaviours, and specifically, spending time in nature in an undergraduate sample. Thematic analysis was employed to examine the interview responses. An improved understanding of nature disconnection will aid in the development of behaviour change interventions that will target increasing time spent in nature in order to improve mental, physical, and cognitive health.},
  note = {Poster; booktitle inferred},
}

@inproceedings{derby2019emergence,
  title = {The Emergence of Envy and Schadenfreude Through Social Comparison and the Disappointing Gift Paradigm},
  author = {Derby, Brianne and Hudson, Amanda and Jacques, Sophie},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Previous studies have found that social emotions such as envy and Schadenfreude typically emerge in situations of social comparison. The purpose of our study was to examine children's ability to control their displays of these negative social emotions. While envy is considered to be discontent with other's successes, Schadenfreude is the pleasure of another's misfortune. We hypothesized that older children would be better at masking social emotions. Younger children aged 49 to 78 months and older children aged 78 to 132 months were tested using the disappointing gift paradigm in situations of social comparison. Results found that older children were more advanced at masking emotions of envy and Schadenfreude whereas younger children were more influenced by social comparison in the disappointing gift paradigm. Future research should compare children's reactions in the disappointing gift paradigm when comparing themselves to adults in contrast to other children.},
  note = {Poster; booktitle inferred},
}

@inproceedings{drake2019seeing,
  title = {Seeing the forest for the trees in large cognitive datasets},
  author = {Drake, Richard S. and MacKinnon, Sean P. and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Computerized cognitive assessments produce a rich set of data that can be difficult to condense. Each variable typically generates two scores, response speed and accuracy, and many variables are needed to adequately measure performance on target constructs (e.g., subcomponents of working memory or attention). Experimental manipulations such as variable response-stimulus intervals further expand the dataset. Using the output of the Dalhousie Computerized Attention Battery (DalCAB) as an exemplar, we showcase a method of maintaining and manipulating a database, selecting and combining relevant variables, using planned contrasts to visualize the overall pattern of results, and testing for differences using a multilevel modelling approach wherein individuals are nested within variables. The described approach may be used in both single-measurement and intervention (pre-post) research. Using our method, we report the results of a three-week intervention study comparing a dual n-back working memory training game to passive and active control groups.},
  note = {Poster; booktitle inferred},
}

@inproceedings{forward2019relating,
  title = {Relating Pupillometric and Behavioural Indices of Effort in Item-Method Directed Forgetting},
  author = {Forward, Evan F. and Greenham, Julia C. M. and Alves, Marcus V. and Taylor, Tracy L. and Fawcett, Jonathan M.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Forgetting in an item-method directed forgetting paradigm has been shown to slow responses in the period immediately following the forget instruction and to facilitate removal of attention from the representation of the preceding study item, including its spatial location. These findings have been interpreted as evidence of an active control process associated with the cessation of rehearsal. However, recent findings using pupillometry have also produced conflicting evidence favouring relatively reduced processing demands immediately following the forget instruction as evidence by relatively larger pupil dilation following the remember instruction. The current experiment sought to compare these findings directly by integrating both pupillometry and a secondary probe response task into the same directed forgetting task. Both effects replicated: In addition to a significant directed forgetting effect - with greater recognition of remember than forget items at test - we observed longer response times following forget instructions but larger pupil dilations following remember instructions. We discuss ways in which these findings may be integrated into a more coherent theoretical framework.},
  note = {Poster; booktitle inferred},
}

@inproceedings{good2019searching,
  title = {Searching for a Target: Do Older Adults Check the Template More Often?},
  author = {Good, Samantha and Aziz, Jasmine and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Some cognitive processes important for daily tasks deteriorate with age, including working memory and visual search abilities. Working memory is required to maintain a target template (i.e., image of target object) in mind during visual search. We examined age differences in visual reliance on a target template displayed during search to enhance our knowledge of changes in visual search ability with age. Ten younger (18-35 yrs) and 38 older (55-80 yrs) participants (to date) completed a visual search task while eye movements were monitored. We manipulated the number of target features (one or three) and the number of distractors in the visual scene. Older adults were expected to show increased reliance on the target template (i.e., more eye movements towards the template and longer fixations) than younger adults, particularly as the number of features and distractors increased. Results will provide further knowledge on the changes in cognitive functions with age and can be implemented to promote maintenance of cognitive performance across the life-span.},
  note = {Poster; booktitle inferred},
}

@inproceedings{idrisova2019influence,
  title = {The Influence of Varying Foreperiods on Error Rate and Reaction Time},
  author = {Idrisova, Aydan and Kamali, Kiyana and Macdonald, Olivia and Ross, Briana G. and Feltmate, Brett B.T. and McCormick, Colin R. and Redden, Ralph S.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Attention is defined as the process of focusing on one stimulus while simultaneously ignoring others. In 1973, Posner, Summers, Klein, and Buggie investigated how a warning signal affects alertness and accuracy. We aimed to replicate their first experiment which provided evidence of speed-accuracy tradeoff and confirmed that rapid response times did not improve accuracy. Reaction time and error rate were measured during the manipulation of foreperiods, as well as compatible or incompatible response conditions. Seventeen subjects participated. The response condition was cued by the border of the screen. A warning signal was played prior to the presentation of the target stimulus. The subjects responded to the stimulus by pressing the key on the same side as the target, or the opposite side. Error rate was the smallest for shorter foreperiods but these reaction times were the longest, therefore supporting the speed-accuracy tradeoff found by Posner et al.},
  note = {Poster; booktitle inferred},
}

@inproceedings{lebelle2019even,
  title = {Even Further Evidence in Favor of Prior Entry from Endogenous Attention to a Location in Space: A Replication Study},
  author = {Lebelle, Kirsten M. and MacIntosh, Morgan G. and Tse, Samantha S. and Fashir, Sana M. and Feltmate, Brett B.T. and McCormick, Colin R. and Redden, Ralph S.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {The laws of prior entry state that attended objects are perceived faster than unattended objects. Previous research has provided contradictory results about the presence of prior entry (Shore et al., 2001; Schneider & Bavelier, 2003). The goal of our current experiment was to replicate a previous study by Redden et al. (2017) which incorporated an orthogonal color probe task into the original TOJ paradigm in order to settle the discrepancy in previous literature and determine if prior entry exists under endogenous cueing. We hypothesized that prior entry would show effects under the endogenous cueing condition. The present study used a modified TOJ task with an orthogonal color probe task to further reduce any response biases and assess prior entry independent of response mechanisms. Effects of attention on prior entry and probability of color encoding were replicated from Redden et al. (2017). Other findings from the experiment will be discussed.},
  note = {Poster; booktitle inferred},
}

@inproceedings{klein2019potential,
  title = {On the potential for wearable technology in the modeling of vigilance and fatigue for aeronautic applications},
  author = {Klein, Raymond M. and Feltmate, Brett and Hurst, Austin and Kopf, Maelle and Gagnon, Jean-François},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Fatigue-related decreases in vigilance (hypovigilance) and their negative effects on performance are widely recognized as posing a serious risk to aviation safety. Scientists at Thales Research & Technology (TRT) Canada (Quebec) collaborated with the Klein laboratory to design and conduct a research project in which participants performed tasks over an 8 hour period during which a variety of physiological, oculomotor and performance parameters, and self-reports of fatigue, were collected either continuously or regularly. Thales scientists then developed a mathematical model that from the physiological data could predict fatigue-related hypovigilance; a model that was successful when generalized to "new" data and that was recently tested in a more ecologically valid scenario (an intercontinental flight). In a followup project the Dalhousie-Thales team plans to test the efficacy of mitigation measures of hypovigilance based on this model's on-line analysis of wearable data collecting during performance on a driving-like task.},
  note = {booktitle inferred},
}

@inproceedings{shapiro2019optogenetic,
  title = {Optogenetic Modulation of the Excitatory-Inhibitory Balance of Mouse V1 Responses to Drifting Sinusoidal Gratings},
  author = {Shapiro, Jared T. and King, Jillian L. and Crowder, Nathan A.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {The primary visual cortex (V1) has served as a model brain region for studying cortical information processing because it is the first cortical stage of the visual pathway, and a region where several novel computations arise. Recent work has investigated the neuronal circuits underlying receptive field properties of mouse V1 neurons due to the many genetic tools available in this species that enable cell-specific targeting and perturbation. One such genetic tool is optogenetics, which has been previously used to demonstrate how distinct classes of inhibitory GABAergic interneurons can affect the excitatory drive of V1 pyramidal cells. Importantly, this past work has focused on optogenetic modulation of the onset and sustained responses of V1 pyramidal cells, but has given no attention to the pattern of activity evoked after photostimulation is terminated. We used optogenetics and in vivo electrophysiology to investigate the role of parvalbumin-expressing interneurons (PV+) in V1 circuitry, and specifically how these interneurons affect pyramidal cell after- responses. We have demonstrated that termination of photostimulation produces a "rebound effect" on pyramidal cell activity, which facilitates their after-responses to flashed bars and sinusoidal gratings. We investigate whether this "rebound effect" is also produced from drifting sinusoidal gratings.},
  note = {booktitle inferred},
}

@inproceedings{shaw2019conduction,
  title = {Conduction velocity and synaptic delay at photoreceptor - amacrine reciprocal synapses in the fly's eye.},
  author = {Shaw, Steve},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Visual search and working memory abilities decline with age, which can interfere with daily activities. During visual search, working memory helps us remember target features and previously searched locations. Thus, we investigated whether working memory abilities would predict visual search efficiency in healthy older adults. Thirty participants (55-78 yrs) completed working memory measures and a visual search task. We varied working memory load by manipulating whether a reference picture of the target (i.e., target template) was displayed during the search. We also recorded eye movements to determine how frequently participants looked at the target template. Visuospatial working memory abilities predicted better conjunction search performance, and verbal working memory abilities interacted with the template presence/absence, although independently of template fixation time. Findings clarify how visual search abilities relate to working memory in older adults and could be helpful for developing ways to support these abilities in aging and relevant clinical populations.},
  note = {booktitle inferred},
}

@inproceedings{fertan2019understandin,
  title = {Understanding the role of amyloid beta in Alzheimer's disease pathogenesis: teaching an old dog new tricks},
  author = {Fertan, Emre and Brown, Richard E. and Weaver, Ian C.G.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Alzheimer's disease (AD) was first described by Dr. Alzheimer in the beginning of the 20th century, based on the observation of "military fossa" made of a "special substance". In the 1980's this substance was identified as amyloid beta, which gave birth to the amyloid cascade hypothesis. However, for many years, the exact role of amyloid beta in the deficits seen in AD remained unknown and many believed that it functioned as a physical barrier in the synapse, hindering the chemical transmission. To explain the other, seemingly unrelated, symptoms, many other theories have been proposed regarding immune dysfunction, oxidative stress, tau phosphorylation. Recently, studies began to appreciate the role of amyloid beta in these "unrelated" disease mechanisms. My talk will focus on our recent work, in which we studied the connection between the increase in amyloid beta, oxidative stress, immune dysfunction and tau phosphorylation in terms of the kynurenine and TRX reduction pathways.},
  note = {booktitle inferred},
}

@inproceedings{rv2019effects,
  title = {Effects of LPS-Induced Maternal Immune Activation on Expression of Autism-Linked Genes and Autism-Like Behaviours in Neonates and Adulthood},
  author = {RV, Wheeler and ICG, Weaver and TB, Franklin},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Epidemiological studies have revealed a link between maternal immune activation (MIA) and autism-spectrum disorder (ASD) risk. To date, the literature has primarily focused on the effects of LPS-MIA in adult male mice; there are few reports describing the behavioural effects of LPS-MIA in female mice or early in development. Further, the involvement of the mammalian target of rapamycin (mTOR) signaling pathway, a risk factor for ASD, has not been studied in this model. In the current study, we injected pregnant C57BL/6J mice with 75µg/kg of LPS on embryonic day 11.5 and 12. Male and female offspring were tested during development and at adulthood for the three core symptoms of ASD: social communication, social interaction, and repetitive behaviours. Additionally, the expression, protein abundance and activity-induced phosphorylation of mTOR and its downstream effect on post-synaptic density 95 (PSD95) was analysed in hippocampal and cortical areas of offspring at postnatal day zero (P0) and},
  note = {booktitle inferred},
}

@inproceedings{rodrigues2019effects,
  title = {Effects of forebrain ATRX deficiency in C57/B6 male mice on offspring ATRX expression and forebrain development: maternal nurture meets offspring nature},
  author = {Rodrigues, Gloria and Lee, Kristen and Maillet, Hillary and Goguen, Donna and Weaver, Ian},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Early childhood experience and degree of parental-infant attachment influence the developing brain, notably in brain areas that support stress regulation, cognition and social behaviours. Siblings of children with autism have an increased relative risk of autism themselves, suggesting a role of gene x environment interactions in the etiology of autism. Although the exact mechanism is not completely understood, the autism risk gene, Atrx, is regulated by maternal behaviour. ATRX is a chromatin remodeling factor that is essential for brain development and plasticity; even small changes in expression and signaling can cause synaptic deficits and contribute to neurodevelopmental disorders. My talk will focus on our recent work, in which we studied the connection between maternal care and the development of brain regions relevant to autistic-like behaviours in the adult offspring of litters containing either wildtype female and male mice or wildtype female and Atrx hemizygous male mice. Our findings demonstrate a persistent effect on forebrain growth, Atrx gene expression and promoter methylation, not only in the ATRX deficient male mice, but also in their heterozygous female litter mates. These results suggest a role of early life environment and ATRX expression in pathological mechanisms underlying long-term chromatin plasticity and neural growth relevant to neurodevelopmental disorders such as autism.},
  note = {booktitle inferred},
}

@inproceedings{kosel2019phenotypic,
  title = {Phenotypic contagion of aggression in male 5xFAD mice},
  author = {Kosel and F and Hamilton and J and Godin and V and Harrison and S and Franklin, T.B},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Alzheimer's disease (AD) is a progressive neurodegenerative disorder that is characterized by a number of cognitive and behavioural effects, including increased agitation and aggression, as well as depressive symptoms, anxiety, irritability, and other neuropsychiatric symptoms. We previously found that females of the 5xFAD transgenic mouse model of Alzheimer's disease exhibit decreased social investigation that mimics the social withdrawal observed in AD patients. This study examines whether transgenic 5xFAD males also exhibit decreased social investigation, and whether transgenic 5xFAD males model the increased aggression observed in many male AD patients. We tested male 5xFAD mice in behavioural tests for sociability, social novelty preference, and free social interaction, as well as examining home-cage interactions. Results suggest that transgenic males exhibit decreased social interest and altered aggressive behaviours compared to wild-type controls, suggesting that they may provide a useful model of aggression and social withdrawal in AD patients.},
  note = {booktitle inferred},
}

@inproceedings{mccormick2019reducing,
  title = {Reducing Cognitive Demand to Explore the Speed Accuracy Trade-off in Endogenous and Exogenous Temporal Cueing},
  author = {McCormick, Colin and Redden, Ralph and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Recently (McCormick, Redden, Lawrence, and Klein, 2018), we observed the independence of exogenous and endogenous temporal attention when implementing a novel signalling method (Lawrence & Klein, 2013) within the canonical temporal cueing paradigm (Kingstone, 1992). However, in an attempt to alleviate task demand, we were limited to the analysis of detection responses instead of the more informative discrimination responses. This is because we were unable to obtain TCEs in the endogenous condition when using discrimination responses, which we suspect was due to the large cognitive load generated from a combination of stimulus and task demands. For the current proposed experiment, we have modified methodological components to alleviate cognitive demand to allow for the implementation of discrimination targets in the Kingstone paradigm, providing opportunity to analyze speed-accuracy trade-off differences for endogenous and exogenous temporal attention. All project materials can be found on the Open Science Framework (https://OSF.io).},
  note = {booktitle inferred},
}

@inproceedings{pandey2019what,
  title = {What Information Escapes An Instruction to Forget?},
  author = {Pandey, Anjali and Taylor-Helmick, Supervisor: Tracy},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {The directed forgetting effect is a phenomena characterized by participants recalling or recognizing more remember instructed than forget instructed items. However, not all forget instructed items are removed from memory and while it can be concluded that an instruction to forget decreases the probability of a memory representation later being retrieved, standard recall or recognition tests reveal nothing about the fidelity of those representations. In looking at what aspects of words (sound, appearance, meaning) escape initial attempts to prevent encoding when the intention is to forget, we expect that the retrieved representations of forget instructed words will be impoverished on the aspects investigated. The results of a recognition test following a typical item- method study phase will be analyzed to compare the mean false alarms of critical foils against those of unrelated foils, with a greater false alarm rate to critical foils suggesting that the single shared aspect between the study and test word is part of what was encoded.},
  note = {booktitle inferred},
}

@inproceedings{aslam2019relationship,
  title = {On the relationship between spatial compatibility effects and Inhibition of Return},
  author = {Aslam, Sinan and Redden, Ralph S. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Inhibition of return (IOR) is an increase in reaction time when orienting to targets that have been previously attended to. The Simon effect is a tendency to respond faster to targets presented in a location spatially compatible with the response. We explored the consequences of the Simon effect on targets suffering from IOR when the frequency of targets is altered. This was accomplished by having participants distributed amongst three conditions where the Simon target was presented in either 20%, 50% or 80% of trials. The remaining trials required a reporting the direction of a centrally-presented arrow. We expect to see a linear change the Simon effect as a consequence of target frequency, where the Simon effect may increase with more directional responses (80% arrows), or the Simon effect may increase with more peripheral events (80% Simon targets). Furthermore, the degree to which IOR impacts this change will be explored.},
  note = {booktitle inferred},
}

@inproceedings{oneil2019auditory,
  title = {Auditory Language Processing in the Visual Cortex of Blind Individuals},
  author = {O'Neil, Kiera and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {In people who are blind, the visual cortex takes on a new linguistic function and becomes involved in processing speech, something that is not seen in sighted people. However, the exact role of the visual cortex in auditory language processing in people who are blind is unclear. Establishing how the visual cortex is integrated into the existing language network may shed light on its specific role. We collected fMRI data from two groups of participants, congenitally blind adults (n = 6) and sighted controls (n=10). Participants made matching decisions about auditorily presented pairs of words (meaning, rhyme, speaker) and performed a n-back task. We found visual cortex activity in the blind group but not the sighted group during linguistic and verbal memory tasks. Our next step is to determine how the visual cortex is connected to other regions in the language network (via dynamic causal modelling) and how those connections might change depending on what type of language processing is occurring.},
  note = {booktitle inferred},
}

@inproceedings{omisade2019prognostic,
  title = {Prognostic biomarkers of seizure recurrence after first seizure and in New Onset Epilepsy},
  author = {Omisade, Megan Vincent (Supervised by Dr. and Fisk), Dr.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {This study seeks to establish prognostic markers of developing epilepsy after a first seizure (FS) or seizure recurrence despite treatment in patients with new onset epilepsy (NOE). Predicting seizure recurrence may facilitate early treatment and reduce disease burden. Our primary objective is to determine if cognitive impairment, mood, and socioeconomic status (SES) can predict seizure recurrence after FS or NOE. We will select 50 patients with NOE or FS at the Halifax First Seizure Clinic. Baseline testing will be conduced and includes measures of major cognitive areas and mood symptoms. Follow-up testing using the same measures will be conducted after 1 year. Chart review will determine 1) seizure recurrence since initial visit 2) baseline results and 3) clinical and demographic measures (diagnostic test results, seizure frequency, SES). The patients will be divided into two groups based on seizure recurrence since baseline: no seizures vs 1+ seizures. Regression analyses will determine if baseline measures are predictive of seizure recurrence.},
  note = {booktitle inferred},
}

@inproceedings{rosenberg2019how,
  title = {How Does Morphological Awareness Contribute to Reading Comprehension in Beginning Readers: A Mediation Analysis},
  author = {Rosenberg and Lindsay and Levesque and Kyle and Deacon, Helene},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Reading comprehension, the ability to comprehend the message that written words convey (Nation, Cocksey, Taylor, & Bishop, 2010), is the primary goal of reading. Morphological awareness is the awareness of, and ability to manipulate, meaningful units in spoken language (teach + -er = teacher) (Carlisle, 1995). Morphological analysis is using awareness to infer the meaning of a word (e.g. treelet = small tree, because -let means small). Both morphological awareness and analysis are associated with reading comprehension. Building on previous research with grade 3 students, this study will examine how morphological awareness contributes to reading comprehension at the grade 1 level. The study will assess whether morphological awareness and analysis are separate dimensions for beginning readers and whether morphological analysis and word reading ability are mediating factors in the relationship between morphological awareness and reading comprehension. This study will assess 200 grade 1 students on morphological analysis, morphological awareness, word reading, and reading comprehension. It is predicted that morphological analysis will have a larger mediating role compared to word reading.},
  note = {booktitle inferred},
}

@inproceedings{ali2019relation,
  title = {The Relation Between Hot and Cool Inhibitory Control and Temperament in 3- to 7-Year-Olds},
  author = {Ali, Tasnim and Jacques, Sophie},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Temperament refers to children's individual differences in emotional, motor, and attentional reactivity and their ability to self-regulate those reactions (Rothbart, 2007). In this study, we examine the relation between Rothbart's three temperament dimensions and their individual relations with hot and cool inhibitory control processes in children aged 3-7 years. Hot and cool inhibitory control processes are cognitive processes that allow children to withhold dominant responses to stimuli when required to solve novel and difficult problems in affective and neutral contexts, respectively. Three- to 7-year-olds were given hot and cool versions of three inhibitory control tasks: the Flanker task, the Stroop task, and the Go-No-Go task and their parents were given the short form of Rothbart's Children Behaviour Questionnaire (Putnam & Rothbart, 2006). We predicted a negative correlation between scores on the two affective dimensions of temperament (negative affect and surgency), and performance on both versions of the inhibitory control tasks, with stronger negative correlations for the hot versions. However, we predicted a positive correlation between performance on both versions of the inhibitory control tasks, and effortful control, the self-regulatory dimension of temperament. Only some of the predicted correlations were significant with the sample we collected to date.},
  note = {booktitle inferred},
}

@inproceedings{mackinnon2019software,
  title = {The Software Wars: SPSS vs. R (and beyond)},
  author = {Mackinnon, S. P},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {There is increasing, vociferous debate on which statistical software to use in the social sciences. On one side are the SPSS users, who are accused of using antiquated methods, having non-transparent workflows, and producing extremely ugly graphs. On the other side are the R users, who can in theory create better final products, but in practice take an enormous amount of time unless they are experienced coders (who frequently use their remaining time to tell SPSS users why they are bad at statistics). I will discuss my experiences with both software types in research and teaching, with an eye to finding solutions that are (a) reproducible, (b) make use of modern statistical practices; and are (c) easy to learn and time-efficient. I will highlight a new free point-and-click statistical software "Jamovi" that provides a hybrid of point-and-click efficiency with the flexibility of R coding that may prove useful for teaching.},
  note = {booktitle inferred},
}

@inproceedings{bailey2019sinister,
  title = {Sinister Participants: Is modern neuroimaging a right-handed tool?},
  author = {Bailey, Lyam M. and McMillan, Laura E. and Newman, Aaron J.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Approximately 10% of humans are left-handed or ambidextrous (adextral). It has been suggested that this demographic is largely avoided by researchers within the neuroimaging community. To date, however, no formal effort has been made to quantify the extent to which adextrals are excluded from neuroimaging-based research. Here we aim to address this question in a review of over 1,000 recent articles published in high-impact, peer-reviewed, neuroimaging-focused journals. Specifically, we sought to ascertain whether, and the extent to which adextrals are underrepresented in neuroimaging study samples. Handedness data was available for over 30,000 research subjects; only around 3% of these individuals were adextral - considerably less than the 10% benchmark one would expect if neuroimaging samples were truly representative of the general population. This observation was generally consistent across different areas of research, but was modulated by the demographic characteristics of participants. The epistemological and ethical implications of these findings are discussed.},
  note = {booktitle inferred},
}

@inproceedings{arora2019does,
  title = {Does Question Phrasing Matter? A mixed-methods analysis of Student Ratings of Instruction.},
  author = {Arora, Swasti and Stamp, Jennifer and Stevens, Leanne and Cormier, Marcus and Jones, Gisela},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {The efficacy of Student Ratings of Instructions (SRIs) is often questioned by teaching professionals. Much research has been done on this topic, and meta-analyses have supported the use of SRIs as indicators for teaching effectiveness and tools for course development (Cohen et al. 1981). However, the colloquial discussion shows a divided opinion among instructors and faculty (Theall, M. (2001). The current study explores the importance of SRI question structure as a predictor of course feedback depth and content. Facilitated by the use of qualitative analysis software, 2,780 student responses collectively were coded from 2015 and 2016 SRIs from an Introductory Psychology course. A codebook of 23 codes, associated with 7 overarching themes and 7 contexts to which codes could correspond was established. Rates of code occurrence and co-occurrence were then calculated between open-ended questions and questions which were structured to address specific aspects of course material and development.},
  note = {booktitle inferred},
}

@inproceedings{conrad2019psychophysio,
  title = {The Psychophysiology of Mind Wandering During Online Lectures},
  author = {Conrad, Colin and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Mind wandering is a construct which describes presence of task unrelated thoughts, and is often identified as an experience that is detrimental to the efficacy of education. However, there has been relatively little research into the impact on mind wandering on education because it is difficult to measure. In this presentation, we will describe the results of two experiments that establish the foundation a covert auditory attention EEG measure which is correlated with reported mind wandering states. In the experiments, participants watched an online lecture video while task-irrelevant audio tones were played in the background. We found significant differences in Event Related Potentials evoked from auditory stimuli during reported mind wandering. The results present a foundation for a larger project in exploring the potential of real-time EEG detection for use in the improvement of education technologies or other information technologies, as well as new types of brain-computer interfaces.},
  note = {booktitle inferred},
}

@inproceedings{deacon2019how,
  title = {How do children become good word readers: The role of learning about how print works.},
  author = {Deacon, S. Hélène and Conrad, Nicole},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {A core question in models of word reading lies in which skills predict individual differences in reading acquisition: specifically, why is it that some children struggle to learn to read, while others acquire reading skill with apparent ease? Most models point to orthographic processing, or knowledge of letter- and word-patterns, as key to children's progress in word reading development. Unfortunately for these models, empirical evidence has not born out this prediction, with multiple studies now showing that orthographic processing is an outcome, rather than a determiner of word reading, at least when measured with traditional tasks. In this talk, I present a new theoretical conceptualisation of orthographic processing, one that includes children's first steps into learning about how printed words work. I also show new evidence that children's appreciation of these early aspects of orthographic features predicts their progress in learning to read.},
  note = {booktitle inferred},
}

@inproceedings{feltmate2019estimating,
  title = {Estimating the Probability and Fidelity of Encoding during the Attentional Blink},
  author = {Feltmate, Brett B. T. and Redden, Ralph S. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {When participants are required to report the presence or identity of two targets presented in close temporal sequence, they are often able to recall that of the first (T1), but not the second (T2). Referred to at the 'attentional blink', this phenomenon is thought to reflect the tying up of resources needed for target processing by T1 leaving them unavailable for T2 processing. Herein we argue that in conventional 'blink' tasks success is measured in dichotomous fashion, thereby conflating two potential sources of recall error: the probability of, and the fidelity to which, T2 is encoded into visual short-term memory. We attempted to generate independent measures of probability and fidelity by making colour our relevant target domain. Target colouring was randomly sampled from within a colour wheel, and responses were made by clicking within the same wheel allowing us to record the degree of error in a given response. Obtained estimates of our parameters are assessed in exploratory fashion and their implications are discussed herein. All pre-registered materials can be found on the OSF at https://bit.ly/2BSHIKH.},
  note = {booktitle inferred},
}

@inproceedings{barresi2019building,
  title = {On Building a Person: Recent Advances and Limitations in the Construction of Robots that Attempt to Mimic Capacities of Human Persons},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Based on criteria of personhood that robotic agents should pass for them to match us in social intelligence, I describe some recent successes as well as difficulties for the future with respect to these criteria. I give illustrations of research in several areas where advances have been made: 1) Evolutionary robotics; 2) Developmental robotics; 3) Knowledge sharing; 4) Robo-science.},
  note = {booktitle inferred},
}

@inproceedings{orr2019systematic,
  title = {A Systematic Review Examining In-Class Interventions for Students with Attention-Deficit/Hyperactivity Disorder in the Mainstream Classroom},
  author = {Orr, Matt and Brine, Sarah and Ali, Nicole and Corkum, Penny},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {It is difficult for teachers to meet the needs of students with ADHD and in-class interventions could help to provide effective support. However, access to information about evidence-based in-class interventions is limited. A systematic review was conducted to determine what evidence-based in-class interventions for ADHD are present in the literature. Fourteen studies examining in-class interventions for ADHD were identified and reviewed. These studies featured a variety of interventions such as tactile cueing, self-management strategies, and peer monitoring. Studies were of moderate-to-high methodological quality. The available evidence does not meet the criteria of evidence-based interventions, suggesting that the summarized studies cannot be confidently recommended as in-class interventions for students with ADHD.},
  note = {booktitle inferred},
}

@inproceedings{hagen2019dose,
  title = {Dose-Response Relationship of Alcohol on Self-Relevant Negative Thought Content in Major Depressive Disorder},
  author = {Hagen, Amanda E.F. and Stewart, Sherry H.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Major depressive disorder (MDD) and alcohol use disorder co-occur and are associated with poorer outcomes. Of possible underlying mechanisms, the self-medication hypothesis posits that individuals with low mood may drink to improve their mood. There is evidence that low doses improve mood, but that mood decreases at higher doses. Individuals with MDD may find alcohol reinforcing due to the alleviation of cognitive symptoms, e.g. negative self-thinking. One study showed that alcohol dampens negative self-relevant thinking at moderate doses in individuals with mild depression symptomology. Extending this, the current study will studying those with MDD and examine different doses of alcohol. We hypothesize the relationship between mood and dose will be extended to cognitive factors. Individuals with depression will be randomly assigned to either no alcohol, low alcohol, or high alcohol conditions, before completing the word task. This study will help understand mechanisms of this comorbidity to inform specific interventions.},
  note = {booktitle inferred},
}

@inproceedings{jemcov2019feasibility,
  title = {Feasibility testing of the ABCs of SLEEPING tool as an intervention},
  author = {Jemcov, Anastasija and Corkum, Dr. Penny},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Behaviourally-based sleep problems are common among school-aged children, are highly treatable, but due to a number of barriers, very few children receive evidence-based behavioural interventions. The ABCs of SLEEPING tool was developed to facilitate the assessment of sleep problems by identifying healthy sleep practice strengths and areas in need of improvement, and to provide parents with evidence-based recommendations. Using Bowen and colleagues (2010) "Does It Work?" feasibility framework, the tool will be tested for its acceptability, implementation, and limited-efficacy, using a cohort, pre-test/post-test design.},
  note = {booktitle inferred},
}

@inproceedings{chambers2019effective,
  title = {Effective solutions for managing procedural pain related to vaccinations},
  author = {Chambers), Nicole MacKenzie (Supervisor: Dr. Christine},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Children often experience pain during vaccinations, however many parents are unaware of evidence-based strategies available for managing vaccination pain. A knowledge translation (KT) resource was previously developed to summarize evidence- based strategies for managing children's vaccination pain. This study aimed to examine parents' perceptions and plans to use this KT resource using the Information Assessment Method (IAM) to assess the relevance, cognitions, utility, and benefits of the resource. Attitudes toward vaccines were also measured. 312 parents completed this survey and 97% demonstrated little to no vaccine hesitancy. Vaccine attitudes were negatively correlated with relevance of the KT resource (rs = -.17, p = .003) and intention to use the information (rs = -.14, p = .012), indicating that vaccine accepting parents were more likely to be receptive and planned to use the strategies. This study highlights key factors which impact parents' plans to use KT resources for vaccination pain management.},
  note = {booktitle inferred},
}

@inproceedings{aronitz2019examination,
  title = {Examination of NMDA receptor subunit composition in the developing cat visual cortex.},
  author = {Aronitz, Elise and Duffy, Kevin R.},
  booktitle = {Psychology and Neuroscience 45th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2019},
  abstract = {Many brain regions exhibit a period during early development called a 'critical period', when the capacity for neural plasticity is high, and neural circuitry is rapidly modified in response to neural activity. In the primary visual cortex of mammals, this capacity for rapid modification has allowed for the refinement of functional characteristics of neural circuitry that optimize visual performance. Following waning and closure of the critical period, neural circuitry within the visual system exhibits minimal capacity for modification. Changes in plasticity that occur throughout development are thought to occur as a result of a change in the subunit composition of the NMDA receptor. We will employ a novel approach to quantifying the ratio of NMDA receptor subunits across development that involves multiplex fluorescence imaging.},
  note = {booktitle inferred},
}

@inproceedings{bagnell2022perinatal,
  title = {Perinatal Grief as a Mediator Between Religiosity and Sexual Satisfaction Among},
  author = {Bagnell, K. Brenna and Allsop, David B. and Rosen, Natalie O.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Perinatal grief has been associated with declines in couples' sexual satisfaction. However, previous research has yet to address the potential factors associated with perinatal grief and sexual satisfaction such as religiosity. Researchers have found associations between religiosity, perinatal grief, and sexual satisfaction; however, no study has examined these associations together in a single model. Accordingly, the present study aimed to examine the extent to which perinatal grief mediates the association between religiosity and sexual satisfaction. A sample of 51 couples who had experienced a pregnancy loss within the last four months completed an online survey assessing their religiosity, perinatal grief, and sexual satisfaction. Analyses were conducted using a path analysis framework through the Actor Partner Interdependence Model of Mediation. I hypothesized that higher religiosity would be associated with lower perinatal grief, which would, in turn, be associated with higher sexual satisfaction. Contrary to my hypothesis, perinatal grief did not mediate the association between religiosity and sexual satisfaction. However, higher levels of the gestational partner's perinatal grief were associated with lower levels of their own and their partner's sexual satisfaction. These findings could inform interventions by suggesting that lowering perinatal grief might enhance sexual satisfaction after a pregnancy loss, ultimately leading to higher overall wellbeing.},
  note = {Poster},
}

@inproceedings{baker2022investigatin,
  title = {Investigating Retinal Inactivation as a Safe Therapy for Amblyopia},
  author = {Baker, Mitch and Hogan, Mairin and DiCostanzo, Nadia and O'Donnell, Tabitha and MacLean, Andrew and Kevin},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Disruption to normal vision during early life can produce a debilitating visual impairment called amblyopia, which is the most common cause of childhood blindness. The efficacy of conventional treatments for amblyopia are limited by a variety of factors including poor compliance with therapy, recurrence after treatment, and poor recovery beyond early life. We developed a novel and more efficacious treatment for amblyopia that involves temporary retinal inactivation of the dominant eye with intravitreal microinjection of a local anesthetic. In this study we examined several characteristics of the visual system to investigate the safety of this novel treatment. Following inactivation, we observed no deviation from normal on the three measurements we made: (1) density thalamic neurons, (2) refractive error, (3) and body weight. Demonstrating the safety of inactivation therapy is a critical step in the translation of this application for human amblyopia.},
  note = {Poster},
}

@inproceedings{briand2022power,
  title = {The Power of the Pencil: Examining the Impact of Drawing on Learning and Memory},
  author = {Briand and C and Klein and R and M and Christie, J},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Drawing has recently been recognized as an aid to teaching, especially in the sciences. Through drawing, the student engages both their active cognitive system and motor system, and they are more self-reflective, thereby recognizing errors in their understanding of the material. While prior research suggests learning and memory are aided by these processes, few studies have examined the impact of drawing a dynamic visual scene; or simultaneously assessed memory and learning. The present study aimed to address these gaps in the literature, asking, compared to simply looking for an equal amount of time, does drawing a visual scene from observation differentially improve learning and memory?},
  note = {Poster},
}

@inproceedings{cantini2022implications,
  title = {Implications of Lactobacillus Probiotic Administration and Maternal Western Diet on},
  author = {Cantini, Dante and O'Leary, Elizabeth and Perrot, Tara},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Maternal obesity during pregnancy is associated with the development of adverse stress physiology in offspring. A maternal high-fat diet decreases the quality of active maternal care behaviours and increases offspring glucocorticoid levels in rats. Inadequate maternal care is associated with impaired development of the offspring's stress response. High-fat diets also negatively impact the intestinal microbiome and the gut-brain axis. Lactobacillus probiotics have been shown to ameliorate the intestinal microbiome in high-fat diet rats. Our study administered a Western diet to pregnant female rats. It investigated the impact of the Lactobacillus probiotic, Lacidofil®, on maternal care behaviour and offspring stress physiology. We hypothesized that probiotic administration to Western diet dams would mitigate the negative effects of a gestational high-fat diet. Behavioural scoring, ELISA, and RT-qPCR techniques were used to determine the effects of treatment. Few statistically significant effects were found; however, the results indicate that certain interactions and trending effects are occurring.},
  note = {Poster},
}

@inproceedings{cohen2022dyadic,
  title = {A Dyadic Comparison of Sexual Desire and Sexual Satisfaction Between Those Who},
  author = {Cohen, Eva and Rosen, Natalie O. and Allsop, David B.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Pregnancy losses are common and can negatively affect individual mental health and well- being. However, there has been little empirical research conducted on the effects of pregnancy loss on couples' sexual well-being. Accordingly, I examined the effects of a recent pregnancy loss on couples' sexual desire and sexual satisfaction. Couples that that had experienced a recent pregnancy loss and a community sample of couples that had never experienced a pregnancy loss completed online questionnaires about sexual well-being. Multilevel modeling was used to examine mean differences in self-reported sexual desire and sexual satisfaction among three groups. It was found that gestational partners (GPs) reported significantly lower levels of sexual desire than non-gestational partners (NGPs) and individuals of the community. It was also found that GPs reported lower average levels of sexual satisfaction than those of the community sample and that NGPs reported significantly lower levels of sexual satisfaction than individuals of the community sample. Results can provide evidence to aid in the development of interventions that aim to improve couples' levels of sexual desire and sexual satisfaction after a pregnancy loss. Keywords: pregnancy loss, sexuality, couples, well-being},
  note = {Poster},
}

@inproceedings{dauphinee2022investigatio,
  title = {Investigation of the Programming Effects of Probiotic Treatment on Metabolic and},
  author = {Dauphinee, L. M. and Myles, E. M. and Perrot, T. S.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Previous research has suggested positive health benefits on anxiety and obesity-related complications from administering specific strains of probiotics. Additionally, indirect probiotic exposure from pregnant mothers may metabolically program favourable health outcomes in young offspring. The purpose of this study was to characterize anxiety- and obesity- related effects of CEREBIOME® administration in male and female Long-Evans rats. The effects of CEREBIOME® were studied in two separate subsets of rats. Experiment A rats received CEREBIOME® or placebo from mothers throughout pregnancy and lactation, and directly from weaning until sacrifice. Experiment B rats were sacrificed at weaning and only received indirect CEREBIOME® or placebo exposure from mothers. In Experiment A, probiotic treatment significantly reduced certain anxiety-like behaviours in the Open Field Test. In Experiment B, the placebo group had significantly higher plasma leptin levels compared to the probiotic group. These results have implications for prevention and treatment of anxiety disorders and obesity- related complications.},
  note = {Poster},
}

@inproceedings{dolman2022role,
  title = {The Role of Strategic Correction in Prism Adaptation Effects},
  author = {Dolman, Bayla and Rajda, Caroline and Aziz, Jasmine and Eskes, Gail},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Prism adaptation is a visuomotor learning paradigm and therapy for spatial neglect that involves wearing laterally right-shifting prisms to create reaching errors that stimulate learning and adaptation. There are mixed findings regarding whether strategic correction (SC; explicit error correction during prism exposure) inhibits, enhances, or is dissociated from post-prism adaptation resulting in leftward aftereffects. We aimed to investigate the temporal aspects of how SC influences adaptation and aftereffects. We manipulated young adults' SC by introducing a secondary task (letter-number sequence task) during early (trials 1-30) or late (trials 31-60) prism exposure to reduce SC and compared effects to a single task condition. Inhibiting SC during early prism exposure slowed error reduction, while inhibiting SC during late prism exposure did not impact error reduction. Aftereffects were unaffected by SC in either condition. While SC is important for initial error reduction, it does not appear critical for aftereffect development.},
  note = {Poster},
}

@inproceedings{fazaa2022personality,
  title = {Personality, Stress, and Academic Cheating During the COVID-19 Pandemic},
  author = {Fazaa, George R. and Blais, Julie and Mungall, Luke R.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {The quick spread of the coronavirus (COVID-19) pandemic has impacted academic institutions and students by forcing them to switch to online teaching and learning methods unexpectedly. Previous research has shown that students are more likely to cheat when stressed, and personality has also been shown to be a correlate of academic cheating. Thus, the current study examined the relationship between personality correlates (the HEXACO and the Dark Triad), stress due to COVID-19, and engagement in academic cheating during the Fall 2020 term (N = 535), while controlling for other established correlates (sex, age, GPA, and attitudes towards cheating). Our results indicated that being less honest and modest, more grandiose and manipulative, and more planful and deliberate were associated with more engagement in cheating. There was no effect clear effect of stress on cheating. We discuss the practical implications of the findings and future directions in academic cheating research.},
  note = {Poster},
}

@inproceedings{henneberry2022tale,
  title = {The Tale of Two Antibodies: A NESC 3370 and NESC 3000 Project},
  author = {Henneberry, Jonathon and Murphy, Nicholas and Baskaran, Meera and Crouse, Aoibh and Euodia, Irene},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Development of the visual system is characterized by an asymmetric capacity for neural plasticity in which neural circuits are readily modified by visual experience only early in life, during the critical period. The waning capacity for plasticity with age is thought to emerge as a consequence of an accumulation of proteins that inhibit plasticity, so-called molecular brakes. In this study we examined the developmental profile of a putative molecular brake in the visual cortex, semaphorin 3A, in an attempt to understand its potential role as an inhibitor of plasticity. Using two different antibodies against semaphorin, we found diametrically opposed developmental profiles. Whereas one profile indicated a progressive increase in semaphorin 3A with age consistent with it acting as a molecular brake, the second antibody presented a development profile that was completely opposite. Our findings underscore the need to express caution when interpreting immunolabeling results, and in the poster we suggest possible controls.},
  note = {Poster},
}

@inproceedings{holland2022automation,
  title = {Automation Reliability and Its Influence on Trust Dynamics},
  author = {Holland, Christopher and Rittenberg, Ben and Barnhart, Grace and Neyedli, Heather},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Automation is at the forefront of many industries as a tool and aid to human counterparts to improve both productivity and quality. With human-automation teams, there is a need to understand how automation reliability affects user trust in the automated system. Both over-trust and under-trust can be detrimental to system performance; however, the temporal dynamics of trust with changing reliability level are relatively unexplored. The purpose of this experiment is to better define how user trust changes over time in conditions of increasing or decreasing reliability of automation. This experiment makes use of a dominant-colour identification task, in which users must decide whether a grid is mostly composed of blue or orange pixels. Automation provides a recommendation to the users, with the reliability of the recommendation either increasing or decreasing over time. Results from this experiment are expected to help better characterize the dynamics of trust in relation to changing reliability of the automation. It is anticipated that differences in trust will arise between the increasing and decreasing condition, likely caused by the intent of the human to use the automation recommendation in the event that the human identifies that it is reliable or unreliable.},
  note = {Poster},
}

@inproceedings{konwisarz2022investigatin,
  title = {Investigating the Impact of Pre-recorded Lecture Length on Mind Wandering and},
  author = {Konwisarz, Tess and Conrad, Colin},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {It is a commonly held best practice to deliver lectures in short segments because it makes it easier to keep attention and prevent students' minds from wandering. However, it is difficult to assess the precise impact of mind wandering on knowledge retention from various formats of lectures because it is difficult to measure without disrupting a user's experience. Previous experiments have identified electroencephalography (EEG)-indexed correlates of mind wandering in online lecture contexts, allowing the passive measurement of mind wandering. This study explores the impact of pre-recorded online lecture design on MW by observing the differences in EEG signals corresponding to thought-probe reports of different MW varieties generated during different lecture length formats as well as the learning implications. Preliminary results show similar EEG markers of MW found in past studies, while possibly identifying additional ERP markers that collectively appear to distinguish between MW varieties in a pre-recorded lecture context.},
  note = {Poster},
}

@inproceedings{lewis2022interaction,
  title = {Interaction of Memory and Attention in the Context of Directed Forgetting},
  author = {Lewis, Ryan and Taylor, Tracy},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {This study aimed to determine whether magnified slowing of response times (RT) to a secondary probe following forget compared to remember instructions in an item method directed forgetting task are due to attentional withdrawal. A target search task consisting of pop-out and serial conditions was embedded in an item-method directed forgetting paradigm to control for task switching and manipulate levels of attentional demand. Results found search RTs were slower in serial search for different compared to same word-target location trials following remember but not forget instructions. Serial search revealed remember different trials to be slower than remember same trials and more accurate than remember same trials and both forget conditions, being comparable to pop-out search accuracy. Remember instructions may lower attentiveness to location of a study item while encoding, decreasing accuracy of responses to a spatially overlapping target during attentively demanding searches despite faster response times.},
  note = {Poster},
}

@inproceedings{maclachlan2022effect,
  title = {The Effect of Prosocial Behaviours on Preschooler's Accent Processing and Word},
  author = {MacLachlan, Madison B. and Yazbek, Yara and Workye, Rebeka and Weatherhead, Drew},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Studies suggest that morally salient information about a speaker may be linked with accent processing and word learning. Our study investigates whether presenting preschoolers with information about a group's prosocial behaviours impacts their comprehension of an unfamiliar accent and their likelihood to trust a member of the group in a selective word learning task. Participants are presented a story including either prosocial, neutral or antisocial information about a group of fictional characters who speak in an unfamiliar accent. Afterwards, participants are asked to correctly identify images corresponding to passages read by a member of the group. Next, participants must choose to endorse labels for novel objects from either a member of the group or an alternate character. Preliminary analyses show that preschoolers have slightly more difficulty understanding an unfamiliar accent than a familiar one and that they endorse the labels of the speaker below chance in the antisocial condition},
  note = {Poster},
}

@inproceedings{munroe2022factor,
  title = {The Factor Structure of a New Executive Function Questionnaire in Young Adults: The},
  author = {Munroe and C and Leckey and J and Johnson and S and Jacques, S},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Executive functions (EFs) are cognitive processes implicated in goal-directed behaviour. Questionnaires originally developed to assess EFs in children have been adapted for adults (e.g., BRIEF- A; Roth et al., 2005), displaying good psychometric properties and predictive validity. However, these measures are expensive to administer, particularly to large samples. We investigated the factor structure of a new EF questionnaire - developed for children - in young adults. The Learning, Executive, and Attention Functioning (LEAF; Castellanos et al., 2018) Scale is free and comprises 11, 5-item subscales that measure components of EF, learning-related cognitive processes, and academic abilities. The LEAF was completed by 232 undergraduates (Mage = 20.63, SD = 2.45). Upon removing all non-EF items following a preliminary factor analysis, we performed exploratory factor analysis on all LEAF EF items. Results revealed a 7-factor solution that is highly concordant with the structure of the originally proposed LEAF EF subscales. LEAF EF items appear to assess seven, moderately correlated (.26 - .66) EF constructs, with 32 of 40 items factoring exactly as expected. The LEAF promises to be an alternative, accessible measure of EFs for young adults.},
  note = {Poster},
}

@inproceedings{murray2022gaze,
  title = {Is Gaze-Cuing More Like Endogenous or Exogenous Orienting?},
  author = {Murray, Nicholas E. and Drake, Richard S. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Gaze-cuing is a form of visual orienting, in which a shift in one person's gaze triggers onlookers to orient in the same direction. It is unclear if uninformative gaze cues invoke endogenous (i.e., deliberate) or exogenous (i.e., reflexive) orienting. This study extended two past modifications of the Posner cuing paradigm which double-dissociated endogenous and exogenous orienting: in Experiment 1, participants were cued to search for a conjunction target amongst an array of similar distractor items. Past studies showed that exogenous orienting helps participants to make fewer illusory conjunctions. In Experiment 2, participants performed a two-alternative-forced-choice task where one target appeared more often than the other. Past studies showed that endogenous orienting decreases reaction time (a "non-spatial expectancy effect") for the likely target. We hypothesized that gaze-cuing would function exogenously (i.e., decrease illusory conjunctions but fail to enhance non-spatial expectancies) because gaze-cuing shares more properties with exogenous orienting than endogenous orienting.},
  note = {Poster},
}

@inproceedings{myatt2022how,
  title = {How COVID-19 Restrictions Impacted Uptake of the Better Nights, Better Days Program},
  author = {Myatt and A and Keys and E and Corkum, P},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Pediatric sleep problems have been exacerbated by the COVID-19 pandemic. An implementation study of the Better Nights, Better Days During COVID-19 (BNBD-COVID) eHealth program was conducted to determine if this behavioural sleep intervention was helpful in reducing behavioural sleep problems during COVID-19. This sub-study (n = 442) examined how pandemic restrictions at baseline (e.g., school closures) as well as consequences of these restrictions (e.g., increased anxiety) influenced the number of BNBD program sessions completed (out of 5) in families who enrolled in the BNBD program. Both quantitative and qualitative data were collected from questionnaires and interviews with families who fully, partially, or did not complete the program. We found no significant relationship between the number of restrictions in place at baseline and overall session completion (r = -.063; p = .203). Significant relationships exist, however, between session completion and school closures (r = -.112; p = .023), increased anxiety (r = -.116; p = .018), decreased socialization (r = -.097, p = .048), and less of a bedtime routine (r = -.102; p = .039). Qualitative findings suggest that families with full engagement were less affected by COVID-19 restrictions, while families with less engagement were more affected. Many families were able to implement this eHealth program to address their child's sleep problems, although those most affected by COVID-19 may have had the most challenges implementing BNBD-COVID. This research will inform how the program is delivered to future families to improve implementation and sleep improvements.},
  note = {Poster},
}

@inproceedings{nastasiuk2022does,
  title = {Does Physical Activity Predict Executive Function in University Students?},
  author = {Nastasiuk, Anika and Leckey*, Jenn and Johnson, Shannon and author, Sophie Jacques *presenting},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Engagement in physical activity is associated with better executive function, specifically better inhibitory control and cognitive flexibility (De Waelle et al., 2021). The current study aimed to determine the association between different aspects of physical activity in the past month and executive function in university students. Data were collected from 233 university students (179 female, 48 male, 5 non-binary, and 1 non-identified) with a mean age of 20.7 years. Physical activity was assessed by a self-report questionnaire based on the Canada Fitness Survey, and measured by the number of activities engaged in in the past month, as well as the total metabolic equivalent of task (MET) minutes in the past month. Executive function was measured by two self-report questionnaires; the Learning, Executive, and Attention Functioning (LEAF) scale (Castellanos et al., 2018), and the Barratt Impulsiveness Scale (BIS; Patton et al., 1995). Correlations were found between physical activity and overall executive function, as well as between physical activity and cognitive flexibility, but not inhibitory control. As well, correlations were found between physical activity and other aspects of executive function. Moreover, the number of different activities engaged in in the past month predicted executive function better than the total MET expended in physical activities. Results support previous research that found similar associations between physical activity and executive function, generally, and cognitive flexibility, specifically, but not inhibitory control. Future research should investigate the association between physical activity and executive function at multiple time points to determine the bidirectionality of this relation.},
  note = {Poster},
}

@inproceedings{prasad2022examining,
  title = {Examining "Immunity" From Attention Capture: Does Cueing Fixation Delay},
  author = {Prasad and S and Feltmate and T.*, B. B. and Briand and C and Sutherland and D and Klein, R. M. *presenting author},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {In their seminal 1992 paper, Folk et al. demonstrated that when targets are identified by some feature (i.e., colour), participants could adopt an attentional control setting (ACS) such that only cues sharing that feature captured attention. Ruthruff & Gaspelin (2018; R&G hereafter), investigating whether participants could adopt an ACS for space, reported observing "immunity to attentional capture" by cues presented in "irrelevant" locations (e.g., locations wherein a target would never appear). Prasad, Mishra & Klein (2021) noted that in a design similar to R&G, Ishigami, Klein & Christie (2009) observed reduced capture, but not immunity. Prasad argued (and confirmed via a replication and extension of R&G) that this was due to Ishigami's inclusion of a warning beep on every trial, which equated alertness levels across cue conditions. R&G attempted to do the same in their E2 by including a centre cue condition, but Prasad argued that this introduced a new confound: cueing fixation might have delayed disengaging from it. The present study tested this hypothesis in two experiments closely modelled off of the designs of Ishigami and R&G.},
  note = {Poster},
}

@inproceedings{silver2022relationship,
  title = {Relationship Between Satisfaction and Willingness to Pay for the Better Nights, Better},
  author = {Silver, H and Orr, M and Corkum, P and Weiss, S},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Introduction: The majority of children (up to 90%) with neurodevelopment disorders (NDD) experience sleep problems. The Better Nights, Better Days for Children with Neurodevelopmental Disorders program (BNBD-NDD) is a parent-guided eHealth behavioural sleep intervention for parents of children 4-12 years of age with ADHD, ASD, CP, or FASD. BNBD-NDD was developed to address access barriers to evidence-based care. Sustainability of eHealth interventions is an ongoing problem. A commercialization approach to sustainability is one potential solution in which parents would pay for the intervention from their own resources. Objectives/Methods: As part of the recently completed randomized controlled trial (RCT) evaluating the effectiveness of the BNBD-NDD program, data was collected about parents' willingness to pay for the intervention. In the current study, we examined parents' level of satisfaction with the BNBD-NDD intervention, and if higher satisfaction with the intervention predicted a higher willingness to purchase the program, and if satisfaction and willingness to purchase differed between diagnostic groups. We examined this data at baseline (before intervention) and 4-months post intervention. Participants included 45 parents who had completed the intervention and 4-month post-intervention surveys. Results: Overall, intervention participants show high satisfaction with the BNBD-NDD program, and on average, participants indicated on both baseline and 4-month questionnaires that they would be willing to pay above the envisioned $100 asking price for the intervention. Average ratings of satisfaction and willingness to purchase were stable across diagnostic groups. A small-to-moderate significant positive correlation was found between participant's level of satisfaction and their willingness to purchase at the 4-month follow-up (r(45)=.312, p=.037). Lastly, questionnaire responses indicated that offering in-person support alongside the eHealth intervention would increase the amount that participants would be willing to pay. Conclusions: The BNBD-NDD program is a step towards evidence-based eHealth interventions that can work to address barriers impacting access to care. The information gathered regarding parent satisfaction and willingness to purchase the program will help guide the future sustainability of the BNBD-NDD program.},
  note = {Poster},
}

@inproceedings{shephard2022impact,
  title = {The Impact of Anxiety Sensitivity on Self Esteem and Negative Affect Following a},
  author = {Shephard and A and Workye and R and Cribbie and A, R. and Flett and L, G. and Alexander and M, S. and Mackinnon, S. P},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Anxiety sensitivity, a trait involving a tendency to misinterpret anxiety-related physical symptoms as indications of physical danger, serious illness, or humiliating social rejection, might amplify psychological distress following academic failures. We hypothesized that anxiety sensitivity will moderate the relationship between test difficulty and the outcomes, such that anxiety sensitivity results in greater decreases in self-esteem and increases in negative affect following a failed statistics test. This hypothesis was tested on 329 post-secondary statistics students, using a 2-group between-subjects design, where students completed either an "easy" or "hard" statistics test. Students in the hard-test condition experienced decreased self-esteem and increased negative affect. Further, anxiety sensitivity amplified this effect for social self-esteem, anxiety, dysphoria, and hostility; as anxiety sensitivity increased, the differences between test conditions also increased. As anxiety sensitivity is related to avoidant coping, awareness of this risk factor should help inform prevention strategies to promote student well-being and academic achievement.},
  note = {Poster},
}

@inproceedings{j2022role,
  title = {The Role of Muscle in the Immune Response: A RT-Qpcr Study of Toll1 and Insulin},
  author = {J, Zbarsky and L.E, McMillan and I, Zacher and S.A, Adamo},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Animals respond to predator and pathogen attack by mounting systemic responses that span across multiple organs. Both anti-predator and immune responses require the consumption of scarce resources, leading to shifts in resources across different tissues in the caterpillar Manduca sexta. When both predators and pathogens are imminently threatening, the defense systems are reconfigured such that the net response is more than a simple summation of the immune and predator defense response. We examined the response of muscle and fat body in the caterpillar to an immune challenge, mock predator exposure and a combination of both challenges. We measured changes in gene expression for Toll1 and insulin receptors using RT-qPCR. Results showed that Toll1 receptor gene expression is upregulated in fat body during both an immune challenge and during dual challenges. This result was expected as the fat body is important for the immune response and Toll1 receptors activate antimicrobial peptide production. However, Toll1 receptor expression was also upregulated in muscle during an immune challenge and dual challenges, suggesting that muscle also plays a role in the immune response. Insulin receptor expression also increased in both fat body and muscle during an immune challenge and during dual challenges, suggesting high metabolic activity in these tissues in response to these challenges. Muscle appears to play an active role in the response to a pathogen challenge through the increased expression of Toll1 and insulin receptors, supporting the concept of an integrated defense system.},
  note = {Poster},
}

@inproceedings{zhekova2022effects,
  title = {The Effects of Cannabidiol Expectancy on Acute Measures of Stress and Anxiety},
  author = {Zhekova and R and Perry and R and Endresz and N and K, Dockrill. and A, Tanner. and T, Spinella. and Stewart and S and Barrett},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {In recent years, Cannabidiol (CBD) has been shown to attenuate anxiety- and stress-related responses in human participants. However, the extent to which these therapeutic effects result from non-pharmacological factors such as expectancy is unclear. The present study aimed to assess the independent effects of CBD expectancy on subjective and physiological measures of stress and anxiety using a sample of 31 volunteers (11 men). All participants consumed CBD-free hemp seed oil while assigned to one of two CBD-expectancy conditions (told CBD vs. told CBD-free). Following oil administration, participants completed a modified version of the Trier Social Stress Test. Marginal linear models revealed significant expectancy by time effects for heart rate following oil consumption, as well as significant time effects for heart rate and subjective measures of stress and anxiety. These results suggest that CBD expectancy alone may possess anxiolytic effects, thereby emphasizing the need to control CBD-related expectancies in future research.},
  note = {Poster},
}

@inproceedings{michaud2022measuring,
  title = {Measuring Size Perception in Unrestrained Wild-type Mice Using a Novel Two-},
  author = {Michaud, Nicole M and Crowder, Nathan A},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Due to the availability of genetic tools used to explore neural circuits within and between brain areas, the mouse has become an invaluable animal model in vision research. However, to link neural circuits to visual perception, novel behavioural tasks must first be developed. To begin investigating the neural underpinnings of visual size perception, we modified the steering wheel paradigm developed by Burgess et al. (2017) to create a two-alternative forced choice size discrimination task in unrestrained wild-type mice. We assessed the ability of mice to correctly select the larger of two simultaneously presented grating patches, which allowed the generation of psychometric functions from perceptually driven behaviour. Mice displayed successful learning and generalization of the task when the reward stimulus size remained constant. However, when the size of the reward stimulus was varied and mice were required to select the relatively larger grating patch, task accuracy failed to reach criterion.},
}

@inproceedings{makau2022inhibition,
  title = {Inhibition of Nav1.7 and Nav1.8 Decreases Pain-Related Behaviour in Speke's Hinge-},
  author = {Makau, Christopher M.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Voltage-gated sodium ion channels in the peripheral nervous system have great potential as targets for eliminating pain with minimal side effects. Highly selective ion channel blockers, have been used to explore the involvement of a range of ion channels in nociception. Comparative studies are important to fully elucidate performance of such molecules and physiological mechanisms of particular ion channels. The tortoise has been demonstrated to be a good animal model for nociception. In this study, NAV 26 and A803467 selective blockers for Nav1.7 and Nav1.8 ion channels were used to investigate their ability to reduce nociception in the Speke's hinge back tortoise. The time spent in pain- related behavior during formalin, capsaicin and hot plate tests was recorded and analyzed. The results show that both blockers significantly reduced the mean time spent in pain-related behaviour in the formalin test and capsaicin test. Only A803467 caused a statistically significant decrease in the mean time spent in pain related behaviour in the hot plate test. In conclusion, Nav1.7 and Nav1.8 are significantly involved in processing of chemical induced inflammatory pain in the Speke's hinge back tortoise. However, only Nav 1.8 appears to participate in processing of thermally induced pain.},
}

@inproceedings{oleary2022acute,
  title = {Acute Probiotic Treatment During the Perinatal Period Affects Maternal Care and Gut},
  author = {O'Leary, M. Elizabeth and Myles, Elizabeth M. and Romkey, Isaac D. and Kamali, Kiyana and Perrot, Tara S.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {In rodents, active maternal care is crucial for offspring; and a mother's behaviour is sensitive to her external environment. Therefore, the external environment can influence how a mother interacts with her offspring. It is essential to understand what impacts maternal care since low maternal care disrupts offspring development. Probiotics have the potential to alter the gut microbiota, and their downstream effects may impact maternal health and behaviour. We investigated the effects of probiotics on maternal care, offspring developmental outcomes and maternal gut microbiota. We found that probiotic-treated mothers performed increased amounts of active nursing and licking/grooming compared to their placebo-treated counterparts. At weaning, offspring from probiotic mothers weighed significantly more than those from placebo-treated mothers. Lastly, we found that probiotic-treated mothers' microbiota contained increased amounts of Bifidobacterium. These results contribute to our understanding of the external factors that may influence the mother, her health and behaviours and affect offspring outcomes.},
}

@inproceedings{parks2022natural,
  title = {Natural Photoperiodic Regulation of Hippocampal Plasticity in Wild Black-Capped},
  author = {Parks, Broderick M. B. and Phillmore, Leslie S.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {In black-capped chickadees (Poecile atricapillus), food-storing behaviour fluctuates seasonally; supporting this behavioural change is a seasonal change in the hippocampus (Hp), critical for spatial behaviour and memory. Seasonal change in Hp is well-documented; we cannot however easily compare findings due to the use of captivity in some studies, and captivity is known to alter Hp plasticity. Also underlying this brain-behaviour interaction are the breeding-associated changes in avian physiology driven by photoperiod (day length). Here, we captured wild black-capped chickadees (N=48) across three distinct photoperiodic conditions: photostimulated (March-April), photorefractory (August- September), and photosensitive (December-January). All birds were sacrificed shortly after capture; we stained neural tissue with cresyl violet and quantified measures of Hp plasticity including volume and neuron number. Our findings are among the first to quantify seasonal Hp plasticity in a large sample of wild chickadees not introduced into any sort of captivity, and provides key evidence in assessing whether food-storing behaviour and its impact on Hp occur independently of photoperiod-driven seasonal regulation of breeding in food-storing birds.},
}

@inproceedings{perrot2022improvements,
  title = {Improvements to Rodent Housing Have Significant Effects on Development of the},
  author = {Perrot, Tara},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {The value of rodents for modeling human neuropsychiatric disorders and unraveling underlying molecular mechanisms is not questioned. Attempts (not always successful) are made to standardize the conditions under which rats or mice are housed to facilitate comparing results generated in different labs all over the world. While the merits of standardizing housing seem obvious, the costs are generally not considered. Over the last 10 years, we repeatedly have demonstrated significant effects of maintaining rats in semi-naturalistic housing, compared to standard housing, on the quality of maternal care. Decades of prior research has demonstrated the importance of maternal care quality for developing offspring, especially with respect to stress-related outcomes. Our work has revealed significant differences in stress-related brain and behaviour measures in offspring raised in semi-naturalistic housing versus standard housing. Here, I argue that standard housing is impoverished, and the conclusions drawn from results generated using standard housing should reflect that.},
}

@inproceedings{klein2022there,
  title = {Is There One "Beam" of Attention for Searching in Space and Time?},
  author = {Klein, Raymond M. and Feltmate, Brett B. T. and Ishigami, Yoko and Murray, Nicholas E.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {In their pure forms, searching in space entails the allocation of attention to items distributed in space and presented at the same time whereas searching in time entails the allocation of attention to items distributed in time and presented at the same location. In independent projects we explored whether the metaphorical "beams" operating the domains of space and time might be independent or the same. In one project we used a differential approach. Early research using spatial (Snyder, 1972) and temporal search tasks (McLean, Broadbent & Broadbent, 1983) reported a substantial degree of sloppiness (binding errors). Our participants performed both of these tasks to see if the frequency of these binding errors in space and time were correlated. We replicated both early findings of binding errors in space and in time, but their frequency of occurrence in the two domains was not significantly correlated. In the other project, we used an experimental approach. With the participation of DISP students we explored whether the principles described by Duncan & Humphreys for searching in space would apply similarly to searching in time. Not surprisingly, performance in spatial search conformed to the predictions of D&H's principles. Importantly, temporal search performance followed the same pattern, suggesting that D&H's principles generalize to temporal search. Why do you think these two approaches yield different answers to the question posed in our title?},
}

@inproceedings{garden2022pavlovian,
  title = {Pavlovian Conditioned Odour Memory in the Neurexin1+/- Mouse Model of Autism},
  author = {Garden, Jessica F. and Weaver, Ian C. G. and Brown, Richard. E.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Neurexins (NRXNs) are presynaptic cell-adhesion molecules that bind with postsynaptic ligands to connect synapses and regulate synaptic transmission. Altered Nrxn gene expression is linked to neurodevelopmental disorders, such as autism spectrum disorder (ASD), in which learning and memory are impaired. The Nrxn1+/- transgenic mouse model, with the loss of one Nrxn1 allele, is a novel model of ASD that is utilized in this research. Mice conditioned to dig in an odor pot to receive a reward during a 1-day Pavlovian conditioning paradigm using the method of Schellinck et al. (2001 Chem. Senses 26:663-72), were tested for short- and long-term olfactory memory. Given the recently identified role of NRXN in synaptic stability, we hypothesised that neurexin would be implicated in molecular processes required for long term memory, and thus, the Nrxn1 +/- mice would have impaired long-term odour memory. Preliminary analyses reveal that Nrxn1 +/- mice have reduced short-term memory during olfactory digging tasks compared to age- and sex-matched controls, and we expect to observe even greater deficits in long-term olfactory memory in Nrxn1+/- mice.},
}

@inproceedings{drake2022reconciling,
  title = {Reconciling Expectation and Interpretation in the Cognitive Training Meta-Analyses},
  author = {Drake, Richard S. and Eskes, Gail A. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {The cognitive enhancement potential of computerized, game-based working memory training tasks continues to attract researchers and investors alike. Laboratory and commercial endeavours of the past two decades have been both basic and applied, with goals ranging from understanding the mechanisms of learning and transfer to improving academic performance or reducing age-related cognitive decline. Hundreds of scholars have participated in the debate of whether working memory training is effective. Putting aside valid criticisms of the debated question itself ("effective" is not specific and is only meaningful when paired with clearly defined goals), there is evidence to support both sides. However, on the basis of an in-progress systematic review of the working memory training meta-analyses, we argue that the controversy has more to do with differences of interpretation, rather than numeric differences. We thus qualify the alleged quantitative controversy (or "quantroversy") accordingly. We will contextualize our preliminary findings with respect to transfer theories and recent best practice recommendations for cognitive training.},
}

@inproceedings{elliott2022lexical,
  title = {Lexical Decisions in Ortho-Semantic Learning: A Behavioural Study of Grade 3},
  author = {Elliott, Laura and Galilee, Alena and Beck, Lisa and Lownie, Clara and Mimeau, Catherine and &, S. Helene Deacon},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {English speaking children in grade 3, in English and French immersion, completed a novel ortho- semantic learning task (Mimeau et al., 2018). They read passages introducing novel words and their meaning, followed by a test on spellings and meanings of the words. Next, participants completed a lexical decision task (LDT) with the novel words, real words, non-words, consonant strings, and false fonts. While reaction times on the LDT for English students were significantly faster, accuracy did not differ significantly between groups. In the absence of a significant difference, French students demonstrated a trend towards higher accuracy for novel words, and lower accuracy for non-words. French immersion students receive formal reading education in a second language, and these results suggest it may reduce their speed for making judgements on English words. Furthermore, French students achieving reduced accuracy for rejecting non- words may reflect a less-established sight word vocabulary in English, compared to their English peers. However, heightened accuracy of French students for novel words provides a potential benefit of learning to read in a second language, as they become proficient in encountering unfamiliar words.},
}

@inproceedings{oneil2022visual,
  title = {The Visual Word Form Area as a Route of Auditory Linguistic Information Into the},
  author = {O'Neil, K. and Newman, A.J.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Auditory language processing in the visual cortex of blind individuals is thought to be caused by input from the left frontal-temporal language network, however the pathways and brain areas involved are not established. The current fMRI study compared brain activity during semantic and phonological processing in early blind and sighted individuals. We used dynamic causal modelling (DCM) to determine how linguistic information reaches the visual cortex in blind individuals via effective connections from the typical language network. Consistent with past studies, both early blind and sighted individuals showed activation in the frontal-temporal language network during semantic and phonological processing, including the inferior frontal gyrus (IFG) and the visual word form area (VWFA), but only early blind individuals demonstrated activity in the visual cortex (V2). DCM showed that in blind individuals, there was an endogenous connection from the VWFA to V2, and a direct modulatory connection from the VWFA to V2 during semantic and phonological processing. This suggests that in early blind individuals, the VWFA forms a reentrant endogenous connection to the visual cortex, and that visual cortex activity associated with semantic and phonological processing is the result of direct integration into the fronto-temporal language network, via connections with the VWFA. T20) Concluding Remarks Aaron Newman All Posters Will Be Presented From 12:30 pm to 2 pm in the Lilyan E. White Study Centre on the 4th floor},
}

@inproceedings{good2022examining,
  title = {Examining Autism Spectrum Disorder Using the Attention Network Test: A Meta-},
  author = {Good, Samantha and Arora, Swasti and Townsend, Jeanne and Mash, Lisa and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Attentional deficits are common in autism spectrum disorder (ASD) however the nature of these deficits is yet to be fully understood. The present study aimed to assess the three attention networks (alerting, orienting, and executive control) as identified by Posner and Peterson. We conducted a Bayesian hierarchical meta-analysis of studies that implemented the Attention Network Test or its variants to explore whether individuals with ASD exhibited differences in any of the attentional networks when compared to typically developing controls. Eight studies were included in our analysis, comprising 322 children and young adults with the average age ranging from 4.76 - 30 years (Mdn = 13.24). There were no credible differences between participants with ASD versus typically developing controls in the alerting network. Orienting scores were not credibly different, however there was a trend suggesting less efficient attentional response to spatial information in ASD. Executive control scores were not credibly different, but there was a trend showing higher average scores in people with ASD. Although the results from this meta-analysis add to the growing literature on the nature of attentional deficits in people with ASD, our findings are limited by the relatively small number of studies.},
}

@inproceedings{rankaduwa2022analysis,
  title = {Re-Analysis of Body Representation in the Somatosensory Cortex: An Investigation of},
  author = {Rankaduwa, Saisha and Stamp, Jennifer},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {The original 2-D somatosensory homunculus based on Penfield's work lacks representation of uniquely female anatomy. For this reason, we created a quantitative 2-D map of female-specific anatomy in the primary somatosensory cortex (S1) based upon a systematic review of published neuroimaging literature, that comprised 11 studies. These studies reported localization of representations of the clitoris, cervix, vagina, dorsal pudendal nerve, perineal nerve, nipple, and breast in the medial wall of S1 in the paracentral lobule. Representations of the dorsal clitoral nerve, posterior vulva, clitoris, breast, and nipple were also found in the secondary somatosensory cortex. Because there were inconsistencies between the locations of anatomy between studies, we proposed a research plan that comprehensively maps female specific anatomy in the somatosensory cortices. The creation of a female somatosensory "femunculus" is necessary considering the implications it has for assessing neuroplasticity after changes to female anatomy in mastectomies and gender affirmation surgery.},
}

@inproceedings{deacon2022reading,
  title = {Reading Through the Elementary School Years, With a Break for COVID},
  author = {Deacon, Hélène and Hartlin, Stef and Ryken, Alex and Elgendi, Mariam and MacKay, Elizabeth and Krenca, Klaudia},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {In 2019, we optimistically launched a longitudinal study with over 300 children in Grade 1 at 18 schools around the province. In partnership with the Dep't of Education, our goal was to follow them through to Grade 6. But, of course, COVID hit when the children were in Grade 2, midway through testing. I report here on our findings from our first couple of years and how we are working to recover from this change in plans. The oral language skills that we report here on an IURN and SSHRC-funded research study designed to investigate the language skills that children use in their reading. We recruited over 300 elementary school aged children, initially tested in Grade 1 (in winter of 2019). We report here on analyses exploring the relations between early language skills and Grade 2 reading levels. We also explore the achievement and opportunity gap in Nova Scotia by contrasting results for African Nova Scotians with those for other Nova Scotian children. Our goal is to provide another lens into the skills that support all children in learning to read.},
}

@inproceedings{mccormick2022lifestyle,
  title = {Lifestyle Changes That Can Impact Your Attention},
  author = {McCormick, Colin R},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {This talk will summarize a literature review on how different lifestyle factors impact the networks of attention. With the help of the 'ANT Database' developed in the Klein Lab (found at AttentionNetwork.ca), 70+ studies were included that fit into five main categories: meditation, exercise, drug use, sleep, and environmental or social factors. All three networks showed that they were sensitive to different changes in lifestyle. This review also reveals gaps in the literature for understanding how attention is being impacted by our day-to-day choices, as well as the importance of consistent reporting of results and the availability of experimental data.},
}

@inproceedings{blais2022personality,
  title = {Personality, Political Ideology, and Partisanship in Canada},
  author = {Blais, Julie and Mungall, Luke R. and Pruysers, Scott},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Personality traits reliably predict political ideology and partisanship around the world, but studies investigating these relationships among Canadians used poor measures of personality, or did not examine the contribution of antagonistic personality traits (i.e., psychopathy, narcissism, Machiavellianism). We surveyed Canadians (N = 2551) on their ideological self-placement and political partisanship using robust measures of HEXACO traits and antagonistic traits. The findings for political ideology were mostly consistent with previous studies. Canadians who placed themselves on the ideological right were lower in openness to experience, honesty-humility, and impulsivity, but higher in extraversion, narcissism, antisocial tendencies, and blunted affect. Nuanced relationships emerged between personality and support for specific political parties (i.e., partisanship). The personality traits of Liberal, Conservative, and Green partisans were not always consistent with the personality traits of their party's ideological wing. Overall, we demonstrated a crucial distinction between ideology and partisanship, and provided further evidence that personality matters for political choice in Canada.},
}

@inproceedings{mackinnon2022history,
  title = {A History of Grading Practices at Dalhousie University},
  author = {Mackinnon, Sean P.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {This session will provide a historical overview of grading practices at Dalhousie. In the early 1900s, Dalhousie was using a variant of the British system, where 65% or higher was required for "distinction." By the late 1940s, additional subdivisions were created (First, Second, and Third Divisions), and the percentage grade cutoff for the highest grade moved to 80%. The 1970s were an experimental phase, where percentage grades were officially abolished and replaced with letter grades. After a period of virtually no standardization in grading across departments, the university moved towards standardization (i.e., the 4.3 GPA system and standardized percentage-to-letter conversion schemes) by present day. Hopefully, the historical context of how modern grading came to be will help us create new approaches that optimally meet both needs. Preprint: https://edarxiv.org/fmgv8/},
}

@inproceedings{schnare2022measuring,
  title = {Measuring Memory Strength in 5xfad Mice Through Olfactory Discrimination Tasks},
  author = {Schnare, Oliver and Brown, Dr. Richard E.},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {We investigated behavioural and epigenetic signs of olfactory learning and memory in 5xFAD model mice and wildtype mice (9-16 months of age). Mice were classically conditioned on a single day using methods adapted from Schellinck et al. (2001) to associate the CS+ odour pot with a sugar reward, and the CS- odour pot with no reward. The behavioural signs of learning and memory were measured as their preference for the CS+ odour pot on 24-hour and 7-day memory tests. Epigenetic signs of learning and memory were measured as the normalized gene expression of Atrx in the hippocampus obtained from RT-qPCR analysis. Previously, mice with reduced Atrx expression display impairments to long-term potentiation in the hippocampus. 5xFAD mice spent significantly more time digging in the CS+ odour pot than wildtype mice during the acquisition stage, however their performances on memory tests did not differ. Wildtype mice displayed higher levels of Atrx expression than 5xFAD mice in the experimental groups, however Atrx expression served minimal predictive value to performance on memory tests overall. Our results suggest that 5xFAD mice do not have impairments to olfactory learning and memory, and that Atrx expression in the hippocampus may not be related to olfactory learning and memory capabilities.},
}

@inproceedings{miller2022hemolymph,
  title = {Hemolymph Nutrient and Metabolite Changes in Caterpillars Experiencing Parasite-},
  author = {Miller and D.W and Zbarsky and J and Cohen and A.M and Penny and S and Adamo, S.A},
  booktitle = {Psychology and Neuroscience 46th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2022},
  abstract = {Parasitic wasp larvae (Cotesia congregata) permanently suppress host caterpillar (Manduca sexta) feeding via an unknown mechanism(s) as the larvae emerge. This study investigated whether any changes in caterpillar hemolymph after wasps emerge may help explain this feeding behaviour change. Plasma samples were collected from five groups of caterpillars. Two control groups (feeding unparasitized caterpillars and food deprived caterpillars the parasitized non-feeding states) were compared to three groups of parasitized caterpillars: before wasp emergence, 1, and 3 days after emergence. Plasma metabolomics (via liquid chromatography with tandem mass spectrometry) identified nearly 200 metabolites in all five groups, including amino acids, nitrogenous waste, lipid metabolism products, and immune signaling molecules (i.e., adenosine). The same groups were also assayed for sugar content-elevated hemolymph nutrients in the hemolymph suppress caterpillar feeding. These found that post-emergent caterpillars tended to have lower levels of sugars and amino acids compared to controls. The metabolomics also suggested an elevated immune activation signal for at least 3 days following parasite emergence. Immune activation can temporarily reduce or suppress feeding, and adenosine (immune signaling molecule) injection suppressed feeding for 2 hours in healthy caterpillars. These results provide insight into how wasps may be influencing their host's behaviour.},
}

@inproceedings{brown2023revising,
  title = {Revising the Hebb Synapse for the 21st Century.},
  author = {Brown, Richard. E},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {In 1949, Donald 0. Hebb developed his neuropsychological postulate, which involved three neural processes: synaptic modifications (i.e., the Hebb Synapse), the cell assembly, and the phase sequence. The Hebb synapse describes how activity at pre- and post-synaptic neurons modulates the strength of a synapse (and synaptic networks). The Hebb synapse theory was based on electrical synapses, but the discovery of synaptic plasticity at NMDA receptors and the discovery of long-term potentiation and long-term depression provided evidence for the chemical nature of the Hebb synapse. However, new findings suggest that the concept of the Hebb synapse needs revision. We propose a 'hepta-partite' model of the synapse to account for the role of astrocytes, oligodendrocytes, microglia, the extracellular matrix (ECM), and the neurovascular unit (NVU) in the regulation of synaptogenesis and modulation of synaptic activity/plasticity. We also re-examine Hebbian plasticity in electrical synapses and consider the role of the gut microbiome in synaptic plasticity, as well as genetic and epigenetic mechanisms. Based on this new information, we revise Hebbian theories of the synapse, the cell assembly, and phase sequence underlying learning and memory to reflect the current understanding of synaptic plasticity, while upholding the legacy of Donald Hebb.},
  note = {Poster; booktitle inferred},
}

@inproceedings{jacques2023language,
  title = {Language and Executive Function in Dogs: Testing for the Universality of the Relation},
  author = {Jacques, Sophie and Reeve, Catherine and Presser, Lara and Ochoa, Karina Alvarado},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Language predicts executive function (EF) in humans (Muller et al., 2009). Cross-species comparisons examining this relation can help determine the universality of this relation. Dogs are ideally suited for this, as owners direct and adapt their speech to dogs (Mitchell, 2001) and dogs respond systematically to words, particularly action commands (Mill, 2005; Ramos & Mills, 2019), demonstrating some receptive abilities, although they vary widely in their reported receptive abilities (Reeve & Jacques, 2022). Dogs also possess rudimentary EFs,measured using owner questionnaires (Foraita et al., 2022) and behavioural tests (Tiira et al., 2020). We examined relations between language and EF in 104 dogs (54 females; Mage=S.21yrs) using Reeve and Jacques' (2022) owner vocabulary checklist, with Total Vocabulary and Action Commands as scores. EFwas assessedusing an incrementally difficult behavioural search task and a 12-item owner questionnaire. Even after controlling for dogs' age and sex, Total Vocabulary and Action Commands correlated with search task performance and owner responses on the EFquestionnaire, indicating that the relation between language and EFextends to another species. Understanding inter-species similarities and differences can help shed light into the nature of the relation between these abilities.},
  note = {Poster; booktitle inferred},
}

@inproceedings{killeen2023drift,
  title = {DRIFT-OFF:Diabetes Related Insomnia in Families and Teenagers- Optimising control and Facing Fears},
  author = {Killeen, Jack},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Type 1 diabetes mellitus (TlD) is a chronic condition that occurs when the pancreas makes little to no insulin, thereby causing raised levels of blood glucose. Sleep disturbances are common in people with TlD due to symptoms of high or low blood glucose levels, anxiety around glucose levels and monitoring throughout the night. Current research focuses on sleep disturbances in adults with TlD, with less known about the relationship in younger populations. This correlational, mixed methods, exploratory study, will use questionnaires, a 7-day sleep diary, and metabolic parameters to focus on the relationship between glycaemic control and sleep in children and adolescent patients and their parents/caregivers. A maximum of 50 children/adolescent and parent/caregiver pairings will be recruited through a tertiary children's hospital diabetes clinic. We hypothesize that poorer glycaemic outcomes will be related to more disrupted sleep in both children/adolescents and parents/caregivers. We also hypothesize that the use of diabetes related technologies, such as Continuous Glucose Monitors (CGM), will decrease Fear of Hypoglcaemia (FoH), the anxiety surrounding low blood glucose levels and its symptoms, in both children/adolescents with CGMs and their parents/caregivers. The results of this study may influence sleep management recommendations for children and adolescents with TlD and their caregivers. Our aim is to create a familial view of diabetes related sleep differences and stress in the home and empower patients and their families to make informed choices to optimize their health. Promoting healthy sleep is an important public health measure, especially in children/adolescents with diabetes as TlD already has widespread negative effects on an individual's health and well-being.},
  note = {Poster; booktitle inferred},
}

@inproceedings{macdougall2023examining,
  title = {Examining the Barriers to and Experiences of Nature Exposure in Undergraduate Students},
  author = {MacDougall, Blythe and McMillan, Rachel and Ibrahim, Yasmeen and Fazaa, George and Johnson, & Shannon A.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Undergraduate student mental health is a rising concern and mental health services for undergraduates are limited. Accessible, affordable, and effective treatments and preventative approaches are needed to address these challenges. Previous research has demonstrated nature exposure's benefits on mental health. We investigated the barriers and experiences of nature exposure in undergraduate students. Eighty-six undergraduate students completed a novel intervention, "Nature Matters". This intervention, designed to increase exposure to and connection with nature, includes two components: seven short videos, followed by a written companion. Consistent with prior research and our hypotheses, undergraduates identified key barriers to nature exposure, including a lack of spare time, insufficient knowledge on how to access nature, and unfavourable weather conditions. As expected, inductive thematic analysis of participants' reflections before and after the brief virtual nature exposure revealed that the video positively affected perceptions of their current states. The nature exposure evoked positive changes in negative state perceptions with most responses suggesting virtual nature exposure was both an effective and pleasant experience.},
  note = {Poster; booktitle inferred},
}

@inproceedings{myatt2023employing,
  title = {Employing the RE-AIMframework to assessthe implementation successof Better Nights, Better Days during the COVID-19 pandemic},
  author = {Myatt, A and Keys, E and Corkum, P},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Background.To address worsening sleep problems in children during the pandemic, an existing eHealth program for sleep problems in children, Better Nights, Better Days (BNBD), was modified to be appropriate in the pandemic context. This study used the Reach, Effectiveness, Adoption, Implementation, Maintenance (RE-AIM) framework to understand how families of children with behavioural sleep problems implemented the program in the context of COVID-19. Methods. Implementation was assessed based on: the best way to reach parents during COVID-19 (Reach);the effectiveness of the program in terms of child sleep and family resilience (Effectiveness); how the program was adopted within families (Adoption); the percentage of parents who accessed and/or completed the program (Implementation); and if parents maintained use of program strategies after program completion (Maintenance). Results. Results suggest that most parents were reached through on line advertisements (74.2%) but that many parents who enrolled in the program did not end up accessingit (70.5%) or completing a clinically significant dose (84.5%). However, those that did complete the program had high fidelity with implementing the strategies and the program was just as effective as pre- pandemic for families who completed it.},
  note = {Poster; booktitle inferred},
}

@inproceedings{ortibus2023olfactory,
  title = {Olfactory Discrimination Tasksand Reversal Learning in a Neurexinl (+/-) mouse model of Autism Spectrum Disorder},
  author = {Ortibus, Wyatt and Roddick, Dr. Kyle and Brown, Dr. Richard},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {The Nrxnl(Nrxnl +/-) mouse model is a novel strain with no previous research into their learning and memory performance. Neurexins (NRXN)are a family of type-1 membrane protein synaptic organizers that bind neuroligins to form Ca (2+) dependent complexes that shape synapse properties of neural networks by synapse specificity. Synaptic function is critical for learning and memory processes and Neurexins are essential for synaptic function as alterations to Neurexins are implicated in neurodevelopmental disorders (autism and schizophrenia). Our experiment examines the effects of Neurexin mutations on learning and memory using transgenic mice and operant conditioning tasks using an olfactometer. Using an olfactometer Nrxnl (+/-) mice and wildtype (Nrxnl +/+) littermates we scored total errors during three odor discrimination learning tasks. The Nrxnl (+/-) and wildtype controls did not differ in their total errors to 85% accuracy criterion in our Introduction and New Operant Odor Pair memory tasks, indicating that both genotypes are effectively able acquire novel operant pairs. Our results show significantly more errors on reversal learning in the Nrxnl (+/-) mice compared to wildtype mice as the reversal learning task requires more cognitive flexibility than the prior learning assessments. The Nrxnl+/- mice underperform in reversal learning olfaction tasks within an olfactometer due to the dysregulation of synaptic function compared to controls.},
  note = {Poster; booktitle inferred},
}

@inproceedings{oulton2023effects,
  title = {Effects of Sleep Deprivation on the Density and Size of Mitochondria in Axon Terminals Presynaptic to Rat Orexin Neurons},
  author = {Oulton, Madison and Golovin, Tatjana and Kaz~~-~~mba},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Orexin (ORX) neurons are wake-active and wake-promoting neurons found in the lateral hypothalamus. During sleep deprivation (SD), we would expect not just ORX neurons but their excitatory inputs to be active. Considering that these inputs utilize their cellular energy stores to fuel synaptic activities, we would expect the mitochondria within these terminals to increase in size and density after SD. To test this hypothesis, adult male Wistar rats were either sleep deprived (n=3) or left undisturbed (n=3) for 6 hours during the first half of the light phase, then immediately sacrificed. Using correlative light-electron microscopy, several ORXneurons were identified and imaged in serial sections at 30-50 nm thickness. The number and length of mitochondria per axon terminal for several hundreds of axon terminals presynaptic to 6 ORXneurons were analyzed. Although the author is required to remain blind to the experimental condition in order to continue to work on the project, significant differences between individual animals were found, potentially supporting the hypothesis that mitochondria in axon terminals presynaptic to ORXneurons increase in size and density after SD.},
  note = {Poster; booktitle inferred},
}

@inproceedings{smith2023does,
  title = {Does early ineffective occlusion treatment of amblyopia in kittens reduce the effectiveness of later longer treatments that are typically quite successful?},
  author = {Smith, Seth and Duffy, Kevin and Mitchell, Donald},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {A smattering of reports on patching therapy (i.e. occlusion of the "good" eye) for amblyopia in children suggest that prior unsuccessful patching treatment may reduce the efficacy of subsequent longer therapy. We are investigating this possibility in kittens that were rendered amblyopic in one eye by monocular occlusion for 7 days starting at P21 days of age. Subsequently, two groups of kittens receive 3 weeks of occlusion of the fellow ("good") eye that starts at 5 weeks of age but in one group is preceded by 3 days of fellow-eye occlusion beginning at the end of the initial period of monocular occlusion at P28. Preliminary behavioural measurements of the grating visual acuity of each eye suggest that the early short period of occlusion of the fellow eye reduces the efficacy of the second long period of occlusion of this eye.},
  note = {Poster; booktitle inferred},
}

@inproceedings{yazbek2023impact,
  title = {The Impact of Accented Prosocial Behaviour on Preschoolers' Selective Word Learning},
  author = {Yazbek, Yara and Maclachlan, Madison and Workye, Rebeka and Tupper, Emma and Weatherhead, Dr. Drew},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Children's language development involves learning from others to navigate linguistic variations such as native and non-native accented speech. Social factors like nationality and accents, as well as behavioural traits play a role in word learning. We investigate how prosocial behaviour interacts with accented information to make an unfamiliar accented speaker more preferred through a label endorsement task. It was hypothesized that preschoolers are more likely to endorse a label presented by a non-native accented speaker when receiving prosocial information about their social group. Analyses show no significant differences in the proportion of times the Wuppit label was chosen between the prosocial, antisocial, and neutral conditions. Post-hoc comparisons showed slight but insignificant differences, but the low-powered sample size prevented statistical significance. The results of this study highlight the need for further research investigating these factors, as it can have implications for the development of programs that promote positive representations of minority language groups.},
  note = {Poster; booktitle inferred},
}

@inproceedings{smith2023cultural,
  title = {Cultural Adaptations of Developmental Interventions (Dis) and Naturalistic Developmental Behavioural Interventions (NDBls) for Preschoolers with Autism Spectrum Disorder: A Delphi Study},
  author = {Smith, Sare Yorukoglu Supervisors: Isabel and Hamodat, Teba},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Background: Developmental Interventions (Dis) and Naturalistic Developmental Behavioural Interventions (NDBls) designed for pre-schoolers with Autism Spectrum Disorder are accepted as the predominant treatment methods that target social processes and emotional development. Although there is existing literature on how both interventions might take form in various ethnic/geographical/cultural settings, most researchers have yet to describe the adaptation process they have taken to adjust interventions. Objective: This study aims to address which modifications and adaptations to Dis and NDBls would be the most suitable for preschoolers with ASD from different ethnic/ geographical/cultural settings. Methods: We are conducting a Delphi study where experts in the ASD field with related experiences will be asked questions based on the core elements of the Framework for Reporting Adaptations and Modifications-Expanded (FRAME) (Stirman et al., 2019). Twenty experts agreed to partake in the study. The rounds of questionnaires will continue until a consensus is reached. Preliminary Findings: After the complication of the first round, we conducted a content analysis based on Graneheim & Lundman's framework (2003) to analyze the qualitative data. The analysis has resulted in the identification of over 100 condensed meaning units, which will be presented to the expert panel in the second round. The experts will be asked to rate their agreement on each unit using a 6-point Likert scale, enabling the prioritization and refinement of the adaptation. Significance: The study's findings will address the critical need for culturally sensitive adaptations of developmental interventions for preschoolers with Autism Spectrum Disorder (ASD).},
  note = {Poster; booktitle inferred},
}

@inproceedings{paola2023brief,
  title = {Brief Retinal Inactivation Promotes Recovery of Microtubule-Associated Protein 2 in an Animal Model of Amblyopia},
  author = {Paola, Andrea De and Lauwerijssen, Paige and Gregor, Jaimie and Pham, Sammy and Setterington, Annika and Sophie},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {The formation and function of neural circuitry relies on interactions between structurally dynamic neurons. Microtubule-associated protein 2 (MAP2) has previously been identified as a prospective determinant of cytoskeletal plasticity. In an animal model of amblyopia, a visual disorder resulting from obstructed visual experience in one eye, monocular deprivation (MD) elicits and atrophy of neurons and loss of MAP2 in layers of lateral geniculate nucleus (LGN) serving the deprived eye. In this study, we investigated whether brief inactivation of the non-deprived eye with microinjection of tetrodotoxin could remediate the atrophy of neuron somata and loss of MAP2 caused by a prior MD. Retinal inactivation of the non-deprived eye for 2 days recovered cell size of neurons in deprived LGN layers and restored immunolabeling of MAP2 to normal. These findings indicate that brief retinal inactivation of the dominant eye is an effective approach to promote recovery of MAP2 following a period of amblyogenic rearing.},
  note = {Poster; booktitle inferred},
}

@inproceedings{drake2023qualifying,
  title = {Qualifying the "quantroversy": Dissecting the working memory training debate},
  author = {Drake, Richard S. and Eskes, Gail A. and Klein, & Raymond M.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {The cognitive enhancement potential of computerized, game-based working memory training tasks continues to attract researchers and investors alike. Laboratory and commercial endeavours of the past two decades have been both basic and applied, with goals ranging from understanding the mechanisms of learning and transfer to improving academic performance or reducing age-related cognitive decline. Hundreds of scholars have participated in the debate of whether working memory training is effective. Putting aside valid criticisms of the debated question itself ("effective" is not specific and is only meaningful when paired with clearly defined goals), there is evidence to support both sides. However, on the basis of our systematic review of the working memory training meta-analyses, we argue that the controversy has more to do with differences of interpretation, rather than numeric differences. We thus qualify the alleged quantitative controversy (or "quantroversy") accordingly. Please come and provide input or debate us!},
  note = {Poster; booktitle inferred},
}

@inproceedings{elgallad2023importance,
  title = {The Importance of Timing: Effect of Retinal Inactivation on Neural Activity in the LGN is Reduced with Age},
  author = {Elgallad, Joseph and Eisner, Mason and Pham, Nhu Y and Thompson, Sappho and Benjamin, Selena and Cook, Emma},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Conventional therapy for amblyopia is limited by issues such as compliance with treatment and recurrence of the disorder. We tested a novel treatment for amblyopia that involves reversible inactivation of the retina with TTX. Brief retinal inactivation promotes recovery from the amblyogenic effects of monocular deprivation at ages previously thought impossible. We subsequently found that the effectiveness of TTXto elicit plasticity is reduced in older animals. The diminishing effectiveness of inactivation in mature animals may be the consequence of a decreased ability for inactivation to reduce synaptic activity. In this study we tested the hypothesis that the impact of brief retinal inactivation on synaptic activity is reduced with age. We assessed immunolabeling for vesicular glutamate transporter 2 (VGLUT2)as a proxy for synaptic activity within the dorsal lateral geniculate nucleus. We found a progressive loss in the ability of retinal inactivation to reduce levels of VGLUT2. That inactivation in older animals does not appreciably reduce activity levels in the visual system implies that older animals subjected to inactivation treatment for amblyopia will show limited recovery in comparison to younger ages.},
  note = {Poster; booktitle inferred},
}

@inproceedings{eyburnshemingway2023mini,
  title = {The Mini-Countryman Vehicle and Stimulus-Response Compatibility.},
  author = {E.Y.Burns-Hemingway, Fiona and Klein, Raymond M. and Feltmate, Brett B.T.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {In the "Union Jack" style taillights employ;a by some Mini-Countryman models, signaling to turn involves illuminating an inward-facing arrow. We asked: what occurs in a driver's mind when observing a vehicle signaling a leftward turn, but via a right-facing arrow? When viewed through a stimulus-response (SR) compatibility lens, the incongruency of the signal's irrelevant spatial shape (i.e, right-facing arrow) and its relevant spatial location (i.e, left-located) ought to impair one's ability to efficiently interpret drivers' intentions. This concern is compounded by the use of arrows as directional markers in turn-signs on roads, presumably leading drivers to adopt an attentional set biasing them towards interpreting the shape of arrows. To test this, we had participants make keypress responses (left, right) indicating the task-relevant property of arrows when presented as turn-signs (shape, ignoring location), or turn-signals (location, ignoring shape) within a mock highway display. For turn-sign responses we replicated the classic Spatial-Stroop effect (performance costs due to incongruency between arrows' task-relevant shape and irrelevant location). For turn-signal responses, we observed a "converse" Spatial-Stroop effect wherein performance suffered when arrows' task-relevant location was incongruent with their irrelevant shape. These results suggest that the "Union Jack" style taillights may be detrimental to road safety.},
  note = {Poster; booktitle inferred},
}

@inproceedings{gendronl2023effects,
  title = {Effects of Intranasal Insulin on Memory and Physiology in the 5xFAD Mouse Model of Alzheimer's Disease},
  author = {Gendronl, William H and Fertanl, Emre and Roddickl, Kyle M and Anini, Younes and Brown, Richard E},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {As well as a disorder of cognitive function, Alzheimer's Disease (AD) is a metabolic disorder related to insulin resistance in the brain and has been termed "type 3 diabetes". Intranasal insulin administration has been proposed as a treatment for AD. The 5xFAD mouse shows age-related decreases in body weight as well as cognitive and motor deficits. As defective insulin signaling in AD is an example of metabolic dysregulation, this study examined whether intranasal delivery of insulin (INDI) at low (LI; 0.875 U) and high (HI; 1.75 U) doses would ameliorate these deficits compared to saline (S) in 12-month-old female 5xFAD and WT (B6SJL)mice. The SxFADmice had poorer performance on the balance beam than WT mice (p < 0.05) and there was no effect of insulin. The HI group performed better than the saline group in the novel object recognition test (p < 0.05) and showed better memory performance in the probe trial of the Morris Water Maze test. Although INDI had no significant effect on body weights, HI doses of INDI increased the liver, spleen, and kidney weights in both WT and SxFADmice (p<0.05). Brown adipose tissue weights in the HI group were lower than in the Sand LI groups. P-Akt signaling was increased by INDI in a dose-dependent manner (p < 0.05). These findings indicate that visuo- spatial memory and organ weights in female SxFADmice are affected by treatment with intra-nasal insulin in a dose dependent manner.},
  note = {Poster; booktitle inferred},
}

@inproceedings{glenham2023grooming,
  title = {Grooming Behaviour in The Neurexinl+/- Mouse Model of Autism Spectrum Disorder},
  author = {Glenham, Cecilia and Brown, Dr. Richard},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Autism Spectrum Disorder (ASD) is a neurodevelopmental disorder characterized by deficits in communication, social interaction, and repetitive behaviors. Mutations of the Neurexin (NRXN) gene result in disrupted synaptic function and have been strongly implicated in ASD,although the precise mechanisms remain unclear. Mouse self-grooming is a repetitive, sequentially patterned behavior model, making it an ideal translational tool for ASD research. The Neurexinl+/- (Nrxnl+/-) is a novel mouse model of ASD, and our study was the first to perform grooming research for this strain. In our study, we examined grooming microstructure in male and female Nrxnl+/- mice compared to wild-type (Nrxnl+/+) mice by using quantitative and sequential analysis. Our research did not yield any statistically significant results, however, some interesting non-significant sex differences were observed. Our research emphasizes the importance of investigating specific behavioural microstructure, with particular attention to potential sexually dimorphic differences. Additionally, we highlight the need for further research in Nrxnl+/- mice.},
  note = {Poster; booktitle inferred},
}

@inproceedings{hartley2023naturally,
  title = {Naturally-Formed Social Hierarchies are not Associated with Indicators of Stress and Anxiety in Male Mice},
  author = {Hartley, Mackenzie and Bhaskara, Millie and MacKay, Alex and Franklin, Tamara},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Within social dominance hierarchies, lower social rank is associated with higher levels of stress. Hdac2 is an epigenetic protein regulated by the glucocorticoid receptors activated during the stress response and, therefore, shows greater expression in individuals with increased stress levels. This study aimed to provide evidence to correlate stress, anxiety, and Hdac2 protein expression in the hippocampus with social rank in male mice. We performed western blots to measure Hdac2 protein expression, used adrenal gland weights to measure stress and a triple-test paradigm to measure anxiety. We expected to find increased stress, anxiety, and Hdac2 protein expression displayed by lower-ranked individuals, however, our findings suggest that there is no link between stress, anxiety, Hdac2 protein expression, and social rank in hierarchies naturally formed by male mice. These findings may be due to the absence of resource competition in lab conditions, or due to stress induced by the behavioural testing procedure.},
  note = {Poster; booktitle inferred},
}

@inproceedings{francesrhaywardotherslistedonpostersophielnkpen2023investigatin,
  title = {Investigating the Effect of Acute Psychosocial Stress and Aerobic Exercise on Salivary Cortisol Concentrations in Young Adults},
  author = {Frances R. Hayward (others listed on poster: Sophie lnkpen, Elizabeth M. Myles, Cory Munroe},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {When humans are stressed, they respond predominately by activation of their hypothalamic- pituitary adrenal (HPA) axis. The HPA axis releases cortisol, a glucocorticoid; crucial in the moment but culprit to the long-term damage caused by stress. Stress related disorders are mitigated by aerobic exercise (AE),which, if done prior to psychosocial stress exposure, lessens cortisol response. AE, a physical stressor, is thought to accomplish this by causing early activation of the HPA axis' regulating mechanism: glucocorticoid negative feedback. The present study aimed to investigate if this impact on cortisol was still present if the order was reversed, and the AE was performed after exposure to psychosocial stress. We hoped to provide evidence that AE might be capable of mitigating negative aspects of the stress response retroactively. Three experimental conditions were conducted, each with four participants; the first group participated only in a psychosocial stress paradigm (The Montreal Imaging Stress Task; Dedovic et al., 2005), the second group participated only in moderately intense AE, and the third group participated in a psychosocial stress paradigm, followed by moderate AE. Six saliva samples were collected throughout the sessions and analyzed later using an enzyme- linked immunosorbent assay. A repeated measures ANOVA revealed that cortisol levels were highest at the end of the session in those who had participated in both the stress and AE paradigms. Contrary to what we had imagined, these results indicate a potential conflation of psychosocial stress and AE when performed in this order, resulting in a subsequent increase of HPA axis activation.},
  note = {Poster; booktitle inferred},
}

@inproceedings{broderick2023growth,
  title = {Growth of vocal control nucleus Area X precedes gonadal recrudescence in wild male black-cap i:ed chickadees (Poecile atricapillus)},
  author = {Broderick, M and Parks, B and McVea, Kyle and Phillmore, Leslie S},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {In temperate songbirds, spring breeding season brings about changes in behaviour, physiology, and neuroanatomy; these changes are initiated by a longer photoperiod (day length). It is believed that breeding- associated neuroanatomical changes, including growth of nuclei of the vocal control system, occur downstream of photo period-induced gonadal recrudescence, however, evidence from wild birds is mixed. Here, we captured wild black-cap i:ed chickadees (N=18 adult males) in spring (March-April), summer (August-September), and winter (December-January). We quantified the volume of two vocal control nuclei: Area X (critical for vocal learning) and HVC (critical for production). Most adult males (6/8) captured in spring had small testes and low levels of circulating androgens, indicating these birds were not yet in full breeding condition. However, spring males still had a significantly larger Area X (i.e., sizes expected in breeding season) than winter males, while HVC did not differ across groLp s. These data suggest that the growth of Area X, but not HVC, occurs Lp stream (or independently) of gonadal recrudescence, and may also reflect differential temporal and behavioural demands on the songbird vocal control system in advance of breeding. Y,},
  note = {booktitle inferred},
}

@inproceedings{henneberry2023abnormal,
  title = {Abnormal Visual Experience Attenuates the Capacity for Neural Plasticity},
  author = {Henneberry, Mark and Elgallad, Joseph and Smith, Seth and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Amblyopia is a debilitating visual impairment caused by an obstruction of normal binocular vision. Conventional treatment for amblyopia involves occluding the fellow eye to allow neural connections serving the amblyopic eye to recover. The effectiveness of this therapy is enabled by a high capacity for plasticity early in postnatal life. It has been suggested that r_eclJ_r~ntabnormal visual experience exhausts the potential for neural plasticity in the visual system. In this study, we assessed the impact of an early and transient monocular deprivation (MD) on the effects of a subsequent period of MD to the fellow eye. The atrophy of soma size and loss of neurofilament typical of MD was reduced in magnitude in animals that experienced a prior MD. These findings suggest that cumulative obstruction of normal vision attenuates the capacity of neural, and may impact the successful treatment of amblyopia.},
  note = {booktitle inferred},
}

@inproceedings{herbison2023mechanisms,
  title = {Mechanisms behind parasitoid wasp induced behavioral changes in the tobacco hornworm caterpillar},
  author = {Herbison, Ryan and Raun, Nicholas and McMillan, Laura and Miller, Dylan and Sh and ell~yAdamo},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Parasites, capable of altering a host's behaviour to facilitate their own life cycle, provide a rare window into the complex physiology of the brain and how to change it. Cotesia congregata, a parasitoid wasp, appears to significantly affect the behaviour of the tobacco hornworm caterpillar Manduca sexta upon emergence from its body wall, suppressing its development, feeding and motivation, culminating in a body guarding behaviour. How these behaviours are induced by the parasitoid wasp is unknown. Elucidating the mechanisms the parasite uses to change behaviour, in this system and others, could be foundational to new methods for interacting physiology, therapeutically or otherwise. In this study we contrasted the transcriptome of parasitized vs. non-parasitized caterpillar brains at multiple time points throughout infection, from prior emergence to 3 days after. At emergence, we found many parasite transcripts present in the caterpillars brain, with functions around synapses, vesicle transport, neuropeptide processing and gene expression.},
  note = {booktitle inferred},
}

@inproceedings{hill2023crafting,
  title = {Crafting happiness from everyday life: Personality, personal projects, basic psychological need satisfaction, and well-being},
  author = {Hill, Taylor G. and Coughlan, Emma C. and Mackinnon, Sean P.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Feeling competent, related, and autonomous promotes well-being through satisfying basic psychological needs, according to self-determination theory's basic psychological need satisfaction mini-theory. Personal projects are personally relevant goal-directed activities that take place over an extended period. The quality of life elicited from pursuing personal projects depends on the degree to which projects provide a sense of relatedness, competence, and autonomy. We expected that, when controlling for perfectionistic standards and discrepancies, achievement striving would lead to the pursual of projects that provide a sense of competence, autonomy, and relatedness, which in turn leads to well-being. The sample (N = 327) was composed of students and the general adult population who provided information on positive mental health, passion, zest for life, life purpose, personality, basic psychological need satisfaction, and personal projects. We used a cross-sectional survey design and tested hypotheses with twelve serial mediation models. Achievement striving and personal standards was positively associated with competence, which in turn predicted well- being, though effect sizes tended to be larger for personal standards. Achievement striving and discrepancies generally did not contribute to change in well-being through relatedness or autonomy after controlling for personal standards. Those oriented toward achievement motivation are likely to feel competent in their pursuits (personal projects), which in turn promotes well-being. Pursuing personal projects that suit one's personality (i.e., make it more likely to meet basic psychological needs) may be a tool to boost well-being.},
  note = {booktitle inferred},
}

@inproceedings{rittenberg2023trust,
  title = {Trust in Automated Systems is Influenced Differently by Increasing and Decreasing Automation Reliability},
  author = {Rittenberg, Benjamin S. P and Holland, Christopher W and Barnhart, Grace E and Gaudreau, Sierra M},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {The reliability level of automation can affect users trust and performance, however, the temporal dynamics of trust in relation to changing reliability levels remains relatively unexplored. The purpose of the study is to determine how user trust evolves over time when automation reliability increases or decreases. Three groups of participants performed a binary decision task with the help of an automated aid. Group 1 used automation that increased from 50%- 100% reliability, group 2 increased from 70%-100% reliability, and group 3 decreased 100%-50% reliability. Self-confidence and trust were measured at regular intervals. Trust in automation only increased in the 70%-100% reliability level and participants' trust was better calibrated to the task when they had higher self-confidence. Human-automation performance tracked with automation reliability level. The results indicate that users need to interact with moderately reliable automation to improve their trust in automation.},
  note = {booktitle inferred},
}

@inproceedings{hurst2023understandin,
  title = {Understanding The Effects of Motor Imagery on Effector Mapping},
  author = {Hurst, Austin J. and Boe, Shaun G.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Motor imagery has been found to improve motor performance in a wide range of contexts, from laboratory tasks to professional athletics. Despite its effectiveness, however, the cognitive mechanisms behind motor imagery remain poorly understood. We designed a study to test whether motor imagery rehearses effector mapping, which occurs late in the motor process. Participants performed three blocks of a fine-motor pointing task using a joystick: a brief familiarization block, a training block consisting of either physical practice, motor imagery, or a control task, and a final test block where the joystick's y-axis was inverted. The more the original effector mapping was rehearsed in the first two blocks, the larger the performance impairment we would expect in the final block relative to the first. Preliminary analyses indicate that the Ml group was less impaired by the inverted axis than the PPgroup, suggesting a notable neural divergence between motor imagery and physical practice with important practical applications.},
  note = {booktitle inferred},
}

@inproceedings{klein2023mental,
  title = {Mental effort, pupil size, task difficulty and endogenous spatial attention},
  author = {Klein, Raymond M and Sutherland, Dawson and Hurst, Austin},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Does mental effort, as measured by pupil dilation, adjust for task difficulty (Kahneman & Beatty, 1966) and matter for task performance in an endogenous cuing task (Posner, Snyder & Davidson, 1980)? We monitored eye movements and measured pupil size while participants responded to peripherally presented targets preceded by informative central cues. The colour of the central fixation stimulus provided information about whether the task would be easy (simple detection) or harder (simple detection followed by the report of the colour of the target) and none of the events during a trial would involve the kind of change in luminance that might confound our use of pupil size as a measure of mental effort. Extending Kahneman's finding from memory to perception, the hard task elicited a greater investment of mental effort (greater pupil dilation) than the easy task. Cuing effects, which decreased monotonically with practice, were relatively unaffected by mental effort but early in practice larger pupils (greater effort) resulted in reduced costs on invalid trials. Implications of these findings will be discussed.},
  note = {booktitle inferred},
}

@inproceedings{lewis2023exploring,
  title = {Exploring the Role of Attentional Withdrawal in Item-Method Directed Forgetting Through Visual Search},
  author = {Lewis, Ryan and Taylor, Tracy L.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {We embedded a serial and pop-out visual search into the study phase of an item method-directed forgetting paradigm to assess attentional availability following instructions to remember (R) or forget (F). Study words were presented to the left or right of a central fixation (Experiments 1-2) or at center (Experiments 3-5), followed by a visual (Experiments 1-4) or auditory (Experiment 5) memory instruction, and then by the search display. Although the evidence did not support a differential withdrawal of attention following F compared to R instructions, Experiment 5 replicated slower response times to visual targets that followed F compared to R instructions (e.g. Fawcett and Taylor, 2008; 2012) - consistent with the view that intentional forgetting engages an active cognitive process. We speculate that this active process might be a non-attentional inhibitory mechanism that is employed to further reduce the encoding of F items alongside selective rehearsal of Rover F item.},
  note = {booktitle inferred},
}

@inproceedings{mackinnon2023understandin,
  title = {Understanding fear in statistics classrooms: The relationship between perfectionism, negative feedback, and statistics anxiety},
  author = {Mackinnon, Sean P. and Alexander, Sean and Cribbie, Robert A. and Flett, Gordon L. and Hill, Taylor G. and RebeccaWorkye},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Anxiety is a problem for statistics education, with many students experiencing statistics-related fears. In three studies, we examine the relationship between perfectionistic personality, negative feedback (i.e., grades) and statistics anxiety. Study 1 (N=200) validated stimuli to be used as experimental manipulations for negative feedback. We generated two 5- item quizzes (easy & hard) from 30 multiple choice questions by assessingpercentages of students answering questions correctly. Study 2 (N=329) used a two-group, pre-post, between-subjects experimental design. Students completed measures of self-critical perfectionism and state anxiety and were randomized to the easy or hard statistics test condition. Using moderated multiple regression, we found an interaction effect where perfectionistic students had more negative reactions to failing a statistics quiz. Study 3 examined correlational data from York and Dalhousie (N=271) students currently taking a statistics class. Results show that self-critical perfectionism is positively correlated with domain-specific statistics anxiety and that GPA is negatively related to computational self-concept. Findings suggest perfectionistic students find statistics education anxiety-provoking. Educators may want to address perfectionistic attitudes in statistics classrooms to facilitate lowered anxiety and reactivity to mistakes.},
  note = {booktitle inferred},
}

@inproceedings{macphee2023development,
  title = {Development of a new treatment protocol for spatial neglect post-stroke: Protocol to test feasibility and effectiveness},
  author = {MacPhee, Catrina and Bergeron-Germain, Noemie and Aziz, Jasmine R. and Vaillancourt, Gina and Milligan, Teagan and Ge_i!J~kes&},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Spatial neglect is a common attentional condition post-stroke linked to poor rehabilitation outcomes. We have validated a game-like and computerized prism adaptation procedure (Peg-the-Mole, PTM) for the treatment of spatial neglect. Our goal now is to extend this treatment to iPad administration and to test the feasibility and effectiveness of the protocol in stroke inpatient and home settings. Forty right-hemisphere stroke patients experiencing mild to severe symptoms of neglect will be randomized to two groups: Use of PTM with 15° prism goggles (intervention) or 5° prism goggles (placebo control). Patients will complete ten treatment sessionswithin two weeks with the PTM prism adaptation procedure for 15 minutes per day. Blinded assessmentswill take place immediately before and after treatment and at one month follow-up. The PTM procedure has the potential to improve patient recovery and quality of life after stroke due to its gamified and portable features that promote treatment accessibility and adherence. The results will help determine if the treatment can be used successfully in inpatient and outpatient settings and who is likely to benefit.},
  note = {booktitle inferred},
}

@inproceedings{maxwell2023can,
  title = {Can a Tired Brain be Trained?},
  author = {Maxwell, Amy E. and Drake, Richard S. and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Working memory, the ability to hold and manipulate information, is a key determinant of many higher-order cognitive functions. Research has demonstrated that adaptive working memory training paradigms, namely then-back task, are more beneficial when paired with mindfulness meditation (MM), then when used alone. The underlying mechanisms of the relationship between MM and working memory are not entirely established. MM is, however, associated with a reduction in mental fatigue. The primary objective of this study was to examine hypothesis that mental fatigue acts as a partial mediator between MM and working memory training. Sixteen healthy adults listened to an audio tape of either MM or a Grimm's fairy-tale (active control), were assessedon their mental fatigue, and then completed n- back training. Pre- and post-intervention, participants were tested on measures of working memory, and mindfulness skills. Our results revealed that while participants in the MM group had decreased scores of mental fatigue, there was no difference in measures of working memory between groups, suggesting that a reduction in mental fatigue may not be the mechanism by which MM produces gains in working memory capacity.},
  note = {booktitle inferred},
}

@inproceedings{barresi2023kafka,
  title = {Kafka's Metamorphosis},
  author = {Barresi, John},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {The hero of Franz Kafka's story, The Metamorphosis, wakes Lp one morning as a huge beetle-like bug. Though he retains memories from his past life, his consciousness adapts to this radically different body until he dies from an injury caused by an ap pe his father threw at him. What are we to make of this transformation in self-identity? I will describe the distinct roles that first- and second/third-person perspectives have in one's experience of self and Kafka's failure at integrating these two perspectives in early development. I base my account on collaborative work with Chris Moore and works by other authors. It concludes with a discussion of Heinz Kohut's theory of how the 'modern' self relies on a vertical splintering of embodied being- in-the-world rather than a horizontal split between a conscious mind and unconscious embodiment found in theories from Descartes to Freud.},
  note = {booktitle inferred},
}

@inproceedings{mcarthur2023coerced,
  title = {Coerced sexting in committed relationships: Insights from a socio-cognitive perspective},
  author = {McArthur, Jennifer and Blais, Julie and Ternes, Marguerite},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Coerced sexting is recognized as a form of sexual violence; however, little attention has been afforded to sexting between partners in romantic relationships. The current study investigated young adults' attitudes and social perceptions of coerced sexting using the theory of planned behaviour (TPB) as a framework. Young adults (N=401) completed a survey assessing the central constructs of the TPB (i.e., attitudes, subjective norms, perceived behavioral control), past behaviour, and intentions to pressure a partner to sext. Attitudes and norms were positively related to intentions with the former accounting for the most variance. Past sexting behaviour was found to explain additional variance in intentions such that having previously pressured a partner increased intentions to engage in the same behaviour in the future. Sexual violence prevention efforts may benefit from targeting young adults' attitudes and perceived social acceptance of coerced sexting, even in the context of a romantic relationship.},
  note = {booktitle inferred},
}

@inproceedings{michaud2023altered,
  title = {Altered Size Discrimination Following Optogenetic Modulation of Somatostatin lnterneurons in Mouse Primary Visual Cortex},
  author = {Michaud and N.M and Boone and E.H and Long and C.R and Cr~wder and N.A},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Mice are an important animal model in vision research attributed to the availability of genetic tools used to explore neural circuits within the brain. In particular, optogenetic tools that use light to modify the activity of specific neural subtypes are useful for investigating the link between neural circuits and perception. Previous in vitro findings have implicated s'?l!1atostatin expressing (SOM+) interneurons in visual surround suppression, which is a receptive field property proposed to underly the perception of object size or the boundaries between objects. Using transgenic mice that express a suppressive optogenetic protein (ArchT) in their SOM+ interneurons, we tested whether size perception depends on SOM+ activity within primary visual cortex. Our mice rapidly learned a two-alternative forced choice size discrimination task, and preliminary data with optogenetic inhibition of SOM+ interneurons showed altered psychometric functions indicating mice made more errors during difficult discriminations.},
  note = {booktitle inferred},
}

@inproceedings{monchesky2023comparing,
  title = {Comparing methodologies: Quantifying beak colouration change in photostimulated European starlings (Sturnus vulgaris)},
  author = {Monchesky*, Ainsley N. and Parks, Broderick M. B. and Phillmore, Leslie S.},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Day length, or photoperiod, is the primary cue that signals breeding season in temperate songbirds. As day length increases (i.e., in spring), birds become photostimulated, which initiates a cascade of physiological changes to prepare birds for breeding. In European starlings (Sturnus vulgaris), one physiological change apparent in breeding season is a change in beak colouration; beaks change from black in winter to yellow in spring. There are multiple methods to quantify beak colouration in starlings, however inconsistencies among scales make comparability across the literature difficult. Here, we captured male and female starlings (n=ll) from the wild in January when in non-breeding condition and housed them indoors on a long day photoperiod for 21 days to induce photostimulation. We photographed beaks throughout the experiment and scored beak colouration using three standard categorical scales used previously in the literature and using a new, continuous scale which quantified beak colouration change as a proportion. The continuous scale revealed changes over the experiment undetectable by the categorical scales; we therefore recommend using this approach in future studies of starling reproductive physiology to ensure accurate, and more fine-grain, representation of beak colouration.},
  note = {booktitle inferred},
}

@inproceedings{mungall2023strategic,
  title = {Do strategic voters have a strategic personality? Examining the role of Machiavellianism in vote-switching},
  author = {Mungall, Luke R. and Pruysers, Scott and Blais, Julie},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Many citizens are "floating" voters, who switch their vote between different parties from one election to the next (Stiers & Dassonneville, 2019). There are many antecedents to vote-switching, but one explanation is individual differences in personality traits. For example, previous studies have consistently found that curious and open-minded people are more likely to engage in vote-switching (Bakker et al., 2016; Erisen & Blais, 2016). Theoretically, people with Machiavellian personality traits should also be vote-switchers, since their cold, calculating, and status-driven nature should lead them to break partisan ties and vote for candidates that have the best chance of winning. A recent study suggests that Machiavellian ism is not associated with a history of vote switching, but this cross-sectional study relied on self-reports of past voting behaviour, where the reasons for vote-switching are unknown (Pruysers & Blais, 2022). To resolve these limitations, we examined whether receiving pre-election polling information increases strategic vote- switching among those with Machiavellian personality traits. Our conference paper will present the results of this experiment.},
  note = {booktitle inferred},
}

@inproceedings{pandey2023investigatin,
  title = {Investigating Semantic Encoding in the Item-method Paradigm},
  author = {Pandey, Anja Ii and Taylor-Helmick, Tracy},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {In the study phase of an item-method directed forgetting task, memory instructions presumably operate by promoting further rehearsal of to-be-remembered (TBR) items and limiting encoding of to-be-forgotten (TBF) items. Consequently, in the test phase that follows, memory for TBR items is better than for TBF items. While some evidence suggests that semantic encoding of TBR items benefits from this differential rehearsal, other evidence suggests that the semantic properties of study items are just as likely to be encoded following an instruction to remember as they are following an instruction to forget. We continue our investigation of the nature of semantic encoding in the item-method paradigm by asking 1) what type of semantic information is encoded following an instruction to remember and despite an instruction to forget and 2) how do factors at encoding and retrieval affect recognition memory performance for the semantic representations of TBR and TBF study items.},
  note = {booktitle inferred},
}

@inproceedings{raja2023modifiable,
  title = {Modifiable Characteristics That Predict Outcomes in a Community-Based Intervention for Preschoolers with Autism Spectrum Disorder (ASD)},
  author = {Raja, Mcmina and Ferland, Melissa and Flanagan, Helen and Chitty, Dorothy and Garon, Nancy and Thomas, Megan and M, Isabel},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Pivotal ResponseTreatment (PRT)is an effective early intervention for children with autism spectrum disorder (ASD),but children do not benefit equally. Study aims were to (1) determine profiles based on children's baseline positive affect, imitation, and toy play; (2) examine associations between profiles and change in expressive communication (EC) following intervention. Preschoolers with ASD (n = 260), enrolled in a provincial PRT-basedprogram, contributed data including key variables coded from video-recorded pre-intervention play interactions with a clinician (n = 130). Cognitive (IQ) data were available for a subset. Latent profile analysis identified two groups differing on positive affect (F(l,128) = 6.791, p = 0.010, 112= 0.05), imitation (F(l,128) = 299.8, p < 0.001, 112= 0.70) and toy play (F(l,128) = 188.5, p < 0.001, 112 = 0.60). Multilevel modelling found that profile membership and IQ predicted post-treatment ECchanges. Findings provide guidance for individualizing early autism treatment.},
  note = {booktitle inferred},
}

@inproceedings{shephard2023motives,
  title = {Motives for substance use in individuals who use alcohol, cannabis, and nicotine},
  author = {Shephard, Aaron and Stewart, Sherry and Yakovenko, Igor and Barrett, Sean},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Background:Alcohol, cannabis, and nicotine are three of the most commonly used drugs, with all three being frequently used by the same individual. Substance use motives typically vary between users, but it is unclear whether these differences are dependent on substance type, level of dependence, or simply come down to individual differences. Method: 516 Canadian adults with past month use of alcohol, cannabis, and nicotine completed online surveys querying their substance use history, level of dependence, and motives for use of each substance. Linear mixed models were conducted for each motive, including substance and dependence on each substance as fixed factors, with participant ID (intercepts) being included as random effects. Results:Different substances were more frequently used for specific motives (i.e., cannabis for enhancement motives, alcohol for social motives, nicotine for sensorimotor motives). Higher levels of dependence correlated with greater endorsement of each motive. The majority of variance in each model was explained by individual differences. Discussion:Previous research has largely focused on one substance at a time, with motives being analyzed for one specific substance. This research shows that, while certain motives were endorsed more for certain substances, individual differences play the largest role in the endorsement of motives.},
  note = {booktitle inferred},
}

@inproceedings{stamp2023your,
  title = {Al as your TA, Using ChatGPTto Vet Exam Questions},
  author = {Stamp, Jennifer},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Maini:afiiing academic integrity is difficult in large undergraduate classes. The student-instructor ratio makes it almost impossible to verify the identity of the person who completes assessments and Al tools like ChatGPT do an excellent job of writing essays. Most strategies to strengthen academic integrity on traditional, in-person, test-based assessmentsfocus on policing cheating efforts when they happen. Although these strategies work reasonably well face- to-face, they are ineffective in an on line testing environment. In this talk, I'll share some strategies to leverage ChatGPT to design meaningful, cheat-resistant questions for open-book. on line exams in 3rd year class in our Psych/Neuro program (Hormones & Behaviour).},
  note = {booktitle inferred},
}

@inproceedings{stevens2023ongoing,
  title = {An Ongoing Journey: lndigenization in Introduction to Psychology},
  author = {Stevens, Dr. Leanne and Paul, Jocelyn},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {During this session, we will outline our ongoing journey aimed at weaving Indigenous knowledge throughout our first-year Introduction to Psychology open textbook - highlighting significant contributions, ways of knowing, and historical injustices, where appropriate. The new content spans many topics, relevant to Psychology and Neuroscience, including (but not limited to) spatial memory, Models of Needs (self-actualization), and the impact of intergenerational trauma on development. By outlining our approach - including the voices of those with lived experience and expertise, engaging students-as-partners, revisiting and revising learning outcomes - we hope to concrete ideas and pathways for creating meaningful learning opportunities in the classroom (and beyond). The textbook is still a work in progress, but our hope is that this remains a feature rather than a flaw. The open nature of the text allows us to respond to student inquiries, recent events, new discoveries, and ultimately to remain relevant to our current and future students.},
  note = {booktitle inferred},
}

@inproceedings{wildeboer2023understandin,
  title = {Understanding the Experiences of Parents Engaged as Partners in Co-Created Knowledge Mobilization Initiatives in Children's Pain},
  author = {Wildeboer, Emily M. and Chambers, Christine T. and MacKenzie, Nicole E. and Tutelman, Perri R. and Doi, Justine and Jordan, Isabel},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Engagement of patients as members of research teams has been increasingly recognized as an important part of patient-centered health research. The aim of this study is to understand the experiences of patient partners who were engaged in two co-created KM initiatives in children's pain. Data were collected as part of two collaborative KM initiatives about children's pain: It Doesn't Have to Hurt and Kids Cancer Pain, both of which engaged patient partners. Following their engagement, partners took part in a structured interview about their experiences. Interviews from each initiative were recorded, transcribed, and analyzed using an inductive content analysis approach. A total of 18 patient partners (9 from each initiative) participated. Overall, partners described their experiences very favourably. Several categories were generated across the data, including: 1) positive outcomes for partners, 2) difference between researcher and partner perspectives based on unique experiences; 3) contributions of patient partners directed the process and outcomes of the research; and 4) necessity of multiple patient partners on research team. These results can inform the development of best practices in patient engagement. Specifically, they can inform recommendations on how to improve engagement within pediatric pain research and KM. POSTER ABSTRACTS (In AlphabeticalOrder of Presenter) All Posters Will Be Presented From 12:30 pm to 2 pm in the Lilyan E. White Study Centre on the 4th floor.},
  note = {booktitle inferred},
}

@inproceedings{blais2023assessingthe,
  title = {Assessingthe Relationship between Antisocial Personality Traits and Cyberstalkingin a large sample of CanadianAdults},
  author = {Blais, Julie and Aelick, Charlotte A. and Scully, J. Michelle and Pruysers, & Scott},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Cyberstalkingis defined as the repeated pursuit of an individual using the Internet. Severalstudies of have identified the Dark Triad (psychopathy, Machiavellian ism, and narcissism) as related to cyberstalking behaviours; however, this research has tended to use less-than-ideal measures of the traits. The purpose of the current study was to assessthe associations between each Dark Triad construct among a large sample of people currently living in Canada (N = 1,725) while addressing several earlier limitations. After controlling for age and sex, only the antisocial facet of psychopathy (early and repeated antisocial behaviour; OR = 1.04, 95% Cl [1.02, 1.06]) and grandiose narcissism (inflated self-esteem and antagonism; OR= 1.01, 95% Cl [1.00, 1.02]) were significantly related to cyberstalking behaviour within the past 12 months. We will discuss how to improve Dark Triad research moving forward and what the results mean for identifying dynamic risk factors that can be targeted in evidence-based interventions.},
  note = {booktitle inferred},
}

@inproceedings{dockrill2023barriers,
  title = {Barriers and Facilitators to the Better Nights, Better Days during COV/D-19 Program for Parents and Healthcare Providers: A Qualitative Perspective},
  author = {Dockrill, Mya and Author), BSc(Presenting and Keys, Elizabeth and PhD and Myatt, Amber and Corkum, ~},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Due to concerns surrounding children's mental health and sleep during the COVID-19pandemic, Better Nights, Better Days (BNBD), was modified to support parents of children with sleep difficulties during the pandemic. Using virtual, semi-structured interviews, this study sought to understand the barriers and facilitators that parents (n = 34) and healthcare providers (HCPs)(n = 15) faced when completing and referring to the BNBD-COVID-19 program. Most parents and HCPsbelieved the program was effective in improving children's sleep, sleep knowledge, and/or daytime behaviour. Half of the parents reported that the pandemic made the program harder to implement, and most parents mentioned that time commitment and/or other external circumstances impeded their ability to complete the program. Interview feedback will be used to improve the program to better support children with sleep difficulties, as well as to improve HCP experiences when referring to the program in the context of a crisis.},
  note = {booktitle inferred},
}

@inproceedings{elliott2023lexical,
  title = {Lexical Decisions in Ortho-semantic Learning: An ERPStudy of Grade 3 Children in English and French Immersion},
  author = {Elliott, Laura and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Children in French immersion (FI) experience a lag in English literacy skills through the early grades of elementary school, until English instruction is introduced into the curriculum. Here we recruited third grade English and FI students to complete a novel-word learning paradigm, and a lexical decision task during EEGrecording, to compare N170 print and lexical tuning effects between the two groups. The N170 print and lexical tuning effects are measured using event-related brain potentials (ERPs) and have been shown to relate to behavioural measures of reading development. We hypothesized FI students would demonstrate bilateral N170 print tuning and no lexical tuning, while English students would demonstrate more left-lateralized print and lexical tuning of the N170, and higher reading proficiency. Findings demonstrated English and FI students performed similarly on behavioural assessments of reading. However, while both groups demonstrated print tuning effects, lexical tuning was only observed for English students. These findings demonstrate measurable differences in neural activity during reading between English and FI students, that do not necessarily indicate a lag in reading skill for FI students.},
  note = {booktitle inferred},
}

@inproceedings{foxall2023sleep,
  title = {Sleep for Health in Hospital and at Home},
  author = {Foxall, Victoria and Thomas, Megan},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Healthy sleep during hospitalization supports recovery, pain management, and resilience. Many pediatric patients and their accompanying guardians experience poor sleep in hospital due to family- and environment-related factors. Patients (2 to 16) and their accompanying guardians staying at least 2 nights in the PM U were invited to participate in a mixed-methods exploratory study comparing sleep in hospital to home. This included an optional semi-structured interview exploring sleep experiences, and disruptors and promotors of sleep. Interviews were audio-recorded, transcribed verbatim, subjected to thematic analysis guided by the Appreciative Inquiry framework, and compared to themes from a previous healthcare provider (HCP) survey. Findings showed a shared understanding between HCPand parents regarding many of the sleep disrupters, possible solutions and examples of supportive practices. COVID-19 was noted to be an additional challenge. Parents provided novel suggestions to encourage sleep and wellbeing and reported positive changes to their sleep at home following participation.},
  note = {booktitle inferred},
}

@inproceedings{garden2023pavlovian,
  title = {Pavlovian conditioned odour memory in the Neurexinl +/- mouse model of autism spectrum disorder},
  author = {Garden, Jessica F and Weaver, Ian C. G and Brown, Richard. E},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Neurexins (NRXNs) are presynaptic cell-adhesion molecules that bind with postsynaptic ligands to regulate synaptic development and function. Altered Nrxn gene expression is linked to neurodevelopmental disorders, such as autism spectrum disorder (ASD), in which learning and memory are impaired. The Nrxnl+/- transgenic mouse model, with the loss of one Nrxnl allele, is a novel model of ASD. Male and female Nrxnl+/- and WT (Nrxnl+/+; C57BL/6J) mice at 90-120 days of age were conditioned to dig in an odor pot to receive a sugar reward over 8 trials in a 1-day Pavlovian conditioning protocol. Their short- and long-term olfactory memory was compared with that of naYvemice receiving no odour conditioning. Using the time spent digging in the odour pot as a measure of olfactory memory, we hypothesised that Nrxnl +/- mice would have impaired long-term memory, however, they did not differ from the WT mice during the training day nor during 24-hour or 7-day memory tests. The Pavlovian conditioned mice, however, showed significantly more digging in the odour pot than na·ive mice during both the learning and memory trials, indicating that digging behaviour accurately reflects olfactory learning and memory in this task. Overall, the results indicate that Nrxnl+/- mice do not exhibit impaired olfactory learning or memory based on this 1-day Pavlovian conditioning odour paradigm.},
  note = {booktitle inferred},
}

@inproceedings{gaudreau2023effect,
  title = {The effect of sensory feedback modality on workload and performance in a remote teleoperation task},
  author = {Gaudreau, Sierra and Holland, Chris and LucasWan and Pan, Dr. Ya-Jun and Neyedli, Dr. Heather},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Combined visual-haptic feedback improves robot teleoperation without an increase in user workload 1 . However, these benefits have only been seen when each modality of feedback is either present or absent and have not been investigated in a graded manner that is more reflective of the settings in which this technology is used. Therefore, this study sought to investigate the impact of imperfect visual and/or haptic feedback on teleoperation and perceived workload. 25 participants navigated a virtual robot using a haptic device in four different conditions with either ideal or impeded visual and haptic feedback. Time to complete each trial and perceived workload were recorded. Only impeded visual feedback significantly impacted navigational ability and perceived workload, haptic feedback did not improve performance. These findings prompt further investigation into the user benefits of cross modal designs to examine if this type of system design is only beneficial to users in high workload tasks.},
  note = {booktitle inferred},
}

@inproceedings{kjgoruk2023sexual,
  title = {Sexual and Gender/Sexuality-Based Harassment in Canada: Prevalence and the Identification of Risk Factors},
  author = {KJGoruk and Blais, Julie and McArthur, Jennifer},
  booktitle = {Psychology and Neuroscience 47th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2023},
  abstract = {Sexual and gender/sexuality-based harassment are common and damaging forms of non-contact violence that can occur in-person or online. The purpose of this study was to determine the prevalence of both types of harassment in Canada and to identify whether established risk factors for offending behaviours (i.e., younger age, general antisociality, sexual deviancy), are predictive of each type of perpetration. Participants (N = 1,151) were recruited via Qualtrics' research panels and completed measures assessingvarious risk factors and were asked whether they had perpetrated both types of harassment in-person and/or online in the preceding twelve months. Overall, 5.2% of the sample reported perpetrating both types of harassment, 4.0% reported perpetrating only sexual harassment, and 4.8% reported perpetrating only gender/sexuality-based harassment within the last year. Salient predictors for both types of harassment were being younger in age, being a man, and scoring higher on telephone scatologia. Hypersexuality and hostile aggression were important for predicting sexual harassment only, and alcohol use and the affective facet of psychopathy were important for predicting gender/sexuality-based harassment only. Results suggest that generalized intervention programs for those who perpetrate both types of harassment may be effective, however, given inconsistencies in predictors for each behaviour, programs should be malleable to each individual's primary risk factors.},
  note = {booktitle inferred},
}

@inproceedings{dyack2024you,
  title = {Are You Wearing Your Clothes or Are Your Clothes Wearing You? The Roots of Children's Clothing-Based Inferences About Group-Level Knowledge},
  author = {Dyack, Alexandra and Workye, Rebeka and Barsoum, Marise and Reeves, Emma and Aragon, Victoria and Weatherhead, Drew},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Clothing is a powerful social marker that allows adults and children to implicitly gather information about others such as group membership, occupation, and social status. Recent research shows that children make inferences about people's knowledge based on their clothing, meaning they can deduce a group of people wearing the same clothing are likely to share similar knowledge. However, this research does not speak to where children are attributing group-level knowledge. It is possible that they believe knowledge comes within an individual or that it is attached to clothing, such that a person gains knowledge when they put on certain clothes and loses it when the clothes are removed. The current study assessed 5-8-year-old children's beliefs about knowledge when clothing was manipulated, by asking whether an individual retained previous knowledge and gained new knowledge upon changing her clothes. On average, participants believed an individual retained her previous knowledge after changing her clothing, but were unsure if she gained knowledge associated with her new clothes. These results support person-specific knowledge attribution, where children believe knowledge is an internal property that persists across external changes. Early on, children make complex inferences about people's internal properties based on group membership; education about within- and between-group diversity as it relates to clothing is crucial to ensure the prevention of overgeneralization, stereotyping and prejudice. Hendy, Basmah},
  note = {Poster},
}

@inproceedings{hendy2024nanoparticle,
  title = {Nanoparticle-based CNS Drug Delivery to Improve the Safety and Efficacy of IRX4204 in the Treatment of Schizophrenia},
  author = {Hendy, Basmah and Kasheke, Gracious DS and Hakim, Antoine and Foldvari, Marianna and Robertson, George S},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Schizophrenia is a psychiatric disorder characterized by positive, negative, and cognitive symptoms. There are no drugs that alleviate the negative and cognitive symptoms of schizophrenia - which have been linked to impaired lipid synthesis. IRX4204 is an experimental drug that increases lipid synthesis by activating the retinoid X receptor (RXR). However, IRX4204 suffers from poor brain penetration and the induction of hyperlipidemia by activating RXRs in adipose tissues. We propose that these problems can be overcome using nanoparticles (NPs) to preferentially deliver IRX4204 to the central nervous system (CNS). Unlike intravenous and oral drug administration, intranasally delivered drugs bypass the blood brain barrier and gain direct access to the CNS. Indeed, intranasal administration of IRX4204-NPs enhanced CNS drug uptake while reducing systemic drug exposure in mice. This increased the expression of RXR-induced genes in the CNS, indicating the enhanced CNS uptake of IRX4204 and release of this drug in sufficient amounts to activate RXRs. We now plan to determine whether our IRX4204-NPF is safe and effective in animal models of schizophrenia. McCord, Betsy},
  note = {Poster},
}

@inproceedings{mccord2024structural,
  title = {Structural Brain Abnormalities in Long-COVID: Impact on Cognition},
  author = {McCord, Betsabe and Hernandez-Castillo, Carlos R.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Introduction: Emerging evidence suggests that COVID-19 infection may induce long-term cognitive impairments. A detailed assessment of such impairments and their neurological underpinnings is still missing. We aim to identify associations between brain abnormalities and cognitive performance in long-COVID patients. Methods: We acquired MRI images from 42 long-COVID patients, and 37 healthy controls. Cognitive performance was assessed using two standardized test batteries (CBS and CCAS). Group differences on grey matter density (GMD) were analyzed using voxel-based morphometry (VBM). Mean GMD was extracted from clusters showing significant difference between groups. Statistical associations between GMD and cognitive test scores were assessed using false discovery rate correction to control for multiple comparisons. Results: VBM revealed significant differences in multiple brain regions, including the left precentral gyrus, left posterior cerebellum (Crus I), left pons, left anterior cerebellum, brainstem, and right anterior cerebellum (V & VI). Significant correlations were found between GMD and cognitive test scores, including semantic fluency, verbal recall, deductive reasoning, spatial planning, verbal short term and working memory, visuospatial working memory, and episodic memory. Conclusion: Our findings shows that GMD is associated with specific cognitive deficits in long-COVID patients. Highlighting the importance of understanding the neurological sequalae of the COVID-19 infection. Matthews, Bianca},
  note = {Poster},
}

@inproceedings{matthews2024anti,
  title = {Anti-Black Racism and Children's Pain Management: A Proposal},
  author = {Matthews, Bianca and Louie-Poon, Dr. Samantha and Chambers, Dr. Christine},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Introduction: Although all children will experience pain (acute or chronic), Black populations are disproportionately negatively impacted due to anti-Black racism. The objective is to gain an understanding of Black caregivers and their children's experiences of the impacts of anti-Black racism on their children's pain management. Methods: A narrative inquiry study, guided by critical race theory, will be used and it aims to capture the stories of lived experiences for marginalized populations. Five dyads (pairs of Black caregivers and their children between 12-18 years old) will be recruited. They must live in Canada and have had pain-related interactions with the Canadian healthcare system. Participants will take part in semi-structured interviews to capture their pain experiences. Interviews will be transcribed verbatim and inductively analyzed through thematic narrative analysis. Significance: Understanding diverse pain experiences of Black families will highlight research gaps in incorporating patient perspectives on anti-Black racism in children's pain treatments. Sozuer, Can},
  note = {Poster},
}

@inproceedings{sozuer2024modeling,
  title = {Modeling the impacts of sleep history dependent structural plasticity of astrocytic processes on glutamatergic transmission at tripartite synapses to lateral hypothalamic orexin neurons},
  author = {Sozuer, Can and Pandey, Vikas and Kubota, Yoshiyuki and Semba, Kazue},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Sleep is homeostatically regulated through interaction of sleep- and wake-promoting neurons such as orexin neurons, and the role of astrocytes in their synaptic interaction is an active area of investigation.Our previous work showed that sleep deprivation induces presynaptic inhibition of excitatory inputs to orexin neurons and that astrocytic processes withdraw from synapses after sleep deprivation. To determine whether astrocyte withdrawal can account for presynaptic inhibition, we computationally modeled synaptic release, the influence of glutamate clearance by astrocytes on glutamate diffusion in the extracellular space, and postsynaptic currents. Different conditions of astrocyte position, glutamate transporter density, and synapse geometry were compared to assess their effectiveness for inducing presynaptic inhibition through presynaptic mGluRs. The model elucidated that the astrocytic regulation on glutamate clearance is most effective under high-affinity presynaptic inhibition mechanisms such as that mediated by group III mGluRs found at synapses to orexin neurons. The results validate astrocyte withdrawal as a potential mechanism for our previous electrophysiological finding of sleep history dependent presynaptic regulation of wake-promoting orexin neurons. Glenham, Cecilia},
  note = {Poster},
}

@inproceedings{glenham2024pattern,
  title = {T-Pattern Analysis of Grooming Behaviour in the Neurexin-1+/- mouse model of Autism Spectrum Disorder},
  author = {Glenham, Cecilia},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Autism Spectrum Disorder (ASD) is a neurodevelopmental disorder characterized by deficits in communication, social interaction, and repetitive behaviors. Mutations of the Neurexin (NRXN) gene result in disrupted synaptic function and have been strongly implicated in ASD, although the precise mechanisms remain unclear. Mouse self-grooming is a repetitive, sequentially patterned behavior model, making it an ideal translational tool for ASD research. The Neurexin1+/- (Nrxn1+/-) is a novel mouse model of ASD, and our study was the first to perform grooming research for this strain. We previously examined grooming microstructure in male and female Nrxn1+/- mice compared to wild-type (Nrxn1+/+) mice by using traditional quantitative analysis. This study is a continuation of this research and by the implementation of T-Pattern analysis to detect hidden patterns of behavior. Preliminary results show that genotypic and sexually demographic differences in grooming patterns may exist between Nrxn-1+/ mice. This research helps enhance our understanding of the microstructural organization of repetitive behaviors in ASD models and highlights the advantages of using T-patterns in behavioral analysis. Aihara de Oliveira, Letícia},
  note = {Poster},
}

@inproceedings{oliveira2024adhd,
  title = {ADHD and Pedestrian Behaviour},
  author = {Oliveira, Letícia Aihara de and Bianchi, Alessandra},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Survival in traffic requires proper functioning of various psychological functions, related deficits, such as attention deficit hyperactivity disorder (ADHD), can be related to greater risk-taking behavior in traffic. The aim of this study was to investigate the relationship between ADHD and risk-taking behavior in pedestrians. Participants were asked to complete a questionnaire on pedestrian behavior, and the Attention Deficit Hyperactivity Disorder Scale for Adults. The sample consisted of 305 adults aged between 18 and 59, literate, and of both sexes. 36.3% were classified as having significant inattention compatible with severe difficulties, and 29.9% were classified as having a moderate level. There was a statistically significant positive correlation between ADHD-related symptoms and pedestrian behavior risk, which means that the higher level of ADHD, the greater the risky behavior as a pedestrian. McDonald, Emily},
  note = {Poster},
}

@inproceedings{macdonald2024more,
  title = {More Absolute Moderate-to-Vigorous Physical Activity is Associated with Better Health Related Quality of Life in Outpatients with Acquired Brain Injuries},
  author = {MacDonald, Emily E and Pellerine, Liam P and Miller, Katerina and Frayne, Ryan J and O'Brien, Myles W},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Health-related quality of life (HRQoL) is a patient perceived measure of physical, social, and emotional health. An acquired brain injury (ABI) occurs due to damage to the brain after birth, and individuals typically present with lower HRQoL. Most activity research characterizes moderate-vigorous physical activity (MVPA) in absolute terms; however, relative physical activity levels have been promoted. We test if higher MVPA duration in absolute/relative levels is associated with higher HRQoL in outpatients with an ABI. Twenty-six adults (54±13 years, 16 female) with an ABI completed the Quality of Life After Brain Injury questionnaire, a six-minute walk test (measure of aerobic fitness; 490±105 m) and wore an activPAL 24 hr/d for 7 days. Participants had an average HRQoL score of 53.4±15.0 (out of 100). Absolute MVPA (74.6±91.0 min/week, b=0.09, p=0.03), but not total (565.7±264.8 min/week, p=0.47), was associated with HRQoL. Neither relative LPA (521.4±244.9) nor relative MVPA (33.5±34.9 min/week) were associated with HRQoL (both, p>0.14). Targeting more absolute MVPA, but not necessarily relative MVPA, may be an effective strategy for interventions aiming to improve HRQoL for those with ABIs. Reeves, Emma},
  note = {Poster},
}

@inproceedings{reeves2024children,
  title = {Children's Beliefs About L2 Learners and Learning Motivations},
  author = {Reeves, Emma and Workye, Rebeka and Weatherhead, Dr. Drew},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Although past research has examined children's attitudes and beliefs about second language (L2) learners, very little has investigated the role of motivation. We examined whether an L2 learner's motivations for learning a language impacts children's social inferences. Participants aged 5-8 (N=90) were introduced to two fictional L2 learners possessing different learning motivations (social or academic) then given a selective learning task and asked which character they believed had higher L2 proficiency. On average, participants preferred to ask the social character for the name of an object but equally endorsed object names by both characters. Additionally, when asked about proficiency, participants chose characters equally. Overall, these results demonstrate that children have varied preferences for L2 learners depending on their learning motivation. Schwenck, Grace},
  note = {Poster},
}

@inproceedings{schwenck2024fear,
  title = {Fear of failure intensifies the relationship between statistics test performance and self-esteem: A two-group pre-post experiment},
  author = {Schwenck, Gracielle C and Alexander, Sean M and Cribbie, Robert A and Flett, Gordon L and Shephard, AND_SEP and Aaron and Mackinnon, Sean P},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Statistics courses are common within post-secondary programs, and many students report significant cognitive and affective barriers to statistics education. In line with the vulnerability-stress model, students with higher fear of failure may be more likely to experience decreases in state self-esteem (e.g., performance and social self-esteem) following the stressor of academic failure. This study examined changes in students' state self-esteem following a failed statistics test and identified if this association was moderated by fear of failure. Post-secondary students (N = 329) participated in a two-group, pre-post, between-subjects experimental study. Participants were randomly assigned to receive an easy or hard 5-item statistics test and feedback on their final score. Analyses used moderated multiple regressions. Students in the hard test condition had greater decreases in post-test performance and social self-esteem. Fear of failure moderated this association for performance self-esteem, but not social self-esteem. Results suggest students high in fear of failure are more likely to experience aversive responses to failure in a statistics assessment. Thus, interventions aimed at adjusting cognitions surrounding failure (e.g., reframing failures as learning opportunities) may prevent procrastination or unenrolment from challenging courses. Boossom, Isabella},
  note = {Poster},
}

@inproceedings{stewart2024impulsivity,
  title = {The Impulsivity Subscale of The Substance Use Risk Profile Scale (SURPS) Has Predictive Utility for Binge Drinking and Binge Eating Among Undergraduates Over Time},
  author = {Stewart, Simon B. Sherry; Aislin R. Mushquash; Christopher J. Mushquash; Daniel S. McGrath; Sherry H.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The Substance Use Risk Profile Scale (SURPS) is a measure that is used to select youth for personality-targeted interventions (i.e., PreVenture) that have been found to prevent or reduce risky substance use in young people. We tested whether the SURPS impulsivity subscale would predict changes in binge drinking and binge eating over time. Undergraduates (N = 410, M age = 20.7 years, SD = 5.5, women n = 307, men, n = 103) from two universities completed a longitudinal study with two weeks separating baseline and follow-up. At baseline, participants completed the SURPS impulsivity subscale and binge drinking and binge eating measures. At follow up, participants completed the measures again. Linear regression analyses showed that SURPS impulsivity (B = .12, p = .02) significantly predicted binge drinking and binge eating at follow up. Findings reveal that the SURPS impulsivity subscale is a useful tool in predicting increases in binge behaviour. Whyte, Kameryn},
  note = {Poster},
}

@inproceedings{whyte2024uses,
  title = {Uses of broad consent among diverse populations: A scoping review protocol},
  author = {Whyte, Kameryn and Emberly, Debbie Johnson and Johnson, Shannon},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The purpose of this scoping review is to examine the use of broad consent among vulnerable populations in Canada, with the intention of identifying cultural considerations for incorporation in the future implementation of broad consent in research. There are two research questions in this review: (1) Have there been any uses of broad consent among diverse populations in Canada? (2) What are the cultural considerations that need to be incorporated in the implementation of broad consent for future research? The diverse populations under study are: Black/African Nova Scotian, Indigenous, 2SLGBTQI+, and Newcomers. They have been identified as the priority population at the Centre for Psychological Health, a PhD clinical psychology training clinic. The findings will contribute to the identification of future areas of research and guidance for the development of policy related to obtaining broad consent for future research. We will share the development of the protocol, including inclusion/exclusion criteria, search strategy, data extraction and analysis. Collings, KC},
  note = {Poster},
}

@inproceedings{collings2024seasonal,
  title = {Seasonal change in neurogenesis within the vocal control system of wild black-capped chickadees (Poecile atricapillus)},
  author = {Collings, KC and Parks, Broderick M. B. and Phillmore, Leslie S.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Birds are remarkable models in neuroscience as they exhibit neuroplasticity throughout their brain and throughout their lifetime. Temperate-zone songbirds often show seasonal changes in the neural structures supporting vocal behaviour, including changes in neurogenesis. These seasonal differences in the brain are believed to reflect seasonal differences in vocal behaviour. Here, we evaluate neurogenesis in the vocal control system of wild male and female black-capped chickadees (Poecile atricapillus) across spring, summer and winter. Neurogenesis was quantified by measuring the immunolabelling of doublecortin (DCX), in vocal control nuclei HVC, Area X, and adjacent (non-nuclear) controls. We found that Area X had significantly more neurogenesis than its two control regions and HVC, while HVC did not differ from its controls. Birds captured in winter had significantly more neurogenesis in HVC than birds captured in spring, and we did not find seasonal differences in Area X. We did not find any sex differences in neurogenesis which may reflect the relatively small sex difference in vocal behaviour of chickadees. Overall, our data suggest the recruitment of new neurons to two distinct vocal control nuclei reflects the seasonally changing (or unchanging) demands of distinct components of vocal behaviour in this species. Roddick, Kyle},
  note = {Poster},
}

@inproceedings{roddick2024discovery,
  title = {Discovery of a new mouse model for spontaneous late-onset epileptic seizures},
  author = {Roddick, Kyle and Brown, Richard E. and Ortibus, Wyatt and Lu, Hong and Craig, Ann Marie},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {More people over 75 years of age develop epilepsy than children under 10. (Sen et al., 2020. Lancet 395:735-748). We have discovered a novel mouse model that (1) spontaneously develops seizures with no external induction; and (2) develops these seizures at an older age. We tested mouse lines with mutations in the neurexin-1 synaptic organizing protein: Nrxn1+/- mice with one allele disrupted, Nrxn1 ΔS5/ΔS5 mice with altered splice site 5 (Hong et al., 2023. Cell Reports 42:112714), Nrxn1 ΔS5/- mice, and WT control mice. Mice show seizures starting at 11 months of age. Seizures were scored on a revised Racine scale. Young mice showed elevated excitatory but not inhibitory synaptic activity in the Nrxn1 ΔS5/ΔS5 mice (Hong et al., 2023). We continue to screen the mice in our colony for seizures and plan to examine the neuroanatomical and neurochemical basis of these seizures. Rahman, Lamisa},
  note = {Poster},
}

@inproceedings{rahman2024mechanisms,
  title = {Mechanisms Localizing NMDA Receptors to Synapses},
  author = {Rahman and Ferguson, L.; and Krueger, L.; and R, S.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {NMDA-type glutamate receptors (NMDARs) play a key role in synaptic plasticity, and their properties are determined by their subunit composition. Studies addressing the regulatory mechanism of NMDAR recruitment to synapses have focused on protein interactions with the cytoplasmic C-terminal domains (CTD) of GluN2 subunits, whereas potential interactions of extracellular domains are unexplored. In this study, we examined the relative roles of the extracellular N-terminal domain (NTD) and the CTD of GluN2A subunits in the synaptic positioning of NMDARs by expressing terminal deletion mutants in rat hippocampal neurons. The constructs were tagged with super-ecliptic pHluorin to detect plasma membrane-localized NMDARs. While NMDARs containing full-length GluN2A were found to be significantly enriched at axospinous synapses, neither deletion mutants lacking the CTD nor the NTD exhibited preferential synaptic localization. Our results support our hypothesis that protein interactions of the CTD and the NTD are necessary for the synaptic localization of GluN2A-containing NMDA receptors. Dang, Lan},
  note = {Poster},
}

@inproceedings{dang2024mice,
  title = {Mice change their mind in a two-alternative-forced-choice psychophysical task.},
  author = {Dang and L.T.J and Michaud and N.M and Crowder and N.A},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Decision making involves gathering and evaluating information before committing to an action. However, even after making the decision, we continue processing information, potentially leading to reconsiderations, or changes of mind (CoM). In this study, we investigated the decision-making processes of mice using a two-alternative-forced-choice contrast detection task, where mice used a steering wheel to indicate the side of a grating stimulus. By continuously monitoring the steering wheel position as a choice was being registered, we found that CoM occurred more frequently in difficult trials. Moreover, mice tended to change to the correct choice on easy trials, but CoM direction approached chance on the most difficult trials. These results highlight several parallels in decision-making processes between humans and a genetically tractable animal model. Elliott, Laura},
  note = {Poster},
}

@inproceedings{elliott2024investigatin,
  title = {Investigating fNIRS Test-Retest Reliability during Lexical Decision},
  author = {Elliott, Laura and Rankaduwa, Saisha and Bode, Devon and Hulls, Marilla and Reynolds, Clare and Hamon-Hill, Cindy and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Functional near infrared spectroscopy (fNIRS) is a new technique in the field of neuroimaging, and the reliability of its signals has not been established during reading tasks. Prior to using fNIRS to investigate reading, it is necessary to establish the technique provides a reliable measure of task-related neural activity. The objective of the present study is to assess the test-retest reliability (TTR) of the signals recorded by fNIRS, during a lexical decision task, at the group and subject level. We recruited adults to complete a lexical decision task during fNIRS recording twice, with sessions occurring one week apart. Contrary to our hypothesis, preliminary results have demonstrated no significant print, sublexical, or lexical tuning effects at the group level. Additionally, our results demonstrate significant variability in TTR at the single subject level, for all tuning effects. At the group level, we observed fair to good TTR for print and lexical tuning, but not for sublexical tuning. Finally, preliminary group level results have demonstrated better TTR when analyzing data at the level of regions of interest, relative to individual channels. Identifying the reliability of fNIRS during a standard reading task will aid inguiding recommendations in its use in future studies of reading. Aubin, Lindsay},
  note = {Poster},
}

@inproceedings{aubin2024predictors,
  title = {Predictors of Sexual Arousal From Exhibitionistic Behaviour},
  author = {Aubin, Lindsay and Blais, Dr. Julie},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {This study investigated self reported measures of hypersexuality, grandiose narcissism, and sexual entitlement as predictors of arousal from exhibitionism. An anonymous self-report Qualtrics survey was completed by 1,200 participants who were at least 18 years of age, living in Canada, and able to read English. All three predictors were found to be moderately positively correlated with exhibitionism, with sexual entitlement having the strongest positive correlation (r = .32), followed by hypersexuality (r = .30), and grandiose narcissism (r = .23). A multiple linear regression with all 3 predictors entered was significant, predicting 13.90% of the variance in sexual arousal from exhibitionism. Gender differences were found, with men scoring significantly higher than women on all measures with effect sizes ranging from 0.20 (exhibitionism) to 0.45 (hypersexuality). This preliminary study makes important contributions to an area of sexual offending that has very little research and sheds light on gender differences in the prediction of arousal from exhibitionism. Keywords: exhibitionism, hypersexuality, sexual entitlement, grandiose narcissism, predictor, motivation ten Haaf, Mark},
  note = {Poster},
}

@inproceedings{haaf2024consistency,
  title = {The (In)consistency of Unilateral Optogenetic Modulation for Contrast Detection in Transgenic Mice},
  author = {Haaf, ten and M.R and Michaud and N.M and Crowder and N.A},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Mice are a valuable model in neuroscience research as they can be used with a variety of genetic tools to link brain and behavior. One such method is optogenetics, where specific neural subtypes express light sensitive channels that can be modulated with high temporal precision. This study used optogenetics to hyperpolarize somatostatin-expressing-interneurons unilaterally in primary visual cortex (V1) while mice completed a two-alternative-forced-choice contrast detection task. We found that for a subset of animals the unilateral disinhibition of V1 caused a side bias in the behavioral task. Here we explore the stability of this side bias over multiple weeks of testing. Raja, Moomina},
  note = {Poster},
}

@inproceedings{raja2024sleep,
  title = {Sleep for health in hospital and at home: The need to prioritize children with autism spectrum disorder and other neurodevelopmental disabilities},
  author = {Raja, Momina and Mathieson, Mitchell and Foxall, Victoria and Smith, Isabel M. and Thomas, Megan},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Healthy sleep is essential for development and protects against chronic pain and mood issues, important factors particularly for children with neurodevelopmental disabilities (NDDs) like autism. Over 80% of these children experience sleep difficulties, which are exacerbated during hospitalization, affecting both children and their parents. Our study assessed sleep disruptions and potential solutions for hospitalized children and their parents. Sleep, activity, mood, and environmental data was collected from eight parent-child (3 to 11 years) dyads over 48 hours in hospital and at home. Five parents also completed interviews post-discharge. Thematic analysis identified five themes: importance of sleep, influences on sleep, managing challenges, support systems, and the potential for positive change. Excessive noise and minimal light diurnal variation were recorded. Children with NDDs had more frequent and longer hospitalizations. Families proposed solutions, and increased awareness improved sleep quality. A follow-up study in partnership with families with NDDs and clinicians is currently underway. Dockrill, Mya},
  note = {Poster},
}

@inproceedings{dockrill2024evaluating,
  title = {Evaluating the usability and feasibility of the ABCs of SLEEPING for Adults mobile application: A proposal},
  author = {Dockrill, M and Bertrand, M and Corkum, P},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Good sleep health plays a vital role in adults' overall health and well-being; however, access to evidence-based sleep health resources is limited. The current study aims to assess the usability and feasibility of the ABCs of SLEEPING for Adults mobile app which provides evidence-based recommendations to improve sleep health based on an assessment of current sleep habits. Twenty adults will a) review and use the app, b) participate in an interview where they will provide feedback on the usability of the app by answering questions based on Morville & Sullenger's (2010) "User Experience Honeycomb" framework, and c) provide feedback pre- and post-intervention via questionnaires to assess the app's feasibility (including its implementation and preliminary effectiveness). The feedback from participants who reviewed and used the app will be incorporated into a modified version. This app has the potential to be an accessible resource for adults to promote sleep health, and if deemed usable and feasible, our next steps will be to test the full-scale effectiveness.},
  note = {Poster},
}

@inproceedings{singh2024sst,
  title = {Sst-Cre; Ai40D transgenic mice performing a psychophysical size discrimination task do not show sex- or cohort-related differences in task accuracy.},
  author = {Singh and P.K and Michaud and N.M and Haaf, ten and M.R and Nadeau and E and Atwell and I and Dang and L.T and Adesalu and K and Crowder and N.A},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Mice serve as an important animal model in neuroscience because of their compatibility with various genetic techniques. Our research program investigates links between neural circuits in primary visual cortex (V1) and perception in transgenic mice using optogenetic tools, which modify the activity of specific neuron subtypes using light. We are evaluating size perception in mice using a two-alternative-forced-choice size discrimination task where mice turn a steering wheel to bring the larger of the two stimuli towards to centerline for a reward. During certain trails, we illuminated V1 bilaterally with yellow light to suppress Archaerhodopsin expressing somatostatin-positive interneurons. Our present analysis of the psychophysical data focused on possible sex and cohort differences, accounting for other factors beyond optogenetic manipulation that could affect task performance.},
  note = {Poster; QA: needs-split-review; Split from P44 at: 'Singh, Prem'},
}

@inproceedings{garay2024exploring,
  title = {Exploring Behavioral Consequences in Cux2iresCre mice: Implications in Neurodevelopmental Disorder Research},
  author = {Garay, Pristine and Witt, Dr. Emily and Stanton-Turcotte, Dr. Danielle and Lulianella, Dr. Angelo},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Neurodevelopmental disorders (NDDs) affect social and repetitive behaviours differently in males and females, highlighting the need to understand the underlying genetic mechanisms. The gene Mllt11, previously studied in cancer, is now linked to neurodevelopment as conditional knockout (cKO) of Mllt11 in the cerebral cortex of mice reflects NDD-like traits. However, this model involves the Cre-loxP system, which requires the insertion of the Cre transgene upon gene inactivation that may cause additional behavioural changes. As such, we conducted a behavioural analysis of Cux2iresCre mice to assess the Cre transgene's impact on NDD characteristics compared to wild-type mice. No significant differences were found in weight regulation, olfactory function, and most anxiety-like and repetitive behaviours. However, sex-dependent differences emerged: male Cux2iresCre mice showed slight social scent response impairment, while females exhibited decreased chamber entries, increased social preferences, and digging behaviour. These findings underscore the sex-linked neurobehavioral effects of the Cre transgene in NDD research. Lewis, Ry},
  note = {Poster},
}

@inproceedings{lewis2024exploring,
  title = {Exploring the development of the N400 event-related potential in new learners of Spanish words},
  author = {Lewis, Ry and Newman, Aaron and Ali, Mobina},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The N400 ERP increases in amplitude in response to semantic violations. Learners of an unfamiliar language (UL) show no N400 ERP in response to semantic violations with UL words before training. Previous work showed that after 10 days of training, learners develop an N400 effect for semantic violations using the UL words. The current study was interested in exploring the development of an N400 for learners of an UL by performing EEG recordings throughout the entire training process, rather than simply at the end. Participants learned the meaning of Spanish words through association with images over a single session. Participants showed significant gains in correctly reporting whether an image and word matched or mismatched in meaning from before to after training, with proportion correct approaching ceiling. However, no significant N400 effects were found between match and mismatch test conditions from before to after training when averaged across participants. More days of training are likely necessary for the N400 to reliably emerge in participants. Hawkins, Sam},
  note = {Poster},
}

@inproceedings{hawkins2024perfectionis,
  title = {Perfectionism and Post-Secondary-Specific Stressors as Risk Factors for Academic. Outcomes: A Vulnerability-Stress Model},
  author = {Hawkins, Sam and Hill, Taylor and Mackinnon, Sean},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Introduction: Self-critical perfectionism and stress have been implicated as risk factors for maladaptive academic outcomes (i.e., decreased academic self-efficacy, decreased academic self-concept, and increased academic burnout). In the present study, we investigated a vulnerability-stress model, testing whether perfectionism (self-critical and rigid) moderates the relationship between stressor severity (academic and interpersonal) and academic outcomes. Method: A sample of 384 post-secondary students completed a cross-sectional survey involving questionnaires assessing perfectionism, stress, academic self-efficacy, academic burnout, and academic self-concept. Results: Main effects of stressor severity (both academic and interpersonal) were found to predict decreased academic self-efficacy and academic self-concept, as well as increased academic burnout. Main effects of self-critical perfectionism were found to predict decreased academic self-efficacy and increased academic burnout. Main effects of rigid perfectionism generally predicted increased academic self-efficacy and increased academic self-concept when controlling for stressor severity. None of the proposed interaction effects were statistically significant. Discussion: Findings suggest stressor severity (both academic and interpersonal) and self-critical perfectionism are strong predictors of maladaptive academic outcomes, and risk factors for poor academic functioning. The lack of an interaction effect suggests that a vulnerability-stress model does not explain why perfectionism leads to maladaptive academic outcomes. Ritsema, Vanessa},
  note = {Poster},
}

@inproceedings{ritsema2024accent,
  title = {Accent Intelligibility: Understanding the effects of race-based expectations and linguistic background},
  author = {Ritsema and V and Woryke and R and Weatherhead, D.E},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Race-based expectations and linguistic background can both influence accent intelligibility. However, past research on accent intelligibility has yielded conflicting results, and the underlying mechanisms of accented-speech processing remain unclear. Furthermore, the effects of race-based expectations and linguistic background have been studied largely in isolation, with past research focusing on monolingual listeners. The current study seeks to better understand the combined effects of race-based expectations and linguistic background on accent intelligibility by replicating the experimental design of McGowen (2015) with bilingual participants. The current study recruited 127 American participants fluent in English and Norwegian who listened to and transcribed 60 Mandarin-accented English sentences in noise. Sentences were presented with a White face or an East Asian face, with each condition designed to match or violate listeners' race-based expectations. Following sentence transcription, participants were asked to rate how strong they found accent to be from the experiment on a Likert scale. Participants also completed a short questionnaire that assessed their language usage, proficiency, familiarity, and attitudes. For analysis, a generalized linear mixed effects model was fitted to the data with condition, sex, accentedness rating, and participant language use as predictor variables. Results suggested that speaker race is not a salient speaker cue for bilingual listeners, and that bilingual listeners may therefore have different associations between ethnicity and accent compared to monolingual listeners.},
  note = {Poster},
}

@inproceedings{monchesky2024age,
  title = {Age, but not food-deprivation, affects hippocampal neuronal recruitment in the domesticated pigeon (Columba livia domestica)},
  author = {Monchesky, Ainsley N. and Parks, Broderick M. B. and Hayar, Casandra and Treberg, Jason R. and Kelly, Debbie M. and Phillmore, Leslie S.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The hippocampus, a brain region important for learning and memory, plays an inhibitory role in the stress response. Despite this structure being relatively conserved across evolution, mammals and birds navigate different environments, suggesting that mechanisms of neural plasticity, including neurogenesis, have allowed for environmental adaptations in hippocampus-based spatial cognition. Additionally, age impacts the mammalian and avian brain differently: mammalian neurogenesis declines with age whereas avian neurogenesis is brain-wide and life- long. Metabolic stress, like food deprivation, also decreases hippocampal neurogenesis, further suggesting that it plays a role in learning, memory, and the stress response. Therefore, my project examined the relationship between food deprivation, age, and neurogenesis in the hippocampus of the domesticated pigeon (Columba livia domestica), an avian spatial specialist. Subjects (n = 22) underwent a food-deprivation manipulation prior to sacrifice. Brain tissue was stained for doublecortin, an endogenous marker of neurogenesis; I quantified immunolabelling in three subregions of the hippocampus (DL, DM, and TrV). I found that TrV had the most neurogenesis across both age groups, however recruitment to DM and DL differed with age. The food deprivation manipulation did not affect neurogenesis. Overall, our findings show that pigeons may be resilient to metabolic stress, and neuronal recruitment may differ with age. Kaser, Alanna},
}

@inproceedings{jpk2024what,
  title = {What should we be studying? Research priorities according to individuals with Sexual Interest/Arousal Disorder and their partners},
  author = {JPK, Shimizu and S, Bergeron and GC, Schwenck and JS, Huberman and NO, Rosen},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Objective: Inclusion of patient perspectives may help to reduce misalignments between the research priorities of patients and researchers, however, the priorities of women and gender diverse individuals with Sexual Interest/Arousal Disorder (SIAD) and their partners remains unclear. The purpose of this study was to identify the research priorities of women and gender diverse individuals with SIAD and their partners. Methods: Couples coping with SIAD responded to an open-ended question asking them to list the top 3 things they think are important for SIAD researchers to focus on. A team-based qualitative thematic content analysis was conducted to identify themes. Results: Analysis of 1429 responses revealed 6 main themes: general causes, general treatment, and coping, biophysiological, relationship, psychological, and environmental contextual. Additionally, 4 sub-themes were identified within the latter 4 of the main themes: general, causes, treatment, and impact. Conclusion: Findings suggest that individuals with SIAD and their partners have similar and heterogeneous research priorities that are consistent with a biopsychosocial approach. Elassy, Kareem},
}

@inproceedings{zhang2024distribution,
  title = {Distribution & Recruitment Patterns during Locomotion},
  author = {Zhang), Kareem Elassy (PI: Ying},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {During development, spinal interneurons (IN) split into distinct populations; one of which being the diverse V3 IN population which are critical for interlimb coordination during locomotion. Efforts to further subdivide these according to their task-dependent recruitment and topographic locations have been limited to the higher lumbar region in the spinal cord. We took an exploratory approach to identify distributions of V3 IN populations in all spinal segments in mice and compare them to previously classified clusters in the lumbar region. Using c-Fos as a marker for neuronal activity, we also investigated V3 IN speed-dependent recruitment patterns. V3 IN clusters were found to have distinct distributions between spinal segments. The proportion of active V3 INs did not differ between high and low locomotor speeds, however, at higher speeds, V3 IN activity was more localized suggesting a more specific reorganization of the circuitry for higher locomotor demands. Semba, Kazue},
}

@inproceedings{hoferek2024kazue,
  title = {Kazue Semba1,2, Tatjana Golovin1, Chantalle Briggs1, Joan Burns1, Sayuri Hatada3, Samuel Deurveilher1, Yoshiyuki Kubota3,4},
  author = {Hoferek, Katie and Deacon, S. Hélène},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Sleep-wake cycles are regulated by alternate activation of sleep- and wake-promoting neurons. Increasing evidence, however, indicates that astrocytes, formerly considered 'housekeeping cells,' are in fact important partners of neurons in various brain functions and behaviours. We previously showed that astrocytes dynamically regulate excitatory transmission to wake-promoting orexin (ORX) neurons according to sleep history, by altering the distribution of glutamate transporter-1 thereby controlling presynaptic inhibition. To test the hypothesis that this synaptic plasticity results from structural remodeling of perisynaptic astrocytic processes, we used serial electron microscopy combined with immunoconfocal microscopy. We found that astrocytic processes at synapses to ORX neurons physically withdraw from synapses following 6 h of SD. We propose that perisynaptic astrocytic restructuring is a cellular mechanism for sleep homeostasis. Ethier-Gagnon, Mikaela},
}

@inproceedings{ethiergagnon2024trauma,
  title = {Trauma and cannabis cue-induced reward circuit alterations in cannabis users with trauma histories},
  author = {Ethier-Gagnon and M and Barret and S.P and Romero-Sanchiz and P and Helmick and C and McAllindon and D and Tibbo and P and Crocker and C and Good and K and Arenella and P and Rudnick and A and Cosman and T and Trottier and S.-J and DeGrace and S and Collins and P and Girgulis and J and Snooks and T and Stewart, S. H},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Trauma histories increase risk for excessive and problematic cannabis use. The trauma-cannabis link may be related to conditioned craving to trauma cues which arises through classical and operant conditioning; underlying brain mechanisms remain unknown. N=23 cannabis users with trauma histories (Mage=33.5, 69.6% female) were presented with personalized trauma, cannabis, and neutral cues in random order using a cue reactivity paradigm in the MRI. Participants were assessed for subjective craving and emotional responses. Functional connectivity (FC) between striatal, cortical, and limbic regions was measured during cue presentation. Trauma and cannabis cues affected craving and emotions in expected ways. Trauma cues increased FC within the striatum and between the striatum and cortical regions, but decreased FC between cortical regions and dorsal striatum-limbic connectivity compared to other cues. Cannabis cues increased dorsal striatum-cortical connectivity but decreased overall cortical connectivity compared to neutral cues. Findings highlight the potential neural mechanisms underlying the trauma-cannabis link. Klein, Raymond},
}

@inproceedings{klein2024assessing,
  title = {Assessing the Networks of Attention: ANT-Database and Portable Attention-Trip},
  author = {Klein, Raymond M and McCormick, Colin and Arora, Swasti},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {As put forward in Posner's taxonomy, attention refers to three basic neuro-cognitive processes: alerting, orienting, and executive control. Developed by Posner & colleagues over two decades ago the Attention Network Test (ANT) provides a convenient measure of the efficacy the networks that mediate these functions. Since then, the ANT and its variants have been so widely used to measure attention networks that we developed a publicly accessible database of all studies using any version of the ANT to answer any question. We have also developed a more engaging, game-like version of the ANT, AttentionTrip, which has recently been ported to the iPad. In this presentation, we will illustrate the value of the ANT-Database by describing the studies which have cited using it, and we will demonstrate the ways AttentionTrip can be used (and has been used). Drake, Richard},
}

@inproceedings{klein2024richard,
  title = {Richard S. Drake, Amy E. Maxwell, Tammy L. Lamb, David Whitehorn, K. Ryan Wilson, Gail A. Eskes},
  author = {Klein, Raymond M and Sutherland, Dawson and Hurst, Austin},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Computerized cognitive training (attention process training) and mindfulness meditation practice (attention state training) are promising avenues for cognitive enhancement given their accessibility (e.g., at-home, cost-effective, available for all ages). Tang and Posner (2009) positioned the two approaches as complementary but orthogonal methods that help an individual avoid "two extremes of the untrained mind": mental fatigue (decreased through attention process training) and mind wandering (decreased by attention state training). Although Tang and Posner imply that combining both training types might confer additional benefits (by reaching an "attention balance state"), dual intervention studies are uncommon. In this talk, we report our in-progress work examining the specific and combined effects of guided, mindfulness meditation and adaptive n-back training. To improve our power and assess the stability of the effects, we analyzed three datasets that used similar methodologies across in-person and at-home (online) formats. We will discuss trends, implications and applications, and next steps. Sean, Mackinnon},
}

@inproceedings{lewis2024exploringa,
  title = {Exploring the Role of Attentional Withdrawal in Item-Method Directed Forgetting Through Visual Search},
  author = {Lewis, Ryan and Taylor, Tracy L.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {We embedded a serial and pop-out visual search into the study phase of an item method-directed forgetting paradigm to assess attentional availability following instructions to remember (R) or forget (F). Study words were presented to the left or right of a central fixation (Experiments 1-2) or at center (Experiments 3-5), followed by a visual (Experiments 1-4) or auditory (Experiment 5) memory instruction, and then by the search display. Although the evidence did not support a differential withdrawal of attention following F compared to R instructions, Experiment 5 replicated slower response times to visual targets that followed F compared to R instructions (e.g. Fawcett and Taylor, 2008; 2012) - consistent with the view that intentional forgetting engages an active cognitive process. We speculate that this active process might be a non-attentional inhibitory mechanism that is employed to further reduce the encoding of F items alongside selective rehearsal of R over F item. Sean, Mackinnon},
}

@inproceedings{mackinnon2024poor,
  title = {Poor grades in statistics classes longitudinally predict increased anxiety and worsened attitudes towards statistics education},
  author = {Mackinnon, Sean P. and Alexander, Sean M. and Cribbie, Robert A. and Flett, Gordon L. and Hill, Taylor G.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Students report anxiety and lack of confidence in statistics classrooms. Because statistics classes can be difficult, early negative feedback (e.g., poor grades) might intensify anxiety and increase negative attitudes towards statistics. In the current study, we test whether statistics class grades predict future attitudes and anxiety towards statistics education. Participants included students taking a statistics class at time 1 (N = 423). We used a 2-wave longitudinal survey design, where participants completed surveys during the first month of classes and ~4 months later once grades were released. We measured statistics anxiety, statistics attitudes, and self-reported statistics grades. Statistics class grades were negatively related to statistics anxiety and attitudes towards statistics at time 2, even when controlling for baseline levels of outcomes at time 1. That is, students who received poor grades experienced increased anxiety and worsened attitudes towards statistics once the class was completed. Findings suggest early setbacks in statistics education (i.e., poor grades) may intensify negative attitudes towards statistics education which may lead students to avoid further study of statistics. Instructors might consider increased use of formative assessments and active attempts to reduce anxiety in the classroom to keep students engaged in statistics education. Stewart, Sherry},
}

@inproceedings{exposure2024effects,
  title = {Effects of trauma cue exposure and PTSD on affect and cannabis cognition in cannabis users with trauma histories: Use of expressive writing as an online cue-reactivity paradigm},
  author = {exposure, Effects of trauma cue and affect, PTSD on and paradigm, cannabis cognition in cannabis users with trauma histories: Use of expressive writing as an online cue-reactivity},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Conditioned memory associations between trauma cues, distress, and cannabis use may contribute to PTSD-cannabis use disorder (CUD) comorbidity. These associations can be studied experimentally by manipulating trauma cue exposure in a cue-reactivity paradigm (CRP). We examined CRP condition (trauma, neutral) and PTSD group (likely PTSD+, PTSD-) effects on affective and cognitive outcomes using an online expressive writing CRP. N=202 cannabis users with trauma histories (43.6% male; M age=42.9) completed a validated PTSD measure and were randomized to trauma or neutral expressive writing. Then they completed validated measures of affect, cannabis craving, and memory accessibility of cannabis information. Hypothesized main effects of expressive writing condition were found for negative affect, expectancy cannabis craving, and memory accessibility of cannabis information, and of PTSD group for negative affect and all cannabis craving dimensions. Interventions focused on reducing negative affect and expectancy craving to trauma cues may prevent/treat CUD among cannabis users with PTSD. Li, Shuya},
}

@inproceedings{li2024alzheimer,
  title = {Alzheimer's Disease associations with estrogen through changed methylation of ERα promoter regions and Aß42 binding},
  author = {Li, Shuya and Weaver, Dr Ian},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Alzheimer's disease (AD), a neurodegenerative disorder associated with Aß42, has gender-linked risks, implicating estrogen (E2), a neuroprotective hormone. The Weaver lab previously showed 5x-FAD mice, an AD model, had decreased methylation of ERα promoter region and increased Aß42 binding. This study investigated these results' applicability to humans and hypothesized that lower ERα expression in AD patients is associated with increased Aß42 binding, and decreased DNA methylation. Using twelve human frontal-cortex brain samples, ERα promoter methylation was determined using bisulfite pyrosequencing, and Aß42 binding, using ChIP-PCR. Of the 23 ERα promoter region methylation sites analyzed using bisulfite pyrosequencing, non-AD patients had increased methylation percent compared to AD patients (p<0.001). ChIP PCR of 5mC, Aß42 DNA interaction patterns found increased Aß-42 binding in the AßID region of AD patients (p<0.001). Methylation and Aß binding patterns suggest Aß42 involvement in ERα regulation, encouraging additional research of ERα mRNA transcript and E2 protein abundance. Dolek, Simal},
}

@inproceedings{kaser2024bullying,
  title = {Bullying prevalence and associations with mental health problems among Canadian undergraduates during the COVID-19 pandemic},
  author = {Kaser and (presenter), A. C. and Lambe and J, L. and Yunus and M, F. and Conrod and J, P. and Hadwin and F, A. and Keough and T, M. and Krank and D, M. and Thompson and K and Stewart and H, S.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The COVID-19 pandemic impacted educational contexts and mental health and has been associated with heightened adolescent cyberbullying; however, bullying research at university is limited. We examined gender and pandemic-related differences in cyber- (online) and traditional (in-person) bullying among 1435 first-year undergraduates and bullying associations with internalizing (anxiety; depression) and externalizing problems (alcohol use; risky behaviour). For overall bullying prevalence, victimization (47.1%) exceeded perpetration (26.2%) and traditional bullying (51.7%) exceeded cyberbullying (18.2%). Women had higher odds of victimization compared to men. Surprisingly, Fall 2022 (low COVID-19 restrictions) students had higher odds of cyber-victimization and -perpetration than Fall 2021 (high COVID-19 restrictions) students. Positive associations were identified for internalizing outcomes with traditional and cybervictimization, alcohol use with traditional perpetration, and risky behaviour with all forms of bullying. Bullying persists post-pandemic and has concerning associations with emerging adults' mental health, warranting continued monitoring and support during the transition to university. Irish, Blair},
}

@inproceedings{dolek2024cueing,
  title = {Are cueing effects really eliminated when accuracy is emphasized, and single masks eliminate uncertainty about target location?},
  author = {Dölek, Şimal and Prasad, Seema and Christie, John and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The present study examined the influence of spatial pre-cuing on the accuracy and speed of masked target identification, with the single target covered by either a single mask on the target location or multiple masks on all possible target locations. We analyzed how invalid versus valid cues affected participant reaction time (RT) and accuracy. Additionally, we introduced a speed-stress manipulation directing one participant group to favor response quickness, while the other was directed to prioritize accuracy without time constraints. In Experiment 1, clear cueing effects were found in RT and accuracy across all conditions. As Experiment 1 presented homogenous blocks of either single or multiple masked trials, a subsequent experiment randomized single and multiple mask trials within each block. This approach aimed to extract the true effects of cueing, detached from participants' strategic adjustments based on the higher informativity of the single mask compared to the pre-cue. Confirming initial findings, the follow-up experiment revealed consistent cueing effects across almost all conditions, in terms of both RT and errors. While our results support the signal enhancement theory of cueing effects, we also consider the potential of a hybrid model involving noise reduction and signal enhancement as the basis of this phenomena. Gazit, Tamar},
}

@inproceedings{gazit2024psychologica,
  title = {Psychological interventions for teenagers with posttraumatic stress disorder: A scoping review},
  author = {Gazit, Tamar and Walker, Sydney and McGrath, Patrick J and Hill, Taylor},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {A scoping review was conducted to examine psychological interventions for treating posttraumatic stress disorder (PTSD) in teenagers. The review aimed to identify relevant studies, research methodologies, and knowledge gaps. We retrieved candidate studies from three databases on July 5, 2023, and screened citations using Covidence. English-language studies of psychological interventions for teenagers (ages 13-19) with PTSD were included. Out of 20,288 retrieved citations, 48 studies met the inclusion criteria. The most frequently reported interventions included Trauma-Focused Cognitive Behavioural Therapy (n=10), Prolonged Exposure (n=8), Cognitive Processing Therapy (n=5), and Narrative Exposure Therapy (n=4). Seventeen studies reported on unique interventions. Study designs varied, including randomized controlled trials (n=27), and quasi-experimental studies (n=10). Reported findings indicate that these interventions generally reduced PTSD symptoms. Gaps were noted in digital delivery methods, mechanisms of change, and interventions for less common traumas. These findings highlight critical areas for future research, particularly the need for additional empirical evaluation of both established and emerging treatment options for this vulnerable population. Hill, Taylor},
}

@inproceedings{hill2024little,
  title = {It's the Little Things in Life: Enjoyment of Different Types of Personal Projects},
  author = {Hill, Taylor G. and Coughlan, Emma C. and Mackinnon, Sean P.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Many positive psychology interventions aim to improve happiness through engagement in simple everyday activities via intrinsic rewards. Personal projects are goal-directed activities that offer a way to study the intentional pursuit of happiness. This exploratory study identifies the types of projects that people engage in, and the dimensions predict hedonic well-being (enjoyment). Participants (N = 327) completed a cross-sectional survey. Two coders thematically coded projects; we used linear mixed models to identify which project types and dimensions uniquely predict enjoyment. People engaged in various types of activities which were enjoyed to different extents - they tend to experience greater enjoyment when projects encourage autonomy, control, likelihood of success, progress, absorption, low difficulty, and low challenge. Knowledge on which activity characteristics are linked to well-being can inform tailored positive psychology programming. Overall, people tend to find activities which are relatively easy and where they make a lot of progress more enjoyable, indicating simple daily activities are one way to intentionally prioritize daily well-being. Hill, Taylor},
}

@inproceedings{hill2024focused,
  title = {Focused, flourishing, but not in flow: Achievement strivers' experiences of competence, flow, and well-being during personally expressive activities},
  author = {Hill, Taylor G. and Loock, Johanna V. and Mackinnon, Sean P.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {One route to increasing well-being is pursuing activities which suit one's personality strengths. Achievement strivers tend to organize their behaviors in ways that promote goal attainment and well-being. We tested the hypothesized process that achievement striving would lead to increased well-being over time through feelings of competence and flow. Students (N = 346 at Time 1; N = 244 at Time 2) completed an online survey measuring personality, personally expressive activities, basic psychological need satisfaction, flow, and well-being at two timepoints, about 4 months apart. We used cross-sectional and longitudinal serial mediation models to test our hypothesis with eudaimonic and hedonic well-being. Achievement striving was positively correlated to competence and well-being, but the indirect effects did not show that well-being is boosted by feeling competent and in flow during personally expressive activities, cross-sectionally or longitudinally. While achievement strivers tended to feel happy and competent at personally expressive activities, the mechanistic pathway to well-being is not yet clear. Future studies might recruit larger sample sizes and utilize smaller time lags.},
}

@inproceedings{irish2024juvenile,
  title = {Juvenile Idiopathic Arthritis and Pain-Related Stigma},
  author = {Irish, Blair N and Chambers, Christine T and Dol, Justine and Huber, Adam H and Brandelli, Yvonne N},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Juvenile Idiopathic Arthritis (JIA) is a chronic inflammatory condition associated with pain in childhood. Youth with JIA have reported experiencing negative judgement from others in response to their feelings of pain (i.e., pain-related stigma). This can negatively affect their physical and psychological health. How pain-related stigma impacts individuals' health outcomes is partly determined by their reactions to these experiences. This study will explore how youth with JIA and their caregivers react to pain-related stigma. To accomplish this, 15 youth (ages 13-18) with JIA and 15 caregivers of a youth with JIA will complete separate semi-structured interviews with questions asking about their (or their child's) experiences of pain-related stigma and how they reacted to these experiences. The interview data will be analyzed using reflexive thematic analysis. This will result in separate themes describing how youth with JIA and caregivers of youth with JIA react to pain-related stigma.},
}

@inproceedings{holland2024correlated,
  title = {Correlated but Not Connected: The Influence of Trust on Reliance Behaviour When Working with Automation},
  author = {Holland, Christopher and Perry, Grace and Neyedli, Heather},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Trust plays a crucial role in human-automation collaboration, with imbalances leading to performance issues (Lee & Moray, 1992; Stowers et al., 2000). Trust's impact on user behavior is influenced by factors such as self-confidence, automation capabilities, and workload. Our lab's previous work used a binary choice task to show that trust in automation is dynamic and influenced by initial performance. Automation with moderate reliability can build trust over time, whereas initially unreliable systems struggle, even if reliability improves (Rittenberg et al., 2024). Despite reported distrust, user performance often aligns with automation reliability, suggesting distinct yet intertwined constructs of trust and reliance. This study aims to understand trust and reliance dynamics with varying automation reliability, directly assessing reliance behavior and capturing self-reported self-confidence. We also explore the effects of feedback, task order, and initial reliability on trust calibration, aiming to enhance the design of future automated systems and interfaces. McCormick, Colin},
}

@inproceedings{mccormick2024about,
  title = {It's About Time: Distinguishing the Influence of Reflexive and Volitional Mechanisms of Temporal Attention},
  author = {McCormick, Colin R. and Klein, Raymond M.},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {In a noisy and dynamic world, the ability to modulate arousal and predict the temporal structure of events is critical to improve how efficiently we process and respond to information. Despite over a century of research on temporal attention, there remains inconsistency in the naming of mechanisms, which involves the confounding of independent modes of allocation. Relatedly, there is also uncertainty regarding the stage of processing which is affected. In this talk, I will present the results from two distinct temporal attention paradigms, which highlight distinctions between voluntary and reflexive modes of temporal attention. I will then explore how the converging evidence from these studies align with prior theories of temporal attention. Johnson, Debbie},
}

@inproceedings{johnson2024year,
  title = {A year in review: The Centre for Psychological Health},
  author = {Johnson, Shannon and Pencer, Alissa and Emberly, Debbie},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {The Dalhousie Centre for Psychological Health (CPH) is a collaboration between the Office of Addictions and Mental Health (OAMH) and Dalhousie University's Clinical Psychology PhD Program. CPH is dedicated to creating a supportive learning environment in which clinical psychology students can gain experience in conducting assessments and delivering treatment with individuals from diverse and marginalized backgrounds. Our aim is to increase access to psychological services, by providing low barrier and evidence-based mental health care, while also meeting student training needs. The CPH offers assessment and intervention services, including individual, couples, and group therapy. Mitchell, Donald},
}

@inproceedings{mitchell2024prior,
  title = {Prior short treatment of amblyopia in kittens reduces efficacy of later therapy.},
  author = {Mitchell, Donald and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Some clinical reports suggest that interventions to treat amblyopia in children may be less effective if they had received prior unsuccessful treatment. This possibility was explored in an animal model of amblyopia by use of conventional patching therapy, whereby the "good" or non-amblyopic eye is occluded to force use of the amblyopic eye. Deprivation amblyopia was induced in one eye of 10 kittens that had one eye occluded for a week at 3 weeks of age. The efficacy of treatment by occlusion (patching) of the non-amblyopic eye for 2-3 weeks at 5-6 weeks of age was compared between two groups of animals. Whereas one group of animals (the control group) received this treatment alone, for animals in the second group the same treatment was preceded by a very short (3 day) period of such occlusion of the non-deprived eye at around 4 weeks. The mean visual acuity recovered by the deprived eye of animals from the control group was 2 ½ times better than that observed in the animals that received two periods of patching treatment. Eskes, Gail},
}

@inproceedings{gaudreau2024visual,
  title = {Visual Scanning Training for Visuo-spatial Neglect},
  author = {Gaudreau, Sierra and Holland, Chris and Wan, Lucas and Pan, Dr. Ya-Jun and Neyedli, Dr. Heather},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Introduction: Visuo-spatial neglect (neglect) is a common attentional disorder after right hemisphere stroke characterized by difficulties with orienting, detecting, or responding to contralesional information. Visual scanning treatment (VST) is recommended, but effective treatment requires intensive practice for at least 10-15 hours, and thus it is difficult to implement with short stays and limited hospital resources. Objectives: We aimed to examine the feasibility and effectiveness of an online VST program (SpyTrain) for neglect post stroke. Methods: VST was delivered to 4 patients with neglect and 1 control using a non-concurrent multiple baseline single-case experimental design. Outcomes were analysed with Tau-U, a nonparametric test of non-overlap and trend. Results: Findings were positive for feasibility and effectiveness on primary and transfer measures and will be discussed. Conclusions: If this online method of VST continues to be feasible and effective in our ongoing research, it would provide an accessible form of treatment for a common and chronic disorder, improving independence and quality of life after stroke. Deacon, Helen},
}

@inproceedings{deacon2024how,
  title = {How theory can inform practice and back again: a virtuous circle.},
  author = {Deacon, Helene and Giatzitzidou, Sofia},
  booktitle = {Psychology and Neuroscience 48th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2024},
  abstract = {Children's books contain many complex words, and these can be a barrier to their ability to understand what they read. One of the primary ways in which words are complex is that they are made up of roots and affixes, also known morphemes. I review our recent theory on how children use morphemes to help them in their reading. I also show recent data from several large-scale longitudinal study testing these ideas, and how we can apply these data to instruction. Shimizu, Justin},
}

@inproceedings{ahmed2025age,
  title = {Age-Related Changes in Olfactory Discrimination and Reversal Learning Performance in Neurexin1 +/- Transgenic Mice},
  author = {Ahmed, Mohammed Ali and Shaw-Litzgus, Simone and Ortibus, Wyatt and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Autism Spectrum Disorder (ASD) is a neurodevelopmental disorder marked by challenges in social communication, restricted interests, and repetitive behaviours. Nrxn1 is a presynaptic cell adhesion protein that interacts with postsynaptic neuroligins to regulate synaptic signalling. Nrxn1 is vital for learning and memory and has been associated with ASD. Nrxn1+/- transgenic mice have a knockdown of the α, β, and γ isoforms, leading to impaired synaptic transmission. Our study examined whether age (young vs. old) and sex (male vs. female) affected performance of Nrxn1+/- mice in olfactory discrimination and reversal learning tasks compared to C57BL/6J wildtype controls. Results showed that old mice had a significantly lower completion rate in the learning tasks, compared to young mice. Among the old mice, Nrxn1+/− mice had a lower completion rate than wildtype mice. The old mice had a significantly higher number of errors to the 85% criterion than the young mice in an initial discrimination task. These results suggest that as mice age, they face impairments in cognitive function and flexibility, indicating that this procedure may be used as a test for novel drugs which might increase cognitive function during aging.},
  note = {Poster},
}

@inproceedings{imam2025leveraging,
  title = {Leveraging Speech Analysis for Cognitive Load Measurement in Young Adults: A Sex-Based Comparative Study},
  author = {Imam, Aurthy},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {This study explored how cognitive load impacts speech production and whether sex or baseline fatigue moderates this relationship. Thirty young adults completed low and high cognitive load speech tasks, which involved spontaneous speech and dual-task conditions with arithmetic and verbal fluency challenges. Acoustic (e.g., speech rate, pitch) and disfluency features (e.g., filled/silent pauses) were analyzed using PRAAT and LIWC, while perceived load was assessed with the NASA-TLX. Results showed significant decreases in speech rate and increases in filled pauses under higher cognitive load. Participants with higher fatigue scores exhibited greater changes in speech rate and pitch modulation. These findings support the use of speech as a non-invasive marker of cognitive load and point toward potential applications in workload monitoring across clinical, educational, and occupational settings.},
  note = {Poster},
}

@inproceedings{inness2025longitudinal,
  title = {Longitudinal Effects of Parental Smartphone Usage on Child Socioemotional Wellbeing Proposal},
  author = {Inness and B and Montalvo and A and Mason and L and Khoury and J and Stewart and H, S. and Meier, S},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Parental connection and responsiveness have been well-established to play a central role in children's social wellbeing and emotional health. However, integrating smartphone technology into daily life has caused concern about how these devices might significantly interrupt parental responsiveness. Research has found differences in parenting practices due to smartphone use, consequently impacting children's socioemotional health. There are a variety of mechanisms that might explain these impacts, however, the details have yet to be identified. This study will investigate the two primary postulated mechanisms: "technoference", the interruption of interactions with children by a smartphone, and "immersion", the absorption of parents' attention by the smartphone. Using a multimodal longitudinal design, 150 parent dyads with 12 to 18-month-olds will complete online questionnaires, download a mobile sensing app, and be observed interacting with their child. It is hypothesized that heavy parental smartphone use, objectively recorded via mobile sensing, will predict poor parental responsiveness and child socioemotional development over time. Technoference and immersion are expected to mediate the association between smartphone use, parental responsiveness, and child socioemotional wellbeing. This study aims to inform parents, policymakers, clinicians, and researchers on how and when parental smartphone use impacts child socioemotional development.},
  note = {Poster},
}

@inproceedings{ismail2025effects,
  title = {Effects of Age on Motor Coordination and Motor Learning in Mouse Models of Autism},
  author = {Ismail, Salma and Grendon, William and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Autism spectrum disorder (ASD) is a neurodevelopmental disorder that impairs social-emotional behaviour, motor coordination, visual-spatial learning and memory. Approximately 2.5% of the human adult population has ASD and adults with ASD have a reduced lifespan, increased frailty and motor gait impairments. The present study assessed motor coordination and motor learning using the Rotarod in 21-month-old male and female Nrxn1+/- transgenic mice; wildtype (C57BL/6J) controls; knockdown rescue ΔS5- ; and double rescue ΔS5/ΔS5 mice. The mice were placed in one of the 4 compartments of the Rotarod, which accelerated to a maximum of 36 rpm and the latency to fall was recorded. There were 6 trials per day over 7 days and body weight was taken prior to testing each day. Performance improved for all mice over days, however, there was a significant negative correlation between motor scores and body weight (r = -0.43, df= 97, p<0.001) with lighter mice performing better than heavier mice. Females performed better than males, but improvement in performance over days was greater in males. Female Ds5/- mice performed better than female WT, Nrxn1+/- and DS5/DS5 mice, but there were no genotype differences in male mice. At 2 and 9 month of age, female mice outperformed males but there were no differences between Nrxn1+/- and WT mice. There results indicate that there are no age-related deficits in motor learning and coordination in these autistic mouse models.},
  note = {Poster},
}

@inproceedings{jones2025investigatio,
  title = {Investigation of Astrocyte Activation in the Visual Cortex Following Monocular Retinal Inactivation},
  author = {Jones, Wes and Duffy, Kevin},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Early discordant vision can cause amblyopia, a lasting impairment usually affecting one eye. In animal models of amblyopia, inactivating the dominant retina with tetrodotoxin elicits better recovery than conventional patching treatment. Despite inactivating the retina, connectivity within the visual system is preserved. Astrocyte activation may support this preservation through homeostatic mechanisms. Our lab previously found elevated glial fibrillary acidic protein (GFAP), a marker of astrocyte activation, in layers of the lateral geniculate nucleus serving the inactivated eye. The current study investigated whether astrocyte activation also occurs in the visual cortex (V1). We compared GFAP labeling between control animals and those subjected to 10 days of MI. While young animals showed no difference, older animals exhibited significantly reduced GFAP after MI. We propose that this decrease in GFAP reflects an upstream synaptic compensation in response to inactivation-induced changes elicited within the lateral geniculate nucleus.},
  note = {Poster},
}

@inproceedings{longino2025exploring,
  title = {Exploring How to Assess Orthographic Learning in Grade 1},
  author = {Longino and Giazitzidou, Kirsty (presenter); Dr. and Hoferek, Sophia; and Deacon, Katie; Dr. and Hélène},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Orthographic learning refers to children's skill in learning the spelling of novel words through their independent reading, and it has been described as central to reading development. Measuring this skill in young readers is challenging, as it requires--by definition--independent reading. The aim of this pilot study was to develop an appropriate task to assess orthographic learning in English-speaking children in Grade 1. As in prior studies, we asked students to read 12 stories that contained made-up inventions. The first method required students to read independently. 25% of students could not accomplish this due to limited reading ability and loss of assent associated with reading difficulty. The second method shifted to shared reading for those who did not have the necessary reading skills, but had them decode the target words independently. This enabled all students to participate, with only one case of lost assent. In both methods, students were assessed immediately following the stories, and the following day, on the spelling and meaning of the inventions. Results showed that only independent reading demonstrated reliability (Cronbach's alpha >.7) while highlighting the importance of multiple methods to ensure full participation.},
  note = {Poster},
}

@inproceedings{macdougall2025does,
  title = {Does Hazardous Drinking in First Year University Students Predict Academic Performance into Their Fourth Year? A Study of Students with and Without a History of Reading Difficulties},
  author = {MacDougall, Erin and Elgendi, Mariam and Stewart, Sherry and Deacon, Hélène},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Background: Both problematic drinking and a history of reading difficulties have been associated with academic challenges in university students. Here we build on these two bodies of work to examine the longitudinal effects of alcohol use on academic performance in a study comparing students with and without a self-reported history of reading difficulties (HRD and NRD, respectively). Methods: We report on a four-year longitudinal study following 93 university students' (46 HRD, 47 NRD) GPA in Year 1 and Year 4. In Year 1, students completed online questionnaires assessing both hazardous drinking and a self-reported history of reading difficulties. Results: Linear regression analyses showed that hazardous drinking was negatively associated with changes in GPA from Year 1 to Year 4, for both students with a without a history of reading difficulties. Follow-up analyses identified drinking quantity as the primary contributor. Discussion: Overall, findings emphasize the need for university-based interventions targeting drinking behaviour to support academic outcomes, regardless of reading history.},
  note = {Poster},
}

@inproceedings{savoie2025decision,
  title = {Decision Making in Mice: A Detailed Analysis of Behaviour in Mice Navigating a Visual Discrimination Task},
  author = {Savoie, Samantha and Brown, Richard},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Behavioural studies using mouse models commonly involve visual stimuli, even though mice are not known to be visually guided animals. Wong & Brown 2006, Genes Brain and Behaviour 5, 389-403 examined the ability of different strains of mice to discriminate between visual stimuli in a forced-choice swim task. How mice make decisions while learning this type of task remains under-researched. We analyzed swim paths to determine decision-making tactics in the visual water box. We recorded 1) correct decision-making, 2) errors, 3) early error correction, 4) late error correction, 5) vicarious trial and error (VTE), and 6) thigmotaxis in 12 strains of mice with varying visual abilities. Using digitized footage, we coded the swim paths and compared the time taken to complete correct paths between visual ability groups. Mice were scored based on their search strategies and the time taken to complete the correct path. We found that visually impaired mice relied more on non-visual search strategies and made more error paths than those with good vision, who were likelier to use VTE and early error corrections. These findings show that mice with differing visual abilities use different search strategies. Mice with good vision showed longer times for VTE and error paths, which suggests more deliberative strategies. Learning trends varied by visual ability across trials. Despite limitations due to video quality and sample size, these results provide more information on how search strategies of mice differ based on visual acuity.},
  note = {Poster},
}

@inproceedings{sozuer2025compartmenta,
  title = {Compartmental Modeling of the Whole-Cell Activity of Wake-Promoting Orexin Neurons in Response to the Sleep Deprivation-Induced Astrocytic Inhibition of Their Excitatory Inputs},
  author = {Sozuer, Can and Pandey, Vikas and Kubota, Yoshiyuki and Semba, Kazue},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Electron microscopy and electrophysiology revealed that six-hour sleep deprivation induces astrocyte withdrawal from perisynaptic regions and presynaptic inhibition at excitatory synapses onto wake-promoting orexin neurons (Briggs et al., 2018, JNeurosci; Semba et al., 2023, SfN). Computational synaptic modeling demonstrated that astrocyte withdrawal drives presynaptic inhibition by modulating glutamate uptake. Although these alterations may homeostatically and substantially attenuate orexin neuron firing, their functional consequences remain unclear. To bridge synaptic changes and neuronal output, we developed the first detailed conductance-based compartmental model of an orexin neuron in our NEURON simulation environment, replicating D- and H-type firing from intrinsic membrane channel and receptor mechanisms. We stimulated this model with excitatory post-synaptic currents reflecting varying degrees of astrocyte withdrawal--holding other parameters constant and incorporating additional sleep-deprivation-induced physiological changes. By linking astrocyte withdrawal to orexin neuron firing, we extend synaptic-level observations into a detailed multiscale integrative framework, illuminating how nanoscale synaptic alterations may potentially impact wakefulness. ten Haaf, Mark POSTER TITLE: Optogenetic Activation of Somatostatin Expressing Interneurons in V1 Impairs Size Perception in Transgenic Mice AUTHORS: ten Haaf, M.R., Michaud, N.M., Atwell, I.F., Dang, L.T.J., Gorski, D.J., Rezende, L.C., Singh, P.K., Zeisberger, L.J.,},
  note = {Poster},
}

@inproceedings{weatherhead2025comparing,
  title = {Comparing Attitudes Toward Diverse and Homogeneous Groups Varying in Race, Accent, and Sex/Gender Among Canadian Primary-School-Aged Children},
  author = {Weatherhead, Drew and Reeves, Emma},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Children in Canada are learning language and interacting with others in far more socially (e.g., race and ethnicity) and linguistically (e.g., languages and accents) diverse environments than ever before. We explored children's attitudes toward diverse and homogeneous social groups using ecologically valid methods that reflect the real-world contexts in which diversity is experienced. Data collection is ongoing. Fifty-five Canadian children, aged 5 to 8 years (males n = 30, females n = 25, M age = 7.8 years), completed three blocks of trials varying by social dimension: sex/gender, race, or accent. On each trial, participants were presented with cartoon images of groups that differed according to the social dimension being evaluated within each block: one group was homogeneous, and the other was diverse. Participants were then asked to rate how much they liked each group using a Likert-response scale consisting of emoticons. Wilcoxon Signed- Rank tests will be used to determine whether responses differ significantly between the two types of stimuli (e.g., diverse vs. homogenous groups) and across age groups. Findings can have implications for educational practice, policy-making, and early interventions that promote acceptance and support for diversity.},
  note = {Poster},
}

@inproceedings{yildirim2025psychopathic,
  title = {Psychopathic Traits and Cooperation: The Role of Punishment Risk in Social Decision-Making},
  author = {Yildirim, S. Deniz and Mungall, Luke and Blais, Julie},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Cooperation is integral to a functioning society, but people higher in psychopathic traits (e.g., showing callous affect, manipulativeness, impulsivity, antisocial traits) may be unwilling to cooperate and consistently violate social norms. The current study investigated the extent to which cooperative decision-making is influenced by psychopathy scores and punishment risk, as measured through three hypothetical Public Goods Game (PGG) scenarios with varying certainties of (monetary) punishment risk (i.e., low-, moderate-, and high-risk). The sample consisted of 455 undergraduate students, recruited through SONA. Participants completed the three hypothetical PGG scenarios and a multifaceted psychopathy measure: the Self-Report Psychopathy Scale - Short Form (SRP-SF). As hypothesized, participants contributed more points in conditions that offered increased risk of punishment. However, total psychopathy scores did not significantly predict lower contributions averaged across the three PGG conditions. Higher psychopathy scores were also not associated with the difference in contributions between low- and high-risk conditions, nor between the low- and moderate-risk conditions. Nonetheless, higher psychopathy scores, specifically on the Erratic Lifestyle facet, were correlated with lower contributions in the moderate-risk condition. Our findings highlight the complex nature of psychopathy and suggest that psychopathy does not uniformly predict cooperative behaviour but may be influenced by the likelihood of punishment as well as certain psychopathy facets.},
  note = {Poster},
}

@inproceedings{atwell2025does,
  title = {Does Inhibiting Parvalbumin-Expressing Interneurons in Visual Cortex Alter Performance on a Perceptual Contrast Detection Task in Mice?},
  author = {Atwell, Isabel F. and Michaud, Nicole M. and Atwell, Isabel F. and Gorski, Daisy J. and Haaf, Mark R. ten and Rezende, Laura C. and Prem},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The application of optogenetic techniques in mouse primary visual cortex (V1) has allowed us to probe the roles for specific neuron subtypes within the neural circuits underlying sensory processing. Past research has identified inhibitory interneurons expressing parvalbumin (Pvalb+), somatostatin (SOM+) and vasoactive intestinal peptide (VIP+) as members of an inhibitory neural circuit that modulates excitatory pyramidal cell activity. We recently found that SOM+ inactivation alters perceptual contrast detection in a manner consistent with a visual phosphene effect, likely caused by release from inhibition of pyramidal cells. In this study we investigate whether Pvalb+ inactivation produced similar perceptual deficits using the same perceptual task. We show for the first time that Pvalb+ inactivation impairs performance on a contrast detection task.},
  note = {Poster},
}

@inproceedings{stewart2025characterizi,
  title = {Characterizing Problematic Internet and Social Media Use Among Young Adults},
  author = {Stewart, Simon B. Sherry; Aislin R. Mushquash; Christopher J. Mushquash; Daniel S. McGrath; Sherry H.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The Substance Use Risk Profile Scale (SURPS) is a measure that is used to select youth for personality-targeted interventions (i.e., PreVenture) that have been found to prevent or reduce risky substance use in young people. We tested whether the SURPS impulsivity subscale would predict changes in binge drinking and binge eating over time. Undergraduates (N = 410, M age = 20.7 years, SD = 5.5, women n = 307, men, n = 103) from two universities completed a longitudinal study with two weeks separating baseline and follow-up. At baseline, participants completed the SURPS impulsivity subscale and binge drinking and binge eating measures. At follow up, participants completed the measures again. Linear regression analyses showed that SURPS impulsivity (B = .12, p = .02) significantly predicted binge drinking and binge eating at follow up. Findings reveal that the SURPS impulsivity subscale is a useful tool in predicting increases in binge behaviour.},
  note = {Poster},
}

@inproceedings{dockrill2025sleep,
  title = {Sleep Disparities in Canadian Children under 18 Years: A Scoping Review},
  author = {Dockrill, Mya and Flores, Brendan and Aidara, Youssouf},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Insufficient sleep is prevalent in children and has many adverse health outcomes. Children facing health inequities (e.g., from a low socioeconomic background, or a racial/ethnic minority) have more sleep difficulties and are less likely to receive treatment. There is a lack of research investigating pediatric sleep and health inequities, particularly in Canada. Thus, the objective was to summarize the extant literature in this area. A list of health inequities was developed following the Canadian Institute of Health Research EDI dimensions and in consultation with the Canadian Sleep Research Consortium. Four key electronic databases (PubMed, EMBASE, PsycInfo, CINAHL) were searched. Studies were included if they were 1) in English or French, 2) original studies (e.g., empirical data collected), 3) conducted in Canada, 4) with children under 18 years, 5) population-based studies, and 6) reported on sleep outcomes and health inequities. Three reviewers screened 15,448 abstracts and titles resulting in 357 articles full-text articles. After screening, 25 studies were included in this review, focusing on sleep in the context of low socioeconomic status (18 studies), gender/sex (17 studies), family composition/caretaking (9 studies), housing/neighbourhood characteristics (8 studies), race/ethnicity (8 studies), immigrants/refugees (3 studies), and language (1 study). Of note, no distinction was made between sex and gender in the literature. Much of the research has been done with Caucasian, adolescents and school-aged children, in Quebec or Ontario. Generally, it appears that sleep health and disordered sleep are negatively affected by low socioeconomic status, poor housing/neighbourhood conditions, and in non-Caucasian children. The findings are varied in terms of sex differences with most studies suggesting no differences (76%) and some suggesting differences between boys and girls with 67% of the literature suggesting that boys sleep better. There is no clear link between sleep disturbances and family composition and caretaking. This is the first review to investigate the impact of health inequities on sleep in Canadian children. Identifying and understanding this link will inform the modification and development of sleep interventions to better meet the needs of these diverse individuals.},
  note = {Poster},
}

@inproceedings{drew2025canadian,
  title = {The Canadian Settler Guilt Scale: Measuring Settler Guilt in a Canadian Population},
  author = {Drew, Ben and Moore, Chris},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Indigenous peoples in Canada have endured significant negative impacts stemming from the colonization of North America in the 1700s and cultural assimilation efforts by European colonizers. Research in Australia has demonstrated that some individuals of European ancestry feel guilt about the injustices and maltreatment that Indigenous populations have endured. This type of guilt, referred to as settler guilt, may be an important avenue towards reconciliation efforts between Indigenous and non-Indigenous populations. However, no research to our knowledge exists on the topic of settler guilt in Canada. To address this issue, the newly designed Canadian Settler Guilt Scale was administered to a sample of undergraduate university students at Dalhousie University to measure settler guilt in a Canadian population. The scale demonstrated strong construct validity and internal consistency through exploratory factor analysis and Cronbach's alpha calculations, and differences in settler guilt scores were observed across various demographic variables providing a strong foundation for future research on the topic.},
  note = {Poster},
}

@inproceedings{faustova2025seizure,
  title = {Seizure Symptoms in Neurexin-1 Knockdown and "Rescue" Mice with Slice Site 5 Modification: Determining the Relationship of Age, Genotype and Sex Using the Brown Lab Scale and KCNQ-1 Expression},
  author = {Faustova, Ana and Ortibus, Wyatt and Ahmed, Mohammed Ali and Ismail, Salma and Weaver, Ian and Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The Neurexins (NRXNs) are a family of membrane protein synaptic organizers encoded by the Nrxn genes. Nrxn-1 mutations are associated with Autism Spectrum Disorder and Schizophrenia. We recorded seizures in male and female mouse models with a knockout of one Nrxn1 gene (Nrxn1+/- mice), wildtype C57Bl/6J controls (Nrxn1+/+), a_n_d_ _N_r_x_n_1_ _"r_e_s_c_u_e_" _m_o_d_e_l_ _w_i_t_h_ _a_ _s_p_l_i_c_e_ _s_i_t_e_ _5_ _a_l_t_e_r_a_t_i_o_n_ _(DS5/- and DS5/DS5 mice) (Lu, H., et al., 2023. Cell Reports, 42: 112714; Lu, H., et al. Molecular Psychiatry, 15 April 2025). The DS5 alteration increases NRXN-1 interaction with presynaptic ligands, counteracting the knockdown behavioral phenotype. Mice carrying the DS5 recovery were more likely to exhibit age-related seizures compared to Nrxn +/+ and Nrxn +/- mice (48% DS5, 31% Nrxn1+/-, 25% Nrxn1+/+). There were no sex differences, but seizure risk increased in micee with age (17.5 months). No Mendelian heritability pattern was uncovered. The epigenetic analysis showed a complex interaction between seizures, KCNQ-1, and genotype. This mouse model therefore may be important for the study of age-related spontaneous seizures.},
  note = {Poster},
}

@inproceedings{fernandes2025personality,
  title = {Personality and Emotional Expression Across Languages: Comparing French and English Emerging Adults During COVID-19},
  author = {Fernandes and O and Snooks and T and Stewart and H, S. and Yunus and F and Moore and M and Keough and M and Krank and M and Thompson and K and &},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {This study examined how personality traits influence emotional expression in written narratives about COVID- 19 pandemic impacts among French-Canadian undergraduates and whether these associations differ from those previously documented in English Canadian undergraduates. Drawing on Ekman's Basic Emotions Theory and Plutchik's Emotion Wheel, which posit universal emotional responses, we hypothesized that associations between personality traits and emotional word use would replicate cross-linguistically. Participants (N=1185; ages 18-25) from 5 Canadian universities (1 French-speaking; N=122) completed a free-response prompt describing the impact of the COVID-19 pandemic. Using the Substance Use Risk Profile Scale, we explored relationships between four traits, Anxiety Sensitivity,},
  note = {Poster},
}

@inproceedings{feltmate2025nature,
  title = {Is the Nature of the Vigilance Decrement Affected by Target Probability?},
  author = {Feltmate, Brett and Dobson, Paige and Bartlett, Mia and Dober, Alyssa and Windybank, Elise and Klein, Ray},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {In tasks requiring vigilant detection of rare and noisy signals, humans ubiquitously commit more errors as time progresses. A consistent theme throughout the literature is how best to characterize this "vigilance" decrement: is it a decline in one's ability to discriminate signals, or a conservative shift in their criterion to respond? Given that both accounts have empirical support, it is more likely that task factors moderate how the vigilance decrement is felt. We explored if/how people's ability to discriminate signals, and their bias in categorizing them as such, are differentially sensitive to target likelihood. Participants signalled whether a central line was sufficiently offset from those flanking it, which occurred on (between-Ss) 25/50/75% of trials (900/ participant). Results hint toward discriminability and response biases dissociating over time, as target likelihood approaches either limit.},
  note = {Poster},
}

@inproceedings{haggett2025heightened,
  title = {Heightened Error-Monitoring Following Childhood Adversity: An ERP Investigation of the ERN},
  author = {Haggett, Sarah M. and Lackner, Christine L.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Adverse childhood experiences (ACEs) are linked to disruptions in brain regions involved in self-regulation and performance monitoring. The error-related negativity (ERN) is a neural marker of error awareness. Although self- regulation is associated with ERN amplitude, findings on the ACE-ERN relationship are inconsistent, possibly due to simplified ACE measures. This study is the first to examine four ACE dimensions - type, timing, extent, and subjective evaluation - in relation to ERN. One hundred young adults will complete ACE questionnaires and perform four Go/NoGo tasks during EEG recording. Tasks will vary in emotional salience (neutral, emotional) and sensory modality (auditory, visual). We hypothesize that ACE extent and subjective severity will negatively correlate with ERN across tasks. The timing- ERN relationship will depend on age at exposure. ACE type effects will depend on task salience, with greater effects during emotional tasks, and on sensory modality, with more negative ERNs when modality aligns with experienced ACEs.},
  note = {Poster},
}

@inproceedings{parks2025ageing,
  title = {Ageing, metabolic challenge, and neural plasticity: transcriptomic insights from domesticated pigeons (Columba livia domestica)},
  author = {Parks, Broderick M. B and Liddle, T. Adam and Stevenson, Tyler J and Treberg, Jason R and Kelly, Debbie M and Phillmore, Leslie S},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Domesticated pigeons (Columba livia domestica) are valuable models for studying spatial cognition and neural plasticity. Unlike mammals, birds exhibit extensive plasticity throughout adulthood, but it remains unclear whether the avian brain shows any evidence of (mammal-like) decline with age. While food deprivation is often used to experimentally motivate spatial behaviour, its effects across different life stages are also unclear. Physiological differences between adult and aged birds suggests a role for the mediobasal hypothalamus, a key regulator of energy balance, but whether age-related physiological differences (and/or responses to food deprivation) reflect molecular changes in this structure remains unexplored. Here, we examined how a standard 90% food deprivation affected neural plasticity in adult (1-4 years) and aged (8-18 years) pigeons. Birds (N=24) were assigned to one of three food conditions over ~16 weeks: (i) recent food deprivation; (ii) past food deprivation; or (iii) ad libitum feed. Using Nanopore RNA sequencing, we profiled all RNA transcripts in the mediobasal hypothalamus and hippocampus, identifying hundreds of differentially expressed genes based on age, food condition, and their interaction. These findings reveal previously unknown molecular signatures of aging and metabolic challenge in the avian brain, providing new insights into neural plasticity and energy regulation across the lifespan.},
}

@inproceedings{klein2025years,
  title = {50 years in Psychology (and Neuroscience) at Dalhousie},
  author = {Klein, Raymond},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {My time at Dalhousie coincides with the history of the Department's annual, and widely copied, In-House Conference. I plan to entertain you with facts, figures and stories that cover three histories: the Department's, the In-House's and mine.},
}

@inproceedings{lewis2025changes,
  title = {Changes in the N400 Event-Related Potential Found Over a Two Day Spanish Language Learning Study},
  author = {Lewis, Hope and Wei, Emily and Ali, Mobina and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The N400 is an event-related potential (ERP) associated with semantic processing. Before training in an unfamiliar language (UL), learners do not show this N400 effect when assessed with UL words, but such effects have been shown to emerge at least after 10 days of training. To determine how much exposure to UL words are required for new learners to show an N400 effect, the current study recorded EEG throughout a two-day UL training period. Spanish words were taught by being paired with images associated with their meaning. Semantic mismatch tasks were used to elicit ERPs in Spanish and in English. A significant N400 effect for trained Spanish words emerged at the end of day 2 of training. This N400 effect was delayed and smaller in amplitude compared to English, perhaps reflecting a difference in proficiency. Follow-up study will assess participants over a semester of language learning to determine longer term development.},
}

@inproceedings{li2025cerebellar,
  title = {Cerebellar Isolation Combining Multi-Modality MRI Using Deep Learning},
  author = {Li, Yao and Diedrichsen, Jorn and Hernandez-Castillo, Carlos},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The cerebellum is involved in motor, cognitive and social behavior, and understanding its development across the lifespan aids in diagnosing neurological disorders. Accurate cerebellum isolation from whole-brain MRI scans is a crucial first step for accurate cerebellar analysis. The current isolation tools have two limitations. First, they were developed on healthy adults' brains. Second, most of them do not utilize multi-modality image inputs. This project introduces a robust deep learning approach using a 3D U-Net architecture to isolate the cerebellum from multi-modal MRI data (T1- and T2-weighted images). The dual-channel input enhances tissue differentiation by capturing spatial features from both modalities. Evaluated using Dice Score and Hausdorff Distance, our model outperforms existing tools in accuracy, particularly by reducing mislabeling of nearby structures. It also generalizes well across different age groups, including neonates, addressing key limitations of previous methods and offering a more reliable solution for cerebellar segmentation.},
}

@inproceedings{mackinnon2025comparing,
  title = {Comparing Structural Equation Models to Network Analysis Models of Depression, Anxiety, and Perfectionism},
  author = {Mackinnon, Sean P. and Kim, Andy J.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Background: We use network analysis to identify bridge symptoms connecting anxiety, depression and perfectionism; that is, are there specific symptoms connecting these constructs? Moreover, we compare network models to traditional structural equation models using latent variables to see how findings differ. Methods: Two undergrad samples (N=774; N=759) completed online measures of anxiety, depression, and perfectionism (concerns over mistakes, doubts about actions, & personal standards). SEM Results: After controlling for other perfectionism variables, concern over mistakes and doubts about actions were positively associated with depressive and anxiety symptoms. Personal standards were negatively associated with depression and non-significantly related to anxiety. Network Results: Four items emerged as bridge symptoms: difficulty taking initiative to do activities, feeling worthless, feeling close to panic, and doubts about simple everyday activities. Conclusions/Impact: Traditional multiple regression-style models are replicable but obscure item-specific relationships. Using network models in place of reflective latent variable models may produce novel insights.},
}

@inproceedings{maclachlan2025impact,
  title = {The Impact of Language Background and Prosocial Behaviours on Preschoolers' Affiliation Preference Towards Unfamiliar Accented Speakers},
  author = {MacLachlan, Madison B. and Weatherhead, Dr. Drew},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Preschoolers prefer people who speak with the same accent as them (e.g., Kinzler, et. al., 2019) and who behave kindly towards others (e.g., Van de Vondervoort & Hamlin, 2017). Recently, it has been found that a preschoolers' language background (i.e., whether they are monolingual or multilingual) may impact these preferences. Bilinguals are more flexible in their preferences based on language (e.g., Byers et al., 2017) and show more sensitivity to kindness cues (Singh, 2020). The present study examined the impact of language background and social behaviours on preschoolers' preferences towards animated characters with an unfamiliar accent. N= 158 preschoolers answered questions regarding their preferences toward the group. Participants significantly preferred prosocial and neutral characters over antisocial characters and bilinguals showed significantly greater affiliation preference towards the accented characters compared to the monolinguals. This suggests that bilinguals may be more accepting socially of speakers with accents different than their own.},
}

@inproceedings{millar2025volumetric,
  title = {Volumetric Plasticity of the Septum Across Age and Feeding Conditions in Domesticated Pigeons (Columba Livia Domestica)},
  author = {Millar, Hannah and Parks, Broderick M. B and Hayar, Casandra and Monchesky, Ainsley N and Treberg, Jason R and Debbie},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Domesticated pigeons (Columba livia domestica) are common models to investigate the interaction between spatial memory and its underlying neural substrates, particularly the hippocampus. Relative to the hippocampus, much less is known about the avian septum, another structure that has been linked to general spatial specialization in birds, is highly interconnected with the hippocampus, and shows some evidence of neural plasticity. Here, I will present data from two ongoing studies examining the effects of age, sex, and food deprivation history on neural plasticity in the pigeon septum. The first study examined age-related changes in overall septum volume (as measured by Nissl staining) in pigeons (N=30) ranging in age from 2-22 years old. The second study examined how food deprivation affected septum volume in a separate sample (N=22) of adult (1-4 years) and aged (8-18 years) pigeons. While overall telencephalon volume varied with both age and food condition, we found no effects on septum volume. We did find some evidence of septum plasticity in response to food deprivation in adult, but not aged birds, however further methodological refinements may be necessary to confirm this effect. Overall these findings suggest the septum may be resilient to potentially detrimental effects of age and metabolic challenge.},
}

@inproceedings{mitchell2025kitten,
  title = {The kitten breeding colony in the Psychology Department: the first fifty years.},
  author = {Mitchell, Donald},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The establishment of a kitten breeding colony at Dal was a crucial initial step in order to study of the role that early visual experience plays in the development of the mammalian central visual pathways of binocular species such as humans. As described in a recent paper (https://doi.org/10.1523/ENEURO.0576-24.2025 ) it was also necessary to develop a method to allow measurement of the changes in the perceptual abilities of kittens following different forms of early visual exposure. In 1970 there were no commercial cat breeding colonies in Canada and we had not yet moved into the LSB. I describe how and from where we acquired intact cats for the initiation of a breeding colony and the progressive changes made in the ensuing years.},
}

@inproceedings{murray2025objective,
  title = {Objective Behavioural Comparison of Youth and Adult Anxiety: A Mobile Sensing Approach},
  author = {Murray, Nicholas E. and Parsa, Mah and Muzamil, Mohamed and Wang, JianLi and Meier, Sandra M.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Widely used subjective measures of anxiety are limited by recall biases and an inability to capture real-time fluctuations in anxiety-related behaviours. This study used the PROSIT app to examine behavioural indicators of anxiety in 65 youth (15-21 years) and 96 adults (26-40 years) with clinically significant anxiety. Participants completed baseline measures of mental health and used the app for 14 days, enabling passive sensing of mobility, sociability, physical activity, screen use, and sleep, alongside daily self-reports. Features were extracted to predict outcomes related to baseline and momentary anxiety. Notably, screen use predicted anxiety in youth only; greater mobility predicted greater momentary anxiety variance in youth, and lesser variance in adults. These results- along with other findings to be discussed - indicate that mobile sensing features can predict anxiety in youth and adults, and that there are measurable differences in the expression of anxiety between youth and adults consistent with prior literature.},
}

@inproceedings{perry2025menthol,
  title = {Menthol Enhances Sensory Reinforcement and Craving Reduction from Nicotine Inhalers},
  author = {Perry and R.N and A, Tanner and Staden, van and F and O'Connor and G and Barrett, S.P},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Flavours, particularly menthol, may influence the reinforcing properties of electronic nicotine delivery systems (ENDS), though findings in human users are mixed. We examined whether menthol alters reinforcement from nicotine inhalers in adult ENDS users. Fifty-three ENDS users self-administered a 4mg nicotine inhaler paired with a menthol or unflavoured inhaler across two within-subject sessions. Craving and withdrawal were assessed pre- and post-inhaler; subjective effects (liking, wanting, stimulation, sensory effects) were rated post-inhaler. Craving and withdrawal decreased pre- to post-inhaler in both flavour conditions (p<0.001). Planned comparisons between flavours showed lower post-inhaler craving in the menthol condition (p=0.04). Menthol also elicited cooling sensory effects, improved the taste of nicotine inhalers, and independently increased ratings of stimulation, liking, and wanting (p<.001). Thus, menthol may enhance the sensory appeal and reinforcing effects of inhaled nicotine, including craving reduction. Findings support regulatory concerns about flavoured ENDS while highlighting nuanced implications for cessation and harm reduction.},
}

@inproceedings{peterson2025examining,
  title = {Examining Patterns of Substance Use Among Simultaneous Alcohol and Cannabis Co-Users},
  author = {Peterson and J and A, Shephard and A, Ethier-Gagnon M. and Zhevoka and R and P, Barrett S.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Simultaneous co-use of alcohol and cannabis has been associated with greater substance use and dependence relative to concurrent or single substance use. We examined use patterns among simultaneous co-users to identify factors that may contribute to this elevated risk. Structured interviews (n = 200) were conducted in monthly alcohol-cannabis co- users. General linear models were used to analyze differences in alcohol and cannabis dependence between concurrent and simultaneous users, and to examine how specific use patterns influenced substance quantity among simultaneous users. Relative to concurrent users, simultaneous users demonstrated more problematic alcohol and cannabis use. Among simultaneous users, order in which alcohol and cannabis were administered impacted quantity used, such that the substance administered first was used more in the session. Finally, we found that more alcohol was consumed in group vs. solitary settings. Findings highlight key risk factors associated with simultaneous co-use and may inform targeted psychoeducation and harm-reduction strategies.},
}

@inproceedings{brown2025chemical,
  title = {Chemical signals, olfactory learning and individual differences: 50 years of research. [Chemical Signals in Vertebrates 16. Edited by B. Schaal et al. In Press, May 2025.]},
  author = {Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {This talk describes 50 years of research in my lab on chemical signals in rodents These began with experiments on the role of odour preferences and urine-marking in the socio-sexual behaviour of rats. Olfactory communication involves both endocrine and experiential factors as shown by our studies on gonadectomy and isolation rearing. The importance of individual recognition by odours was studied through the rat pups' response to "maternal pheromones" and by examining the role of the major histocompatibility complex in odours of individuality. The initial studies done using habituation-dishabituation tests were continued using an operant olfactometer to study odour discrimination learning using the urine odours of rats and mice. We also investigated the importance of individual recognition in puberty acceleration in juvenile female mice. We then began to examine the use of the olfactometer to study working memory in rats and learning set formation in mice. We are now examining olfactory reversal learning in mice using signal detection methods to identify sex, age and genotype differences in learning strategies. We also use the Pavlovian conditioned odour preference task developed by Heather Schellinck to study olfactory learning and memory. Our studies have attempted to integrate mechanisms of olfactory communication (releaser effects), neuroendocrine responses (primer effects) and learning and memory (cognitive processes) in olfactory signalling in rodents.},
}

@inproceedings{byron2025standing,
  title = {Standing up in the Virtual World: Observing Social-Cognitive Factors Influencing Peer Defending Behaviours Using Virtual Reality},
  author = {Byron, Julia and MacGillivray, Anna and Lambe, Laura and Redden, Ralph},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Bullying victimization is a serious threat to Canadian youth. Bullying most often occurs in the presence of peer bystanders, who can intervene to defend their victimized peers. Although rare, peer defending is an effective way to combat bullying, ending the bullying episode rapidly when a bystander intervenes. Past research has used passive viewing methods (e.g. vignettes) to study factors associated with peer defending, limiting our understanding of how social attention contributes to peer defending in real-time. The present study used a virtual reality (VR) paradigm to examine how social attention is related to peer defending in a bullying scenario. Multi-method data were collected during the VR task, including eye tracking data, state affect, and various defending behaviours in response to a social exclusion scenario. Results indicate that there is a correlation between gaze allocation and some types of peer defending, as well as a correlation between specific peer defending behaviours and negative affect during social exclusion. Results from this study are among the first to demonstrate the social cognitive processes underlying peer defending behaviour as it unfolds in real-time, showing that gaze allocation in dynamic social situations can be sensitive to witnessing peer victimization.},
}

@inproceedings{sadek2025brains,
  title = {Brains in Conversation: Science Communication and Public Impact},
  author = {Sadek, Wateen},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {This presentation explores the role of science communication in making neuroscience more accessible and engaging to the public. Drawing on my involvement with outreach initiatives such as SURGE, Dalhousie Science Scholars and Science Leaders Program (DSSLP), the Brain Repair Centre, and high school workshops, I highlight how interactive demonstrations using EEG and brain-computer interface (BCI) technology can spark curiosity and enhance science literacy among young people. As a neuroscience major with minors in entrepreneurship and education, I aim to bridge the gap between complex scientific research and community understanding. The presentation also reflects on the impact of hands-on activities and youth-centred programming in fostering future interest in neuroscience. These experiences demonstrate how science communication can expand the reach of research, inspire young minds, and foster stronger public engagement with neuroscience.},
}

@inproceedings{sozuer2025using,
  title = {Using AI to Detect AI Use in Online Exams},
  author = {Sozuer, Can},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Unproctored online examinations are highly susceptible to covert artificial-intelligence (AI) use and peer collaboration, undermining assessment integrity. Although manual review can uncover isolated incidents, its scalability is prohibitive. To bridge this gap, I developed Zapper, a custom AI-based advanced data analysis tool that processes textual student responses to flag question- and student-level signatures of AI usage and collaboration. For a class of ~300 students, Zapper reduces ~8,000 person-hours of manual inspection into a review of its outputs and student work lasting only a few hours. Applied over three semesters in two distinct courses with close to 700 students in total, Zapper consistently achieved high accuracy. By integrating advanced AI-detection capabilities into a scalable framework, Zapper advances the integrity of unproctored online assessments.},
}

@inproceedings{stewart2025cross,
  title = {Cross-Priming of Stimulant Cravings by Gambling in Regular Stimulant Users},
  author = {Stewart and H, S. and Zack and M and McGrath and D and Seale and I and Collins and P and Barrett and P, S. and Al-hamdani, M},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Administration of addictive drugs can prime motivation to use other drugs with similar properties (i.e., "cross- priming"; Barrett et al., 2006). Amphetamine administration increases urge to gamble in problem gamblers (Zack & Poulos, 2004). We tested whether motivation for stimulant use would be similarly cross primed by gambling in regular stimulant users. Stimulant users (n=32) and n=31 controls (n=15-16 of each sex/group): engaged in lab-based video lottery terminal gambling; reported gambling, stimulant, and alcohol craving pre- and post-gambling; and provided heart rate and blood pressure samples at both timepoints. Gambling increased desire to gamble. While heart rate and systolic blood pressure declined pre- to post-gambling in controls, they remained elevated post-gambling in stimulant users. Gambling also cross- primed increased craving for stimulants and alcohol but only in the female stimulant users. Results bolster arguments that problem gambling shares common mechanisms with psychostimulant addiction and suggest cross-priming may be particularly important in females.},
}

@inproceedings{tan2025improving,
  title = {Improving Functional Connectivity Estimation in rs-fMRI for Biomarker Discovery Across Neurological Disorders},
  author = {Tan, Bei Ni and Hernandez-Castillo, Carlos},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Neurological disorders, caused by central and peripheral nervous system abnormalities, often impair brain function. Functional connectivity (FC) form Resting-state functional MRI (rs-fMRI) is a promising tool for biomarker discovery in neurological disorders. However, current methods to calculate FC may overlook subtle connectivity patterns leading to weak predictive power. Using three different rs-fMRI datasets, we evaluate different FC estimation methods:},
}

@inproceedings{tanner2025cannabidiol,
  title = {Cannabidiol Expectancy Attenuates Users' Anxiety Response to Cannabis Cues},
  author = {Tanner and B, A. and Shephard and S, A. and Barrett and P, S. and Sherry and S and Stewart, S. H},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Cannabidiol (CBD) dampens psychophysiological arousal and substance craving; however, the extent to which these effects are attributable to placebo effects remains unclear. CBD expectancy alone has been shown to elicit anxiolysis and attenuate cue-induced cannabis craving. We examined whether CBD expectancy influences stress or anxiety responses to cannabis-related cues. Forty-six cannabis users self-administered a vaporizer containing propylene glycol; half were falsely informed that the vaporizer contained CBD. Participants then viewed neutral and cannabis- related cues. Stress and anxiety were assessed at baseline, following vaporizer administration, and after each cue. Participants who believed they received CBD showed significant reductions in anxiety following drug (but not neutral) cue exposure compared to baseline, while those who believed they received placebo maintained higher anxiety ratings post-drug cue. Findings suggest CBD expectancy alone is sufficient to dampen anxiety to cannabis-related cues, underscoring the need to control for expectancy effects in clinical research investigating CBD's therapeutic efficacy.},
}

@inproceedings{tennen2025developing,
  title = {Developing an Online Treatment Approach for Spatial Neglect Using a Single Case Design},
  author = {Tennen, Lucas and Murphy, Nick and Horne, Samantha and DuJohn, Julia and Boyce, Joy and Sherri},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Spatial neglect, a common consequence of right hemisphere stroke, leads to attentional deficits and poor rehabilitation outcomes. While visual scanning treatment (VST) is a potential intervention, its effectiveness typically depends on therapist-guided sessions exceeding 15 hours, posing challenges in resource-limited settings. SpyTrain, an online VST program, offers intensive, adaptive, game-like scanning practice and has shown validity in healthy controls (Aziz et al., 2021), and early efficacy in stroke patients. This study is assessing the feasibility and effectiveness of SpyTrain for treating spatial neglect, focusing on the application of strategies. Patients with right hemisphere stroke and neglect are randomized to three different baseline lengths using a non-concurrent multiple baseline single-case design, followed by 5 weeks of online VST (5 sessions/week). Outcomes will are measured across phases and analyzed using Tau-U, a nonparametric test assessing improvement trends. If effective, SpyTrain could offer an accessible, home-based treatment to support recovery and independence in stroke survivors with neglect.},
}

@inproceedings{whitfield2025impact,
  title = {The Impact of Communal Nesting on Adolescent Stress-Induced Intergenerational Effects in Male and Female Mice},
  author = {Whitfield, Caden and MacLean, Tasia and Adedeji, Ewa and Hartley, Mackenzie R. and Franklin, Tamara B.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Chronic stress during the adolescent period has proven to be impactful to mental health and behaviour throughout adulthood. Previous research in our lab has demonstrated that chronic adolescent stress in mice induced behaviour similar to postpartum depression, with the dams showing reduced motivation and providing less maternal care to their pups. Altered behaviour states during the postpartum period impact the pups' behaviour in adulthood, with pups demonstrating increased anxiety-like behaviour. The current research focuses on assessing interventions to help counter these intergenerational effects by investigating the potential of communal nesting as a model for social support in the postpartum period. F0 generation mice undergo a predator stress protocol daily over the course of 12 days during the early adolescent period to mimic the experiences of chronic adolescent psychological stress. These mice are bred in same- treatment pairings and once pups are born, are either placed alone in standard housing or housing with another dam and their pups. As adults, the offspring were tested in a battery of tests aimed at assessing exploration, anxiety-like behaviours and depressive-like behaviours: olfactory habituation/dishabituation, open field, sucrose splash test and the elevated plus maze. This study is ongoing, however preliminary results from this behavioural testing suggest that communal nesting can modulate some, but not all of the effects of ancestral stress.},
}

@inproceedings{hossain2025evaluating,
  title = {Evaluating the Impact of an Online Coaching Intervention for Families Affected by 22q11.2 Deletion Syndrome},
  author = {Hossain, Holly Carbyn Abiaz and Lingley-Pottie, Patricia and Palmer, Lisa D. and Ayoub, Sophie and Shugar, Andrea and M, Donna},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {22q11.2 Deletion Syndrome (22q11DS) is the most common microdeletion syndrome, with broad phenotypic variability often involving high levels of internalizing/externalizing symptoms in children. Caregivers of children with 22q11DS are at increased risk of poor mental health, yet caregiver-focused supports remain scarce. This pilot study evaluated the effectiveness of an online coaching intervention for families affected by 22q11DS using a repeated- measures design, examining its impact on caregiver mental health, parenting practices, and child internalizing/externalizing symptoms. Eighteen caregivers completed the intervention, which included 12 weekly modules with coached group phone calls. Outcomes were assessed at baseline, 3-, and 6-month follow-up using the DASS-21 (parent distress), PAFAS (parenting practices), and SDQ (child symptoms). Linear mixed models revealed significant reductions in caregiver stress at both follow-ups and a marginal decrease in anxiety at 6 months. Children's externalizing behaviours declined significantly over time. Findings suggest the online intervention may alleviate caregiver distress and improve child behaviour in families affected by 22q11DS. Larger studies (RCTs) are warranted to confirm results.},
}

@inproceedings{collings2025brains,
  title = {Brains in Tune with Season: Seasonal Regulation of Neurogenesis Within Vocal Control and Auditory Perceptual Regions of Wild Black-capped Chickadees (Poecileatricapillus)},
  author = {Collings, KC and Parks, Broderick M. B and Phillmore, Leslie S},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Songbird vocal behaviour often changes seasonally, with birds singing more in the spring to attract mates and defend territories. This behavioural plasticity is supported by neural plasticity specifically within the vocal control system, the interconnected regions and circuits supporting songbird vocal behaviour. One measure of neural plasticity is neurogenesis: the proliferation, differentiation, migration, and incorporation of new neurons. Here, we evaluated seasonal differences in neurogenesis within four brain regions: two vocal control nuclei (HVC [proper name] and Area X) and two auditory perceptual regions (caudomedial nidopallium and caudomedial mesopallium) in adult male and female black-capped chickadees (Poecile atricapillus). We captured birds across three seasons (spring, summer, and winter) and quantified neurogenesis by labelling brain tissue for doublecortin (DCX), a marker of newborn neurons. We counted three morphologies of DCX+ cells (multipolar, fusiform, and round) and found the distribution of these morphologies differed in each brain region. We also found seasonal changes in HVC multipolar cells, and sex-specific seasonal differences in Area X round cells. These results suggest that seasonal patterns of neurogenesis relate to the functional roles of the different brain regions and also vary between sexes, broadening our overall understanding of avian physiology, behaviour, and neural plasticity.},
}

@inproceedings{drake2025content,
  title = {Content Variability as Desirable Difficulty in N-Back Training},
  author = {Drake, Richard S. and Bhaskara, Sophie and Klein, Raymond M. and Eskes, Gail A.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Working memory training research has been a grand quest for transfer (improvements on related but untrained tasks). Recent culture shifts in the field have reprioritized mechanistic studies probing transfer theories, and one underexplored area involves manipulations of training variability. Our VARIA project is a 5-day training study that draws together multiple learning theories, from Schmidt and Bjork's work on desirable difficulties in motor and vocabulary learning to Gathercole's theory of novel subroutines as transferable units of cognitive skill learning. We embedded a categorization task within a traditional n-back paradigm to create a novel "varback" training program that we used to test the hypothesis that training with high variability (3x as much as a lower variability group) will boost retention and near transfer measures of working memory. We will present and contextualize preliminary findings with respect to contemporary debates in working memory training.},
}

@inproceedings{ethiergagnon2025effects,
  title = {The Effects of Cannabidiol (CBD) Expectancy on Subjective Stress, Anxiety, and Intrinsic Connectivity Network Functional Connectivity in Healthy Adults},
  author = {Ethier-Gagnon and A, M. and Perry and R.N and Helmick and C and Crocker and C and Good and K and Stewart and H, S. and Barrett, S. P},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Cannabidiol (CBD) may be a promising candidate for stress/anxiety disorder treatment. CBD expectancy alone impacts subjective, physiological, and endocrine markers of stress/anxiety. We aimed to delineate CBD expectancy effects on subjective state and resting state functional connectivity (rsFC) within and between the default mode network (DMN), salience network (SN), and central executive network (CEN). Healthy adults (N=32) were randomized to receive accurate or misleading instructions regarding the CBD content of a CBD-free oil. rsFC was assessed at baseline and following a stress task. Subjective state was measured at multiple timepoints. In the Told CBD-free (control) condition, the SN showed increased rsFC with both the CEN and DMN. In the Told CBD (expectancy) condition, decreases in stress and anxiety were reported following oil administration and during stressor recovery, and increased rsFC was observed within and between the DMN and CEN. Results suggest CBD expectancy may engage neural pathways involved in stress-regulation.},
}

@inproceedings{farquhar2025relationship,
  title = {The Relationship of Perfectionism, Culture, Acculturative Stress and Depression in University Students},
  author = {Farquhar, Alexander},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {The stress generation hypothesis suggests that perfectionistic tendencies can create stress, increasing the risk of depression. This may apply to international students who experience acculturative stress, defined as a stress reaction towards struggles associated with adapting to a different culture. This study investigated whether acculturative stress mediates the relationship between perfectionism and depression. Participants were 119 Dalhousie University students who identified as international students or first-generation immigrants. They completed an online survey including measures of perfectionism (Big Three Perfectionism Scale), acculturative stress (Riverside Acculturative Stress Inventory), and depression (Center for Epidemiologic Studies Depression Scale). Mediation analysis revealed no indirect effect for rigid or self-critical perfectionism. However, narcissistic perfectionism was found to indirectly predict depression through acculturative stress. When controlling for time in Canada, this indirect effect was no longer significant. These findings highlight a potential link between narcissistic perfectionism and stress generation in the context of cultural adjustment and suggest that acculturative stress may be a pathway to depression for this perfectionism subtype.},
}

@inproceedings{good2025smoking,
  title = {Smoking Cue Reactivity and Smoking Motives in Patients with Early Phase Psychotic Disorder: A Behavioural Study},
  author = {Good and K and Couture and M.-E and Stewart and H, S. and Barrett and P, S. and Tibbo and P and Milliken and H and Alexiadis and M and Robertson, N},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Rates of tobacco smoking and unsuccessful smoking cessation attempts are high in individuals with psychosis. Exposure to smoking-related cues reliably enhances cigarette cravings in dependent smokers. Smoking-related cues do not affect smokers with chronic schizophrenia to the same degree as for non-psychotic smokers. However, less is known about individuals in the early phase of psychotic (EPP) illness. Additionally, it is unknown whether the smoking motives of EPP differ from those of non-psychiatric smokers. Cue-elicited cigarette cravings, and self-reported motives for smoking, were compared between EPP individuals (n=21) and non-psychiatric participants (NC; n=40). EPP individuals were less sensitive than NC to the cue-reactivity paradigm, suggesting individuals in the early phase of illness may not be affected by tobacco cues to the same degree as non-psychiatric smokers. Further, smoking motives did not differ between EPP and non-psychiatric smoker controls. Findings have implications for differences in smoking cessation interventions for these two populations.},
}

@inproceedings{hartley2025impacts,
  title = {The Impacts of Chronic Late Adolescent Stress on Adult Sociability in Mice},
  author = {Hartley, Mackenzie R. and Whitfield, Caden and Karimi, Pouria Vallapour and Franklin, Tamara B.},
  booktitle = {Psychology and Neuroscience 49th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2025},
  abstract = {Adolescents are more sensitive to stress than adults and experiencing stress during this developmental period can have lasting effects on behaviour, including increased depression-like and anxiety-like behaviours. However, its long-term impact on sociability has not been well studied. The present research aims to determine the effects of chronic late adolescent stress on adult peer-to-peer sociability using male and female, stressed and control mice. Male and female mice (n=48) were evenly split into stress and control groups. From post-natal day (PND) 48-60, we exposed stressed mice to a chronic predator stress paradigm while controls were left undisturbed in their home cages. Once mice reached adulthood (PND 96), we performed behavioural testing aimed at quantifying social dominance and social interest in same-sex and opposite-sex peers. Results suggest that chronic adolescent stress may lead to increased interest in same-sex peers and decreased social dominance. These findings could inform research on the lasting effects of human childhood and adolescent chronic stressors such as unsafe home environments and mental health struggles.},
}

@inproceedings{sparks2026remembering,
  title = {Remembering Kailey Simon (2000-2025)},
  author = {Sparks, Erin and Parsons, Ella},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Kailey Simon was from Elsipogtog First Nation in New Brunswick. She was a student in our program, working toward her BA in Psychology with a Certificate in Indigenous Studies. Her involvement at Dal spanned widely: She was a TA for Indigenous Studies, an RA on a project with Math & Stats and Oceanography, and worked with the Office of Sustainability, contributing art that you'll find on signage for the pollinator garden behind our building. Kailey was a persistent student who took intellectual ownership of her work in ways I've rarely seen, and who never shied away from a challenge in pursuit of her academic goals. Her peers in the Indigenous Student Society memorialized Kailey saying, "[s]he brought light, laughter, and care into our community … Kailey was so proud to be L'nu, and her confidence in who she was helped many others feel comfortable in their own skin. Her legacy will live on in everyone who had the privilege of knowing her." I had the privilege of working with Kailey for three years, across contexts. In this talk I'll introduce you to Kailey as I knew her, drawing from my experience watching her navigate my classes and our undergraduate program.},
}

@inproceedings{blais2026personalized,
  title = {Personalized Persuasion? Testing the Efficacy of Personality-Targeted Political Advertisements},
  author = {Blais, Julie and Pruysers, Scott and Mungall, Luke},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Before we can evaluate the harm that psychographic microtargeting may entail, we must first empirically examine whether political advertising can be tailored to resonate with people at the level of their personality. In Study 1, we conducted a survey among personality experts (N = 86) to evaluate the face validity of real-world targeted ads used for a US midterm election. In Study 2, we conducted a pre- registered between-subjects experimental design with a nationally representative sample of over 2,000 US citizens to assess whether advertisements that match participants' personality traits are more effective (i.e., vote intention, likability, etc.). Study 1 indicated that a majority (63%) of experts in personality psychology were unable to correctly identify the Big Five trait that was targeted in the video. In Study 2, there were no significant aggregate effects of the matching variable, once controlling for participant personality. However, a classification tree analysis did identify a small sub-group of participants where matched ads had higher efficacy. While concerns about psychological voter manipulation are widespread, the results of these studies suggest that such fears are likely overstated. However, even small and subtle effects when scaled to tens of millions of voters may influence election outcomes. In-House Conference | Friday, May 15, 2026 5 RETURN TO SESSION A SCHEDULE},
}

@inproceedings{bossom2026explaining,
  title = {Explaining Unique and Common Variance in Financially Focused Self-Concept from Dark Triad and Honesty-Humility Personality Traits Using Commonality Analyses},
  author = {Bossom, Isabella and Enouy, Sarah and Blais, Julie and Wohl, Michael and Pruysers, Scott and Tabri, Nassim},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {We investigated the personality correlates of financially focused self-concept, a construct describing individuals who overemphasize financial success as central to their self-definition and self-worth. Although some of the consequences of a financially focused self-concept have been studied, little is known about the personality characteristic of financially focused people. To address this gap, we examined the unique and shared associations between financially focused self- concept and the Dark Triad traits (Machiavellianism, psychopathy, and narcissism) as well as Honesty-Humility at the facet level to provide greater specificity than trait- level analysis. Using cross-sectional data from 1,725 Canadian adults who completed validated self-report measures, we conducted commonality analyses. Results revealed significant associations between financially focused self-concept and Machiavellianism facets (antagonism, planfulness), all psychopathy facets, narcissistic vulnerability, and lower levels of Honesty-Humility (greed-avoidance and modesty). These findings enhance understanding of the personality profiles of individuals who prioritize financial success excessively.},
}

@inproceedings{park2026emotional,
  title = {The Emotional Demands of Civilian Crisis Work: Exploring Burnout, Role Clarity, and Support in Civilian Crisis Intervention Teams},
  author = {Park, Christopher and Giacomantonio, Chris and Wozney, Lori},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Civilian Crisis Intervention Teams (CCITs) are rapidly expanding as alternatives to police-led mental health crisis response across Canada and the United States, yet little is known about responder well-being. Grounded in the Job Demands-Resources (JD-R) framework, this study examined burnout, perceived organizational support (POS), and role clarity during police collaboration among CCIT responders. Participants (N = 50) were current or recent civilian crisis responders who completed an anonymous online survey including the Copenhagen Burnout Inventory, the Perceived Organizational Support Scale-10, the Brief Role Clarity in Police Collaboration Scale, and demographic items. Descriptive statistics, reliability analyses, Pearson correlations, and hierarchical multiple regression were conducted. Responders reported moderate-to-high burnout, with the highest levels in personal and work-related domains. POS was significantly and negatively associated with burnout and remained a significant predictor in a model explaining 28.6% of burnout variance, even after accounting for years of experience. In contrast, role clarity did not significantly predict burnout, despite being positively associated with POS. These findings suggest POS may be a central factor in understanding burnout among CCIT responders. As CCIT's continue to expand, strengthening POS may be critical for sustaining CCIT models. In-House Conference | Friday, May 15, 2026 6 RETURN TO SESSION A SCHEDULE},
}

@inproceedings{stephen2026experimental,
  title = {Experimental Manipulations to Improve Participant Comprehension of Informed Consent Forms},
  author = {Stephen, Sasha and Walia, Sakshi and Mackinnon, Sean P.},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Though informed consent is a critical part of research ethics, research suggests that comprehension is low. The present study explores methods to improve the comprehension of consent forms via supplementary quizzes and videos. Using an online survey, undergraduates (n = 533) were given a standard consent form. Each participant was randomized to one of 4 conditions: (a) a control condition with standard consent; (b) adding a practice quiz; (c) watching a summary video with a male or (d) female actor. The primary outcome was scores on a multiple-choice quiz of facts related to the consent form. A secondary outcome was whether participants chose to share their data in a repository. Both video conditions were superior to control, with the male video condition having the best comprehension. The quiz condition was not statistically different from control. Though comprehension on most questions was good (~70-80%), understanding of open-access repositories was generally poor (~40%). Despite poor understanding, data sharing in repositories was high (~94%) and there were no differences by condition. Using video summaries following a written consent form can improve comprehension of the consent form's content. However, more work needs to be done to improve participants comprehension of broad consent. In-House Conference | Friday, May 15, 2026 7 RETURN TO SESSION B SCHEDULE},
}

@inproceedings{webster2026experimental,
  title = {Experimental Investigations of Smartphone Use and Attention},
  author = {Webster, Jeremy and Klein, Raymond},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {A review of research and literature on the interaction between smartphone use and attention. Includes an analysis of present limitations in the field when aiming to assess causality. Review of most commonly practiced experimental designs on the subject: notification, mere presence (brain drain), acute use, prolonged use. Results are interpreted using a contemporary taxonomy of attention (Klein, 2022), and suggest a negative influence on endogenously allocated attention and executive control. Consideration of future directions concludes the review.},
}

@inproceedings{wilson2026effects,
  title = {The Effects of Acute Short-Form Video Viewing on Go/No-Go Performance},
  author = {Wilson, Reyhana and Neyedli, Heather and Munroe, Cory},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Short-form videos (SFVs), typically lasting from a few seconds to a few minutes, have become increasingly popular across social media platforms. Although SFV use has been associated with poorer cognition, particularly inhibitory control and attention (Nguyen et al., 2025), experimental evidence testing its acute effects remains limited. This study examined whether brief SFV viewing, relative to a reading control, impairs Go/No-Go task performance, which requires response inhibition and sustained attention. Using a counterbalanced crossover design, participants (N = 36, Mage = 18.6, SD = 1.38) completed two 15-minute smartphone-based conditions: SFV viewing and reading. Immediately after each condition, participants completed a Go/No-Go task and self-report questionnaires. Preliminary analyses showed that participants reported an average of 31.8 hours (SD = 15.05) of smartphone use per week, with 44% of this time spent viewing SFVs (M = 14.07, SD = 9.98). The most viewed SFV genres included entertainment, music, people/blogs, comedy and news/politics. Our sample reported substantial SFV viewing, highlighting the popularity of this form of media. The effects of acute SFV viewing on Go/No-Go performance will also be presented. In-House Conference | Friday, May 15, 2026 8 RETURN TO SESSION B SCHEDULE},
}

@inproceedings{battist2026from,
  title = {From Bonding to Focus: Examining the Relationship Between Attachment Styles and Networks of Attention},
  author = {Battist, Kyra and Haggarty, Veda and Byron, Julia and Redden, Ralph},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Relationship attachment style has been found to influence performance associated with two of the three networks of attention. Attachment avoidance has been shown to influence the executive network of attention, wherein individuals higher in attachment avoidance show reduced interference in the standard Eriksen Flanker task. Attachment anxiety has been shown to influence the executive network as well, in addition to the orienting network of attention, wherein individuals higher in attachment anxiety show larger endogenous cueing effects. The current study was designed to replicate these prior findings, and to examine the heretofore untested relationship between attachment styles and the alerting network of attention, all in a single task. AttentionTrip is an engaging, gamified version of the Attention Network Task, played on an iPad tablet. Attachment styles were assessed using the Experience in Close Relationships-Revised Questionnaire. Robust network scores were observed for each network of attention. Attachment styles were associated with inverse relationships with overall RT. Moreover, orienting and executive control interacted differently with both attachment styles, whereas neither attachment style reliably influenced the alerting network. These findings support the hypothesis that the two forms of insecure attachment are associated with different underlying attentional functioning.},
}

@inproceedings{murray2026gagnon,
  title = {Gagnon, Raymond Klein, and Sherry Stewart Assessing Attentional Bias for Cannabis Activated by Trauma Cue Exposure in Cannabis Users with Trauma Histories},
  author = {Murray, Nicholas and DeGrace, Sarah and Burke, Melissa and Bossom, Isabella and Ethier-, Mikaela},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Posttraumatic stress disorder (PTSD) and cannabis use disorder (CUD) co-occur at rates five times higher than chance. An integrated self-medication/attentional bias (iSM-AB) model suggests that trauma reminders may shift attention toward cannabis cues in cannabis users with trauma histories, increasing cravings and intentions to use. This project tests the iSM-AB model using a personalized cue reactivity paradigm and an Addiction Stroop Task. To date, 17 (aiming to continue recruitment for a total of 50) participants completed both sessions. In Session 1, participants completed questionnaires and a semi-structured interview to generate personalized trauma and neutral scripts. In Session 2, participants were exposed to trauma and neutral cues, each followed by an Addiction Stroop Task with cannabis-related and neutral words. Preliminary linear mixed model results indicate that among individuals with higher PTSD symptoms, trauma cue exposure (but not neutral exposure) increases cannabis- related attentional bias (β = 0.43, p = .04). Post-cue negative affect was also positively associated with attentional bias, but only in the trauma condition (r = 0.46, p = .03). These preliminary findings support the iSM-AB model and suggest attentional bias modification training may be best targeted to individuals with more severe PTSD symptoms when preceded by trauma cue exposure. In-House Conference | Friday, May 15, 2026 9 RETURN TO SESSION B SCHEDULE},
}

@inproceedings{macarthur2026developing,
  title = {Developing a Deep-Learning Model for Individual Recognition in Canadian Geese: Extending Avian Observational Research Through Computer Vision},
  author = {MacArthur, Ryan},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Individual recognition is a foundational cognitive pillar that supports complex social architectures across the animal kingdom, enabling behaviours such as long-term pair bonding, reciprocal altruism, and hierarchy maintenance. Studying these behaviours requires both establishing cognitive capacity and developing non-invasive tools to observe undisturbed behaviour. Avian ethology has emphasized auditory recognition, yet mounting evidence shows visual signals also carry identity information. Work on the Greylag Goose (Anser anser) has demonstrated bill- and face-level individuality with high algorithmic accuracy. The Canadian Goose (Branta canadensis) presents as a similar candidate and remains unexplored. Here we report a computational study comparing two deep-learning architectures trained and tested on identical data, as a step toward non-invasive individual identification. Individually-labelled images were assembled from a reference dataset and from video-derived exports produced by a purpose-built annotation tool. We tuned a ResNet-50 classifier (closed-set assignment) and a MegaDescriptor-L-384 retrieval model (gallery matching). Both reached >90% accuracy on novel test images. Saliency maps emphasized the cheek- patch boundary, bill, and facial regions as candidate identity cues. Together, the results support a passive, camera-based alternative for avian observational research.},
}

@inproceedings{sozuer2026quantitative,
  title = {Quantitative Data-Based-Evaluation of Signal-to-Noise in Assessments Reveals Novel Insights},
  author = {Sozuer, Can},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Online learning platforms like Brightspace, Remark, or Crowdmark can display evaluative metrics for questions graded on their platforms. These metrics estimate how well a question assesses student learning by comparing how well performance on that question predicts performance on other questions (signal). However, platform- provided metrics may not evaluate well assessments with a wide variety of question types, as this variation reduces predictiveness. They also cannot incorporate question information supplied externally by a teaching user to account for between question variation. Here, I present a new metric for evaluating how well a question assesses learning, with the added ability to incorporate externally provided question information. This metric is thought to evaluate how well a question assesses learning, especially on high-variation assessments, more accurately than readily available alternatives. I then apply this metric to datasets to extract insights into which assessment design elements increase how well a question assesses student learning (signal). In-House Conference | Friday, May 15, 2026 10 RETURN TO SESSION C SCHEDULE},
}

@inproceedings{brown2026influence,
  title = {The Influence of Ramon y Cajal and Rafael Lorente de Nó on Donald O. Hebb},
  author = {Brown, Richard E.},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Donald O. Hebb obtained his BA in English and Philosophy from Dalhousie University in 1925 and his MA in Psychology from McGill in 1932. He completed his PhD with Karl Lashley at Harvard in 1936. Between 1932 and 1934 he wrote three unpublished papers on the neural basis of behaviour. After his PhD he conducted neuropsychological tests on the patients of Dr. Wilder Penfield at the Montreal Neurological Institute (1937-39). From 1939 to 1942 he was a professor at Queen's University in Ontario and then he studied emotionality in chimpanzees at the Yerkes Primate Centre in Florida (1942-1947). It was here in 1944 that he began to revise his old theory of the neural basis of behaviour and wrote five sets of unpublished notes for his influential book, The Organization of Behavior. This book introduced the concepts of the "Hebb synapse" and learning rule, cell assemblies, and phase sequences to account for the neural events underlying behaviour. The crucial element in Hebb's theory was the reverberatory circuit of Lorente de Nó, based on Cajal's concept of closed circuits. This presentation examines the unpublished notes and papers written by Hebb as he developed his neuropsychological theory.},
}

@inproceedings{butler2026determining,
  title = {Determining Cortical Roles in Motion Perception via Optogenetic Inactivation of Visual Areas},
  author = {Butler, Andrew and Michaud, Nicole and Dang, Lan and Crowder, Nathan},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Motion perception is an integrative process that combines information about the direction, size, and velocity of a stimulus. Our aim is to examine the cortical networks underlying speed discrimination, which is the ability to perceive differences in velocity. The optogenetic regulation of an inhibitory interneuron circuit in the mouse cortex allows for reversible inactivation of various cortical areas to determine which areas are involved with speed discrimination. By combining this optogenetic technique with a 2- alternative forced-choice task where the mouse must select the faster of two random- dot kinematograms, we are able to assess if the targeted region is involved in speed discrimination. Pilot data has already been collected showing that optogenetic inactivation of the primary visual cortex (V1) can impact motion perception. From here we plan to conduct a more complete experiment to fully assess the role of V1 and higher visual areas in speed discrimination. This research provides foundational information about the contributions of individual cortical regions to visual perception, but also provides a methodological framework for future research to assess the relevance of individual cortical areas to any behaviourally measurable aspect of perception or cognition due to canonical circuitry. In-House Conference | Friday, May 15, 2026 11 RETURN TO SESSION C SCHEDULE},
}

@inproceedings{locke2026seeing,
  title = {Seeing More in the Electroretinogram: Integrating Time, Frequency, and Resting-State Analyses Across Mouse Models and Human Retinal Disease},
  author = {Locke, Jeffrey and Côté, Patrice and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Interpretation of the electroretinogram (ERG) has traditionally focused on time-domain waveform features which may oversimplify complex retinal signaling. Frequency- and time-frequency-domain analyses offer complementary perspectives but remain inconsistently applied due to methodological variability. Resting-state ERG has also emerged as a potential probe for intrinsic retinal activity, though its relationship to evoked responses remains poorly defined. Full-field ERGs were recorded across stimulus-evoked and resting-state conditions in mouse models representing normal retina (n=23), inner-retinal dysfunction (n=10), and global-retinal degeneration (n=11). Signals were analyzed using time-domain metrics, power spectral density, and time- frequency transforms. Time-frequency analysis employed Morlet wavelets parameterized using a full-width-at-half-maximum (FWHM) framework to explicitly control temporal-spectral trade-offs. An identical analytical pipeline was applied to human clinical ERG and resting-state data (n=69). Progressive retinal dysfunction produced graded reductions in waveform amplitude, spectral power, and time- frequency energy, with broad, permutation-corrected spectral and temporal clusters distinguishing phenotype. Resting-state ERG demonstrated consistent alterations in aperiodic spectral slope and high-frequency structure, persisting even when evoked responses approached the noise floor. Comparable patterns were observed across species. Integrating time-domain, frequency-domain, time-frequency, and resting- state analyses provides a more sensitive and comprehensive assessment of retinal function than any signal method alone.},
}

@inproceedings{lewis2026how,
  title = {How Quickly Does Neural Activity Change in Response to Learning Unfamiliar Language Vocabulary?},
  author = {Lewis, Hope and Brandt, Cate and Newman, Aaron},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Semantic processing is associated with the N400 event-related potential (ERP), with larger N400 amplitudes appearing when information mismatches versus when it matches expectation. This differentiation is called the N400 effect, which does not appear with unfamiliar language (UL) vocabulary before training, but does appear by 10 days after training begins. By recording EEG throughout the training process, the current study determined how much exposure to UL vocabulary a new learner needs to show an N400 effect in response to said UL vocabulary. Over two sessions, Spanish vocabulary was taught to UL learners by pairing words with images representing their meaning. A semantic mismatch task paradigm was used to assess N400 ERPs in Spanish and in English before and after each block of training in each session. We found that after 3-4 exposures to UL words in the first session, an N400 effect emerged, with this remaining during the second session. Mean amplitude was smaller in the Spanish vocabulary compared to English, reflective of the difference in proficiency. Accuracy of responses also improved over time, reaching ceiling by the end of day 1. Findings provide useful insight into the earliest neural markers of acquiring new semantic information with UL vocabulary. In-House Conference | Friday, May 15, 2026 12 RETURN TO SESSION C SCHEDULE},
}

@inproceedings{yu2026one,
  title = {One Skill, Different Journeys? Morphological Awareness and Reading Growth Across Socioeconomic Status},
  author = {Yu, Shuqi and Deacon, Hélène},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Reading comprehension supports learning across academic subjects. A robust predictor is morphological awareness (MA), the ability to recognize and manipulate meaningful word units. Although higher-SES children show faster reading growth especially in Grade 1, it remains unclear how SES shapes the long-term impact of Grade 1 MA on reading growth. Therefore, this study examined whether MA contributes differently across socioeconomic contexts from Grade 1 to Grade 4. Participants were 313 English-speaking children from 18 primary schools in Eastern North America. In Grade 1, children completed MA, reading comprehension, and control measures (word reading, vocabulary, phonological awareness, nonverbal ability, working memory). Parents reported family demographics, including SES. In Grade 4, standardized reading comprehension was assessed. Grade 1 MA uniquely predicted Grade 4 reading comprehension (β = 0.51, p < .001). SES was also positively associated with later reading comprehension (β = 0.10, p = .01). A significant MA × SES interaction indicated that the association between MA and reading comprehension growth was stronger for children from lower-SES backgrounds (β = −0.11, p = .02). These findings suggest that MA is particularly important for reading development among lower-SES children, highlighting its potential as a target for early instruction. In-House Conference | Friday, May 15, 2026 13 RETURN TO SESSION D SCHEDULE},
}

@inproceedings{dauphinee2026semantic,
  title = {Semantic Similarity Disrupts Order Recall: The Moderating Role of Task Difficulty},
  author = {Dauphinee, Ian and Guitard, Dominic and Ishiguro, Sho and Saint-Aubin, Jean},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Similarity affects memory across many stimulus domains, typically impairing short- term order recall, with one important exception: semantically similar words (e.g., apple, orange, banana). In fact, the challenging insensitivity of short-term order recall performance to semantic similarity is has become a benchmark effect for evaluating memory models. However, contrary to the literature, three key studies reported a detrimental effect of semantic similarity on short-term order recall. Here, in five large- scale experiments, we revisited these three exceptions. Despite implementing more rigorous methodological controls, we reproduced the detrimental effect of semantic similarity across all experiments. We then conducted a review and meta-analysis, which revealed a small but reliable detrimental effect across the literature. To account for previous inconsistencies, we identified a potential moderating variable: task difficulty. Across four additional experiments, we manipulated task difficulty via presentation speed and list length. As predicted, under more difficult task conditions semantic similarity impeded order recall, and critically, when the task was easier, its detrimental effect on order recall vanished. These findings show that semantic similarity is not a special case for short-term order memory and that its effect depends in part on task difficulty, helping reconcile previously conflicting results for models of serial order memory.},
}

@inproceedings{hartley2026persistent,
  title = {The Persistent Effects of Adolescent Chronic Psychological Stress on Sociability in Male and Female Mice},
  author = {Hartley, Mackenzie R. and Franklin, Tamara B.},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Adolescents are more sensitive to stress than adults and experiencing stress during this developmental period can have lasting effects on behaviour, including increased depression-like and anxiety-like behaviours. Our research aims to determine the effects of chronic adolescent stress on adult sociability, and the neural mechanisms that may underlie these effects. Our behavioural research has found that adolescent Chronic Predator Stress (aCPS) exposure leads to an increase in same-sex peer investigation and altered social dominance behaviours in adult mice. Gene expression in the brains of these animals was analysed using rt-qPCR analyses, with an initial focus on the dorsal and ventral hippocampus, brain regions that are still developing during adolescence, are responsive to stress, and have been shown to be critical for social function. We quantified Drd2 and Oxtr (genes that encode for dopamine and oxytocin receptors), and histone deacetylase 2 (Hdac2), all of which represent systems that have been associated with both social behaviours and stress. aCPS had no effect on hippocampal expression of these genes in male or female mice. Future work includes a brain-wide c-Fos mapping study to gain insight into the brain areas likely to contribute to the altered peer investigation behaviours observed in our behavioural study. In-House Conference | Friday, May 15, 2026 14 RETURN TO SESSION D SCHEDULE},
}

@inproceedings{babcock2026expanding,
  title = {Expanding on the Two-Hit Model of Depression-Like Behaviour and the Underlying Role of the Oxytocin System},
  author = {Babcock, Megan and Zucconi, Kate and Menard, Janet and Franklin, Tamara},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {The two-hit hypothesis proposes that early-life stress increases vulnerability to later stressors. While this hypothesis was originally developed in schizophrenia research, recent work has applied it to depression as well. My MSc research tested whether early-life adversity (ELA) heightens sensitivity to subthreshold stress. Rats exposed to both neonatal limited bedding and nesting stress and a subthreshold version of chronic mild stress in adolescence displayed greater depression-like behaviour and aggression in adulthood, whereas neither stressor produced effects alone. LBN exposure was also associated with reduced oxytocin (OT)-immunoreactive cells in the paraventricular nucleus, a key OT-producing region that helps regulate stress responses and social behaviour. These findings suggest that ELA renders individuals more vulnerable to depression-like behaviour following a later stressor, even when subthreshold, and implicate altered OT signaling as a potential underlying mechanism. Building on this work, my proposed PhD research will test the hypothesis that ELA disrupts OT system function, and that these disruptions have lasting consequences for stress sensitivity across development. Specifically, I will investigate whether the timing and type of stress exposure differentially alter OT production, release, and receptor signaling, and whether these changes drive depression-like and social behavioural outcomes.},
}

@inproceedings{whitfield2026impact,
  title = {The Impact of Income Level on Child Sleep, Parental Engagement, and Perceived Effectiveness of the Better Nights, Better Days eHealth Intervention},
  author = {Whitfield, Caden and Dockrill, Mya and Corkum, Penny and Emberly, Debbie and Cassidy, Christine and Pencer, Alissa and Simonelli, Guido},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Behavioural sleep disturbances (e.g., insomnia) are common in school-aged children and negatively impact health and functioning. Better Nights, Better Days (BNBD) is an evidence-based eHealth intervention proven to improve sleep in children. Given that most intervention research mainly includes participants with middle to high income, we do not know how income level impacts children's sleep and treatment for sleep problems. A secondary analysis of four previous BNBD studies was performed to examine differences between families with low income (n = 145) and mid-high income (n = 820) regarding sleep problem severity, engagement with the intervention, and perceived effectiveness. Data from sleep health questionnaires demonstrated that low-income children had more severe sleep problems. User analytics (i.e., number of sessions completed) from the BNBD intervention showed very similar rates of engagement between income-level groups. Differences between pre- and post- intervention questionnaires for participants who completed a "clinical dose" of the program showed that the low-income participants reported lower effectiveness than the mid-high-income participants. This study supports that sleep health disparities are present in Canadian children and demonstrates the promise of BNBD as a usable intervention for low-income families, while emphasizing the need to further investigate the intervention's effectiveness for low-income families. In-House Conference | Friday, May 15, 2026 15 RETURN TO SESSION D SCHEDULE},
}

@inproceedings{ethiergagnon2026impact,
  title = {The Impact of Menstrual Cycle Phase on Subjective, Behavioural, and Physiological Responses to Electronic Cigarette Ingredients},
  author = {Ethier-Gagnon, Mikaela and MacLean, Makayla and Perry, Robin and Munroe, Cory and Perrot, Tara and Stewart, Sherry and Good, Kim and Barrett, Sean},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Electronic nicotine delivery systems (ENDS) use has increased in recent years, partly due to appealing flavours such as menthol. Sensory factors appear particularly important for nicotine reinforcement in females, and ovarian hormones may modulate these effects. However, the role of the menstrual cycle in menthol- and nicotine-related reinforcement remains largely unexamined. Naturally cycling female ENDS users (N = 34) completed experimental sessions during two menstrual phases (follicular and luteal phase) in a randomized mixed within-subjects (menstrual phase) and between- group (menthol vs. menthol-free) design. Immediately before and after a standardized puffing procedure, subjective measures (craving, withdrawal, subjective state, inhaler effects) and heart rate variability (HRV) were assessed. Salivary estradiol and progesterone were collected to validate menstrual phase and for exploratory analyses. Menthol enhanced sensory and reward-related subjective effects and was associated with greater reductions in relief craving relative to the menthol-free condition. In the menthol-free condition, participants in the follicular phase reported greater withdrawal and subjective 'high' relative to the luteal phase. Exploratory analyses indicated that higher progesterone levels were associated with reduced withdrawal in the menthol-free condition only. Results support policy efforts regulating menthol in ENDS products and highlight the need for targeted cessation strategies for female users.},
}

@inproceedings{koning2026psilocybin,
  title = {Psilocybin Treatment as an Adjunct to Cognitive Behavioral Therapy for Eating Disorders: Therapeutic Rationale & Considerations for Protocol Development},
  author = {Koning, Elena and Gamberg, Susan and Keshen, Aaron},
  booktitle = {Psychology and Neuroscience 50th Annual Graham Goddard In-House Conference, Dalhousie University},
  year = {2026},
  abstract = {Eating disorders (EDs) remain challenging to treat, with high dropout and low remission rates in cognitive-behavioral therapy for EDs (CBT-ED). Psilocybin treatment (PT) demonstrates therapeutic potential to enhance CBT-ED by exerting several neurobiological (e.g., neuroplasticity, cognitive flexibility), psychological (e.g., antidepressant), and experiential (e.g., illness insights) effects. Specifically, the effects of PT are hypothesized to increase psychotherapeutic engagement/learning, reduce dropout, and improve clinical outcomes. This perspective article (recently published in Behavioral Sciences) provides the first consolidation of neurobiological and transdiagnostic clinical evidence for PT/CBT-ED, proposes considerations for a concurrent intervention protocol, and presents clinical research considerations to empirically test its feasibility, safety, and efficacy. This line of inquiry is expected to advance the development of approaches that improve ED treatment outcomes. More broadly, it advances the study of psychedelics as tools to enhance evidence-based psychotherapy models for difficult-to-treat neuropsychiatric conditions. In-House Conference | Friday, May 15, 2026 16 RETURN TO SCHEDULE POSTER ABSTRACTS 1 NESC/PSYO 3370: Sarah MacMillan, Ewan MacKinnon, Avery Nadalini, Emma Morais, Ella Power, Ozan Ozmen, Laura Kuyper, Brian Corbett, Elijah Akpan, Utkarsh Pandey, Sofia Westfall, Khushbu Aumeer, Max Vaillancourt, Luke Janze, Sarah Taylar, and Kevin Duffy Synapsin Immunolabeling in the LGN Remains Unchanged Following Monocular Retinal Inactivation Conditions that disrupt visual experience early in life can alter the structure and function of neurons, producing a vision impairment called amblyopia. Success recovery with conventional occlusion treatment is plagued by poor compliance, and is effective only when administered very in early childhood during the critical period. Previously, we demonstrated rapid recovery from the effects of monocular deprivation following temporary retinal inactivation of the dominant eye with intraocular application of tetrodotoxin. Brief retinal inactivation produced rapid and significant structural and functional recovery at ages beyond what is observed with mainstay occlusion therapy. Verifying the safety of retinal inactivation is of paramount importance in considering it as viable means of correcting the effects of early abnormal vision. In this study we show that immunolabeling for a common marker of synaptic integrity, synapsin, is preserved after retinal inactivation indicating that synapses serving the silenced eye are not lost following temporary loss of retinal activity. 2 Aarushi A and Javeria Hashmi Resilience Profiles in Chronic Pain: The Role of Trauma Exposure & Symptoms Chronic pain is a prevalent and complex condition that causes physical, psychological and functional difficulties. Such populations usually have had exposure to traumatic events, which have been linked to worse psychological & pain-related outcomes. Individual responses to such traumatic exposure, however, differ greatly: some may develop post-traumatic stress symptoms (PTSS), but others may maintain relatively adaptive daily functioning. These differences suggest that psychological and clinical pain outcomes, specifically after trauma exposure, may be significantly influenced by resilience. The present study aims to examine resilience profiles in individuals with chronic pain, with a particular focus on how trauma exposure and PTSS relate to adaptive traits and pain outcomes. Using pre-existing data from a chronic pain study, we looked at whether those with trauma exposure who report fewer post-traumatic stress symptoms exhibit higher levels of psychological resilience resources, more adaptive acute and clinical pain profiles as well as better emotional burden management. A one-way ANOVA was used to evaluate group differences amongst the 16 variables, with a non-trauma-exposed group included for comparison. Findings revealed that while the resilient and vulnerable groups differed in their psychological resilience resources and emotional burden, there were no significant differences in the clinical pain outcomes. These results suggest that resilience and vulnerability may be more strongly reflected in psychological and emotional domains rather than in pain intensity itself. Hence, this study aims to advocate for more individualized trauma & resilience-informed approaches into chronic pain assessment and management, supporting more individualized and comprehensive care strategies. In-House Conference | Friday, May 15, 2026 17 RETURN TO SCHEDULE 3 Laura Adams, Anika Cloutier, Daphna Motro, and Maria Adams Leaders' Depression Disclosure: Followers' Perceptions and Leadership Expectations Organizations are increasingly encouraging leaders to foster a positive mental health climate, including by disclosing personal challenges. However, how followers perceive leaders following such disclosure remains unclear. This study examined how the degree of leader's depression disclosure influences follower perceptions and leadership expectations. Drawing on stigma theory and implicit leadership theories (Goffman, 1963; Lord et al., 2020), we predicted that greater disclosure would reduce perceived leader prototypicality, which would in turn lower expectations of effective leadership behaviours. Based on role congruity theory (Eagly & Karau, 2002), we further predicted stronger negative effects for male leaders, given the incongruence between depression and male gender norms. 403 Prolific participants were randomly assigned to a 4 (disclosure degree: control, low, moderate, high) × 2 (leader gender: man, woman) video vignette design. Participants rated leader prototypicality and the expected servant and laissez-faire leadership behaviours. Results indicated that the disclosure amount did not affect prototypicality, nor did prototypicality mediate leadership expectations; these relationships were not moderated by leader gender. However, exploratory analyses showed that authenticity ratings varied by condition, with moderate disclosure rated higher than low, and authenticity mediated the link between disclosure and leadership expectations. Findings contribute to both occupational health and leadership literatures. 4 Victoria Adams, Tamara Franklin, Sarah Hughes, Mackenzie Hartley, and Megan Babcock Comparing the Warm Spot Test and Tube Test as Behavioural Measures of Social Hierarchy in C57Bl/6N Mice Social hierarchies are fundamental to communal species, shaping social behaviour, stress responses, and cognition. In rodent models, reliable and ecologically valid measures of dominance are essential for accurately linking social rank to biological processes. The widely used tube test establishes hierarchy based on winning/losing over repeated trials across 7-10 days, which may introduce learning effects and confound results. The warm spot test is a newer, less-studied approach that suggests that dominant mice will spend the most time in the warm spot compared to subordinate mice. However, knowledge gaps remain regarding its validity, reliability, and ability to distinguish intermediate (Rank 2) from subordinate (Rank 3) individuals. This pilot study directly compared the warm spot and tube tests in adult male and female mice housed in trios. Mice were assessed using the warm spot test before and after a 7-day tube test protocol. Males performed similarly on both warm spot trials, indicating stability despite tube test exposure, whereas females did not. Notably, males identified as rank 2 based on number of wins in the tube test spent more time in the warm spot than Rank 1 or Rank 3 mice, suggesting distinct behavioural strategies in this group. Overall, our findings suggest that the warm spot test is more consistent in males than females, and that time in the warm spot does not measure the same dominance trait as number of wins in the tube test. In-House Conference | Friday, May 15, 2026 18 RETURN TO SCHEDULE 5 Mohammed Ali Ahmed and Richard E. Brown Effect of Number of Training Trials on Olfactory Learning and Memory in a Pavlovian Conditioned Odour Preference Task Olfactory learning is a robust and ethologically relevant model for investigating cognitive function in rodents. However, defining the boundary conditions of these tasks, particularly the minimum number of training trials required to generate a stable memory trace, is essential for developing sensitive behavioural assessments. This study examined these conditions in the Pavlovian Conditioned Odour Preference Task using the Nrxn1+/- mouse model of Autism Spectrum Disorder. Male and female Nrxn1+/- mice and wild-type littermates underwent a one-day training protocol consisting of either 16 or 8 training trials. Memory strength was assessed in 24-hour and 14-day memory tests, followed by extinction trials and a spontaneous recovery test. Results indicated that 8 trials were insufficient to produce an odour preference in either genotype. Unexpectedly, wild-type mice also failed to show a preference in the 16 trial condition, whereas Nrxn1+/- mice demonstrated both short- and long-term memory. However, this memory was extinguished within two unreinforced trials after 14 days and did not show spontaneous recovery. These findings are compared with the results of previous studies in our lab and define memory formation and extinction parameters in the one-day Conditioned Odour Preference Task as an efficient assay for memory strength in mice. 6 Madison Baggs The Impact of High Cognitive Demand on the Directed Forgetting of Negative Words This experiment used an item-method paradigm to examine whether high versus low cognitive demand during encoding influences directed forgetting of negative and neutral words. Using rapid serial visual presentation, each study trial began with 8-15 random letter strings, followed by a neutral or negative study word and then by an instruction to remember or forget. This was followed by seven additional letter strings, one of which was a probe consisting of all Xs or all Os. In the high cognitive demand condition, participants identified the probe by pressing X or O on the keyboard; in the low cognitive demand condition, participants were not required to identify the probe and, instead, pressed the space bar at the end of each study trial. After all study trials were presented, a yes-no recognition task assessed the directed forgetting effect for negative and neutral study words. Directed forgetting was defined as the difference between to-be-remembered word recognition and to-be-forgotten word recognition. A two-way ANOVA showed a main effect of valence, with a smaller directed forgetting effect for negative words compared to neutral words; a main effect of cognitive demand, with a smaller directed forgetting effect when participants encoded words under high demand compared to when they encoded words under low demand; and, no significant interaction. These results suggest that the influence of negative valence on directed forgetting occurs early in encoding and is not affected by subsequent demands on limited-capacity resources. In-House Conference | Friday, May 15, 2026 19 RETURN TO SCHEDULE 7 Jiah Bhutani, Cameron Calder, and Javeria Ali Hashmi The Role of Trauma History in Chronic Pain: Distinguishing the Effects of Type, Timing, and Cumulative Exposure Trauma exposure is highly prevalent in chronic pain and may contribute to pain-related symptom burden. However, trauma is often treated as a single construct, limiting understanding of how trauma type, developmental timing, and cumulative exposure differentially relate to pain and psychological outcomes. This study examined these trauma dimensions in adults with chronic pain. Participants were 149 adults with fibromyalgia, chronic back pain, or both. Lifetime trauma was assessed using the Brief Trauma Questionnaire, and developmental trauma was assessed using the Childhood Trauma Questionnaire and the Adverse Childhood Experiences questionnaire. Interpersonal trauma was based on endorsement of relevant items. Outcomes included pain threshold, pain tolerance, pain severity, pain interference, pain catastrophizing, depressive symptoms, state and trait anxiety, post-traumatic stress symptoms, and dissociative symptoms. Trauma exposure was common, with sexual violence, serious accidents, and witnessing trauma most frequently reported. Women reported higher rates of sexual violence, whereas men reported higher rates of combat exposure. Approximately 60% reported at least one interpersonal trauma, which was associated with greater affective and post-traumatic stress symptom burden. Lifetime trauma was associated with higher pain severity and interference, whereas developmental trauma was associated with lower pain tolerance. Findings support a multidimensional, trauma-informed approach to chronic pain assessment and management. 8 Karina Bouter, Sophia Giazizidou, Catherine Mimeau, and Hélène Deacon Do Students with Dyslexia Learn the Spellings and Meanings of Words Through Reading? Fluent and accurate reading is a critical skill in navigating society. Typically developing children learn the spelling and meaning of words through independent reading, called orthographic and semantic learning respectively. We investigate whether these skills are impaired in students with dyslexia - children with poor word decoding and fluency. We tested orthographic and semantic learning in 139 Grade 3 students. We identified 21 students with dyslexia (scored below one standard deviation on standardized measures of word reading) and matched 21 controls by age and nonverbal intelligence. Students completed a learning task where they read stories about new inventions (e.g., a fish tank cleaner called a veap). Students demonstrated orthographic learning by choosing the invention spelling from four nonwords and semantic learning by choosing the image depicting its function from four pictures. We found that controls outperformed those with dyslexia on orthographic learning (p = .013, d = .8) but not semantic learning (p = .277, d = .34). Harnessing strengths in semantic learning may help students with dyslexia form orthographic representations of new words, increasing their reading fluency and accuracy. In-House Conference | Friday, May 15, 2026 20 RETURN TO SCHEDULE 9 Heather Carr and Simon Gadbois Assessment of Biomedical Alert Dog Candidate Learning and Training Methodology Biomedical alert dogs are utilized increasingly in treatment and diagnosis, resulting in an increase in related studies in the recent literature regarding their potential. This growth has led to ever-increasing demand for trained animals. Training protocols are not able to keep up with the need, leading to long wait times for service dogs. Modifications of training procedures to best accommodate dogs' learning mechanisms could streamline this process. The importance of investigating the best way to train a given dog is underscored by the extensive time and economic investment in training a scent-detection dog. In this study, I will examine scent-detection canine performance across two different scent-detection training methodologies. My questions will be whether the matrix technique pioneered in the Wildlife Ethology and Canine Olfaction Lab (W.E.C.O.) offers advantages over the funnel technique for the dog's overall performance, specifically accuracy and precision (consistency in the type of error), as well as if it benefits the overall consistency of their performance. 10 Ava Cole, Isaiah Seale, and Richard Brown Sex Differences in Olfactory Learning and Memory Across Nrxn1 Genotypes in Mice Autism spectrum disorder (ASD) is a neurodevelopmental disorder affecting ∼1% of the population. Neurexins, including Nrxn1, are strongly linked to ASD and have been associated with learning deficits. This study examined sex differences in four Nrxn1 genotypes in mouse models using a Pavlovian conditioned odour preference paradigm, with memory tested 24 hours, 7 days, and 30 days after training. Learning and memory were evaluated through digging behaviour in the rewarded (CS+) and non-rewarded (CS-) odour pots, as well as difference and preference scores. Sugar consumption was also measured during acquisition. Males displayed significantly more digging behaviour than females during training and early memory tests, although preference scores did not differ. No significant genotype effects or sex by genotype interactions were observed. These findings suggest that Nrxn1 related learning deficits may not be detectable using simple Pavlovian conditioning procedures. Observed sex differences indicate that performance strategies may vary while overall memory abilities remain comparable between males and females. High preference scores further indicate that this one-day Pavlovian conditioned odour preference training procedure is effective, and mice can acquire, store and consolidate olfactory memories 24 hours, 7 days, and 30 days after learning the association. In-House Conference | Friday, May 15, 2026 21 RETURN TO SCHEDULE 11 Ella Mae Cueto, Gia Samuel, Paige Parsons, Ian Dauphinee, and Raymond Klein The Exploration of Sensitivity and Response Bias in the Vigilance Decrement Vigilance, or sustained attention over time is essential in numerous fields, and a decline in vigilance during a repetitive, cognitively taxing task is often observed. The exact cause of this decrement is not completely clear. However, in current literature, sensitivity and criterion are two theories that could help explain this decline in hit rate over time. We investigated whether vigilance decrement was due to a sensitivity decline, a conservative criterion shift, or combination of the two. Nine participants were told to imagine themselves in the role of a radar operator scanning spy planes as their targets and passenger planes as their non-targets and asked to perform a repetitive, cognitively demanding task over the course of 35-40 minutes. Participants detected these targets while rating their confidence level. In contrast to our hypothesis, results indicated that participants did not adopt a criterion shift and exhibited an increase in sensitivity. We conclude that because our vigilance task was too cognitively demanding, they did not experience a vigilance decrement. 12 Rachel Dean, Kevin LeBlanc, Anne Lacroix, Brett Feltmate, and Heather Neyedli Planning for the Unknown: Effects of Target Uncertainty on Grasping Motor planning for grasping known objects is well understood, but how we plan grasping movements under uncertainty is not. Competing theories propose an averaging strategy, where multiple possible actions are combined, or an optimization strategy, where the safest or most demanding movement is prioritized (maximal-safety approach). Research supports the maximal-safety approach, showing larger hand openings when a larger object is present, regardless of the target. However, those findings may be influenced by differences in object size and weight. To address this, we used two identical rectangular objects and varied their orientation to change the required grip size while keeping the physical properties the same. Participants (n = 25) completed two conditions, a Go-Before-You-Know (GBYK) condition, where the target was revealed after movement, and Know-Before-You-Go (KBYG) condition, where the target was specified in advance. Peak grip aperture (PGA) was defined as the maximum distance between the thumb and index finger during the reach. Under uncertainty (GBYK), PGA was influenced by the target and the distractor, consistent with an averaging strategy. When the target was known (KBYG), PGA reflected only the target. Overall, these results suggest that when confounds are controlled, the brain plans grasping movements under uncertainty by averaging