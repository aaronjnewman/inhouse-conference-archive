  author = {Yoon, Myong and Yoon, Myonghae Joy},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {We study young (2-5 years old) children's cognitive development with respect to their abilities to make appropriate predictions of a protagonist's actions and to explain their own judgements. Four brief movies are designed to test (1) "Simple Desire Reasoning", (2) "Belief/Desire Reasoning", (3) "Descepant Belief Reasoning", and (4) "False Belief Reasoning" (Wellman & Woolley, 1990; Pemer, 1990) as follows: [a] Let a child (the subject) assume an active role of 'explainer' who tells his/her addressee (the experimenter) what is going on in a test story enacted in the movie that the child has been watching (instead of being passive observer of the test situation presented by the experimenter). Then the experimenter asks the child to predict what the protagonists in the movie will do. [b] Video-recording of all utterances and communicative gestures produced by the chidren and the experimenter during the entire discursive organizations as well as for their lexico-syntactic structures and semantic cohesion. These analyses will reveal not only the cognitive abilities of the children for different types of reasoning but also their pragmatic competence in communicating their thoughts and emotions at various stages of their develoment [c] Longitudinal studies with individual children (2 to 5 years old) to denote the individual patterns of developmental changes through consecutive tests.},
  note = {QA: abstract-too-short},
}

@inproceedings{kind1991effects,
