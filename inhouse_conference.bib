  author = {ology, O.C.E.A.N. -},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {The five-factor model is a taxonomy of ~rsonali~ traits in terms of five broad dimensions: Openness to Experience, Conscientiousness, Extraversion, Agreeableness, and Neuroticism. Although evidence suggests that these five factors are useful in studying and modelling normal personality, there is less consensus regarding their ability to model abnormal personality, particularly Eersonali!'.disorders. This study investigated the relationship between the five factor model ofpersonality and personality disorders. Two hundred and fifty undergraduate students completed the Personality Diagnostic Questionnaire-Revised (PDQ-R)as a measure of personality disorders and the Big Five Inventory (BFI-54) as a measure of the five factors of personalty. Results are discussed with respect to the theoretical relationship between personality disorders and the five factor model.},
