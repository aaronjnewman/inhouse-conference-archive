@inproceedings{phillips1995once,
  title = {Once Is Not Enough: Turning Your Partner On With Multiple Spikes},
  author = {Phillips, D.P. and Kitzes, M.N. Semple. L.M. and Hall, S.E.},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {In independent studies, Phillips (Dalhousie) and Eggermont (Calgary) are compiling circumstantial evidence on local circuits in the cerebral cortex. Phillips & Sark (1991) reported that many cells in the cat's primary auditory cortex (AI) had responses consisting of a burst of spikes; the inter-spike intervals in these responses were very short(= 2 ms) and were typically stimulus-invariant. Bowman, Eggermont & Smith (1995, submitted) confirmed and extended these findings. They suggested that most extracellular recordings in AI come from larger neurons (likely pyramidal and basket cells), while the smaller (nonpyramidal) cells are relatively inaccessible to metal electrodes. There is reason to believe that the small cells are probably inhibitory interneurons that receive input from the pyramidal cells. and which. either through post-synaptic membrane specializations or local GABA-mediated inhibition (Winer, personal communication), are best excited by a train of closely-spaced pyramidal cell spikes. If these pyramidal celVnonpyramidalcell circuits are a property of the cerebral cortex generally, rather than a property specifically of AI, then the same phenomenology should be seen in other cortical areas. We have obtained evidence on the responses of neurons in the posterior auditory field, studied under the same conditions as our earlier studies of AI. Can you guess what we've found?},
  note = {booktitle inferred},
}

@inproceedings{macdonald1995gender,
  title = {Gender Differences In Consistency of Alcohol Consumption Measures},
  author = {MacDonald, Alan and Stewart, Sherry and Samoluk, Sarah and Sweet, Susan},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {Kidorf et al. (1990) found that the self-reports of males were highly predictive of their analogue alcohol consumption, whereas the self-reports of females bore no relation to their analogue consumption. The present study examined the effects of social context on the consistency between self-report and analogue alcohol consumption in males vs females. Male and female university students, assigned to either a social or alone drinking context, provided self-reports of alcohol consumption, and then participated in an analogue drinking test disguised as a beverage taste-rating task. Alcohol consumption dependent measures were analyzed as a function of context and gender. Preliminary correlations show that self-reports were more consistent with analogue drinking in both males and females in the social vs the alone context. Consistency between analogue drinking and self report was approximately equal for males and females in both contexts. Possible reasons for differences between these results and those reported by Kidorf et al. (1990) are discussed.},
  note = {booktitle inferred},
}

@inproceedings{frankland1995boundary,
  title = {Boundary Formation and Melodic Memory},
  author = {Frankland, B. W. and Cohen, A. J.},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {Most people can recognize a large repertoire of melodics. The present two-part study examines how their melodic information is stored. In particular, it focuses on the role of boundary formation. It first addresses the issue of determining where boundaries arise. Secondly, it examines how boundaries at different positions in a melodic excerpt affect memory. Following comparable work in psycholinguistics (Jarvella, 1970; Wingfield & Butterworth, 1984), it was hypothesized that excerpts not straddling a boundary would be more easily recognized than excerpts which straddle a boundary. In Part 1 of the Experiment, 20 subjects listened to a familiar melody and depressed a key each time they detected a boundary. Note-by-note boundary profiles generated for each subject were significantly intercorrelated (with the exception of one subject). Group profiles were highly consistent across three presentations of the song. In Part 2, subjects heard 16 four-note excerpts from the song (50% contained an error) and judged whether the exerpt belonged to the melody. Generally, excerpts which straddled the boundary led to poorer performance. Excerpts that did not contain boundaries and excerpts that ended with a boundary led to higher performance. Thus, the memory structure for melodies entails a systematic boundary formation process not unlike that found for language. While this proposal is not new for music, the current methodology permits its quantitative investigation by the use of boundary assessment and subsequent memory testing that is tailored to the individual subjects within the study.},
  note = {booktitle inferred},
}

@inproceedings{davidson1995statistical,
  title = {The Statistical Versus Clinical Significance of Medication, Psychotherapeutic and Cardiac-Rehabilitation Trials with Post-MI Patients},
  author = {Davidson, Karina and Gidron, Yori and Chaplin, Bill},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {This study compared the methodology and efficacy of Medication, Psychological and Mixed (cardiac-rehabilitation) trials with post-myocardial-infarction (Ml) patients, using meaningful effect sizes. Twenty-four randomly selected and representative trials (eight per each trial type) were compared regarding prevention of reinfarcts and mortality. Tests of statistical significance (X2) and clinical significance (number of prevented reinfarcts or deaths in treatment group per 100 people), and a comprehensive methodological assessment scale were employed. Medication trials obtained statistically significant effects at the highest level. However, Psychological trials prevented 10 times more reinfarcts (2.9) and three times more mortalities (1.7) per 100 people than did Medication tirals (.3, .5, repsectively). Medication trials obtained higher mean quality ratings (38) than Psychological (31) and Mixed trials (33). Thus, tests of statistical significance may be misleading when comparing clinical trials with different sample sizes. Psychological trials should increase their sample sizes and improve their methodology to reveal their stronger clinical significance with greater reliability and validity.},
  note = {booktitle inferred},
}

@inproceedings{hoffman1995caught,
  title = {Caught in the Web: Psychology on the Internet in 1995},
  author = {Hoffman, Ron},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {The past year has seen a tremendous amount of activity on the World Wide Web, currently one of the most popular segments of the Internet. Individuals, businesses, governments and institutions of all sorts are making information about themselves available electronically, taking advantage of the hypertext and graphic capabilities of web browser software. Today it is possible to tour the Louvre Museum, book a hotel room in San Francisco (and view the room, of course), or order fresh Nova Scotia lobsters delivered anywhere in North America, all from your computer workstation. Tomorrow even more will be possible. We should be taking advantage of this medium, and in this presentation, I will demonstrate a Web site (Home Page) for the Dalhousie Psychology Departtnent. tv~vJ Nlcc;.(U_,t;},
  note = {booktitle inferred},
}

@inproceedings{losier1995justificatio,
  title = {The Justification For Depression Scales: A Bibliometric Analysis},
  author = {Losier, Bruno J. and Bilsbury, C.D. and Richman, A.},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {Depression is a topic of increasing importance in both research and therapy. Its measurement has for three decades dependent largely on two rating scales, the Hamilton and the Beck. These warhorses vie for acceptance as the gold standard. Is there justification for their preeminence? This bibliometric analysis begins to answer this question. What are the time trends in citations? Are the Hamilton and Beck co-cited? Is the selection of one justified over the other? When both scales are used, are the results compared? We have used PSYCLIT and Science Citation Index to count citations to each of these scales during each year over the past two decades. We examined representative samples of 20 publications from 1974 to 1979 and 20 more from 1989 to 1994. Neck and neck over the years, the number of citations for each scale steadily increased. However, there was little growth in the concurrent use of both scales, and of these publications less than a quarter provided analyses of their differential outcomes. Reading the source publications showed little if any discussion of the rationale underlying the selection of these scales and little if any qualification of the overall results of the investigation as being- specific. Thompson's (1989) content analysis of depression scales by domains shows major differences between the Beck and the Hamilton. These differences are obscured in the articles reviewed. Each paper regards the scale they used as the gold standard without justifying its selection. We recommend that the particular symptoms that brought the patient to therapy should be considered in assessing clinical change. Clinimetric advances (Feinstein, 1987) have recognized that the measurement of change must be 6ased on the clinical phenomena presented by the individual patient, rather than utter dependence on alterations in scores from psychometrically derived constructs.},
  note = {booktitle inferred},
}

@inproceedings{losier1995attentional,
  title = {Attentional Biases In Peripersonal And Extrapersonal Space: An Analysis Of Line Bisection And Visual Orientation Performances In A Group Of Young Adults},
  author = {Losier, Bruno J.},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {In recent decades, attentional biases along three-dimensional spatial coordinates have been a topic of increased interest. However, physical boundaries, as well as methodological restraints have precluded a thorough and systematic investigations of human performances along these planes. The currentstudy proposed to address some of these limitations by investigating line bisection and visual orientation performances along horizontal and vertical planes in peripersonal (within hand's reach) and extrapersonal (outside of hand's reach) space. Subjects bisected a total of 72 computer-generated horizontal and vertical lines projected in each spatial location. Furthermore, on any given trial, horizontal lines appeared at the top, centre or bottom of the screen, while vertical lines appeared at the left, centre or right of the screen. As well, a bisecting cursor appeared at either end of each line. In the visual orientation task, subjects reponded to 229 validly or invalidly cued targets in each spatial location. On any given trial, targets appeared at the top left, top right, bottom left or bottom right of the screen. Overall, horizontal and vertical lines were bisected to the left and above the midpoint, respectively. Moreover, analyses of variance revealed that bisecting biases varied significantly in peripersonal and extrapersonal space contingent upon bisector and line position on the screen. Overall, subjects responded more quickly to validly than invalidly cued targets. Analyses of variance revealed that response time also varied significantly and differently along horizontal and vertical planes in peripersonal and extrapersonal space. These findings are discussed in light of current models of visual attention. ~},
  note = {booktitle inferred},
}

