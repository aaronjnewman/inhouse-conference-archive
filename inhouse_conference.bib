  booktitle = {Fourth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1978},
  abstract = {The episodic memory trace was studied by having subjects attempt to access the memory trace according to different types of retrieval codes. The results indicated that the first letter of the name of a word may function as a retrieval code only if it is inten- tionally marked as such, whereas the categoric meaning of a word is marked for retrieval purposes automatically. In addition, it was found that the names of words are not linked directly to one another in the lexical dictionary, but the meaning of words have direct connections. These results have implications for theories of encoding specificity, the organization of the mental lexicon, and a speech- production hypothesis of initial-letter cueing effects.},
