@inproceedings{watt1995sex,
  title = {Sex Differences: It's Not the Size, It's the Shape},
  author = {Watt, Margo and McGlone, Jeannette},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {As long ago as 1880, English surgeon James Crichton-Brown reported slight differences in the brain anatomy of men and women - a few more neurons here in one sex, a few more there in the other. But by far one of the most frequent findings through the years has been that th~us the main fiber tract connecting the callOSE!Jl...: two cerebral hemispheres - tends 1o larger in women than in men. It has also been found to vary in shape between the sexes. Researchers, such as deLacoste-Utamsing and Holloway (1982), have speculated that if a larger corpus callosum implies a larger number of fibers interconnecting cortical areas and the number of interhemispheric fibers correlates inversely with lateralization of function, then this finding would be consistent with neuropsychological theories that men's brains are more lateralized for function than women's. We review the last ten years of anatomical and radiological studies of sex differences in inter-hemispheric fibers pointing out inconsistencies in the methodologies employed. We conclude that certain segments of the corpus callosum linked to posterior association areas are greater in women. Whether these relate to functional asymmetries remains to be seen. Stay tuned!},
  note = {booktitle inferred},
}

@inproceedings{scott1995histamine,
  title = {Histamine Activates / Inhibits / Modulates / Has No Effect / Does Whatever I Want It To* In the SCN (*Delete As Appropriate)},
  author = {Scott, George and Rusak, Benjamin},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {These studies investigated the effects of histamine on spontaneous and NMDA-evoked activity in the hamster SCN in vitro. Application of histamine either activated (n=l3/27), attenuated (n=6/27) or had no effect (n=8/27) on spontaneous firing in SCN cells. Attenuation of spontaneous firing rate by histamine was evident at higher ejection currents than those which elicited activations. Application of NMDA increased the firing rates of single SCN cells in a current-dependent manner. Co-application of histamine, at ejection currents which elicited no direct response to histamine itself, potentiated NMDA-evoked activity by up to 40% (61 % of cells tested). These results suggest that, in addition to having direct effects on spontaneous neuronal activity in the SCN, histamine may modulate the activity of NMDA receptors at glutamatergic synapses in the hamster SCN. And a bunch of other stuff. (-j ~-fu:~v- ~c--:ttl-.... -;'},
  note = {booktitle inferred},
}

@inproceedings{schellinck1995key,
  title = {The Key Is In The Pee},
  author = {Schellinck, Heather and Brown, Richard},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {Individual animals can be identified by their urine odours. To determine the influence of genetic, microbiological and dietary factors in producing urinary odours of individuality in rodents, a series of experiments were undertaken using two different paradigms. Results from a habituation-dishabituation task and a go/no go operant task revealed that rats and mice with genetic differences at the major histocompatibility complex have urine odours which can be discriminated by conspecifics. Bacteria are necessary for the production of these urine odours and the removal of different types of bacteria by drug treatments changes the nature of the urine odour, however, the specific nature of the odour-producing bacteria could not be determined. Mice and rats on different diets produce urine odours which are easier to discriminate than urine odours from mice of different MHC genotypes. These results indicate that odours of individuality are multidimensional and that when dietary cues are available, they may be more influential than genetic factors in providing discriminable cues.},
  note = {booktitle inferred},
}

