@inproceedings{forestell2001usinga,
  title = {Using Taste Reactivity to Measure Shifts in the Palatability of Conditioned Taste Cues},
  author = {Forestell, Catherine A. and LoLordo, Vincent M.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Tastes become more preferred after they have been paired with sugar reinforcement in a classical conditioning paradigm. The mechanism involved in the formation of conditioned taste preferences is not clear. It is possible that conditioned preferences occur because animals learn to expect calories upon consumption of the taste cue. Alternatively, the conditioning procedure may produce an increase in the palatability of the taste cue. Typically the taste reactivity test is used to assess the palatability of tastes. This test involves measuring a rat's hedonic and aversive affective responses to oral infusions of taste solutions. In this talk I will describe some of the taste reactivity experiments currently being conducted in our laboratory to assess palatability shifts in conditioned taste cues.},
}

@inproceedings{schellinck2001challenges,
  title = {Challenges of running research in a large laboratory class: An animal experiment where the researchers outnumber the animals by 30 to 1},
  author = {Schellinck, Heather},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {As part of the continuing evolution of the introductory psychology class (P 1001) into a laboratory class, this past year an animal research project was incorporated into the curriculum. Eighteen mice were assigned to either of two groups. Mice in the experimental group received caffeine in their drinking water. The mice were then observed in an open field apparatus, and experimenters recorded several behaviours. With over 600 potential experimenters, the logistics were challenging. In this talk, we describe how live observations were combined with additional observations recorded on digital video and presented over the internet. The preparations were not trivial, but the outcome was a success in several ways.},
}

@inproceedings{fisk2001construction,
  title = {Construction and Initial Validation of a Daily Version of the Fatigue Impact Scale (D-FIS)},
  author = {Fisk, John and Doble, Susan},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Introduction: The Fatigue Impact Scale (FIS) has been developed as a symptom-specific profile measure of health-related quality of life (HRQoL). Its item content reflects subjects' attribution of problems to fatigue in the areas of physicaCcognftive, and psychosocial functioning. The FIS was initially developed for cross-sectional studies of medical conditions in which fatigue is a chronic symptom. Thus, it had not been designed to be a responsive measure of daily changes in fatigue. The present study describes the development and initial validation study of an adaptation of the FIS for use in conditions in which fatigue symptoms are of acute onset or have significant daily variation. Methods: Items for the Daily F_MigueImpact Scale (D-FIS) were selected from the pool of original FIS items with the aid of Rasclianalyses of existing data. The reduced, 18-item FIS was administered to a sample of 93 subjects with flu-like illness, some of whom were followed for a 21-day period. Rasch analyses were used to further reduce the scale to a minimum number of items that represented a unidimensional measure of self-reported fatigue impact. Results: The resulting 8-item D-FIS demonstrated good relations to ratings of other flu symptoms and to general ratings of HRQoL. It also proved to be a responsive measure, demonstrating significant reduction in fatigue impact for those subjects that were followed longitudinally. Moreover, subjective ratings of fatigue impact were associated with work hours lost and estimated work productivity for those subjects who did work for pay during the study period. Conclusions: This initial validation study indicates that the D-FIS has considerable promise as a measure of the subjective daily experience of fatigue and as a specific HRQoL outcome measure.},
}

@inproceedings{fisk2001concordance,
  title = {The Concordance Between Health-Related Quality of Life Utility Measures and Neurologic Disability Ratings in Multiple Sclerosis},
  author = {Fisk, John and Brown, Murray and Metz, Luanne and Murray, T.J.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Introduction: Clinical trials of disease-modifying agents for MS have focused on neurologic disability, relapse rates, and MRI measures of central nervous system lesions. While the results have been promising, study limitations, coupled with the high costs of treatments and the limited evaluations of their cost-effectiveness, have lead to controversies about their use. The goal of this study was to evaluate the relation between clinical ratings of neurologic disability and generic Health- Related Quality of Life (HRQoL) utility measures in MS patients. Methods: A total of 195 patients with MS (47 males, 148 females), representing the full range of neurologic disability (i.e. no neurologic signs to bedridden) were recruited in a stratified (neurologic disability) and randomized manner from two regional MS clinics. All subjects received a standardized clinical assessment and completed the EuroQol (EQ5D) and the Health Utility Index (HUI) Mark II and Mark III. Results: The EQSD and both versions of the HUI all demonstrated correlations > .60 with the clinical ratings of neurologic disability. Analyses of variance demonstrated that the HUI Mark II and, to a greater extent the HUI Mark III, were able to distinguish between clinically distinct subgroups of patients. A surprising finding was the marked differences in the extent and rate of decline of the various HRQoL utility measures across the full range of increasing neurologic disability. Conclusions: HR.QoL utility measures can be appropriate outcome measures in clinical trials for MS. Differences in item content and in the valuation methods are evident in how the subjective health states of a specific disease population are represented by HR.QoL utilities. The selection of a HR.QoL utility measure can have a profound effect on the cost- utility ratios in pharmacoeconomic analyses of MS treatments.},
}

@inproceedings{rusak2001patterns,
  title = {Patterns of Orexin Immunoreactivity in the Brains of Alzheimer's Disease Patients},
  author = {Rusak and B and Darvesh and S and Hopkins and D and Goguen and D and Fice and D and Kale and K and Reid and A and Groot, de},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Qrexins (hypocretins) are a class of peptides originating in cells of the hypothalamus that are attracting grearTnterest. Orexins appear to play a critical role in regulating arousal; for example, loss of either orexins or their receptors have been implicated as a cause of narcolepsy in animals and humans. In addition, orexins have an important impact on food intake in animal models. Patients with Alzheimer's Disease (AD) often show clinical symptoms related to dysregulation of both sleep and body weight. While neuronal cell loss occurs in many brain regions in AD patients, the regions responsible for dysregulation of feeding and sleep are not known. We have conducted immunocytochemical studies of selected regions of the brains of AD patients and age-matched controls to evaluate the number of orexin- immunoreactive neurons and the extent and pattern of orexin fibre staining. Preliminary results will be presented.},
}

@inproceedings{boudreau2001mousing,
  title = {Mousing around with sensory preconditioning},
  author = {Boudreau, Sarah E. and LoLordo, Vincent M.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The ability of mice to acquire a stimulus-stimulus association was tested with odor stimuli in a sensory preconditioning paradigm, as a means of measuring their abilities to integrate separately learned associations. Two distinct odor stimuli, rose and lemon, were presented in buried odor pots. On the first day of training mice in the paired group received paired presentations of odor 1 (01; lemon) and odor 2 (02; rose). Mice in the unpaired group received randomized odor presentations 15 minutes apart. On the following day, both groups received paired presentations of 02 and a sugar reward. On the third day, both groups of mice received one trial of 02 and sugar followed immediately by trials of 01 alone. If separate associations were learned and integrated, then those in the paired group should spend more time digging in 01 on the final day then mice in the unpaired group. Results to be discussed.},
}

@inproceedings{brown2001plasmid,
  title = {Plasmid protection rackets},
  author = {Brown, Will and Doolittle, Ford},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Bacterial plasmids are self-replicating elements that exist within a cell but are not part of the chromosome proper. When plasmids are mobile they can laterally transmit between phylogenetically distant lineages (e.g. E. coli and S. enterica) and confer advantages to the host organism. For example antibiotic resistance is probably a case of adaptive host evolution due to lateral transfer. However, why do plasmids transmit themselves laterally? Are host benefits a sufficient explanation to explain the presence of plasmids? Benefits to the host could be an epiphenomenon of benefits to the plasmid. It is suggested that social evolution may favour multi-level 'conspiracies' between evolutionary units and this potentially leads to conflicts within a given level of selection (e.g. plasmid 'protection rackets'). Despite the effectiveness of conspiratorial selection between evolutionary units, the threat of mutinous counter-adaptations may exist in all social systems (e.g. meiotic drive, maternal-effect selfish genes or postsegrational killing in plasmids). It seems that, in contrary to intuitive 'folk wisdom,' the brain is not necessary for social evolutionary processes to operate.},
}

@inproceedings{darcy2001influences,
  title = {The influences of increased working memory load on semantic neural systems.},
  author = {D'Arcy and R.C.N and Connolly and J.F and Service and E and Hawco and C and Houlihan},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The effects of WM on the semantic N400 response were studied using high-resolution ERPs. Subjects studied visual sentence primes (The man is teaching in the classroom), anticipated the superordinate terminal word (school), and then evaluated the semantic appropriateness of the visual target sentence (The man is in the ...school/barn). Level 1 WM load contained a single prime sentence and Level 2 contained two prime sentences. The inappropriate words elicited the N400, but the latency of this response was delayed significantly by ~50ms due to increased WM load. Subsequent brain mapping and source analysis techniques showed the effects of WM on N400 generators.},
}

@inproceedings{groot2001more,
  title = {More on Marleen's Misbehaving Mice: Maximizing the Mating of Monogamous Mutants},
  author = {Groot, Marleen H. M. de and Rusak, Benjamin},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {California mice (Peromyscus califomicus) are studied by Richard Brown's lab because of their unusual pattern of bi-parental care of the young. We became interested in these mice because, unlike other species we have studied, they show high levels of activity in their home cages in anticipation of the onset of the daily light phase. Although the circadian systems of two species of Peromyscus mice have previously been studied (P. leucopus and P. maniculatus; Daan & Pittendrigh, 1976), circadian rhythms of California mice have not been described in the literature. Eighteen adult male California mice were housed in individual cages inside isolation boxes that allow for manipulation of each animal's light exposure. Activity rhythms were recorded under a variety of lighting conditions. Although most of these mice behaved similarly to other Peromyscus species studied previously, a few animals showed extremely unusual patterns. Efforts to further characterize these anomalous patterns, and to selectively breed for unusual circadian characteristics will be discussed.},
}

@inproceedings{wang2001effects,
  title = {The effects of the segmental and suprasegmental processes of spoken Chinese Mandarin on the auditory ERPs},
  author = {Wang, Jingtian and Connolly, John F.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {In this study, event-related brain potentials (ERPs) were used to investigate spoken Chinese Mandarin processes. Chinese four-character proverbs were presented auditorally to 15 native Mandarin speakers for listening comprehension. Five conditions used proverbs that ended with: 1) the accurate fourth character of the proverb; 2) a character with the same final vowel and tone as the correct proverb- terminal character, but different initial consonant and meaning; 3) a character with the same initial consonant and tone as the correct proverb-terminal character, but different final vowel and meaning; 4) a character with the same segments as the correct proverb-terminal character, but different tone and meaning; and, 5) a character with a totally different segments, tone and meaning from the correct ending character. The N400 was seen in the last four conditions with the largest N400 in the fifth condition while the smallest was seen in the fourth condition. Only a late positive component was found in the first condition. It was concluded that tone processing does play a role although not that much as segments in processing spoken Chinese. Before N400, there was another negativity whose peak varied across last four conditions, which suggested that within highly constrained proverb contexts, tone was processed earlier than vowel. In addition, the ERP scalp distribution varied not only across different conditions but also different time periods. These data suggest that an auditory code relies upon discrete processing stages with different neural mechanisms underlying consonant, vowel and tone processing. The findings are integrated into current theories of spoken word recognition.},
}

@inproceedings{devoulyte2001relation,
  title = {Relation between catastrophizing, depression, and the intensity of cold and influenza symptoms},
  author = {Devoulyte and K and Laskis and S and Sullivan, M},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The current study examined the role of catastrophizing and depression in predicting the intensity of cold and influenza symptoms. Participantsincluded 49 adults (35 females, 14 males) who agreed to complete a diary ofsymptoms for 7 days after the onset of a cold or the flu. Participant swere classified as catastrophizers or noncatastrophizers based on their scores on the Pain Catastrophizing Scale (PSC). Results showed that catastrophizers reported significantly more symptoms, and significantly more severe symptoms than noncatastrophizers. The relation between catastrophizing and symptom severity remained significant even when controlling for initial symptom severity, duration of onset of symptoms, and depression. Catastrophizers also reported using more medication than noncatastrophizers. Catastrophizers did not differ from noncatastrophizers on an objective measure of fever, nor did they differ in the amount of school/work time lost due to symptoms. The theoretical and practical implications of these results are discussed.},
}

@inproceedings{garon2001development,
  title = {The Development of the Objective Self},
  author = {Garon, Nancy and Moore, Chris},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The present study explored the development of the objective self. This refers to the child's ability to perceive the self from a third person perspective. Other measures of this ability such as the mirror recognition task have been related to important developmental changes. It was hypothesised that this ability develops in stages consistent with the development of other cognitive abilities. Two tasks, thought to measure this ability, were created for this study. The first task assessed children's ability to reason about their mass while the second task assessed children's ability to reason about their size. Children in different age groups showed significant differences in performance on both tasks. The results of this study suggest that a child's ability to represent the objective self changes considerably over the preschool period.},
}

@inproceedings{gingras2001procedures,
  title = {Procedures for testing the sensory abilities of inbred, transgenic and mutant mice: a review of the literature},
  author = {Gingras, Gll~ and Brown, Richard E.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {With the increasing number of strains of inbred, transgenic and mutant mice available, it is common to use these mice in studies of cognitive functions. However, many strains of mice have sensory deficits and it is important to test for sensory function before using these mice in tests of cognitive function. A number of review papers have been written on the behavioral phenotypes of mutant mice, but unfortunately, little information is available on the sensory capacities of these mice. Moreover, online databases on mutant mice are rather broad and contain little information on behavioral abnormalities. Because behavioral tests are dependent on sensory abilities, basic information on sensory abnormalities in mutant mice is important for research in the neural and the behavioral biology of the mouse. The goal of this presentation is to describe the methods used in testing the sensory functions (vision, hearing, taste, smell, touch, and pain) of normal and mutant mice. To our knowledge, this is the first attempt to create a comprehensive review of the sensory abilities of mice.},
}

@inproceedings{rasmusson2001ach,
  title = {ACh is AChing for Attention},
  author = {Rasmusson, Doug and Semba, Kazue},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Acetylcholine (ACh) is important because its release in the cortex is high during EEG "activation", it enhances sensory input and its neurons are lost in Alzheimer's disease. However, we don't understand if this cholinergic system functions by activating the entire cortex in preparation for significant inputs or if separate cortical regions can be activated independently. This is partially an anatomical question (do individual neurons branch to many regions or do different cholinergic neurons go only to each region?) that will be examined using tract-tracing techniques . It will also be examined functionally by measuring ACh release from two cortical areas under different sensory conditions-can ACh be released selectively from one region and not from another? or does it increase everywhere regardless of the input? This will be studied in anesthetized animals using visual and auditory stimuli and then in awake behaving animals trained to carry out difficult visual or auditory discriminations.},
}

@inproceedings{semba2001how,
  title = {How does the circadian clock tell the rest of the brain it's time to wake up?},
  author = {Semba, Kazue and Deurveilher, Samuel and Burns, Joan},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Daily cycles of sleep and waking characterize the lives of various species. In mammals, the master clock for these circadian rhythms is located in the suprachiasmatic nucleus (SCN), whereas the neuronal system controlling sleep and wakefulness is distributed throughout the brain. To understand how these two systems are linked, we previously electrophysiologically characterized direct projections from the SCN to the ventrolateral preoptic area (VLPO), a major site of sleep-active neurons (Sun, Whitefield, Rusak and Semba, submitted). However, the most of the SCN output is thought to reach its targets indirectly. In the present study, therefore, we are using a cocktail of anatomical tracers to identify multisynaptic SCN pathways. The potential relay nuclei so far identified include the medial preoptic area, dorsal hypothalamic area, and dorso- and ventromedial hypothalamic nuclei. These nuclei could relay SCN output to the VLPO, and to known wake-active cell populations, including neurons containing hypocretins/orexins, histamine, dopamine, acetylcholine, serotonin and noradrenaline in the forebrain and brainstem.},
}

@inproceedings{carr2001nonpredictiv,
  title = {Nonpredictive Gaze and 14-Month-Old Infants: Saccadic Responses to Static and Animated Cues Varying in Validity and SOA},
  author = {Carr, Amy},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Reflexive orienting to nonpredictive gaze cues has been demonstrated in adults, young children, and infants (Friesen & Kingstone, 1998; Hood, Willen, & Driver, 1998; Ristic, Friesen, & Kingstone, in preparation). In the present study, as in the Ristic et al study, a schematic happy face was used to present nonpredictive central gaze cues. Infants' saccadic responses to subsequent peripheral targets were examined. Out of 37 infants tested, 25 (mean age: 14 months; 9 days) met the inclusion criteria of 8 usable trials. The design was mixed, with cue type (static or animated) as a between-subjects variable, and cue validity (valid or invalid), target location (left or right), and stimulus onset asynchrony (200 ms, or 1000 ms) as within-subjects variables. At the present stage of analysis, none of the anticipated effects are significant. A follow-up study will use more interesting and age-appropriate stimuli to examine the effects of nonpredictive gaze cues.},
}

@inproceedings{stewart2001effects,
  title = {Effects of the Swiss Air Flight 111 disaster on community-level alcohol consumption: Post-traumatic drinking?},
  author = {Stewart, Sherry H. and Team, the Learning from Experience Research},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {BACKGROUND: The previous literature is controversial whether communities respond to disaster with increased or decreased alcohol consumption. Inconsistencies may stem from the different time periods following disaster over which communities are tracked. For example, decreased drinking may occur during the initial response to disaster, when communities are mobilizing their resources to deal with the trauma. Increased "post-traumatic drinking" may still occur during later stages of a community's response to disaster, as some members attempt to cope with symptoms of post-traumatic stress. By examining liquor sales over a wider time span, this study may help bring resolution to prior inconsistencies. OBJECTIVE: To determine whether there are changes in alcohol sales in coastal communities affected by the 1998 airline disaster in Peggy's Cove, Nova Scotia. DESIGN: Liquor sales records are being examined in communities affected by the disaster and control communities for the months and years prior to, during, and after the disaster. SETTING AND SUBJECTS: Liquor stores serving coastal communities affected by the disaster are being compared with liquor stores serving matched control communities. RESULTS: Analyses will be performed both within affected communities over time, and between affected and control communities. We examine whether alcohol sales increased or decreased in the period immediately following the disaster, whether there is sustained increased sales over time, or a delayed increase in alcohol sales well after the disaster. IMPLICATIONS: The results could help identify whether alcohol abuse prevention needs to be provided for communities affected by large-scale disaster.},
}

@inproceedings{anon2001what,
  title = {What does the human genome project mean for Psychology?},
  author = {----------, Richard E. Brown},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The human genome was published in Science and Nature in February 2001. The mouse genome, Drosophila genome, C. Elegans genome and others have also been published. It is predicted that everything we know in pharmacology, medicine and human biology will have to be revised in light of genetic knowledge. How will these breakthroughs in genetics impact on psychology? Will everything in psychology have to change to reflect genetic knowledge? Do psychology students understand the language and concepts of genetics? What new theories and techniques will be required for animal research? Will genetics manipulations, gene chip technology and gene insertion by adenoviral vectors become standard tools in the study of brain and behaviour? Can we keep up with the demand for neurobiological and behavioural studies on transgenic and mutant mice? What will we have to learn about genetics to facilitate human experimental and clinical research? Finally, how can psychologists use bioinformatics and neuroinformatics, the handling and use of large genetics databases, in their research? This talk examines some of the emerging knowledge in genetics that psychologists will need to integrate into their teaching and research in order to benefit from the genetics revolution.},
}

@inproceedings{marchant2001sillier,
  title = {Sillier Cilia: The Hairy Walls of the Mouse Third Ventricle},
  author = {Marchant, Elliott and Devarajan, K. and Rusak, B.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {In the course of anatomical research aimed at confirming the results of microarray gene expression studies, we re-discovered the generally ignored fact that portions of the third ventricle in the hypothalamus are lined with cilia. We also made the novel observation that these cilia contain two proteins: the calcium-regulating protein parvalbumin, and the neurohormone oxytocin. Levels of both parvalbumin and oxytocin in the cilia were regulated both by time of day and by whether or not the mice had been exposed to light an hour earlier. The rapid responses of these proteins to light exposure suggest a dynamic regulation that may influence the secretion of oxytocin into the cerebrospinal fluid (CSF). Oxytocin has been implicated in various affiliative behaviours and in the regulation of excitatory neurotransmission in the brain. Our observations suggest novel mechanisms for rapid regulation of global brain function via hypothalamic modulation of hormonal secretion into the CSF. I I -I I},
}

@inproceedings{clarke2001human,
  title = {Human Patient Simulator: A proposed feasibility study},
  author = {Clarke, James and Ruyak, Peggy},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The Human Patient Simulator (HPS) is a highly sophisticated computer based mannequin used to train a wide range of medical professionals. The HPS is extremely diverse and can provide training in acute crisis resource management, basic and advanced medical interventions and management, basic pharmacology, and equipment usage. This unique training tool has been used extensively in the training of medical personnel but it has been virtually ignored for research purposes. One of the difficulties that arise in the use of the HPS for research is the lack of standardized scenarios. The proposed study evaluating the performance of sleep deprived paramedics would allow us to evaluate the capabilities of the simulator, develop standardized scenarios, and establish a research program using the HPS as a research tool.},
}

@inproceedings{theakston2001what,
  title = {What matters in personal survival: Philosophical questions and empirical answers.},
  author = {Theakston, Jennifer and Barresi, John},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {What do people care about in personal survival? If they have to change and become different from what they are now, what do they think is most important to maintain about themselves through change? Some philosophers have suggested that what is important to maintain in survival is one's identity. But what does identity mean for a person? Others say that what matters in survival is that one can identify with the person that continues even if the person that one is now no longer exists. But who decides when a 'continuer' is no longer one's self? Rather than answer these philosophical questions the present investigation looks into which aspects of self matter to people in survival: what they care most about preserving in change, even in circumstances in which death is one the alternatives.},
}

@inproceedings{woodworth2001homicide,
  title = {Homicide Perpetration as a Function of Psychopathy: The Instrumental-Reactive Continuum Explored.},
  author = {Woodworth, Mike and Porter, Stephen},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {The purpose of the present study was to examine the characteristics of a large sample of Canadian homicides as a function of psychopathy. Although previous studies have investigated the relationship between psychopathy and criminal behaviour, little is known about the relationship between psychopathy and homicide. One hundred and twenty-five (N = 125) Canadian offenders who had perpetrated a criminal homicide were investigated for several characteristics regarding the nature of, and possible motivations behind, their offence. Results indicated that homicides committed by psychopathic offenders (as measured by the Psychopathy Checklist-Revised; Hare, 1991) were significantly more instrumental (planned, goal-oriented) relative to non-psychopathic offenders who committed more spontaneous "crimes of passion." In addition, psychopathic offenders were found to commit more gratuitous, sadistic, and sexual violence in the content of their homicides than non-psychopathic offenders. This research strongly contributes to the scientific understanding of homicidal violence as a function of psychopathy, and could have important implications for homicide investigations.},
}

@inproceedings{peace2001investigatio,
  title = {Investigation of the Consistency of Traumatic Memories over Time as a Function of Interview Style},
  author = {Peace, Kristine A. and Porter, Stephen},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {In the legal system, it is often important to evaluate the credibility of memories for distant emotional experiences. The purpose of the proposed study will be to examine prospectively the characteristics and consistency of both traumatic and positive emotional memories as a function of interview style. Although previous studies have investigated the qualitative aspects of emotional memories, little is known about the consistency of traumatic memories over extended periods of time. The goals of the current study are to contribute to the understanding of characteristics of traumatic memory, as well as examine the extent to which these memories are consistent over time. It is expected that this research will reveal important findings to further our understanding of how traumatic experiences are remembered, in addition to potential enhancing or biasing influences of various interview techniques.},
}

@inproceedings{mccabe2001who,
  title = {Who Can Catch a Liar? An Investigation of the Effect of Motivation and Feedback on Deception Detection},
  author = {McCabe, Sean and Porter, Stephen and Birt, Angela R. and Woodworth, Mike},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Previous research indicates that most people are not overly proficient at detecting deception, typically performing around the level of chance. However, a recent study suggested that the provision of immediate and accurate feedback may gradually facilitate the accuracy at detecting deceptive reports (Porter, Woodworth, & Birt, 2000). This apparent improvement in accuracy from the feedback could be related to either: (1) an increase in the social pressure from the feedback to elevate the participants' motivation to make accurate judgments, or (2) the feedback may have allowed the participants to gradually adopt more successful decision-making strategies. The present experiment was designed to examine the validity of these competing theories. Participants (N = 151) were randomly assigned to two experimental conditions according to motivation (High versus Low) and feedback (Accurate, Inaccurate, or No Feedback). They were shown a series of twelve videotaped speakers providing either a true or deceptive report. Contrary to the major hypothesis, results indicated that the highly motivated participants (those who anticipated a reward for performing well) performed significantly less accurately than low motivated participants (who were not motivated by or aware of any possible reward). A significant effect for any feedback (no difference for accurate versus inaccurate) was found for the accuracy for the honest videos and a significant interaction between motivation and feedback was seen in the accuracy for deceptive targets. Although results indicated a general motivational impairment effect for the detection of deception, any type of feedback appears to counteract this impairment effect and facilitate judgements on liars.},
}

@inproceedings{angelopoulos2001left,
  title = {Are Left Handers Better Lie Catchers? An Investigation of Individual Differences and Accuracy in Deception Detection},
  author = {Angelopoulos, Paul and Birt, Angela R. and Porter, Stephen and Campbell, Mary Ann},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {In a recent study (Porter, Stapleton, Campbell, & Birt, 2001), it was found that left-handed individuals were able to detect deception at a higher level than right-handed individuals. The present study was intended to replicate this result and explore possible reasons for the difference. Participants (N = 110) viewed twelve videotaped targets (six liars, six truth-tellers). They were asked to judge the honesty of the video targets. The videos were presented in one of three modalities: audio only, visual only and audiovisual. Participants were asked to complete a number of questionnaires to explore possible information processing styles associated with accuracy in detecting deception. It was hypothesized that left-handed participants rely more on nonverbal information such as facial cues when making credibility judgements, and therefore, would have higher accuracy levels in the visual only and audiovisual conditions than right-handed participants. Overall, left-handers were 14.17% more accurate in judging deception than were right handers. As hypothesized, left handers displayed this superiority effect in both the visual and audiovisual conditions. No significant differences in accuracy scores between left and right handers were found in the audio only condition. Analysis of self-reported cues upon which detection judgements were based revealed a trend for left handers to rely primarily upon cues of a visual nature. The findings are discussed in relation to possible differences in information processing tendencies/styles between left and right handed individuals.},
}

@inproceedings{spencer2001bleeding,
  title = {"Bleeding Men and Parrot Ladies": Effect of emotionality of a scene on susceptibility to false memories},
  author = {Spencer, Lesley and Porter, Stephen and Birt, Angela R.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Although some level of distortion is commonly present in eyewitness memory, the relation between the emotionality of a witnessed scene and susceptibility to false memories is less clear. In the present investigation, participants (N = 90) were randomly assigned to one of six conditions in a 2 (misled versus non-misled) X 3 (positive, neutral, or negative emotional scene) between-subjects design. Participants were informed that the study was focusing on "emotional processing" and were not aware that their memory for the scene would be tested. After viewing a highly positive, neutral, or highly negative scene (e.g., graphic accident) from the International Affective Picture System (Lang & Ohman, 1988), half of all participants were exposed to a series of misleading questions, one of which included a dramatic false suggestion (e.g., a large animal in the scene that did not exist). Approximately one hour later, after a series of filler tasks, participants were given ten direct questions about the scene (five related to the misinformation provided earlier). Results indicated that the misleading questions had a substantial impairing effect (37% difference) on recall accuracy. Overall, emotional valence did not significantly influence susceptibility to memory distortion. However, it was related to false memories for the dramatic misinformation in misled participants. Specifically, misled participants in the negative emotion condition recalled seeing the dramatic misinformation significantly more often (80%) than participants in either the positive (40%) or neutral emotion (40%) conditions. Further reflecting the strong impact of misleading questions, no (0%) non-misled participants in any condition recalled seeing the dramatic misinformation. Possible implications for eyewitness memory are discussed.},
}

@inproceedings{campbell2001young,
  title = {Young Offender Recidivism: Development and Validation of a Comprehensive Risk Scheme (A Doctoral Dissertation Proposal)},
  author = {Campbell, Mary Ann and Porter, Stephen},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Psychopathy is over-represented in criminal offender populations, is associated with persistent and violent offending, and is considered an important component of adult risk assessment (Hare, 1998; Hemphill, Templeman, Wong & Hare, 1998; Salekin, Rogers, & Sewell, 1996; Serin, 1995). Although psychopathic traits have been identified in both children and adolescents (Forth, Hart & Hare, 1990; Frick, O'Brien, Wooton, & McBurnett, 1994), the relevance of psychopathy to young offender recidivism risk is less clear. The main objectives of the proposed research will be to: 1) determine the base rate of psychopathy in a large sample of young offenders; 2) retrospectively identify the psychosocial and criminal correlates of youth psychopathy in order to identify potential early markers in its development; 3) evaluate the contribution of an adolescent measure of psychopathy to the prediction of past and future criminal behaviour; 4) identify the criminal and psychosocial factors discriminating persistent offenders high in psychopathic traits from non-persistent psychopathic youths; and 5) develop a much needed comprehensive risk/need assessment instrument based on psychopathy and other factors contributing to the prediction of re-offending in young offenders. To meet these objectives, the psychosocial and criminal history data previously collected from 227 male and female young offenders (see Santor and Kusumakar, 1998) will be used. The PCL-YV (Forth, Kosson, & Hare, in press) will be scored from this information to measure psychopathy. Recidivism will be measured from the point of participation in the original study to the present (3-4-year follow-up). Half of the sample will be used to develop a risk/need measure, while the other half will be used in a cross-validation. Collectively, these results will contribute to the understanding of psychopathy in its earlier stages and provide a useful tool for the assessment of risk/need in young offenders.},
}

@inproceedings{shaw2001exchange,
  title = {Exchange of dye tracers across the blood-brain barrier systems around the fly's eye},
  author = {Shaw, Steve},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {To gauge the effectiveness of the barriers around the eye, quantitative estimates of dye exchange were made by microfluorometry, using sulforhodamine 101 (SR) or lucifer yellow (LY). Influx to the retina from the blood was calibrated by making a known injection into the retina, allowing influx and efflux to be measured on the same preparations. Efflux of SR averaged 2.8 µM eye-1 min-1 per mM driving concentration of the dye injected, while the paired influx rate was significantly lower, 0.20 µM eye-1 min-1 per mM dye injected, for an exchange ratio of 14: 1. Values for LY were higher but not significantly different, for a ratio of 8: 1. The efflux half-times for LY and SR also were not significantly different, 2.9-3.6 h, but were ~5 times slower than previous estimates. The molecular uptake rate for dye significantly exceeds that recently calculated for ATP usage during the maximum rate of neural signaling by the photoreceptors, 1000 bit s-1 (55 x 109 versus 7.5 x 109 molecules ceu-1 s-1 ), and might represent the flux rate of the corresponding transporter. Earlier estimates of dye loss from the retina also used phenol red (PR). Photographic evidence indicates that with optimum concentrations in the eye, clearance of PR was also slow, taking 8-17 h. To identify the dye exchange route, 20 µm fluorescent microspheres were injected into the retina, based on reports that larger microspheres remain mobile in the eye and eventually to leave it. Instead, they penetrated a distal zone of mechanical weakness which opened up around the cone cells, then closed again, trapping the microspheres. The barrier sites which rate-limit influx and efflux to and from the eye and account for the flux asymmetry remain to be identified, and could be different neuroanatomical structures.},
}

@inproceedings{loba2001manipulation,
  title = {Manipulations of the Features of Standard Video Lottery Terminal (VLT) Games: Lab-based and In-vivo Results},
  author = {Loba, Pamela and Stewart, Sherry H and Klein, Raymond M and Blackburn, James R},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {A set of and in-vivo studies were conducted to identify game parameters that would reduce the risk of abuse of video lottery terminals by pathological gamblers, while exerting minimal effects on the behavior of non-pathological gamblers. Three manipulations of standard VLT game features were explored. Participants were exposed to: a counter which displayed a running total of money spent; a VLT spinning reels game where participants could no longer "stop" the reels by touching the screen and sensory feature manipulations. In control conditions, participants were exposed to standard settings for either a spinning reels or a video poker game. For the lab-based study dependent variables were self-ratings of reactions to each set of parameters. A set of 2 x x (game manipulation [experimental condition vs. control condition] x game [spinning reels vs. video poker] x gambler status [pathological vs. non-pathological]) repeated measures ANOVA's were conducted on all dependent variables. The in-vivo study used behavioural ratings as the dependent measure. Finding for both studies suggest that the sensory manipulations produced the most robust reaction differences},
}

@inproceedings{owens2001quickest,
  title = {The quickest cancellation in the west},
  author = {Owens, Kyle C.},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Having the best tactic for successfully cancelling an action ensures the minimum of unwanted movements. Normal overt responses to environmental stimuli can unexpectedly require sudden cancellation. Strategies for movement cancellation include freezing all movement or making an alternate movement instead. It is not known which strategy is more effective at preventing an overt action. Participants can be instructed to cancel a response to a stimulus when presented with a 'stop-signal', or to replace the original response with an alternate action when presented with a 'change-signal'. Past research has investigated the effectiveness of inhibition mechanisms by plotting the likelihood of successful inhibition along points in time. This research has used stop-signals almost exclusively. Following a brief literature review, the present talk will outline a research proposal that is intended to provide a direct comparison of the effectiveness of inhibiting responses to stop-signals compared to change-signals. Preliminary data will be provided.},
}

@inproceedings{newman2001identifying,
  title = {Identifying Phonological Awareness Deficits with Event-Related Brain Potentials (ERPs)},
  author = {Newman, Randy Lynn and Connolly, John and Mclvor, Kimberly and MacDonald, Wayne and Arnold, Sarah},
  booktitle = {27th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2001},
  abstract = {Reading disabilities primarily arise from a deficit in phonological awareness, which is simply defined as the ability to identify, think about, or manipulate the individual sounds in words. The present research used event-related brain potentials (ERPs) to elucidate the neural correlates involved in phonological analysis, and how these differ in individuals with and without reading disabilities. Participants heard instructions, such as "Clap without the /cl sound", where the target word (Clap) was always monosyllabic and began with a consonant cluster. The instructions were followed by presentation of a correct item (lap) or one of three incorrect items: (1) wrong consonant deleted (cap), (2) consonant cluster deleted (ap); or an (3) irrelevant word (goose). Those with efficient phonological skills elicited a Phonological Mismatch Negativity (PMN), a component associated with phonological expectations, to incorrect items and a P300, a component associated with memory updating, to correct items. Individuals with the greatest deficits in phonological skills showed no differentiation between correct and incorrect items, with the exception of a PMN to irrelevant words. Those with moderate deficits displayed a PMN to both irrelevant words and to items with the wrong consonant deleted. Further, these individuals elicited a P300 to both correct items, and to items with the consonant cluster deleted. Results will be discussed in terms of the capacity that ERP techniques have for identifying reading disabilities, and for assisting reading recovery programs.},
}

@inproceedings{klages2002case,
  title = {A Case Study of the Effects of Neglect on Reading},
  author = {Klages, J. and Ingles, J. and Eskes, G.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {SS is a 66 year-old white male who had a right hemisphere infarct affecting the basal ganglia, posterior temporal and occipital lobes, associated with impaired left-sided sensory and motor function and left hemi-spatial neglect. Clinical neuropsychological screening with the Cognistat on admission to a Rehabilitation service showed no evidence of dementia and severe left-sided neglect on the Behavioural Inattention Test. Further testing of his neglect revealed evidence for neglect based on sensory/perceptual rather than motor mechanisms, and object-centered left-sided errors or omissions, suggesting a representational deficit. Neglect dyslexia was also seen in his reading errors and omissions on the left side of single words. Interestingly, his reading errors were significantly higher for regular words (13/30) and non-words (14/30), then for matched irregular words (2/30), suggesting different forms of lexical representations and/or processing as revealed by the differential effects of neglect. To our knowledge, this difference between regular and irregular words has not been previously reported in the literature and will be valuable in developing a fuller understanding of normal reading processes as well as lexical neglect.},
  note = {Poster},
}

@inproceedings{hawken2002jax,
  title = {The Jax Phenome Project: Anxiety, Locomotion and Spatial Memory in A/J, Balb/cByJ and Molf/ei mouse strains},
  author = {Hawken, Christianne and Luedemann, Krista and Brown, Richard},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {The purpose of this research was to create a comprehensive database of behavioral phenotypes for inbred mouse strains. We examined the behaviour of twenty-four A/J, Balb/cByJ and Molf/ei mice on measures of exploration, anxiety, learning and memory in a standardized test battery (Brown et al., 2000). Anxiety-related behaviors were measured using the elevated zero maze, elevated plus maze and light-dark box test. Exploration and locomotor ability were tested in the open field and Rota Rod. Spatial memory was examined using the Morris water maze and Barnes maze. There were significant differences among the three strains. The A/J strain was the most anxious in the elevated plus maze, elevated zero maze and the light/dark box. The Molf/ei had the greatest locomotor ability and explored to a greater extent in the open field than the other strains. In addition, the Molf/ei strain had the best spatial ability of the three strains in both the Barnes maze and Morris water maze. Pl 1.},
  note = {Poster},
}

@inproceedings{mmosher2002effect,
  title = {Effect of Methylphenidate Hydrochloride (Ritalin) Administration on Locomtor Activity, Emotional Behaviour and Spatial Learning in C3H/HeSnJ Mice},
  author = {M.Mosher, Tera and Brown, Richard E.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Attention Hyperactivity Disorder (ADHD) is a neuropsychological disorder prevalent in 3-5% of children. The three major characteristics of ADHD are hyperactivity, impulsivity and inattention. Currently, ADHD is treated through a variety of methods, including the use of psychostimulants. Ritalin is the treatment used by the majority of those diagnosed with ADHD because it decreases hyperactivity allowing subjects to concentrate more effectively. There are, however, few animal studies concerned with the effects of Ritalin on behaviour. In particular, it is important to ensure that drugs which alter hyperactivity do not impair cognitive function (e.g. Learning and Memory). The focus of the present study is to determine the effects of Ritalin vs. saline injections on locomotor activity, emotional behaviour and spatial learning in C3H/HeSnJ mice, which are not hyperactive. These mice were tested in the elevated plus maze, open field and Morris water maze. In the elevated plus maze the Ritalin-treated mice spent more time in the open arms than saline-treated mice. In the open field, mice treated with Ritalin were significantly more active than those treated with saline. In the Morris water maze there was no effect of Ritalin treatment on the latency to reach the platform. From these results we conclude that Ritalin increases locomotor activity, and decreases emotionality, but does not effect spatial learning and memory. Our next experiment will compare the effects of MPH on the hyperactive coloboma mouse with those of the control mice. We expect that MPH will reduce locomotor activity in these mice.},
  note = {Poster; QA: needs-split-review; Split from P10 at: 'Effect of Methylphenidate Hydrochloride'},
}

@inproceedings{theakston2002what,
  title = {What does your personality say about your reasons for drinking?},
  author = {Theakston, J. A. and Stewart, S. H. and Dawson, M. and Lehman, D. and Knowlden, S.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {The present study sought to replicate and extend research on the relationships between five-factor personality models and motivations for drinking alcohol. Undergraduate students (n = 571) completed the Drinking Motives Questionnaire-Revised (Cooper, 1994) and the 100-item International Personality Item Pool questionnaire (Goldberg, 1999) measuring the Big-Five personality domains. Multiple regression analyses revealed that personality domains predicted both external (Conformity and Social), and particularly, internal (Coping and Enhancement) drinking motives after accounting for demographics and alternate drinking motives. Replicating previous findings with the NEO personality scales, Coping motives were predicted by low Emotional Stability, and Enhancement motives were predicted by high Extraversion and low Conscientiousness. High Intellect/Openness and low Agreeableness also predicted Enhancement motives, and low Extraversion predicted Coping motives. High Emotional Stability predicted Conformity and high Agreeableness predicted Social motives. Low Intellect/Openness also predicted both external motives. Thus, converging evidence suggests the presence of personality risk factors associated with risky reasons for drinking.},
  note = {Poster},
}

@inproceedings{doucette2002investigatio,
  title = {An Investigation of the Ability of Individuals to Detect Deception in Criminal Offenders},
  author = {Doucette, Naomi},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Because nearly all studies examining the detection of deceit have focused on university student samples, the generalizability of the findings to forensic settings is questionable. Given the importance of detecting deception in forensic settings, the present study examined how well people were able to detect deception in a sample of incarcerated criminal offenders. Undergraduate students (N = 103) viewed a series of eight videotaped segments in which offenders related truthful or deceptive autobiographical events of a positive or negative valence. The results illustrated that, contrary to the main hypothesis, the participants were able to make accurate judgments about the veracity of the statements at a level that was significantly above chance (M = 66%) and higher than that seen in previous studies with non-offenders. In addition, it was found that participants were most accurate at judging positive deceptive statements (76%).},
  note = {Poster},
}

@inproceedings{williamson2002strain,
  title = {Strain differences in locomotion, anxiety and spatial learning and memory performance between C57BL/6J and 129S3 mice.},
  author = {Williamson, Martin},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {This study examined strain and sex differences in locomotion, anxiety and spatial learning and memory in male and female C57BL/6J and 129S 1 mice using a behavioral test battery. The elevated zero and elevated plus maze, light-dark box test and open field indicated that the C57BL/6J mice had higher levels of locomotor and exploratory behavior that the 129S1 mice, while the 129S1 mice demonstrated higher levels of anxiety than the C57BL/6J mice. The Barnes maze and Morris water maze were used as tests of spatial learning abilities. In the Morris water maze, there were no strain or sex differences in latency to or distances to reach the platform, however the C57BL/6J swam substantially faster than the 129S1 mice. During the probe trial, both C57BL/6J and 129S1 strains displayed more time spent in the correct quadrant, demonstrating that learning had occurred, though there was no strain or sex difference noted. Strain and sex differences in both neuromuscular function were shown as the C57BL/6J mice remained on the rotating rod significantly longer than did the 129S 1 mice, while the females performed better than the males. This study indicated that the 129S1 strain exhibit greater levels of anxiety than C57BL/6J however can perform equally well as the C57BL/6J mice under appropriate test conditions as shown in motor and spatial learning. Nonetheless, more general conclusions on the abilities of the 129S1 strain cannot be drawn, since variability between the 129 substrains exists and only one was tested here.},
  note = {Poster},
}

@inproceedings{hatchette2002pain,
  title = {Pain and pain management: Attitudes and practices of adolescents.},
  author = {Hatchette, Jill E. and MSc and McGrath, Patrick J. and PhD and Murray, Michael},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Objective: To describe adolescents' attitudes toward pain and pain management strategies, knowledge of over-the-counter analgesics (OTCs) as well as the social influences and gender differences apparent in pain management practices, attitudes and knowledge. Design: Focus groups. Setting: Junior high school and the meeting room of a local mall. Main Outcome Measures: Demographic data collected from participants via questionnaire prior to focus group discussions. Content analyses of transcripts to interpret statements within the context of categories formulated a priori from existing literature. Participants: Junior high school adolescents (grades 7, 8 and 9) participated in the sessions. Results: Adolescents' attitudes toward OTCs ranged from negative (e.g. unnatural, over-used, largely placebo) to positive (e.g. a preference to be pain free). Females indicated independence in self-administering OTCs - a gender difference not attributable to onset of menstruation -both male and female adolescents cited sports injuries as their most frequent pain-related complaint. With respect to knowledge adolescents expressed importance of reading the label, but also based dosing on irrelevant factors like perceived effect, size of pill and age estimation. Parental role in OTC use included approval seeking, availability & talk (particularly to mother). Peer role in OTC use included availability and talk. Gender differences were apparent in both parental and peer roles; parents encouraged males to use physical methods of pain relief & females to take OTCs. In discussing pain with peers males indicated more qualifiers; where females were likely to talk about their pain "all the time", males tended to minimize pain that resulted from their own mishaps. Conclusions: This study is the first of a series designed to understand adolescents' attitudes toward pain & pain management strategies. The findings yield additional research questions to be investigated in a second study addressing the emergence of attitudes within the family dynamic.},
  note = {Poster},
}

@inproceedings{inanlou2002contractile,
  title = {Contractile Activity Of Skeletal Musculature Involved in Breathing is Essential for Normal Lung Organs Genesis},
  author = {Inanlou, Mohammad R. and Reid, G. Andrew M. and Kablar, Boris},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Mouse fetuses that develop without both Myf5 and MyoD entirely lack skeletal myogenesis (i.e., amyogenic fetuses) and as a consequence perform no fetal breathing movements (FBMs). By employing amyogenic fetuses we tested the hypothesised influence of FBMs on cell fate and differentiation in the lung. To study cell differentiation, we performed immunohistochemistry against surfactant protein (SP)-A, B, -C and AD.We also examined cell cycle kinetic, using immunohistochemistry against proliferating cell nuclear antigen (PCNA) and in situ detection of programmed cell death (TUNEL). Mutant lung tissue was examined at pseudoglandular (embryonic day, E, 15.5), canalicular (E16.5) and terminal (E17.5-19.5) stage of lung development. We found: (a) an underdeveloped alveolar system, (b) increased cell death, (c) decreased cell proliferation and (d) down-regulated SP-D. In conclusion, our preliminary data suggest that FBMs influence development of the terminal part of the bronchial tree, where the gas exchange normally occurs, by controlling cell differentiation and functional maturation and by affecting cell cycle kinetic through unknown mechanochemical signal transduction pathways (Supported by an NSERC operating grant to B. K.).},
  note = {Poster},
}

@inproceedings{sparkes2002neuroimaging,
  title = {Neuroimaging Studies of Pediatric Attention-Deficit/Hyperactivity Disorder},
  author = {Sparkes, Sandra and MacMaster, Frank P. and Carrey, Normand and Kusumakar, Vivek},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Attention-Deficit/Hyperactivity Disorder is a prevalent and debilitating illness affecting 3-6% of children. Past studies have implicated the cerebellum in the pathophysiology of the illness. The corpus callosum has also been implicated in ADHD, although not consistently. Methods: 13 ADHD children (7-11 years, 8 males, 5 females) and 13 healthy controls (7-11 years, 9 males, 4 females) underwent magnetic resonance imaging (MRI) scans. Results: Body I in the corpus callosum was significantly smaller in ADHD children as compared to controls. No other corpus callosum region differed between groups. Cerebellum vermis was also reduced in ADHD subjects as compared to controls. Conc!usions: Reductions in Body I and the vermis may reflect the abnormalities noted in motor behavior and inhibition respectively.},
  note = {Poster},
}

@inproceedings{arnold2002glutamate,
  title = {Glutamate Injection into the Rat Motor Cortex Conditions Against Subsequent Brain Injury Induced Motor Dysfunction},
  author = {Arnold, Amanda and Allen, Gary V.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Introduction: Repetitive mild injury to the rat primary motor cortex has been shown to produce a conditioning effect, so that subsequent severe injury to the same site has no effect on motor function. The present study investigates whether local glutamate release following repeated mild injury is a mechanism for this conditioning effect. Methods: Adult male, Sprague-Dawley rats were trained on a beam-walking task, and received a series of glutamate or phosphate buffered saline (PBS) injections, spaced three days apart, into the rat hindlimb motor cortex. A second group of trained animals received either glutamate or PBS injections and a subsequent severe brain injury three days after the last injection. Results: Animals with repeated PBS or glutamate injections showed no motor deficits in the beam-walking task. Animals with repeated PBS injections followed by severe brain injury had significant motor deficits, whereas animals with repeated glutamate injections prior to severe brain injury had no significant motor deficits in the beam-walking task. Groups of animals with either repeated glutamate or PBS injections and severe brain injury had similar necrotic cavity volumes in the hindlimb region of the primary motor cortex. Animals with repeated glutamate injections showed patterns of heat shock protein 27 and glial fibrillary acidic protein expression that was similar to that seen following repeated mild brain injury. Conclusions: This data suggests that the conditioning effects on motor function seen after repetitive mild brain injury may involve local glutamate release from injured neurons and subsequent activation of secondary motor control sites. (Supported by the Nova Scotia Neurotrauma Society)},
  note = {Poster},
}

@inproceedings{boehnke2002segregating,
  title = {Segregating the scene: the effectiveness of sound localization cues on the formation of auditory objects in time},
  author = {Boehnke, Susan and Phillips, Dennis},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {The goal of the auditory system is to reconstruct sources in the acoustic scene and follow them through time, i.e. the formation of separate auditory 'streams' or objects (after Bregman, 1990). Differences in frequency, pitch, ear, or timbre can promote segregation of two interleaved sounds, but little is known of the effectiveness of the auditory cues for spatial location. In experiment l, subjects rated their perceptual experience of a repeating A_ B_A_ sequence of spectrally-identical noise bursts, where A differed from B in either ear of presentation, interaural level difference or interaural time difference (ITD). In experiment 2, detection thresholds were obtained for a temporal asymmetry in each type of ABA sequence, a task sensitive to stream formation. In both tasks, ITD was the least effective spatial cue for segregation, despite the fact that it is the dominant cue used for sound localization. The reason for this apparent mismatch will be discussed.},
}

@inproceedings{brown2002fearful,
  title = {Fearful Asymmetry: Genomic Imprinting and Family Conflict},
  author = {Brown, William Michael},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Conflicts of interest may occur between mother's and father's genes within offspring due to genomic imprinting (Haig, 2002). Genomic imprinting is the differential expression of a gene depending upon the parent-of-origin in which the gene was inherited. Specifically it appears that father's genes are predominantly expressed in the hypothalamus (involved in homeostasis)/limbic system while mother's genes are predominantly expressed in the neocortex (involved in flexible decision making). Haig (2000) and Trivers (2000) have both suggested that genomic imprinting could mediate conflicts over information transmission and reception within the brain. Keverne (2001) has further hypothesized that maternal genes may have been selected for the emancipation from endocrinological determinism mediated by paternal genes. It is a tantalizingly (albeit speculative) idea that the occurrence of genomic imprinting approximately 135 million years ago (MYA) in mammals may have indirectly facilitated coevolutionary conflicts between genes and social learning. This paper will outline some reasons to suspect that there are intragenomic conflicts over fear responses (e.g. fight or flight). Neuroscientists have located specific neurotransmitters in the brain that are involved in the suppression of agonistic responses. These transmitters and neural areas appear (in part) to be maternally derived.},
}

@inproceedings{phillips2002our,
  title = {Our Biggest Headache: The Body's Smallest Muscle},
  author = {Phillips, Dennis and Stuart, Andrew and Carpenter, Michael},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {The stapedius muscle of the middle ear holds the dubious distinction of being the smallest muscle in the human body. It contracts reflexively in response to loud sounds, and the result of the contraction is a directly measurable reduction in transmission of lowfrequency vibrations to the cochlea. Now, speech sounds are inherently broadband, and at high intensities, the high-frequency content of the sounds is prone to masking by the sound's low-frequency content. This is problematic because the high-frequency content of speech carries much information on phoneme identity, so an inability to perceive the high-frequency information is highly deleterious to speech perception. The stapedius reflex thus has the beneficial consequence that at high stimulus intensities, highfrequency information is less masked than it would otherwise be by concurrent lowfrequency content in the sound. The main behavioral evidence on this view comes from patients with Bell's palsy. Bell's palsy is thought to be an isolated pathology of the facial nerve (the nerve that innervates the stapedius). In those patients, word recognition at the affected ear(s) is often profoundly poorer at high stimulus intensities than it is at low intensities. The explanation offered for this is that the high-frequency content of the speech sounds is not afforded its usual protection from low-frequency masking when the stimulus amplitudes are high. The present talk will describe two new experiments on the stapedius reflex. These experiments provide independent, converging lines of evidence on the role of the stapedius reflex in human hearing.},
}

@inproceedings{peace2002impact,
  title = {The Impact of the Interview: A Comparison of Traumatic and Positive Memory Characteristics},
  author = {Peace, Kristine A. and Porter, Steve},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {In the legal system, it is often important to evaluate the credibility of memories for distant emotional experiences. The purpose ofthis study was to examine the characteristics of both traumatic and positive emotional memories as a function of interview style. Although previous studies have investigated the qualitative aspects of emotional memories, little is known about the influence of differential modes of recall on memory report characteristics and ratings of the psychological impact of the event. A comparison of four commonly used police and therapeutic interview styles (free narrative, cognitive interview, guided imagery, and written narrative) was conducted on both qualitative and quantitative characteristics of traumatic and positive memories reported in a community sample. Approximately 50 participants were interviewed at two time intervals. Further analyses were conducted on the consistency of traumatic and positive memories over time intervals of two to five months on a series of consistency questions and memory ratings (e.g., quality of memory, vividness/clarity). Results have important implications for understanding memory reports in the criminal justice system, and the variations in memory reporting that occurs as a function of various interview protocols.},
}

@inproceedings{perrotsinai2002uncovering,
  title = {Uncovering The Mechanisms Establishing and Maintaining Sex Differences in Brain},
  author = {Perrot-Sinai, and Behaviour Tara},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Rodents provide a useful model system in which to study sex differences and gonadal steroid action, at a behavioural and a cellular level. The importance of gonadal steroids during development for organizing sexually dimorphic neural circuitry is well established. However, until recently the molecular mechanisms underlying steroid action in developing brain were not known. We have recently elucidated a pivotal role for GABA in the developmental process of defining a male versus female brain. Once neural circuitry is sexually differentiated during development, gonadal steroids 'activate' this circuitry in adulthood resulting in behavioural sex differences. My current research focus is studying how stress responding differs between the sexes. This research has relevance for humans as the incidence of various stress-induced psychopathologies is higher in women than men. Using a natural model of stress, I have demonstrated that male and female rats differ in ethologically relevant behavioural responses and in neural activation (using c-fos protein induction as a marker) following the stressor. Future experiments will ( 1) examine sex differences in the effects of stress on cellular processes implicated in the development of stress-induced psychopathologies, and (2) investigate a causal role for gonadal steroids, both in adulthood and during development, in mediating sexually dimorphic responses to stress.},
}

@inproceedings{boudreau2002mousing,
  title = {Mousing Around With Sensory Preconditioning: Part II},
  author = {Boudreau, Sarah E. and LoLordo, Vincent M.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Little is known about the mouse's ability to associate neutral stimuli. Our research has focused on sensory preconditioning using the albino CD- I mouse. Training consisted of three phases. During Phase 1, mice were repeatedly presented with two pairs of odors. Odors were presented in small odor pots covered in bedding. Following Phase 1 exposure, one odor from one pair was paired with a buried sugar reward (S+), and one odor from the other pair was presented without sugar (S-). Mice learned to dig in the bedding more to S+ than to S-. Finally, in Phase 3, mice were given a choice between the two odors that had not been conditioned. If a mouse had indeed formed a bond between the two odors in a pair during Phase 1, then the associate of S+ should have been the preferred odor. In several experiments, the associate of S+ was not preferred, though in a subsequent test, S+ was preferred to S-. In an effort to explain our failure to produce sensory preconditioning, two more experiments were conducted looking at the possibility of configuring and spontaneous configuring of odor compounds in Phase 1. Preliminary results from these two studies will be discussed.},
}

@inproceedings{owens2002excuse,
  title = {Excuse me, your face is interfering with my Inhibition of Return.},
  author = {Owens, Kyle C.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Is inhibition of Return (IOR) affected by the biological significance of the target? IOR refers to the relative slowing of reaction times when responding to a target appearing in a cued versus uncued location. As faces are typical targets of a visual search, facial images were used as cues and targets and presented either intact as faces or scrambled as nonfaces. In Experiment 1 participants were presented with simplistic line and circle images of faces and exhibited no evidence of IOR. Experiment 2 used realistic facial images and IOR occurred only when a face was the target. Experiments 1 and 2 were repeated using a simple circle as the cue, and IOR then occurred for both face and non-face targets. Overall, IOR was affected by the complexity of the cue, and the biological significance of the target was important only when the cue and target were complex.},
}

@inproceedings{christie2002there,
  title = {There Is No Spatial Negative Priming},
  author = {Christie, John},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {All eight negative priming theories are based on a particular pattern of data, and most necessarily require this pattern. The pattern derives from a congruency hypothesis, "if items are congruent in a sequence of events then performance will be improved, else if items are incongruent then performance will be impoverished." In examining other relationships, besides those usually used to test negative priming, it was found that negative priming for spatial locations is not what it was once believed to be. It behaves more like inhibition of return, which does not follow a congruency hypothesis. This is important given the number of"negative priming" experiments that have been performed using the localization paradigm to test inhibition in populations. A reanalysis of location negative priming experiments needs to be performed given because costs in location negative priming are due to stimulation and not special treatment of the distractor.},
}

@inproceedings{groot2002promiscuous,
  title = {Promiscuous (and Probably Perverted) Pairings of Peromyscus Produce a Plethora of Peculiar Progeny.},
  author = {Groot, Marleen H. M. de and Rusak, Benjamin},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Light can affect daily rhythms by entraining the endogenous circadian pacemaker that normally drives these rhythms, as well as by directly affecting (masking) the overt expression of behaviour. A novel photopigment, melanopsin, is hypothesized to mediate both of these effects, as well as pupillary responses to light, all of which survive loss of classical photoreceptors in the retina. Last year, we described a California mouse (Peromyscus ca/ifornicus) expressing a normal circadian rhythm that failed to entrain to the light/dark cycle, but whose activity was completely masked by light exposure. We have recently established that this mouse responds to visual stimuli and shows normal pupillary constriction in response to light. This animal's phenotype appears to have a genetic basis, since the progeny of selective crosses of his descendants showed similar abnormalities. These mice are the first example of animals expressing apparently normal circadian rhythms that are not entrained by light, but that still show potent masking responses to light exposure.},
}

@inproceedings{wintink2002looking,
  title = {Looking for BrdU-incorporated hippocampal cells in an animal model of depression.},
  author = {Wintink, Amanda},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Various theories exist regarding the aetiology of human depression. One theory of depression is that it is due to stress-induced decreases in hippocampal neurogenesis (Jacobs, Van Praag, & Gage, 2000). Support for this theory comes from observations of decreased hippocampal volume in individuals with depression and also from data showing that various antidepressant treatments in rodents increase hippocampal neurogenesis. The present experiment was, therefore, designed to examine hippocampal neurogenesis in animal model of depression. Olfactory bulbectomy (OBX) has been shown to cause depression-like symptoms and may occur through stress-mediated mechanisms. In the present experiment, adult male rats underwent OBX or sham surgery. Six weeks after surgery rats received 4 injections of BrdU ( a marker of mitotic activity; 50mg/kg, i.p.) and sacrificed 24 hrs after the last injection. Brains were processed using immunohistochemistry for BrdU-:incorporated cell identification. The results are discussed in relation to the neurogenesis theory of depression.},
}

@inproceedings{birch2002mood,
  title = {The Mood-Induced Activation of Alcohol Expectancies in Internally Motivated Drinkers},
  author = {Birch, Cheryl and Stewart, Sherry and Eisnor, Shondalee and Theakston, Jennifer},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {This study investigated whether Coping Motivated (CM) and Enhancement Motivated (EM) drinkers differ in their activation of alcohol-related cognitions following exposure to musical mood induction procedures (MMIP). A total of 86 undergraduates who had elevated screening scores on either the CM or EM subscale of the Drinking Motives Questionnaire (DMQ-R; Cooper, 1994) participated in this experiment. Half the people in each motive group were randomly assigned to a positive mood condition and the other half to a negative mood condition. The Alcohol Craving Questionnaire (ACQ; Singleton, Tiffany & Henningfield, 1994) was administered at baseline and following the MMIP to assess phasic changes in alcohol-related cognitions. After an ANCOV A was used to adjust for motive-group differences in baseline mood state, it was evident that the MMIP's induced the intended target moods for all groups. The mood induction operated specifically to trigger different alcohol expectancies for CM and EM drinkers. Consistent with hypotheses, planned comparisons revealed that only CM drinkers in the negative (but not the positive) mood condition reported significant increases in expectancies that alcohol would relieve negative mood states. Also consistent with hypotheses, only EM drinkers in the positive (but not the negative) mood condition reported increases in beliefs that alcohol would enhance positive affective outcomes. Theoretical and clinical implications will be discussed.},
}

@inproceedings{elgar2002dead,
  title = {Dead Thesis Revival: Reforming Graduate Studies in Canadian Universities},
  author = {Elgar, Frank J.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {In PhD programs in Canada, completion rates hover around 50%, less than 10% of students who do finish do so within scheduled residencies, and mean times-to-completion has nearly doubled during the last three decades from 6 to 11 years. Such inefficiency creates significant costs to universities and to students. Reform is needed to address low completion rates and lengthy times-to-completion. This presentation includes data from US and Canadian PhD programs and a discussion about the personal, social, financial and institutional factors that influence completion rates. A study is under way to examine the relation between institutional regulations and resources and completion rates in PhD programmes. Administrators of graduate studies from Canada, the United States and the United Kingdom will participate in a mail-in survey. Implications of the results and directions for further research will be discussed.},
}

@inproceedings{stewart2002win,
  title = {In Win, Lose, and Booze: Implicit Gambling Outcome - Alcohol Associations In Problem Gamblers},
  author = {Stewart, Sherry and Zack, Martin and Loba, Pamela and Klein, Ray},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Although prior research shows that most gamblers drink alcohol while gambling, the functional relationship between particular gambling events (e.g., wins, losses) and alcohol use remains unknown. This study examined priming of alcohol cognition by gambling gain and loss events among gamblers with differing histories of drinking in response to these events. A stronger tendency to drink following a particular gambling outcome (win, loss) was predicted to coincide with a stronger association between that outcome and alcohol in memory, resulting in greater priming on an implicit association task (!AT). Participants were community-recruited problem gamblers. On the IAT, gain (e.g., winnings) and loss (e.g., bankrupt) words were paired with alcohol (e.g., vodka) or non-alcohol (e.g., lemonade) words and participants made a category judgment (e.g., alcohol vs. non-alcohol) to each word by pressing one of two response keys. Participants also reported how likely they were to drink when they won and lost at gambling. Preliminary analyses indicate that history of loss-based drinking did not influence priming of alcohol concepts by exposure to loss cues on the !AT. However, the predicted association was observed between gain events and alcohol in those who reported a history of win-based drinking.},
}

@inproceedings{reynolds2002effect,
  title = {Effect oflnsulin-like Growth Factor-1 on Functional Recovery Following Cerebellar Injury.},
  author = {Reynolds, Laura P.R. and Allen, Gary V.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Faculty of Medicine, Dalhousie University Introduction: Insulin-like growth factor (IGF-1) acts as a non-selective neurotrophic agent in the adult brain in response to injury. IGF-1 has been shown to mediate levels of Calbindin-28kD in Purkinje cells and promote climbing fiber re-innervation. Our aim was to determine whether administration of exogenous IGF-1 following severe cerebellar injury would enhance recovery of motor function. Methods: A weight drop model of brain injury was used to induce severe damage to the left paravermal cerebellar cortex in the anesthetized adult rat. Treatment animals (n=6) received 3 series of direct IGF-1 injections (l.25mg/kg) 2 mm deep into the cerebellar cortex immediately before injury and 24 hour and 48 hours post-injury. Control animals (n=6) received severe injury followed by a series of PBS injections (0.05 M, pH=7.4) into the cerebellar cortex. Sham animals (n=4) received craniotomy without injury or injection. Animals were tested for motor function using the beam-walking test. Results: Motor recovery rates were significantly enhanced in treated animals compared to controls (p < 0.01). Animals that received IGF-1 injections approached near recovery levels by day 15. In contrast, the motor function of control animals failed to reach near recovery levels by day 29. Conclusions: These findings suggest that post-injury treatment with IGF-1 is an effective means of enhancing motor function following severe cerebellar injury. Analysis of brain sections for the immunohistochemical detection of Hsp27, Calbindin-28kD, Parvalbumin and Glycogen Synthase Kinase 3~ are currently in progress to reveal the role ofIGF-1 in cell survival and to determine the intracellular mechanism of action of IGF-1. (Supported by Nova Scotia Health Research Foundation)},
}

@inproceedings{emotionality2002differential,
  title = {Differential Effects of Kindling Different Brain Regions on Kindling-Induced},
  author = {Emotionality},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {AC Davis, V Thome, A Gregus, AJ Wintink and LE Kalynchuk. Amygdala kindling dramatically increases emotionality in rats and is considered a good model of the behavioural changes associated with temporal lobe epilepsy. Less well studied have been the effects of kindling other brain regions on changes in emotionality. One study has shown that kindling the dorsal hippocampus causes increased emotionality whereas caudate kindling does not (Kalynchuk et al, 1999). The purpose of this study was to further study the effects of kindling both limbic and non-limbic regions on kindling-induced emotionality. Rats were given either 99 kindling or sham stimulations of the left amygdala, caudate, claustrum, bed nucleus of the stria terminal is (BNST), or perirhinal cortex. After kindling the rats were tested on the open field, elevated plus maze, and forced swim test. Amygdala-, BNST- and perirhinal-kindled rats showed increases in emotionality on all tests compared to controls. In contrast, caudate and claustrum kindling did not significantly increase emotionality. These results demonstrate that kindling-induced emotionality is only produced by kindling of specific brain regions.},
}

@inproceedings{injections2002effects,
  title = {Effects of Repeated Corticosterone and Restraint Stress on Anxiety and Depressionlike Behavior in Male Rats},
  author = {injections and injections, vehicle and stress, restraint and every, or handling},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Gregus A*, Davis, AD, Wintink, A J, Kalynchuk, LE Repeated stress increases glucocorticoids and is associated with the development of affective psychopathology in humans and maladaptive behavioral changes in rats. It is well established that stress-induced corticosterone (CORT) impairs cognitive functioning in rats; however, little is known about its effects on affective behavior. Accordingly, the present study examined the effects of two repeated stressors, restraint and CORT injections, on changes in emotional behavior in male rats. Rats received either CORT day for 21 days prior to and during behavioral testing. Starting on day 22, animals were tested for changes in fearful/anxious behavior in the open field, and the elevated plus maze, and for symptoms of depression in the forced swim test and sucrose consumption test. Results revealed that neither CORT nor restraint altered motor or anxiety-related behavior the open field or the elevated plus maze. However, CORT increased the frequency and time spent immobile in the forced swim test compared to vehicle injected controls. Additionally, CORT significantly decreased the proportion of sucrose-to-water solution consumed compared to vehicle injected rats in the sucrose consumption test. Restraint did not alter behaviors in the forced swim or sucrose consumption tests. These results suggest that repeated CORT injections produce behaviors associated with depression and that neither CORT nor restraint increase anxiety-like behavior in male rats.},
}

@inproceedings{bernier2002evoked,
  title = {Evoked Potentials In Coma Populations},
  author = {Bernier and D and Marchand and Y and Rahey and S and Striemer and C and Young and B, G. and Connolly, J. F},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {A variety of electrophysiological protocols will be used to evaluate the functional state of cortical and subcortical structures of patients in coma following traumatic head injury. The population to be investigated will be patients between 18-50 years of age. Testing will start as early as possible after the injury and will be repeated on a regular basis for a period of six months. The battery of assessments includes Somatosensory Evoked Potentials, Brain Stem Auditory Evoked Potentials, as well as Event-Related Potentials associated with pre-conscious attention mechanisms(MMN) and higher level semantic functions (N400). The ultimate goal is to investigate which measures will reliably predict return to consciousness, and to investigate cognitive function in coma and at emergence.},
}

@inproceedings{lee2002effect,
  title = {Effect Of Postnatal Handling On The Emotional Behaviour Of Adult AmygdalaKindles Rats},
  author = {Lee, Anna and Kalynchuk, Lisa},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Long-term amygdala kindling in adult rats produces high levels of anxiety, and is often used as an animal model for studying the emotionality associated with human temporal lobe epilepsy. Brief handling in early-life decreases anxiety and the behavioural responses to stressors encountered in adulthood. The present study examined whether postnatal handling would reduce the development of emotionality in adult amygdalakindled rats. Male rats were handled for the first 14 days of life or left undisturbed. At adulthood, rats were either left undisturbed in their home cage or received sham stimulations, or 10, 25 or 60 amygdalakindling stimulations and were tested for changes in anxiety and depression. Kindling produced increases in emotional behaviour, consistent with previously published findings. However, postnatal handling had no effect on kindling-induced emotionality, suggesting that variations in early environmental experience do not play a role in the development of epilepsy-induced emotionality.},
}

@inproceedings{murphy2002caffeine,
  title = {Caffeine-induced activation of orexin neurons},
  author = {Murphy, Jeremy A. and Semba, Kazue},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Caffeine is the most commonly used psychostimulant. Orexins are novel neuropeptides, found in posterior hypothalamic neurons, which are suggested to participate in normal wakefulness, feeding as well as in the neuropathology of the sleep disorder narcolepsy. We investigated whether stimulant doses of caffeine activate orexin-containing neurons in rats, using c-Fos as a neuronal activation marker. We confirmed that caffeine increased locomotion at low doses (10 and 30 mg/kg), while inhibiting locomotion at a high dose (75 mg/kg); saline had no effect. In the same animals, all doses of caffeine increased the number of c- Fos expressing, orexin neurons by approximately 200%, whereas a similar degree of activation of non-orexin neurons occurred only after the highest dose. These results indicate that orexinergic neurons are selectively activated by stimulant doses of caffeine, and suggest that the activation of orexin neurons, either directly or indirectly, play a role in mediating behavioural activation by caffeine.},
}

@inproceedings{newman2002evidence,
  title = {Evidence for Neural Plasticity Following Reading Remediation Training},
  author = {Newman, Randy Lynn},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {The present study recorded ERPs as participants, with and without phonological processing deficits performed a modified phoneme deletion task. Participants in the phonologically impaired (Pl) group were enrolled in a reading remediation program (Spell Read) and were tested prior to receiving instruction and at specified time points during the program (i.e., 20 hours, 40 hours, completion of program). Participants heard instructions asking them to omit the initial phoneme from a monosyllabic word (e.g., Clap without the /Cl sound). This was followed (ISi = 2 sec) by presentation of the correct (e.g., Lap) or incorrect answer (e.g., cap). In the control group, two ERP components were elicited: the Phonological Mismatch Negativity (PMN), a component linked to phonological analysis was largest to incorrect items, and the P300, a component associated with memory recognition was largest to correct items. In the PI group, the PMN and P300 responses were atypical (i.e., small, absent, delayed) prior to receiving reading instruction. However, after only 20 hours of training, both the PMN and P300 responses began to normalize relative to the control group. These results have been observed in both children and adults indicating that changes observed in children are not solely the result of ongoing neural development.},
}

@inproceedings{santor2002eight,
  title = {"Eight Decades of Measurement in Depression"},
  author = {Santor, Darcy},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Since 1930, some 400 instruments and measures have been developed to assess and diagnose depression. These measures differ in content, response format and in objectives. Although there are good reasons for constructing different measures of depression, the large number of often diverse measures created over the past 80 years creates its own challenge to one of the main goals of measurement, namely to standardize assessment and streamline decision-making. The proposed talk reviews some of the many important psychometric techniques and substantive developments that have impinged directly on these measurement goals, including (a) the need for impossibility equating different scales, (b) item content heterogeneity, and (c) potential difficulties associated with the use of principal components analysis for developing short forms. Many of these challenges can be resolved through the use of techniques based on item response models.},
}

@inproceedings{bernier2002sleep,
  title = {Sleep Deprivation Effects on Magnetic Resonance Spectroscopy and Mood in Major Depressive Disorder},
  author = {Bernier and D and MacMaster and F and Gates and L and Kusumakar and V and Rusak and B},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {A variety of studies using different methods of imaging brain structure and function have reported changes associated with major depressive disorder (MOD). PET and functional magnetic resonance imaging (fMRI) studies have reported decreased metabolic activity in the dorsolateral prefrontal cortex (PFC), concurrently with increased activity in the ventrolateral PFC. Differences in metabolic activity have also been reported in the anterior cingulate, the temporal lobe, and some subcortical structures, including the hippocampus and parahippocampus. Many of these abnormalities are reversed after successful antidepressant treatments. Pharmacological treatments generally take weeks to achieve their effects, making it difficult to identify the steps leading to these changes. Partial overnight sleep deprivation has been shown consistently to produce transient but very substantial mood improvement in more than 50% of patients suffering from MOD. This provides an opportunity to study brain changes within hours of an effective treatment. Single-proton, magnetic resonance spectroscopy (H-MRS) allows detection of some neurochemical changes in targeted brain regions that are not detected by other functional brain imaging methods. We have been using H-MRS to investigate the effects on features of the MR spectra that represent levels of choline and levels of glutamate/glutamine/GABA in several brain regions after sleep-deprivation induced mood improvement. Preliminary results demonstrating rapid changes in brain neurochemistry associated with mood improvement will be presented.},
}

@inproceedings{forestell2002palatability,
  title = {Palatability Shifts in Taste and Flavor Preference Conditioning},
  author = {Forestell, Catherine A. and LoLordo, Vincent M.},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Although rats acquire strong conditioned preferences for tastes and flavors paired with glucose, it is not clear whether this occurs because of a shift in palatability to the CS or whether the CS evokes an expectancy of postingestive reinforcement in test. The present studies sought to determine whether preference conditioning enhanced CS palatability using a taste reactivity procedure. Our results indicate that ingestive responses to taste and flavor stimuli are enhanced as a result of differential preference conditioning.},
}

@inproceedings{mitchell2002correlated,
  title = {Correlated Binocular Activity Guides Recovery From Monocular Deprivation},
  author = {Mitchell, Donald and Kind, Peter and Ahmned, Bashir and Blakemore, Colin and Bonhoffer, Tobias and Sengpiel, Frank},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {The mild effects of binocular as compared to monocular visual deprivation led to the widely held view that the plasticity observed in the mammalian visual cortex during development reflects the operation of competitive interactions for synaptic space between inputs from the two eyes. However, during a subsequent period of binocular vision there is substantial behavioural and physiological recovery, leading to the suggestion that absolute activity levels, or some other non-competitive mechanism, determine recovery from MD. Here we demonstrate that correlated binocular input is essential for such recovery. Both behavioural and physiological (assessed by optical imaging) recovery is far less complete if the two eyes are surgically misaligned after a period of MD. This is a powerful demonstration of the importance of cooperative, associative mechanisms in the developing visual cortex.},
}

@inproceedings{loba2002planned,
  title = {Planned Investigations of the Opiate-Mediated Reward Mechanisms Involved in Pathological Gambling-Alcohol Use Disorder Co-Morbidity},
  author = {Loba, Pamela and Stewart, Sherry},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Alcohol abuse and pathological gambling are commonly co-morbid, yet little is known about mechanisms underlying this co-occurrence. In a preliminary study (Stewart, Loba, Blackburn, Ellery, & Klein, in press), we examined heart rate (HR) responses to video lottery terminal (VL T) play and alcohol intake among a sample of regular VL T players. The results of this pilot study replicated previous findings that gambling and alcohol intake alone each result in increased HR. The results also provided novel information that the combination of VLT play and alcohol further intensifies HR increase relative to either activity alone. We have hypothesized that activity in the endogenous opiate system may underlie both pathological gambling and alcohol use disorders and may help explain their co-morbidity. We describe our plans for a set of three studies that will evaluate the possible role of endogenous opiates. The first is a replication and extension of our pilot study that controls for possible confounds (e.g., controls for movement artifact, use of placebo control). The second study will evaluate levels of beta endorphin release (via blood analyses) in response to VLT play, alcohol intake, and their combination in pathological and non-pathological gamblers, and will determine the degree to which betaendorphin correlates with HR acceleration to each activity. Finally, a third study will evaluate whether naltrexone (an opiate antagonist) blocks HR increase and positive mood changes to VL T play, alcohol intake, and their combination in a sample of pathological gamblers. Theoretical and clinical implications of this planned research will be discussed.},
}

@inproceedings{shoemaker2002impact,
  title = {The impact of female reproduction on immunocompetence in the cricket},
  author = {Shoemaker, Kelly and Adamo, Shelley},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {Animals may be selected to increase energy invested in reproduction at the expense of other physiological systems such as immunity. We examined whether a trade-off was evident between reproduction and immunity in the cricket, Gryllus texensis, by comparing the immunocompetence of mated females with the number of eggs they produced. Females will adjust egg output when presented with different egg-laying substrates. Immunocompetence was measured by: 1) phenoloxidase (PO) activity in the hemolymph; and 2) a functional assay analysing survival rates following infection with the bacterium Serratia marcescens. Contrary to prediction, we found no evidence for a difference in PO activity in the hemolymph of females laying significantly different numbers of eggs. Additionally, preliminary data suggest that females laying high numbers of eggs are, in fact, less likely to succumb to infection. These initial results suggest that while reproduction may be costly, these costs are not at the expense of immunity. Future studies will investigate a larger contrast in reproductive investment with virgin and mated females.},
}

@inproceedings{brown2002einstein,
  title = {Einstein meets Lenin in Brodmann's area 39},
  author = {Brown, Richard},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {This talk is based on my research after reading two books: Michael Paterniti (2000) Driving Mr. Albert: A trip across America with Einstein's Brain, and Tilman Spengler (1991) Lenin's Brain. When Albert Einstein died on 18 April 1955, he was considered the greatest genius of his time. His brain was removed for analysis by Dr. Thomas Harvey, who kept it in a jar in a wooden box in his lab until the first research paper was published in 1985 (Diamond et al., 1985. Exp. Neurol. 88, 198-204). Since that time there have been at least 8 papers, two books, and numerous newspaper and magazine articles written about Einstein's brain. When Lenin died in January 1924, he was considered the greatest of geniuses. His brain was removed and analyzed by Oskar Vogt, who was selected by a special advisory board of the Soviet government. Vogt was a student of Haeckel and had worked for a year in Paris with the Joseph and Marie Dejerine (one of the most famous medical couples since the Curies), and from 1901-1910, Vogt and his wife Cecile (another famous medical couple), supervised the neuroanatomical research of Korbinian Brodmann, whose famous monograph "Localization in the Cerebral Cortex" was published in 1909 [English translation 1994].These neuroanatomists are only some of those who have examined "famous brains" as medical curiosities. What has been learned about the neural basis of intelligence from this "cult of genius"? This talk will examine some of the history of neuroscience related to the neuroanatomical analysis of famous brains.},
}

@inproceedings{ivanoff2002using,
  title = {Using speed-accuracy trade-off functions to explore the effect of inhibition of return on information processing},
  author = {Ivanoff, Jason and Klein, Raymond},
  booktitle = {28th Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {2002},
  abstract = {In two tasks - a go/no-go task and a choice-RT task - we generated speed-accuracy tradeofffunctions (SATFs) to examine the timecourse of the influence of inhibition of return (IOR) upon target processing. The SATFs were created by plotting accuracy as a function of response time. With the go/no-go task, IOR was characterized by slower responses, an increase in criterion (C), and a slight increase in sensitivity (d') at a relatively early portion of target processing. In contrast, with the choice-RT task, IOR was characterized by slower responses at an early portion of target processing and reduced accuracy at a late portion of target processing. This pattern of results suggests that IOR increases the criterion to make a response and it reduces the sensitivity of target processing during the relatively late portion of target processing, but only with choice-RT tasks.},
}

@inproceedings{currie2003behavioural,
  title = {Behavioural and histological analysis of the effects of mup75-saporin in an effort to create a mouse model of Alzheimer's Disease},
  author = {Currie, Lisa M. and Brown, Richard E.},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {A loss of cholinergic cells in the basal forebrain produces memory deficits similar to those in Alzheimer's Disease (AD) (Francis, P.T. et al., 1999, J. Neural. Neurosurg. Psych., 66, 137-47). Following injection of 192-IgG saporin, a neurotoxin targeting p75 cells in the cholinergic basal forebrain, into the medial septum, rats have a deficit in spatial working and reference memory (Shen, J. et al., 1996, Behav. Neurosci. 110, 1181-86). The destruction of cholinergic cells in the mouse brain using mup75-saporin (a mouse version of 192 IgG saporin) resulted in a dose- dependant cell loss in the medial septum, and deficits in spatial learning in the Morris Water Maze (Berger-Sweeney, J. et al., 2001, J. Neuroscience, 21, 8164-73). Our study extended that of Berger Sweeney et al., (2001) with a more comprehensive analysis of behavioral deficits associated with the injection of mup75-saporin. Using the results of Berger-Sweeney et al., (2001). One of three doses of mup75 saporin (3.6 µg/µl, 1.8 µg/µ1, 0.9 µg/µ1, or a PBS control) was infused bilaterally into the lateral ventricles of male C57BL/6J mice using a 30 gauge Hamilton syringe. Starting 15-20 days after drug injection, the mice were tested in the Open Field, Elevated Plus Maze, Beam Walking, Rotarod, Morris Water Maze, and a modified win- shift paradigm of the Radial Arm Maze. Following behavioral testing, the mice were inter- cardially perfused using 4% paraformaldehyde in PBS, and the brain tissue was retrieved, and stained for VachT, AchE, and Niss!. Behavioral analysis indicated no significant effects of mup75-saporin across tasks. However, when body weight was used as a covariate in the Radial Arm Maze, group differences were found on performance measures (latency and total arm entries). Cell counts in the nucleus basalis magnocellularis indicated no significant cell loss due to mup75- saporin. A difference of fiber density in the hippocampus was found between the control and drug groups indicating damage to the septo-hippocampal pathway. Analysis of the superficial layer of Purkinje cells in the cerebellum found no difference across drug groups, indicating that the toxin did not affect the cerebellum. These results indicate that mup75-saporin caused very little cell loss in the nucleus basalis magnocellularis and cerebellum and very few behavioural deficits. It is hypothesized that there may not be as many p75 cells in the mouse brain as in the rat. In addition, other neurotransmitter pathways may be compensating for any cell damage caused by the neurotoxin.},
  note = {Poster},
}

@inproceedings{williamson2003potentially,
  title = {Potentially protective effects of Ritalin},
  author = {Williamson, Martin and Brown, Richard E.},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Methylphenidate (MPH, Ritalin), a central nervous system stimulant, is widely used for the treatment of Attention-Deficit Hyperactivity Disorder (ADHD), a chronic childhood disorder with a prevalence of 3 to 6% in school-aged children. In recent years, the therapeutic use of MPH for the management of ADHD has increased substantially in children and also in adults. Furthermore, as MPH is increasingly prescribed to adult women to treat ADHD, there is an increasing danger of taking MPH during pregnancy. Little is known about the effects of MPH during pregnancy, therefore in this study, pregnant C57BL/6J mice were given daily sub cutaneous injections of MPH (5 mg/kg) or saline during embryonic day 4 to 18. Since postnatal environmental enrichment can exert profound and positive neurobehavioural changes in animals, pups were reared in an enriched or isolated environment. On postnatal day 60, the pups underwent behavioural testing in the elevated plus maze, open field, rotarod and Morris water maze. Prenatal MPH exposure caused lasting changes in behaviour, illustrated by decreases in emotionality and increases in exploration and locomotion, while having no effect on motor and spatial learning performance. Pups reared in an enriched environment showed similar reductions in emotionality, and increased exploratory and locomotor behaviour, combined with improved spatial learning performance. Of particular interest is the finding that the effect of prenatal MPH injections on behaviour is similar to that of environmental enrichment. Future studies will focus on the mechanisms mediating the behavioural alterations and the potential stimulating or protective role of enrichment and stimulant drugs such as MPH. BALLOT},
  note = {Poster},
}

@inproceedings{butler2003gradients,
  title = {Gradients of attention in visuo-spatial neglect after right hemisphere stroke},
  author = {Butler, Beverly and Eskes, Gail},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {According to Kinsbourne's theory of attention, the two hemispheres of the brain contain opponent, mutually inhibitory vectors to direct attention to different spatial locations; the left hemisphere vector directs attention to the right side of space, while the right hemisphere vector directs attention to both sides of space. Thus, left-sided neglect occurs when the right hemisphere is damaged, resulting in an impaired leftward attentional vector and a disinhibited rightward attentional vector. This theory also suggests that individuals with neglect will show a linear gradient of decreasing attention from right to left. The present study investigated whether individuals with neglect show attentional gradients in both peripersonal space (within arms reach) and extrapersonal space (beyond arms reach). Subjects with right hemisphere damage with or without neglect, and healthy controls searched for visual targets on matched sheets placed in peripersonal and extrapersonal space. A right-to-left gradient of decreasing target detection was seen in both peripersonal and extrapersonal space in the neglect group, but not in the control groups. Double dissociations of gradients in peripersonal and extrapersonal space were also found. These results support Kinsbourne's theory and suggest independent neural mechanisms of attentional control in the right hemisphere related to spatial reference planes.},
  note = {Poster},
}

@inproceedings{mirkovic2003expression,
  title = {Expression pattern of neurotrophic factors and their receptors in the nervous system that develops in the absence of skeletal myogenesis},
  author = {Mirkovic, Slobodan and Gupta, Jagdish and Belliveau, Anne C. and Kablar, Boris},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {It is well established that during development motor neurons compete for their target, the skeletal muscle, to avoid programmed cell death. Human disorders characterized with motor control disturbances and human muscular diseases provide some evidence for that. However, it is still largely unclear whether any of the neurotrophins are of unique importance in preventing the death of developing motor neurons. We employed wild-type and Myf-5-1-:MyoD-/- embryos (that completely lack skeletal muscle) to test in vivo muscle-related neurotrophic requirements of skeletal muscle associated neurons [i.e., MMC (median motor column) and LMC (lateral motor column) motor neurons in the spinal cord and proprioceptive neurons in the dorsal root ganglia (DRG)]. To determine which neurotrophic factor and receptor is important for survival of MMC, LMC and DRG neurons, we assessed the expression pattern of muscle-secreted neurotrophic factors (e.g., BDNF, NT-3, NT-4/5) and their receptors (e.g., Trk Band Trk C) in mutant and control neural tissues by immunohistochemistry. Together, our results indicate that alterations in the expression pattern of neurotrophins and their receptors in the spinal cord and DRG are related to the decreased ability of MMC, LMC and DRG neurons for survival.},
  note = {Poster},
}

@inproceedings{lowepearce2003beat,
  title = {And The Beat Goes On ... Life After Heart Surgery},
  author = {Lowe-Pearce and C and McGlone and J and Hirsch and G and Legare and J-F and Peters and V},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Controversy exists over recovery from coronary artery bypass grafting (CABG). A healthy control group (n=36) was compared with patients (n=44) to contrast three different Reliable Change Indices (RCI), and then, to contrast outcomes based on incidence (RCI) versus group means (ANCOVA) six weeks prior to surgery and seven months later. Gain, no change, or loss on a composite neuropsychology battery and Quality of Life (SF-36) were identical using each RCI formula. Cognitive change was not significantly different between groups over time, and patients reported significantly improved physical health compared to controls. More patients reported positive and negative mental-health changes than controls, a difference absent from group analyses.},
  note = {Poster},
}

@inproceedings{stanford2003effect,
  title = {The effect of a single versus repetitive pain experience during infancy on anxiety and spatial learning in juvenile mice.},
  author = {Stanford, Lianne and Darrah, Matthew and Kelly, Carrie and Schellinck, Heather},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Exposure to pain during development has long been hypothesized to disrupt behaviour in later life. (Hebb, 1949, Organization of Behaviour). Recent evidence has shown that rats subjected to pain as infants are more anxious as adults (Anand & Scalzo, Bio. Neonate, 77, 2000). In Experiment One, we investigated the influence of early pain experience on anxiety and learning and memory in mice. Neonatal mice were exposed to a one time acute pain, i.e., a tail snip at postnatal day 8 or repetitive pain, i.e., paw pricks on postnatal days 8-14. When tested in an elevated plus maze on Day 30, both acute and chronic pain mice showed behavioural changes indicative of increased anxiety compared with control animals. The effects included a reduction in open arm entries, percent time spent in the open arms and a decrease in head dips. In addition, chronic pain animals showed a greater decrease in time spent in the open arms and in number of entries into the open arms as well as an increase in stretch attends compared with acute pain animals. There were no differences in the number of line crossings in the experimental and control animals. This pattern of results would suggest that the pain exposed animals showed an overall increase in risk assessment, a behaviour associated with hypervigilance in humans. When tested in the Morris Water Maze, these mice demonstrated an intact working memory in a three- day acquisition task as well as in a probe trial and reversal trials. Thus, it appears that their increased anxiety did not adversely affect their performance in a spatial working memory task. In a second experiment, the effect of environmental enrichment on decreasing anxiety in mice experiencing early neonatal pain was assessed. There was no difference in anxiety between control and experimental animals when tested in the elevated plus maze. The implications of this failure to replicate the results of the initial effect are discussed.},
  note = {Poster},
}

@inproceedings{macpherson2003eyes,
  title = {Do eyes act like arrows? Responding to nonpredictive directional cues in children and adolescents},
  author = {MacPherson, Amy and Moore, Chris and Friesen, Chris Kelland},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Covert orienting to socially significant gaze cues and more symbolic arrow cues was recently examined in a manual detection task with preschoolers and adults (Ristic, Friesen, & Kingstone, in press). Significant cueing effects were observed in both conditions for both age groups, contrary to the hypothesis that for young children arrows are less well-learned than they are for adults and would therefore make less effective cues than gaze cues (which are believed to be processed reflexively). The present cross-sectional study used the same stimuli and design as Ristic et al., but with a localization task, to examine the range of ages between those tested in their study. One hundred and ten 5- to 17-year-olds were recruited and tested at a summer camp. They participated in two counterbalanced cueing conditions, making keypress responses to peripheral targets appearing, at varying cue-to-target stimulus onset asynchronies (SOAs), to the left or right of centrally-positioned nonpredictive directional cues. In the Gaze Condition, the direction of gaze of a schematic happy face served as the cue, and in the Arrow Condition the direction of an arrow served as the cue. Participants made a speeded response by pressing either a left or right computer key to indicate target location. Each block of 52 randomly ordered trials included two each of 24 trial types representing the factorial combination of cue validity (valid or invalid), target location (left or right), target identity (cat or snowman) and SOA ( 195, 600, or 1005 ms), along with 4 catch trials. The 5- to IO-year-olds (N =49, M = 8y4m) completed one block in each condition, while the 11- to 17-year-olds (N = 61, M = 14y) completed two blocks in a row in each condition. As expected, we found that participants in both age groups responded more quickly to targets appearing on the side of the screen indicated by the cue. Although both reaction time (RT) and the magnitude of the RT advantage decreased as age increased, the overall pattern of faster responding to targets on the cued side was consistent across age groups in both the Gaze and Arrow Conditions. The present study provides further evidence that when gaze and arrow cues are nonpredictive they can produce similar effects, and it adds the new finding that the cueing effects triggered by nonpredictive centrally-presented cues remains consistent from the preschool years through to adulthood.},
  note = {Poster},
}

@inproceedings{westwood2003eye,
  title = {Eye movements are not required for fast manual responses to visual target perturbations.},
  author = {Westwood, David A. and Danckert, James},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Previous studies have shown that reaching movements can be quickly updated when the position of the target is unexpectedly changed during the course of the response (i.e., the double-step reaching paradigm). Because the change in target position typically takes place during a saccadic eye movement, perceptual awareness of the perturbation is suppressed (i.e., saccadic suppression). Nevertheless, the eyes move quickly (and unconsciously) to fixate the new target position before the reaching movement is complete. Therefore it is unclear whether the updating of the reaching movement is driven by a visual (i.e., the position of the target on the retina) or non-visual signal (i.e., gaze direction). We sought to distinguish between these possibilities by comparing reaching performance in a double-step task with free gaze (i.e., subjects were free to saccade to the target when it appeared) and central fixation (i.e., subjects maintained central fixation during the course of the trial). If reaching corrections are driven by a non-visual signal related to eye position then performance should be impaired in the central fixation condition (since eye position and target position are decoupled). In contrast to this prediction, our results show that performance is equivalent in the two conditions; reaching adjustments were as fast, accurate, and frequent in the free gaze and central fixation conditions. Although knowledge of eye position is undoubtedly important for the control of reaching movements, the reaching control system has fast access to visual information about the position of targets on the retina; this information can be used to implement fast and accurate adjustments to ongoing reaching movements. In other words, the control of reaching movements is not a simple case of reaching to where the eyes are looking.},
  note = {Poster},
}

@inproceedings{mcglone2003periodic,
  title = {Periodic stimulation (of the vagal nerve for treatment of intractable seizures) may be less than it is cracked up to be.},
  author = {McGlone, J and Clarke, D and Sadler, R. M and Valdivia, I and Penner, M},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {In an experimental paradigm, Clarke et al. (2000) found that verbal recognition memory was enhanced immediately after stimulation of the vagal nerve in humans with epilepsy. If this effect were more permanent, the prediction could be made that patients receiving vagal nerve stimulators might experience enhancement of memory functioning on standardized clinical tests. Three groups of patients with epilepsy underwent a broad neuropsychology evaluation including a memory assessment (WMS-III) and self-rating of memory functioning on two occasions, i.e., before and 12 months after implantation of a vagal nerve stimulator (n = 16), or a temporal lobectomy (n = 10), and a medication only control group (n = 9) seen 12 months apart. Depression scores (Geriatric Depression Scale), seizure frequency, and Quality of Life (QOLIE- 89) were also analyzed. Grouped data were subjected to an Analysis of Variance and individual change scores were subjected to a reliable change index analysis. Results: The patients with vagal nerve stimulators were not superior to the other groups on any outcome measure one year after treatment. Similarly, the percentage of patients who improved beyond measurement error did not differ in the three patient groups. Conclusions: Vagal nerve stimulation did not reduce seizure frequency or enhance memory functioning or quality of life in a clinical sample of patients with medically intractable epilepsy after 12 months of treatment. Our negative findings based on matched samples contrasts with the positive outcomes published in industry funded, but less well controlled studies. The results highlight the need for non-industry funded granting agencies to embark on multi-centre research on this new technology.},
  note = {Poster},
}

@inproceedings{inanlou2003abnormal,
  title = {Abnormal Development of the Diaphragm in mdx:MyoD-l- 9thembryos leads to pulmonary hypoplasia},
  author = {Inanlou, Mohammad R. and Kablar, Boris},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Introduction: In vitro studies have shown that mechanical factors play an important role in cell cycle kinetics and cell differentiation of the lung through an unknown mechanochemical signal transduction pathway. In the current study we evaluated the in vivo role of mechanical factors due to fetal breathing movements (primarily executed by the diaphragm) on lung growth and development by using genetically engineered mouse embryos. Materials and Methods: Lung growth and development of mdx and the ninth backcrossed generation of mdx:MyoD-1- embryos (designated as: mdx:MyoD-l- 9'h) were compared to that of the wild-type littermates (and to each other) at the embryonic day 18.5 using histological studies and immunohistochemistry. Results: The mesenchymal compartment of the diaphragm was intact and no herniations were observed in the embryos. By contrast, the skeletal muscle compartment of the diaphragm was significantly reduced in mdx:MyoD-/- 9'h embryos. No abnormalities in lung organogenesis were observed in mdx term embryos, whereas lung hypoplasia was detected in mdx:MyoD-l- 9'h embryos. In the hypoplastic lung, the number of proliferating lung cells was lower in comparison to the wild-type and mdx littermates, while the thyroid transcription factor- I (TTF-1) gradient was not maintained. Surprisingly, no difference was observed in the apoptotic lung cells distribution and occurrence in mdx:MyoD-!- 9thembryos. Conclusions: Together, it appears that mechanical forces generated by contractile activity of the diaphragm muscle play an important role in normal lung growth and development by affecting cell proliferation and TIF-1 expression.},
  note = {Poster},
}

@inproceedings{reyno2003influence,
  title = {The influence of Parental Factors on Recurrent Headache in Adolescents},
  author = {Reyno, Sandra},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Functional headache or headache not due to an identified organic cause is one of the most common somatic complaints in adolescents. Recurrent functional headache in adolescents is associated with a number of factors. These include child mental health factors (i.e., depression, anxiety), child demographic factors (i.e., gender, age), and familial factors (i.e., socioeconomic status, family headache history). Parental factors associated with recurrent functional headache in adolescents include parental encouragement of child illness behavior and parental modeling of illness behavior. It is not known how these parental factors impact on headache-related impairment (pain intensity), functional disability (restriction in performing social, academic, and physical tasks), or handicap (inability to fulfill social, academic, or physical roles). In the proposed research, an Internet-based study will be used to evaluate a model of headache in adolescents. The model will examine hypothesized relationships between parental factors and headache-related impairment, functional disability, and handicap in adolescents.},
}

@inproceedings{morris2003oops,
  title = {Oops, We Gave You the Wrong List: List-Method Directed Forgetting using Threat and Anxiety Related Words with Those High and Low in Social Anxiety},
  author = {Morris, Eric},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Directed forgetting is the conscious effort to forget information. Studies in this area typically use one of two methods to elicit the directed forgetting effect: the list method and the item method. The list method was used in the present study and involved presenting a list of neutral, positive, threatening and anxiety producing words and telling participants to either remember or forget the preceding list, followed by a free recall test. The first stage of the present study involves running normal controls in order to confirm that the program we created to produce the directed forgetting effect is effective. The talk will focus on this stage of the study. The second phase of the study will involve administering the program to high and low socially anxious individuals. The goals of the study are two-fold: To create a program that consistently produces the directed forgetting effect and to determine whether high or low socially anxious individuals have more or less trouble actively forgetting threat and anxiety related words.},
}

@inproceedings{douglas2003memory,
  title = {Memory for Details of Visual Scenes: The Role of Psychopathic Traits and Emotional Valence},
  author = {Douglas, Rebecca},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Emotion has been shown to play a complex role in memory. It appears that with emotional stimuli, central details are retained better than peripheral details, and that central details of emotional events may be retained better than those of non-emotional events. In contrast, individuals with psychopathic traits display virtually the same memory for central and peripheral details of emotional stimuli, and show no difference between memory patterns for emotional and neutral stimuli. However, as the majority of research with both individuals high in psychopathic traits and non-psychopathic populations has focused on negative emotional events, the degree to which these findings apply to positive stimuli is unknown. Thus, the objective of this study is to extend previous research findings concerning the influence of emotion on memory to positive stimuli. Also to be examined is the relationship that psychopathic traits may have with stimuli of negative, neutral and positive emotional content. Ninety participants will be assessed on their degree of psychopathic traits using the self-report Psychopathic Personality Inventory (Lilienfield & Andrews, 1996). A positive, negative and neutral scene, selected from the International Affective Picture System (Lang, Bradley & Cuthbert, 1999), will be presented to each participant. Participants will then be tested on their memory for central and peripheral details of each scene. The relationship between degree of psychopathic traits, emotional valence, and memory for central versus peripheral details will be examined. It is hypothesized that previous findings will be replicated, and that patterns demonstrated with negative stimuli may extend to positive stimuli.},
}

@inproceedings{hourihan2003does,
  title = {Does rehearsal time affect the way in which information is forgotten?},
  author = {Hourihan, Kathleen},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {The present experiment examined the effects of rehearsal time in an item method directed forgetting paradigm. Participants were presented with a list of words and were instructed to recall the words unless they received a forget cue, which occurred on half of the trials, at varying delays after word presentation. After studying the words, participants completed a recall test of all words (regardless of initial cue), a recognition test, and a second recall test. Results showed that while a directed forgetting effect was obtained for all three tests, the magnitude of the effect was reduced for the recognition and second recall test, and that words that received a forget cue at a longer delay were more frequently recalled than words that received the short delay. Results were discussed in terms of retrieval inhibition and selective rehearsal.},
}

@inproceedings{taylor2003role,
  title = {The role of spatial attention in directed forgetting: Take 1},
  author = {Taylor, Tracy},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {This study determined whether directed forgetting of peripherally presented words involves processes related to visuo-spatial attention. This was tested by examining the magnitude of inhibition of return at the location ofto-be-remembered and to-be-forgotten words. Using a modified item method paradigm, words appeared one at a time to the left or right, followed by a visual Remember or Forget instruction at center. A target dot was then presented either in the same peripheral location as the preceding word or in a different location; participants made a speeded response to localize this target. Despite the fact that a directed forgetting effect occurred for both recognition and recall, there was no effect of memory instruction on the magnitude of inhibition ofreturn (as measured by the reaction times to the subsequent targets). This suggests that information about the to-be-remembered and to-be-forgotten words is extracted independently of the spatial information that marks the presentation episode.},
}

@inproceedings{therrien2003role,
  title = {The role of spatial attention in directed forgetting: Take 2},
  author = {Therrien, Megan and Taylor, Tracy},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {This is a follow-up to a study by Taylor that indicated that directed forgetting of a to-be-forgotten word does not involve inhibition of that word's location. The present study attempted to replicate this result, using tones rather than visual stimuli to designate words as to-be-forgotten or to-be-remembered. Words appeared to the left or right, followed by a tone instructing participants to remember the word or to forget it. Participants then made a speeded response indicating the location of a target dot that appeared subsequently to the left or right. The magnitude of inhibition of return was evaluated at the location of both to-be-forgotten and to-be-remembered words. (At present, the results are unknown).},
}

@inproceedings{deurveilher2003how,
  title = {How coffee wakes up your brain: caffeine-induced activation of Arousal-Related Aminergic neurons in rat},
  author = {Deurveilher, Samuel and Murphy, Jeremy and Burns, Joan and Semba, Kazue},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Caffeine is the most widely used psychostimulant in the world. However, neuronal mechanisms mediating its stimulatory effect are not well understood. We recently reported, using c-Fos as a marker for neuronal activation, that psychostimulant doses of caffeine induce activation of hypocretin/orexin-containing neurons which play an important role in arousal. Here we examined whether other components of the arousal system, specifically aminergic neuronal groups, are also activated by caffeine, by using dual immunostaining for c-Fos and aminergic transmitter markers. We found that low locomotor-stimulant doses of caffeine (10 and 30 mg/kg, i.p.) increase Fos immunoreactivity in noradrenergic neurons in the locus coeruleus and histaminergic neurons in the tuberomammillary nucleus, as well as in orexin-containing neurons of the hypothalamus, but not in serotonergic neurons in the dorsal raphe nucleus. A higher, locomotor-depressant dose of caffeine (75 mg/kg, i.p.) induces c-Fos expression in all of these neurons. Dopaminergic neurons in the ventral tegmental area and substantia nigra did not respond to caffeine with changes in c-Fos expression. These results indicate that caffeine induces c-Fos expression differentially among aminergic arousal-related cell groups. The noradrenergic and histaminergic neurons and orexin-containing neurons which are activated at low doses of caffeine might play a role in mediating behavioral activation induced by caffeine. Tl 7)},
}

@inproceedings{poulin2003confocal,
  title = {Confocal Microscopic Analysis of the Colocalization of Vesicular Glutamate Transporters in Cholinergic Neurons of the Rat Basal Forebrain: Do cholinergic neurons release glutamate?},
  author = {Poulin, Amanda and Semba, Kazue},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {In addition to its well known role in cognition, the basal forebrain (BF) is implicated in the regulation of behavioural state. Neurochemically, these functions have been attributed primarily to the cholinergic, and to some extent, the GABAergic neurons in this brain region. Recent evidence also suggests the involvement of a glutamatergic system within the BF. Glutamate may act as a major transmitter in the BF, and may also be co-released from a subpopulation of cholinergic BF neurons. We examined the possibility of glutamate colocalization in BF cholinergic neurons by using antibodies to vesicular acetylcholine transporter and vesicular glutamate transporters (VGluT)-1/2/3, three recently identified transporters responsible for glutamate uptake into synaptic vesicles. Confocal microscopy was used to examine coimmunofluorescence for VAChT and VGluT 1/2/3 in the cell bodies of BF cholinergic neurons and their terminals in selected target areas. In the BF, scattered neurons in the horizontal limb of the diagonal band, ventral pallidum, substantia innominata, and globus pallidus were immunoreactive (ir) for both VAChT and VGluT3; however, no cell bodies in the BF were double-labeled for VGluTl/2 and VAChT. No fibers or terminals in the motor, somatosensory, piriform and entorhinal cortices were coimmunoreactive for VGluTl/2/3 and VAChT; similarly, VAChT-ir terminals within the BF were not VGluTl/2/3-ir. The reticular nucleus of the thalamus, which receives cholinergic projections from the BF, was also devoid of coimmunofluorescence for VAChT and VGluTl/2/3. In some of the above areas with cholinergic innervation, VGluTl/2/3-ir and VAChT-ir terminals were segregated in distinct patterns, whereas in others they were intermixed. These results suggest that VGluT3 is present in a small population of cholinergic BF neurons. The presence of VGluT3 in a subpopulation of BF cholinergic neurons suggests that terminals of some BF cholinergic neurons might release both acetylcholine and glutamate. Tl8) Mothers' Views about Stress and Depression Marie-josee Lefaivre Despite the fact that depression is a prevalent mental health problem in women, very little is actually known about women's views and opinions regarding stress and maternal depression. A few qualitative studies suggest that women in rural communities tend to normalize their depressive experiences by seeing it as part of their lives as mothers and housewives. Other studies indicate that these women are more likely to present somatic symptoms associated with depression or distress. Previous research also suggests that individuals often characterize their depression},
  note = {QA: needs-split-review; Split from T16 at: 'Confocal Microscopic Analysis of the Col'},
}

@inproceedings{lefaivre2003mothers,
  title = {Mothers' Views about Stress and Depression},
  author = {Lefaivre, Marie-josee},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Despite the fact that depression is a prevalent mental health problem in women, very little is actually known about women's views and opinions regarding stress and maternal depression. A few qualitative studies suggest that women in rural communities tend to normalize their depressive experiences by seeing it as part of their lives as mothers and housewives. Other studies indicate that these women are more likely to present somatic symptoms associated with depression or distress. Previous research also suggests that individuals often characterize their depression symptoms as part of a physical illness as a result of stigma and that perceived stigma constitutes a barrier to seeking help and to treatment adherence. Consequently, a better understanding of mothers' perception towards depression and social stigmas could be beneficial given that these perceptions are reflected in their coping skills including help-seeking behaviours. The goal of the following research project aims at examining (1) rural and urban mothers' views about depression and its symptoms, (2) their awareness of depression indicators, (3) their causal belief about maternal depression and (4) their perception of social stigma associated with this mental health issue. Mothers ( 19 to 49 years of age) randomly selected from the Nova Scotia Atlee Perinatal Database will be invited to participate in this study. This research is being conducted within the Maternal Depression Project of the Family Help Program: Bringing Health Home (Pediatric Pain Lab, IWK Health Centre) and in collaboration with the Reproductive Care Program.},
}

@inproceedings{stewart2003music,
  title = {Music, Mood and Booze: Activation of implicit alcohol cognition in coping and enhancement motivated drinkers.},
  author = {Stewart, Sherry and Birch, Cheryl and Eisnor, Shondalee and Theakston, Jennifer},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Cooper's (1994) model of drinking motivations distinguishes between two groups of drinkers at risk of drinking problems - those who drink to enhance positive mood and those who drink to cope with negative mood. We investigated whether these groups differ in their activation of implicit alcohol cognition following mood induction. Participants were 86 undergraduates with elevated scores on the Enhancement or Coping Motives (EM or CM) subscale of the Drinking Motives Questionnaire. Participants in each motive group were randomly assigned to a musically-induced positive or negative mood condition. A modified Stroop (1935) task, involving color-naming of alcohol and non-alcohol control words, was administered following mood induction. As hypothesized, EM drinkers in the positive (but not negative) mood condition showed significantly longer color-naming speeds for alcohol vs. control words indicating interference in color-naming by the content of the alcohol words. Even though CM drinkers in the positive mood condition did not show evidence of selective processing of alcohol cues (as expected), CM drinkers in the negative mood condition also failed to show evidence of alcohol interference. Overall, CM drinkers showed significantly longer color-naming latencies than EM drinkers suggesting possible ceiling effects in the CM group. Theoretical and clinical implications will be discussed. New poster Pl I)},
}

@inproceedings{luchtman2003how,
  title = {How do different mouse strains differ on measures of locomotion, exploration, anxiety, learning and memory?},
  author = {Luchtman, Dirk and Brown, Richard},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Transgenic mouse models of human diseases provide an animal model for understanding the underlying mechanisms of these diseases. It is hoped that, eventually, these models will translate into new treatments of human (neurological) diseases. Researchers are assembling test batteries in order to compare behavioral expressions of transgenic and mutant mice. The data that is produced in these experiments can be used to build up electronic databases, like the Mouse Phenome Database of the Jackson Laboratory. As part of the Phenome Project, we are investigating the behavioral differences in 5 strains of mice: SPRET/Ei, MOLF/Ei, C3H/HeJ, SJL/J and A/J. We are testing these mice for anxiety-like behaviors on the elevated plus maze, and light-dark box; locomotion and exploration in the open field; motor learning on the rotarod; and spatial learning in the Barnes maze and Morris water maze. We are also testing these mice for olfactory discrimination learning and visual acuity. Our poster compares the 5 strains of mice on these behaviors and examines the influence of body weight, anxiety, exploratory behavior and visual acuity on performance in tests of learning and memory.},
  note = {QA: needs-split-review; Split from T19 at: 'How do different mouse strains'},
}

@inproceedings{harker2003neuropsychol,
  title = {Neuropsychological Assessment of Memory using Event-Related Potentials},
  author = {Harker, Troy and Connolly, John},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {The use of cognitive event-related potential recordings (ERP) in conjunction with standardized neuropsychological testing instruments provides a useful, non-invasive clinical tool for investigating and measuring the cognitive abilities of non-communicating clinical populations. In light of previous success using this approach with respect to speech and language processing, the goal of the present study was to determine if neuropsychological tests of higher-order cognitive functions such as learning and memory could also be successfully adapted for ERP presentation. Thirty undergraduate students (15 male, 15 female) will be tested on both the regular and the ERP adapted version of one to two standardized neuropsychological tests. ERP results will be examined to identify possible characteristics that can differentiate between correct and incorrect responses. Performance on the ERP version will also be cross-validated with performance on the standardized version of the test to determine concurrent validity. Results will be discussed in terms of both the potential clinical utility of the ERP adapted tasks as well as the important insight into the neurophysiological mechanisms, by which individuals accomplish such memory tasks, afforded by the ERP component patterns.},
}

@inproceedings{walker2003hear,
  title = {Hear no consonant. Speak no consonant. Read no consonant.},
  author = {Walker, Kerry},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {People show great variation in their language and reading proficiency, even within the normal population. Historically, language function was viewed as somewhat separate from basic perceptual and cognitive processes. Some experts now suggest that problems with auditory and visual perception underlie language disorders. In particular, dyslexia has been theorized to be a temporal processing disorder, in which children cannot normally perceive auditory and/or visual events that occur quickly in time. Over the past 15 years, many studies have provided empirical support for this theory of language function, but most of this research has specifically targeted highly-selected and clinically-impaired children or adults. Therefore, the present study will aim to identify the basic perceptual skills that are most highly correlated with language and reading abilities in normal subjects (ages 6 to 17). The same subjects will complete various tests of auditory and visual temporal processing, language, and reading performance. Statistical analysis will then identify the basic perceptual skills that covary with language and reading proficiency. This research will help us understand the development of language in the general population, and will have implications for the treatment of developmental language delay in children. T2 l)},
}

@inproceedings{wong2003behavioral,
  title = {Behavioral assessment of visual discrimination, pattern discrimination and visual acuity in seven strains of mice},
  author = {Wong, Aimee A. and Brown, Richard E.},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Previous research has demonstrated that mice are capable of brightness discrimination and visual pattern discrimination and that it is possible to quantitatively determine the visual acuity of the mouse. Based on the procedure of Glen Prusky (Prusky et al., 2000, Vision Research, 40, 2201- 2209), we have developed a protocol using a computer-based, two-alternative swim task that evaluates visual discrimination, pattern discrimination and visual acuity in one apparatus. Seven strains of mice (BALB/cByJ, C3H/HeSnJ, C57BL/6J, Coloboma, DBA/2J, FVB/NJ and MOLF/Ei) were tested on 8 trials/day for 8 days on each of the three tests. There was a significant strain difference in visual ability in all three tests. Mice with normal vision (C57BL/6J and DBA/2J) performed very well in these tasks. Mice with poor vision (BALB/cByJ) took longer to learn the tasks than mice with normal vision and mice with retinal degeneration (C3H/HeSnJ, Coloboma, FVB/NJ, MOLF/Ei) performed only at chance levels. Because measures of leaning and memory on visuo-spatial tasks may be affected by visual ability, we correlated performance in the Morris Water Maze with the visual acuity of each strain. We found that visual acuity was significantly correlated (r = -0.998) with the latency to find the platform in the Morris Water Maze. This suggests that the visual ability of each strain is a confounding variable in visuo-spatial learning and that visual acuity, rather than spatial memory capability, may account for some of the strain differences in mice in the Morris Water Maze.},
  note = {QA: needs-split-review; Split from T20 at: 'Behavioral assessment of visual discrimi'},
}

@inproceedings{coolican2003investigatin,
  title = {Investigating Spatial Biases in Face Perception},
  author = {Coolican, Jamesie and BSc and Eskes, Gail and Ph.D},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {We were interested in the reported left-sided perceptual bias in interpreting facial emotion and in facial recognition. Our purpose was to replicate the reported bias in normal subjects and to examine whether this phenomenon was related to global/holistic face processing per se. Twenty- one undergraduate students participated in the study. In Study 1, subjects were shown chimeric faces created by combining half of a smiling face and half of a neutral face. They were asked to judge which of two faces (smile on left vs smile on right side of the face) was "happier". Results showed a strong bias for judging the face with the left-sided smile as happier. In a second condition, the chimeric faces were inverted. The left-sided bias in emotion judgement remained, suggesting this judgement was not based on global face processing. In Study 2, composite faces from the left or right side of a neutral face were created and the subjects were asked to identify which composite most nearly matched the original face. In this case, a significant (but smaller) left-sided bias for matching a composite was seen. In addition, top faces were significantly more likely to be judged as more similar to the original than bottom faces, suggesting the recognition process was related to vertical spatial position of the face as well. When the faces were inverted, vertical spatial position ceased to affect judgements, while the left-sided bias remained. Implications of these findings for neurocognitive models of face processing will be offered for discussion. T23) How to Grow up and be normal: Lessons from the visual system and accenture. It is not the variety or amount of early experience you have, it's the proportion that is normal that makes good things happen. Donald Mitchell and Marc Jones Although a number of key features of the anatomical and physiological organization of the central visual pathways of higher mammals can be remarkably well developed at birth, others achieve their adult status more gradually. Nevertheless, even those characteristics that appear remarkably mature at birth, such as the segregated pattern of ocular dominance observed in the granular layer of the visual cortex (area 17) of monkeys, as well as those that appear less developed, can change in a dramatic fashion in response to abnormal visual input imposed during documented sensitive periods in early postnatal life. The cortical changes induced by such selected early visual exposure can be accompanied by profound and long-standing visual deficits. In this study we demonstrate that with respect to form vision, normal visual input is weighted far more strongly during development than is biased visual exposure such that 2 hours of normal visual exposure each day},
  note = {QA: needs-split-review; Split from T20-split1 at: 'T22) Investigating Spatial Biases in Fac'},
}

@inproceedings{coolican2003investigatina,
  title = {Investigating Spatial Biases in Face Perception},
  author = {Coolican, Jamesie and BSc and Eskes, Gail and Ph.D},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {We were interested in the reported left-sided perceptual bias in interpreting facial emotion and in facial recognition. Our purpose was to replicate the reported bias in normal subjects and to examine whether this phenomenon was related to global/holistic face processing per se. Twenty- one undergraduate students participated in the study. In Study 1, subjects were shown chimeric faces created by combining half of a smiling face and half of a neutral face. They were asked to judge which of two faces (smile on left vs smile on right side of the face) was "happier". Results showed a strong bias for judging the face with the left-sided smile as happier. In a second condition, the chimeric faces were inverted. The left-sided bias in emotion judgement remained, suggesting this judgement was not based on global face processing. In Study 2, composite faces from the left or right side of a neutral face were created and the subjects were asked to identify which composite most nearly matched the original face. In this case, a significant (but smaller) left-sided bias for matching a composite was seen. In addition, top faces were significantly more likely to be judged as more similar to the original than bottom faces, suggesting the recognition process was related to vertical spatial position of the face as well. When the faces were inverted, vertical spatial position ceased to affect judgements, while the left-sided bias remained. Implications of these findings for neurocognitive models of face processing will be offered for discussion.},
}

@inproceedings{mitchell2003how,
  title = {How to Grow up and be normal: Lessons from the visual system and accenture. It is not the variety or amount of early experience you have, it's the proportion that is normal that makes good things happen.},
  author = {Mitchell, Donald and Jones, Marc},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Although a number of key features of the anatomical and physiological organization of the central visual pathways of higher mammals can be remarkably well developed at birth, others achieve their adult status more gradually. Nevertheless, even those characteristics that appear remarkably mature at birth, such as the segregated pattern of ocular dominance observed in the granular layer of the visual cortex (area 17) of monkeys, as well as those that appear less developed, can change in a dramatic fashion in response to abnormal visual input imposed during documented sensitive periods in early postnatal life. The cortical changes induced by such selected early visual exposure can be accompanied by profound and long-standing visual deficits. In this study we demonstrate that with respect to form vision, normal visual input is weighted far more strongly during development than is biased visual exposure such that 2 hours of normal visual exposure each day can outweigh much longer periods of deprivation so as to permit the development of normal vision in both eyes. This result is not what would be expected by a passive process whereby neural connections are continually shaped or refined in response to the integrated visual input during the appropriate sensitive period, but instead suggest a process which effectively responds preferentially to normal input.},
}

@inproceedings{phillips2003take,
  title = {Take the HINT. Actually, Scratch That. Don't Take the HINT. Or if You Do Take the IDNT, Rotate Your Chair 45 Degrees.},
  author = {Phillips, Dennis P. and Vigneault-MacLean, B. and Boehnke, S.E. and Hall, S.E.},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {One of the most common problems encountered by persons with or without hearing loss is a poor ability to discriminate speech that occurs against noisy backgrounds. A clinical test (the Hearing In Noise Test, HINT) has been developed to measure the perceptual benefit obtained in speech discrimination achieved by having a 90-degree azimuthal (eccentricity) separation of speech and concurrent noise. The noise is presented from straight ahead, and the speech signal is presented either from the same location, or from 90 degrees into the left or right auditory hemifield. The "release from masking" effected by the 90-degree spatial separation is reported to average about 6-7 dB. Our lab previously showed that the human perceptual system has channels for auditory azimuth that are hemifield in configuration (Boehnke & Phillips, 1999). The HINT does not exploit this knowledge. We'd expect the maximum benefit of a 90-degree separation to occur when speech and noise are presented in different hemifields, and the minimum benefit to occur when the sounds are presented in a single auditory hemifield. The HINT does not employ either of these configurations. In the present study we show, using the HINT stimulus materials, that spatial release from masking can be increased to about 8.6 dB, or reduced to 1.3 dB, simply by locating the speech and noise sources in opposite hemifields or in the same hemifield, respectively, while maintaining the 90 degree azimuthal separation. The HINT configuration produced an intermediate (6.05 dB) release from masking. These data may be useful to clinicians wishing to enhance the effect size of the existing HINT. The data also provide a new corollary of the tuning of human spatial perception mechanisms, which was originally derived from auditory temporal gap detection studies.},
}

@inproceedings{franklin2003ovarian,
  title = {Ovarian Hormones and Acute Restraint Stress Interact to Modulate BDNF Protein Levels in Rat Brain},
  author = {Franklin, Tamara and Perrot-Sinai, Tara},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Abnormal levels of brain-derived neurotrophic factor (BDNF) are associated with major depression, a disorder with a higher incidence in women than men. Stress affects BDNF levels in various brain regions and thus, a heightened stress response in females could contribute to the development of depression. As well, ovarian hormones directly affect brain levels of BDNF RNA and protein. The present experiment investigated the interaction between stress and ovarian hormones on BDNF protein levels in the hippocampus (CAI) and paraventricular nucleus of hypothalamus (PVN). Forty-six female Sprague-Dawley rats were ovariectomized; half received one hour of restraint stress while the other half received control handling prior to sacrifice. Stressed and handled groups received a single injection of either estrogen (E; 48 h prior to sacrifice), estrogen and progesterone (EP; P given at 53 hand E given at 48 h prior to sacrifice) or vehicle (OVX). BDNF protein was quantified using an enzyme-linked immunosorbent enzyme assay (ELISA). In the CAI, there was significantly more BDNF in the EP group compared to E and OVX groups. Relative to handled controls, BDNF levels were slightly elevated in OVX-stressed rats but significantly reduced in E-stressed rats. In the PVN there was significantly less BDNF in both E and EP groups compared to OVX rats but there was no effect of stress and no interaction between hormones and stress in this region. Thus, in some stress- sensitive brain regions, the presence of estrogen alters stress-induced changes in BDNF levels. Studies are currently underway to examine the effects of ovarian hormones on BDNF protein in other brain regions involved in stress.},
}

@inproceedings{bain2003effects,
  title = {Effects of restraint stress exposure on hippocampal neurogenesis in rats and mice.},
  author = {Bain, Megan},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Neurogenesis in the dentate gyms of the hippocampus persists during the adult life of many species, including mice, rats, monkeys, and humans. There are many factors that regulate neurogenesis; however, stress exposure is of particular interest because of its role in human anxiety and depressive disorders. This study investigated the effects of acute restraint stress exposure on hippocampal neurogenesis in rats and mice. Male Sprague-Dawley rats and CD57BL/6 mice were injected with bromodeoxyuridine (BrdU), a marker of neurogenesis, followed by 3 h of restraint stress via confinement to a small container. Using immunohistochemistry, cell proliferation was assessed by measuring the number of BrdU- labeled cells in the dentate gyrus. To determine whether this restraint stress evoked a typical stress response in these species, we also examined the number of c-Fos-labeled cells in the paraventricular nucleus of the hypothalamus (PVN), a brain area known to be activated during stress. The results show that acute restraint stress significantly inhibited hippocampal cell proliferation in rats, as compared to unstressed controls. In contrast, acute restraint stress in mice resulted in increased hippocampal cell proliferation, relative to that seen in unstressed mice. Restraint stress activated the stress response in both species, as indicated by a significant increase in c-Fos immunoreactivity in the PVN. These results suggest that hippocampal neurogenesis in response to stress exposure is differentially regulated in the rat and mouse. Examining the differences between mouse and rat cell proliferation in response to stress may provide useful information on the mechanisms that regulate neurogenesis and a better understanding of the failures of neurogenesis that may underlie various pathological conditions.},
}

@inproceedings{johnson2003effects,
  title = {Effects of repeated and acute corticosterone on phosphorylated camp response element binding protein in the rat hippocarnpus.},
  author = {Johnson, Sarah and Gregus, Andrea and Davis, Alica and Wintink, Amanda and Kalynchuk, Lisa},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Chronically elevated glucocorticoid levels have been linked to stress-related disorders such as depression and physiological changes within the hippocampus including decreased neurogenesis and neuronal remodeling. These physiological changes may result from decreased cAMP and MAP kinase intracellular cascade activity following repeated exposure to high levels of glucocorticoids over a prolonged period of time. The effects of chronic vs. acute increases in glucocorticoids on cAMP cascade proteins in the hippocampus are currently unknown. Accordingly, the current study assessed the effects of chronic vs. acute corticosterone (CORT) exposure on phosphorylated cAMP response element binding protein (pCREB) as a marker for changes in cAMP and MAP kinase intracellular cascades in the male rat hippocampus. Rats received either a single CORT (40mg/kg s.c.) or vehicle injection every day for 21 consecutive days. An additional two groups of rats were handled every day for 20 days and received a single CORT or vehicle injection on day 21. Rats were perfused intracardially 48 hours after the final injection, and hippocampal tissue was immunohistochemically labeled for pCREB. Results are considered in the context of stress and glucocorticoid-based models of depression.},
}

@inproceedings{bernier2003what,
  title = {WHAT IF ... you do faint in front of the whole class?? SO WHAT! ... On your wedding day, you will not remember},
  author = {Bernier, Denise and Watt, Margo and Stewart, Sherry and Birch, Cheryl},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {We conducted a brief cognitive behavioral (CBT) group intervention with first year undergraduate female students. Our objectives were twofold. First, we attempted to replicate the findings of other studies that have examined the efficacy of a brief CBT for panic disorder. We also extended the earlier work by examining, in a non-clinical population, the efficacy of this treatment on lowering levels of anxiety sensitivity, which is a known and established risk factor for the development of anxiety disorders. Secondly, we intended to lay the groundwork for the development of an intervention manual designed for use with groups of high anxiety sensitive university students. Preliminary data will be presented, illustrating the effects of this approach on levels of anxiety sensitivity.},
}

@inproceedings{time2003oxytocin,
  title = {Oxytocin in the Plasma and Cerebrospinal Fluid of Male Rats: Effects of Circadian},
  author = {Time, Light and Stress},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Karthika Devarajan & Benjamin Rusak Oxytocin (OXT), a neuropeptide known to be involved with reproductive and social behaviours, has also been implicated in responses to stress and depression. Past work has shown that OXT is regulated by circadian phase in the brain, plasma and CSP of monkeys; however, circadian regulation of OXT expression has only been reported in the brain and plasma of the rat. In the present study, we examined the effects of 30 min light pulses at two different circadian phases (mid subjective day and late subjective night) on OXT in circulating plasma, cerebrospinal fluid (CSP) and hypothalamic tissue adjacent to the third ventricle. An enzyme immunoassay was used to measure OXT levels in the plasma and CSP, while immunoreactivity was studied in the hypothalamus. We found that the previously reported circadian difference in plasma OXT levels in the rat disappears when the rats have been previously habituated to handling and injections. Therefore, we speculate that the previously reported OXT rhythm in rat plasma may actually reflect a stress response to experimental procedures expressed selectively at some circadian phases. We also showed for the first time that circadian phase and brief light pulses significantly affect OXT levels in the CSF of the rat.},
}

@inproceedings{service2003phoneme,
  title = {Phoneme-level information in short-term memory for wordlike items},
  author = {Service, Elisabet},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Verbal short-term memory has in the majority of studies been investigated as the capacity for immediate ordered reproduction of a series of words, letters or digits. In three studies, we explored memory and forgetting of sub-lexical units, for instance syllables and single phonemes, in pseudowords. Our studies suggest that immediate recall is affected by information representations on different layers of phonological complexity (whole words, as well as syllables and single vowels and consonants). Poor phonological memory, linked to developmental dyslexia and language learning difficulties, can result from poor encoding or storage of traces on these sub-lexical levels, leading to unsuccessful retrieval of whole words at recall. Poor representations on the sub lexical level can also be revealed in ERP studies of tasks relying on precise phonological representations.},
}

@inproceedings{shaw2003discriminati,
  title = {Discriminating diode detector demystifies disquieting doubts documenting dyed dextrans' diffusional dribble.},
  author = {Shaw, Steve and Frohlich, Ami},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {The insect blood-brain barrier offers a unique model system in which to explore the evolutionary progression of glial function in the CNS. The barrier resides in a superficial layer of glial cells covering the CNS. The powerful barrier in advanced insects like Diptera (flies) evolved from a barrier-less precursor state present in insects' crustacean ancestors, somewhere back around the Carboniferous. We've been looking for the evolutionary step at which an effective barrier first appeared. A place to start might be the present-day CNS of the alleged Most Primitive Living Insect, a wingless bristletail that inhabits local sea cliffs and looks similar to domestic silverfish. A way to probe the barrier is to inject a tracer into the blood and follow it to see if it gets into the CNS quickly. The tracer of choice has been lanthanum, which can be localized in the electronmicroscope. It seems to be largely excluded from the bristletail' s CNS, pointing to the emergence of some sort of a barrier very early on in insects. A major drawback to using lanthanum is that its detection threshold is very high, perhaps l part in 10: if it were able to diffuse into the CNS to achieve a concentration up to 10 percent of that in the blood, even this high level could not be detected reliably. We therefore explored whether the detection limit can be lowered significantly by switching to dextrans as light microscope tracers. These inert bacterial polysaccharides are available with fluorescent labels in a range of molecular weights. Our dextrans do appear to be completely excluded by the fly's CNS barrier, gauged by visual observation. We have developed a new approach to quantifying this exclusion, using optical averaging on thin sections of the CNS, measured with a computerized microfluorometer which improves the detection limit markedly. In the fly's CNS, the brightest dextran was excluded from the CNS to better than one part in several thousand, after correcting for the limiting background autofluorescence of the neural tissue. The bristletail' s CNS fared much worse when tested with dextrans and appeared quite leaky, somewhere between the extremes of crustaceans and advanced insects. Overall, dextrans emerge as the tracers of choice for probing such barrier systems, where extreme fine-structural localization is not required. POSTERS},
}

@inproceedings{dukewich2003limiting,
  title = {Limiting the number of inspections during a difficult search task: Implications for the seriality of search},
  author = {Dukewich, Kristie and Klein, Dr. Ray},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Treisman and Gelade ( 1980) changed the literature on visual search when they made the distinction between feature search and conjunction search. Serial search is inferred from a linear increase in reaction times as set size increases. Triesman and Gelade's Feature Integration Theory (FIT) accounts for this by assuming that attention is required to glue together the features of a conjunction target, making serial inspection necessary to find the target. Recent challenges to this view suggest that conjunction search uses both serial and parallel processes to localize the target. If serial self-terminating search is responsible for the linear functions found in conjunction search tasks, then accuracy on a task that limits display duration should be predictable based on search rates estimated from slopes obtained from a typical, long display duration task. We found that people are not limited by typical conjunction search rates, and are able to extract more information than predicted by the serial search model. Our results converge with other challenges to a strictly serial self-terminating inspection process, and point to the likelihood of a hybrid model wherein serial and parallel mechanisms operate in tandem during difficult searches.},
}

@inproceedings{barresi2003from,
  title = {From "Nobody Nowhere" to "Somebody Somewhere": A case study in the phenomenology of autism and of the discovery of the interpersonal world.},
  author = {Barresi, John},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {In three astonishing autobiographies, Donna Williams describes a phenomenological journey from her own private world of childhood autism to her adult discovery of - and eventual entry into - the interpersonal world. In this talk, I will analyze these autobiographies with a focus on the transformations in Williams' experience and understanding of self and other and of the role that her body plays in her discovery of and entry into the interpersonal world. In order to enter this world that unifies self and other, she has to overcome the alternating perspectives of the first- and third-person worlds of her earlier experiences, where Donna-for-others differed from Donna-for-self. Since the battle ground of this opposition between the two worlds is her own body, a major part of her transformation involves a process by which Donna comes to experience her self as a unified person who is both owner & agent of her body. Only once she has done this can she enter freely into an interpersonal world with other embodied agents and persons.},
}

@inproceedings{lewis2003elucidating,
  title = {Elucidating the link between bullying, mood and self-injury among young people},
  author = {Lewis, Stephen},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Self-injurious behaviour (SIB) can be best understood as intentionally harming oneself (e.g. cutting) in order to provide rapid, albeit ephemeral, relief from psychological turmoil (Briere & Gil, 1998; Favazza, 1996, 1998). Typically, SIB onsets during adolescence and persists well into adulthood if left untreated. The plight of SIB carries with it many risks, including serious injury, and accidental or intentional suicide, all of which accentuate the psychological pain of the self- injurer (Favazza, 1998). Though precise aetiologies for SIB remain elusive, several correlates have been identified. For instance, it is well accepted that abuse associates with SIB (Lipshitz et al., 1999). It is also well accepted that abuse associates with mood problems (Andrews, 1995; Browne & Finkelhor, 1986). Taken together, it is interesting to speculate how abuse and mood are associated with SIB. Specifically, it is interesting to consider bullying as a form of abuse due to its ubiquity amongst young people (Bond et al., 2001; Nansel et al., 2001) and its association with mood disturbances (Bond et al., 2001). Despite this relationship, little work has been done to investigate bullying and SIB. The dearth of work completed suggests that bullying may be a correlate of SIB (Bhugra et al., 2002; Davies & Cunningham, 1999). In sum, little is known about the link between bullying, mood and SIB. As a result, the present study aims to elucidate this link by regressing these variables in order to construct a mediational model. Findings, clinical implications and directions for future research will be discussed.},
}

@inproceedings{good2003functional,
  title = {Functional Magnetic Resonance Imaging of the Olfactory System in patients with First Episode Psychosis: Preliminary Data from a Normosmic Subgroup},
  author = {Good, Kimberley P. and Schellinck, Heather and Gates, Larry and Brown, Richard and Boudreau, Sarah and Choo, Sheldon and Haacke, E. Mark and Kopala, Lili},
  booktitle = {29th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2003},
  abstract = {Classical neuroanatomic techniques and lesion studies have well delinated the neural substrates involved in olfactory processing. Functional imaging has extended these findings by allowing the identification of brain regions engaged by different cognitive-olfactory tasks. The purpose of this ongoing study is to use FMRI to examine the functional topography of the olfactory system in patients with first episode psychosis and healthy control subjects. Fourteen normosmic subjects participated: 8 healthy controls and 6 patients with DSM-IV confirmed diagnosis of schizophrenia. A manually-controlled olfactometer delivered the stimulus (amyl acetate) to the subjects during the FMRI scan. Twenty six second on-off epochs (5 odour, 4 no- odour) were presented. As predicted, healthy control subjects demonstrated activity in previously defined olfactory regions (left superior, middle and inferior frontal gyri, right orbitofrontal cortex, and right inusla). Activation in left basal ganglia and left superior temporal gyms was also observed. Patients demonstrated activity in the left superior frontal gyms and posterior cingulate. In this preliminary dataset, secondary olfactory cortices did not show the predicted activity in the patient sample in response to the presented odour. As patients with psychosis have been documented with olfactory identification deficits (OID), these data broaden our understanding of the functional brain abnormalities in these patients. Further research by our lab will examine cognitive-olfactory tasks in psychosis patients with confirmed OID.},
}

@inproceedings{currie2004behavioural,
  title = {Behavioural and histological analysis of the effects of mup75-saporin in an effort to create a mouse model of Alzheimer's Disease},
  author = {Currie, Lisa M. and Brown, Richard E.},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {A loss of cholinergic cells in the basal forebrain produces memory deficits similar to those in Alzheimer's Disease (AD) (Francis, P.T. et al., 1999, J. Neurol. Neurosurg. Psych., 66, 137-47). Following injection of 192-IgG saporin, a neurotoxin targeting p75 cells in the cholinergic basal forebrain, into the medial septum, rats have a deficit in spatial working and reference memory (Shen, J. et al., 1996, Behav. Neurosci. 110, 1181-86). The destruction of cholinergic cells in the mouse brain using mup75-saporin (a mouse version of 192 IgG saporin) resulted in a dose-dependant cell loss in the medial septum, and deficits in spatial learning in the Morris Water Maze (Berger-Sweeney, J. et al., 2001, J. Neuroscience, 21, 8164-73). Our study extended that of Berger Sweeney et al., (2001) with a more comprehensive analysis of behavioral deficits associated with the injection of mup75-saporin. Using the results of Berger-Sweeney et al., (2001). One of three doses of mup75 saporin (3.6 μg/μl, 1.8 μg/μl, 0.9 μg/μl, or a PBS control) was infused bilaterally into the lateral ventricles of male C57BL/6J mice using a 30 gauge Hamilton syringe. Starting 15-20 days after drug injection, the mice were tested in the Open Field, Elevated Plus Maze, Beam Walking, Rotarod, Morris Water Maze, and a modified win-shift paradigm of the Radial Arm Maze. Following behavioral testing, the mice were inter-cardially perfused using 4% paraformaldehyde in PBS, and the brain tissue was retrieved, and stained for VachT, AchE, and Nissl. Behavioral analysis indicated no significant effects of mup75-saporin across tasks. However, when body weight was used as a covariate in the Radial Arm Maze, group differences were found on performance measures (latency and total arm entries). Cell counts in the nucleus basalis magnocellularis indicated no significant cell loss due to mup75- saporin. A difference of fiber density in the hippocampus was found between the control and drug groups indicating damage to the septo-hippocampal pathway. Analysis of the superficial layer of Purkinje cells in the cerebellum found no difference across drug groups, indicating that the toxin did not affect the cerebellum. These results indicate that mup75-saporin caused very little cell loss in the nucleus basalis magnocellularis and cerebellum and very few behavioural deficits. It is hypothesized that there may not be as many p75 cells in the mouse brain as in the rat. In addition, other neurotransmitter pathways may be compensating for any cell damage caused by the neurotoxin.},
  note = {Poster},
}

@inproceedings{williamson2004potentially,
  title = {Potentially protective effects of Ritalin},
  author = {Williamson, Martin and Brown, Richard E.},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Methylphenidate (MPH, Ritalin), a central nervous system stimulant, is widely used for the treatment of Attention-Deficit Hyperactivity Disorder (ADHD), a chronic childhood disorder with a prevalence of 3 to 6% in school-aged children. In recent years, the therapeutic use of MPH for the management of ADHD has increased substantially in children and also in adults. Furthermore, as MPH is increasingly prescribed to adult women to treat ADHD, there is an increasing danger of taking MPH during pregnancy. Little is known about the effects of MPH during pregnancy, therefore in this study, pregnant C57BL/6J mice were given daily sub cutaneous injections of MPH (5 mg/kg) or saline during embryonic day 4 to 18. Since postnatal environmental enrichment can exert profound and positive neurobehavioural changes in animals, pups were reared in an enriched or isolated environment. On postnatal day 60, the pups underwent behavioural testing in the elevated plus maze, open field, rotarod and Morris water maze. Prenatal MPH exposure caused lasting changes in behaviour, illustrated by decreases in emotionality and increases in exploration and locomotion, while having no effect on motor and spatial learning performance. Pups reared in an enriched environment showed similar reductions in emotionality, and increased exploratory and locomotor behaviour, combined with improved spatial learning performance. Of particular interest is the finding that the effect of prenatal MPH injections on behaviour is similar to that of environmental enrichment. Future studies will focus on the mechanisms mediating the behavioural alterations and the potential stimulating or protective role of enrichment and stimulant drugs such as MPH.},
  note = {Poster},
}

@inproceedings{butler2004gradients,
  title = {Gradients of attention in visuo-spatial neglect after right hemisphere stroke},
  author = {Butler, Beverly and Eskes, Gail},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {According to Kinsbourne's theory of attention, the two hemispheres of the brain contain opponent, mutually inhibitory vectors to direct attention to different spatial locations; the left hemisphere vector directs attention to the right side of space, while the right hemisphere vector directs attention to both sides of space. Thus, left-sided neglect occurs when the right hemisphere is damaged, resulting in an impaired leftward attentional vector and a disinhibited rightward attentional vector. This theory also suggests that individuals with neglect will show a linear gradient of decreasing attention from right to left. The present study investigated whether individuals with neglect show attentional gradients in both peripersonal space (within arms reach) and extrapersonal space (beyond arms reach). Subjects with right hemisphere damage with or without neglect, and healthy controls searched for visual targets on matched sheets placed in peripersonal and extrapersonal space. A right-to-left gradient of decreasing target detection was seen in both peripersonal and extrapersonal space in the neglect group, but not in the control groups. Double dissociations of gradients in peripersonal and extrapersonal space were also found. These results support Kinsbourne's theory and suggest independent neural mechanisms of attentional control in the right hemisphere related to spatial reference planes.},
  note = {Poster},
}

@inproceedings{mirkovic2004expression,
  title = {Expression pattern of neurotrophic factors and their receptors in the nervous system that develops in the absence of skeletal myogenesis},
  author = {Mirkovic, Slobodan and Gupta, Jagdish and Belliveau, Anne C. and Kablar, Boris},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {It is well established that during development motor neurons compete for their target, the skeletal muscle, to avoid programmed cell death. Human disorders characterized with motor control disturbances and human muscular diseases provide some evidence for that. However, it is still largely unclear whether any of the neurotrophins are of unique importance in preventing the death of developing motor neurons. We employed wild-type and Myf-5-/-:MyoD-/- embryos (that completely lack skeletal muscle) to test in vivo muscle-related neurotrophic requirements of skeletal muscle associated neurons [i.e., MMC (median motor column) and LMC (lateral motor column) motor neurons in the spinal cord and proprioceptive neurons in the dorsal root ganglia (DRG)]. To determine which neurotrophic factor and receptor is important for survival of MMC, LMC and DRG neurons, we assessed the expression pattern of muscle-secreted neurotrophic factors (e.g., BDNF, NT-3, NT-4/5) and their receptors (e.g., Trk B and Trk C) in mutant and control neural tissues by immunohistochemistry. Together, our results indicate that alterations in the expression pattern of neurotrophins and their receptors in the spinal cord and DRG are related to the decreased ability of MMC, LMC and DRG neurons for survival.},
  note = {Poster},
}

@inproceedings{lowepearce2004beat,
  title = {And The Beat Goes On... Life After Heart Surgery},
  author = {Lowe-Pearce and C and McGlone and J and Hirsch and G and Legare and J-F and Peters and V},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Controversy exists over recovery from coronary artery bypass grafting (CABG). A healthy control group (n=36) was compared with patients (n=44) to contrast three different Reliable Change Indices (RCI), and then, to contrast outcomes based on incidence (RCI) versus group means (ANCOVA) six weeks prior to surgery and seven months later. Gain, no change, or loss on a composite neuropsychology battery and Quality of Life (SF-36) were identical using each RCI formula. Cognitive change was not significantly different between groups over time, and patients reported significantly improved physical health compared to controls. More patients reported positive and negative mental-health changes than controls, a difference absent from group analyses.},
  note = {Poster},
}

@inproceedings{stanford2004effect,
  title = {The effect of a single versus repetitive pain experience during infancy on anxiety and spatial learning in juvenile mice.},
  author = {Stanford, Lianne and Darrah, Matthew and Kelly, Carrie and Schellinck, Heather},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Exposure to pain during development has long been hypothesized to disrupt behaviour in later life. (Hebb,1949, Organization of Behaviour). Recent evidence has shown that rats subjected to pain as infants are more anxious as adults (Anand & Scalzo, Bio. Neonate, 77, 2000). In Experiment One, we investigated the influence of early pain experience on anxiety and learning and memory in mice. Neonatal mice were exposed to a one time acute pain, i.e., a tail snip at postnatal day 8 or repetitive pain, i.e., paw pricks on postnatal days 8-14. When tested in an elevated plus maze on Day 30, both acute and chronic pain mice showed behavioural changes indicative of increased anxiety compared with control animals. The effects included a reduction in open arm entries, percent time spent in the open arms and a decrease in head dips. In addition, chronic pain animals showed a greater decrease in time spent in the open arms and in number of entries into the open arms as well as an increase in stretch attends compared with acute pain animals. There were no differences in the number of line crossings in the experimental and control animals. This pattern of results would suggest that the pain exposed animals showed an overall increase in risk assessment, a behaviour associated with hypervigilance in humans. When tested in the Morris Water Maze, these mice demonstrated an intact working memory in a three-day acquisition task as well as in a probe trial and reversal trials. Thus, it appears that their increased anxiety did not adversely affect their performance in a spatial working memory task. In a second experiment, the effect of environmental enrichment on decreasing anxiety in mice experiencing early neonatal pain was assessed. There was no difference in anxiety between control and experimental animals when tested in the elevated plus maze. The implications of this failure to replicate the results of the initial effect are discussed.},
  note = {Poster},
}

@inproceedings{macpherson2004eyes,
  title = {Do eyes act like arrows? Responding to nonpredictive directional cues in children and adolescents},
  author = {MacPherson, Amy and Moore, Chris and Friesen, Chris Kelland},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Covert orienting to socially significant gaze cues and more symbolic arrow cues was recently examined in a manual detection task with preschoolers and adults (Ristic, Friesen, & Kingstone, in press). Significant cueing effects were observed in both conditions for both age groups, contrary to the hypothesis that for young children arrows are less well-learned than they are for adults and would therefore make less effective cues than gaze cues (which are believed to be processed reflexively). The present cross-sectional study used the same stimuli and design as Ristic et al., but with a localization task, to examine the range of ages between those tested in their study. One hundred and ten 5- to 17-year-olds were recruited and tested at a summer camp. They participated in two counterbalanced cueing conditions, making keypress responses to peripheral targets appearing, at varying cue-to-target stimulus onset asynchronies (SOAs), to the left or right of centrally-positioned nonpredictive directional cues. In the Gaze Condition, the direction of gaze of a schematic happy face served as the cue, and in the Arrow Condition the direction of an arrow served as the cue. Participants made a speeded response by pressing either a left or right computer key to indicate target location. Each block of 52 randomly ordered trials included two each of 24 trial types representing the factorial combination of cue validity (valid or invalid), target location (left or right), target identity (cat or snowman) and SOA (195, 600, or 1005 ms), along with 4 catch trials. The 5- to 10-year-olds (N = 49, M = 8y4m) completed one block in each condition, while the 11- to 17-year-olds (N = 61, M = 14y) completed two blocks in a row in each condition. As expected, we found that participants in both age groups responded more quickly to targets appearing on the side of the screen indicated by the cue. Although both reaction time (RT) and the magnitude of the RT advantage decreased as age increased, the overall pattern of faster responding to targets on the cued side was consistent across age groups in both the Gaze and Arrow Conditions. The present study provides further evidence that when gaze and arrow cues are nonpredictive they can produce similar effects, and it adds the new finding that the cueing effects triggered by nonpredictive centrally-presented cues remains consistent from the preschool years through to adulthood.},
  note = {Poster},
}

@inproceedings{westwood2004eye,
  title = {Eye movements are not required for fast manual responses to visual target perturbations.},
  author = {Westwood, David A. and Danckert, James},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Previous studies have shown that reaching movements can be quickly updated when the position of the target is unexpectedly changed during the course of the response (i.e., the double-step reaching paradigm). Because the change in target position typically takes place during a saccadic eye movement, perceptual awareness of the perturbation is suppressed (i.e., saccadic suppression). Nevertheless, the eyes move quickly (and unconsciously) to fixate the new target position before the reaching movement is complete. Therefore it is unclear whether the updating of the reaching movement is driven by a visual (i.e., the position of the target on the retina) or non-visual signal (i.e., gaze direction). We sought to distinguish between these possibilities by comparing reaching performance in a double-step task with free gaze (i.e., subjects were free to saccade to the target when it appeared) and central fixation (i.e., subjects maintained central fixation during the course of the trial). If reaching corrections are driven by a non-visual signal related to eye position then performance should be impaired in the central fixation condition (since eye position and target position are decoupled). In contrast to this prediction, our results show that performance is equivalent in the two conditions; reaching adjustments were as fast, accurate, and frequent in the free gaze and central fixation conditions. Although knowledge of eye position is undoubtedly important for the control of reaching movements, the reaching control system has fast access to visual information about the position of targets on the retina; this information can be used to implement fast and accurate adjustments to ongoing reaching movements. In other words, the control of reaching movements is not a simple case of reaching to where the eyes are looking.},
  note = {Poster},
}

@inproceedings{mcglone2004periodic,
  title = {Periodic stimulation (of the vagal nerve for treatment of intractable seizures) may be less than it is cracked up to be.},
  author = {McGlone, J and Clarke, D and Sadler, R.M and Valdivia, I and Penner, M},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {In an experimental paradigm, Clarke et al. (2000) found that verbal recognition memory was enhanced immediately after stimulation of the vagal nerve in humans with epilepsy. If this effect were more permanent, the prediction could be made that patients receiving vagal nerve stimulators might experience enhancement of memory functioning on standardized clinical tests. Three groups of patients with epilepsy underwent a broad neuropsychology evaluation including a memory assessment (WMS-III) and self-rating of memory functioning on two occasions, i.e., before and 12 months after implantation of a vagal nerve stimulator (n = 16), or a temporal lobectomy (n = 10), and a medication only control group (n = 9) seen 12 months apart. Depression scores (Geriatric Depression Scale), seizure frequency, and Quality of Life (QOLIE-89) were also analyzed. Grouped data were subjected to an Analysis of Variance and individual change scores were subjected to a reliable change index analysis. Results: The patients with vagal nerve stimulators were not superior to the other groups on any outcome measure one year after treatment. Similarly, the percentage of patients who improved beyond measurement error did not differ in the three patient groups. Conclusions: Vagal nerve stimulation did not reduce seizure frequency or enhance memory functioning or quality of life in a clinical sample of patients with medically intractable epilepsy after 12 months of treatment. Our negative findings based on matched samples contrasts with the positive outcomes published in industry funded, but less well controlled studies. The results highlight the need for non-industry funded granting agencies to embark on multi-centre research on this new technology.},
  note = {Poster},
}

@inproceedings{inanlou2004abnormal,
  title = {Abnormal Development of the Diaphragm in mdx:MyoD-/-9th embryos leads to pulmonary hypoplasia},
  author = {Inanlou, Mohammad R. and Kablar, Boris},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Introduction: In vitro studies have shown that mechanical factors play an important role in cell cycle kinetics and cell differentiation of the lung through an unknown mechanochemical signal transduction pathway. In the current study we evaluated the in vivo role of mechanical factors due to fetal breathing movements (primarily executed by the diaphragm) on lung growth and development by using genetically engineered mouse embryos. Materials and Methods: Lung growth and development of mdx and the ninth backcrossed generation of mdx:MyoD-/- embryos (designated as: mdx:MyoD-/-9th) were compared to that of the wild-type littermates (and to each other) at the embryonic day 18.5 using histological studies and immunohistochemistry. Results: The mesenchymal compartment of the diaphragm was intact and no herniations were observed in the embryos. By contrast, the skeletal muscle compartment of the diaphragm was significantly reduced in mdx:MyoD-/-9th embryos. No abnormalities in lung organogenesis were observed in mdx term embryos, whereas lung hypoplasia was detected in mdx:MyoD-/-9th embryos. In the hypoplastic lung, the number of proliferating lung cells was lower in comparison to the wild-type and mdx littermates, while the thyroid transcription factor-1(TTF-1) gradient was not maintained. Surprisingly, no difference was observed in the apoptotic lung cells distribution and occurrence in mdx:MyoD-/-9th embryos. Conclusions: Together, it appears that mechanical forces generated by contractile activity of the diaphragm muscle play an important role in normal lung growth and development by affecting cell proliferation and TTF-1 expression.},
  note = {Poster},
}

@inproceedings{wright2004differential,
  title = {Differential Effects of Early Life and Periadolescent Psychological Stress on Adult Behaviour in Male and Female Rats.},
  author = {Wright, Lisa D and Perrot-Sinal, Tara S},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Chronic administration of the D2/D3 dopamine receptor agonist quinpirole is used to induce compulsive behaviours in rodents. The present study examined the roles of early life and periadolescent psychological stressors in determining the adult behavioural profiles of quinpirole-sensitized male and female Spraque-Dawley rats. Rats were maternally separated (MS) for 3 h per day for the first 10 days of life, and/or experienced an olfactory cue of predatory threat on five occasions between postnatal days 40-48. Adult behavioural assessment involved measuring perseveration rates in a T-maze task prior to quinpirole treatment, following quinpirole sensitization, and after 21 days of withdrawal. Behavioural profiles were extended by assessing: 1) adaptive stress responding using a paradigm in which animals are exposed to predator odour (PO), and 2) locomotor activity in a large open field. We predicted a greater effect on compulsive behaviours in MS females relative to males due to neuroprotective effects of estradiol in neonate male brain. Conversely, periadolescent PO exposure was expected to affect males more than females due to stress-induced dysregulation of pubertal dopamine receptor pruning, which occurs only in males. Results supported both hypotheses, and long lasting behavioural effects of stressors were found to be specific to compulsive-type behaviours. Additionally, it was found that perseveration induced by quinpirole treatment increased across the withdrawal period in females, whereas perseveration rates in the males returned to baseline after withdrawal. This work was supported by a CPRF award to TSPS and an NSHRF studentship to LDW.},
}

@inproceedings{morris2004oops,
  title = {Oops, We Gave You the Wrong List: List-Method Directed Forgetting using Threat and Anxiety Related Words with Those High and Low in Social Anxiety},
  author = {Morris, Eric},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Directed forgetting is the conscious effort to forget information. Studies in this area typically use one of two methods to elicit the directed forgetting effect: the list method and the item method. The list method was used in the present study and involved presenting a list of neutral, positive, threatening and anxiety producing words and telling participants to either remember or forget the preceding list, followed by a free recall test. The first stage of the present study involves running normal controls in order to confirm that the program we created to produce the directed forgetting effect is effective. The talk will focus on this stage of the study. The second phase of the study will involve administering the program to high and low socially anxious individuals. The goals of the study are two-fold: To create a program that consistently produces the directed forgetting effect and to determine whether high or low socially anxious individuals have more or less trouble actively forgetting threat and anxiety related words.},
}

@inproceedings{wintink2004jack,
  title = {Jack and Jill swam in a pool to find a hidden platform. Jack swam by, like the other guy, but Jill found it right after},
  author = {Wintink, Amanda},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Several lines of research suggest that anxiety behavior in amygdala-kindled rats is related to changes in the hippocampus, such as increased serotonin and GABA receptors, decreased NMDA and glucocorticoid receptors, and decreased cFOS expression. Behaviorally, amgydala-kindled rats primarily express anxiety behavior in novel environments, which further suggests a hippocampal involvement. The present experiment was designed to test whether amygdala-kindled rats were impaired on a hippocampal-dependent task, as a behavioral assessment of hippocampal functioning. For this experiment, adult male and female rats were trained to find a hidden platform in the Morris watermaze using a delayed-matching-to-sample (DMTS) paradigm with a 60-minute delay between the sample (i.e., trial 1) and matching (i.e, trial 2) trials. Rats were trained on the task for 5 days prior to kindling, in which only the platform location changed daily. Rats were then kindled and tested on the task once a week during kindling, for a total of 6 weeks, with a new platform location each week. The results showed that kindling had a negative impact on watermaze performance primarily for male rats.},
}

@inproceedings{douglas2004memory,
  title = {Memory for Details of Visual Scenes: The Role of Psychopathic Traits and Emotional Valence},
  author = {Douglas, Rebecca},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Emotion has been shown to play a complex role in memory. It appears that with emotional stimuli, central details are retained better than peripheral details, and that central details of emotional events may be retained better than those of non-emotional events. In contrast, individuals with psychopathic traits display virtually the same memory for central and peripheral details of emotional stimuli, and show no difference between memory patterns for emotional and neutral stimuli. However, as the majority of research with both individuals high in psychopathic traits and non-psychopathic populations has focused on negative emotional events, the degree to which these findings apply to positive stimuli is unknown. Thus, the objective of this study is to extend previous research findings concerning the influence of emotion on memory to positive stimuli. Also to be examined is the relationship that psychopathic traits may have with stimuli of negative, neutral and positive emotional content. Ninety participants will be assessed on their degree of psychopathic traits using the self-report Psychopathic Personality Inventory (Lilienfield & Andrews, 1996). A positive, negative and neutral scene, selected from the International Affective Picture System (Lang, Bradley & Cuthbert, 1999), will be presented to each participant. Participants will then be tested on their memory for central and peripheral details of each scene. The relationship between degree of psychopathic traits, emotional valence, and memory for central versus peripheral details will be examined. It is hypothesized that previous findings will be replicated, and that patterns demonstrated with negative stimuli may extend to positive stimuli.},
}

@inproceedings{hourihan2004does,
  title = {Does rehearsal time affect the way in which information is forgotten?},
  author = {Hourihan, Kathleen},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {The present experiment examined the effects of rehearsal time in an item method directed forgetting paradigm. Participants were presented with a list of words and were instructed to recall the words unless they received a forget cue, which occurred on half of the trials, at varying delays after word presentation. After studying the words, participants completed a recall test of all words (regardless of initial cue), a recognition test, and a second recall test. Results showed that while a directed forgetting effect was obtained for all three tests, the magnitude of the effect was reduced for the recognition and second recall test, and that words that received a forget cue at a longer delay were more frequently recalled than words that received the short delay. Results were discussed in terms of retrieval inhibition and selective rehearsal.},
}

@inproceedings{taylor2004role,
  title = {The role of spatial attention in directed forgetting: Take 1},
  author = {Taylor, Tracy},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {This study determined whether directed forgetting of peripherally presented words involves processes related to visuo-spatial attention. This was tested by examining the magnitude of inhibition of return at the location of to-be-remembered and to-be-forgotten words. Using a modified item method paradigm, words appeared one at a time to the left or right, followed by a visual Remember or Forget instruction at center. A target dot was then presented either in the same peripheral location as the preceding word or in a different location; participants made a speeded response to localize this target. Despite the fact that a directed forgetting effect occurred for both recognition and recall, there was no effect of memory instruction on the magnitude of inhibition of return (as measured by the reaction times to the subsequent targets). This suggests that information about the to-be-remembered and to-be-forgotten words is extracted independently of the spatial information that marks the presentation episode.},
}

@inproceedings{therrien2004role,
  title = {The role of spatial attention in directed forgetting: Take 2},
  author = {Therrien, Megan and Taylor, Tracy},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {This is a follow-up to a study by Taylor that indicated that directed forgetting of a to-be-forgotten word does not involve inhibition of that word's location. The present study attempted to replicate this result, using tones rather than visual stimuli to designate words as to-be-forgotten or to-be-remembered. Words appeared to the left or right, followed by a tone instructing participants to remember the word or to forget it. Participants then made a speeded response indicating the location of a target dot that appeared subsequently to the left or right. The magnitude of inhibition of return was evaluated at the location of both to-be-forgotten and to-be-remembered words. (At present, the results are unknown).},
}

@inproceedings{deurveilher2004how,
  title = {How coffee wakes up your brain: caffeine-induced activation of Arousal-Related Aminergic neurons in rat},
  author = {Deurveilher, Samuel and Murphy, Jeremy and Burns, Joan and Semba, Kazue},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Caffeine is the most widely used psychostimulant in the world. However, neuronal mechanisms mediating its stimulatory effect are not well understood. We recently reported, using c-Fos as a marker for neuronal activation, that psychostimulant doses of caffeine induce activation of hypocretin/orexin-containing neurons which play an important role in arousal. Here we examined whether other components of the arousal system, specifically aminergic neuronal groups, are also activated by caffeine, by using dual immunostaining for c-Fos and aminergic transmitter markers. We found that low locomotor-stimulant doses of caffeine (10 and 30 mg/kg, i.p.) increase Fos immunoreactivity in noradrenergic neurons in the locus coeruleus and histaminergic neurons in the tuberomammillary nucleus, as well as in orexin-containing neurons of the hypothalamus, but not in serotonergic neurons in the dorsal raphe nucleus. A higher, locomotor-depressant dose of caffeine (75 mg/kg, i.p.) induces c-Fos expression in all of these neurons. Dopaminergic neurons in the ventral tegmental area and substantia nigra did not respond to caffeine with changes in c-Fos expression. These results indicate that caffeine induces c-Fos expression differentially among aminergic arousal-related cell groups. The noradrenergic and histaminergic neurons and orexin-containing neurons which are activated at low doses of caffeine might play a role in mediating behavioral activation induced by caffeine.},
}

@inproceedings{poulin2004confocal,
  title = {Confocal Microscopic Analysis of the Colocalization of Vesicular Glutamate Transporters in Cholinergic Neurons of the Rat Basal Forebrain: Do cholinergic neurons release glutamate?},
  author = {Poulin, Amanda and Semba, Kazue},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {In addition to its well known role in cognition, the basal forebrain (BF) is implicated in the regulation of behavioural state. Neurochemically, these functions have been attributed primarily to the cholinergic, and to some extent, the GABAergic neurons in this brain region. Recent evidence also suggests the involvement of a glutamatergic system within the BF. Glutamate may act as a major transmitter in the BF, and may also be co-released from a subpopulation of cholinergic BF neurons. We examined the possibility of glutamate colocalization in BF cholinergic neurons by using antibodies to vesicular acetylcholine transporter and vesicular glutamate transporters (VGluT)-1/2/3, three recently identified transporters responsible for glutamate uptake into synaptic vesicles. Confocal microscopy was used to examine coimmunofluorescence for VAChT and VGluT 1/2/3 in the cell bodies of BF cholinergic neurons and their terminals in selected target areas. In the BF, scattered neurons in the horizontal limb of the diagonal band, ventral pallidum, substantia innominata, and globus pallidus were immunoreactive (ir) for both VAChT and VGluT3; however, no cell bodies in the BF were double-labeled for VGluT1/2 and VAChT. No fibers or terminals in the motor, somatosensory, piriform and entorhinal cortices were coimmunoreactive for VGluT1/2/3 and VAChT; similarly, VAChT-ir terminals within the BF were not VGluT1/2/3-ir. The reticular nucleus of the thalamus, which receives cholinergic projections from the BF, was also devoid of coimmunofluorescence for VAChT and VGluT1/2/3. In some of the above areas with cholinergic innervation, VGluT1/2/3-ir and VAChT-ir terminals were segregated in distinct patterns, whereas in others they were intermixed. These results suggest that VGluT3 is present in a small population of cholinergic BF neurons. The presence of VGluT3 in a subpopulation of BF cholinergic neurons suggests that terminals of some BF cholinergic neurons might release both acetylcholine and glutamate.},
}

@inproceedings{lefaivre2004mothers,
  title = {Mothers' Views about Stress and Depression},
  author = {Lefaivre, Marie-josée},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Despite the fact that depression is a prevalent mental health problem in women, very little is actually known about women's views and opinions regarding stress and maternal depression. A few qualitative studies suggest that women in rural communities tend to normalize their depressive experiences by seeing it as part of their lives as mothers and housewives. Other studies indicate that these women are more likely to present somatic symptoms associated with depression or distress. Previous research also suggests that individuals often characterize their depression symptoms as part of a physical illness as a result of stigma and that perceived stigma constitutes a barrier to seeking help and to treatment adherence. Consequently, a better understanding of mothers' perception towards depression and social stigmas could be beneficial given that these perceptions are reflected in their coping skills including help-seeking behaviours. The goal of the following research project aims at examining (1) rural and urban mothers' views about depression and its symptoms, (2) their awareness of depression indicators, (3) their causal belief about maternal depression and (4) their perception of social stigma associated with this mental health issue. Mothers (19 to 49 years of age) randomly selected from the Nova Scotia Atlee Perinatal Database will be invited to participate in this study. This research is being conducted within the Maternal Depression Project of the Family Help Program: Bringing Health Home (Pediatric Pain Lab, IWK Health Centre) and in collaboration with the Reproductive Care Program.},
}

@inproceedings{boudreau2004measuring,
  title = {Measuring Flavor Preference and Palatability After Aversive Conditioning},
  author = {Boudreau, Sarah and LoLordo, Vincent},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Flavor preferences and palatability shifts were examined following aversive conditioning. Rats were surgically implanted with intraoral cannulae. Orange and LemonLime Kool-Aids were placed in solution with either bitter quinine (CS+) or water (CS-) in Experiment 1, and nausea inducing lithium chloride (CS+) or sodium chloride (CS-) in Experiment 2. One solution was placed on each cage and left overnight such that each rat received three CS+ trials and three CS- trials. Preference was measured with a two-bottle test, and palatability was assessed using a taste reactivity test (TRT). The TRT involved infusing each solution into the rat's mouth for two minutes and recording its orofacial reactions. In both Experiments 1 and 2, rats overwhelmingly consumed more of the CS- compared to the CS+ in the preference test, i.e., the CS+ flavor was avoided. In Experiment 1 there was no difference in orofacial reactions between CS+ and CS-. However, in Experiment 2, rats showed fewer appetitive reactions to the CS+ compared to the CS-. It appears that while avoidance can be obtained with either aversive solution, palatability shifts are only seen with solutions that induce illness.},
}

@inproceedings{walker2004hear,
  title = {Hear no consonant. Speak no consonant. Read no consonant.},
  author = {Walker, Kerry},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {People show great variation in their language and reading proficiency, even within the normal population. Historically, language function was viewed as somewhat separate from basic perceptual and cognitive processes. Some experts now suggest that problems with auditory and visual perception underlie language disorders. In particular, dyslexia has been theorized to be a temporal processing disorder, in which children cannot normally perceive auditory and/or visual events that occur quickly in time. Over the past 15 years, many studies have provided empirical support for this theory of language function, but most of this research has specifically targeted highly-selected and clinically-impaired children or adults. Therefore, the present study will aim to identify the basic perceptual skills that are most highly correlated with language and reading abilities in normal subjects (ages 6 to 17). The same subjects will complete various tests of auditory and visual temporal processing, language, and reading performance. Statistical analysis will then identify the basic perceptual skills that covary with language and reading proficiency. This research will help us understand the development of language in the general population, and will have implications for the treatment of developmental language delay in children.},
}

@inproceedings{wong2004behavioral,
  title = {Behavioral assessment of visual discrimination, pattern discrimination and visual acuity in seven strains of mice},
  author = {Wong, Aimee A. and Brown, Richard E.},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Previous research has demonstrated that mice are capable of brightness discrimination and visual pattern discrimination and that it is possible to quantitatively determine the visual acuity of the mouse. Based on the procedure of Glen Prusky (Prusky et al., 2000, Vision Research, 40, 2201-2209), we have developed a protocol using a computer-based, two-alternative swim task that evaluates visual discrimination, pattern discrimination and visual acuity in one apparatus. Seven strains of mice (BALB/cByJ, C3H/HeSnJ, C57BL/6J, Coloboma, DBA/2J, FVB/NJ and MOLF/Ei) were tested on 8 trials/day for 8 days on each of the three tests. There was a significant strain difference in visual ability in all three tests. Mice with normal vision (C57BL/6J and DBA/2J) performed very well in these tasks. Mice with poor vision (BALB/cByJ) took longer to learn the tasks than mice with normal vision and mice with retinal degeneration (C3H/HeSnJ, Coloboma, FVB/NJ, MOLF/Ei) performed only at chance levels. Because measures of leaning and memory on visuo-spatial tasks may be affected by visual ability, we correlated performance in the Morris Water Maze with the visual acuity of each strain. We found that visual acuity was significantly correlated (r = -0.998) with the latency to find the platform in the Morris Water Maze. This suggests that the visual ability of each strain is a confounding variable in visuo-spatial learning and that visual acuity, rather than spatial memory capability, may account for some of the strain differences in mice in the Morris Water Maze.},
}

@inproceedings{coolican2004investigatin,
  title = {Investigating Spatial Biases in Face Perception},
  author = {Coolican, Jamesie and BSc and Eskes, Gail and Ph.D},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {We were interested in the reported left-sided perceptual bias in interpreting facial emotion and in facial recognition. Our purpose was to replicate the reported bias in normal subjects and to examine whether this phenomenon was related to global/holistic face processing per se. Twenty-one undergraduate students participated in the study. In Study 1, subjects were shown chimeric faces created by combining half of a smiling face and half of a neutral face. They were asked to judge which of two faces (smile on left vs smile on right side of the face) was "happier". Results showed a strong bias for judging the face with the left-sided smile as happier. In a second condition, the chimeric faces were inverted. The left-sided bias in emotion judgement remained, suggesting this judgement was not based on global face processing. In Study 2, composite faces from the left or right side of a neutral face were created and the subjects were asked to identify which composite most nearly matched the original face. In this case, a significant (but smaller) left-sided bias for matching a composite was seen. In addition, top faces were significantly more likely to be judged as more similar to the original than bottom faces, suggesting the recognition process was related to vertical spatial position of the face as well. When the faces were inverted, vertical spatial position ceased to affect judgements, while the left-sided bias remained. Implications of these findings for neurocognitive models of face processing will be offered for discussion.},
}

@inproceedings{mitchell2004how,
  title = {How to Grow up and be normal: Lessons from the visual system and accenture. It is not the variety or amount of early experience you have, it's the proportion that is normal that makes good things happen.},
  author = {Mitchell, Donald and Jones, Marc},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Although a number of key features of the anatomical and physiological organization of the central visual pathways of higher mammals can be remarkably well developed at birth, others achieve their adult status more gradually. Nevertheless, even those characteristics that appear remarkably mature at birth, such as the segregated pattern of ocular dominance observed in the granular layer of the visual cortex (area 17) of monkeys, as well as those that appear less developed, can change in a dramatic fashion in response to abnormal visual input imposed during documented sensitive periods in early postnatal life. The cortical changes induced by such selected early visual exposure can be accompanied by profound and long-standing visual deficits. In this study we demonstrate that with respect to form vision, normal visual input is weighted far more strongly during development than is biased visual exposure such that 2 hours of normal visual exposure each day can outweigh much longer periods of deprivation so as to permit the development of normal vision in both eyes. This result is not what would be expected by a passive process whereby neural connections are continually shaped or refined in response to the integrated visual input during the appropriate sensitive period, but instead suggest a process which effectively responds preferentially to normal input.},
}

@inproceedings{phillips2004take,
  title = {Take the HINT. Actually, Scratch That. Don't Take the HINT. Or if You Do Take the HINT, Rotate Your Chair 45 Degrees.},
  author = {Phillips, Dennis P. and Vigneault-MacLean, B. and Boehnke, S.E. and Hall, S.E.},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {One of the most common problems encountered by persons with or without hearing loss is a poor ability to discriminate speech that occurs against noisy backgrounds. A clinical test (the Hearing In Noise Test, HINT) has been developed to measure the perceptual benefit obtained in speech discrimination achieved by having a 90-degree azimuthal (eccentricity) separation of speech and concurrent noise. The noise is presented from straight ahead, and the speech signal is presented either from the same location, or from 90 degrees into the left or right auditory hemifield. The "release from masking" effected by the 90-degree spatial separation is reported to average about 6-7 dB. Our lab previously showed that the human perceptual system has channels for auditory azimuth that are hemifield in configuration (Boehnke & Phillips, 1999). The HINT does not exploit this knowledge. We'd expect the maximum benefit of a 90-degree separation to occur when speech and noise are presented in different hemifields, and the minimum benefit to occur when the sounds are presented in a single auditory hemifield. The HINT does not employ either of these configurations. In the present study we show, using the HINT stimulus materials, that spatial release from masking can be increased to about 8.6 dB, or reduced to 1.3 dB, simply by locating the speech and noise sources in opposite hemifields or in the same hemifield, respectively, while maintaining the 90 degree azimuthal separation. The HINT configuration produced an intermediate (6.05 dB) release from masking. These data may be useful to clinicians wishing to enhance the effect size of the existing HINT. The data also provide a new corollary of the tuning of human spatial perception mechanisms, which was originally derived from auditory temporal gap detection studies.},
}

@inproceedings{franklin2004ovarian,
  title = {Ovarian Hormones and Acute Restraint Stress Interact to Modulate BDNF Protein Levels in Rat Brain},
  author = {Franklin, Tamara and Perrot-Sinal, Tara},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Abnormal levels of brain-derived neurotrophic factor (BDNF) are associated with major depression, a disorder with a higher incidence in women than men. Stress affects BDNF levels in various brain regions and thus, a heightened stress response in females could contribute to the development of depression. As well, ovarian hormones directly affect brain levels of BDNF RNA and protein. The present experiment investigated the interaction between stress and ovarian hormones on BDNF protein levels in the hippocampus (CA1) and paraventricular nucleus of hypothalamus (PVN). Forty-six female Sprague-Dawley rats were ovariectomized; half received one hour of restraint stress while the other half received control handling prior to sacrifice. Stressed and handled groups received a single injection of either estrogen (E; 48 h prior to sacrifice), estrogen and progesterone (EP; P given at 53 h and E given at 48 h prior to sacrifice) or vehicle (OVX). BDNF protein was quantified using an enzyme-linked immunosorbent enzyme assay (ELISA). In the CA1, there was significantly more BDNF in the EP group compared to E and OVX groups. Relative to handled controls, BDNF levels were slightly elevated in OVX-stressed rats but significantly reduced in E-stressed rats. In the PVN there was significantly less BDNF in both E and EP groups compared to OVX rats but there was no effect of stress and no interaction between hormones and stress in this region. Thus, in some stress-sensitive brain regions, the presence of estrogen alters stress-induced changes in BDNF levels. Studies are currently underway to examine the effects of ovarian hormones on BDNF protein in other brain regions involved in stress.},
}

@inproceedings{bain2004effects,
  title = {Effects of restraint stress exposure on hippocampal neurogenesis in rats and mice.},
  author = {Bain, Megan},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Neurogenesis in the dentate gyrus of the hippocampus persists during the adult life of many species, including mice, rats, monkeys, and humans. There are many factors that regulate neurogenesis; however, stress exposure is of particular interest because of its role in human anxiety and depressive disorders. This study investigated the effects of acute restraint stress exposure on hippocampal neurogenesis in rats and mice. Male Sprague-Dawley rats and CD57BL/6 mice were injected with bromodeoxyuridine (BrdU), a marker of neurogenesis, followed by 3 h of restraint stress via confinement to a small container. Using immunohistochemistry, cell proliferation was assessed by measuring the number of BrdU-labeled cells in the dentate gyrus. To determine whether this restraint stress evoked a typical stress response in these species, we also examined the number of c-Fos-labeled cells in the paraventricular nucleus of the hypothalamus (PVN), a brain area known to be activated during stress. The results show that acute restraint stress significantly inhibited hippocampal cell proliferation in rats, as compared to unstressed controls. In contrast, acute restraint stress in mice resulted in increased hippocampal cell proliferation, relative to that seen in unstressed mice. Restraint stress activated the stress response in both species, as indicated by a significant increase in c-Fos immunoreactivity in the PVN. These results suggest that hippocampal neurogenesis in response to stress exposure is differentially regulated in the rat and mouse. Examining the differences between mouse and rat cell proliferation in response to stress may provide useful information on the mechanisms that regulate neurogenesis and a better understanding of the failures of neurogenesis that may underlie various pathological conditions.},
}

@inproceedings{johnson2004effects,
  title = {Effects of repeated and acute corticosterone on phosphorylated camp response element binding protein in the rat hippocampus.},
  author = {Johnson, Sarah and Gregus, Andrea and Davis, Alica and Wintink, Amanda and Kalynchuk, Lisa},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Chronically elevated glucocorticoid levels have been linked to stress-related disorders such as depression and physiological changes within the hippocampus including decreased neurogenesis and neuronal remodeling. These physiological changes may result from decreased cAMP and MAP kinase intracellular cascade activity following repeated exposure to high levels of glucocorticoids over a prolonged period of time. The effects of chronic vs. acute increases in glucocorticoids on cAMP cascade proteins in the hippocampus are currently unknown. Accordingly, the current study assessed the effects of chronic vs. acute corticosterone (CORT) exposure on phosphorylated cAMP response element binding protein (pCREB) as a marker for changes in cAMP and MAP kinase intracellular cascades in the male rat hippocampus. Rats received either a single CORT (40mg/kg s.c.) or vehicle injection every day for 21 consecutive days. An additional two groups of rats were handled every day for 20 days and received a single CORT or vehicle injection on day 21. Rats were perfused intracardially 48 hours after the final injection, and hippocampal tissue was immunohistochemically labeled for pCREB. Results are considered in the context of stress and glucocorticoid-based models of depression.},
}

@inproceedings{bernier2004what,
  title = {WHAT IF ... you do faint in front of the whole class?? SO WHAT! ... On your wedding day, you will not remember},
  author = {Bernier, Denise and Watt, Margo and Stewart, Sherry and Birch, Cheryl},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {We conducted a brief cognitive behavioral (CBT) group intervention with first year undergraduate female students. Our objectives were twofold. First, we attempted to replicate the findings of other studies that have examined the efficacy of a brief CBT for panic disorder. We also extended the earlier work by examining, in a non-clinical population, the efficacy of this treatment on lowering levels of anxiety sensitivity, which is a known and established risk factor for the development of anxiety disorders. Secondly, we intended to lay the groundwork for the development of an intervention manual designed for use with groups of high anxiety sensitive university students. Preliminary data will be presented, illustrating the effects of this approach on levels of anxiety sensitivity.},
}

@inproceedings{time2004oxytocin,
  title = {Oxytocin in the Plasma and Cerebrospinal Fluid of Male Rats: Effects of Circadian},
  author = {Time, Light and Stress},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Karthika Devarajan & Benjamin Rusak Oxytocin (OXT), a neuropeptide known to be involved with reproductive and social behaviours, has also been implicated in responses to stress and depression. Past work has shown that OXT is regulated by circadian phase in the brain, plasma and CSF of monkeys; however, circadian regulation of OXT expression has only been reported in the brain and plasma of the rat. In the present study, we examined the effects of 30 min light pulses at two different circadian phases (mid subjective day and late subjective night) on OXT in circulating plasma, cerebrospinal fluid (CSF) and hypothalamic tissue adjacent to the third ventricle. An enzyme immunoassay was used to measure OXT levels in the plasma and CSF, while immunoreactivity was studied in the hypothalamus. We found that the previously reported circadian difference in plasma OXT levels in the rat disappears when the rats have been previously habituated to handling and injections. Therefore, we speculate that the previously reported OXT rhythm in rat plasma may actually reflect a stress response to experimental procedures expressed selectively at some circadian phases. We also showed for the first time that circadian phase and brief light pulses significantly affect OXT levels in the CSF of the rat.},
}

@inproceedings{darnbrough2004synapsin,
  title = {Synapsin I immunoreactivity and fear-like behaviour in kindled rats, and kindled rats exposed to environmental enrichment. " - I'll see if I can come up with a more unusual one later.},
  author = {Darnbrough, Andrea},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Many patients with temporal lobe epilepsy (TLE) experience increases in fear and anxiety between seizures. Long-term amygdala kindling (i.e., 99 stimulations) is an animal model of TLE that has proven effective for studying kindling-induced fear and anxiety, and the underpinning neural mechanisms, such as hippocampal neuroplasticity (Kalynchuk et al., 2001). This study measured resistance to capture (RTC), a test of fear and anxiety in rats, and hippocampal levels of synapsin I immunoreactivity, a marker of neuroplasticity, between long-term kindled (KI) and sham-stimulated rats (SS). KI rats displayed increased RTC, and increased synapsin I immunoreactivity in CA1 stratum oriens, CA1 stratum lucidium, and CA3 stratum lucidium relative to SS rats. A second group of rats was exposed to environmental enrichment (KE) after fully kindled state had developed (after 3 class 5 convulsions). No statistically significant differences in RTC, synapsin I immunoreactivity, or seizure severity were found between KI and KE rats.},
}

@inproceedings{shaw2004discriminati,
  title = {Discriminating diode detector demystifies disquieting doubts documenting dyed dextrans' diffusional dribble.},
  author = {Shaw, Steve and Dalhousie and Fröhlich, Ami and MSVU},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {The insect blood-brain barrier offers a unique model system in which to explore the evolutionary progression of glial function in the CNS. The barrier resides in a superficial layer of glial cells covering the CNS. The powerful barrier in advanced insects like Diptera (flies) evolved from a barrier-less precursor state present in insects' crustacean ancestors, somewhere back around the Carboniferous. We've been looking for the evolutionary step at which an effective barrier first appeared. A place to start might be the present-day CNS of the alleged Most Primitive Living Insect, a wingless bristletail that inhabits local sea cliffs and looks similar to domestic silverfish. A way to probe the barrier is to inject a tracer into the blood and follow it to see if it gets into the CNS quickly. The tracer of choice has been lanthanum, which can be localized in the electronmicroscope. It seems to be largely excluded from the bristletail's CNS, pointing to the emergence of some sort of a barrier very early on in insects. A major drawback to using lanthanum is that its detection threshold is very high, perhaps 1 part in 10: if it were able to diffuse into the CNS to achieve a concentration up to 10 percent of that in the blood, even this high level could not be detected reliably. We therefore explored whether the detection limit can be lowered significantly by switching to dextrans as light microscope tracers. These inert bacterial polysaccharides are available with fluorescent labels in a range of molecular weights. Our dextrans do appear to be completely excluded by the fly's CNS barrier, gauged by visual observation. We have developed a new approach to quantifying this exclusion, using optical averaging on thin sections of the CNS, measured with a computerized microfluorometer which improves the detection limit markedly. In the fly's CNS, the brightest dextran was excluded from the CNS to better than one part in several thousand, after correcting for the limiting background autofluorescence of the neural tissue. The bristletail's CNS fared much worse when tested with dextrans and appeared quite leaky, somewhere between the extremes of crustaceans and advanced insects. Overall, dextrans emerge as the tracers of choice for probing such barrier systems, where extreme fine-structural localization is not required. POSTERS},
}

@inproceedings{butler2004inattentiona,
  title = {Inattentional Blindness for Ignored Words: Comparison of Explicit and Implicit Memory Tasks},
  author = {Butler, Beverly C. and B.Sc and Klein, Raymond and Ph.D},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Inattentional blindness is described as the failure to perceive a supra-threshold stimulus when attention is directed away from that stimulus. Based on performance on an explicit recognition memory test Rees, Russell, Frith, & Driver (1999) reported inattentional blindness for word stimuli that were fixated but ignored. The present study examined both explicit and implicit memory for fixated but ignored words using a focused attention task in which overlapping picture/word stimuli were presented at fixation. Results of a recognition memory test showed no explicit awareness of the unattended words. However, there was evidence that unattended words were implicitly perceived. Results of the implicit memory tasks showed significant perceptual priming but no conceptual priming by either attended or unattended words, suggesting that while subjects may have been inattentionally blind to the conceptual/semantic properties of attended and unattended words, they were not blind to the perceptual properties of presented words.},
}

@inproceedings{poulin2004subpopulatio,
  title = {A Subpopulation of Cholinergic Basal Forebrain Neurons Projecting to the Amygdala Co-Expresses Glutamate},
  author = {Poulin, Amanda and Semba, Kazue},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {The basal forebrain (BF) plays a profound role in behaviours ranging from basic drives and emotions to higher cognitive functions. Cholinergic, GABAergic and petidergic neurons populate the BF and their projections span the neuraxis to modulate these processes. A glutamatergic component has also been suggested to reside in the BF. Glutamate may act as a main transmitter of BF neurons, and may also be co-released with acetylcholine from a subpopulation of cholinergic terminals. Our studies suggest that a subpopulation of BF cholinergic neurons co-express glutamate as demonstrated by immunofluorescence histochemistry using cholinergic and glutamatergic markers. To further characterize this subpopulation, cells co-expressing choline acetyltransferase (ChAT) and vesicular glutamate transporter 3 (VGluT3) were counted and plotted using Neurolucida. Axon terminals in their projection areas were also examined with confocal microscopy for colocalization of ChAT and VGluT3. Double labeled cells are located primarily in the ventral pallidum, and are also found scattered in the horizontal and vertical limbs of the diagonal band of Broca, medial preoptic area, substantia innominata and magnocellular basal nucleus. Cortical, hippocampal and thalamic target areas are devoid of colocalized terminals; however the basolateral amygdala harbours numerous terminals co-immunoreactive for ChAT and VGluT3. These data indicate that a subpopulation of BF cholinergic neurons projecting to the amygdala may also be glutamatergic. (Supported by NSERC & CIHR)},
}

@inproceedings{drahovzal2004decisional,
  title = {Decisional balance of physical activity and nutrition among children and adolescents.},
  author = {Drahovzal*, Deanna N. and Candidate, PhD},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {As we gain a greater understanding about the factors that influence illness prevention, focus is being placed on the importance of a healthy lifestyle. In particular, healthy eating patterns and physical activity can be instrumental in the prevention of obesity, type 2 diabetes and other serious medical problems. Ideally, illness prevention through lifestyle modification would begin in childhood. Yet, little is understood about how children or adolescents choose healthy over unhealthy behaviours. In adults, behavioural health experts have been developing techniques directed at altering decisional balance to improve health behaviours. Decisional balance (DB) is a construct from Prochaska's transtheoretical model (TTM) that has been successfully applied to numerous adult health behaviours. DB scales produce a difference score that represent a person's relative balance of pros and cons for performing a particular health behaviour (pro scale t-score minus con scale t-score). According to the TTM model, this DB difference score predicts health behaviour. The purpose of the present research is to examine the validity of the DB model among children and adolescents in grades 11, 7, and 3 for their physical activity and nutrition behaviour using two informants: child self-report and parent proxy. First, appropriate items for children and adolescents regarding their choices about activities (sedentary vs. active) and foods (calorie-dense vs. nutrient-dense) were generated through literature searches, focus groups, and written feedback from parents. Second, expert advice and various statistical procedures on a cross-sectional survey data set of 297 children and adolescents from the Halifax Regional School Board were utilized to select the best items. The resulting DB measures showed an expected 2-factor structure, accounting for 29% of the variance for physical activity DB and 27% for nutrition DB. As well, good psychometric properties, such as content validity using TTM self-efficacy scales and one-week test-retest reliability, were shown for those in grades 11 and 7, but not grade 3. Third, an external validation study was conducted with approximately half of the youth (N = 148) that participated in the cross-sectional survey. Physical activity and nutrition behaviors were measured for the following week using an accelerometer (a small device worn on the hip) and a food frequency questionnaire, respectively. Results revealed that when using self report, the newly developed physical activity DB measure did not predict average daily activity counts among youth of any grade. However, the DB measure was temporally associated with physical activity among adolescents in grade 11 when using parent proxy. Within the nutrition domain, the DB measure was significantly correlated with percent calories of fat and sugar consumed among those in grades 11 using self-report, and among those in grades 11 and 7 using parent informants. These results suggest that the DB model is not valid among those in grade 3 for physical activity and nutrition behaviour. However, depending on the informant, the DB model is externally valid among those in grade 11 for physical activity, and grades 11 and 7 for nutrition behaviour. These results have implications for the use of the DB model in future interventions and research in the area of lifestyle modification among youth.},
}

@inproceedings{reyno2004influence,
  title = {The influence of Parental Factors on Recurrent Headache in Adolescents},
  author = {Reyno, Sandra},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Functional headache or headache not due to an identified organic cause is one of the most common somatic complaints in adolescents. Recurrent functional headache in adolescents is associated with a number of factors. These include child mental health factors (i.e., depression, anxiety), child demographic factors (i.e., gender, age), and familial factors (i.e., socioeconomic status, family headache history). Parental factors associated with recurrent functional headache in adolescents include parental encouragement of child illness behavior and parental modeling of illness behavior. It is not known how these parental factors impact on headache-related impairment (pain intensity), functional disability (restriction in performing social, academic, and physical tasks), or handicap (inability to fulfill social, academic, or physical roles). In the proposed research, an Internet-based study will be used to evaluate a model of headache in adolescents. The model will examine hypothesized relationships between parental factors and headache-related impairment, functional disability, and handicap in adolescents.},
}

@inproceedings{good2004functional,
  title = {Functional Magnetic Resonance Imaging of the Olfactory System in patients with First Episode Psychosis: Preliminary Data from a Normosmic Subgroup},
  author = {Good, Kimberley P. and Schellinck, Heather and Gates, Larry and Brown, Richard and Boudreau, Sarah and Choo, Sheldon and Haacke, E. Mark and Kopala, Lili},
  booktitle = {30th Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2004},
  abstract = {Classical neuroanatomic techniques and lesion studies have well delinated the neural substrates involved in olfactory processing. Functional imaging has extended these findings by allowing the identification of brain regions engaged by different cognitive-olfactory tasks. The purpose of this ongoing study is to use FMRI to examine the functional topography of the olfactory system in patients with first episode psychosis and healthy control subjects. Fourteen normosmic subjects participated: 8 healthy controls and 6 patients with DSM-IV confirmed diagnosis of schizophrenia. A manually-controlled olfactometer delivered the stimulus (amyl acetate) to the subjects during the FMRI scan. Twenty six second on-off epochs (5 odour, 4 no-odour) were presented. As predicted, healthy control subjects demonstrated activity in previously defined olfactory regions (left superior, middle and inferior frontal gyri, right orbitofrontal cortex, and right inusla). Activation in left basal ganglia and left superior temporal gyrus was also observed. Patients demonstrated activity in the left superior frontal gyrus and posterior cingulate. In this preliminary dataset, secondary olfactory cortices did not show the predicted activity in the patient sample in response to the presented odour. As patients with psychosis have been documented with olfactory identification deficits (OID), these data broaden our understanding of the functional brain abnormalities in these patients. Further research by our lab will examine cognitive-olfactory tasks in psychosis patients with confirmed OID.},
}

@inproceedings{murphy2005where,
  title = {Where did it go? Developmental Changes in Preschoolers' Search Strategies as a Function of the Type of Symbol Used for Searching},
  author = {Murphy, Matthew and Jacques, Sophie},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The current study assessed the effects of iconicity on the flexible use of cognition in young children using model-room search tasks. Three- and four-year-olds were tested using two model conditions that varied in the degree to which items in one room matched items in the other room (iconic vs. noniconic). Two types of trials that differed on whether they required the use of cognitive flexibility were also included (control vs. flexible). Results showed an effect of iconicity on both trial types, but this effect was mediated by children's age and whether they were searching in a corresponding room or in the original model suggesting a developmental change in children's efficient use of different kinds of symbols.},
  note = {Poster},
}

@inproceedings{corkum2005effect,
  title = {Effect of Stimulant Medication on Daily Rhythms in Children with Attention-Deficit/Hyperactivity Disorder},
  author = {Corkum, Penny and Dumaresq, Alex},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Much research has been devoted to the study of sleep in children with ADHD. Stimulant medication, the most common form of treatment for ADHD, has been shown to negatively effect sleep. To date, no research has been done investigating how stimulant medication affects 24-hour cycles. The present study tested the hypothesis that stimulant medication negatively effects the rhythmicity of an individual‚s 24-hour cycle. Four children newly diagnosed with ADHD-C and who were participating in a blinded medication trial were recruited. The medication trial consisted of four 7-day conditions: baseline, Placebo control, low dose, and medium dose MPH. Activity levels over the medication trial were recorded using actigraphy. Increased night-time activity and dampened circadian amplitude were observed in all participants during MPH conditions. These findings are discussed in terms of their implications for clinical practice and future research.},
  note = {Poster},
}

@inproceedings{doucet2005thinking,
  title = {Thinking vs. Doing: Effects of Active Participation and Inference on Children's Performance on the Representational Change Task},
  author = {Doucet, Amélie and Jacques, Sophie},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Research suggests that allowing active participation and decreasing inferential requirements may help preschoolers succeed on the representational-change task earlier than they typically do. Forty-eight 3-year-olds participated in one of three variations of an unexpected-contents task. In a control condition, children's initial belief about the contents of a box had to be inferred; in a see condition, children visually confirmed their initial belief; and in an active condition, children actively participated in creating their initial belief. Children also participated in a false-belief task and on separate measures assessing participation memory and inferential ability. Three-year-olds' performance did not differ across conditions on the representational-change task. In addition, there was no relation between performance on the representational-change task and any of the additional measures. Results do not support the idea that allowing participation or reducing inferential requirements facilitate representational change performance in 3-year-olds.},
  note = {Poster},
}

@inproceedings{larochette2005genuine,
  title = {Genuine, Suppressed, and Faked Facial Expressions of Pain in Children},
  author = {Larochette, Anne-Claire and Chambers, Christine T. and Genuine, Kenneth D. Craig and suppressed and boys, faked facial expressions of pain were examined in six and cold, four girls aged to years old. Children submersed their hands in and water, warm and genuine, were given different instructions about what to show on their faces. Ten degree Celsius cold water was used for the and conditions, suppressed and warm degree Celsius water was used for the faked condition. The Facial Action Coding System was used to code the facial expressions in each condition, as well as a baseline condition. Faked expressions of pain in children were found to show more frequent facial actions typical of a genuine pain expression, making the faked expression distinct from the genuine expression. Children were able to successfully suppress their pain and mimic the baseline expression. The results indicate that children are capable of controlling their facial expressions of pain when instructed to do so, but may be better able to hide their pain than fake it},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  note = {Poster; QA: no-abstract},
}

@inproceedings{macfadyen2005statistician,
  title = {Statisticians in the Making? The Role of Statistical Learning in Preschoolers' Categorization Tendencies},
  author = {MacFadyen, Allison and Jacques, Sophie},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Despite the findings that statistical learning may be fundamental to cognitive development in infancy, research on statistical learning during the preschool years is still lacking. The current study was designed to assess 3- to-5-year-olds' use of statistical learning in categorization. It was proposed that children passively exposed to the statistical variability of different visual features of novel categories would exhibit higher categorization accuracy during subsequent categorization tasks compared to children not exposed to this information. The role of language was also investigated in the passive pre-exposure phase using category exemplar labels, and in the categorization phase itself using a naming task. Based on previous findings (Alexander & Enns, 1988), it was expected that younger children would show an increase in categorization accuracy in the naming task compared to a sorting task. Results were interpreted in terms of the strategies available to children in solving the categorization tasks. Although somewhat limited, the findings in this exploratory study provide a promising base for future research.},
  note = {Poster},
}

@inproceedings{fawcett2005relative,
  title = {Relative Attentional Load in an Item-Method Directed Forgetting Task},
  author = {Fawcett, Jonathan M. and Tracy L. Taylor Reaction time was measured in response to visual probes embedded within a standard item-method directed forgetting task. Study words were presented sequentially, each followed ms later by a cue to remember or forget. RT probes were presented at stimulus onset asynchronies of},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  note = {Poster; QA: no-abstract},
}

@inproceedings{mochinski2005early,
  title = {Early Postnatal Pain Results in Test Apparatus Anxiety},
  author = {Mochinski, Autumn P. and Schellinck, Heather M.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Pain during development is believed to permanently alter neurobiology and behaviour in both humans and rodents. Behavioural studies in animal models have primarily focused upon measuring the effects of early pain on subsequent anxiety in standard tests such as the elevated plus maze and the open field. The results have not been consistent either within or between labs and appear to depend on such variables as the type of pain, the age of the animals when they experienced the pain, the age when tested for anxiety and the type of apparatus in which they were tested. In the current study, CD-1 mice received injections of either 1% formalin, physiological saline or a sham treatment on Post Natal Days (PND) 3-5 and were exposed to a rat as a predator stressor on PND 30. Formalin injected animals scored significantly differently than controls on several measures of anxiety during habituation to the test apparatus but not during the test phase when the rat was present. These results would suggest that being in the test apparatus itself created such anxiety in the formalin injected animals that their levels of anxiety did not increase in the predator-stress situation.},
  note = {Poster},
}

@inproceedings{hoffman2005selective,
  title = {Selective cholinergic basal forebrain lesions using anti-murine-p75-saporin (mu p75-saporin): a mouse model of Alzheimer's disease?},
  author = {Hoffman, Nicola and Semba, Kazue and Stamp, Jennifer and Brown, Richard},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Degeneration of cholinergic neurons in the basal forebrain (BF) is a prominent characteristic of Alzheimer's disease (AD). One current animal model developed to mimic BF cholinergic neuron atrophy observed in human AD is via injecting neurotoxins into the mouse brain. Our long-term research aims are to selectively lesion mouse BF cholinergic neurons and then examine the cognitive and other functional deficits associated with this cell loss. Mu p75-saporin is an immunotoxin that has been shown to selectively destroy cholinergic neurons in the medial septum (MS), but demonstrates concurrent cell loss in cerebellar Purkinje cells. In the present study we examined the efficacy of the recently developed, presumably improved mu p75-saporin in selectively lesioning BF cholinergic neurons in the mouse brain. One of three doses (1.0, 1.5, or 2.0 μg/μl) of the immunotoxin or vehicle was infused bilaterally into the lateral ventricles of male C57BL/6J mice. Two weeks following injections, mice were intra-cardially perfused, the brains removed and sectioned for immunohistochemistry to visualize cholinergic and a subtype of GABAergic BF neurons, as well as acetylcholinesterase (AChE) histochemistry. Quantitative analysis revealed a reduction of cholinergic neurons in the MS/VDB following intracerebroventricular injections of mu p75-saporin, but only a trend for a decrease of cholinergic neurons in the nBM. The density of AChE-postive fibers in the hippocampus and somatosensory cortex was not significantly altered following neurotoxin injection, although there was a trend for a decrease in the hippocampus. No loss of noncholinergic neurons in the MS or nBM was apparent, nor was there a loss of noncholinergic cerebellar Purkinje cells. The results indicate that the most recently developed mu p75-saporin has an increased selectivity to cholinergic MS neurons, compared with the previous formula, and may be useful as a selective cholinergic immunotoxin for mice. Mu 75-saporin may be a useful tool to create an animal model of AD and expand research concerning the progression and neuropathology of the disease.},
  note = {Poster},
}

@inproceedings{klein2005everyone,
  title = {If, "Everyone knows what attention is..." then why should you come to this talk?},
  author = {Klein, Raymond},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {To learn: What are the components of attention and How to measure them. Attention, the gateway to awareness and memory and according to Titchener the conceptual fulcrum for psychological science, is not a single concept with a simple, underlying machinery. Rather attention refers to a complex, interrelated set of components that can be construed as isolable subsystems or as separable, interconnected networks. Posner & colleagues have designed a simple test, the Attention Network Test (ANT), for assessing the efficacy of three of the components of attention: alertness, orienting and executive control. Scholars are excited by the scientific progress that might follow from the conceptual distinctions implicit in this view of attention and by the simple test battery for assessing these three isolable components of attention. I will critically review this test, describe some studies that have used it and highlight an improved version recently developed in Spain.},
}

@inproceedings{lawrence2005median,
  title = {The Median is Not the Message: Ex-Gaussian Decomposition of Reaction Time Distributions and Application to Measures of Attention},
  author = {Lawrence, Mike and Christie, John},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Reaction time (RT) distributions are typically positively skewed, indicating that conventional analyses using Gaussian statistics (mean, median, etc) may inaccurately represent data relative to more informative distribution models. One alternative model, the Ex-Gaussian distribution, provides three descriptive parameters: Mu (a measure of central tendency), Sigma (a measure of variance) and Tau (a measure of skewness). Estimation of these parameters is called Ex-Gaussian Decomposition (EGD). In this talk, a brief review of past psychological research using EGD on RT data will be presented, followed by discussion of the technical details of applying EGD to RT tests of attention. A Monte Carlo simulation will be reviewed that tests and corrects a popular EGD algorithm so that it can be validly applied in situations where the number of observations per participant is limited.},
}

@inproceedings{lau2005validating,
  title = {Validating and Modifying a Healthy Model of Visuo-Spatial Neglect.},
  author = {Lau, Esther Y. Y. and Eskes, Gail A.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Visuo-spatial neglect is characterized by an impaired ability to orient, detect and/or respond to stimuli on the opposite side of the lesioned hemisphere. Studies of visual orienting ability using a cuing paradigm suggest neglect is related to a disengage deficit (DD) as measured by significantly increased costs when targets appearing on the poor side are preceded by an invalid cue. Although neglect is common after right hemisphere stroke, the heterogeneity of neglect presentation renders large-scale, randomized-trial study on the phenomenon and its rehabilitation strategies extremely difficult. The present study aimed at validating and extending a model of the disengage deficit in visuo-spatial neglect in healthy individuals as recently reported by Vecera and Flevaris (in press). Twenty-four normal young adults were tested using a covert orienting target detection task with exogenous cueing at 3 stimulus-onset asynchronies (SOAs). Unlike Vecera & Flevaris, but similar to neglect patients, our results showed a DD pattern only when the left side was degraded. Furthermore, and consistent with previous studies with neglect patients, the DD pattern decreased with increase in SOAs. Development of this model may be a useful method to explore some aspects of visuo-spatial neglect in normal people},
}

@inproceedings{mckee2005reflexive,
  title = {Reflexive orienting to gaze cues that look away from centre and then return does not produce inhibition of return.},
  author = {McKee, Darren and Christie, John and Klein, Raymond},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Orienting to an uninformative peripheral cue is characterized by a brief facilitation followed by a long lasting inhibition once attention is removed from the cued location. Although central gaze cues cause automatic orienting, no one has yet seen the delayed inhibitory effect. We hypothesized that this might be seen but only if attention were effectively returned to center by a return gaze. Normal subjects were presented with a central schematic face gazing straight ahead. Following a shift in gaze, accomplished only by an apparent movement of the eyes within the schematic face, to the left or right either (i) the gaze continued in this direction, (ii) the gaze returned to centre, or (iii) the outline of the face was made bolder. The time-course of gaze-directed orienting was measured by varying the interval between the gaze cue and a peripheral target appearing randomly to the left or right of the central face. Despite our efforts to unmask inhibition of return by ensuring that attention was removed from the cued (gazed at) location we robustly failed to elicit IOR in this paradigm.},
}

@inproceedings{arsenault2005don,
  title = {Don't Ignore Me! The Role of Directed Attention in Directed Forgetting},
  author = {Arsenault, Angela and Taylor-Helmick, Tracy},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {A standard item-method directed forgetting task presented sequential word pairs consisting of two differently colored words. Participants were instructed to attend or ignore designated words based on color. Immediately following the each word pair, a remember or forget memory cue was presented aurally. Succeeding study, a recognition test measured participants' retention of both forget and remember cued words, regardless of attention instruction (attend or ignore). Percentage correct scores for attended words illustrate superior recognition performance on remember-cued as compared to forget-cued words, indicative of a robust directed forgetting effect. In contrast, this effect was not evident from recognition performance for ignored words. Interesting trends, such as the potential for a reverse directed forgetting effect for ignored words, and the role of fixed attention capacity, will be discussed.},
}

@inproceedings{hamonhill2005music,
  title = {Music: Cheescake or a primer of social cognitions?},
  author = {Hamon-Hill, Cindy and Frankland, Bradley},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Music has been identified as integral to human emotional and social development and may play a strong functional role in strengthening alliances between like-minded individuals. It is proposed that music may have a priming effect on mechanisms underlying social cognitions. An outline for a study investigating a priming effect by a musical manipulation will be presented. Subjects exposed to a musical treatment will be asked to interpret short video segments of animated geometric shapes. The quality and quantity of social attributions in their responses will be compared to those of a control group. Methodology and expectations will be discussed.},
}

@inproceedings{watt2005brief,
  title = {A Brief Cognitive-Behavioral Treatment Designed to Reduce Anxiety Sensitivity: Evidence from a Randomized Controlled Trial.},
  author = {Watt, Margo C. and Stewart, Sherry H.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Anxiety sensitivity (AS) refers to the fear of arousal-related sensations. AS is a known risk factor for anxiety and related disorders (e.g., depression, substance abuse). For the past two years, a brief cognitive behavioral (CBT) group intervention has been conducted with first year undergraduate female students at Dalhousie and StFX Universities. Participants were classified as either high or low in AS, according to their scores on the Anxiety Sensitivity Index (ASI; Peterson & Reiss, 1992). They then were randomly assigned to participate in 3 one-hour, small group sessions of either CBT to lower AS (psychoeducation, cognitive restructuring and physical exercise interoceptive exposure) or a control group seminar (discussion about psychology ethics). Measures of anxiety, as well as depression and drinking behaviour, were assessed at three time points: pre-, immediately post-, and approximately 10 weeks post-participation. Findings are discussed in terms of implications of such treatment for the prevention of important psychological disorders.},
}

@inproceedings{uman2005psychologica,
  title = {Psychological interventions for needle-related procedural pain: Results of a systematic review for the Cochrane Collaboration},
  author = {Uman, Lindsay and Chambers, Christine and McGrath, Pat and Kisely, S.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The purpose of this review was to assess the efficacy of psychological approaches for the management of needle-related pain and distress in children. We conducted a systematic review for the Cochrane Collaboration of all randomized controlled trials (RCTs) examining psychological interventions for needle pain and distress in children aged 2 to 19 years. A variety of cognitive behavioural approaches were examined. Pain and distress outcomes were assessed by self and observer report, as well as observational and physiological measures. Preliminary searches yielded 137 possible studies; of these 17 met criteria and were included (N=1311). Weighted mean differences with 95% confidence intervals were calculated for all outcome categories. Preliminary analyses indicate that psychological interventions, particularly distraction, hypnosis, preparation, memory alteration, and coaching were effective in reducing pain and/or distress. Insufficient data were available to assess the efficacy of a number of other common cognitive-behavioural interventions. Preliminary results provide support for the efficacy of certain psychological interventions for reducing needle pain and distress.},
}

@inproceedings{mcgonnell2005programme,
  title = {Programme Evaluation of the Colchester East Hants Attention Deficit Hyperactivity Disorder Clinic},
  author = {McGonnell, Melissa and Corkum, Penny},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The purpose of this study was to conduct a programme evaluation of the Colchester East Hants Attention Deficit Hyperactivity Disorder Clinic (ADHD Clinic). The ADHD Clinic is a partnership between the Colchester East Hants Health Authority and the Chignecto Central School Board with strong ties to Dalhousie University and has been operating since the fall of 2000. Informal feedback has led to the demand for increase and expanded services by the ADHD Clinic. Before undertaking any enhancement of the services it currently offers, it was decided that an evaluation of current services as well as the satisfaction of the stakeholders in the ADHD Clinic and of its clients should be undertaken. In Phase 1 of this evaluation, stakeholders were interviewed regarding their thoughts about their roles as well as the current functioning of the clinic with regard to teamwork, the organisation of the clinic day, and the information provided to families and schools. Stakeholders had generally very positive feelings about the ADHD Clinic along with many suggestions for future directions. Stakeholders were also asked about their thoughts about Phase 2 of the evaluation. In Phase 2, surveys will be mailed to parents, family doctors, and teachers, of the children who have attended the clinic to date, so as to determine their beliefs about the services provided by the ADHD Clinic and their suggestions for possible improvements.},
}

@inproceedings{moon2005painful,
  title = {Painful procedures in the pediatric emergency department: A DVD-based intervention program for child pain and anxiety},
  author = {Moon, Erin C. and McGrath, Patrick J. and Chambers, Christine T. and Sinclair, Douglas and Fitzpatrick, Eleanor},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {This talk will provide an overview of a DVD-based intervention program developed for school-aged children undergoing painful procedures in the emergency department. The intervention program is designed to reduce the pain and anxiety children experience when they have venepunctures (needles) as part of their emergency department care. Two short DVD's are included in the intervention program, both of which will be presented to children and their parents on a portable DVD player in the emergency department. The first DVD instructs children and parents on how to use distraction and relaxation techniques, which recent studies have shown to be effective at reducing children's pain and distress during medical procedures. The second DVD is an age-appropriate movie that will be used to distract children from their venepunctures. In addition to the overview of the intervention program, this talk will describe a research protocol developed in order to examine the effectiveness of the intervention.},
}

@inproceedings{kiefte2005auditory,
  title = {Auditory Representation of Vowel Spectra},
  author = {Kiefte, Michael and Macintosh, Sara},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Several attempts have been made to estimate the auditory representation of vowel spectra in human listeners analogous to what has been obtained via single unit recordings in the auditory nerve of non-human animal surrogates. One such attempt with human subjects uses the pulsation-threshold technique to evaluate masking patterns with complex maskers such as steady-state vowels. However, it is not clear what this psychoacoustic task is measuring and there is a clear potential for strong bias effects. This paper describes a preliminary attempt to eliminate some of that bias and presents data from several listeners. We also discuss some remaining problems with the paradigm.},
}

@inproceedings{lewis2005development,
  title = {The development of a measure to elucidate motivations for self-injury: The Self-injury Motivations Scale (SIMS)},
  author = {Lewis, Stephen},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {To date, empirical and theoretical works have attempted to articulate motivations for self-injury (SI). The research conducted thus far has examined SI-motivations in the context of specific psychiatric illnesses (e.g. borderline personality disorder), in the context of self-poisoning only, and without accounting for proximal and distal concomitants of SI. Though useful, these finding are limited in terms of generalizability and clinical utility. Furthermore, there is currently no psychometrically sound measure by which to effectively assess motivations for SI. As such, the purpose of the present study was two-fold. First, a scale was developed to examine motivations for SI and psychometric properties were computed. Second, motivations for SI, extracted from the newly developed measure, were examined in the context of proximal and distal psychosocial SI-correlates (e.g., sex, history of abuse, sad mood). Results, clinical implications and directions for future research will be discussed.},
}

@inproceedings{breyhan2005modelling,
  title = {Modelling Alzheimer's Disease in transgenic mice},
  author = {Breyhan, Henning and Bayer, Thomas A.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The 'amyloid hypothesis' proposes that ß-amyloid is the cause of Alzheimer's disease pathogenesis. Although many transgenic mouse lines develop ß-amyloid plaques in the brain, the link between amyloid plaques and neuron loss has not clearly been established. We identified substantial age-related neuron loss in the hippocampal pyramidal cell layer of APP751/PS1 double-transgenic mice at 16 months of age. These APP751/PS1KI mice produce abundant Aß42 with an advanced onset of plaque formation, which correlated with the PS-1 knock-in gene dosage. Six month old mice hemizygous for APP751 and homozygous for PS1KI revealed a dramatic hippocampal neuron loss predominantly in CA1. Thus the APP751/PS1KI mouse model shows major neuropathological hallmarks with abundant neuron loss that is clearly independent from extracellular amyloid deposition and identifies intraneuronal Aß as a major neurotoxic risk factor. We will now conduct behavioural tests on these mice.},
}

@inproceedings{stamp2005individual,
  title = {Individual differences in locomotor reactivity to novelty predicts expression of the transcription factor delta FosB in the central reward circuitry of the mouse},
  author = {Stamp, Jennifer},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {In laboratory rodents, individual vulnerability for self-administration can be predicted by locomotor response to a novel environment. Animals that show high behavioural reactivity to a novel environment (known as high responders or HR) acquire self-administration much more readily than animals that display lower behavioural reactivity (low responders or LR). The present study attempted to characterize molecular differences between HR and LR in the nucleus accumbens and striatum of mice. C57 mice were first identified HR or LR in an open field test; subsequently, Western blotting was used to determine if differences also exist in gene expression. Levels of the transcription factor, delta FosB, were found to be significantly enhanced in the nucleus accumbens of HR compared to LR. The downstream protein cyclin-dependent kinase 5 (Cdk5) did not differ between the two groups, neither in the nucleus accumbens nor dorsal striatum. Both delta FosB and Cdk5 are up-regulated after chronic drug exposure and are thought to mediate changes in the brain involved in addiction. Our findings that individual differences exist in delta FosB expression at basal levels in the reward circuitry of the brain may further clarify the long-term neural and behavioural plasticity changes involved in addiction.},
}

@inproceedings{jaworska2005behavioural,
  title = {Behavioural and neurochemical effects of early stress and Substance P antagonists in a gerbil model of human depression},
  author = {Jaworska, Natalia and Dwyer, Suzanne and Rusak, Benjamin},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The proposed research will assess an animal model of human depression, the maternal separation paradigm, using a species infrequently studied in relation to depression. The reason for using this species (Mongolian gerbil; Meriones unguiculatus) relates to the potential role of the neuropeptide Substance P (SP) in depression and/or anxiety. Several pre-clinical and clinical studies suggest that antagonism of SP receptors (neurokinin [NK]-1R), which are structurally very similar in humans and gerbils, but not in most other rodents, results in behavioural changes similar to those produced by treatment with standard antidepressants, but with fewer side effects. We will also examine the neurochemical and behavioural changes induced by early maternal separation in adult gerbils of both sexes. The lack of studies using depression and anxiety tests in gerbils also necessitates evaluating the appropriateness for this species of various behavioural tests commonly used for rats and mice.},
}

@inproceedings{mashoodh2005smell,
  title = {Smell Hath This Furry Woman Warned: The Effect of Predator Cues on Maternal Behaviour and the Implications for Offspring Development},
  author = {Mashoodh, Rahia and McLeod, Jane and Karas, Alexandra and Perrot-Sinal, Tara},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {In rodent mothers, variations in maternal behaviour during the first week of life are associated with the development of the stress response in offspring. We hypothesized that plasticity of maternal care in rats may exist to serve as the interface between the offspring and environmental conditions, such that parents can alter both physiology and behaviour of adult offspring in accordance with present environmental demands. We have started investigating this hypothesis using experiments in which rat mothers are exposed to the threat of predation after giving birth (GB). We have demonstrated that acute (1hr; given 5-6h GB) and chronic (1hr/day for 10d GB) exposure to cat odour has lasting effects on particular maternal behaviours exhibited by the rat mother. Preliminary work suggests that the offspring raised by predator-exposed mothers are generally less anxious but maintain a robust behavioural response to cat odour exposure in adulthood. Taken together, it is our contention that the use of more ecologically relevant stimuli may be more suited to the study of environmental impact upon the programming of the developing brain.},
}

@inproceedings{gadbois2005behavioural,
  title = {Behavioural ecotoxicology: Why you should care about the mummichog},
  author = {Gadbois, Simon and Bard, Shannon},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Behavioural ecotoxicology is a field in full expansion. Data is accumulating suggesting that many environmental neurotoxins and endocrine disruptors are changing the natural action patterns of many vertebrate species, influencing reproduction, foraging, homing, predator avoidance, social interactions, etc. We trace the history of this new field and present conceptual issues emanating from the convergence of many different areas (behavioural neurosciences, ecotoxicology, psychology, ethology, behavioural ecology, etc.) working towards the understanding of neurotoxins and endocrine disruptors. We also present a common animal model in ecotoxicology, the common killifish, or mummichog (Fundulus heteroclitus) that is unfortunately not well documented in ethology. We are working on an exhaustive ethogram of the species as well as specific behavioural assays that will allow the detection and/or assessment of neurotoxins and endocrine disruptors on the nervous and endocrine systems.},
}

@inproceedings{poulin2005cholinergic,
  title = {Cholinergic basal forebrain neurons containing vesicular glutamate transporter 3 project to the amygdala.},
  author = {Poulin, Amanda and Semba, Kazue},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The cholinergic basal forebrain (CBF) plays a major role in behavioural and cortical arousal. It has been suggested that some CBF neurons may co-release glutamate. A subpopulation of CBF neurons has been reported to contain vesicular glutamate transporter 3 (VGluT3). This study characterized this subpopulation of CBF neurons by examining their distribution and projections, using immunofluorescence for choline acetyltransferase (ChAT), VGluT3 and p75 nerve growth factor receptors, and retrograde tracing. ChAT+VGluT3+ neurons are located throughout the BF. Few of these neurons are positive for p75. ChAT+ axon terminals found in the neocortex, hippocampus and thalamus were devoid of VGluT3. The basolateral amygdala, which receives projections from p75-negative CBF neurons, contained numerous ChAT+VGluT+ terminals. ChAT+VGluT+ BF neurons were retrogradely labeled from the BLA. These findings indicate that a subpopulation of BF cholinergic neurons containing VGluT3 might have the capacity to release both glutamate and acetylcholine in the amygdala.},
}

@inproceedings{stevanovski2005can,
  title = {Can the N2pc be observed in the absence of distractors?},
  author = {Stevanovski, Biljana and Jolicoeur, Pierre},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Previous research suggested that the N2pc, an electrophysiological component believed to reflect the allocation of visuospatial attention, reflects distractor suppression (e.g., Luck & Hillyard, 1994) and is not observed for a single target in the absence of distractors. However, others have argued that the component reflects target selection ( e.g., Eimer, 1996). We examined whether the N2pc is observed in the absence of distractors. Subjects viewed a lateralised line followed 500 ms later by a centrally presented digit. A larger N2pc was observed when subjects performed a line length discrimination task than when subjects performed a digit identification task, suggesting that this component can be observed in the absence of distractors.},
}

@inproceedings{paul2005caffeine,
  title = {Caffeine evoked activation in the basal forebrain: The quest for the nameless neurons},
  author = {Paul, Alana and Cumyn, E. and Deurveilher, Samuel and Semba, Kazue},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Caffeine is a commonly used drug that acts in the brain to increase arousal. Using c-Fos as a marker of neuronal activation, we recently showed that neurons in the substantia innominata (SI), a wake-promoting region of the basal forebrain, were activated following injection of caffeine; these neurons were neither cholinergic nor parvalbumin-positive. We examined other possible phenotypes of caffeine activated neurons using double-labelling for c-Fos or Egr-1 (another neuronal activation marker) and the calcium binding proteins, calbindin-D and calretinin. We found that a moderate dose of caffeine (30 mg/kg i.p.) increased locomotor activity; this increase was positively correlated with the number of cells immunoreactive for c-Fos, but not Egr-1, in the SI. The c-Fos or Egr-1 expressing neurons did not colocalize with neither calbindin-D nor calretinin. These results indicate that the caffeine-activated neurons in the SI are not cholinergic nor contain the calcium binding proteins examined, and so the identity of these neurons is still unknown.},
}

@inproceedings{standage2005computationa,
  title = {A computational model of divided visual attention},
  author = {Standage, Dominic and Trappenberg, Thomas and Klein, Ray},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Experimental evidence on the distribution of visual attention supports the idea that environmental and cognitive influences on attention are integrated by a winner-take-all mechanism. We implement this mechanism with a computational model, testing the ability of our model to explain divergent evidence on the spatial allocation of attention. The majority of evidence supports the view that attention is unitary, but recent experiments suggest that the focus of attention may be split. We simulate two such experiments. Our results suggest that the ability to divide attention depends on sustained short-term memories, stressing the interplay between attention and working memory.},
}

@inproceedings{vigneaultmaclean2005time,
  title = {"Time after Time": Central Auditory Aftereffect for Interaural Time Difference},
  author = {Vigneault-MacLean, Bronwyn K. and Phillips, Dennis P.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {This research employs psychophysical methods to explore the neural mechanisms that the brain uses for localizing sounds in space. We are using a selective adaptation paradigm to interfere temporarily with part of the mechanism, and measuring the effect of this on a listener's ability to localize sounds. This paradigm investigates the ability of subjects to localize tonal stimuli on the basis of interaural time differences (ITDs). The subjects report the absolute position from which they perceive the sound to come - and do so before and after exposure to an adapting stimulus that consists of tones strongly lateralized to one or other side. The adaptation results in a "flattening" of the Localization vs ITD function, i.e., the range of reported positions of the test stimulus, is narrowed after exposure to the adapting stimulus. These effects inform us about the architecture of the neural machinery for sound localization.},
}

@inproceedings{dukewich2005comparing,
  title = {Comparing target detection, target localization, and target identification in a visual search paradigm},
  author = {Dukewich, Kristie R. and Klein, Raymond M.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Visual search is a fundamental everyday activity and one of the most frequently used tasks to study attention. The majority of search experiments require the participant to signal the presence or absence of a pre-specified target; however, everyday searching more typically entails finding a target that is present and localizing it (finding one's car in a parking lot) or determining one of its properties (does the yellow car have its lights on). Yet, studies of localization and identification are relatively rare, and we are aware no studies that have compared the three tasks. In the present study, participants searched an array of rotated Ls for a target, T, rotated either 90 deg. or 270 deg. from upright. Each participant searched using each of the three different tasks, counterbalanced for order. Participants were more efficient at finding the target in the present/absent task, compared to the localization and identification tasks, which did not differ. Moreover, slopes for localization and identification were significantly correlated, but neither of these correlated significantly with "present" slopes suggesting - despite conventional wisdom -that "finding the target" is a common stage underlying the slope in all three task - that the tasks may be eliciting fundamentally different search strategies.},
}

@inproceedings{eskes2005moving,
  title = {Is moving right to left from left of left harder than moving right to right from left of left after being hit in the right side of the head? John Christie & Gail},
  author = {Eskes},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Husain et al (2000) found that neglect patients were impaired in initiating a movement to the left when the damage was more parietal than frontal. This effect was independent of whether the stimulus location was to the left or right of fixation and is believed to be a motor programming deficit only in the parietal neglect patients. We have replicated their experiments in normals and imaged the behaviour using fMRI. This presentation will focus on the methods, new performance findings, and adventures in functional imaging.},
}

@inproceedings{mushquash2005structure,
  title = {The Structure of Drinking Motives in Mi'kmaq Adolescents},
  author = {Mushquash, Christopher and Stewart, Sherry and McGrath, Patrick and Comeau, Nancy},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {When psychological measures are used with cultural groups that are different from the sample the measures were developed with, it is important to evaluate the psychometric properties within the new group. The Revised Drinking Motives Questionnaire (DMQ-R; Cooper, 1994) is a 20-item self-report measure designed to quantify adolescents' reasons for drinking alcohol. Specifically, it was designed to tap levels of the four drinking motives in Cooper's model (i.e., social, enhancement, coping, and conformity). Respondents rate their relative frequency of drinking for each of the indicated reasons on a 5-point Likert scale. The factor structure of the DMQ-R was examined in a sample of First Nations (i.e., Mi'kmaq) adolescents. Exploratory factor analysis was used because the factor structure of the DMQ-R has not been examined previously in this group. Analyses indicated a three-factor structure, with enhancement and social motives not separating into two distinct factors. Moreover, community informants (e.g., school personnel) anecdotally indicated possible problems with some of the social motive items in this cultural group. A qualitative methodology will be used to determine potential reasons for the discrepancy from previous findings in the majority culture (i.e., measurement problem vs. real difference in the structure of drinking motives in the Mi'kmaq culture).},
}

@inproceedings{stewart2005relations,
  title = {Relations between personality variables and risky drinking motives in aboriginal adolescents.},
  author = {Stewart, Sherry and English, Kaitlin and Comeau, Nancy},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {164 high school students from two Aboriginal communities in NS completed a measure of personality risk for substance abuse - the Substance Use Risk Profile Scale [SURPS] - which taps anxiety sensitivity (AS), hopelessness (HOP), sensation seeking (SS), and impulsivity (IMP). The 96 drinkers also completed the Drinking Motives Questionnaire - Revised, which taps coping, conformity, enhancement, and social drinking motives. AS was correlated with conformity drinking motives. HOP was marginally positively correlated with coping drinking motives and significantly negatively correlated with enhancement and social motives. SS was correlated with enhancement and social motives. IMP was correlated with all four drinking motives. The SURPS appears a valid measure for tapping personality variables related to risky drinking motives in Aboriginal teens. Similarities and differences between the present findings and those observed in a sample of teens from the majority culture will be discussed with emphasis on possible cultural factors contributing to the observed differences.},
}

@inproceedings{emms2005mri,
  title = {MRI-based anatomical analysis of the caudate nucleus in children with attention-deficit/hyperactivity disorder.},
  author = {Emms, Mandy and Bernier, Denise and MacMaster, Frank and Rusak, Benjamin and Carrey, Normand},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Attention-deficit/hyperactivity disorder (ADHD) is a childhood onset behavioural disorder that affects 3-5% of school age children and is characterized by inattention, impulsivity and hyperactivity. Anatomical studies using magnetic resonance imaging (MRI) have reported differences between controls and children with ADHD in the size and structure of the caudate nuclei, but results have not been consistent across studies. In this study, two observers, blinded with respect to group assignment, quantified the size and shape of the caudate nuclei of 6 boys (6-8 years of age) and 6 age-matched controls using manual tracing of the whole caudate in MR images. Analysis included detailed volumetric measurements of the caudate in each section through the nucleus, studied in the sagittal, coronal and horizontal planes. Analysis revealed that while the ADHD children did not differ in total caudate volume from controls, they showed a significant localized volume loss. The main finding of the study was that the central region of the left caudate was significantly smaller in the children with ADHD, as well as the caudal region of the left caudate and the rostral region of the right caudate. These findings of localized volume loss on both the left and right caudate nuclei help elucidate why previous neuroimaging studies have found such varied results when assessing total caudate volume.},
}

@inproceedings{kuznetsova2005tissue,
  title = {Tissue Type Classification of Brain Regions of Interest in Magnetic Resonance Images},
  author = {Kuznetsova, Antonina and Bernier, Denise and Alda, Martin and Hajek, T. and Rusak, Benjamin and Fisk, John},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Magnetic resonance spectroscopy (MRS) is a method for examining concentrations of metabolites in circumscribed areas of the living brain (regions of interest; ROIs). Any given ROI may contain different tissue types (white matter, grey matter and cerebrospinal fluid), the proportions of which will affect interpretation of MRS data. The purpose of this study is to compare the ability of two commonly used software packages (Brain Voyager QX v. 2 and AFNI) to perform automated tissue-type classification of ROIs accurately and reliably. We will use twenty anatomical (T1-weighted) MR brain images collected using a 1.5 Tesla General Electric scanner and containing 60 ROIs in the in the left medial temporal lobe, in the right and left dorsal pre-frontal cortex, and in the right and left medial pre-frontal cortex. Two experimenters familiar with these methods will independently use the standard AFNI and Brain Voyager procedures for tissue type classification on these ROIs. Intra-rater reliability of 95% and above and inter-rater reliability of 90% and above will be considered acceptable. Validity of classification results produced by each method will be assessed by a blind expert rater who will be asked to visually assess each ROI and to determine which software provided the most accurate representation of tissue type proportions in each one. The outcome measure will be the frequency with which each method is chosen.},
}

@inproceedings{gunde2005validation,
  title = {Validation of High-field MRI Volumetric Assessment of Morphological Changes in Olfactory Structures in Humans},
  author = {Gunde, Eva and Good, Kim},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Recent neuroimaging studies have reported significantly smaller than normal olfactory bulb volumes associated with impaired olfactory performance in patients with schizophrenia and related psychotic disorders. The small dimensions of the olfactory bulb and tract, however, make in vivo volumetric assessment of these structures difficult. The present study was undertaken to investigate the feasibility of using of high field (4T) structural MRI to perform volumetric analysis of the olfactory bulb and tract in patients with psychotic disorders in comparison with healthy volunteers in order to determine parameters that will generate optimal signal quality. A second objective of the study was to determine reliability and validity of performing volumetric assessments. A replica of the adult human olfactory bulb and tract was constructed and three-dimensional, high-resolution imaging was performed. Our findings indicate that volumetric assessment of human olfactory structures can be achieved with high field MRI in order to examine putative differences between patients with psychotic disorders and control subjects.},
}

@inproceedings{macleod2005individual,
  title = {Do individual differences in inhibition of return and single target discrimination ability affect visual search efficiency?},
  author = {MacLeod, Jeffery},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {We investigated whether amount of inhibition of return (IOR: a tendency for slower responses to targets presented at previously attended locations) and discrimination ability can predict individual differences in visual search efficiency. There is suggestion that IOR can act as a 'foraging facilitator' in visual search by working as a type of implicit memory system that discourages re-inspection of items. Also, it was suspected that search efficiency should vary with individual discrimination ability, as search difficulty can vary with the similarity between targets and distractors. Three tasks were used: a single-item discrimination task (target/non-target discrimination), a visuo-spatial attention task (to measure IOR), and a visual search and probe task (to measure search efficiency and IOR to a probe presented following search). Amount of IOR following search and discrimination ability were each found to be significantly correlated with search efficiency: increasing amount of IOR and increasing discrimination ability predicted increasing search efficiency. Findings support the proposal that IOR is a foraging facilitator, and suggest that discrimination ability is a rate-determining factor in visual search.},
}

@inproceedings{li2005doing,
  title = {"Doing the Locomotion" With the Rat Perifornical Hypothalamus: Who's excited about glutamate?},
  author = {Li, Frederick and Deurveilher, Samuel and Morgan, Christina and Semba, Kazue},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The present study examined the role of glutamatergic inputs to the perifornical lateral hypothalamus PeFLH in the regulation of various arousal-related behaviors. Rats received a unilateral microinjection of vehicle or glutamate receptor agonists, AMPA (1 or 2mM) or NMDA (10mM), and were placed into an open field for a 90-min video recording. Rats were then perfused and processed for double-label immunohistochemistry for c-Fos, a marker for neuronal activation, and orexin, a neuronal phenotype exclusive to this region. As compared to vehicle, AMPA and NMDA injections increased the total distance traveled within 90 min. The number of cells immunoreactive for both c-Fos and orexin increased at the injection site. These results suggest that glutamatergic inputs to orexin neurons in the PeFLH may play an important role in locomotor activity.},
}

@inproceedings{shaw2005neuronal,
  title = {Neuronal or glial origin for the electroretinogram (ERG) in insect eyes?},
  author = {Shaw, Steve},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {An insect's CNS is isolated from its circulation by a blood-brain barrier, derived from which is a blood-eye barrier (BEB). Because visual neurons cross this BEB, their electrical activity should generate responses across it. This is the conventional explanation for the unusually large extracellular waves recorded in the eye as the electroretinogram (ERG). The ON- and OFF-responses of the ERG are supposed to come from monopolar neurons directly postsynaptic to the photoreceptors, in the first synaptic zone, the lamina. The ERG is employed widely to gauge whether the first synapse is working normally, following genetic perturbations aimed at dissecting the molecular mechanisms underlying cycling of the photoreceptors' neurotransmitter, histamine. Do monopolar neurons really generate the ERG transients? Simultaneous recordings of the ERG and intracellular recordings from visual neurons suggest not. A high resistance barrier proximal to the lamina (likely the marginal glial cells) appears to generate the ERG transients. Monopolar neurons cross this glial zone so their responses should also contribute to the ERG, and candidate wavelets exist. Their small size indicates that the ERG currents from the glia are much larger than those coming from the neurons. These glial cells are obviously light-responsive: the same histamine release may activate both glia and monopolar neurons. At least for those interested in presynaptic mechanisms, ERG transients from glia merely substitute a glial origin for a response so far assumed to be neuronal.},
}

@inproceedings{boudreau2005caffeine,
  title = {Caffeine's role in conditioning preference and palatability shifts.},
  author = {Boudreau, Sarah and LoLordo, Vin},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Caffeine is one of the most widely consumed psychoactive substances in the human population. Human data indicate both an increased wanting and liking for substances containing caffeine. The current study sought to further examine the role of caffeine in liking and wanting. Rats were implanted with intraoral cannula that allowed infusion of solution directly into the mouth. On CS+ trials grape or cherry Kool-Aid was mixed into a tap water solution with caffeine, and on CS- trials the other flavor was mixed with water alone, in a counterbalanced procedure. Rats were given thirteen days of training; six days with the CS+ solution, and seven days with the CS- solution. Experimental bottles were placed on the cages overnight, and removed the next morning in a single alternation schedule. Following training, rats were given a taste reactivity test (TRT) with each Kool-Aid-water solution. Each TRT consisted of placing the rat in the TR chamber, and infusing the Kool-Aid solution for 2 minutes while recording the rat's orofacial reactions. Immediately following the TRTs, all rats were given two overnight two-bottle preference tests. Both groups showed a preference for the CS+ in the two-bottle test, but there was no evidence from the TR data of an appetitive palatability shift towards the CS+. These data indicate that while the rats learned to want the Kool-Aid previously paired with caffeine more then the Kool-Aid paired with water, they did not learn to like it any more then the CS-.},
}

@inproceedings{ishigami2005using,
  title = {Using illusory line motion to explore attentional capture},
  author = {Ishigami, Yoko and Klein, Ray and Christie, John},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Uninformative peripheral cues (figure-8 markers) and targets (an 8 changing to a 2 or 5) were combined with illusory line motion (ILM) probes to explore attentional capture. Markers were presented above, below, left and right of fixation. Any marker could brighten but for a particular participant targets only appeared on the horizontal or vertical axes. Occasionally, a diagonal line was presented connecting two of the 8s. Such lines are seen to be drawn away from a cue when the cue is adjacent to the line. We used ILM and digit identification performance to measure how endogenous attention (allocated to the 8s that could change to targets) modulates the cue‚s signal strength. Digit identification reaction time and accuracy revealed that attention was captured by exogenous cues even when they were presented at task irrelevant locations. Whereas the reported magnitude of ILM away from an adjacent cue was not significantly affected by endogenous attentional control settings, ILM was weakly experienced in lines not adjacent to a cue in a manner suggesting endogenous generation of ILM.},
}

@inproceedings{grandy2005opposite,
  title = {Opposite representations of object mass by the perceptual and sensorimotor systems in the size-weight illusion},
  author = {Grandy, Mathew S. and Westwood, David A.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Goodale and Milner's (1992) duplex vision model suggests that separate visual pathways underlie object perception and the control of object-directed actions. Virtually all the research behind this model is based on tasks for which (1) vision is the primary or exclusive sensory input, and (2) grasping is the motor output. Recently, Flanagan & Beltzner (2000) showed that perceptual and motor responses to the size-weight illusion (in which a smaller object is perceived to weigh more than a larger object of identical mass) can also be dissociated. Using faulty logic, they claimed to have shown a dissociation between the effect of the SWI on perceptual reports of object mass and on the scaling of lifting forces used to pick up the object. We show in the present study using superior methods that the sensorimotor and perceptual systems clearly generate separate (and indeed opposite) representations of object mass in the SWI over repeated lifting episodes. This finding has clear and important implications for understanding multi-sensory integration for perception and action.},
}

@inproceedings{salmon2005affect,
  title = {The Affect of Short Musical Phrases with Different Melodic Contours},
  author = {Salmon, Joshua and Frankland, Bradley},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The affect (emotional content) induced by music has been assessed in longer pieces of music, mainly by reference to constructs such as modality, pitch height, tempo, and tonality. Specifically, major keys sound happy, minor keys sad, higher keys (pitches) more uplifting, faster tempos more exciting, and tonal pieces more pleasant to listen to. Note that terms like modality tempo and tonality refer to broad qualities of music leading to broad affective experience. Less is known about the affective quality of melodic contour, possibly because it is so hard to define. We propose to explore the relationship between induced affect and the attributes of the melodic contour on a note-by-note basis. Using short (8-14 notes) simple phrases of different melodic contours, the primary goal is to tease out the specific aspects of contour that lead to affective responses to music. The second goal is to create computational models of structures that lead to induced affect. POSTERS},
}

@inproceedings{goldwateradler2005bullying,
  title = {Bullying of Children with Autistic Spectrum Disorders: A Review of the Literature},
  author = {Goldwater-Adler, Samantha and Bryson, Susan E.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {To date, the empirical literature on the prevalence and nature of bullying of youth with autistic spectrum disorders (ASD) is sparse, at best. However, clinical, parental and first-hand accounts all implicate an increased prevalence of peer-victimization and social exclusion for this group as compared to that for typical children (e.g., Little, 2002; Jackson, 2002), consistent with reports for children with other learning and intellectual disabilities (e.g., Mishna, 2003). Furthermore, the key characteristics of victims of bullying correspond to the primary deficits found in those with ASDs, specifically, poor social skills, few friendships (Griffin & Gross, 2004; Yude et al., 1998), and negative communication beliefs and abilities (Storch et al., 2002). The severity of the adverse outcomes of bullying, including increased risk of mood and anxiety disorders (Griffin & Gross, 2004) and even suicide (Coggan et al., 2003), is an issue of pressing concern. Our review of the relevant literature focuses on recommendations for future research and for the development of intervention strategies oriented to the special needs of children with ASDs and related learning problems.},
}

@inproceedings{grant2005impact,
  title = {Impact of Positive & Anxious Mood on Alcohol-Related Cognitions in Internally Motivated Drinkers},
  author = {Grant, Valerie V. and Stewart, Sherry H.},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {This study investigated the impact of mood on the alcohol-related cognitions of undergraduates who drink to cope with anxiety (CM-anxiety) versus those who drink to enhance positive mood states (EM). Participants were randomly assigned to either a positive or anxious musical mood induction condition. We expected that EM (but not CM-anxiety) participants would exhibit increases in explicit emotional reward expectancies following exposure to the positive mood induction procedure and that CM-anxiety (but not EM) participants would show increases in explicit emotional relief expectancies after exposure to the anxious mood induction procedure. Also, we anticipated that EM (but not CM-anxiety) participants would have longer colour-naming latencies (in a Stroop task) for alcohol versus non-alcohol targets in the positive mood condition and that CM-anxiety (but not EM) participants would have longer colour-naming latencies for alcohol versus non-alcohol targets in the anxious mood condition. Preliminary results will be presented.},
}

@inproceedings{parker2005lions,
  title = {Lions and Tigers and Bears - Oh My! Conceptual Categorization in Adults.},
  author = {Parker, Jennifer and Jacques, Sophie},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {Conceptual categorization, grouping objects into structured categories, is a critical developmental achievement. People can group objects thematically (objects co-occurring in the same event; lion and circus), perceptually (similar looking objects; ball and apple), or taxonomically (objects belonging to the same semantic category; tiger and bear). Preschoolers have thematic and perceptual biases, whereas older children tend to match taxonomically. However, in exp. 1 with adults, we found that they also show a first-choice selection bias for matching thematically. In exp. 2, we examined the role of language in adults' categorization preferences using a dual-task paradigm. Participants were given 3 versions of a match-to-sample task in which they selected two objects that were related to the target object in different ways while either doing nothing, saying a word repeatedly, or smacking their lips. Results suggest that language may be important for categorization as participants took longer to make their first selection in the verbal-interference condition than in the other conditions.},
}

@inproceedings{leung2005how,
  title = {How do kids spell?},
  author = {Leung, Dilys and Deacon, Heléne},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {The way children think about words may have an influence on how they spell. Many studies have shown that young children spell based on how words sound (e.g. Read, 1986). However, other research has shown that young children use their knowledge of morphemes, or the smallest units of meaning, to help them spell (e.g. Treiman & Bourassa, 2000). The current study investigates young children's use of morphological information when spelling inflections and derivations. Children are asked to choose the spelling for the same word-final sound sequence in 3 types of words: inflected (-er; e.g. smarter); derived (-er and -or; e.g. teacher and director); and one-morpheme (-er and -or; e.g. number and author). Preliminary results indicate that 6- and 7-year-olds have some knowledge of the relationship between morphemes and spelling. The results will be discussed in the context of current theories of spelling development.},
}

@inproceedings{deacon2005criss,
  title = {Criss-cross: The role of language-skills in reading in developing bilinguals},
  author = {Deacon, Heléne},
  booktitle = {31st Annual Psychology and Neuroscience In-House Convention, Dalhousie University},
  year = {2005},
  abstract = {We report on the results of a three year study following six-year-old English speaking children in a French immersion programme. This study focused on the roles of language-related skills, such as phonological and morphological awareness, in reading development. Results show that skills in each language contribute to reading in the other, showing that skills can be used across languages. Intriguingly, the patterns of contributions change as children's French language and reading abilities develop. Results will be discussed in the context of current theories of bilingual reading development.},
}

@inproceedings{craig2006expressive,
  title = {Expressive and Receptive Pain Language and Its Relationship to General Language Development Among Healthy Children},
  author = {Craig, Tessa J. and Chambers, Christine T.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Recent research has shown that young children tend to rely on a select number of words to describe pain. The purpose of the current study was to extend previous research by examining receptive as well as expressive pain language in children, and to examine the relationship between pain language and children's general vocabulary skills. Sixty children (30 boys; 30 girls) aged 3-6 years (M = 4.17, SD = 1.03) and a parent (93% mothers) participated in the study. Parents completed a questionnaire assessing the degree with which their children used and understood seven words for pain, and the age at which they first started to use and understand these words. Children's general vocabularies were assessed using two standardized measures of vocabulary development: the PPVT-III and the EVT. Results indicated that 'hurt' was used most frequently and was best understood by the children, appearing in their vocabularies at 28 months of age. 'Pain' and 'ache' were rated as being infrequently used and poorly understood, and did not appear in children's vocabularies until around 40 months of age. There were no significant relationships between children's expressive and receptive pain language and their scores on the measures of general expressive and receptive vocabulary (r's = .06 to .22). These results have implications for developmentally appropriate assessment of pain in young children.},
  note = {Poster},
}

@inproceedings{parker2006equating,
  title = {Equating Secondary Tasks: A Dual-Task Investigation in 5-Year-Old Children Or… Doing Two Tasks at the Same Time Should be Harder Than Doing Just One (But Apparently It Isn't)},
  author = {Parker, Jennifer A. and Jacques, Sophie},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Two experiments were performed with 5-year-old children to establish equivalent verbal and nonverbal secondary tasks for use in future dual-task studies. Children's response time on a simple primary task was measured while they were asked to perform a series of concurrent secondary tasks. The primary task in the first experiment required children to touch a target on a computer screen, while in the second experiment, they were asked to draw a continuous path. Children in both studies participated in five secondary task conditions. They were asked to repeat one word continuously in two verbal secondary tasks (i.e., "ball" vs. "candy"); they were asked to make a facial movement in the two nonverbal secondary tasks (i.e., smack their lips vs. make a kissy face); and they were not asked to perform any secondary tasks in a control condition. Interestingly, it was found that children's response times in the control condition were not faster than those in secondary task conditions. These findings are consistent with Luria's theory on the verbal regulation of motor behaviour.},
  note = {Poster},
}

@inproceedings{pike2006using,
  title = {Using the Attention Network Test to Measure Three Types of Attention in Children with Attention Deficit/Hyperactivity Disorder},
  author = {Pike, Meredith and Mullane, Jennifer and Corkum, Penny},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The Attention Network Theory (Posner & Peterson, 1990) proposes that there are three functionally and anatomically independent networks of attention: Executive, Alerting and Orienting. The Executive and Alerting networks are thought by some researchers to be impaired in children with ADHD. Recently, the Attention Network Test (ANT) was developed to measure these three networks simultaneously. To date, the ANT has never been used in children with ADHD. In the current study, the ANT was given to 20 children with ADHD. The results validate the utility of the ANT as a new measure for studying attention in children with ADHD. As well, further evidence for the independence of the three attention networks was found which provides further evidence of support for the Attention Network Theory.},
  note = {Poster},
}

@inproceedings{knickle2006influence,
  title = {The Influence of Subtype on Academic Difficulties and Cognitive Profiles in Children with ADHD},
  author = {Knickle, Laura and McGonnell, Melissa and Corkum, Penny},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {It has been proposed that the subtypes of ADHD differ in their cognitive and academic profiles, as well as in their symptom profiles and demographic characteristics. However, the results of previous research has been inconsistent, most likely due to a number of limitations, including poorly diagnosed ADHD samples and lack of standardized assessment of cognitive and academic skills. The present study included 64 children who received a diagnosis of ADHD-Combined Type or ADHD-Inattentive Type based on a rigorous, interdisciplinary assessment process. It was found that the ADHD subtypes did not differ in terms of their age of diagnosis, sex distribution, mean IQ scores or academic performance, but that the ADHD-Inattentive Type had less comorbid mental health problems and higher socio-economic level. The results question the clinical utility of the subtypes in helping to understand cognitive and academic performance in elementary school-aged children.},
  note = {Poster},
}

@inproceedings{ironside2006impact,
  title = {Impact of Methylphenidate on Sleep and Daytime Alertness in Children with Attention-Deficit/Hyperactivity Disorder.},
  author = {Ironside, Sarah and Corkum, Penny},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Changes in sleep quality related to treatment with methylphenidate and potential daytime sequelae of sleep disturbances were evaluated across a randomized placebo-controlled medication trial in 15 children, rigorously diagnosed with attention-deficit/hyperactivity disorder (ADHD). Data were analyzed with a repeated measures ANOVA and contrast analyses. Parents and teachers reported an improvement in ADHD symptoms on medication. Parent questionnaires and actigraphy indicated increased sleep disruption on medication. Significant changes in sleep duration, time to fall asleep, and wake episodes were recorded, with no significant changes in sleep efficiency or nocturnal activity. No changes in daytime alertness were reported, but preliminary evidence of hypersomnolence after discontinuation of medication is presented. Results and implications of the study for treatment of children with ADHD are discussed.},
  note = {Poster},
}

@inproceedings{junek2006effects,
  title = {Effects of sleep deprivation on hippocampal plasticity in adult rats},
  author = {Junek, Adrienne and Rusak, Ben and Semba, Kazue},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Sleep deprivation for 96 h decreases hippocampal cell proliferation in rats (J Physiol 2003 549:563). We are currently investigating whether sleep deprivation for 6, 12, 24, and 48 h can produce the same effect. We are also investigating any changes in hippocampal PSA-NCAM expression after sleep deprivation. Adult male rats were sleep deprived using a modified Wahmann running wheel, injected with bromodeoxyuridine (BrdU, a marker for cell proliferation) 2 h before the end of the SD, and perfused at the end of SD. Blood samples were also collected for plasma corticosterone analysis in order to assess the stressfulness of SD. Preliminary counts of BrdU-immunoreactive cells in the dentate gyrus show a small but significant increase in cell proliferation after 12 h SD, and a trend for decreased cell proliferation after 24 and 48 h SD.},
  note = {Poster},
}

@inproceedings{mazerolle2006event,
  title = {Event-related potential methods for evaluating functional status in epilepsy},
  author = {Mazerolle, Erin L. and D'Arcy, Ryan C.N. and Bolster, R. Bruce},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Neuropsychological assessment in temporal lobe epilepsy (TLE) can be augmented by event-related potential (ERP) methods that evaluate the functional status of tissue adjacent to medial epileptogenic foci. Anterolateral temporal regions have been linked to visual object recognition (VOR) in healthy controls. We propose an ERP method for assessing the functional integrity of anterolateral temporal regions using a word-picture matching task. The semantic level of the word (basic versus superordinate) and the object category (natural versus artifactual) were manipulated in order to identify components that are sensitive to intact VOR. Distributed sources were modeled to determine whether these components were localized to anterolateral temporal lobe regions. ERP components that were sensitive to both semantic level and object category manipulations were identified in healthy controls. Furthermore, one of these components was localized to the anterolateral temporal lobes. The findings demonstrate that the spatiotemporal information provided by ERPs can potentially be used to evaluate the functional status of the anterolateral temporal lobes. This approach can be applied in epilepsy assessment to, for example, guide surgical intervention in TLE.},
  note = {Poster},
}

@inproceedings{brewer2006spiraling,
  title = {Spiraling into Control: Overcoming fMRI susceptibility to artifacts in the inferior temporal lobe},
  author = {Brewer, Kim and Gawryluk, Jodie and Rioux, James and Bowen, Chris and D'Arcy, Ryan C.N. and Beyea, Steven},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {We are developing a site directed functional magnetic resonance imaging (fMRI) approach to guide pre-surgical mapping in patients with temporal lobe epilepsy (TLE). Susceptibility effects are the basis of functional imaging, however, susceptibility induced signal loss also occurs at numerous tissue-sinus interfaces. This signal loss creates artifacts in the inferior temporal lobes and orbitofrontal area, thereby limiting the ability to detect functional activation in these regions. The current investigation utilized a 4 tesla imaging system to examine alternative fMRI techniques with the objective of reducing artifacts caused by susceptibility. Specifically, the commonly utilized technique of echo-planar imaging (EPI) was compared to spiral out and spiral in methods of image acquisition. Compared to EPI and spiral out, the spiral in technique has produced promising results. Utilizing spiral in, it is possible to gain functional information at the tissue-sinus interface. To our knowledge, this represents the first demonstration of spiral in methods at 4 tesla. Application of this novel technique will allow for advanced pre-surgical functional mapping research on temporal lobe epilepsy.},
  note = {Poster},
}

@inproceedings{moore2006studies,
  title = {Studies in visual-proprioceptive integration},
  author = {Moore, Chris},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Integration of information over visual and proprioceptive modalities is an important means for establishing a sense of self in early development. Recently, we have been studying this process in adults through two approaches. First, we examine the temporal parameters of visual-proprioceptive integration by showing adult participants delayed video (from 0 to 5 video frames) of their own arm and facial movements. Our results show a discrimination of live from delayed video for both hand and facial movements at delays of over 2 video frames (66 msec). Second, we have been investigating whether the rubber hand illusion first described by Botvinick & Cohen (1998) for visual-tactile information extends to visual-proprioceptive information. In our study, participants have a rubber hand attached to their own hand with a brace. They watch the rubber hand as they move their own hand behind a screen and then report on whether they experience the movement in the rubber hand. Our results to date indicate that the rubber hand illusion does extend to visual-proprioceptive integration.},
}

@inproceedings{salmon2006affect,
  title = {The Affect of Short Musical Sequences with Different Melodic Contours},
  author = {Salmon, Joshua and Frankland, Bradley},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {This research examined the relationship between affect (emotional content) and the shape of 16 equi-temporal eight note musical sequences designed to differ only on melodic contour (ascending, descending, arch, inverted-arch, etc.). Two groups of participants rated the intended affect of each sequence on ten bipolar affect scales (contentment-joy, delicacy-strength, excitement-boredom, passivity-aggression, etc.). Modeling of melodic contour was done using fourth-order polynomial equations. Of which, the first term captures the average pitch height. The second term captures the ascending / descending aspect of the shape. The third term captures the arch aspect of the shape. Higher order terms capture nuances. The analysis indicated that pitch height was a primary predictor on eight of the affect scales. However, the analysis also indicated that the ascending/ descending aspect was important for five affect scales, while the degree of arch was important for eight affect scales. Different terms were important for different affect scales.},
}

@inproceedings{mckee2006information,
  title = {Do the information processing differences in figure and ground reported by Wong & Weisstein (1983) generalize to a speeded orientation discrimination task?},
  author = {McKee, Darren},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Wong and Weisstein (1983) reported that sharp line targets were detected better within a visual region perceived as figure while blurred line targets were detected better within a region perceived as background. They interpreted these results as evidence for two modes of visual processing: 1) high spatial-frequency channels that facilitate figure analysis and 2) low spatial-frequency channels that facilitate ground analysis. These results have not been replicated and until now, no published work has demonstrated whether they generalize beyond the narrow range of methods used in the original study. The current investigation examined the generalizability of their findings using similar figure/ground and target stimuli and a better choice of target locations within the figure/ground drawing. The task was also changed from one of detection to one of horizontal/vertical line discrimination. The findings failed to replicate Wong and Weisstein. As such, their results do not generalize after minor methodological alterations.},
}

@inproceedings{wassersug2006mechanistic,
  title = {Mechanistic Issues in Human Coitus: Implications to Sexual Recovery after Iatrogenic Impotence},
  author = {Wassersug, Richard},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Tens of thousands of men become impotent each year as a result of either the surgery or radiation used to treat prostate cancer. For approximately a third of these men, phosphodiesterase 5 (PDE5) inhibitors, such as Viagra, are ineffective. Many studies indicate that this loss of sexual function undermines the men's self-esteem and lowers their overall quality of life. In this talk I will review options for these patients. I will discuss the limitations of current treatments for erectile dysfunction and introduce a counter-intuitive work-around for recovery of rewarding sex that completely circumvents the issue of penile erectility. I will provide a hypothesis, based on neural activity in cortical sensory fields, for why this approach works. I will also discuss the psycho-social challenges to making novel approaches to sex therapy acceptable to men and their partners, the majority of whom are senior citizens.},
}

@inproceedings{bandstra2006role,
  title = {The Role of Child Life in Pediatric Pain Management},
  author = {Bandstra, Nancy and Skinner, L. and LeBlanc, C. and Moores, C. and Brennan, D. and Chambers, C.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {There is now strong support in the use of non-pharmacological approaches for reducing children's pain and distress during painful medical procedures. Although an exponential growth in knowledge in these techniques has occurred in the past decade, studies continue to suggest that children are undertreated for their pain. This research project is being conducted to examine child life specialists' role in pediatric pain management. While it is generally known that child life specialists make an important contribution in terms of pediatric pain management, no research has described the specific pain management strategies used by child life specialists. The purpose of the current study is 1) to describe the strategies currently being used by child life specialists to manage pediatric pain 2) to describe how effective child life specialists find these strategies to be, and finally, 3) to determine how much training experience child life specialists have in pediatric pain management and assess the level of interest in receiving more training. Child life specialists from hospitals across Canada will be invited to complete an online questionnaire concerning their use of various non-pharmacological pain management strategies to help pediatric patients cope with pain.},
}

@inproceedings{porter2006investigatio,
  title = {Investigations of Affective Processing and Psychopathy using fMRI},
  author = {Porter, Steve and Leslie, Ron and Schmidt, Matthias},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Antisocial Personality Disorder (APSD) is a personality disorder characterized by a major affective deficit accompanied by a disregard for societal rules in general (e.g., Hare, 1996). A subset of those with APSD can be characterized as manipulative, callous, remorseless, irresponsible individuals (e.g., Hare, 1996, 1998), or as having psychopathic traits. According to Patrick (1994), a central feature of psychopathy is the deviant affective response. Since individuals with psychopathic characteristics appear to have emotional deficits, the question remains as to whether or not these deficits have a neurological basis. The limited existing studies that have used neuroimaging techniques implicate brain abnormalities in psychopathy and antisocial behaviour. The main objective of this program of research will be to determine how the brain processes affective visual and audio information in normal controls and in individuals with psychopathic characteristics. This research will shed light on the underlying neural deficits postulated to be associated with psychopathy, which may in turn help explain the antisocial behaviour that is characteristic of this disorder.},
}

@inproceedings{macswain2006gender,
  title = {Gender differences in implicit and explicit cognitions pertaining to anxiety},
  author = {MacSwain, Kerry Lynn and Watt, Margo C.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Previous research has found that women (vs. men) yield higher anxiety scores on both explicit and implicit measures of cognitions related to trait anxiety and anxiety sensitivity (AS). In addition to this, the correlation between implicit and explicit measures of trait anxiety is higher for women, suggesting that explicit measures reflect this underlying personality construct more accurately in women than in men. The present study proposes to further investigate these gender differences in cognitions related to anxiety. Participants will complete two explicit measures and two implicit measures of trait anxiety and AS, including a newer implicit measure known as the Extrinsic Affective Simon Task (EAST). It is hypothesized that women (vs. men) will yield higher anxiety scores on implicit and explicit measures of cognition. It is also expected that the correlations between implicit and explicit anxiety measures will be higher for women than men.},
}

@inproceedings{vriend2006sleep,
  title = {Sleep on it},
  author = {Vriend, Jennifer and Ivanoff, Jason and Vaughan, Angeline and Christie, John and Rusak, Ben},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The Visual Discrimination Task (VDT) is a sensory learning task, performance on which has been reported to depend on sleep intervening between initial acquisition and later testing. We studied VDT performance in 21 subjects (19 F, 2 M, aged 20-27), each in two conditions: once with, and once without, a 2 h nap opportunity (13:30-15:30) intervening between morning training (08:30) and evening testing (19:00). Performance improvement was assessed as the difference between morning and evening performance during each session. Subjects were divided into good versus bad nappers based on whether they showed at least 2 min of REM and 2 min of Slow Wave Sleep during the nap opportunity. Good nappers improved more during the day in the nap session than did bad nappers. This improvement, however, depended entirely on good nappers performing poorly during the morning of the nap session. The results suggest the hypothesis that sleep may improve newly acquired cognitive skills only in people who are relatively sleep deprived.},
}

@inproceedings{baldwin2006effects,
  title = {The Effects of Positive and Negative Mood States on Mood-Regulation Gambling Outcome Expectancies},
  author = {Baldwin, Jane and Mushquash, Chris},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {This study aimed to clarify how positive and negative mood states influence the mood-regulation gambling outcome expectancies of undergraduate gamblers, as self-reported on a recently developed questionnaire (the Gambling Expectancies Questionnaire; GEQ). Participants were 91 undergraduate psychology students, aged 18 or older, who reported regular gambling. Participants were randomly assigned to a positive or negative musical mood induction procedure (MMIP) or to a neutral mood control. The GEQ was administered at baseline and after the MMIP to determine changes in reward and relief expectancy strength. The hypotheses of mood specificity of the activation of reward and relief expectancies were only partially supported. The trend of increased reward expectancies following positive mood induction was expected; however, the trends of increased relief expectancies following positive mood induction and decreased reward expectancies following negative mood induction were unexpected. Further research and potential clinical implications are discussed.},
}

@inproceedings{currie2006effect,
  title = {The Effect of Outcome Expectancy on Depression and Quality of Life in Rural Stroke Survivors},
  author = {Currie, Shannon},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Patient recovery expectations are related to health outcomes and have been found to be influence the success of treatment. The relationship between outcome expectancy and overall functioning has potential implications for the rehabilitative process of patients with a chronic illness; however this relationship has not yet been explored in stroke survivors. The purpose of the present study is to examine the relationship between outcome expectancies and depression and quality of life in rural stroke survivors. A measure of outcome expectancy was designed to assess 13 different domains of outcome within 6 broad categories of memory, physical functioning, social relationships, leisure and occupational activities, dependence, and overall expectations. This measure was included in the Yarmouth Stroke Project (YSP) interviews, which are currently being conducted and include qualitative and quantitative questions that address psychosocial functioning. The development and efficacy of the expectancy measure will be discussed with reference to preliminary results if available.},
}

@inproceedings{boutilier2006history,
  title = {The History of Psychology at Dalhousie},
  author = {Boutilier, Lisa and Clark, Daniel and Longard, Julie and Singh, Sarbjeet},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Psychology at Dalhousie has a rich past, filled with interesting personalities, and dedicated and driven researchers. In some ways, it is a microcosm of the development of disciplinary psychology over the past century and a half, yet with a unique Nova Scotian flavour. This is the story of an unwelcome Freudian and a Prince whose connections to the President allowed him to move the department into the White House. It is also the story of an award-winning architectural wonder and how respectability was brought to "snake oil salesmen." And it is the story of a chairman who brought wolves to Nova Scotia, and another who added a seal tank to the LSC. And it is also a lament that Richard Brown's exile to Sable Island failed. The class interviewed past and present faculty and staff, including six department chairs. Students conducted extensive archival research, and began the construction of an extensive report on the development of this leading psychology department in Canada.},
}

@inproceedings{paul2006eyes,
  title = {Are my eyes playing tricks on me? Evidence of inhibitory neurotransmitter actions of β-alanine in the salamander retina},
  author = {Paul, Alana R. and Barnes, Steve},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {β-Alanine is a putative inhibitory neurotransmitter in the central nervous system. Using calcium imaging, the responses of neurons in living retinal slices were investigated during exposure to β-alanine, glycine, GABAA agonist, muscimol, and GABAC agonist, cis-4-aminocrotonic acid. At 1 mM, β-alanine caused inhibition of depolarization-induced calcium responses in both photoreceptors (PRs) and inner nuclear layer (INL) cells, similar to results seen with 500 μM muscimol and glycine. However, 200 μM β-alanine caused enhancement (possibly due to disinhibition) of calcium response in PRs, and an ambivalent response in INL cells. Neither glycine nor muscimol caused this enhancement. It is possible that β-alanine can inhibit both PRs and INL cells, but that it has more potent effects in the INL and thus at lower concentrations, β-alanine selectively inhibits cells in the INL. This response to β-alanine could provide evidence for a novel β-alaninergic signalling pathway in the retina involving inhibition of cells presynaptic to PRs.},
}

@inproceedings{kutcher2006non,
  title = {Non-Phosphorylated Neurofilament Labeling is Regulated by Visual Experience in the Kitten Lateral Geniculate Nucleus: Implications for Anatomical Remodeling During the Critical Period.},
  author = {Kutcher, Matthew and Duffy, Kevin},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Monocular deprivation (MD) during early development causes rearrangement of neural connectivity that can produce severe and permanent vision impairment. Neurons in deprived layers of the lateral geniculate nucleus (LGN) exhibit smaller somata and reduced geniculocortical terminal fields compared to neurons in non-deprived layers. The mechanisms underlying these deprivation-induced changes are unknown. We have demonstrated a correlation between structural change and cytoskeleton alteration in visually deprived cats. Following 4 days of MD, neurons within deprived layers of the LGN were smaller than those in non-deprived layers, and this structural change was accompanied by a spatially and temporally coincident reduction in neurofilament labeling. Recovery of cell-size and neurofilament labeling was observed after 4 days of post-deprivation binocular visual experience. The recovery appeared to be complete after 8 days of binocular vision. The results from our study support the hypothesis that cytoskeleton alteration provides a substrate for deprivation-induced neuronal restructuring.},
}

@inproceedings{mitchell2006not,
  title = {Not all visual input is created equal: Normal input is more efficacious for development of the visual cortex and for vision.},
  author = {Mitchell, Donald E and Sengpiel, Frank},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Continuous monocular deprivation during early postnatal life results in reduced cortical and visual acuity of the deprived eye. However, loss of visual function in one eye after a brief period of compromised vision would appear to be maladaptive. Previously we have reared cats with a daily regimen in which they received variable amounts of MD and BE and subsequently assessed the visual capabilities of the two eyes. Here we report on visual cortex function on the basis of optical imaging of intrinsic signals. As with behaviour, we show that daily amounts of binocular vision as short as 0.5 h allowed normal ocular dominance architecture and visual responses to develop despite much longer periods of MD. However, unlike vision where the outcome appears to be dictated by the proportion of total exposure that is normal, cortical architecture appears to be determined by the absolute amount of binocular vision rather than its relative share. As with behaviour, continuous binocular experience was more effective for cortical development than an equivalent exposure split into two epochs. Normal experience is clearly more efficacious in driving visual cortical development and experience, vision than abnormal experience.},
}

@inproceedings{wood2006swim,
  title = {The Swim of the Mummichog},
  author = {Wood, Heather-Dawn and Lingley, Jacob and Gadbois, Simon},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The present experiment sought to determine if Fundulus heteroclitus (the common killifish or mummichog) would use distal visual cues or proximal landmarks to complete an innovative place preference paradigm. A plus maze consisting of four empty beige saucers and one enriched darker saucer was used to exploit the mummichog's innate preference for concealment. In condition 1, 10 fish were trained with a high-contrast, extra-maze distal cue, situated over the enriched saucer. In condition 2, 10 fish were trained with proximal landmarks situated in the entrance of the arm leading to the enriched saucer. Experimental trials consisted of displacing the visual cues and recording accuracy. Error rate for condition 2 was found to be significantly lower than condition 1, indicating fish using proximal landmarks had significantly fewer errors than fish using distal cues. These results promote the present paradigm as a useful fish cognitive task for research across the fields of ecotoxicology, ethology, and psychology.},
}

@inproceedings{braubach2006learning,
  title = {Learning about Learning from Zebrafish},
  author = {Braubach, Oliver and Fine, Alan and Croll, Roger},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The zebrafish olfactory system is emerging as an important model for studying neural processing of chemosensory information. This is largely due to its accessibility for in vivo physiological studies and also the ease of genetically manipulating this system. While our knowledge about the neurophysiology of zebrafish olfaction is advancing rapidly, these fish have not yet been widely used in studies of olfactory behavior. We therefore sought to develop various assays to study olfactory-driven behaviors and learning in zebrafish. We have succeeded in conditioning zebrafish to respond to specific odorants in order to obtain a food reward, while at the same time conditioning them to ignore other odors of similar quality. Physiological recordings in the zebrafish olfactory system will enable us to pinpoint regions in the olfactory bulb that are responsive to specific odorants. Combining these approaches allows us to induce behavioral plasticity that can be correlated with detailed physiological data to reveal neural substrates activated and modified in olfactory learning.},
}

@inproceedings{vriend2006sleepa,
  title = {Sleep on it},
  author = {Vriend, Jennifer and Ivanoff, Jason and Vaughan, Angeline and Christie, John and Rusak, Ben},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The Visual Discrimination Task (VDT) is a sensory learning task, performance on which has been reported to depend on sleep intervening between initial acquisition and later testing. We studied VDT performance in 21 subjects (19 F, 2 M, aged 20-27), each in two conditions: once with, and once without, a 2 h nap opportunity (13:30-15:30) intervening between morning training (08:30) and evening testing (19:00). Performance improvement was assessed as the difference between morning and evening performance during each session. Subjects were divided into good versus bad nappers based on whether they showed at least 2 min of REM and 2 min of Slow Wave Sleep during the nap opportunity. Good nappers improved more during the day in the nap session than did bad nappers. This improvement, however, depended entirely on good nappers performing poorly during the morning of the nap session. The results suggest the hypothesis that sleep may improve newly acquired cognitive skills only in people who are relatively sleep deprived.},
}

@inproceedings{lau2006sleep,
  title = {"I Sleep Therefore Can I Think": Effects of Obstructive Sleep Apnea on Neurocognitive Function},
  author = {Lau, Esther Y Y},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Obstructive sleep apnea (OSA) is characterized by disrupted breathing during sleep, leading to hypoxemia and fragmented sleep at night, daytime sleepiness, and changes in cognition and mood. Individuals treated with CPAP (continuous positive airway pressure) report improved fatigue and better sleep, yet commonly continue to have complaints of persistent cognitive dysfunction and reduced performance at work and daily activities, particularly those that require executive functions. The purpose of the study is to investigate the executive function of individuals with OSA on treatment with CPAP. OSA patients and matched controls will be compared on experimental working memory tasks, standardized neuropsychological battery, measures of mood, daily functioning and quality of life. All patients and some controls will also receive an overnight polysomnographic sleep study to characterize their current sleep. It is hypothesized that while CPAP may improve sleep and thus attentional capacity related to the excessive daytime sleepiness, performance on tasks measuring executive control will continue to be impaired.},
}

@inproceedings{bellhouse2006effect,
  title = {The Effect of Mood on Susceptibility to Misinformation Regarding Emotional Photographs},
  author = {Bellhouse, Sabrina},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The current study will investigate the influence of mood and the emotional valence of stimuli on accuracy of recall and susceptibility to the misinformation effect. A negative, positive, or neutral mood will be induced in participants using a musical mood induction technique. Participants will then be shown three emotional photographs: one negative, one neutral, and one positive, and after a delay will be asked accurate or misleading questions regarding details contained in the photographs. After a second delay, half of the participants will answer open-ended questions about certain details that were in the photographs that they saw, and the other half will be shown two photographs (one original and one altered to incorporate the misinformation in the misleading questions) and will be asked to select the original photograph that they saw.},
}

@inproceedings{uman2006differences,
  title = {Differences in High and Low Anxiety Sensitive Women's Responses to a Laboratory-Based Cold Pressor Task},
  author = {Uman, Lindsay S. and Stewart, Sherry H. and Watt, Margo C. and Johnston, Amber},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Anxiety sensitivity (AS) or the fear of anxiety-related sensations has been recently linked to a variety of disabling chronic health conditions including pain-related conditions (Asmundson et al., 2000). In the present study, 90 undergraduate university women were selected for inclusion in one of two AS groups (high or low) based on their screening scores on a 16-item measure of AS. Participants were tested individually on a lab-based cold pressor task using a variety of self-report and observer-measured variables. Data analyses revealed that, as expected, the high AS participants reported significantly more fear in response to the cold pressor on the McGill Pain Questionnaire - Short Form (SF-MPQ) than did the low AS participants. Also as expected, the high AS participants reported more pain in response to the cold pressor on the Present Pain Index (PPI) of the SF-MPQ than did the low AS participants. High AS participants did not differ from low AS participants on other aspects of the cold pressor response (e.g., pain threshold, pain tolerance, pain recovery). Results also provide support for the role of pain-related fear as a mediating variable between AS and increased perceived pain intensity.},
}

@inproceedings{arsenault2006didn,
  title = {?I didn?t forget it, I just remembered something else instead!?: Examining possible attentional allocation in directed forgetting.},
  author = {Arsenault, Angela},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {A standard item-method directed forgetting task presented sequential word pairs consisting of two differently colored words. Participants were instructed to attend or ignore designated words based on color. Immediately following the presentation of each word pair, a remember or forget memory cue was presented aurally. Following study, a recognition test assessed memory of both forget and remember-cued words, regardless of attention instruction (attend or ignore). As expected, percentage correct scores for attended words illustrate superior recognition performance on remember-cued as compared to forget-cued words, indicative of a robust directed forgetting effect. In contrast, memory performance on ignored words shows an interesting potential trend for a reverse directed forgetting effect. It appears as though withdraw of attention from forget-cued words is succeeded by attention to irrelevant information, such as ignored words. Support for attention models of directed forgetting and applications will be discussed.},
}

@inproceedings{hoffman2006come,
  title = {We've Come a Long Way in 35 years},
  author = {Hoffman, Ron},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {In September of 1971, the Life Sciences Centre opened to house the departments of Psychology, Biology and Oceanography (in order of importance, although you could argue the last two) at Dalhousie. Just four years earlier, the Tupper Medical building had opened, complete with basement television studio, bringing home-grown moving imagery to modern teaching at the university. The Psychology Department enthusiastically embraced this new technology for both teaching and research, and pushed to have a television studio included in the new LSC. The first consumer-level video recording equipment appeared at the same time, and our initial occupation of the LSC was accompanied by much video making. Most of that early work has been lost, and much of what remains is nearly irredeemable due to deterioration of the media and changing standards in video technology. This presentation will give you a taste of the historical records we are losing and suggest that perhaps we should be doing a better job of documenting the history of what arguably has been one of the most influential Psychology departments in Canada.},
}

@inproceedings{fawcett2006relationship,
  title = {The Relationship between Attention and Forgetting in Humans},
  author = {Fawcett, Jonathan and Taylor, Tracy L.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Reaction time (RT) was measured in response to visual detection probes embedded within an item-method directed forgetting paradigm. Study words were presented individually followed by an instruction to remember (R) or forget (F). Probes were presented at stimulus onset asynchronies (SOAs) of 1400, 1800, or 2600 ms in relation to the study word or the memory instruction. No-probe catch trials and a no-word control condition were included to evaluate false alarms and provide a subtractive baseline measure. At the end of all study trials, a yes-no recognition task measured retention of R and F words. The results demonstrated a tendency for post-F instruction probe RTs to be longer than post-R instruction probe RTs at the two earliest SOAs; this effect was marginally significant at the 1400 ms SOA and statistically significant at the 1800 ms SOA. Recognition data indicated a significant directed forgetting effect, with better recognition of R than F words. These findings suggest that intentional forgetting requires more attentional resources than remembering.},
}

@inproceedings{oleary2006learning,
  title = {Learning and memory in C57BL/6J mice on the Barnes maze with a fixed or randomly located escape hole.},
  author = {O'Leary, Timothy P. and Brown, Richard E.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {The Barnes circular maze is a visuo-spatial learning and memory task that was originally designed for rats, and has been adapted for use with mice. In the Barnes maze, animals use extra-maze visual cues to locate a hole that provides escape from aversive bright light. To determine if mice use extra-maze visual cues in the Barnes maze, male and female C57BL/6J mice were trained with the escape hole in a fixed location, or moved randomly across trials, so that extra-maze visual cues could not predict the location of the escape hole. Mice trained with the escape hole in a fixed position made fewer errors, traveled shorter distances and searched more accurately during probe trials than mice trained with a randomly positioned escape hole, indicating that mice may use extra-maze visual cues in the Barnes maze. Sex differences were found for some training phases but not others, and will be discussed.},
}

@inproceedings{wright2006effects,
  title = {The Effects of Repeated Exposure to Cat Odour on Behavioural and Endocrinological Stress Responding in the Rat},
  author = {Wright, Lisa and Mashoodh, Rahia and Hébert, Kimberly and Perrot-Sinal, Tara},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Acute exposure of a rodent to a predatory odour is an ethologically appropriate stressor that induces robust and quantifiable behavioural and physiological responses. Predator odour (PO) exposure therefore models psychological stress experience and may be used to study the long-term consequences of continued or repeated activation of the hypothalamic-pituitary-adrenal (HPA) axis and hypersecretion of glucocorticoids (GCs), which are linked to the development of various anxiety and depression-related neuropsychiatric illnesses in both men and women. The goal of the present study was to characterize changes in behavioural and hormonal responses to predation threat across a period of chronic odour exposure, and also to examine sex differences in such changes. This was achieved by exposing groups (n=12) of adult male and female Long Evans rats to a PO or control odour (CO) stimulus for one hour/day over a period of 22 days. Behavioural responses were examined on the first exposure day and every fourth day thereafter. Corticosterone (CORT) levels were assayed from blood samples collected during a baseline condition, and following exposure conditions at the beginning and end of the chronic odour exposure period. Interestingly, patterns of behavioural change across the exposure period were similar for PO and CO exposed rats, although the magnitude of behaviours remained very different. There were also sex-specific alterations in GC release, with both CO and PO exposed females showing higher levels of plasma CORT at the end of the chronic odour exposure period relative to the beginning. In a subsequent study, we will characterize the temporal profile of GC release following initial exposure to PO.},
}

@inproceedings{alcolado2006flavour,
  title = {Flavour-Flavour Learning in a Devaluation Procedure Controlling for Post-Ingestive Effects.},
  author = {Alcolado, Gillian M. and LoLordo, Vincent M.},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {We were looking for evidence of flavour-flavour learning across long delays between flavour presentations. Twenty-six male rats received pairings of a neutral flavour with a delayed, differently flavoured carbohydrate, and pairings of a second neutral flavour with another delayed, differently flavoured carbohydrate. A third neutral flavour was presented alone. Then one of the flavoured carbohydrates was devalued by pairing it with an injection of lithium chloride. All rats avoided the devalued flavoured carbohydrate in a test pitting it against the non-devalued flavoured carbohydrate, supporting the effectiveness of the devaluation procedure. Most rats failed to avoid the neutral flavour that had been paired with the devalued carbohydrate when it was pitted against the neutral flavour that had been paired with the non-devalued carbohydrate. However, one subgroup that didn't have mint as one of the flavours paired with a carbohydrate learned the association, suggesting that replication with truly neutral flavours is merited.},
}

@inproceedings{boudreau2006utilizing,
  title = {Utilizing Caffeine Dependence To Condition An Avoidance To A Novel Flavor},
  author = {Boudreau, Sarah},
  booktitle = {32nd Annual Psychology and Neuroscience In-House Conference, Dalhousie University},
  year = {2006},
  abstract = {Male Sprague-Dawley rats were given chronic exposure to caffeine in their drinking water for 21 days in an effort to establish caffeine dependence. They were then given daily 30-minute trials with a Kool-Aid/Saccharin flavor (Maintenance CS), after each of which the caffeinated drinking water was returned. Rats were then given daily 30-minute access to a different Kool-Aid/Saccharin flavor (Withdrawal CS), followed by tap water allowing the rats to go into caffeine withdrawal. All rats were then given a 24-hour two-bottle test pitting the Maintenance and Withdrawal CSs against each other. The rats overwhelmingly avoided the Kool-Aid/Saccharin flavor paired with caffeine withdrawal symptoms, and drank more of the Maintenance CS. Based on these results, we can conclude that caffeine dependence was established, and that dependence can be used to condition an avoidance to a flavor paired with caffeine withdrawal. POSTERS},
}

