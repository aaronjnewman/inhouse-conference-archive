  title = {Some Behavioral Correlates of Mate-Choice in the Coyote (Canis latrans).},
  author = {Bennett, C. N.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
