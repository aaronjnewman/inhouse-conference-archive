@inproceedings{bishop1994does,
  title = {DOES ATTENTION MEDIA TE THE RELATION BETWEEN CATASTROPHIZING AND PAIN?},
  author = {Bishop, Scott},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Catastrophizing has been identified as an individual difference variable that contributes to increased distress reactions during painful experiences. Catastrophizing has been described as a tendency to engage in pain-related negative ideation characterized by rumination, magnification of threat, and lack of confidence and control. Research has been consistent in showing that catastrophizing is associated with increased pain and emotional distress during painful stimulaton. However, there has been little research examining the mechanisms that mediate the relation between catastrophizing and distress reactions. Based on recent findings in our lab, I will present a model in which will suggest that attentional processes mediate the relation between catastrophizing and pain. Future research and implications will also be discussed.},
  note = {QA: needs-split-review; Split from T11 at: 'Tl 2. Scott Bishop'},
}

@inproceedings{antle1994getting,
  title = {Getting a GRiP on GRouP GRoPe in the Light},
  author = {Antle, Michael and Piggins, Hugh and Rusak, Benjamin},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {In rodents, the suprachiasmatic nucleus (SCN) of the hypothalamus is the circadian pacemaker. The SCN contains various substances which may be involved in photic entrainment of the pacemaker. The bombesin like peptide, gastrin-releasing peptide (GRP) is one such substance. The present study was designed to determine if GRP would phase shift hamsters housed in continuous illumination. GRP was found to produce "light pulse-like" shifts when injected to the SCN. These results suggest that GRP may be involved in photic entrainment.},
  note = {QA: needs-split-review; Split from T11-split1 at: 'Michael Antle'},
}

@inproceedings{antle1994gettinga,
  title = {Getting a GRiP on GRouP GRoPe in the Light},
  author = {Antle, Michael and Piggins, Hugh and Rusak, Benjamin},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {In rodents, the suprachiasmatic nucleus (SCN) of the hypothalamus is the circadian pacemaker. The SCN contains various substances which may be involved in photic entrainment of the pacemaker. The bombesin like peptide, gastrin-releasing peptide (GRP) is one such substance. The present study was designed to determine if GRP would phase shift hamsters housed in continuous illumination. GRP was found to produce "light pulse-like" shifts when injected to the SCN. These results suggest that GRP may be involved in photic entrainment.},
}

@inproceedings{phillips1994functional,
  title = {FUNCTIONAL SPECIALIZATION IN THE CAT'S AUDITORY CORTEX (Or: What Needles in the Posterior Area Reveal About God's Inventiveness)},
  author = {Phillips, D.P. and Semple, M.N. and Kitzes, L.M.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The cat's auditory sensory cortex contains a number of territories distinguished by their anatomy and the internal organization of their frequency maps. Much quantitative evidence is available on the physiology of cells in the primary auditory field (AD, but virtually nothing is known of the physiology of neurons in the other territories. In anesthetized, adult cats, we explored the posterior auditory field (P), studying individual neurons with stimulus paradigms that have previously been used to study AI cells. We found that the majority (70-90%) of field P neurons had properties seen in a minority (20-30%) of AI cells: powerful lateral inhibition, apparent tuning to the amplitude of preferred-frequency tones, and sensitivity to the rise-time of tonal signals. The minimal latencies of field P cells were slightly longer than those of AI cells. These findings raise the question of whether field P cells derive their input from the subset of AI cells that already possess these properties.},
}

@inproceedings{frankland1994weon,
  title = {WeOn Geons},
  author = {Frankland, B. W. and McMullen, P.A.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Biederman's (1987) Recognition-by-Components proposal argued that a limited set of categorically-perceived, geometric, three-dimensional visual primitives (geons) form the (neurological) basis of all object perception. To test the prediction of categorical perception, a continuum of three-dimensional volumes between a block and cylinder (two geons advocated by Biederman) was constructed, rendered in a two-dimensional computer display, and presented to subjects. In a multiphase, two- altemative, timed, forced-choice decision, subjects repeatedly labelled each volume as block or cylinder. In Phase 1, subjects established a baseline boundary between the block and cylinder. The sharp discontinuity between the two provided evidence for a categorical boundary. In Phase 2, subjects were presented with either the block or cylinder in an anempt to exhaust the (neurological) detectors for that object (adaptation). In Phase 3, the categorical perception of block versus cylinder was reassessed. After adaptation, relative to its Phase 1 position, the categorical boundary shifted towards the adapting stimulus. The shift was in the predicted direction supporting the existence of geons.},
}

@inproceedings{twum1994now,
  title = {NOW YOU SEE IT, NOW YOU DON'T: ROLE OF ATTENTION IN PRIMING},
  author = {Twum, Maxwell and Eskes, Gail},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Many recent studies show that attention manipulation has little effect on perceptually driven implicit tests of memory. In these studies, priming (nonconscious facilitation of processing due to previous study) is obtained even when attention is divided between the target information and another ongoing task. There are, however, no studies that have directly compared the amount of priming obtained as a function of the amount of attention given to target information. The present study was conducted to further investigate whether focal attention was necessary for priming. It was hypothesized that if focal attention was crucial for priming, then greater priming could be expected where attention was focused on the target information. The Stroop Color-Word paradigm was used to manipulate attention to the words. In this paradigm, different groups of subjects either read words, named the ink in which the the words were printed or named the ink color of a series of XXX:s which were presented simultaneously at different locations on a computer screen. Retention of the words was later tested using both cued recall (explicit) and word fragment completion (implicit) tests. Priming was obtained in all conditions of the experiment. However, only priming for the word-reading condition was significantly different from baseline performance. There were no differences in priming for naming the ink of the words and the XXX:s. There was also greater explicit cued recall when subjects read the words. Implication of these results will be discussed in the framework of attention and information processing.},
}

@inproceedings{cantoni1994social,
  title = {SOCIAL AND SPATIAL ORGANIZATION OF FREE-RANGING SHREWS},
  author = {Cantoni, Debora},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The social organization of free-ranging Sorex coronatus and Neomys fodiens was studied by measuring the spatial distribution and temporal avoidance or aggregation of individuals, using simultaneous radio-isotope tracking of several shrews. Sorex coronatus was strictly territorial during the non-breeding season, with little overlap between home ranges and low coincident activity between individuals. In the breeding season, females remained strictly territorial, whereas large home range overlap between males and females and also between males was observed. During this season, males kept intensive watch on one female and occasionally visited a second, in tum was regularly visited by another male. This behaviour suggests a monogamous mating system with a tendency towards polygamy. Neomys fodiens • was territorial during the non-breeding season. Each individual defended a portion of a river but a slightly greater home range overlap was observed between than within the sexes. During the breeding season, females remained strict!~ territorial, whereas males tended to wander, indicating an ]Joverlap promiscuous,I mating system. After weaning, juveniles of both species dispersed rapidly and became territorial until the following breeding season. These results were compared with published data on Crocidura russula. During the non-breeding season, there are two types of social organization: a colonial system in C. russula, where coincident rest between individuals allows them to reduce their daily expenditure of energy by social thermoregulation; and a territorial system in S. coronatus and N. fodiens, which may ensure an adequate food supply. During the breeding season for all three species females are strictly territorial perhaps to ensure they have sufficient food for their litters. For the males, three different strategies have been observed and these are also discussed .},
}

@inproceedings{losier1994line,
  title = {LINE BISECTION AND VISUAL ORIENTATION ERRORS ALONG HORIZONTAL AND VERTICAL PLANES IN PERIPERSONAL AND EXTRAPERSONAL SPACE IN PATIENTS WITH VISUOSPATIAL NEGLECT: A PROPOSAL},
  author = {Losier, Bruno J.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {In recent years, line bisection and visual orientation studies of visuospatial neglect have been prolific, but the evidence provided has been fixed by physical limitations and methodological moderations. Line bisections are performed manually and are confined to peripersonal space. Thus, knowledge of visuospatial deficits outside of arm's reach (e.g., extra- personal space) is missing. Similarly, the visual orientation task is carried out by comparing responses along a left-right continuum. Thus, investigation of visuospatial neglect along multiple planes is absent. The purpose of the present study will be twofold. First, it proposes to investigate line bisection and visual orientation errors along horizontal and vertical planes in peripersonal and extrapersonal space. Second, a model explicating line bisection errors is missing. It is suggested that the theoretical framework of the visual orientation task may provide an opportunity to funher elucidate on mechanisms of line bisection errors. Thus, the present study intends to illuminate mechanisms underlying bisection errors by comparing displacement errors on line bisection to errors on a visual orientation task. A proposal outlining the background and research plan will be presented.},
}

@inproceedings{scott1994met,
  title = {MET ABOTROPIC GLUTAMATE RECEPTORS IN THE HAMSTER SUPRACHIASMATIC NUCLEUS.},
  author = {Scott, George and Rusak, Benjamin},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The suprachiasmatic nuclei (SCN) of the mammalian hypothalamus function as a pacemaker which controls mammalian circadian rhythms. The SCN receive photic input via the geniculohypothalamic tract (GHT), an indirect visual pathway arising from cells in the intergeniculate leaflet (IGL) of the lateral geniculate body, with neuropeptide Y and GABA being likely neurotransmitter candidates. The SCN also receive direct visual input via the retinohypothalamic tract (RHT), and evidence suggests that the excitatory amino acid glutamate mediates neurotransmission in the RHT. Recent reports have demonstrated the presence of ionotropic excitatory amino acid receptors of the NMDA and non-NMDA receptor subclasses in the SCN. In addition, metabotropic excitatory amino acid receptors have been located in the SCN. To date, very little information is available on the effects of metabotropic receptor activation in the SCN, however, initial studies in our laboratory have demonstrated that 1S,3R ACPD, a specific metabotropic receptor agonist, causes a dose-dependent increase in neuronal activity in the SCN in vitro. Further studies aim to pharmacologically characterise metabotropic glutamate receptors in the SCN and elucidate the role of this receptor type in the SCN in vivo.},
}

@inproceedings{brown1994memory,
  title = {MEMORY FUNCTIONS IN MULTIPLE CHEMICAL SENSITIVITY},
  author = {Brown, Anne-Marie},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Case series of patients with Multiple Chemical Sensitivity (MCS) suggest difficulty on several memory tests in addition to cacosmia. Bell (1992) suggested that this pattern of symptoms might implicate focal dysfunction of the temporal lobes. To test this hypothesis a case control study was initiated to compare the pattern of memory loss in MCS, healthy controls matched for age, education and sex and :  patients with temporal lobectomy on measures of estimated pre-morbid ability, ••intelligence, attention, immediate and delayed memory for verbal and nonverbal material. Twenty-six employees from a "sick building" were referred for extensive neuro-psychological evaluations based on impairments documented in cognitive screening. The majority had MCS. Group results for MCS patients, controls and patients with temporal lobe lesions will be presented.},
  note = {QA: needs-split-review; Split from T20 at: 'T2 l. Anne-Marie Brown'},
}

@inproceedings{piggins1994time,
  title = {TIME FOR SUBSTANTIAL P?},
  author = {Piggins, Hugh D. and Cutler, David J. and Semba, Kazue and Rusak, Benjamin},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The tachykinin substance P (SP) is found throughout the mammalian central nervous system. We have demonstrated SP-like immunoreactivity in cells, fibres, and terminals of the Syrian hamster suprachiasmatic nuclei (SCN), which contain the primary circadian pacemaker. The possible role of SP in circadian processes has yet to be established. We examined the effects of ionophoretically applied SP on the extracellularly recorded firing rates of hamster SCN cells maintained in an in vitro brain slice preparation. SP evoked responses from ~54% of 85 cells tested. Most responsive cells were activated (~85%) while ~ 15% were suppressed by SP. A greater proportion of cells responded when tested during the projected day ( ~72%) than during the projected night (~38%). These preliminary data indicate that SP can alter hamster SCN neuronal activity, particularly during the subjective day.},
}

@inproceedings{stewart1994university,
  title = {UNIVERSITY STUDENTS' DRINKING MOTIVES: RELATIONSHIPS TO ANXIETY PRONENESS, ANXIETY-SENSITIVITY, AND GENDER},
  author = {Stewart, Sherry H. and Zeitlin, Sharon B.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The present study examined the relationships between anxiety-proneness (trait anxiety), anxiety-sensitivity (fear of anxiety), and self-reported reasons for drinking using a newly-validated measure of drinking motives. The State-Trait Anxiety Inventory-Trait subscale (STAI-T), the Anxiety Sensitivity Index (ASI), and the Drinking Motives Questionnaire (DMQ) were administered to 314 university students. Higher ASI scores were associated with greater scores on the Coping Motives (CM; drinking to reduce or avoid negative emotional states) subscale of the DMQ, particularly in women. In contrast, ASI scores were not related to scores on either the Enhancement Motives (EM; drinking to facilitate positive emotional states), or Social Motives (SM; drinking to meet social norms) subscales of the DMQ. A regression equation involving scores on the ASI and STAI-T significantly predicted DMQ-CM scores; the regression equation was superior in predicting the frequency of CM drinking for women vs. men. These results imply greater risk for alcohol abuse in individuals (particularly women) who are high in both anxiety-sensitivity and anxiety-proneness. i.},
}

@inproceedings{taylor1994fixation,
  title = {FIXATION OFFSETS AND COVERT ORIENTING: THE FAILURE TO FIND EFFECTS},
  author = {Taylor, Tracy and Klein, Raymond},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {When a fixation stimulus is offset prior to saccadic target onset, eye movement latencies are facilitated. The present experiment determined whether facilitation is also observed for coven attentional orienting. Subjects were presented with predictive verbal (endogenous), unpredictive visual (exogenous), or predictive visual (endogenous+exogenous) cues to one of four possible target locations. The target was the appearance of an horizontally- or a vertically-oriented ellipse, in response to which subjects made a speeded manual discrimination. The timecourse of orienting --revealed by the function relating reaction times to cue-target onset asynchrony -- was examined under three "gap" conditions, wherein on one-third of trials there was no fixation offset, on one-third of trials fixation offset occurred simultaneously with cue onset, and on one-third of trials fixation offset occurred 210 msec prior to cue onset. In none of the cue conditions was the speed of coven orienting facilitated by fixation offset.},
}

@inproceedings{brown1994behavioural,
  title = {BEHAVIOURAL DIFFERENCES OF MHC-CONGENIC MICE DURING DEVELOPMENT},
  author = {Brown, Richard and Calder, Thane and Gilben, Charles},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Since 1979, it has been known that mice that differ only in the genes of the major histo-compatibility complex (MHC) on chromosome 17 produce different urine odours. These odours thus provide phenotypic markers of the genotype of the mouse which can be used for mate selection and kin recognition. We investigated differences in the development of the behaviour of C57BL/6J (H-2b) and B6.C-H- 2bml mice, two strains which differ only in the class 1 (H-2K) region of the MHC. Thane Calder found differences in ultrasonic vocalization rates, growth rates, slight movement, grooming and eye opening in these mice and Charles Gilbert found differences in their behaviour in an open field. As developmental biologists have found that MHC-congenic mice differ in their embryonic growth rate, our hypothesis is that postnatal growth and development are also influenced by MHC type. The behavioural differences between genotypes may provide additional information for mate selection and kin recognition.},
}

@inproceedings{semba1994synaptic,
  title = {SYNAPTIC CONTROL OF WAKE- AND SLEEP-ACTIVE FOREBRAIN NEURONS},
  author = {Semba, Kazue},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {In our continuing effon to elucidate the neural networks involved in the regulation of sleep and wakefulness, we propose a series of working hypotheses that can be used to investigate synaptic control of wake- and sleep-active neurons in the basal forebrain as an integral component of regulatory mechanisms for conical arousal.},
}

@inproceedings{barresi1994cargo,
  title = {CARGO CULTS, BRANCH DAVIDIANS, BORN AGAIN VEGETARIANS, AND "THE PIOUS GENE."},
  author = {Barresi, John},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {The present paper is a commentary on a target article to be published in Behavioral and Brain Sciences by-D~S.~ils-c,_]!· &t.SoBerl;itled, "Re-introducing Group Selection to the HumaifBeliavioral Sciences."-Wilson and Sober argue that the process of group selection has~rly devalued as an evolutionary force during the past thirty years. Usin(!?_awkini,.ooncept of "vehicle", they propose an evolutionary model with a nestecffiierarchy of vehicles of selection ranging from genes to groups. In my commentary I consider the role that group selection may have ~yed in the e~olution of human religious _behavi~)Ur.In p~icular, I consider select:J.onmodel of the psychological trait of "docility" and how L ·reltgious beliefs could serve as absolute authoritative sources for eliciting docile behaviours that are often of genetic, but not necessarily of "rational", self-interest to the individual. I I r. i .},
}

@inproceedings{macgregor1994gendera,
  title = {GENDER DIFFERENCES IN THE RELATION BETWEEN MEASURES OF HOSTILITY AND RESTING SYSTOLIC BLOOD PRESSURE},
  author = {MacGregor, Michael and Davidson, Karina},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Gender differences in the ability of the Cook-Medley Hostility Scale (HO) and its subscales, and the Anger Expression Scale (AES) to predict resting systolic blood pressure were examined. Four blood pressure readings were taken at three-minute intervals and the fourth reading was used as the baseline. Following baseline readings, 99 male and 109 female undergraduate subjects completed the HO and the AES. Results indicated that for males the following HO scales were significantly positively correlated with restirtg systolic blood pressure: The HO total hostility score (I= .245, 12< .01), Costa's subscales of cynicism and paranoid alienation (r = .231, 12< .05 and r = .263, ll < .01 respectively), and Barefoots' subscales of cynicism, hostile emotion, and aggressive responding (r = .208, ll < .05; r = .328, ll < .001; and r = .315, ll < .001 respectively). For females none of the HO subscales were significantly correlated with resting systolic blood pressure. There was no relation between the AES and resting systolic blood pressure for either gender. These results are discussed in terms of the implications of using traditional measures of hostility for predicting risk for CHD in male and female populations.},
}

@inproceedings{klein1994how,
  title = {HOW CAN WE DETERMINE IF ATTENTION IS THE GENERATOR RESPONSIBLE FOR ILLUSORY LINE DRAWING?},
  author = {Klein, Raymond and MacDonald, Alan and Christie, John},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Two circles, separated by 4° are displayed on a screen. One briefly brightens and then a line connecting the two circles is added to the display. Although the line appears instantaneously, the subject's subjective experience is that the line is "drawn" from the flashed circle toward the unchanged one. The flashed circle does attract the observer's attention, and Shimojo, who discovered this line drawing illusion, attributes it to the locus of attention. Alternatively, the illusion might depend on purely visual mechanisms activated by the stimulus, such as those associated with apparent motion. We plan to compare the strength of the illusion under conditions of exogenous (externally generated, e.g. following abrupt peripheral luminance increment) and endogenous (internally generated, e.g. following verbal instruction) control over attention. Our first step was to determine if the line drawing illusion could be cancelled by presenting a line that WAS drawn over time in the direction opposite to the illusory motion.},
  note = {QA: abstract-too-short},
}

@inproceedings{christie1994negative,
  title = {NEGATIVE PRIMING: OBJECT FILE REVIEW OR SELECTIVE INHIBITION? THE METHOD MATTERS!},
  author = {Christie, John and Klein, Raymond},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Negative priming is the impaired performance that occurs when a subject has to respond to a target that occupies the same space as a previously ignored distractor. Object file review and selective inhibition are the two principal explanations for this phenomena. Object file review explains negative priming as caused by mismatch between the attributes of the target and those of the item that previously occupied the location. According to selective inhibition negative priming occurs because a distractor is not merely ignored, but actively inhibited as part of the selective process and that this carries forward to items presented later in the same space. Two experiments, using the most common methodologies were designed to test these two theories. It was also found that the relative contribution of object file review and selective inhibition depends on, as yet indeterminate methodological factors. ---},
}

@inproceedings{forbes1994nart,
  title = {THE NART AS A TOOL FOR ESTIMATING PREMORBID INTELLIGENCE IN A NORTH AMERICAN POPULATION: A WILD GOOSE CHASE?},
  author = {Forbes, Kelly and Mate-Kole, C. Charles},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {Current level of cognitive performance is not indicative of premorbid level of functioning. Estimates of premorbid intelligence are essential for determining the extent of cognitive impairment in brain damaged populations. A relatively new approach to estimating premorbid intelligence is based upon the relationship that exists between word-reading ability and general intelligence (Nelson & McKenna, 1975; Nelson & O'Connell, 1978). The National Adult Reading Test (NART), which contains orthographically irregular words, was normed on a British population and provides estimates based upon the WAIS. The present study based estimates of intelligence in a North American population on the W AIS-R. NART based predictions of intelligence were compared to other estimates based upon the Vocabulary Age Scaled score and the VIQ-PIQ discrepancy in performance on the W AIS-R. Results indicate that the NART is a useful tool for predicting premorbid intelligence in normal and brain damaged populations within a North American population.},
}

@inproceedings{yoon1994children,
  title = {CHILDREN'S UNDERSTANDING OF MENTAL MISREPRESENTATIONS},
  author = {Yoon, Myong G. and Yoon, Myonghae},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {We studied the development of children's understanding of two common types of mental misrepresentations: Holding false beliefs and forgetting previous beliefs. A person may hold a false belief about a current state of affairs due to ignorance of externally caused changes or perceptual illusions. Or a person may misrepresent a current state of affairs by simply forgetting its previous mental representation caused by internal changes within the person. The results of our experiments suggest that children's abilities for retroactive inferencing of the protagonist's forgetting from her incongruous action begin to emerge around 4y8m, about a half year later than their abilities for attribution of a false belief.},
}

@inproceedings{mitchell1994single,
  title = {SINGLE-CELL RESOLUTION OF THE CHANGES IN THE PATTERN OF INNERVATION OF AREA 17 BY THE TWO EYES FOLLOWING MONOCULAR DEPRIVATION AND ITS REVERSAL IN KITTENS},
  author = {Mitchell, D.E. and Bateman, G. and Beaver, C.J. and Ritchie, P.},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {C-Fos,the protein product of the c-fos gene, has been shown (l) to be expressed rapidly in the visual cortex of kittens following brief exposure to light Our purpose was to explore the use of Fos immunohistochemistry as a means for examining the three dimensional pattern of innervation of area 17 by the two eyes in monocularly deprived kittens as well as the speed and nature of the changes that occur subsequently following reverse occlusion. The experiments were performed on kittens that had been monocularly deprived at 1 week of age until they were 5 weeks old. To visualize the pattern of innervation of area 17 by a given eye, the animal was first placed in a darkroom for a period (24 hrs) that was sufficient for constitutive Fos expression to be driven below baseline levels of detectability. The kitten was then allowed normal visual experience with just the eye of interest open for 2 hours at which point the animal was euthanized and perfused. The immunocytochemical procedures (1) were conducted on 50 um sections cut from unfolded and flattened visual cortex. In animals exposed through the deprived eye, immunoreactive neurons were observed in patches in superfical and deeper layers of area 17. The number of immunoreactive neurons within each patch as well as the size and shape of the patches changed with increasing length of deprivation. This method permits, for the first time, visualization with cellular resolution of the columnar arrangement of territory innervated by a given eye throughout area 17 and as such may prove to be a superior method for assaying the effects of deprivation than existing methods.},
}

@inproceedings{hamm1994fast,
  title = {THE FAST LETTER GAME},
  author = {Hamm, Jeff and Taylor, Tracy},
  booktitle = {Twentieth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1994},
  abstract = {When subjects identify a target in a rapid serial visual presentation (RSVP) stream, their ability to detect a subsequent probe stimulus is reduced. Known as an attentional blink (AB), we determined whether this phenomenon depends on shared categorical membership between target and probe stimuli. We presented subjects with RSVP streams of black letters in which one white (target) letter was embedded. In half the streams, a probe (0) was one of eight post-target stimuli. For half the subjects this probe was referred to as the letter "O"; for the other half it was referredto as the digit "zero". Relative to an ignored-target control, an AB occurred in both experimental groups. However, the AB was attenuated when subjects detected zero rather than "O". This dependence of AB on categorical membership of target and probe stimuli was confirmed in a study that had subjects detect a "6" following letter identification.},
}

