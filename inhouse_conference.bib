@inproceedings{moore1995conflictinga,
  title = {Conflicting Desire And The Child's Theory Of Mind},
  author = {Moore, Chris},
  booktitle = {Twenty-First Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1995},
  abstract = {We contrast the standard representational theory of mind approach to the understanding of mental states with an alternative view which has it that theory of mind tasks require executive functioning or the inhibition of more 'cognitively salient' information. In the first experiment 3-5-year-olds were tested on their understanding of desire in others either when they themselves held a strong and conflicting desire or when they had no strong desire. Results showed that under the condition of having a strong and conflicting desire, only 5-year-olds were able to recognize that another person might desire something different In contrast when the children themselves held no strong desire, even 3-year-olds were able to judge another's desire correctly. The second experiment compared 3-year-olds' performance on a standard false belief task with that on an equivalently structured desire task in which subjects had again to inhibit their own strong and conflicting desire. Results showed similar performance on the traditional false belief task and the new conflicting desire task.},
  note = {booktitle inferred},
}

