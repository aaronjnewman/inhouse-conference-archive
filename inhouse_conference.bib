@inproceedings{m1984spatial,
  title = {Spatial Memory in Pigeons},
  author = {M, Spetch},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Previous attempts to demonstrate good spatial working memory in pigeons using the radial arm maze apparatus have met with little success, However, these studies may have inadvertently constrained the pigeon's foraging repertoire, In the present study, the pigeons' task was to locate maple peas which were hidden in eight elevated perches attached to three walls of an 8 x 8 x 10 ft test room, In condition 1, four birds were permitted to choose freely by flying between the perches until all eight peas had been consumed, Choice accuracy improved over trials, was reliably better than chance, and did not appear to depend upon response sequencing, In condition 2, the pigeons could obtain peas from only four randomly selected perches and then were allowed to choose among all eight perches to find the remaining four peas. Again, choice accuracy was above chance. In the last condition a delay of either 3, 30, or 300 sec was imposed after four peas had been obtained, Accuracy in locating the remaining peas declined as a function of delay, but remained above chance, Taken together, three results suggest that pigeons can use spatial memory to forage for food,},
}

@inproceedings{shaw1984receptors,
  title = {Receptors, Development, Plasticity, and All That Jazz.},
  author = {Shaw, C.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {We have devised methods to enable us to selectively locate and study receptors for different neurotransmitters in the visual system, We have examined receptor location in different cortical areas and in different cortical layers within a given area, Some neurotransmitter receptors appear to change their location during the first few months of postnatal life; others do not. The relationship between these findings and the critical period for cortical plasticity will be discussed.},
}

@inproceedings{honig1984anticipation,
  title = {Anticipation of Memory Interval Duration Affects Working Memory},
  author = {Honig, W. and W, Matheson},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Pigeons were trained on two similar working memory tasks that differed in the values of the memory intervals, but had one memory interval in common. The problems were run on different days, with different initial stimuli. Memory performance was strongly affected by the anticipated average duration of the memory interval, so that the birds did much better with the common memory interval from the "favorable" distribution than from the "unfavorable" distribution,},
}

@inproceedings{t1984developmenta,
  title = {Developmental Influnces on the Awareness of Causal Determinants of Behaviour},
  author = {T, Schrans and Werker, J.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {It has been suggested that the deficit in introspective awareness of causal determinants of behaviour noted by Nisbett and Wilson in 1977, may differ in both quality and degree between adults and children, In the present study it was predicted that initially children would demonstrate accurate awareness of the factors influencing their behaviour and this ability would decrease as a function of age and/or cognitive development. The research participants were 31 children; 8 males and 8 females aged 3- 4 years, and 7 males and 8 females aged 5-6 years. Each child was required to participate in three experimental tasks over two consecutive days of testing, Task 1 involved standard measures of cognitive development (conservation of number, conservation of area). Task 2 & 3 measured awareness of causal determinants of behaviour (T-shirt experiment, liking judgements). The results supported the hypothesis indicating a developmental trend or inverse relationship between age and introspective awareness of causal determinants of behaviour.},
}

@inproceedings{meijer1984projection,
  title = {Projection Phase Shifts Circadian},
  author = {Meijer, J. and B and Rusak and M and Harrington},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {The suprachiasmatic nuclei (SCN) function as the dominant pacemaking system in the mammalian circadian system. Direct electrical stimuVltion of the SCN mimics the effects of light pulses in causing phase-dependent delays and advances of behavioural rhythms. The ventral nucleus of the lateral geniculate body sends a peptidergic projection to the SCN. Application of this peptide (NPY) to the SCN or electrical stimulation of the lateral geniculate area causes phase-dependnet shifts of behavioural rhythms, but these shifts are different from those caused by light pulses. Instead, they resemble the effects on rhythmicity of dark pulses. These data suggest that release of NPY into the SCN may have the opposite effect of light on SCN neural astinity, 2 s. R. Klein, D. Pilon, S. Prosser & D. Shannahoff Nostrils, Hemispheres and Human Performance: Epiligue. Last year we described EEG data (Werntz et al,) suggesting a link between hemispheric activity and the pattern of air flow through the two nostrils, and we presented the design of an experiment to determine if human performance on hemisphere specific (verbal and spatial) tasks would be appropriately influenced by which nostril is breathing, Two such experiments, testing over 120 subjects, have now been completed- The relative performance on the verbal and spatial tasks Na3 (weakly) correlated with the pattern of nasal congestion (the nasal cycle), but 30 minutes of uninostril breathing had little effect on performance. fPOs¥"l},
}

@inproceedings{a1984several,
  title = {Several assays were used in assessing conditioned inhibition within a},
  author = {A and Delamater and Kruse, J. and Revisited, V. I.oLordo Pavlovian Conditoned Inhibition In Taste Aversion Learning},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {taste aversion procedure, Following A+, AX- training, X (NaCl) was not consistently preferred to water or diluted quinine in two-bottle tests, nor did retardation or summation tests yield consistent outcomes, We question the usefulness of CTAs for studying Pavlovian conditoned i nhi bi tion.  P0ST~J},
}

@inproceedings{e1984dual,
  title = {Dual Task Analysis of Cognitive Control of Visual Attention,},
  author = {E, Hansen and Klein, R.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {A priming paradigm was used to induce attentional shifts towards likely locations of imperative visual stimuli. Manual or saccadic responses systems showed equal costs and benefits in a single task design, Infrequent responses did not show costs and benefits in a dual task situation- A factorial set of experiments manipulated whether infrequent stimuli had to be discriminated from frequent ones, and whether primes were informative for infrequent stimuli, Costs and benefits for both stimuli were equal in the single response experiments; in the dual response experiments, infrequent stimuli/responses did not show costs an<l benefits, The assumption that locational cues orient attention towards simply a locus ln space is incomplete, /P~~'!_E~},
}

@inproceedings{frohlich1984freeze,
  title = {Freeze-Fracture of Visual Receptor Synapses in the Fly.},
  author = {Frohlich, A.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Photoreceptor axon terminals in the lamina ganglionaris, the first optic neuropile of the housefly Musca domestica, were examined using freeze- fracture technique. The p-face of the terminal membrane contalns numerous bow-tie shaped particle clusters representing the presynaptic site. In some fractures the remains of postsynaptic elements can be seen opposite these sites displaying several characteristic featu~.g., presumptive intramembraneous transmitter receptor particles. ~RJ},
}

@inproceedings{mitchell1984comparison,
  title = {Comparison of the Effects On Visual Acuity of Ablation of Visual Cortical Areas 17 and 18 in Kittens or Cats of Different Ages.},
  author = {Mitchell, D.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Previus work has shown that following complete excision of cortical area 17 and 18 in adult cats visual acuity is reduced by about a factor of two. However, comparable lesions made in infancy at between 10 and 27 days of age produce little or no deficits in visual acuity. Surprisingly, I have recently found that lesions made even earlier, on the third day of postnatal life, produce deficits comparable to those observed in animals lesioned in adulthood. This paradoxical finding may be related to the loss of X type retinal ganglion cells reported by others in animals lesioned on or about the day of birth.},
}

@inproceedings{k1984functional,
  title = {Functional Asymmetries in the Oculomotor Reflexes of Frontal and Lateral eyed animals,},
  author = {K, Grasse},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {When an animal moves around the environment an optical flow field is produced on the retina which provides information concerning the visual consequences of postural adjustments, During locomotion, the predominent vectors (e.g., horizontal or vertical) of self-motion induced optical flow fields depends among other things upon the position of eyes in the head, Some features of this dependency will be discussed,},
}

@inproceedings{droungas1984possible,
  title = {Possible involvement of Opponent Processes in the Development of Inhibition in Backward Conditioning.},
  author = {Droungas, A.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Backward conditioning (US - CS interval Q.S sec) was found to be more effective than explicitly unpaired training (US - CS interval 7 min) in resulting in inhibition when the inter-trial interval was fixed and equal in the two procedures (ITI = 7 min). Inhibition in backward conditioning was augmented when the ITI was varied unpredictably across trials; inhibition was restored when US pre-exposure preceded backward conditioning with the variable ITI. These results are discussed in view of the opponent process theory of acquired motivation (Solomon and},
}

@inproceedings{phillips1984neural,
  title = {A Neural Mechanism in the Cat's Auditory Cortex Underlying Sensitivity to Direction ~ Frequency Charige':-},
  author = {Phillips, D.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Single neurones in the cat's primary auditory cortex have restricted frequency 'response areas' within which a tone of constant frequency is able to elicit spike discharges. We have examined the sensitivity of these cells to ongoing tones in which we embedded a small (2 kHz) frequency-modulated (FM) ramp. The absolute frequency range traversed by the FM was varied in and around each cell's response area. Irrespective of their other properties, cortical neurones responded to these FM ramps with a profound direction selectivity. These neurones responded to FM ramps only if direction of frequency change was towards the centre of their response areas. The strength of directional preference depended on the amount of the response area covered by the FM ramp, and on the rate of change of the ramp's instantaneous frequency's ability to elicit spike discharges.},
}

@inproceedings{werker1984toward,
  title = {Toward an Understanding of Consonant Errors in Reading and Spelling: Severely Disabled and Normir Readers.},
  author = {Werker, J. and Bryson, S.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {This research examined how severely disabled readers read and spell common English consonants. Three groups of disabled readers were compared to both age and reading level-matched control groups. Consonant errors were analyzed according to five error types. Results replicated previous findings showing that most consonant errors can be accounted for by phonetic rather than visual substitutions. Moreover, all three groups of severely disabled readers made as many addition errors as they did phonetic substitutions, and significantly more addition errors than did the normal readers. The pattern of addition errors suggests the use of an articulatory strategy in reading.},
}

@inproceedings{james1984animal,
  title = {An Animal Model for Schizophrenia: Effects of Chronic Phencyclidine Treatments on Levels of Dopamine and DOPAC in the Extrapyrimidal and Mesolimbic Systems of the Rat.},
  author = {James, G. and Robertson, H.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Chronic treatment with phencyclidine for three weeks caused changes in the levels of dopamine and DOPACin the striatal and mesolimbic systems. The nature and extent of the change was related to the length of time the sujects were drug free prior to sacrifice. The levels of dopamine were increased shortly after phencyclidine treatment, but then drop to normal after 51 days drug free. Similarly, the levels of POPACalso fall after 21 days drug free to below control levels. Haloperidol challenge 1 hour prior to sacrifice was found to have little effect on the levels of either dopamine or DOPACin both striatum and nucleus accembens.},
}

@inproceedings{nakajima1984dopamine,
  title = {Dopamine Receptors Involved in Self-Stimulation.},
  author = {Nakajima, S.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Self-stimulation is suppressed by various substances that block dopamine receptors. We now report that a drug (SCH23390) specific to Dl receptors suppresed self-stimulation in the rat with hypothalamic electrode but another drug (sulpiride) specific to D2 receptor did not. (We are grateful to Dr. G. McKenzie for SCH233390 and to Mr, DeLaGrange for sulpiride)},
}

@inproceedings{ozier1984induced,
  title = {Induced Depression and Elation and the Episodic Memory Trace},
  author = {Ozier, M.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Induced depression and elation may have differential effects upon automatic and effortful encoding of episodic memory codes. An experiment to test this hypothesis was performed and the data provide strong support for the notion that there are two modes of encoding episodic information• 3 6. M. MacLean & S. Bryson Hemispheric Diferences in the Perception of Emotional Valence. This study investigated hemispheric differences in the perception of emotional valence. Right-handed, male and female subjects rated the degree of happy or sad emotion displayed in a series of happy, sad and neutral expressions. The faces were presented laterally and in the central field of vision for a duration of 60, 120 and 180 msecs. Independent of both the exposure duration and the emotional expression, faces presented to the left visual field were rated more negatively than those projected to the right visual field. Moreover, the left visual field ratings for the females were even more negative than those for the males. No visual field differences were found in the ability to distinguish among emotional expressions, The findings are discussed in terms of the idea that the two cerebral hemisheres differ in their emotional responses.},
}

@inproceedings{j1984pavlovian,
  title = {Pavlovian Factors in Thirst,},
  author = {J, Kruse},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Rats initially prefer ,9% (isotonic) saline to water, but protracted experience with saline as the sole fluid reverses this preference, The present experiment extended the Pavlovian analysis of this phenomenon by including an overshadowing group, which experienced salt mixed with vanilla as their sole fluid between the two-bottle pretest and posttest for salt preference. As expected, this group showed an attenuated saline aversion relative to a group which drank pure saline solution duirng the training interval, In addition, a vanilla aversion developed in the former group, The results suggest that thirst can serve as a US in Pavlovian preparations.},
}

@inproceedings{r1984preferences,
  title = {Preferences for Maternal Odours: 500 Mice Can't Be Wrong,},
  author = {R, Brown},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Olfactory signals have the potential to contain many different types of information, They can be used to identify the species, sex, age and even the individuallty of an animal as well as its social status, breeding condition, stress level and maternal state, "Haternal odours" excreted in the feces of lactating female rats and mice may contain information about sex and individuality and can be modified by maternal diet, Five experiments were done to examine the influence of diet on preferences of 18-20 day old CD-lGF albino mice for maternal odours, odours of non- lactating females, males, and strange mothers, The results suggest that infant mice develop graded preferences for different components of the "maternal odour", This supports the hypothesis that maternal diet may increase the preferences of pups for other adults on the same diet.},
}

@inproceedings{mendelson1984selectivity,
  title = {Selectivity of Cells in Cat Superior Colliculus for Features of Simulated Sound Movement.--- -- --},
  author = {Mendelson, J.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {The superior colliculus (SC) is a multimodal structure which appears to be involved in orientation toward objects in the environment. The superficial layers processd visual information only while the intermediate and deep layers process a combination of visual, auditory, and somatosensory information. Most research in the area has been devoted to studying the SC's responses to visual stimuli; comparatively little has been devoted to the processing of stimuli from the other two modalities. We have recently embarked on a series of experiments which will study the effects of simulated sound movement on cells in the deep layers of the SC. Preliminary data reveal that the collicular responses are remarkably similar to those of the auditory cortex. These data re relevant to investigations of the interaction between auditory and visual stimuli on collicular unit responses.},
}

@inproceedings{m1984functional,
  title = {Functional Topography in Areas _!2 and~ of Cat Visual Cortex},
  author = {M, Cynader},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {There are a large number of different cortical areas in the cat, We have examined the neuronal response features and topographic organisation of two of these areas, called areas 17 and 18. These Rreas are different in the way in which they represent the visual field and in receptive field size and prefered velocities of cortical neurons, but bear certain similarities in the way feature extraction properties are laid out across their surfaces.},
}

@inproceedings{mclaren1984hemispheric,
  title = {Hemispheric Asymmetries in the Perception~ Emotion~~ Function~ Task Demands},
  author = {McLaren, J.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {This research investigates hemispheric asymmetries in the perception and identification of both positive and negative emotion. The main purpose was to identify conditions under which an overall left visual field advantage obtains for all emotion and those in which a dissociation is found for positive and negative emotion. Pairs of faces were presented such that one face was presented to each visual field. The pairs consisted of either happy and neutral or sad and neutral faces. Righ- handed subjects were required to respond to the faces that 1) were more emotional, and 2) made them feel either better or worse. The dependent measures were the latency and accuracy of respones. The main finding was that visual field asymmetries depended on the task requirements. When asked to respond to the more emotional face visual field differences varied primarily as a function of the sex of the subject. However, both sexes showed an overall left visual field advantage for better and worse judgements. Support was not provided for the idea of differential hemipsheric specialization for positive and negative emotion. Results are discussed in light of previous findings suggesting that males and females tend to use different strategies in such tasks.},
}

@inproceedings{berridge1984trigeminal,
  title = {Trigeminal Control Of Ingestive and Grooming Sequences.},
  author = {Berridge, K.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {We're currently examining sensorimotor interactions in the production of taste-elicited fixed action patterns and grooming sequences in rats. -~ ,· We're employing a trigeminal deafferentation procedure that eliminates j.?,c,ti le input from the face and mouth while preserving intact all motor fll-' • t, efferent ·,, v issues: and gustatory afferent 1) the role of non-taste neurons. afferent This study addresses information in the assessment two ltU~, . 01', of food palatability, and 2) the role of tactile sensory feedback in the ,.jjj_;>• production of ingestive and grooming movements and sequences.},
  note = {QA: needs-split-review; Split from 5 at: 'K. Berridge'},
}

@inproceedings{barresi1984dead,
  title = {Dead or Alive: When Motion Becomes Intention. ------ A single object moved on a Apple-controlled monitor according to a quantifiable rule. Human observers were asked to evaluate its motion on six Likert Scales: Mechanical, Random, Purposive, Intelligent, Alive, and Human. The proportion of foreward versus 27° turns of the object affected judgements on some of these scales. Whether or not the object occasionally stopped and changed direction also affected judgements. However, complex interactions involving sex of subject and stimulus appearance argue against any simple interpretation of these results.},
  author = {Barresi, J. and Wyatt, E.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  note = {QA: needs-split-review; Split from 5-split1 at: 'J. Barresi & E. Wyatt'},
}

@inproceedings{barresi1984deada,
  title = {Dead or Alive: When Motion Becomes Intention. ------ A single object moved on a Apple-controlled monitor according to a quantifiable rule},
  author = {Barresi, J. and Wyatt, E.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {Human observers were asked to evaluate its motion on six Likert Scales: Mechanical, Random, Purposive, Intelligent, Alive, and Human. The proportion of foreward versus 27° turns of the object affected judgements on some of these scales. Whether or not the object occasionally stopped and changed direction also affected judgements. However, complex interactions involving sex of subject and stimulus appearance argue against any simple interpretation of these results.},
}

@inproceedings{fentress1984differentiat,
  title = {The Differentiation of Integrated Movement Patterns in Mice and Wolves: !"""Progress Report, -- --},
  author = {Fentress, J.},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {During development animals (and people) are faced with a dual task, The first challenge is to specify individually isolable dimensions of behaviour from more roughly defined beginnings ("differentiation"). The second challenge is to combine these specified dimensions into co-herently ordered patterns of expression ("integration"), In terms of behavioural organization we know surprisingly Tmre· -or-either of these processes' not to mention their relations in time, across levels of operation, etc, Our work on wolves and mice may provide some clues.},
}

@inproceedings{m1984anatomical,
  title = {Anatomical Studies of the Ventral Lateral Geniculate Nucleus in the Hamster.},
  author = {M, Harrington},
  booktitle = {Tenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1984},
  abstract = {The internal dorsal division of the ventral lateral geniculate body (VLGNid) has been shown to contain cells which project to the suprachiasmatic nucleus (SCN) in both rats and hamsters. Cells in the VLGNid show avian pancreatic polypeptide-like (APP-like) immunoreactivity and studies done with rats strongly suggest that the VLGN cells are responsible for most, if not all, of the APP-like immunoreactive fibers observed in the SCN. It has become clear recently that APP-like immunoreactivity observed in the rat brain is probably due to the APP antibody binding to neuropiptide Y (NPY) antigen. I have demonstrated NPY immunoreactive cells in the VLGNid, as well as a dense network of NPY immunoreactive fibers in the SCN of hamsters. I plan to combine wheat germ agglutin-horseradish peroxidase (WGA-HRP) eye injections with NPY immunocytochemistry to demonstrate the relationship of retinal fibers and NPY-immunoreactive VLGNcells. This work is being done in collaboration with Dr, Dwight Nance,},
}

@inproceedings{berridge1985modulation,
  title = {Modulation of Palatability by Trigeminal Tactile Sensation},
  author = {Berridge, K.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {The trigeminal (5th cranial nerve) system carries somatosensation from the face and mouth. Trigeminal sensation is crucial to normal feeding. This experiment examined in rats how trigeminal tactile input modulates the perceived palatability of tastes, as measured by species-typical actions that are sensitive to palatability evaluations. The results suggested that low-level trigeminal input amplifies selectively positive palatability while having little or no effect on the aversive limb of palatability evaluations. Trigeminal deafferentation thus unbalances the palatability of tastes.},
}

@inproceedings{briand1985attention,
  title = {Attention and Feature Integration},
  author = {Briand, K.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Treisman's Feature Integration theory of attention predicts that focal attention is needed to correctly combine the different features which make up a visual pattern or object. The present study was intended to determine whether orienting of attention to (or away from) a given spatial location would affect the tendency for subjects to report illusory conjunctions at that location. Subjects searched for the letter R with two sets of distractors, PB and PQ. Results showed that performance was better when the location cue was valid than when it was invalid, and importantly, that this effect was no greater for the PQ distractor set than for the PB distractor set. The data are inconsistent with the notion that allocating attention spatially serves a role in integrating the features of an object correctly.},
}

@inproceedings{nicol1985cell,
  title = {The Cell Lineage of the Ascidian Neural Plate},
  author = {Nicol, D. and Meinertzhagen, I.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Ascidians, or sea -squists, are unprepossessing sessile, marine animals which produce embryos demonstrating almost perfect mosaic development. The embryo produces a motile larva with chordate-like characteristics including a dorsal tubular nerve cord which forms from a neural plate and on the basis of which the group is thought to resemble the primitive chordate ancestor. We have examined the lineage of the cells of this neural plate and have now accounted for all the cell divisions (about 12) which generate all the cells (about 350) of the nervous system. We are thus how ready to examine the effects of cell deletions and thus test the ability of the neural plate to regulate both the cell number and cell type of its progeny.},
}

@inproceedings{edwards1985category,
  title = {Category Learning in Pigeons},
  author = {Edwards, C. and Honig, W.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Four groups of pigeons were trained on a go/no go task that required birds to discriminate slides of naturalistic stimuli. Pairs of slides had identical backgrounds, but within each pair the slides were distinguised by the presence or absence of a human figure. The group of birds trained to respond to human present slides acquired the discrimination. However, a second group, one that was trained to respond to human absent, failed to acquire the discrimination. Two additional groups that were given "pseudo-concept" training (i~., both the positive and the negative slide sets contained human-present and human-absent slides) also failed to acquire the discrimination.},
}

@inproceedings{klein1985stimulating,
  title = {Stimulating the Subjective Lexicon},
  author = {Klein, R.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Galton's studies of associative processes suggested a complex mental machinery that seemed unavailable to conscious introspection. That machinery which Ga.lton likened to the "pipes and flues and bell wires" in one's basement might today be called the subjective lexicon (~ Miller) or semantic memory (Quillian, Tulving). The most popular paradigm for exploring properties of the subjective lexicon has been to examine the effects of prior or simulataneous stimulation of some region of the lexicon upon task performance involving the same or different region. The evolution and current status of this paradigm will be described and exemplified with some recent data from our lab. i 4 .---J.F entres s - Modulations Muddle Monolithic Modules in Mamma~lian Movement As in figurative tongue twisters, movements of the tongue and other appendages in rats show incomplete encapsulation (modularity). Kent Berridge and I have recently been able to show this by examining the detailed form of facial and forelimb actions in trigeminally deafferented animals under various motivational and sequential contexts. The point of the exercise is not merely that strict dichotomies between "reflex" and "centrally patterned" actions are both a logical and biological misnomer, but that even relatively simple behavioural patterns exhibit dynamic and relational control preperties that deserve further investigation. Contextual factors are necessary complements to more traditional (fragmented) conceptualizations of control-},
}

@inproceedings{crowe1985effect,
  title = {The Effect of Viewing Pornographic, Violent and Pornographic Violent Film on Viewer'sSubsequent Administration of Reward and Punishment},
  author = {Crowe, L.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Twenty-seven undergraduate males participated in this study designed to examine the effect of pornographic and pornographic violent film on viewer's tendency to reward and punish a female. Following exposure to either a pornographic, pornographic violent, neutral or violent 10 minute videotape segment, subjects had the opportunity to reward and punish a mythical female learner in a bogus teaching task. The effect of the film was measured as the ratio of the total duration of rewards to the total duration of punishment. Sequential analysis ( o( =-05) indicated significant differences in the reward to punishment ratios for all film s conditions. The highest ratio was found for the pornographic film and the lowest for the pornographic violent film. Results are discussed in terms of the aggressive cue value of the films. Several explanations, including reference to the social learning theory, were offered to account for this unexpected pattern of results.},
}

@inproceedings{mcleod1985effects,
  title = {Effects of Prenatal Stress on Parental Behavior of Male Rats ---- ----- -- --- --- Prenatal environmental stress has been shown to both feminize and},
  author = {McLeod, P. and Brown, R.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {demosculinize the sexual behavior of male rats (Ward, 1972). The extent of these effects is influenced by prepuheral rearing conditions (Ward and Reed, in press). We are conducting an experiment on another sexually dimorphic behavior. This tests the interaction between prenatal stress and post-weaning social environment or parental behavior of male rats. Data available from this experiment (which is currently in progress), will be presented.},
}

@inproceedings{frohlich1985developmenta,
  title = {Developmental Perturbations in Postsynaptic Cells Produced by Cold-Shock during Development},
  author = {Frohlich, A.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {After studying normal development leading to the formation of tetrad synapses by the visual receptors in the complex eyes of the house fly, we have now started to disturb the developmental processes to further unravel developmental rules governing synapse formation. In a pilot study using (for the time being) the sledge hammer method of applying heat- or cold-shocks during development we hope to disturb the formation of the tetrad synapse, for instance by knocking out propective post- synaptic cells. Preliminary results are presented.},
}

@inproceedings{fairless1985effect,
  title = {The Effect of Context Shifts upon the Resistance-to-Reinforcement Assay of Conditioned Inhibition},
  author = {Fairless, J. and LoLordo, V.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Pigeon's exposed to a negative CS-UCS contingency show attenuated acquisition of excitatory responding when these stimuli occur later in a positively contingent relation. This effect constitutes the traditional resistance-to-reinforcement assay of conditioned inhibition. Our most recent work suggests that his acquisition deficit may be composed of three separable processes, only one of which is attributable to pre- exposure to the negative CS-UCS relation per se.},
}

@inproceedings{thompson1985grail,
  title = {The ~ Grail: ~ Quest for Circadian Rhythmicity in the Life of ! Fly},
  author = {Thompson, P.M. and Shaw, S.R.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Nassel et al recently discovered an efferent serotonergic neuron TAN-3, that runs out from the brain to end in diffuse branches in the fly's peripheral visual system. The structure and location of TAN-3's endings suggest that it releases its neurotransmitter non-synaptically throughout the eye, perhaps such as to influence some "global" attribute of visual processing. Since very large circadian changes in visual sensitivity are found in the eyes of many arthropods at dawn and dusk, and are mediated by bioamine-containing efferent neurones in one known case, we hypothesized that TAN-3 could be another such circadian controller neuron. We shall describe long-term retinal recordings made to test this idea, that ought to reveal any circadian changes in visual sensitivity taking place either in the photoreceptors themselves, or in the neurons immediately post-synaptic to them. This being a psychology department, we also looked to see if this strain of flies showed any behavioural evidence for circadian rhythmicity. Actually, our most intriguing finding has nothing much to do with all this: it is that long term light-adaptational depression follows exposure to simple room lights. Adaptational recovery is quite fast at the level of the photoreceptors, and the long term changes therefore must have been added at the synaptic zone itself. This suggests, tentatively, a different "global" role for a neuron like TAN-3 in visual processing, that should be testable in future.},
}

@inproceedings{wassenberg1985consonant,
  title = {Consonant Substitution Errors in Reading-Disabled and Normal Children: Phonetic, Visual and FrequencyEffects},
  author = {Wassenberg, K.M. and Bryson, S.E. and Werker, J.F.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Consonant misreadings were examined in two groups of severely reading- disabled children, and both age- and reading-watched, normal controls. Stimuli were single-syllable nonsense words with consonants in word- initial and/or -final position. Substitution errors were classified according to: i) word-position; ii) phonetic simularity; ii) visual similarity. Comparisons between groups showed effects of position and phonetic similarity for the normal children. The reading-disabled groups showed no effect of position, a strong visual effect and differing patterns of phonetic error types. In addition, in both reading-disabled groups, unlike the normal children, /d/ was the most frequent error response. These results are discussed in terms of the articulatory hypothesis (Werker & Bryson, 1984).},
}

@inproceedings{radel1985regeneration,
  title = {Regeneration in the Central Nervous System~ Small, Furry Creatures},
  author = {Radel, J.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Traditional wisdom states that the mammalian central nervous system is incapable of regenerating damaged tissues. I will present a brief history of the more successful attempts to induce CNS regeneration in mammals.},
}

@inproceedings{henken1985examination,
  title = {An Examination of Cell Proliferation in the Goldfish Retina During Regeneration of the Optic Nerve},
  author = {Henken, O.B.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Using thymidine autoradiography, I am examining changes in the rate of cell birth in the retina as a consequence of optic nerve crush. The question that I am addressing is, does regeneration of retinal ganglion cell axons influence other cells that are one or two connections removed from the event? I have found changes in cell birth rate in the outer nuclear layer and ganglion cell/optic fiber layer of the retina that appear to coincide with the regeneration process.},
}

@inproceedings{mcnulty1985experiments,
  title = {Experiments in the~ of Hyperbaric Oxygen for the Treatment of Medical Conditions},
  author = {McNulty, J.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Hyperbaric oxygen is used as the primary mode of treatment for conditions such as decompression illness and as adjunct therapy for a wide range of medical conditions from asteromyelitis to skin grafts. There is also a class of conditions categorized as experimental, for which these are suggestions that hyperbaric oxygen may be of benefit but for which further research is required. Research currently being done at the Hyperbaric Medicine Unit of the VG Hospital for one of these "experimental" conditions will be described.},
}

@inproceedings{marlin1985endogenous,
  title = {Endogenous Pain Control Systems: Excitation and Inhibition Procedures for Classicailyconditioned Analgesia},
  author = {Marlin, S.G. and LoLordo, V.M.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {By repeatedly pairing a neutral cue with a noxious stimulus, the cue alone comes to evoke analgesia. To examine conditioned excitation of analgesia rats were restrained and received tailshock during the last 15 seconds of a 1.00 minute white noise CS presentation. Following three and six trails, the animals pain reactivity during the CS was assessed using the tail-flick test. The rats showed increased pain thresholds relative to baselines after six but not after three trials. A second study examining the time course of the decay of analgesia following four conditioning trials showed profound analgesia during the CS and for 14 min following the test trial. Also the possibility of producing conditioned inhibition using this paradigm was investigated. For a stimulus to be a conditioned inhibitor it must counteract a conditioned excitor. To achieve this a flashing light/white noise compound stimulus was added which reliably predicted the absence of shock. Experimental animals showed higher pain thresholds to the excitor than to the flashing light/white noise compound. The consistancy of these results suggest conditioned inhibitor mechanisms were responsible. Results are discussed in terms of Bolles and Fanselow's perceptal-defense- recuperative model of fear and pain.},
}

@inproceedings{rusak1985rhythms,
  title = {Rhythms, snake oil and acetylcholine},
  author = {Rusak, B.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {The neurotransmitter _acetylcholine has been implicated in a number of relatively trivial functions, such as causing muscular contractions and maintaining higher mental functions in humans. It has now been implicated in entrainment of rodent circadian rhythms, and has therefore finally attracted my attention. I'll review some older data suggesting a cholinergic mechanism for light entrainment of rhythms, some newer data indicating some strange complexities in putative cholinergic binding sites in the CNS, and I'll talk about some ongoing and planned studies related to these issues.},
}

@inproceedings{honig1985modulation,
  title = {Modulation of Performance in Working Memory as a Function of Anticipated Frequency of Long and ShortMemory Intervals},
  author = {Honig, W.K.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Pigeons are learning two delayed discriminations concurrently; blue and white are the initial stimuli in one; green and red in the other. The same long and short memory intervals (Mis) are used in each problem (e.g., 2 sec and 10 sec). However, one problem contains 80% long Mis and 20% short Mis, while the other contains the reverse proportions. We expect that performance at a given MI will be modulated by the anticipated frequency of that interval; pigeons should do worse with the long MI if it occurs on 80% of the trials in one problem than if it occurs on 20% of the trials in the other.},
}

@inproceedings{mclaren1985hemispheric,
  title = {Hemispheric Differences in the Perception of Happy and Sad Faces: Effects of Expressive Asymmetrie'sin the Stimuli-},
  author = {McLaren, J.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {The purpose of the present series of experiments was to further evaluate the claim that the two cerebral hemispheres are differentially specialized for the perception of positive and negative emotion (cf. Reuter-Lorenz and Davidson, 1981). In a previously reported study we failed to replicate the finding of a left visual field advantage for sad faces and a right visual field superiority for happy faces. Our study differed from that of others in some methodological respects. Most importantly, we used mirror-image as well as normally orientated faces, to control for expressive asymmetries in the stimuli. The experiments to be reported were designed, firstly, to investigate the apparent discrepancy described above and, secondly, to determine the effect of subject's mood on the lateralized perception of emotional faces,},
}

@inproceedings{d1985cure,
  title = {~ Cure for Amblyopia},
  author = {D, E. Mitchell},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {It is well known that a period of monocular deprivation in early life can exert profound effects on the development of the visual pathways of kittens. These are accompanied by severe deficits in the vision of the deprived eye that are comparable to those observed in severe forms of human amblyopia. Although these effects are severe, considerable recovery of vision can occur in the deprived eye if, subsequent to the period of monocular deprivation, the formerly nondeprived eye is occluded. However, we have reported here earlier that the recovery promoted by this procedure (reverse occlusion) is not maintained afterwards. We now report that it is possible to achieve total behavioural recovery by instituting part-time occlusion where the nondeprived eye is occluded for only part of each day followed by a daily period of at least two hours during which both eyes are open. Thus while only limited permanent recovery is achieved in situations when either of these conditions are imposed full-time, a combination of both can lead to complete behavioural recovery for certain conditons of deprivation.},
}

@inproceedings{connolly1985psychophysio,
  title = {Psychophysio~1ogical Research in Schizophrenia},
  author = {Connolly, J.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {A brief overview of the rationale and objectives of psychophysiologlcal research in the schizophrenias will be presented. An example of basic psychophysiological research applied to psychopathology will be discussed. Recently completed work on event-related brain potentials relevant to the dichotic listening procedure together with in-progress tachistoscopic data will be presented. These and other data will be used to suggest that so-called "higher order cognitive deficits" seen in schizophenia are attributable to "lower order" abnormalities in sensory and perceptual processes.},
}

@inproceedings{maclean1985differing,
  title = {Differing Emotional Responses~ the Two Cerebral Hemispheres: The Effects of Scale and Gender},
  author = {MacLean, M.J. and Bryson, S.E.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Previous authors (see, e.g., Natale, Gur & Gur, 1983) report that the two cerebral hemispheres differ in their emotional responses. The general finding is that stimuli projected to the right field-left hemisphere are rated more positively than those projected to the left-field-right hemisphere. Most studies have employed left-to-right positively ascending scales. The present series of experiments was carried out to evaluate the effects of scale on judgements of emotion. Sad, happy and neutral faces were presented unilaterally and centrally and right-handed subjects rated the degree of happy or sad emotion on one of four types of scales. Our results qualify previous findings in this area. They suggest that careful attention must be paid to the effects of spatial compatibility in laterality research.},
}

@inproceedings{jones1985effect,
  title = {The Effect of a Sandy Substrate on Intra-Specific Agonistic Behavior in the Syrian Golden Hamster (Mesocrioetus auratus).},
  author = {Jones, C.H.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {The agonistic behavior of male' Syrian golden hamsters was recorded in environments with sandy and barren substrates. The effect of the sandy substrate was to decrease the amount of agonistic behavior shown by the hamsters in comparison to levels observed when the substrate was barren. This effect was observed across varying motivational states, prior housing conditions of the animals, lighting conditions of the test arena, light dark cycles and social groupings during the test. The results are discussed in terms of traditional conceptualizations of the hamster's social tendencies in the wild.},
}

@inproceedings{baker1985spatial,
  title = {Spatial properties of direction-selective neurons in striate cortex of the cat},
  author = {Baker, C.L. and Jr},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Bar-shaped stimuli flashed sequentially at adjacent points in the receptive fields of direction-selective striate cortex neurons produced direction-selective behavior comparable to that observed with smoothly moving stimuli. Independent variation of the positions of the 2 flashes allowed determination of the optimal displacement, Dop t' for direction- selectivity from sequential flashes. Measured values of D0 P-t typically ranged from 0.3 to Q.8 deg for receptive field sizes of ca 4-7 deg. The spatial separation of 2 simultaneously presented bars which produces the largest lateral inhibition was also determined for each direction- selective neuron. Twice this value provided the spatial subunit , wavelength, A , for a given neuron. Measurements of A were obtained from line weighting functions, in the case of Simple cells, or from double-line interaction functions, in the case of Complex cells 1 . Measured values of A were generally ca 1-5 deg. For the majority of neurons studied, the ratio of optimal displacement for direction-selectivity (D0 t) to subunit wavelength (A ) fell in the range of o.10-0.3 5. These 1i-esul ts imply a systematic quan ti tati ve relationship between the spatial subunit wavelength and mechanisms for direction-selectivity. Supported by Centennial Fellowship (Canadian MRC) to CLB and a Canadian ~ MRC (PG-29) to MC,},
}

@inproceedings{croll1985functional,
  title = {Functional anatomy of gastropod neurons},
  author = {Croll, R.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {While gastropods have been used extensively for the last two decades as preparations for studying the physiological bases of behaviour, relatively few techniques are available for examining the details of neurooal morphology in this class of animals. Over the last year I have been applying two techniques to the gastropod nervous system which reveal much new information about the functional anatomy of single identifiable neurons.},
}

@inproceedings{spetch1985milk,
  title = {The "Milk Run": ! New Apparatus for Studying Spatial Memory in Pigeons},
  author = {Spetch, M. and Edwards, C.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Pigeons, unlike rodents, do not display good spatial memory in traditional radial-arm mazes without special and extremely lengthy training. Thus, they seem able, but "unprepared" to use spatial memory in radial mazes, perhaps because labyrinthine structures are constraining for pigeons who, in the wild, generally feed in open fields. In support of this, pigeons displayed spatial memory without extensive pretraining in an open-room "flight maze" (reported at the 1984 In House). However, since some birds proved reluctant to make the flight response, we have recently developed an open-field, ground feeding version of the "maze" that involves a number of "feeding stations" (milk cartons baited with peas) placed on the floor. Our preliminary results suggest that this apparatus overcomes the response problems of the flight maze, and that pigeons readily display good spatial memory to efficiently locate the food.},
}

@inproceedings{enns1985further,
  title = {Further Explorations of Changes with Age in the Integration of Shape},
  author = {Enns, J.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Experiments with observers aged 6-24 years examined changes with age in the sequential integration of shape in a free-viewing task. The stimuli were line-drawings of "r;l.bbons" which consisted of a series of panels connected randomly at 900 angles. The task was to indicate whether the end-panels of each ribbon displayed the same surface or different surfaces to the viewer. Age-related improvements were found in the speed and accuracy of this task (Experiment 1). Moreover, these improvements with age were found even when the distance over which observer's eyes travelled was held constant (Experiment 2) and when the need for any overt eye movements was eliminated (Experiment 3), supporting the view that the ability to construct cognitive "schemas" of novel objects improves with age. A final experiment explored the effects of instructing observers to use special strategies to solve the task.},
}

@inproceedings{phillips1985forward,
  title = {Forward Masking Studies of Cat Auditory Cortex Cells},
  author = {Phillips, O.P.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Single neurons in the cat's auditory cortex encode stimulus intensities over limited ranges. The "dynamic range" undergoes a shift towards higher sound pressure levels if the stimulus of interest is presented in a background of continuous white noise. The magnitude of the dynamic range shift is linearly related to the intensity of the noise, and is comparable in cells that are excited or inhibited by noise bursts. To examine the sequence of neural events underlying this dynamic range shift, cortical cells were studied parametrically with preferred- frequency tones delivered at various delays after the onset and offset of a noise mask. These experiments shed light on the mechanisms used by the central nervous system to dafict signals in noise.},
}

@inproceedings{mckelvie1985trace,
  title = {Trace Acquisition with and without Awareness},
  author = {McKelvie, S.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {One hundred and sixty-three subjects were tested individually on the Hebb digits task in which they listened to 24 lists of 9 digits read at a rate of about 1 per sec and following each list, attempted to recall the digits in their correct order; however, they were not informed that the series on Trial 3 was repeated on every subsequent third trial- On the basis of a post-experimental questionnaire, subjects were categorized as Unaware (n = 21), Late Aware (n = 29), and Early Aware (n = 29) with respect to the reoccurrence of the repeating string. Similar rates of learning of the critical series were found for the three groups, supporting the contention that repetition of a set of digits casn directly set up a structural or long-term memory trace-},
}

@inproceedings{brown1985dissecting,
  title = {Dissecting the Components of the Maternal Odour of Mice},
  author = {Brown, R.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {In a follow-up to my last in-house presentation, we have conducted another five experiments on the attraction of 16-20 day old mice to "maternal odours" and I shall discuss the results of these with reference to last year's results. Using feces from mice as stimuli in a series of forced choice tests, we have examined the effects of diet (Purina vs• Halifax Aquarium House), species (rat vs. mouse), sex (male vs. female), lactation (lactating vs. nonlactating females) and relatedness (own vs. another mother) on odor preferences. Each of these factors appears to contribute to the attractiveness of the maternal odour, with diet playing an especially important role. These results indicate that the "maternal odour" is a complex stimulus which includes many components and that pups may attend to some of these components more than others. Cheryl Reed- Elder will give an interpretation of these results.},
}

@inproceedings{reedelder1985concept,
  title = {Is the Concept of a Maternal Pheromone useful to explain the Attractiveness of Maternal Odours?},
  author = {Reed-Elder, C.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Studies of odour preferences were examined in an effort to·answer some questions regarding the interpretation of such preferences as evidence for a "maternal pheromone". Some odorous substances, in particular, feces and ventral scent gland sebum, both of which are copiously produced by lactation females, are preferentially approached by preweanling pups. The attractiveness of an odour to pups may, in part, be a function of the odour's saliency, its familiarity, or its similarity to other, already familiar odours. Unfamiliar odours can be made attractive by exposure, and familiarity with an odour seems to be both necessary and sufficient to increase the attractiveness of that odour, whether it is produced by a conspecific or not. Simple exposure has been shown to be effective in establishing an odour as attractive but this attraction may be increased if conditioning contingencies are also present. Since the attractiveness of maternal odours can be explained simply by assessing the role of familiarity, the concept of a "maternal pheromone" is not necessary and is not parsimonious with the data. Furthermore, it is not successful in explaining the modifiability of odour preferences through experience.},
}

@inproceedings{mistlberger1985effects,
  title = {Effects of Paraventricular Nuclei Lesions on Entrainment of Circadian Activity Rhythms to Restricted Feeding in the Rat},
  author = {Mistlberger, R. and Rusak, B.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Periodic food availability cycles (2h food - 22h fast) can entrain a variety of circadian rhythms in rats. The phase angle of entrainment is such that these rhythms anticipate the daily mealtime; for example, the rat becomes active 2-3h before mealtime. The neural mechanisms mediating anticipatory, food entrainable rhythms are functionally and antomically distinct from those controlling free running, light entrainable rhythms since suprachiasmatic nuclei lesions abolish or severely disrupt free running but not food anticipatory rhythms, Previous attempts to localize critical components of the food entrainment mechanism indicate that the pineal and adrenal glands, the hypophysis and the ventromedial hypothalamus are non-essential. The present study investigates whether the paraventricular nuclei (PVN) might be involved, in view of their purported role in the regulation of food intake and the preminence of food intake over light in the phase control of certain PVN receptor rhythms. Circadian locomotor rhythms were monitored in 9 rats on restricted food schedules (2h diurnal mealtime) for 2 weeks prior to and 3 weeks after bilateral PVN ablation. Six rats displayed signs of obesity typically associated with PVN lesions. Anticipatory activity was markedly attenuated in 3 of these rats and largely unaffected in the remaining 6. The animals will be tested again after several months to assess the stability of this effect.},
  note = {QA: needs-split-review; Split from 5 at: 'R. Mistlberger'},
}

@inproceedings{shaw1985synaptic,
  title = {Synaptic Promiscuity and Neuronal Fidelity as the Forces of Destiny.},
  author = {Shaw, S.R. and Meinertzhagen, I.A.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Comparative ethologists have long suggested that animal behaviour has evolved progressively as speciation has proceeded. Changes in behaviour may have been just as important in evolution as the more obvious alterations in body plan, for instance as mechanisms ensuring reproductive isolation. By contrast, neuroscientists have had little that is useful to offer about the evolution of the brain, which after all supposedly controls behaviour. They offer unlikely tales that changes in neuron size and shape, in brain size or in the direction taken by neuronal tracts, are the main correlates of brain evolution. A more appealing idea is that new neuronal classes arise at each twist and turn of evolutionary advance, accounting for each new behaviour, but this appears confounded by the facts. In cases where we can identify neurons as individuals, they appear to have persisted as recognizable entitles for perhaps )100 million years (admittedly few cases so far, mostly in invertebrates). How might this apparent bottleneck to the evolution of brain function be overcome? If "new" neurons cannot readily emerge in the CNS, we speculate instead that rearrangement of synaptic connections amongst existing nerve cells must take precedence, as a fundamental mode of evolutionary progression. Evidence supporting this new if obvious hypothesis will be presented, drawn from a comparative EN study of a particular class of sensory synapse that is made between identifiable neurons, and that must have existed since the Carboniferous (~250MYr BP). We have discovered that the composition of the post-synaptic set of elements at the synaptic has altered, during the monophyletic evolutionary divergence into the many modern families. Alterations in some other types of synapse have also been noted.},
}

@inproceedings{nakajima1985dopamine,
  title = {Dopamine Receptors Involved in Food Reinforcement .'},
  author = {Nakajima, S. and Faisal, I.},
  booktitle = {Eleventh Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1985},
  abstract = {Rats trained to press a bar for food pellets under CRF, VI-1 min, or VI-3 min schedule were injected with SCH 23390 (dopamine Dl receptor blocking agent), sulpiride (D2 blocker), or physiological saline. D1 blocking suppressed responding, but D2 blocking did not. Responding under the VI schedules was more susceptible to Dl blocking than the responding under CRF.},
}

@inproceedings{baker1986lost,
  title = {Lost in Space and Lost in Time},
  author = {Baker, C.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {The relationship between spatial and temporal factors underlying velocity selectivity in cat striate cortex neurons was studied by obtaining responses to 2-flash stimuli for all combinations of a series of spatial and temporal separations between the two flashes. Analysis of the nonlinear components underlying the direction selectivity revealed interactions (space-time non-separability) which were generally small in magnitude, and uncorrelated in either magnitude or sign with the velocity preference measured in the same neurons. These results indicate that direction selectivity in striate cortical neurons depends separately on spatial and temporal parameters, rather than on the velocity implied by their ratio.},
}

@inproceedings{nakajima1986cell,
  title = {Cell assembly: Hebb's neuronal model of learning},
  author = {Nakajima, S},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {One of the basic assumptions in the cell assembly hypothesis is that synaptic connections are changeable, Studies in our Department by Cynader, Yoon, and Goddard have all supported this assumption. Experiments on invertebrates provides further insight into the nature of synaptic change: cyclic AMP plays an important role in producing lasting modifications of synaptic functions. Recent findings that the type of dopamine receptors which is critical in producing reinforcement effect is the Dl type -- the type that increases the production of cyclic AMP suggest a future direction of the development of the model,},
}

@inproceedings{r1986hebb,
  title = {Hebb's contribution~ contemporary cognitive psychology},
  author = {R, Klein},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Through his effective attack on radical behaviorism, his unflagging emphasis on internal mental processes (thought), his cogent demonstration of weaknesses in some key assumptions of the Gestalt and S-R frameworks, and his own cell-assembly proposal, Hebb may be said to have plowed the soil from which the rennaissance in cognitive psychology would grow & flourish,},
}

@inproceedings{a1986object,
  title = {Object Superiority Effect~~ Function of Diss!_ Dimensionality},
  author = {A, Gilani and Enns, J.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {The identification of a briefly presented line segment is sometimes facilitated by embedding the target line in a context of other noninformative lines (the "object superiority" and "object line" effects), This study compared two alternative hypotheses for these effects, One hypothesis claims that line figures with interpretations as three- dimensional objects are processed more rapidly and accurately by the visual system that two-dimensional figures (Weisstein and Harris, 1974), The second hypothesis claims only that some lines-in-context are more discriminable in a brief flash than others because of emergent features created by the interactlon of target and context lines (Enns and Prinzmetal, 1984),},
}

@inproceedings{g1986autistic,
  title = {Autistic children's comprehension of single words,},
  author = {G and Eskes and Bryson, T. McCormick ands.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {There is considerable evidence that children with early childhood autism suffer a general language impairment, This impairment is manifested as a difficulty in understanding the meanings of words and in organizing and also illustrates a general principle of human and animal neural behavior which is "Show me something I don't already know".},
}

@inproceedings{maccallum1986meaning,
  title = {Meaning in Motion: A reanalysis of the unit £!_ perception of ongoing behavior},
  author = {Maccallum, B. and Barresi, J.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Three experiments were conducted in order to investigate the unitization of ongoing behavior, In the first experiment subjects were instructed to press a button while watching a film (1) "when a meaningful act ends and a different one begins", or (2) "when a meaningful act occurs". No difference was found between these instructional sets. On the whole, the results of this and two subsequent experiments, as well as, previous research suggest that people identify the meaning of events by observing rapid changes in motion that can be meaningfully interpreted rather than by identifying the beginnings and ends of hierarchically organized behavioural units,},
}

@inproceedings{henken1986changes,
  title = {Changes in cell proliferation in the goldfish retina following optic~ crush.},
  author = {Henken, D. B.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {In goldfish, new cells are continuously added to the retina throughout life. Optic nerve axotomy modulates this ongoing histogenesis. Labelling densities in the ganglion cell/optic fiber layer and the photoreceptor layer are affected following unilateral optic nerve crush, when fish are allowed to survive for 1 day following injection of tritiated thymidine. 25. 1. McCook The Electroretinogram of Insect Compound Eye: The origins of the ERG, and its ~ In examining tne determination orcontrast codingin thevTsuaI' system. The cellular origins of the electroretinogram (ERG) of the blowfly compound eye were investigated for both waveform and stimulus-response characteristics. The results suggest that the ERG may be due to a summation of the responses of the photoreceptors and the lamina large monopolar cells. The ERG was also used to study the determination of .the monopolar cell response to visual contrast, using flies reared under abnormal contrast conditions. The results suggest that there may be some visual plasticity, or environmental regulation of contrast coding in the visual system, which is contrary to expectations for a short lived animal.},
}

@inproceedings{baker1986optic,
  title = {The Optic Tectum Influences Production and Transport of Proteins in Retinal Ganglion Cells of Adult Goldfish.},
  author = {Baker, F. A and Yoon, M. G and Benowitz, L. I},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Ganglion cells in the goldfish retina produce proteins which are transported through optic fibers to their target tissue, the optic tectum. During regeneration of optic fibers the presence of the optic tectum enhances the prod11ction of rapidly-transported proteins with molecular lesion results, in short, indicate that the hypothalamus can take a licking, but the FED keeps on ticking. Our current efforts to localize the FED by assessing temporal variations of local cerebral 2-deoxyglucose uptake will also be discussed-},
}

@inproceedings{p1986early,
  title = {Early Developmental Changes in Timber Wolf Social Behaviour},
  author = {P, McLeod},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {The social organization of wolf packs is maintained by a complex variety of ritualized postures and actions. Here I document the early development of these postural displays plus the social interactions within which they occur, Daily video recordings of social interactions of two hand-reared wolf pups (Canis lupus) from eight days of age were used to document the ontogenetic emergence of the postural components of adult social interactions, I transcribed interaction sequences from video records to examine temporal patterns of pup-pup interactions. I found that postural components emerge in a consistent order, with a progressive narrowing of their contextual associations, Interactions between pups initially involved maintaining contact, but by three weeks of age, biting and pushing were common, By the fifth week, biting elicited yelps, At this time pups were also likely to raise their tails vertically before biting, At seven weeks of age, contacts became truncated, These data indicate the operation and development of processes that may be relevant to a number of mammalian social interactions, is theoretically "strong"). Your laboratory microcomputer can help you think more clearly about these issues.},
}

@inproceedings{ross1986behavior,
  title = {Behavior is in the eye of the Beholder: Differences in Response DefinitioncanEngencfer~verse-i,:ieoretical Interpretations},
  author = {Ross, R. T. and LoLordo*, V. M.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Two procedures for observing rearing behavior during a localized visual CS paired with food were compared within the same subjects. Using the method and response definition described by Holland, rearing was acquired during conditioning trials and declined with introduction of extinction. Using the method and response definition described by Kaye and Pearce, rearing declined from baseline levels during conditioning but was temporarily restored with extinction. These within-subject outcomes indicate that the response definitions used by Holland and by Kaye and Pearce, which differ along a continuum of "directedness", assess different components of behavior occurring in response to a visual CS reflecting associative strength or associability, respectively. Thus, differences in response definition, if not recognized, can give rise to theoretical conceptions of the processes that mediate overt behavior which may appear contradictory. * With thanks to Cheryl Reed Elder and Anastasia Droungas for serving as additional observers.},
}

@inproceedings{prusky1986muscarinic,
  title = {Muscarinic and nicotinic acetylcholine binding sites in the developing cat visual cortei:""},
  author = {Prusky, G.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {We have demonstrated that at distinctly different periods during development, both muscarinic and nicotinic acetylcholine receptors are specifically localised to layer IV of primary visual cortex. The muscarinic receptors exemplify this pattern only during early postnatal life but the nicotinic receptors develop this characteristic during the physiologically defined critical period and express it into adulthood. The different anatomical distributions of muscarinic and nicotinic receptors in the visual cortex together with other physiological evidence suggests distinctive roles for each of these receptor systems in the control of plasticity.},
}

@inproceedings{d1986requirements,
  title = {The requirements for optimum behavioural recovery from the effects of early monocular deprivation in kittens. -- --},
  author = {D and Mitchell, E. and Murphy, K. M. and Dzioba, H. and A, J. and Horne},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Last year we described a procedure that permitted an amazing degree of recovery from the very severe behavioural effects of early monocular deprivation, The method combined daily periods of reverse occlusion (patching) where the kitten is forced to employ its formerly deprived eye, with periods of binocular visual exposure. In kittens monocularly deprived to 6 weeks of age, the vision of the formerly deprived eye recovered to normal levels if the formerly nondeprived eye was patched for},
}

@inproceedings{fentress1986faps,
  title = {Faps, Maps and Saps: Contextual Rules of Integrated Action},
  author = {Fentress, J.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Ethologists have documented, in behavioural terms, the existence of numerous "fixed action patterns" (FAPS) for diverse animal species, have more recently liberalized notions of extreme motor stereotypy in terms of "modal action patterns" (MAPS), and have argued for the necessary existence of independently ordered "specific action potentials" (SAPS). However, a limit to current models is an a·ppropriate documentation of variations in the form and central control of movement sequences as a function of the broacie'r contexts within which these movements occur. I thus report upon contextual modulations of integrated movement in rats, with and without specific sensory & central lesions, based upon collaborative work with Kent Berridge. • These investigations suggest new ways to conceptualize the neural control of integrated behavioural patterns in mammals. ADDENDUM},
}

@inproceedings{olfactory1986reax,
  title = {REax;NITION OF (X)riGENICSTRAINSOF RATS. Richard~- Brown!, Prim_!!. ~2, and Bruce.:!_.Roser2.},
  author = {OLFACTORY},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {1 ( subdeparonent of Animal Behaviour, Madingley and 2 Institute of Animal Physiology, Babraham, Carnbridge,England). Recognition of different major histocanpatibility (MHC) types of mice is based on urinary charosignals fran congenic strains 'Nhich differ only in the MHC(Yamazaki, et al, 1979, J. Exp. Med., 150, 755-760). CA.trexperiment provides the first eviaence"tnat congenic strains of rats wich differ only in the MHCalso produce different urinary cheroosignals. Urine fran adult male PVGand PVG-Rlrats was used in a habituation - dishabituation test Sundberg, et al, 1982, Behav. Neur. Biol., 34, 113-119) wit.'1 male PVG-RTlUrats as subjects. Urine fran PVGmales was easily distinguished fran that of PVG-Rl males (p. C:.001). Individual PVGmales ~re not distine;uished by their urinary odours, but iniividual PVG-Rl males did produce discriminabl y different odours (p. <. .05) . These results deroonstrate that PVGand PVG-Rlmales, which idiffer only in the A region of the MHC,produce different •urinary cheoosignals and that i.rxiividual males of the PVG-Rl strain also produce distinguishable "individual" odours. These may be related to individual differences in the quantity of A .region classical class 1 antigens in the urine of PVG-Rlrats (Singh and Roser, tmpUblished observations). We are now using I.imillnological assays to determine how the quality and quantity ~ of class 1 antigens or their fragments in the urine of these rats enables recognition of their substrain and of individuals within a highly inbred substrain.},
}

@inproceedings{a1986csc,
  title = {CSc Explicitly Unpaired with the US Become Conditioned Inhibitors when CS and US Trials Occur in Single Alternation and also when they Occur in Unpredictable Order,},
  author = {A and Oroungas and V and LoLordo, M.},
  booktitle = {Twelfth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1986},
  abstract = {Two groups of rats were trained with Rescorla's (1969) "Explicitly Unpaired Procedure" (EUP) whereby US (0,5s foot-shock) and CS (60s white noise) occured alone, separated by long intertrial intervals (III=7 min). For one group the US and CS trials occured in single alternation (EUPs), while for the second the sequence of US and CS trials was randomized (EUPr). Strong conditioned inhibition accrued to both the EUPs- and EUPr- trained CSs as indexed by both summation and retardation tests and compared to a control group. This result, although in accord with Rescorla's (1969) theoretical formulations on conditioned inhibition resulting from negative CS-US contingency, is contrary to recent demonstrations by Fowler (1985) that have followed from Wagner's SOP theory. 10 ■ o. Treit Pharmacological evidence for a continum between anxiety and convulsive states A variety of clinical observations have suggested that some convulsive, epileptic states are correlated with "fear" or "anxiety". One specific hypothesis that can be derived from these observations is that "anxiety" might represent a mild, or "sub-clinical" epileptic state; i.e., anxiety and convulsions might lie along the same mechanistic continum, Consistent with this speculation, many potent anti-anxiety drugs also are potent anti-convulsants, and some potent convulsant drugs appear to produce "anxiety". These pharmacological relationships may not be coincidental, and there is evidence that all of these drugs may act upon a similar neurological substrate. My research on the interactive effects of convulsants and anxiolytics within an animal model further supports the notion of a link between anxiety and convulsant states. capture the point, which will be discussed briefly in light of some current perspectives.},
}

@inproceedings{barresi1987psychology,
  title = {Is Psychology an 'etic' or 'emic' science? And what of Biology?},
  author = {Barresi, J.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {An 'etic' science (e.g. 'phonetics') takes as its starting point a set of categories that are to apply to the phenomena of interest based on Cartesian principles of a hypothetics - deductive science. An 'emic' science (e.g. 'phonemics') applies categories that are grounded in the mental life of the subject of study, whether it be a man, a culture, or another organism. Its task is to rationally reconstruct that mental life in terms of rules that apply to mental activity in general. I will argue that the interests of these two types of science differ, and that psychology tries, unsuccessfully, to wed the two approaches.},
}

@inproceedings{briand1987shape,
  title = {The shape of things to come: Spotlight failure in exogenous covert orienting},
  author = {Briand, K.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {A briefly presented visual stimulus shown in the periphery, is assumed to orient attention automatically. In fact, dissociations have been demonstrated between the effects of visual-spatial attention thus oriented; and attentional orienting which is more voluntary in nature. One rule of thumb which has been adopted is that a peripheral cue will enhance the processing of any possible item occuring at the cued location. The studies I report examine the alternative possibility that a peripheral cue, in fact, enhances processing of subsequent stimuli only to the extent that they are somehow physically similar to that cue. The rationale will be discussed, and preliminary data presented.},
}

@inproceedings{anon1987does,
  title = {Does Life Imitate Art?},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {The development of perspective in children's drawings will be examined with an eye on the development of perspective in the history of Western art. Several experiments that examine one aspect of perspective in children's drawings -- how to draw occluded objects -- will be reported. author = Enns, J.},
  note = {QA: abstract-too-short},
}

@inproceedings{phillips1987coding,
  title = {Coding of Small Amplitude.:: Modulations by Cat Auditory Cortex Neurons},
  author = {Phillips, D.P. and Hall, S.E.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {As part of an on-going research program on the neural coding of complex sounds, we have examined the responses of cat cortical cells to small (6--dB) linear modulations of the amplitude of continuous carrier tones. We found that these neurons were sensitive to the direction and rate of intensity change, and to the carrier level on which those modulations were imposed. Moreover, the fashion in which neural response rates varied with alterations in any of those stimulus parameters was of the kind predicted by our recent model of the afferent input to cortical cells. In conjunction with our previous evidence on the sensitivity of cortical neurons to other complex sounds, notably frequency modulations and tone-noise combinations, these data reinforce our view that the auditory cortex contains much or all of the neural machinery required for the analysis of sounds with complex spectral and temporal microstructure, including speech.},
}

@inproceedings{mclaren1987review,
  title = {A Review of Recent Epidemiological Studies of Mental Retardation: Canadian and Non-Canadian Data~ Prevalence, Associated Disorders and Aetiology},
  author = {McLaren, J. and Bryson, S.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {This poster will review recent epidemiological studies of mental retardation. Discussion will focus on Canadian versus non-Canadian data pertaining to 1) prevalence, 2) associated disorders, and 3) aetiology. The prevalence of mental retardation has been shown to vary as a function of degree of retardation, chronological age, and gender. Moreover, a large proportion of mentally retarded individuals present with additional disorders (e~-, language problems, behavioural difficulties, epilepsy, and cerebral palsy). The number of disorders varies with the degree of mental retardation. Investigations into the aetiology of mental retardation have focussed on the contributions of pre-, peri- and post-natal factors. Although it has traditionally been assumed that mild retardation (IQ=S0-70) has a cultural familial basis, recent data have challenged this claim. The aetiologies of mild and severe (IQ(SO) retardation will therefore be compared. The limitations of current epidemiological- data and implications for future research will be discussed.},
}

@inproceedings{klein1987does,
  title = {Does "inhibition of return" operate in visual search?},
  author = {Klein, R.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {After a peripheral event the processing of nearby stimuli is facilitated for about 300 msec. From about 300 msec onwards there is a longer lasting inhibitory effect that has been called "inhibition of return". We conducted two experiments to determine if "inhibition of return" might operate to make visual search more efficient. Our main hypothesis was that when visual search appears to be serial and self-terminating (i.e. attention is inspecting each location), then inhibition would be left behind at each inspected location. We used a dual task in which the search response was followed immediately by a simple luminance detection probe that was presented "on" a potentially inhibited location or on some other location ("off")· Using Treisman 's "popout" condition as a control for most visual variables we found evidence consistent with a functional role for inhibition of return in visual search.},
}

@inproceedings{connolly1987peripheral,
  title = {Peripheral filtering of unattended input revisited: A brainstem auditory evoked response study.},
  author = {Connolly, J.F. and Scott, N.w.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Psychological theories of selective attention have been particularly concerned with the degree to which unattended inputs are processed. Proposals have ranged from peripheral filtering of unattended input to complete central processing of all input before the initiation of any selective processes. Attempts to determine which of these theories is correct and the nature of the physiological mechanisms involved have produced conflicting results. Experimentation in non human species has demonstrated attention driven efferent modulation of brainstem (olivocochlear bundle) responses to auditory input. Attempts to duplicate these findings in humans have resulted in a good deal of controversy with claims of both success and failure. In a recent study (Connolly, Aubry and McGillivary, 1987) the conditions associated with peripheral fl ltering 1n animals were adapted to human experimentation. No evidence was found in the brainstem auditory evoked response (BAER) for attention related response modulation. This failure to support the idea of peripheral filtering of unattended input in humans could not be considered definitive until greater task demands were introduced into the design. We report here BAERamplitude and latency data collected when subjects were required to attend and respond to: 1. the auditory stimuli evoking the response; 2. visual stimuli in conditions where the concurrent auditory stimuli assisted performance; 3. visual stimuli where the auditory stimuli hindered performance; and 4. visual stimuli where the auditory stimuli were of little consequence for performance. Results are discussed in terms of their implications for cognitive theories of selective attention and the putative physiological mechanisms mediating the process.},
}

@inproceedings{p1987why,
  title = {Why do dogs roll in stuff that stinks?},
  author = {P and J and McLeod and J and Mencher and Ryon, J. and Fentress, J.C.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Despite the widespread occurrence of scent-rubbing behaviour in mammals, neither the factors responsible for eliciting this behaviour nor the function(s) it serves are understood, The question we address here is which characteristics of an odour are important in eliciting rubbing. To determine this, 14 odors in 7 classes were presented to groups of wolves. Their responses to these stimuli were analyzed using multidimensional scaling (MOS) techniques to illustrate how the wolves themselves were categorizing the odors. Differences in rubbing behaviour among individuals were also analyzed using MDS to examine the possible role of social factors in scent-rubing behaviour.},
}

@inproceedings{juckes1987methodology,
  title = {~ methodology for explanation in the social sciences},
  author = {Juckes, T.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Explanation of action involves finding and modelling the generative mechanisms which produce manifest behaviours. The method employed in the natural sciences is appropriate for the social sciences: Positivism's attempt to limit knowledge only to accessible mechanisms has stunted explanation in the social sciences. Underlying intentional and meaningful action are intrinsic and extrinsic generative mechanisms, both of which are necessary for a complete explanation of action. To produce models of these forces, the developmental methodology, as employed by Piaget and Vygotsky, is valuable. In overcoming constraints, the organism is seen in change, thus showing the generative mechanisms~ action, effecting behaviour.},
}

@inproceedings{s1987holes,
  title = {Of Holes ~ Space and Shifts in Time},
  author = {S and Marlin, G. and Cynader, M.S.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {In the cosmic space-time continuum there are billions and billions of stars. There are more cells in the brain than there are stars in the sky. Each neuron in our visual cortex views one small place in visual space. Light from distant stars must travel through space until after some fixed amount of time, it reaches our eyes. But the long journey is not over for that signal must then travel through many synaptic connections until it is registered in our visual cortex, The time necessary for this synaptic trek appears to be a constant (40-60 ms), We have investigated the effect of repeated stimulation of small portions of the receptive fields of neurons in area 17 of the cat visual cortex. We examined the changes in the spatial properties of these receptive fields and the temporal characteristics of the cells. We have found that if a small part of the receptive field undergoes adaptation, the following four events may occur 1) no adaptation; 2) general adaptation of the entire receptive field; 3) a decrease in response to stimulation only at the point of adaptation; or 4) a decrease at the point of adaptation as well as increased responses at adjacent points in the receptive field. We also examined the cell's latency to respond to see if these changes in the spatial properties of the receptive fields could result from making the afferent neurons more sluggish.},
}

@inproceedings{marois1987embryonic,
  title = {Embryonic Development of Serotonin-Like Immunoreactivity in the Snail, Lymnaea},
  author = {Marois, R. and Chiasson, B.J. and Croll, R.P.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Modern immunohistochemical techniques allow for the identification of subpopulations of cells with dis ti nc t biochemical phenotypes within the central nervous system (CNS). The use of these techniques also allows for descriptions of the number, sizes and some aspects of the morphology of these cells. In this study we have exploited these advantages to identify the approximately 250 serotonergic cells found within the CNS of the pond snail, Lymnaea stagnalis at the time of hatching and then describe aspects of their embryonic development.},
}

@inproceedings{hasan1987keeping,
  title = {Keeping ~ Eye £E: Your Other},
  author = {Hasan, S.J. and Marlin, S.G. and Cynader, M.s.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Studies of individual neurons in visual cortex have demonstrated selective adaptation of neuronal responses to such stimulus parameters as direction of motion, orientation and spatial requency. We have examined interocular transfer of some of these adaptive effects in neurons displaying different strengths of excitatory input from the two eyes. An optimally oriented high contrast square wave grating, selected to evoke vigorous responses from a given unit, was swept across the receptive field. Unit responses for both preferred and null directions of grating movement in each eye were determined prior to and following one minute of unidirectional stimulation. Following adaptation, most units showed decreased responsivity to stimulation in both the dominant and non-dominant eyes. A clear minority of cells, however, showed adaptation effects specific to the eye which had been stimulated. The degree to which direction selective adaptation effects transferred interocularly was unrelated to the cell's ocular dominance categories as measured by Hubel and Wiesel's seven point scale. Both simple and complex cells exhibited comparable amounts of interocular transfer of adaptation. A large fraction of the neurons studied exhibited interocular transfer of direction,,,.. selective adaptation. However, direction selective adaptation could occur ~ithout obvious interocular transfer. In addition, interocular transfer could occur even when prolonged stimulation in one direction resulted in response decrement in both directions of stimulation. Since the motion aftereffect displays marked interocular transfer in humans, it is possible that cells like those exhibiting interocular transfer of direction selective adaptation play a significant role in this illusion. The further characteristics of these cells are currently under investigation.},
}

@inproceedings{mccormick1987midlocation,
  title = {Midlocation placement strategy in the orienting of visual attention: A spotlight £E: the hemi.field activation hypothesis},
  author = {McCormick, P.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Previous research has shown that we are able to orient visual attention to spatial locations without moving our eyes. How is this visual attention distributed? Posner, Snyder & Davidson (1978) have proposed a spotlight metaphor describing a spatially restrictive phenomenon. In contrast, Hughes & Zimba (1985) have presented evidence suggesting that attention is allocated to the entire left or right visual half-fields. However, the Hughes and Zimba data could have been generated by a midlocation placement strategy (MPS) of an attentional 'beam'· Evidence against the hemifield activation hypothesis and current research on MPS is discussed.},
}

@inproceedings{g1987nick,
  title = {Nick: ~ teen with terminal foresight},
  author = {G, Prusky},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {We have characterised and localised a population of nicotinic acetylcholine (ACh) receptors in the cat visual cortex, superior colliculus (SC) and laterageniculate nucleus (LGN). In visual cortex, the distribution of these receptors is associated with the pattern of LGN termination. The receptor distribution in the SC and LGN closely resembles the pattern of retinal termination. Surgically undercutting the visual cortex eliminates receptors in this area, however they remain intact when cortical cells are selectively removed. Localised, unilateral lesions of the LGN abolishes nicotinic receptors in the areas of the visual cortex corresponding to the LGN lesion area. Bilateral eye removal eliminates nicotinic receptors in the SC of both tecta, and unlilateral enucleation selectively destroys these receptors in the SC contralateral to the ablation. In the LGN, bilateral enucleations diminish nicotinic receptors in all retinal projection areas, and unilateral ablations reduce the number of receptors only in the areas recetvlng an afferent projection from the previously intact eye. Taken together, these data describe the affinity of nicotinic ACh receptors for primary sensory afferent terminals in the SC and LGN, and LGN terminals in the visual cortex. These receptors, via this strategic location, provide a mechanism by which ACh can modulate transmitter release in the visual system.},
}

@inproceedings{brown1987love,
  title = {Love and hate among the gerbils},
  author = {Brown, R. and Holman, S.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {We examined sexual behaviour and odour preferences in mated pairs of gerbils. They were given sexual behaviour tests with their own mate and with a novel partner. We predicted that gerbils would show more sexual behaviour and less aggression to familiar partners. While many of the behaviours showed this trend, the differences were not significant. Steve Holman has been repeating this experiment and I hope he has significant results by now. In a second experiment we examined responses of gerbils housed in mixed- or same-sex pairs to the urine odours of their cage-mates and novel gerbils. Gerbils housed in mixed-sex pairs approached and investigated the odour of their cage-mate and produced more modulated ultrasounds in the presence of this odour than in the presence of the odour of a novel gerbil. Gerbils housed in same sex pairs showed no such differential responsiveness to the odour of their cage-mates. Odour may be used for individual recognition and function to reduce aggression in social interactions between mated pairs of gerbils.},
}

@inproceedings{reedelder1987comparison,
  title = {Comparison of pavlovian conditioned inhibition procedures having different temporal arrangements of excitor and inhibitor on nonreinforced trials},
  author = {Reed-Elder, c. and LoLordo, v.M.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Pigeons were trained with simultaneous (Sim) or serial (Ser) Pavlovian conditioned inhibition procedures. Transfer of inhibition was tested. In the first test, the inhibitor was presented in various temporal arrangements with the training excitor (transfer across procedures). In the second test, the inhibitor was presented in compound with a second excitor (transfer across excitors). Inhibitors conditioned with Ser procedures suppressed responding both Sim and Ser trials but did not suppress responding to another excitor. Inhibitors established with a Sim procedure transferred across excitors but showed poor transfer to Ser procedures.},
  note = {QA: needs-split-review; Split from 23 at: 'c. Reed-Elder'},
}

@inproceedings{tuning1987subjects,
  title = {Subjects viewed adaptation stimuli for l minute. Then two rival test gratings, differing in orientation from each other by 90 , were presented one to each eye, for l minute and subjects recorded binocular rivalry. When one eye was adapted, rivalry alternations were briefer for adaptation and test gratings of similar orientation, especially in the adapted eye. However, when both eyes were adapted by rival gratings, the duration of rivalry alternations increased in both eyes equally, to produce symmetrical U-shaped orientation functions, This implies that rivalry adaptation affects only binocular units in the human visual system,·},
  author = {tuning, Orientation and vision, binocularity of binocular-rivalry adaptation in human},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  note = {QA: needs-split-review; Split from 23-split1 at: 'Orientation'},
}

@inproceedings{m1987individual,
  title = {Individual Differences in Attention: Type~ and Type Band Cognitive Failure},
  author = {M, Brennan},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {A significant negative correlation was found between two self-report measures: the JAS (Jenkins Activity Survey) and the CFQ (Cognitive Failure Questionnaire). The JAS is used to distinguish Type A from Type B individuals. The CFQ assesses a person's absent-mindedness and everyday errors, Thus, the correlation showed that Type A's reported low CFQ and Type B's reported high CFQ, Previous literature has shown that ( 1) Type A and Type B individuals differ in their attentional mechanisms, and (2) high CFQ and low CFQ differ in attention, My research will involve looking at whether or not these attentional differences really exist,},
  note = {QA: needs-split-review; Split from 23-split1 at: 'M, Brennan'},
}

@inproceedings{m1987individuala,
  title = {Individual Differences in Attention: Type~ and Type Band Cognitive Failure},
  author = {M, Brennan},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {A significant negative correlation was found between two self-report measures: the JAS (Jenkins Activity Survey) and the CFQ (Cognitive Failure Questionnaire). The JAS is used to distinguish Type A from Type B individuals. The CFQ assesses a person's absent-mindedness and everyday errors, Thus, the correlation showed that Type A's reported low CFQ and Type B's reported high CFQ, Previous literature has shown that ( 1) Type A and Type B individuals differ in their attentional mechanisms, and (2) high CFQ and low CFQ differ in attention, My research will involve looking at whether or not these attentional differences really exist,},
}

@inproceedings{fentress1987from,
  title = {From Moscow with Love -------},
  author = {Fentress, J.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {My plan in this talk is to discuss some recent data on contextual controls in integrated movement (with K, Berridge: rats) in the still broader context of the March, 1987, Moscow meeting on movement, The key problems from which details will be selected are: a) how do we deal with separable action properties that are also connected to one another; b) how do we deal with movement dynamics and also stabilities in action; c) how do Halifax rats relate to Russian polit burocrats? Scenic slides as well as data (I hope!),},
}

@inproceedings{d1987effectivenes,
  title = {The effectiveness of part-time reverse occlusion as a means for promoting recovery from the pnysiological effects of monocular deprivation in the kitten visual cortex - --},
  author = {D and Mitchell, E. and Cynader, M.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Previously it has been shown that certain regimens of part-time reverse occlusion can promote recovery of normal visual function in the deprived eye of kit tens that had been monocularly deprived to 6 or 8 weeks of age. We now report on the extent of the physiological recovery in the visual cortex of four such kittens that had recovered normal vision in their deprived eye. Considerable shifts of occular dominance towards the deprived eye were observed in one of the two conditions of occlusion. Moreover, a number of cells exhibited tuning for retinal disparity that was of sufficient magnitude to provide a possible substrate for stereopsis.},
}

@inproceedings{chiasson1987post,
  title = {Post-hatching Development of Serotonin-Like Immunoreacti vi ty in the Snail, Lymnaea},
  author = {Chiasson, B.J. and Croll, R.P.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Post-hatching development of Lymnaea involves a 10-20 fold increase in the linear dimensions of ganglia comprising the central nervous system (CNS)- As a first step toward an explanation of this growth we have examined the post-hatching development of a subpopulation of neurons which exhibit serotonin-like immunoreactivity. Growth of the CNS can be partially explained in terms of increases in both cell size and cell number within this subpopulation. Several large, identified neurons increase greatly in soma cross-sectional diameter. A large number of cells which are identifiable only as members of clusters tend to be smaller throughout development and tend to increase more slowly in cross-sectional diameter. In addition to these increases in cell size the population numbers of most cell clusters increase throughout development.},
}

@inproceedings{croll1987distribution,
  title = {Distribution of Monoamines in the Hatchling Land Snail, Achatina Fulica},
  author = {Croll, R. P.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {As was shown in the previous two presentations histochemical procedures can be used to describe single cells or clusters of cells within the nervous system of certain invertebrates. These techniques can also serve as a basis for the tentative identification of cellular homologies between species. The glyoxylic acid histofluorescent method for the demonstration of monoamines and immunohistochemical procedures for the localization of serotonin were applied to the central ganglia of the land snail, Achatina fulica. Based on cell body size and location, biochemical content and neuritic projection patterns, several cells in Achatina appear to be homologous to cells previously identified in Lymnaea and several other gastropods.},
}

@inproceedings{bryson1987preliminary,
  title = {Preliminary Report on~ Epidemiological Study of Autistic Syndromes},
  author = {Bryson, S.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Autism is a stable disorder beginning in early childhood, and characterized by severe impairment in cognitive, linguistic and social development. The diagnosis of this syndrome has been the source of considerable contraversy and confusion. The study to be described is an in-depth epidemiological investigation of the full spectrum of autistic conditions. In addition to providing the first North American prevalence data, we are examining the relationships among a number of psychological and physical variables. The aim is to provide data relevant to the altiology of autism. This talk will focus on findings regarding genetic and traumatic contributory factors.},
}

@inproceedings{delamater1987reinforcer,
  title = {Reinforcer location effects in simple conditioning: How does the rat know when and where to go ~ pick up food?},
  author = {Delamater, A.R. and LoLordo, V.M.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Two experiments inquire as to how the rat is sensitive to manipulations that vary the location of a reinforcer during simple conditioning procedures. In the first, we asked whether changing the location of a preferred edible after the rat had already learned that a stimulus signalled its availability in another place, would affect responses conditioned to that stimulus. Following the location-shift manipulation, conditioned responses continued to be elicited by the stimulus but they were directed to the shifted location. In the second experiment, we asked whether presenting the preferred edible in one location before the rat had learned that a stimulus signalled its availability in a different location, would affect the course of learning accruing to that stimulus. Preliminary data indicate that the rate of learning was enhanced in the location-shifted group relative to a non-shifted group. It is suggested that these data pose problems for most "reflex-oriented" conceptions of behavior.},
}

@inproceedings{harrington1987mystery,
  title = {The mystery of the misplaced clock},
  author = {Harrington, M.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Several laboratories have now reported that circadian rhythmicity, disrupted after ablation of the suprachiasmatic nucleus (SCN), can be restored by transplantation of fetal hypothalamic tissue containing SCN neurons. Transplant tissue has usually been placed into the part of the brain where the SCN is normally located - the base of the third ventricle. In collaboration with Dr. p. Decoursey, I tested whether SCN tissue transplanted to a site distal to the hypothalamus would be capable of restoring circadian rhythmicity in hamsters made arrhythmic by SCN lesions.},
}

@inproceedings{honig1987pigeon,
  title = {The pigeon and the polka dot},
  author = {Honig, W.K.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {Pigeons were trained to discriminate among matrices of 36 randomly arranged dots, some of them red, and the rest blue. If a matrix with red was positive, then the birds provided an orderly declining gradient of generalization as the proportion of red dots decreased. If blue was positive, the opposite gradient was obtained. During a transfer test with matrices of 64 dots the pigeons provided similar gradients according to the same ratios of red and blue as those that controlled the behavior with 36 dots.},
}

@inproceedings{jia1987painless,
  title = {The Painless Tale of a Tunicate Headache Identification of specific neurons in the larval tunicate},
  author = {Jia, W-G. and Meinertzhagen, I.},
  booktitle = {Thirteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1987},
  abstract = {The larval acsidian (tunicate) has some vertebrate affinities and its nervous system contains relatively few neurons (about 50). This preparation provides a unique opportunity to study the development of nervous systems. In the present investigation, an acetylcholinesterase (AChE)-selective staining method and a methionine (MET)-enkephalin immunocytochemical technique was utilised to examine the nervous system in the larvae of Ciona intestinalis. Eight-10 primary sensory neurons and a pair of neurons in the vesical ganglion were identified by AChE staining and a single caudal neuron in the tail nerve cord showed MET-enkephalin immunoreactivity. This is the first demonstration of AChE-positive and MET-enkephalin reactive neurons in the larval tunicate, and the latter is also the first evidence for neuronal perikarya in the nerve cord.},
}

@inproceedings{meinertzhagen1988madrid,
  title = {Madrid, Spain.},
  author = {Meinertzhagen, I.A. and *C.s.r.c, A. Ferrus*. and Velazquez},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {The Influence of Cell Size Upon Synaptic Frequency in Drosophila. The size of a neuron provides a major prediction of both the number of its synapses and of its aggregate area of synaptic contact. Our previous studies establish a close correlation between the number of afferent synaptic sites and the presynaptic membrane surface area over which these are distributed, in the terminals of photoreceptors innervating the first optic neuropile, or lamina, underlying the fly's eye. A similar relationship also exists for their target interneurons, Ll and 12, each unique occupants of one of the cartridges of lamina neuropile, the dendrites of which also receive synaptic input in proportion to their surface area. All such studies are correlative, however, and fail to distinguish directly whether large neurons bear more synapses or, alternatively, whether neurons with more synapses grow larger, perhaps for some trophic reason, I will describe experiments in Drosophila in which the causal relationship between cell size and synaptic number may be established by analysing synaptic frequencies in neurons which are made independently large, using genetic mutants.},
}

@inproceedings{dunham1988mother,
  title = {Mother Care and Other Care: Some Differences in Mother-Infant Social Structure:----},
  author = {Dunham, P. and F and Dunham and Davis, C.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {While studying the structure of mother-infant social interactions, we encountered some unexpected and interesting differences when comparing mothers employed outside the home and mothers who care for their infants full-time in the home.},
}

@inproceedings{walsh1988development,
  title = {The Development of Imitation During the First Year.},
  author = {Walsh, E. and Legerstee, H. and Kienapple, K.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Many studies have looked at imitation in infants under constrained, unnatural conditions and at a particular age. In contrast, this study has taken a longitudinal approach to study the development of imitation by infants when engaged in natural interactions with their mothers. Play sessions of 2 mothers and their infants were videotaped. Dyads were observed biweekly from 3 to 25 weeks of age and monthly thereafter until 12 months. Sessions were of 45 sec durations at 3, 5 and 7 weeks and of 60 sec thereafter. Patterns of imitation (especially in mouth opening, lip movements, smile and vocalization) indicate that an imitative ability may be present in the first 3 to 9 weeks of an infant's life. Imitation appears to decrease at about 17 weeks and increase again at about 34 to 40 weeks. The results suggest that imitation may be an integral part of early mother/infant social interactions.},
}

@inproceedings{klein1988does,
  title = {Does Covert Visual Orienting Affect Stimulus Encoding or Decision Criteria?},
  author = {Klein, R. and Smith, C.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {The debate goes on. Investigators have applied paradigms from within mental chronometry, signal detection theory and electrophysiology to answer this question. This literature will be critically reviewed with particular emphasis on the distinction between endogenous and exogenous covert orienting. Mathematical frameworks like the accumulator and random walk models will be applied to the corpus of chronometric data from the Hansen thesis and similar follow-up experiments conducted in our laboratory. By focussing attention on a detailed analysis of these studies we hope to enhance the "signal" in this noisy area. Strategies for future research will be presented.},
}

@inproceedings{shaw1988nouvelle,
  title = {La nouvelle sensation: plus~ change, plus ce n'est pas la meme mouche.* ~Supported by NSERCand a rather small dictionaryj':- -- -- ---},
  author = {Shaw, S. and D and Moore and Frohlich, A. and Dawson, J. and Dickson, P. and Collective, The Fly},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {The nature of evolutionary change has been little studied at the cellular level in any nervous system, and so constitutes an important lacuna in knowledge. We have told you before that in the system we study for convenience, in insects, evidence suggests that the evolution of function has been accomplished by saving the same fixed set of ancestral neuronal homologues, but allowing these to vary some of their mutual synaptic connections, Attempts to justify a statement of such penetrating simplicity will be made with the help of actual results, drawn from our current work on a particularly stupid and probably primitive fly. The new results throw more light on the things that may change more readily, and things that may not, in the evolution of a nervous system,},
}

@inproceedings{briand1988implicit,
  title = {Implicit Expectancies in Automatic Visual Orienting.},
  author = {Briand, K.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Peripheral visual stimuli can attract attention very quickly, and such orienting effects appear to be automatic. It is usually assumed that the cue operates via a system which informs higher-level processes 'where' in space an event occurs, and that 'what' is at the cued location is irrelevant. From this it follows that (all other things being equal) a given cue will have identical effects on all possible classes of targets which occur. This is not the case. Cueing effects are modulated by the physical similarity between the cue and target, indicating that when a peripheral event occurs, information concerning attributes such as form, orientation, and motion is used to facilitate processing of subsequent targets. Color information does not appear to be used in this manner. It seems that when one orients attention to a location via some peripheral 'event', one expects to find the object responsible for that 'event'.},
}

@inproceedings{eskes1988further,
  title = {Further Studies of Comprehension in Autistic Children.},
  author = {Eskes, G. and Bryson, S. and McCormick, T.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Converging evidence from our studies and those from other laboratories suggest that high-functioning autistic children's comprehension of single words is similar to that of carefully matched control children. However, while single word comprehension may be developmentally normal, both clinical reports and language comprehension studies agree that autistic children do have trouble comprehending more complex, sequentially ordered information, such as sentences or paragraphs. This talk will describe a study we are about to begin that will examine their understanding of the same words presented individually or in the context of a sentence.},
}

@inproceedings{cohen1988tune,
  title = {To Tune or Not to Tune: Cognitive and Sensory Influences on Memory for a Microtonal ScaleasShown by ~ Signar-Detection Analysis.},
  author = {Cohen, A.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Musically trained and less trained subjects completed nine conditions of an absolute judgment task resulting from three sequential (melodic) and between people and objects, they do not seem to differentiate between the active and inactive person as ~arly and as clearly as do normal infants. Rather than showing distress, OS babies continue to smile and vocalize with neutral faces when in front of the nonresponsive adult ■ This lack of communication skills may be one of the contributing factors to their delayed linguistic development. Additional results focused on the evolution of the responses to people and objects of these OS infants during their first year of life.},
}

@inproceedings{wisker1988effects,
  title = {Effects of Genetic Differences at the Major Histocompatibility Complex and Diet ~ Attraction ~ the Maternaliliour by H-2 Congenic Mice.},
  author = {Wisker, L.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Mouse pups are attracted to the "maternal odors" produced by lactating females. This experiment investigates the role of diet and the Major Histocompatability Complex (MHC) in maternal odor recognition. Two congenic strains of mice, which differ in the MHCwere used (C57BL/6J and B6C-H-2bml/BYJ). Pups were tested for odor preferences using maternal urine and feces odors in 2 min. tests, If the MHCplays an important role in maternal odor identification, odors from the same strain should be preferred to those of the other strain. If diet influences odor identification, odors from mothers on the same diet should be preferred. Finally, it is possible that the MHC will influence preferences for urine ~while diet influences preferences for feces odors.},
}

@inproceedings{b1988catecholamin,
  title = {Catecholamines in the Central Nervous System of Lymnaea,},
  author = {B, J. Chiasson and R.P, Croll},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {The dist ri bu tion of catecholamines (CA's) within the central 0 anglia of the pond snail, Lymnaea stagnalis was examined through the use of glyoxylic acid and aqueous formaldehyde histofluorescence techniques, We found prominent clusters of CA cells located in the right and left parietal ganglia and along the anteriolateral margin of the pedal ganglia.},
}

@inproceedings{rusak1988food,
  title = {The Food, the Pad and the Cuddlies,},
  author = {Rusak, B. and Mistlberger, R. and B and Losier and C, H. Jones},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Rats and a few other species have been shown to anticipate a daily time at which they are fed by increasing their activity before this time, This increased anticipatory activity has been shown to be under the control of a food-entrainable oscillator (FEO), a component of the circadian system. This oscillator is separate from the light-entrainable pacemaker in the obtained, Numerosity is established as a "robust" stimulus dimension, The mechanism is a mystery, but the adaptive value of the discrimination would be considerable for a foraging animal. I 7. A, Droungas and V. LoLordo Short Exposure to Long Noises in the Midst of Shocks Will Make Rats Relax: Reasons Remain to be Determined- -- --- --- --- It is well documented that a CS, like a noise or a light, that is presented on trials during which shock is postponed will become a fear inhibitor, In the presence of such a CS, which has been "explicitly unpaired" with shock, rats will continue to lever-press for food even if another CS that has been "explicitly paired" with shock is concurrently present. The present experiment demonstrated that such fear inhibiting property was acquired by the CS after what is typically considered "limited" amount of training (8 conditioning sessions) but only if the explicitly unpaired CS was of relatively long duration (60 s). An identically trained CS of short duration (10 s) failed to become a fear inhibitor,},
}

@inproceedings{wright1988hale,
  title = {Hale Parental Behaviour in the House Mouse (Mus musculus).},
  author = {Wright, S. and Brown, R.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {All studies of paternal behaviour have been done with ad lib food and water in a warm environment. No studies have examined the importance of the male when environmental conditions mimic the real world, i.e. food must be foraged. Two groups of house mice were compared in a controlled environment: litters with their dam alone and litters with both parents. The environment consisted of a home cage with a running wheel and a feeder controlled by a computer. The amount of running needed to obtain food was manipulated. The growth and development of the pups was monitored by measuring the number of pups/litter, pup weight, growth rate, eye and ear opening, the number of pups at weaning and the weight of pups at weaning. Differences on these measures between the two groups was determined• Behavioural observations were also conducted to examine the male's contribution to litter development.},
}

@inproceedings{nakajima1988blockade,
  title = {Blockade of Dopamine D2 Receptors in the Brain Suppresses Operant Responding-. -},
  author = {Nakajima},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Raclopride, a dopamine antagonist, has a high affinity for D2 receptors but extremely low affinity for Dl receptors, Intraperitoneal injection of raclopride suppressed bar-pressing for food (CRF and VI-30 sec), ventral tegmental stimulation, and intravenous heroin infusion in the rat. The degree of suppression was related to the dose, and the maximal effects were observed from 30 to 180 min after injection, Raclopride injection into the nucleus accumbens suppressed ipsilateral tegmental self- roles of experience, b) rules of generalization, and c) the organism's handling of incomplete or distorted information. This talk is designed to highlight some of these issues, with reference to existing literature and potential experimental approaches for future work. Naturally, mice and wolves will play a key (but not exclusive) role here!},
}

@inproceedings{barresi1988myriad,
  title = {The Myriad Mind: Steps Toward~ Science of Persons.},
  author = {Barresi, J.},
  booktitle = {Fourteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1988},
  abstract = {Psychologists have given insufficient attention to the possible use of biographical materials involving whole lives as a data base for the development of the psychology of persons. In a book that I am currently working on, I will argue for an approach for using such data which treats individual lives as a unit. According to this approach, competing theories would be developed to account for the causal history of particular lives, and the power of these theories would be assessed relative to alternative theories in terms of their simplicity, coherence, and plausability in accounting for the particular life, and in terms of the generality and testability of their principles in applying to other lives.},
  note = {QA: needs-split-review; Split from 5 at: 'J. Barresi'},
}

