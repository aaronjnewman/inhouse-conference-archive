@inproceedings{raymond1980abnormala,
  title = {Abnormal Grating Adaptation in Multiple Sclerosis.},
  author = {Raymond, D. J.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
  abstract = {Reduced contrast sensitivity is often found in individuals with multiple sclerosis (MS). I investigated this abnormality of contrast vision by measuring changes in contrast sensitivity after adaptation to a high contrast sine wave grating pattern in MS patients and normal control subjects. I found that after viewing a 70 90 contrast adapting pattern for 1 minute, 15 out of 17 MS patients showed contrast sensitivity changes, or adaptation effects, smaller than 2. 0 standard deviations below the mean adaptation effect for the normal group with at least one eye. In normals, the size of the adaptation effect increases both as the contrast of the adapting pattern is increased and as the duration of exposure to the adapting pattern is increased. Although these relationships also hold for the MS patients studied, the shapes of both the contrast and duration functions are different for the MS group. When the contrast of the adapting pattern is low but still visible to the subject (less than 1.0 l.u. greater than the unadapted log contrast threshold), an adaptation effect can always be observed in normal subjects. However, in some MS patients adapting patterns of m1,lchhigher contrasts (up to 1. 0 1. u greater than the log unadapted contrast threshold) are insufficient to induce adaptation effects. Similarly, 20 to 60 seconds of exposure to a 70% contn:.st adapting pattern are enough to produce near-maximum adaptation effects in normal subjects. MS patients require exposures of 180 to 300 seconds before adaptation effects similar in size to those found in normals can be observed. These differences between MS patients and normal subjects cannot be explained by reduced contrast sensitivity and indicate that the neural, probably cortical, mechanisms mediating visual contrast adaptation may be considerably altered by MS.},
  note = {QA: needs-split-review; Split from 8 at: 'D. J. Raymond'},
}

@inproceedings{meinertzhagen1980synaptogenes,
  title = {Synaptogenesis in the Fly's Visual System.},
  author = {Meinertzhagen, E. I. and Frtlhlich, A.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
  abstract = {The ultrastructure and composition of fly photoreceptor synapse populations has been examined by serial electron microscopy of developing animals. Adult synapses are tetrads with four postsynaptic elements. At younger stages dyad and triad synapses (with nrn and three postsynaptic elements, respectively) coexist alongside tetrads, those of older animals having an average more postsynaptic processes per synapse. It is suggested that individuc1.l synapses assemble piecemeal, element by element.},
  note = {QA: needs-split-review; Split from 8 at: 'E. I. Meinertzhagen'},
}

@inproceedings{d1980quine,
  title = {Quine. 8 Octaves Below Human Hearing: Pigeons Detect Infrasound.},
  author = {D, F.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
  abstract = {Homing pigeons can detect sow1ds at frequencies as low as 0.05 Hz. 1nis poster will summarize the procedures used in measuring the infrasound sensitivity of homing pigeons. Frequency discrimination thresholds at these frequencies will be discussed in the contextofwhat adaptive value these unusual sensory abilities may have to the pigeon. Possible uses include navigation, weather prediction and flight control. A comparison will be made with human low frequency hearing thresholds.},
  note = {QA: needs-split-review; Split from 8 at: 'F. D. Quine'},
}

@inproceedings{ryon1980aspectsa,
  title = {Aspects of Dominance Behavior in Groups of Sibling Coyotes.},
  author = {Ryon, J.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
  abstract = {Two unrelated groups of sexually mature sibling coyotes with three males and two fema]es each were observed when each group was a) housed together, b) divided by sex into four groups and c) reunited after three months. Tvo dominance hierarchies (male and female) in each group were determi1:ed by social display. TI1e effect of opposite-sex animals on 1) prosocial and 2) agonistic interactions, 3) scent-marking, 4) some aspects of howling and S) spatial containment of lo1v-ranking animals was studied. Same-sex aggression was higher in females than in males. The presence of males correlated with a striking increase in levels of aggression between females. TI1e rate of scent-marking and howling was greater for the dominant females than for any other individual of either group. TI1e only incident of spatial containment occurred among females.},
  note = {QA: needs-split-review; Split from 8-split4 at: 'J. Ryon'},
}

@inproceedings{barresi1980froma,
  title = {From Percept to Concept: Parsing Prj..nciples for Perceptual Categories.},
  author = {Barresi, J. and MacCallum, B.},
  booktitle = {Sixth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1980},
  abstract = {When subjects are asked to partition random 9-dot patterns into their "natural" parts, most of the subjects' partitions for a particular pattern can be fit into a single nested hierarchy of parts. Such hierarchies often differ even among quite "similar" patterns. How then do ve form abstract concepts to represent a category of such related patterns? Perhaps, with experience, related patterns assimilate to a single nested hierarchy of parts which comes to define the concept. Evidence will be presented which supports this hypothesis.},
  note = {QA: needs-split-review; Split from 8-split4 at: 'J. Barresi and B. MacCallum'},
}

