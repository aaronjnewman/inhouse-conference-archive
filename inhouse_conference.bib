@inproceedings{phillips1991temporal,
  title = {Temporal auditory processing deficits in developmental dysphasia},
  author = {Phillips, Dennis and Tallal, Paula},
  booktitle = {Seventeenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1991},
  abstract = {The most comprehensive, if somewhat controversial, account of developmental dysphasia is Tallal's. Briefly, she argues that the speech reception deficit is due to an auditory temporal processing disorder: the disordered mechanism is thought to be cortical in locus, and to affect the perception of both linguistic and nonlinguistic sounds. The most compelling demonstration of the impairment lies in the inability of these children to discriminate the order of two brief (75 ms) tone pulses if the duration of the silent period between them is less than 100 to 300 ms, a task which normals perform with near-perfect accuracy for inter-stimulus intervals as small as O ms. The intended connotation of the term "temporal processing" is, however, far from clear in Tallal's published work. By the same token, nothing is known about the generality of any deficit across auditory perceptual dimensions that have their origins in different forms of time-related or time- dependent sound processing. In this talk, I will present sketches of two of a long series of experiments, based on modem auditory neuroscience, that we have planned to address these lacunae.},
  note = {QA: abstract-too-short},
}

