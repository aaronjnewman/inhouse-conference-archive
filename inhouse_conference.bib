@inproceedings{bennett1978some,
  title = {Some Aspects of Communal Pup-Rearing i~the Timber Wolf.},
  author = {Bennett, N.},
  booktitle = {Fourth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1978},
  abstract = {Communal pup-rearing is a major co-operative feature of pack social behavior in the timber wolf (Canis lupus) which has not yet been studied in detail. It is known that in the pack,adults assist both mothers and pups in a variety of ways. The present study exam- ined some aspects of pup-rearing in a pack of 12 captive timber wolves and found that assistance to mothers was rendered in a highly selective manner whereas all pups were cared for equally and without distinction. In addition an analysis of the social relationship between pairs of pack members suggests that little aggression occurs during the breeding season between future mothers and their helpers.},
}

