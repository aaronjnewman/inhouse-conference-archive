@inproceedings{yoon1978neuritic,
  title = {Neuritic Outgrowths from the Adult Goldfish Retinal Tissue ·in Culture.},
  author = {Yoon, M.},
  booktitle = {Fourth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1978},
  abstract = {The patterns of neuritic outgrowths from the retina are inves- tigated in vitro under various experimental conditions by culturing the retinal tissue, explanted from the adult goldfish. Under favorable culture conditions, the retinal tissue shows vigorous outgrowth of neurites as early as 12 hr and as late as 4-5 weeks after explantation. The neuritic outgrowths from the retinal explant is enhanced by sec- tion of the axons of the retinal ganglian cells prior to the explanta- tion of the retinal tissue. The direction of neuritic outgrowths from the retinal explant in vitro seems to follow the regularity in the embryonic developmentof neuronal processes in vivo: the retinal neurites tend to grow in the radial directiontowards the optic disc at the center of the retina, especially at an early stage in culture. In further experiments, a strip of retinal tissue and its topographi- cally matching area of the optic tectum are co-cultured in various geometric configuration within the same culture chamber. Some of the retinal neurites eventually grow into the tectal tissue. It is not known as yet whether these retinal neurites re-establish functional synapses with appropriate visual neurones of the tectal tissue in vitro.},
}

