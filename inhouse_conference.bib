@inproceedings{phillips1989summertime,
  title = {Summertime Diversions of a Man and Two Women, Or,Why It's Important That Spikes bePrecisely Timed},
  author = {Phillips, D.P. and Hall, S.E. and Hollett, J.L.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {A much-favoured neural code for the frequency content of a sound is the temporal one. This theory proposes that each acoustic event in the stimulus generates a spike discharge in an auditory neuron, so that the time between spikes specifies the spectral and temporal content of the sound. There is abundant evidence in the auditory nerve not only that this temporal representation exists, but also that it is competent for frequency elements up to about 3500 Hz. The further question, however, is the extent to which this temporal code significantly penetrates the central auditory nervous system. This question is not unreasonable, because the greater the number of serial synapses in the pathway transmitting the time code, the greater must be the imprecision in spike timing at the end of the neural pathway. In studies conducted last summer, we obtained evidence on this issue from single cat cortical neurons, by studying the effects of placing increasing temporal demands on a neuron's spike response rate. Our data show that cortical neurons which entrain spikes to brief tones presented at low repetition rates (eg., 1 Hz) fail to do so for tones at higher repetition rates, even though the precision of their spike timing is more than capable of supporting perfect entrainment This suggests that factors other than spike time precision limit the temporal representation of acoustic events in the cortex. Second, we provided evidence that even under the most optimal of stimulus conditions, cortical cells probably do not have sufficient precision of spike timing to support a temporal code for components in excess of about 100 Hz. This suggests to us that the cortex does not possess a representation of the fine time structure of a sound's waveform.},
}

@inproceedings{barresi1989descartes,
  title = {Descartes' mind, Descartes' body: The onto~enesis of a distinction between mind and matter.},
  author = {Barresi, John},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {It is generally acknowledged that a major turning point in western man's self-understanding occurred when Descartes originated the distinction between mind and matter. Descartes' distinction and his mind/body dualism struck such a responsive chord that we have yet to extricate ourselves from it, as indicated by the existence of cognitive science and neuroscience as separate but interactive disciplines. In the present talk I will try to provide a theoretical account of the causal origin of this distinction through a psychosocial investigation of Descartes' life history and its socio-cultural context. I will also try to account for its long-term consequences.},
}

@inproceedings{honig1989eons,
  title = {Pi~eons Discriminate Numbers of People in Pictures},
  author = {Honig, W.K.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Pigeons readily learn to distinguish slides of natural scenes that contain a person from slides that do not. We asked whether they would also be sensitive to the number of people in a picture. Four birds were trained to discriminate slides containing one person from slides containing "many", where "many" was defined as eight or more. For two birds, one person was positive; for two others, "many" was positive. The birds were then tested with other numerical categories: the presence of 2, 3, 4-5, and 6-7 persons in the picture. All birds provided orderly discrimination gradients among these test values. We asked whether the numerosity discrimination had to be made explicit in training in order to obtain such a gradient. For this purpose, we trained a second group of birds that had to discriminate "many" from the absence of any person in the picture. This was an easy discrimination for them, and a test with the same numerical categories again provided an orderly discrimination gradient. These data provide evidence for number discriminations within "natural" categories, but that is not the same as counting.},
}

@inproceedings{alsop1989flashes,
  title = {Flashes of red, flashes of blue, If you're a pi~eon, what do you do?},
  author = {Alsop, B.L. and Honig, W.K.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Pigeons can discriminate the relative numerousness of one type of stimulus element versus another type when these two types of stimuli are presented simultaneously in a two dimensional array (Honig, last year). Recently we have been investigating pigeons ability to discriminate the relative numerousness of two types of stimuli presented sequentially. Pigeons are presented with 5 "flashes" of light. Some flashes are a blue light, others are a red light. If the sequence contained more blue than red (an extreme example would be 5 blue and Ored) then pecking the left key may provide a reinforcer, but pecking the right key darkens the chamber for 3 seconds. If there were more red, then these contingencies are reversed. Accuracy in this task appears to be a function not only of the relative number of elements, but also their arrangement within the sequence.},
}

@inproceedings{williams1989black,
  title = {Black is beautiful, but white is alri~ht,},
  author = {Williams, Doug and LoLordo, Vin},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {When given a choice, rats prefer spending time in a black compartment of a two-compartment apparatus when the other compartment is painted white and brightly lit. This unconditioned preference for black was used as a baseline against which the effects of various Pavlovian treatments on contextual learning was assessed. Rats were locked in the black compartment and given mild electric shocks. To our surprise they now preferred the white compartment in a follow-up preference test.},
}

@inproceedings{droungas1989dis,
  title = {Is dis~st necessary in taste-mediated potentiation of cue aversion},
  author = {Droungas, Anastasia and Delamater, Andrew and LoLordo, Vincent},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Animals learn aversions to exteroceptive cues, e.g. visual, auditory, olfactory, and contextual cues only if during the poisoning episode these cues are compounded with taste. This phenomenon has been termed taste-mediated potentiation of cue aversion and seems to defy the general principle of stimulus equipotentiality. Garcia has proposed that potentiation is a phenomenon unique to the feeding system since it is observed only in preparations where LiCl is used as the US and not in preparations where shock is used. Li Cl is a potent toxicosis inducing agent that also produces shifts in the hedonic evaluation of tastes that have been paired with it Shock on the other hand, is a fear inducing agent and it does not produce palatability shifts. This talk will explore whether it is necessary to use toxicosis inducing agents in order to produce potentiation.},
}

@inproceedings{croll1989phillip,
  title = {Is Phillip Rushton wrong? Can one both have a large brain and be sexually well endowed?},
  author = {Croll, R.P. and Bina, K.G.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Recent work indicates that the nervous systems of gastropods grow post-embryonically by increasing both the size and the number of resident neurons. For example, the Pelb cluster within the pedal ganglia of the pond snail, Lymnaca. is undetectable in juvenile snails. It first appears near the time of sexual maturity and thereafter the cells within the cluster increase rapidly in both size and number. Parallel growth occurs in the cluster's target tissue, the penis. Our future studies will employ both ablation and transplantation experiments to test the role of the penis in determining the growth of the Pelb cluster. We hypothesize that contrary to certain well-established (but perhaps not scientifically supported) beliefs, a large penis and perhaps a well used penis might enhance neural development. If generalized to other animals this hypothesis could have profound social and ethical ramifications.},
}

@inproceedings{rusak1989foscinating,
  title = {Foscinating rhythm, I'm under your spell.},
  author = {Rusak, Benjamin and Robertson, Harold A.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {We have been studying the neural mechanisms by which lighting cycles entrain (synchronized) circadian (daily) rhythms in mammals. The suprachiasmatic nuclei (SCN) in the hypothalamus serve as the dominant pacemaker of the circadian system, and cells here are responsive to retinal illumination. We have recently found that these cells alter their gene expression in response to photic cues. Brief light exposures cause SCN cells (and not other retinorecipient cells) to increase expression of the cellular-ms. (c-fu.s) gene, a member of the family of proto-oncogenes. This discovery presents new opportunities for analysing the transmitters in the entrainment pathway, the intracellular events involved in entrainment, and the biochemical mechanism of the circadian clock.},
}

@inproceedings{brandstatter1989degenerate,
  title = {Degenerate Synapses},
  author = {Brandstatter, J.H. and Meinertzhagen, LA. and Shaw, S.R.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {We are interested in the plastic changes which synapses undergo during normal adult life. In the fly's visual system, for example, synapses formed by the terminals of photoreceptors in the first optic neuropile, or lamina, gradually decrease in number with age. The dynamic events of their loss are being investigated by procuring the death of photoreceptors by photoablation, following treatment with a dye sulphorhodamine. The terminals commence degeneration within one hour, progressing through characteristic changes of mitochondrial swelling, terminal shrinking and cytoplasmic darkening. Their synapses disappear, but asynchronously, progressing through the following sequence: first the presynaptic ribbon disappears, then the postsynaptic elements separate from the presynaptic site (usually together), and finally glia insinuate themselves into the enlarged synaptic cleft.},
}

@inproceedings{meinertzhagen1989inter,
  title = {Inter-s_peciesocular trans_plantationin flies: intended synaptic bestiality.},
  author = {Meinertzhagen, I.A. and Seyan, H.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Transplantations of eyes and brains have been undertaken between flies, of the same or different species, with the aim of procuring inter-species synaptogenesis. Our objective is to examine how conserved the intercellular signals that are widely hypothesised to underly synapse formation have been between flies of progressively remote ancestry. Current progress and its implications will be reported.},
}

@inproceedings{kind1989cell,
  title = {Cell sizes in the Lateral Geniculate Nucleus of theCat Followin~ Reverse Occlusion Re~mens which Optimize Visual Recovezy from Early Monocular Deprivation.},
  author = {Kind, P. and Mitchell, D.E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Monocular deprivation in early life causes the anatomical and physiological development of the central visual pathway of kittens to be severely impaired and results in visual deficits resembling those observed in severe forms of amblyopia. Following monocular deprivation from birth to six weeks of age, the cells in the lateral geniculate nucleus (LGN) which receive input from the deprived eye are 25-30% smaller in area than those cells which receive input from the non-deprived eye, The present research was designed to investigate further the duration of the critical periods in the kitten •LGN during which these anatomical changes occur. The kittens were monocularly deprived from birth to six weeks of age and then received a period of either full-time or part-time reverse occlusion. In addition, we examined the effects of a period of binocular vision imposed after the critical period on the morphology of the LGN. Finally several kittens were either reverse sutured or monocularly deprived at three months of age. The results indicate that a period of binocular visual exposure can alter LGN cell areas even when imposed after the critical period. In addition, the anatomy of the LGN is not directly correlated with the final visual capacities of the cat, but instead may reflect the visual acuities of the two eyes at the age of three months.},
}

@inproceedings{shaw1989evolution,
  title = {Evolution of the visual optics and associated neural wirin~ in Diptera,},
  author = {Shaw, S.R.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {In pursuit of the nature of evolutionary modification in nervous systems, so far we have looked mostly at neuronal connectivity, finding that there has been wholesale change in the synaptic connections between an invariant set of neuronal homologues, in Diptera (flies). The visual optics have received less attention, but evolved in parallel from a more primitive symmetrical state to form the asymmetric clusters of photoreceptors found exclusively in today's advanced families. This switch apparently happened in a single transition in an ancestor back in the Triassic or earlier. A highly stereotyped projection pattern of axons is needed behind the eye to take advantage of the new optics, raising the question of whether this "neural wiring" changed in step with the optical changes, or occurred earlier or later, out of synchrony. Reconstructions of the axonal projection pattern in several primitive groups indicates a very tight linkage between the optics and the wiring, pointing probably to some kind of coupling between the two seemingly independent developmental programmes. In attempting to shed more light on the transition state, I have started to examine the optics in a primitive group that lies near the stem line of the advanced Diptera, as a prelude to tracing its axonal projection., and will show how the optics can be analysed in vivo with a suitably arranged microscope, and what the results predict so far.},
}

@inproceedings{kind1989hybridoma,
  title = {Hybridoma Technolo~: A Technique for Identifying the Molecular Basis Developmental Plasticity.},
  author = {Kind, P. and Mitchell, D.E. and Beaver, C.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Many hypotheses for the specificity of connections in the nervous system involve the presence of cell surface molecules which act as recognition sites between appropriate neurons. Indeed, many theories concerning the molecular mechanisms which underly plasticity in developing mammalian pathways include the presence of surface molecules capable of mediating synaptic reorganization. Hybridoma technology provides a potential vehicle for identifying the cellular antigens which underly synaptogenesis and developmental plasticity. In the present study, the visual cortex of kittens reverse sutured at four weeks for four days were used to immunize adult mice in an attempt to produce antibodies specific for developmental antigens of the visual system. We will describe our attempt with the hybridoma procedure and in addition present some results obtained with CAT 301, a monoclonal antibody produced by Dr. Susan Hockfield at Yale University which labels a subset of neurons in the cat visual system.},
}

@inproceedings{brown1989rearing,
  title = {Rearing rats in a germ-free environment eliminates their odours of individuality,},
  author = {Brown, Richard E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {To test the hypothesis that commensal bacteria influence the urinary odours of individuality, we collected urine from PVG and PVG.Rl male rats born by Caesarian section and reared in a germ-free environment. Urine from the germ-free rats was not discriminated in a habituation-dishabituation test, while urine from males kept in a conventional animal house could be discriminated. When the germ-free rats were moved to a conventional animal house their urine was discriminable. These results provide the first evidence that the :MHC and commensal bacteria interact in the production of the unique individuality signal in the urine of congenic rat strains. Similar interactions between animals and their commensural bacteria are responsible for producing other social odours.},
}

@inproceedings{schellinck1989use,
  title = {The use of operant conditioning methods to study discrimination of complex social odours in rats,},
  author = {Schellinck, Heather A. and Rouse, Valerie C. and Brown, Richard E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Using an habituation-dishabituation task, Brown, Singh & Roser (1987) showed that the urine of rats which differed only in the A region (Class 1) of the Major Histocompatibility Complex (:MHC) was discriminable by other rats. To further this research, we constructed a small animal olfactometer so that operant conditioning techniques could be used to test the ability of rats to discriminate between odours. Preliminary results suggest that the procedure is appropriate for demonstrating the ability of rats to discriminate between the odours of two individual male rats of an outbred strain; the odours of congenic strains of rats and human odours. However, inconsistencies in the results would suggest a slack of stimilus control and modifications are now being made before further hypotheses are tested. The nature of these hypotheses will be discussed.},
}

@inproceedings{staicer1989vocal,
  title = {Vocal communication systems of Dendroica warblers.},
  author = {Staicer, Cynthia A.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {The songs of birds play an important role in intraspecific communication, though mechanisms involved remain poorly understood. Song use in Dendroica warblers suggests different songs serve different functions: Males use A songs when advertising for mates and B songs when interacting with other males. A and B songs differ structurally and are associated with different singing behaviours (slow, repetitive, stereotyped vs. rapid, alternating, variable.) This unusual vocal system presents an opportunity to study underlying mechanisms, including the neural organization of singing behaviours, the control of switching between singing behaviours, and the process of learning songs and their appropriate uses.},
}

@inproceedings{coscia1989moan,
  title = {Moan, groans, screams, and whines, was what she heard from behind the blinds,},
  author = {Coscia, Elizabeth M. and Phillips, Dennis P. and Fentress, John C.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {The development of the wolf (Canis lupus) vocal repertoire was examined in a litter of wolf pups during the first 35 days of life. Audio and video recordings were collected from inside a den located within a 3.8 hectare wooded enclosure. The vocalizations recorded were analyzed spectrographically to trace changes in acoustic content with postnatal age. The neonatal sounds varied in hannonic structure, fundamental frequency, duration, frequency modulation, temporal patterns, and time of first appearance. Hannonically-rich vocalizations present on day one were seen to lower in fundamental frequency with increasing age. Other, often non-harmonic vocalizations, were less common during the first two weeks but by the end of the first month had acoustic structures consistent with their being precursors to adult vocalizations.},
}

@inproceedings{ryan1989modification,
  title = {The modification of neonatal ultrasound vocalizations in therat by nore_pinephrinea~onists and},
  author = {Ryan, Catherine L. and Brown, Richard E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {anta~onists. Infant murid rcxlents emit ultrasonic vocalizations (UV) to guide maternal behavior. Although it has been reported that lesions to the noradrenergic (NE) system do not alter the frequency of UV emitted by rcxlent pups, we investigated the relationship between NE activity and UV using drugs which act as NE agonists or antagonists. Rat pups were tested at 4, 8, and 12 days of age. Five groups of pups were given a single s.c. injection of one of two doses of clonidine (alpha 2 agonist) or propranolol (beta blocker) or saline. Twenty minutes following injection, activity levels and isolation- induced ultrasounds were assessed using an ultrasonic microphone and a computer compatible ultrasound digitizer. Significant alterations in UV were detected. These results suggest a role for NE in the manifestation of UV and indicate that measurement of neonatal UV can be a sensitive tool for detecting perinatal perturbations of the NE system.},
}

@inproceedings{wright1989importance,
  title = {Importance of paternal care in mice when required to fora~e for food.},
  author = {Wright, Sandra L. and Brown, Richard E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Studies of parental behaviour in rcxlents generally provide the animals with ad lib food and water in a warm environment No studies have examined parental behaviour when environmental conditions mimic the real world, i.e. food must be foraged and temperature changes accommcxlated. In this experiment we examined the male's contribution to the pup's development in mice (Mus musculus) when wheel running was necessary to obtain food. Two groups of mice were compared: solitary dams with litters (sire absent) and paired dams with litters (sire present). Paired dams weaned more pups than solitary dams but there were no differences in pup weight from birth to weaning. Both groups showed parental care in the light phase and wheel running in the dark phase of the light:dark cycle. However, paired dams alternated parental care and running with the sire. When the sire ran, the dam was on the nest and when the dam ran the sire was on the nest These results suggest that the benefits of paternal care will be more evident in extreme environmental conditions than in the standard laboratory environment.},
}

@inproceedings{brown1989diet,
  title = {Diet and Genetic differences influence maternal odour preferences of infant mice. Olfactory signals communicate information about the species, sex, reprcxluctive condition, individuality and maternal state of an animal (Brown, 1979, Adv. Study Behav .. 10, 103-162). The},
  author = {Brown, Richard E. and Wisker, Lynda A.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {subjects were 16-19 day old mice of two congenic strains (C57BL/6J and B6-ARK-H-2k), which differ only in the major histocompatibility complex on chromosome 17. We tested the preferences of these mice for maternal odours of lactating females of the two strains on two different diets. Pups were attracted more to odours from lactating females of the same strain and on the same diet as their mother to lactating females of the other strain or those on the other diet. These results indicate that pups may "imprint" on different components of the maternal odour. Dietary information so learned may be used to direct food choices and genetic infonnation to influence the choice of social partners and mates.},
}

@inproceedings{legerstee1989communicativ,
  title = {Communicative Imitation in mother-infant and stranger-infant dyads during the first year.},
  author = {Legerstee, Maria},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {This study focused on the development of imitation between infants, their mothers and female strangers, and how these behaviors of the participants changed over time. Eight infants were observed longitudinally during the first year of life in natural interactions with the adults. Five behaviors were measured of the interactants: Mouth Open, Eye Open, Lip Protrusion, Smiling, Negative Face and Vocalizing. Lag sequential analyses were performed for each dependent variable. The z-score calculations were subsequently adjusted for the effects of autocorrelations. Significant imitative patterns for all behaviors occurred for the infants and adults at various points throughout development, although the vocalizations of the infants suppressed those of the adults. However, imitative development was not uniform. Peaks in imitative development occurred between 9 and 23 weeks for both infants and adults and between 34 and 45 weeks for infant and mother only. Log linear analyses revealed that significantly more imitative responding took place between mother and infant, than between stranger and infant. Differential imitative responsiveness occurred as early as three weeks for mouth open and vocalizations, and significantly more smiles of the mother were imitated throughout development. The study reveals that imitation is an intergral part of infant communication and illustrates the usefullness of this paradigm for investigating the development of imitation during the first year.},
  note = {QA: needs-split-review; Split from 28 at: 'Maria Legerstee'},
}

@inproceedings{ryon1989bringing,
  title = {Bringing home the bacon: food provisioning within a captive pack of coyotes (Canis latrans)},
  author = {Ryon, Jenny and Brown, Richard and Fentress, John},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Social behaviour in a pack of coyotes was observed for six years. This report concerns pup and related feeding by adults. All adult members of coyote packs feed young. Some members also feed pregnant and lactating females and yearlings. In our study, feeding began just before the birth of pups and continued for about 24 weeks. One adult male (Obie) was the only individual to feed the mother as well as the pups in the two years pups were born. The mother, another adult male and adult female also.fed the pups in these two years. Obie and the mother but not the other adults also fed the yearlings. All males were vasectomized before the mating season of the third year, thus no further pups were born. Obie continued to feed his mate (the mother in past years) at the appropriate time of year (i.e., just before the expected time of birth, as measured from the time of mating). He also fed his "pups" from previous years. He continued this pattern of feeding for four years (until his death) despite the fact that one of the male "pups" he fed had become dominant to him and one of the female "pups" had become dominate to his mate. The mother also continued to feed older off spring in the absence of new pups. We present data for six years and discuss these with respect to the stimuli which activate food provisioning within coyote packs. 31. April D'Aloisio and Ray Klein Agin~ andAttention This study examined age differences in attention and the relationship among different tasks previously used to measure attention. Sixteen community-dwelling older adults (X age= 61.1) and 16 young undergraduates (X age= 19.4) were tested on three attention tasks: Treisman's serial search task, Eriksen's distractor task and LaBerge's attentional range tasks. For all tasks, stimuli were arranged on an imaginary circle in order to eliminate any effects of retinal eccentricity. In Treisman's task the old showed slower search rates than young which suggests that the old were slower to shift their attention than the young. Both the amount of interference and the shape of the interference function in the Eriksen task was similar for both young and old indicating that there was no age difference in the size of the attentional 'beam'; the probe data from the LaBerge narrow task also support this conclusion. In sum, the results show that older subjects are able to control the size of the attentional 'beam' as well as young subjects, but they may not be as efficient at shifting their 'beam' as the young. •},
  note = {QA: needs-split-review; Split from 28-split1 at: 'Jenny Ryon'},
}

@inproceedings{beaver1989cortical,
  title = {Cortical areas mediating behavioural recovezy following early periods of monocular deprivation in kittens,},
  author = {Beaver, C.J. and Mitchell, D.E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Previous work in the laboratory has shown that following termination of six weeks of reverse occlusion of kittens that had been monocularly deprived until six weeks of age there is a surprising change in the visual acuities of both eyes. Although the visual acuity of the initially deprived eye improves substantially during the period of reverse occlusion, during the subsequent binocular period the vision of the eye deteriorates rapidly while that of the initially non-deprived eye regains almost normal acuity. As of yet, the mechanism mediating these changes is still unknown. I:esions of areas 17 and 18 are being carried out to determine the location of the mechanism. Possible outcomes and their meaning will be discussed.},
}

@inproceedings{ryon1989bringinga,
  title = {Bringing home the bacon: food provisioning within a captive pack of coyotes (Canis latrans)},
  author = {Ryon, Jenny and Brown, Richard and Fentress, John},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Social behaviour in a pack of coyotes was observed for six years. This report concerns pup and related feeding by adults. All adult members of coyote packs feed young. Some members also feed pregnant and lactating females and yearlings. In our study, feeding began just before the birth of pups and continued for about 24 weeks. One adult male (Obie) was the only individual to feed the mother as well as the pups in the two years pups were born. The mother, another adult male and adult female also.fed the pups in these two years. Obie and the mother but not the other adults also fed the yearlings. All males were vasectomized before the mating season of the third year, thus no further pups were born. Obie continued to feed his mate (the mother in past years) at the appropriate time of year (i.e., just before the expected time of birth, as measured from the time of mating). He also fed his "pups" from previous years. He continued this pattern of feeding for four years (until his death) despite the fact that one of the male "pups" he fed had become dominant to him and one of the female "pups" had become dominate to his mate. The mother also continued to feed older off spring in the absence of new pups. We present data for six years and discuss these with respect to the stimuli which activate food provisioning within coyote packs.},
}

@inproceedings{daloisio1989agin,
  title = {Agin~ andAttention},
  author = {D'Aloisio, April and Klein, Ray},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {This study examined age differences in attention and the relationship among different tasks previously used to measure attention. Sixteen community-dwelling older adults (X age= 61.1) and 16 young undergraduates (X age= 19.4) were tested on three attention tasks: Treisman's serial search task, Eriksen's distractor task and LaBerge's attentional range tasks. For all tasks, stimuli were arranged on an imaginary circle in order to eliminate any effects of retinal eccentricity. In Treisman's task the old showed slower search rates than young which suggests that the old were slower to shift their attention than the young. Both the amount of interference and the shape of the interference function in the Eriksen task was similar for both young and old indicating that there was no age difference in the size of the attentional 'beam'; the probe data from the LaBerge narrow task also support this conclusion. In sum, the results show that older subjects are able to control the size of the attentional 'beam' as well as young subjects, but they may not be as efficient at shifting their 'beam' as the young. •},
}

