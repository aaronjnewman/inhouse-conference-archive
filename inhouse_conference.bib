@inproceedings{mitchell1989comparison,
  title = {A Comparison of two Methods of Assessment of the Visual Acuity of Cats: A Search for Evidence of Aliasing,},
  author = {Mitchell, D.E. and Hall, S.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {The ability to resolve grating patterns at a given retinal location has traditionally been thought to be limited by the spacing of photo-receptors or sampling elements at that location. However, it is possible for acuity to exceed this limit in certain situations because of spurious resolution of patterns generated by undersampling of gratings by a regular array of sampling elements. The term "aliasing" is applied to such spurious resolution since the pattern observed has a spatial frequency different (lower) than that of the pattern that is actually imaged on the retina. Because of the potential for aliasing in the cat we have compared estimates of acuity obtained on a detection task (subject to aliasing) with estimates derived on a discrimination task that should be immune to aliasing effects. Since the two estimates were very similar it was concluded that conventional _E.1easuresof acuity in the cat are not contaminated by aliasing.},
}

@inproceedings{yoon1989development,
  title = {Development of Narrative Discourse in Normal Children},
  author = {Yoon, M.G. and Yoon, Myonghae Joy},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {We study the development of narration in the way how normal children represent an input-story into their own narrative outputs. Child-subjects (2.5 - 8 years old) and their mothers are invited to converse over an internal telephone system across two separate test rooms, while they can view each other via a reciprocal video-monitoring system. The mother reads a short story to the child over the phone as many times as the child wants. When the child is ready, he/she retells the story to a third party, the experimenter. All utterances of the child and the experimenter are recorded on videotapes, and later transcribed verbatim for detailed analyses. The utterances are segmented into unitary propositions with differential symbolic notations. Individual children's recounts of each story are depicted into characteristic textural graphs: unitary propositions constitute nuclear nodes which are interconnected with various cohesive ties into a semantically coherent pattern. These textural graphs are analyzed with respect to the categorical spectra of recalled propositions, modifications of syntactic structures, the pattern of cohesive ties, and the types of semantic inferences as compared with the template graph of the input-text The results show that preschool children recalled action-propositions at higher frequencies whereas elementary school children recalled external state-propositions at higher rates. Few children recalled narrator's perspectives. The modes of syntactic combination of propositions became more elaborated as they grew older. The degree of causal interpretations inferred from the input-propositions also increased with age.},
}

@inproceedings{moore1989children,
  title = {Children's understanding of the expression of uncertainty},
  author = {Moore, Chris and Pure, Kiran},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Modal terms (e.g. must, might, probably, possibly) are commonly used in natural language to express different degrees of the mental state of uncertainty. This paper reports an experiment which examined the development of children's understanding of this function of modals. Sixty children between the ages of three and six were presented with a task in which they had to find the location of an object hidden in one of two boxes. Their only clues were two statements said to them by two puppets. The two statements differed only in terms of the particular modal verb (of must, might, and could) that was employed in the sentence frame "It [verb] be in the red/blue box" or modal adjunct (of probably and possibly) employed in the sentence frame "It's [adjunct] in the red/blue box." Results revealed that children's understanding of the distinctions between the modal terms with respect to certainty and uncertainty develops at around four to five years of age. This finding is in agreement with results from studies on mental terms such as know and think, and implies that children's understanding of the mental state concept of uncertainty develops at about this age.},
}

@inproceedings{akhtar1989directive,
  title = {Directive interactions and early vocabulazy development: The role of joint attentional focus.},
  author = {Akhtar, Nameera and Dunham, Frances S. and Dunham, Philip J.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Several dimensions of maternal speech correlate with aspects of language acquisition in the second year of life. Directiveness, for example, when assessed by syntactic or pragmatic aspects of the mother's speech (i.e. frequency of prescriptives), predicts slow vocabulary development As prescriptives are most often used to direct a child's attention to a different activity or object, it may be that attentional regulation is the critical factor in this negative relationship. In the present study, twelve mothers were videotaped interacting with their thirteen month old children, and 100 maternal utterances were coded for pragmatic intent Prescriptives were coded as either leading or following the child's previously established focus of attention. The frequency of mothers' follow-prescriptives was positively correlated with a productive vocabulary measure taken at 22 months. These results indicate that directing a thirteen month old's behavior can have beneficial effects on subsequent vocabulary development, if it occurs during periods of joint focus.},
}

@inproceedings{farmer1989spatial,
  title = {Spatial and Sequential Processin~ in Dyslexic and Normal Readers},
  author = {Farmer, Mary E. and Bryson, Susan E.},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {Some researchers claim that the problem dyslexics· have with remembering the order of items is specific to phonetically cod.able mateii.al. On the other hand, Tallal (1984) has proposed that the difficulty is with processing any rapidly occurring sequential stimuli. These alternative hypotheses were investigated by presenting three tasks to three groups: dyslexics, age-matched, and reading- matched controls. The three tasks involved reproducing the identity and/or location of four letters which appeared at various rates either simultaneously or sequentially in a matrix, or sequentially in the same spot. Results indicated that dyslexics had more difficulty than age-matched controls with sequential presentation, and their performance deteriorated even more when both identity and location were required. Our findings provide support for the idea that dyslexics suffer a deficit in processing both sequential and phonetically codable material.},
}

@inproceedings{rosenthal1989frequency,
  title = {The frequency and behavioral manifestation of post-traumatic stress disorder in sexually abused children: A proposal.},
  author = {Rosenthal, Florence},
  booktitle = {Fifteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1989},
  abstract = {The purpose of the proposed study is to assess the frequency and behavioral manifestation of PTSD in school-age children who have been sexually abused, using a representative sample of verified cases. There will be a matched comparison group of physically abused children. The types and prevalence of behavior problems exhibited by sexually abused children will be assessed using the Child Behavior Checklist (Achenback & Edelbrock, 1983). Any problems found will be examined for relationships with characteristics of the abusive event, the child's pre-abuse development, the number and type of negative life events experienced by the child, family characteristics and family support. It is expected that children with high levels of behavioral problems will have had a more severe abuse experience and/or a more difficult pre-abuse history and will be more likely to have symptoms of PTSD.},
}

@inproceedings{phillips1990cache,
  title = {"Cache me if you can", the chuckling chicken cackled, or How Captive Coy Canids Cache Cadaverous Chicks.},
  author = {Phillips, D.P. and Danilchuk, W. and Ryon, J. and Fentress, J.C.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Behaviors as (arguably) simple as leech swimming, or as (arguably) complex as mammalian walking reflect control by central motor programs: they are overt expressions of the activity of neural mechanisms which stereotype a temporal sequence of motor responses. When the sequence links distinct movements of normally unrelated body parts, there may be evidence of "synactic rules of action". To date, the only published evidence for such rules in mammals has come from studies of grooming in laboratory rodents. As part of a much larger study, we have gathered evidence of a highly temporally structures, protracted sequence of distinct actions used by two canoid species to cache food for later retrieval. The action sequence was independent of the sex of the animal, the season in which the observations were made, and the substrate in which the food was buried. We argue that some features of the action sequence are not constrained by factors external to the animal. The action sequence may thus be the first demonstration in a large mammal, in a natural setting, of endogenous rules of action syntax.},
}

@inproceedings{schellinck1990i,
  title = {..I''.½ ~ " c€ J-1:5. i'O -,,,_,1'--cr1. U" . (1._l -u..u ~ -},
  author = {Schellinck, Heather and /, Richard Brown I},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {GeneticandMicrobiological Basesof IndividualOdoursin Rats Both genetic and microbiological factors may influence the ability of animals to discriminate between individuals by their odours. To determine the role of each, we examined the ability of Long Evans male rats to discriminate between urine odours from the following pairs of male rats in an olfactometer: (1) outbred Long Evans, (2) MHC congenics, (3) germfgree MHC congenics, (4) genti.cally indentical individuals. Discriminable differences were present in the urine odours used in all four tasks. Analysis of the errors to a critereon of 85%correct discrimination responses revealed different learning patterns in each task indicating that genetic and microbiological differences both contribute to their individual odours of rats. When there are no genetic differences (Task 4) or no microbiological differences (Task 3) discrimination was most difficult; when both genetics and bacteria differed (Tasks 1 & 2) discrimination was easier. The easiest discrimination (Task 2) involved the presence of bacteria and a genetic difference at the major histocompatibility complex (MHC) of genes on chromosome 14.},
}

@inproceedings{mcgrath1990sane,
  title = {Is it sane to think of pain on the plane? Answers from the WHO},
  author = {McGrath, Pat},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Pain transmission theories such as the gate control theory have been useful in enhancing our understanding of pain and have legitimized the role of psychological factors in pain. They have not however, provided any guidance to clinicians or researchers in how to assess pain. Because of the lack of an appropriate theoretical model pain assessment has not progressed as much as one of pain assessment that may provide a strategy for advancing pain assessment.},
  note = {QA: abstract-too-short},
}

@inproceedings{wright1990importance,
  title = {Importance of Paternal Care for Pup Survival andDevelopment in Monogamous vs. Poly~nous Mice},
  author = {Wright, S.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {In monogamous species of mammals, males usually show paternal behaviour, while in polygynous species males are not normally parental care on pup development in a monogamous species (P. californicus) and a polygynous species (M. musculus) of mouse. Since paternal care may be shown only when females need to leave the nest, we designed an experiment in which wheel running is necessary to "forage" for food. This 2 x3 mixed factorial experiment has two levels of parental care mixed factorial (male absent vs. male present) and three levels of foraging (wheel running for food; free food plus wheel running; free food and no wheel). We measured litter weight, parental behaviour and number of revolutions run per hour in each group in both the light and dark phase of the L:D cycle. This talk will focus on species differences in pupweight and pup swvival under the six conditions and discuss species differences in paternal care.},
}

@inproceedings{potvin1990neural,
  title = {/---i:A..,~) h'.,-t( Neural and Behavioural Effects of Domoic Acid, an Amnesic Shellfish Toxin, in the Rat l},
  author = {Potvin, James L. and /Qu, S. Nakajima and ~ and l-c-t, ~ Lt},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Among those who were poisoned by shellfish containing domoic acid, 13 persons suffered from varying degrees of memory loss. To study the mechanism of the amnesic effect, domoic acid was injected into the cerebral ventricle of 53 rats. They showed spike discharges in EEG and loss of pyramidal neurons in the hippocampus. They were also impaired in learning a radial-arm maze. In the animals previously trained on the maze task, domoic acid interfered with relearning. The memory deficits following the ingestion of tainted shellfish seem to have resulted from lesions in},
}

@inproceedings{anon1990split,
  title = {Split Personality and Identity Crisis in a Subject with Sensational Legs},
  author = {•, S. R. Shaw},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {If a part of a nervous system can be turned on in two quite distinct ways by the hapless experimenter, how does the onlooker decide which of these two is the proper route to activation? Suggestive comments will be made about one way to arbitrate on this dilemma, while taking a fresh look at a previously misinterpreted neural system. The results indicate provisionally that in order to arouse this subject, a properly pitched word in the ear beats the more traditional hand-on- the-knee approach.},
}

@inproceedings{frankland1990effects,
  title = {Effects of Tonality on Accuracy and Reaction Time in an Intewlated Pitch Memozy Task},
  author = {Frankland, Bradley W. and Cohen, Annabel J.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Three groups of listeners (N = 12) differing in level of musical training (no, low, and high) indicated, on each trial, whether the first (standard) and last (comparison) tone of a five-tone melody were the same or in different pitch. On one-half of the trials, the standard and comparison tone were identical; on the other half the comparison was one semitone higher than the standard. The three middle (interpolated) tones of each five-tone melody formed either a major or minor triad in a key either near to or remote from that of the standard, thus providing four levels of decreasing _ tonality relation with the standard. Accuracy increased and reaction time decreased with increasing tonality relation between the interpolated tones and the standard, producing significant linear trends for both dependent measures. Both measures demonstrated flatter functions for the group which had no formal musical training. These results are consistent with the application of Krumhansl's tonal hierarchy for musically trained listeners. The study also confirms the use of reaction time for measuring the mental representation of melodic structure. (Work supported by NSERC).},
}

@inproceedings{ibeaver1990cortical,
  title = {Cortical Areas Mediatin~ Behavioural Recovro: Followin~ EarlyPeriods of Monocular Deprivation in Kittens},
  author = {I.Beaver, C. and Mitchell, D. E.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Previous work in the laboratory has shown that following termination of 6 weeks of reverse occlusion of kittens that had been monocularly deprived until 6 weeks of age there is a surprising change in the visual acuities of both eyes. Although the visual acuity of the initially deprived eye improves substantially during the period the vision of the eye deteriorates rapidly while that of the initially non-deprived eye regains almost normal acuity. As of yet, the mechanism mediating these changes is still unknown. Lesions of areas 17 and 18 have been carried out to determine the location of the mechanism. Outcomes and their meaning will be discussed.},
}

@inproceedings{durup1990visual,
  title = {Visual Attention Bias in Trait Anxiety},
  author = {Durup, Josette},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {In the last decade there has been a blossoming interest by some cognitive psychologists/researchers investigating information processing models in various affective states. The studies carried out so far have been rather convincing at showing how individuals with various affective states differ from each other and from normals in the way they process information. The differences have been observed at various stages of the information processing continuum, be it at the perceptual, interpretive or recall/response level. This line of research can assist in our understanding of these disorders and may have implications in their treatment. I will talk about an empirical research to investigate biases at the visual attentional/perceptual stage of information processing in high and low trait anxious individuals.},
}

@inproceedings{cohen1990items,
  title = {Items and Orders in Melodic Trackin~: The NeXT Step},
  author = {Cohen, A. and Frankland, B. and Lamoureux, M. and Dunphy, D.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Listeners indicated the serial order of 8 tones in 36 sequences representing all combinations of 4 8- note scales and 9 serial orders. Accuracy was higher for scales with wider frequency ranges, for serial order with simpler contour changes, for sequences in which scale did not vary from trial to trial and for listeners with musical training. These effects are discussed from the perspectives of concatentative versus rule-governed accounts of sequential learning. The experiment also represents successful application of the NeXT computer in a serial tracking task . ------·=:rG=::::.. ..-,,,;asz;:::·},
}

@inproceedings{fentress1990lookmom,
  title = {LookMom! No Malke in Co~itiveland},
  author = {Fentress, John C.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {One of the interesting but poorly explored questions in ethology is how we code behaviour. What features do we attend to, what are our biases, and how do observation profiles emerge during development? In this talk I offer some preliminary explorations. First, a brief comment on work being done with Rita Anderson at Memorial (wolf watching). Secondly, confessions from sabbatical voyeurism at Oregon ("spot" watching). With Mike Posner and Mary Rothbart I scored video tapes of adult and infant attentional movements. Preliminary analyses of "attention runs" suggest parallels to ethological evaluations of patterned animal performance. If McDonnell-Pew cooperates, Posner, Rothbart and I plan to extend this research line.},
}

@inproceedings{goodwin1990role,
  title = {The Role of Expressed Emotion in Relapse of Schizophrenia},
  author = {Goodwin, Joanne},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Research is examining the role of the emotional climate within families of schizophrenics plays in the exacerbation of schizophrenic symptomatology has been ongoing for the past 30 years. Studies in this area have generated a body of literature focusing on the degree of "expressed emotion" (EE) in families, repeatedly finding a strong relationship between high familial EE and the subsequent relapse of schizophrenic members. Despite numerous replications of this effect, the concept of EE continues to provoke controversy. Some recent studies have produced negative results; variability in approach and methodology have served to obscure the nature of the EE effect. Fundamental methodological issues involved in the EE controversy and the current status of the contruct in clinical management of schizophrenia will be presented.},
}

@inproceedings{goldman1990wolf,
  title = {Wolf ear movements: A Measure of Maternal Responsiveness},
  author = {Goldman, Jill A. and Coscia, Elizabeth M. and Fentress, John C.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {We examined communication between a mother wolf and her pups in the den. Previous work has shown that although neonatal pups emit a diverse repetoire of sounds during this period, the mother rarely responds by vocalizing (Coscia, 1989, unpublished). These findings prompted our investigation of pup vocalizations which might elicit other forms of behavioural response. A 180- hour videotape database gave us the opportunity to observe mother and pups' behavioural and vocal activity during the first 5 postnatal weeks. Mother's responses were coded for both ear and body movements. Toe data suggest that most pup vocalizations do not elicit an overt behavioural response. However, the majority of mother's ear movements do occur while the pups are active and vocal. Toe latter has given us reason to believe that the mother's ear movements represent a form of monitoring which is used to decipher which pup vocalizations are acted upon.},
}

@inproceedings{dentremont1990concept,
  title = {Concept Development in Preschoolers},
  author = {D'Entremont, Barbara},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {It has been shown that preschoolers organize their concepts thematically (e.g. dog-bone), but the presence of a novel label biases them to look for a taxonomic relationship (e.g. dog-dog). Fifty- six three-year-old children were tested to determine if a general labeling pretreatment would also bias them to respond taxonomically. A picture was placed in front of the child and they were asked to "find another one that is the same as this one" from a taxonomic, thematic or irrelevant choice. In the novel label conditions, the child was asked to "find another X that is the same as this X", where "X" was a nonsense word. Toe labeling pretreatment consisted of asking the children to label various pictures. Four groups were formed (pretreatment-labeV-no label, no pretreatment- label/-no label). Results showed the novel label group made more taxonomic choices than the no label group only when there was no pretreatment. When there was a pretreatment, the no label group did as well as the novel label group. This supports the argument that language provides a taxonomic constraint on children's interpretation of word meanings.},
}

@inproceedings{braha1990nopain,
  title = {NoPain NoGain: Lookin~ back at Pain.},
  author = {Braha, Richard and McGrath, Pat},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {How ~ood were the ~ains? Treatment strategies for pain abound. Toe efficacy of these strategies is well documented: major review papers tell us this! Unfortunately, most of the reviews are flawed. In ten minutes, I will (1) review problems with the way researchers synthesize knowledge, (2) revive the adage, "garbage in, garbage out"-as it applies to methods of data collapsing, and (3) present a proposal to implement what I have facetiously called, " A Best Evidence Critical Appraisal Meta-Analytic Synthesis"**},
  note = {QA: abstract-too-short},
}

@inproceedings{rusak1990gettin,
  title = {Gettin~ into your Genes: It's not always worth the Fos},
  author = {Rusak, B. and Robertson, H.A. and Wisden, W. and Hunt, S.P.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Last year, we found that light stimuli cause increased levels of the Fos protein to appear in cells in the hamster circadian pacemaker, the suprachiasmatic nucleus. We have since found that this increase results from altered gene expression in response to light input This altered gene expression occurs at the time of day when light can shift the circadian clock, but not at other times of day when light is ineffective in shifting the clock. Toe results imply that altered gene expression is intimately linked to the mechanism that resets the circadian clock. These findings may provide a novel approach to the identification of the genes responsible for running the circadian pacemaker.},
}

@inproceedings{phillips1990timin,
  title = {Timin~ is Transient Stimulus Events by Cortical Auditory Neurons in the Cat},
  author = {Phillips, D. P.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {My lab is engaged in a long-term study of the temporal grain with which the spike activity of auditory cortical neurons can represent the time structure of sounds. Last year, we talked about why these cells are unable to encode, in spike times, stimulis periodicities in excess of about 100 Hz. In this year's presentation, we show that in response to transient stimuli, many cortical cells discharge spikes with a precision in the range from a few hundred migQseconds to a few milliseconds. We show that this response precision can suppon a temporal resolution in the range from about a millisecond to a few tens of milliseconds. Interestingly, this is the grain of temporal processing lost after lesions to the homologous region in man.},
}

@inproceedings{rouse1990ability,
  title = {The Ability of the Rat to Discriminate Human Urine Odours},
  author = {Rouse, Valerie and Brown, Richard},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Genetic differences at the major histocompatability complex (MHC) contribute to individual differences in urine odours of both rats and mice which can be detected in discrimination tasks. Discrimination experiments with dogs have suggested a genetic connibution to human body odours. Operant conditioning techniques were used to determine the ability of rats to discriminate human urine odours from pairs of boys which differed in genetic relatedness: unrelated, brothers, fraternal twins, indentical twins. All animals were able to discriminate between the two odours on all tasks. Analyses revealed no diiference in task difficulty. It was concluded that rats were not attending to genetic cues in the odours but were relearning the discrimination tasks each day based on urine concentration, metabolites in the urine or other variables.},
}

@inproceedings{barresi1990persona,
  title = {Persona Grata: Fragments for a History of the Concept of Person},
  author = {Barresi, John},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The criteria by which personhood is ascribed to an object or being have changed dramatically from primitive through civilized cultures. In the present paper I can only highlight some of the more interesting transformations and try to place them in their historical context},
}

@inproceedings{boyd1990ificance,
  title = {The Si~ificance of Maternal Feedback on Children's Line:µistic Development},
  author = {Boyd, Gisele and Moore, Chris},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {To date, the role of the linguistic environment in facilitating language acquisition is unclear. In an attempt to resolve this issue, the present study examined one particular aspect of input, maternal sensitivity to the grammatically of the child's utterance. The purpose of the present study was two- fold The first issue was to investigate whether mothers provided differential feedback towards their child's grammatical and ungrammatical utterances. The second issue was whether such maternal feedback had any influence on the child's subsequent utterance. Nineteen children were observed with their mothers in naturalistic conditions at two age levels, 24 months of age and 36 months of age. Transcribed conversations between the mother and child were analyzed, and the results indicated that mothers were indeed sensitive to the grammaticality of the child's utterance. In addition, the results suggest that the children were influenced by their mother's immediate feedback and often reformulated their subsequent utterance to reflect this understanding.},
}

@inproceedings{cohen1990musical,
  title = {Musical andVisual ProcessinJi in Film},
  author = {Cohen, Annabel and Dunphy, Debora},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The present study examines whether processing of musical soundtracks exploits general of modality-specific resources. Subjects received either a film + music, film-only or music-only presentation for 20 min and subsequently completed a respective 25-item recognition test. In the film + music test, recognition excerpts were either unchanged, had a new musical track, had a new visual track, were mismatched visual and musical tracks, or were entirely novel. Music-only and film-only tests used one modality from the film+ music test tape. Subjects distinguished old from new material in both modalitites in both single- and double- modality response patterns confirmed that processing film music did not compete for visual resources. Intermodal effects were also apparent.},
}

@inproceedings{klein1990can,
  title = {Can Auditmy Freguency Control the Direction fo Visual Attention?},
  author = {Klein, Raymond and Juckes, Tim},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Tones of fixed frequency (250, 650 and 2500Hz) of frequency glides (900-400Hz and 700- 1200Hz) emanating from straight ahead had no effect on reaction time to luminance targets above or below fixation. This suggests the the phenomenal correspondance between pitch and location does not involved reflexive control of visual orienting mechanisms. Recent studies manipulated the relationship between the direction of the frequency glides and the likelihood of the visual target appearing above or below fixation. The results indicate that subjects can shift their visual attention in the congruent direction within about 500ms while incongruent shifts are not observed with 990ms.},
}

@inproceedings{maryfanner1990comparison,
  title = {A Comparison of the Sequential Processing Abilities of Dyslexic and Normal Readers},
  author = {MaryFanner},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {It has been suggested by Tallal that the phonological difficulties apparent in many dyslexics are in fact symptoms of an underlying deficit in processing rapidly occurring sequential stimuli. Perception of spoken language is particularly vulnerable to such a deficit, because many of the component sounds in speech involve rapid spectral changes over time periods in the tens of milliseconds range. It is proposed to assess the rapid sequential processing ability of adolescent dyslexics, using auditory, visual, and motor sequencing tasks. The dyslexics' performance on all tasks will be compared to that of both age-matched and reading-level matched normal readers of equivalent intelligence.},
}

@inproceedings{ryan1990effects,
  title = {The Effects of Y ohimbine on the Copulat01y Behaviour of Older Male Rats},
  author = {Ryan, C.L. and Brown, R. E.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The present study was designed to determine whether age related deficits in copulatory behaviour in male rats could be reversed by the alpha 2 antagonist, yohimbine, a reported aphrodisiac. An acute dose of yohimbine was administered to eight 15 month old male rats, who had previously demonstrated deficits in copulatory behaviour compared to that of eight 6-8 month old male rats. The copulatory behaviour was assessed in a 20 minute trial with a receptive female. Y ohimbine altered copulatory performance and tended to shift the behaviour of the older males towards that of the younger age performance. The drug also caused a decrease in 22kHz post ejaculatory vocalizations. This may reflect changing arousal levels or a specific effect of the drug on ultrasonic vocalizations.},
}

@inproceedings{droungas1990search,
  title = {In Search of Parametres that Yield a Pure Explicitly Unpaired Safety Si!iDal},
  author = {Droungas, Anastasia and LoLordo, Vincent M.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {As a result of Pavlovian Explicity Unpaired (EUP) conditioning, whereby a CS and shock US occur on separate trials, the CS becomes a safety signal. We have shown that a CS trained with a variant of not the EUP procedure ( a brief CS singly alternated with shock with a short intertrial interval) functioned both as a safety signal AND as a fearful stimulus. We argued that the CS functioned as a safety signal because, during conditioning, it was negatively correlated with shock; and as fearful stimulus because, during conditioning, it was associated with the fearful conditioning context. The current experiment explored parametric variations of EUP aiming at establishing conditions which will yield a "pure" EUP safety signal.},
}

@inproceedings{pontefract1990search,
  title = {In Search of Inhibition of Return},
  author = {Pontefract, Amanda},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Events in the visual field often attract attention as indicated by a nearly immediate facilitation for the processing of nearby stimuli. In contrast, Posner and Cohen discoverd a delayed inhibitory effect which begins about 300 ms after a visual event if attention is not maintained at the location of that event. This phenomenon, known as "inhibition of return", serves to decrease the probability that attention retwns to a previously attended location. This talk will focus on the experimental conditions necessary for producing this inhibitory effect},
}

@inproceedings{honig1990numerosity,
  title = {Numerosity as a Perceptual Continuum: Howto ~et by WithoutActually Countin~},
  author = {Honig, Vern and Stewart, Karen},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Cognitive and developmental psychologists are preoccupied with counting, especially of smaller numbers, perhaps up to the "Magical Number Seven". This may be due to the fact that people can "subcept" such numbers and count them even after a brief presentation. As a result, many animal psychologists concentrate on counting with small numbers as well. We have data that show that pigeons can discriminate among small numbers of elements in the way that they typically do among different values on other sensory continua: They provide orderly gradients of discrimination, for example, with 2+, 3+, 4+, 5-, 6- and 7-. They cannot however, respond differentially to adjacent small numeroisty values, such as 2+, 3-, 4+ and 5-.},
}

@inproceedings{brandstatter1990floatin,
  title = {Floatin~ Synapses},
  author = {Brandstatter, J.H. and Meinertzhagen, I. A. and Shaw, S. R.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {In a continuation of last year's project-the disassembly of afferent photoreceptor synapses following photo-degeneration-we have examined the effects of the loss of receptor terminals on a second major class of synapses in the lamina of the fly's eye, the feedback synapses of one of the monopolar cells, L2, back upon the receptor terminal. A first and for us, very surprising finding was the presence of "floating synapses", presynaptic ribbons separated from their membrane sites by invagination to form an organelle that is free floating in the cytoplasm of the L2 axon. These floating synapses seem to be a degradation product of feedback synapses. Despite this loss, we found no decrease in synaptic fequency, but an increase attaining a twofold value of 8d, suggesting the occurrence of reactive synaptogenesis. L -=},
}

@inproceedings{klein1990orientatingo,
  title = {Orientatingof Visual Attention},
  author = {Klein, Ray},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Percpetion of a visual scene can be spatially selective in two senses. First,~ adjustments of gaze direction can be made to control which regions of the visual field are processed by the sensitive fovea and its associated neural machinery. Second,~ adjustments can be made in which specific objects or regions are selected ( in the absence of gaze changes) for preferential treatment. Overt and covert visual orienting can be controlled exon~nously by features of the visual scene as well as endo&enously by the observer's expectations and intentions. Imagine the 2x2 matrix implied by this classification. In this talk I will concentrate on the cells representing endogenous and exogenous control are quite different. This might be interpreted to imply that two different attentional systems are involved. Alternatively, a single attentional system might bring different resources or strategies to bear depending on the nature of the control signal.},
  note = {QA: abstract-too-short},
}

@inproceedings{oregan1990reinforcin,
  title = {Reinforcin~ Characteristics of Brain Stimulation Altered by Rece.ptor:=Specific Dopamine A~nists and Anta~onists},
  author = {O'Regan, Noel B. and Nakajima, S.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The involvement of dopaminergic system to the generation of the reinforcing effect of brain stimulation was examined. Eight rats were trained to press a bar for hypothalamic stimulation and injected intraperitoneally with agonists and anatagonists selective to either D 1 or D2 subtypes of dopamine receptors. Quinpirole (D2 agonist) reduced the threshold for self-stimulation while raclopride (D2 antagonist) and SCH 23390 (Dl antagonist) increased it. SKF 38393 (Dl agonist) and physiological saline solution had no effect These results suggest a critical involvement of dopaminergic system with D2 as well as Dl receptors in the reinforcing effect of brain stimulation.},
}

@inproceedings{mitchell1990reco,
  title = {Reco~nition of Videotape Sports; Coaches andPlayers Compared},
  author = {Mitchell, D. and Ozier, M. and McCabe, J.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Expert and novice coaches and players were presented 5-second samples of a ten-minute video exerpt of a basketball game they had seen, along with samples taken from elsewhere in the same game. The samples were of three types: moving samples, still photos of the video material, or still photos taken from a view point different to the video. The subjects' task was to indicate whether the sample had occurred in the ten-minute video or not The results indicated that coaches were more able to recognize the samples than were the players, and that three types of display differed in difficulty, the moving displays being recognized by all groups better than the stills.},
}

@inproceedings{bina1990daily,
  title = {Daily Variation in Muscarinic Bindin~ Sites in the Cortex andHypothalamus of Golden Hamsters},
  author = {Bina, K. G. and Wilkinson, M. and Rusak, B.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Circadian variation in the binding of (3H)N-methyl scopolamine ((3H)NMS), a hydrophylic muscarinic receptor antagonist was studied in the hypothalamus and cortex of the Golden Hamster (Mesocricetus auratus) using a novel micropunch technique which selectively detects only cell surface receptors. Intact and suprachiasmatic nucleus abated (SCNX) animals maintained in light dark cycle (LD) 14:10 were killed every four hours starting at lights on and binding assays performed on hypothalamus and the cortex. Binding assays were also performed on intact animals maintained in constant darkness (DD) every four hours starting at circadian time (CT) 0. The intact LD animals showed a significant daily rhythm in (3H)NMS binding in the cortex with highs occurring 12 hours after lights on and lows at lights on. No significant rhythm was detected in the hypothalamus. The rhythm in the cortex was abolished in the SCN-ablated animals and in animals maintained in DD. The data suggest that photic information mediated through the SCN or the pacemaker property of the SCN is responsible for this rhythm. Autoradiography ((3H)NMS; 2nM, 3 weeks exposure) clearly revealed specific binding in the SCN and surrounding  periventricular region. '#::::'.'. Cathy Ryan and Richard Brown ~ Mcxiification of Neonatal lTitrasonic Vocalizations in Rats by Adrenergic Drugs There is some confusion regarding the role of the noradrenergic (NA) system in regulating neonatal rodent ultrasonic vocalizations (UV). We decided to systematically investigate the role of NA in the production of these infant distress vocalizations. Hooded rat pups received a single injection of one of four adrenergic drugs: propanolol, yohimbine, prazosin, or clonidine at 4, 8, 12, or 16 days of age. With the exception of clonidine, all drugs depressed isolation induced UV. Clonidine enhanced vocalizations with its effects on UV being age-dependent The role of the NA system in the manifestation of these findings.},
}

@inproceedings{brown1990twenty,
  title = {Twenty years a rat-man:Searching for a Common Thread Amon~theTan~led Web of My Research},
  author = {Brown, Richard},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {My research on animal social behaviour has been organized over the last 20 years by a series of planned experiments, accidental encounters, serendipidous results and late nights in the pub. In this talk I will attempt to illustrate the common thread in a tangled web of experiments on sexual behaviour, aggression, parental behaviour, olfactory communication, ultrasonic vocalizations, sexual differentiation, hormonal stimulation, developmental differences, mate recognition, behaviour genetics and operant conditioning. The results will examine the characters, setting and, possibly the solution to the elusive question "What am I doing here?". -=-=--},
}

@inproceedings{moore1990mentalstatel,
  title = {MentalstateLan~a~ in Mother-ChildCommunication},
  author = {Moore, Chris and Furrow, David and Chiasson, Lorraine},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The acquisition of a mental state language has been assigned some significance in the development of a theory of mind. For example, Olson ( 1988) has argued that without means of representing such attitudes, the child would never be able to acquire and understanding of propositional attitudes. However, little is known about the conditions under which mental state language is acquired. In this paper, we report data from a longitudinal study of 19 mother-child pairs in communication when the child was 2 and 3 years of age. All occurrences of maternal and child utterances containing a mental term were coded for function. The results show that while the overall use of mental terms by the mother when the child was 2 years correlated with the child's use at 3 years, particular maternal functions appeared to be especially important. Specifically, mothers who used mental terms in open-ended directives to their children at 2 years has children who used mental terms more at 3 years. We argue that mother's use of open-ended directives serves to direct their children's thought rather than action, and that such direction is important for fostering a sensitivity on the pan of the child to the existence of mental life.},
}

@inproceedings{kingstone1990express,
  title = {Express Saccades},
  author = {Kingstone, Alan and Klein, Raymond},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Fischer and colleagues (e.g Fischer and Breitmeyer, 1987; Fischer and Ramsperger, 1984) have reported that human eye movement latencies to a peripheral target are unusually brief (lOOms - 120ms) when a fixation point is removed shortly before target onset This new phenomenon is called 'express saccades'. It has also been reported that it is not the offset of the fixation stimulus per se that permits express saccades, but rather the offset of any stimulus ( even a parafoveal one) that is attended. This observation appears to provide a strong link between attention and the eye movement system: attention must be disengaged before a saccade can be inititated. But the conclusion is questionable since the studies which 'manipulated' attention told subjects to attend to a peripheral stimulus without providing any objective evidence that this instruction was followed. We report a series of experiments which confirm the express saccade phenomenon, explore variables such as temporal spatial (un)certainty which may mediate the effect, and examine the role that attention may play in its occurrence.},
}

@inproceedings{yoon1990bilateral,
  title = {Bilateral Ablation of the Forebrain Enhances the Optomotor Res,ponses in Goldfish},
  author = {Yoon, M. G.},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The topographic pattern of visual projection from the eye to the brain in goldfish can be experimentally induced to undergo two types of dramatic reorganizations: (1) the filed compression following partial excision of the optic tectal lobe, and (2) the retention of original topographic polarity by tectal tissue following reimplantation after 180 rotation. We study the functional significance of these two types of neural reorganization in the goldfish by various behavioural tests. One of the innate visual behaviours we use is the optomotor response. It is not easy to elicite a reliable optomotor response to a well localized moving stimulus in normal goldfish. About two weeks after bilateral ablation of the forebrain in goldfish, however, we find that the operated fish tend to follow the moving visual target with remarkably enhanced consistency. Thus, the forbrain seems to exert a distracting influence on the optomotor response generating mechanism in normal goldfish.},
}

@inproceedings{juckes1990mindis,
  title = {A "We" Mindis Bi~~r and Better <:},
  author = {Juckes, Tim and Barresi, John},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {Individualism has produced a psychology which givesi~torical and@.#ial explanatioiof the mind. A non-individualist ontology, grounded in the social relations between individuals and mediated to individuals through social practices (e.g., language), is developed. Wittgenstein's rejection of individualism through his remarks on rules and private language are reviewed. In response to the popularity of mind-brain supervenience models, Burge's counterfactual example of "arthritis" on Earth and twin-Earth is used to show that different mental states are possible when identical brains exist. It is argued that the language--or more broadly, the social relations--of a given community must be used to determine the mental state of an individual.},
}

@inproceedings{moore1990theorv,
  title = {Theorv of Mind in Autismand Psychwathy},
  author = {Moore, Chris and Barresi, John},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {In this paper, we suggest that two psychopathological syndromes may represent a double dissociation of two components of a theory of mind. Recent work of autism has shown that autistics do not show protodeclarative communicative acts, which have been assumed to index the initial stages of the capacity for representation. Austistics do, however, produce and comprehend protoimperatives communicative acts, which indicate the expression of emotional states of desires. Psychopaths do appear to recognize the existence of belief states in themselves and others. However, current theortical work on psychopathy suggests that the primary problem in psychopaths is a lack of intense emotional states. This deficit prevents the psychopath from experiencing through empathy the emotional states of others and of self across time. They are thus unable to construct a concept of desire. This account predicts that there will be a subgroup of conduct disordered children who, while performing essentially normally on belief tasks, will show particulary difficulty with tasks assessing the understanding of desire.},
}

@inproceedings{abe1990revolutionaz,
  title = {Revolutionazy DietPlan: SlimDownandGetEntrained! Applesauce},
  author = {Abe, Hiroshi and Rusak, Benjamin},
  booktitle = {Sixteenth Annual In-House Convention, Department of Psychology, Dalhousie University},
  year = {1990},
  abstract = {The circadian system of hamsters does not typically become synchronized (entrained) to daily presentations even of a highly preferred, palatable diet We asked whether hunger would potentiate the effects of daily.Je~ing schedules on the circadian system. When hamsters' body weights were reduced to 80-,S~,,,% of free-feeding weights, many hamsters showed clear anticipatory increases in activity before the daily feeding times. Some hamsters also showed entrainment on their freerunning circadian rhythms to these schedules. The results suggest that in an appropriate motivational state, hamsters can be entrained by non-photic cues acting directly or indirectly on the circadian pacemaker.},
}

